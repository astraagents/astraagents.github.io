"Supported by Novikov & Copley (2013, PNAS); hydrothermal mineral-catalyzed carbon fixation gives rise to \u03b1-ketoacids."}, {"id": "rxn_010", "name": "Transamination of pyruvate with pyridoxal cofactor and metal catalyst", "inputs": ["mol_007", "mol_013", "mol_005"], "outputs": ["mol_009", "mol_014"], "environment": "Biochemical", "agents": ["Fe3+", "pyridoxal"], "conditions": {"temperature": "340-350K (75\u00b0C)", "pressure": "1 atm", "catalyst": "pyridoxal + Fe3+", "aqueous": true, "other": "mildly acidic to neutral pH 5-7.5"}, "mechanism": "Pyruvate forms a Schiff base (imine) with pyridoxal, then ammonia provides nitrogen, and Fe3+ accelerates the process. Release of alanine regenerates pyridoxamine.", "reasoning": "Dherbassy et al. (2023, JACS); Schlikker et al. (2024, FEBS J.), combining demonstrated acceleration by metal-pyridoxal co-catalysis."}, {"id": "rxn_011", "name": "Pyridoxal reduction to pyridoxamine on Ni0 and H2", "inputs": ["mol_013", "mol_005", "mol_003", "mol_017"], "outputs": ["mol_014"], "environment": "Hydrothermal", "agents": ["native nickel"], "conditions": {"temperature": "353K (80\u00b0C)", "pressure": "5 bar H2", "catalyst": "Ni0", "aqueous": true, "other": "pH 11"}, "mechanism": "Ni0-catalyzed reduction of pyridoxal in the presence of ammonia and H2 generates pyridoxamine.", "reasoning": "Schlikker et al. (2024, FEBS J.); shown to proceed efficiently in vent-analog conditions, supports subsequent transamination."}, {"id": "rxn_012", "name": "Imine (Schiff base) formation from acetaldehyde and ammonia", "inputs": ["mol_004", "mol_005"], "outputs": ["mol_012"], "environment": "Biochemical", "agents": ["null"], "conditions": {"temperature": "300-320K", "pressure": "1 atm", "catalyst": null, "aqueous": true, "other": "equilibrium step"}, "mechanism": "Nucleophilic addition of ammonia to acetaldehyde yields the corresponding imine.", "reasoning": "Universal step in Strecker and imine-based proto-biocatalysis; mechanistic necessity in all alanine Strecker variants (see Green et al., 2023, JACS)."}], "pathways": [{"pathway_id": "P1", "name": "Acetylene/CO \u2192 acetaldehyde \u2192 Strecker \u2192 alanine", "description": "Hydrothermal acetaldehyde generation from acetylene and CO, followed by surface Strecker aminonitrile chemistry, and aqueous hydrolysis to alanine.", "reaction_sequence": ["rxn_001", "rxn_002", "rxn_003"], "key_intermediates": ["mol_004", "mol_008"]}, {"pathway_id": "P2", "name": "Hydrothermal pyruvate \u2192 iron oxyhydroxide-catalyzed alanine", "description": "Pyruvate generated hydrothermally is reductively aminated using mixed valent iron oxyhydroxide, yielding alanine as main product.", "reaction_sequence": ["rxn_009", "rxn_004"], "key_intermediates": ["mol_007"]}, {"pathway_id": "P3", "name": "Native nickel-catalyzed pyruvate reductive amination", "description": "Pyruvate is reductively aminated to alanine at mild conditions using Ni0/H2 catalytic chemistry.", "reaction_sequence": ["rxn_009", "rxn_005"], "key_intermediates": ["mol_007"]}, {"pathway_id": "P4", "name": "Ferocyanide-reservoir cyanide Strecker", "description": "Cyanide from a ferrocyanide reservoir supports Strecker aminonitrile synthesis and subsequent hydrolysis to alanine.", "reaction_sequence": ["rxn_001", "rxn_006", "rxn_003"], "key_intermediates": ["mol_004", "mol_008"]}, {"pathway_id": "P5", "name": "Formamide-rich aminonitrile stabilization (protection/hydrolysis sequence)", "description": "Aminonitriles formed from Strecker synthesis are stabilized in formamide-rich pools before hydrolysis to yield alanine.", "reaction_sequence": ["rxn_002", "rxn_007", "rxn_003"], "key_intermediates": ["mol_008"]}, {"pathway_id": "P6", "name": "Atmospheric discharge (Miller\u2013Urey-type) direct alanine synthesis", "description": "Amino acids (including alanine) generated by atmospheric spark discharge of simple gases, with intermediates including acetaldehyde and HCN funneled into Strecker networks.", "reaction_sequence": ["rxn_008", "rxn_003"], "key_intermediates": ["mol_009"]}, {"pathway_id": "P7", "name": "Pyruvate\u2013Schiff base imine\u2013hydrolysis\u2013alanine (via 'prebiotic imine' intermediates)", "description": "Pyruvate generated hydrothermally forms an imine with ammonia or via biochemical intermediates, which then hydrolyzes or is reduced to alanine.", "reaction_sequence": ["rxn_009", "rxn_012", "rxn_003"], "key_intermediates": ["mol_012"]}, {"pathway_id": "P8", "name": "Pyruvate formation from CO2 + acetaldehyde (convergent hub pathway)", "description": "Cross-environmental delivery, where pyruvate can be formed from acetaldehyde, CO2, and H2 on vent minerals, then fed into various alanine-forming routes.", "reaction_sequence": ["rxn_001", "rxn_009", "rxn_004"], "key_intermediates": ["mol_004", "mol_007"]}, {"pathway_id": "P9", "name": "Pyruvate transamination with pyridoxal and Fe3+", "description": "Pyruvate is converted to alanine via proto-biochemical transamination catalyzed by pyridoxal (vitamin B6-like) and Fe3+ ions.", "reaction_sequence": ["rxn_009", "rxn_010"], "key_intermediates": ["mol_007", "mol_013"]}, {"pathway_id": "P10", "name": "Pyridoxal reduction in vent settings, followed by transamination", "description": "Pyridoxal is reduced to pyridoxamine via Ni0 and H2 in vent-like conditions; this activates transamination whereby pyruvate is converted to alanine in the presence of the cofactor.", "reaction_sequence": ["rxn_011", "rxn_010"], "key_intermediates": ["mol_013", "mol_014"]}], "hub_molecules": ["mol_004", "mol_007", "mol_008", "mol_012", "mol_013"], "convergence_points": [{"molecule_id": "mol_004", "incoming_reactions": ["rxn_001", "rxn_008"], "outgoing_reactions": ["rxn_002", "rxn_006", "rxn_009", "rxn_012"]}, {"molecule_id": "mol_007", "incoming_reactions": ["rxn_009"], "outgoing_reactions": ["rxn_004", "rxn_005", "rxn_010", "rxn_012"]}, {"molecule_id": "mol_008", "incoming_reactions": ["rxn_002", "rxn_006", "rxn_007"], "outgoing_reactions":
": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"Acetylene/CO hydrothermal acetaldehyde formation\",\n      \"inputs\": [\"mol_001\", \"mol_002\", \"mol_003\"],\n      \"outputs\": [\"mol_004\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"nickel sulfide (NiS)\", \"FeS\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"NiS, FeS\",\n        \"aqueous\": true,\n        \"other\": \"vent-analog alkaline environment\"\n      },\n      \"mechanism\": \"Hydrothermal reduction and coupling of acetylene and CO to generate acetaldehyde via metal-sulfide catalysis.\",\n      \"reasoning\": \"Directly cited: Diederich et al. (2023, PNAS); acetaldehyde generated by acetylene/CO net chemistry on NiS/FeS minerals under hydrothermal vent condition (see o3-deep-research).\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Strecker synthesis of alanine aminonitrile from acetaldehyde\",\n      \"inputs\": [\"mol_004\", \"mol_005\", \"mol_006\"],\n      \"outputs\": [\"mol_008\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"null\"],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite clay\",\n        \"aqueous\": true,\n        \"other\": \"concentrating wet-dry cycles, near-neutral to basic pH\"\n      },\n      \"mechanism\": \"Aldehyde reacts with ammonia to form imine; HCN or cyanide adds to form alanine aminonitrile.\",\n      \"reasoning\": \"Canonical Strecker pathway; supported by Green et al. (2023, JACS), Diederich et al. (2023, PNAS), and classic Strecker context (see o3-deep-research).\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Hydrolysis of alanine aminonitrile to alanine\",\n      \"inputs\": [\"mol
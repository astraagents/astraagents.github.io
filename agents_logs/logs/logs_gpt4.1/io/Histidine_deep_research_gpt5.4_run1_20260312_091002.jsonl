sible per prebiotic models."}, {"id": "rxn_010", "name": "Carbohydrate + Ammonia + Zinc Hydroxide to 4-Methylimidazole", "inputs": ["mol_001", "mol_004"], "outputs": ["mol_013"], "environment": "Surface", "agents": ["zinc hydroxide"], "conditions": {"temperature": "373K (100\u00b0C)", "pressure": "ambient", "catalyst": "zinc hydroxide", "aqueous": true, "other": "Extended warming"}, "mechanism": "Dehydration and ring closure of carbohydrate and ammonia catalyzed by metal hydroxide.", "reasoning": "Or\u00f3 et al., 1984, Origins of Life; product identification and mineral catalysis validated."}, {"id": "rxn_011", "name": "Aldehyde + Ammonia to Imidazole Pool", "inputs": ["mol_011", "mol_004"], "outputs": ["mol_014"], "environment": "Surface", "agents": ["montmorillonite", "zinc hydroxide"], "conditions": {"temperature": "330-370K", "pressure": "ambient", "catalyst": "montmorillonite, zinc hydroxide", "aqueous": true, "other": "Ring closure, wet-dry cycling"}, "mechanism": "Small aldehydes condense and cyclize with ammonia to form imidazole ring.", "reasoning": "Or\u00f3 et al., 1984, imidazole pool formation; plausible prebiotic ring-closure route."}, {"id": "rxn_012", "name": "Spark Discharge in Ammonia-rich Aqueous Environment generates Histidine", "inputs": ["mol_003", "mol_004", "mol_005"], "outputs": ["mol_010"], "environment": "Surface", "agents": ["montmorillonite"], "conditions": {"temperature": "ambient to boiling", "pressure": "up to 1.5 bar", "catalyst": "montmorillonite", "aqueous": true, "other": "Spark discharge, plasma conditions"}, "mechanism": "Energy input induces amino acid formation, including histidine, via complex network.", "reasoning": "Turse et al., 2013, Life (Basel); histidine detected in spark discharge, but pathway is non-specific."}], "pathways": [{"pathway_id": "P1", "name": "Shen Pathway (Erythrose + Formamidine)", "description": "Classic staged route: HCN forms glycolaldehyde/glyceraldehyde; aldol gives erythrose; erythrose + formamidine yields imidazole-4-glycol/acetaldehyde, which undergoes Strecker and hydrolysis to histidine.", "reaction_sequence": ["rxn_004", "rxn_003", "rxn_001", "rxn_007", "rxn_009"], "key_intermediates": ["mol_001", "mol_006", "mol_008"]}, {"pathway_id": "P2", "name": "Erythrose + Formaldehyde + Ammonia Route", "description": "Erythrose plus formaldehyde and ammonia generates imidazole-4-ethanol/glycol, then oxidation/dehydration yields imidazole-4-acetaldehyde, proceeding to Strecker and hydrolysis.", "reaction_sequence": ["rxn_004", "rxn_003", "rxn_002", "rxn_006", "rxn_007", "rxn_009"], "key_intermediates": ["mol_007", "mol_006", "mol_008"]}, {"pathway_id": "P3", "name": "Imidazole-4-Glycol Branch", "description": "HCN \u2192 sugars \u2192 erythrose \u2192 imidazole-4-glycol \u2192 dehydration/oxidation \u2192 imidazole-4-acetaldehyde \u2192 Strecker \u2192 histidine.", "reaction_sequence": ["rxn_004", "rxn_003", "rxn_001", "rxn_005", "rxn_007", "rxn_009"], "key_intermediates": ["mol_006", "mol_008"]}, {"pathway_id": "P4", "name": "Imidazole-4-Ethanol Branch", "description": "Erythrose + formaldehyde + ammonia \u2192 imidazole-4-ethanol \u2192 oxidation \u2192 imidazole-4-acetaldehyde \u2192 Strecker \u2192 histidine.", "reaction_sequence": ["rxn_004", "rxn_003", "rxn_002", "rxn_006", "rxn_007", "rxn_009"], "key_intermediates": ["mol_007", "mol_008"]}, {"pathway_id": "P5", "name": "Phosphoro-Strecker (neutral pH)", "description": "Classic pathways converge on imidazole-4-acetaldehyde, then phosphate-coupled Strecker yields aminonitrile, hydrolyzed to histidine.", "reaction_sequence": ["rxn_004", "rxn_003", "rxn_001", "rxn_005", "rxn_008", "rxn_009"], "key_intermediates": ["mol_015", "mol_008"]}, {"pathway_id": "P6", "name": "Carbohydrate + Ammonia Route (Or\u00f3/Imidazole Pool)", "description": "Carbohydrate + ammonia generates methyl-imidazole or imidazole; side-chain functionalization by condensation eventually yields histidine via Strecker network.", "reaction_seq
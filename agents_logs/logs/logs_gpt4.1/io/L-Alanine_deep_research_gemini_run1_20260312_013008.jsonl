le\": \"hub_intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_010\",\n      \"formula\": \"C3H6N2\",\n      \"iupac_name\": \"2-aminopropanenitrile\",\n      \"common_name\": \"Strecker alanine nitrile\",\n      \"inchi\": \"InChI=1S/C3H6N2/c1-3(5)2-4/h3,5H,1H3\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_011\",\n      \"formula\": \"C3H7NO2\",\n      \"iupac_name\": \"(S)-2-aminopropanoic acid\",\n      \"common_name\": \"L-Alanine\",\n      \"inchi\": \"InChI=1S/C3H7NO2/c1-2(4)3(5)6/h2H,4H2,1H3,(H,5,6)/t2-/m0/s1\",\n      \"role\": \"target\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_012\",\n      \"formula\": \"C3H7NO3\",\n      \"iupac_name\": \"L-serine\",\n      \"common_name\": \"L-serine\",\n      \"inchi\": \"InChI=1S/C3H7NO3/c1-2(4)3(5)6/h2H,4H2,1H3,(H,5,6)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_013\",\n      \"formula\": \"C3H7NO2\",\n      \"iupac_name\": \"D-alanine\",\n      \"common_name\": \"D-alanine\",\n      \"inchi\": \"InChI=1S/C3H7NO2/c1-2(4)3(5)6/h2H,4H2,1H3,(H,5,6)/t2-/m1/s1\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_014\",\n      \"formula\": \"HCONH2\",\n      \"iupac_name\": \"methanamide\",\n      \"common_name\": \"formamide\",\n      \"inchi\": \"InChI=1S/CH3NO/c1-2/h1H,(H2,2)\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_015\",\n      \"formula\": \"H2S\",\n      \"iupac_name\": \"hydrogen sulfide\",\n      \"common_name\": \"hydrogen sulfide\",\n      \"inchi\": \"InChI=1S/H2S/h1H2\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Surface\"\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"Miller-Urey Spark Discharge Synthesis (Alanine/Racemic Amino Acids)\",\n      \"inputs\": [\"mol_001\", \"mol_002\", \"mol_003\"],\n      \"outputs\": [\"mol_004\", \"mol_005\", \"mol_011\", \"mol_013\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"Montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"Montmorillonite\",\n        \"aqueous\": true,\n        \"other\": \"Electrical discharge, reducing atmosphere\"\n      },\n      \"mechanism\": \"Electric spark discharges in a methane-ammonia-water mixture create high-energy radicals, leading to the formation of HCN, acetaldehyde, and amino acids via chain reactions and subsequent condensation.\",\n      \"reasoning\": \"Classical Miller (1953, 1955), Parker et al. (2011): Comprehensive amino acid formation seen in original and subsequent spark discharge experiments under simulated early Earth conditions.\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Strecker Synthesis of Alanine from Acetaldehyde\",\n      \"inputs\": [\"mol_005\", \"mol_002\", \"mol_004\"],\n      \"outputs\": [\"mol_010\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"Montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"Montmorillonite\",\n        \"aqueous\": true,\n        \"other\": \"Neutral to slightly alkaline pH\"\n      },\n      \"mechanism\": \"Stepwise imine formation, nucleophilic addition of cyanide ion, and condensation yields 2-aminopropanenitrile.\",\n      \"reasoning\": \"Miller (1957), Kasting (2013), Or\u00f3 (1960): Strecker mechanism is dominant pathway for prebiotic alanine, observed in meteorites; see also input from Sutherland et al. (2015).\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Hydrolysis of 2-Aminopropanenitrile to Racemic Alanine\",\n      \"inputs\": [\"mol_010\", \"mol_003\"],\n      \"outputs\": [\"mol_011\", \"mol_013\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"Montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"Montmorillonite\",\n        \"aqueous\": true,\n        \"other\": \"Long timescale; partial conversion\"\n      },\n      \"mechanism\": \"Acid or base-promoted hydrolysis of the nitrile group followed by amide hydrolysis yields alanine.\",\n      \"reasoning\": \"Miller (1957), Bernstein et al. (2002), Powner et al. (2010): Nitrile hydrolysis is a well-established route to amino acids, both in lab and meteoritic contexts.\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"Cyanosulfidic Synthesis (UV/H2S/HCN, Sutherland Systems Chemistry)\",\n      \"inputs\": [\"mol_004\", \"mol_015\", \"mol_003\"],\n      \"outputs\": [\"mol_005\", \"mol_010\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2\", \"Cu(I)/Cu(II)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"TiO2, Cu ions\",\n        \"aqueous\": true,\n        \"other\": \"UV irradiation\"\n      },\n      \"mechanism\": \"Photoredox-driven homologation of HCN leads to C2/C3 aldehydes and amino nitrile intermediates with H2S as a reductant.\",\n      \"reasoning\": \"Patel et al. (2015, Nature Chemistry), Sutherland (2016): UV-catalyzed cyanosulfidic chemistry simultaneously produces amino acid and nucleotide precursors via shared intermediates.\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"Hydrothermal CO2 Fixation to Pyruvate\",\n      \"inputs\": [\"mol_001\", \"mol_003\"],\n      \"outputs\": [\"mol_009\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"Greigite\", \"Pyrite\"],\n      \"conditions\": {\n        \"temperature\": \"350-450K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"Greigite, Pyrite\",\n        \"aqueous\": true,\n        \"other\": \"Redox gradients present\"\n      },\n      \"mechanism\": \"Greigite- and pyrite-catalyzed reduction of CO2 and methyl groups leads to formation of pyruvate via serial H-abstractions.\",\n      \"reasoning\": \"Barge et al. (2019, Nature Ecology & Evolution), Huber & W\u00e4chtersh\u00e4user (1997), Cody (2000): Pyruvate formation in iron-sulfur hydrothermal systems is an experimentally validated route.\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"Reductive Amination of Pyruvate to Alanine (Hydrothermal Ammonia Source)\",\n      \"inputs\": [\"mol_009\", \"mol_002\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"Green Rust (Fougerite)\", \"Pyrite\"],\n      \"conditions\": {\n        \"temperature\": \"343-373K\",\n        \"pressure\": \"moderate/high\",\n        \"catalyst\": \"Green Rust (1:1 Fe2+/Fe3+), Pyrite\",\n        \"aqueous\": true,\n        \"other\": \"Alkaline (pH 9-11), vent interface\"\n      },\n      \"mechanism\": \"Ammonia reacts with pyruvate, facilitated by electron transfer on iron oxide surfaces, yielding alanine.\",\n      \"reasoning\": \"Preiner et al. (2020, PNAS), Barge et al. (2019), W\u00e4chtersh\u00e4user (1990): Green rust and pyrite catalyze robust amination of pyruvate under vent conditions.\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Formamide Proton Irradiation: Alanine & Nitrile Synthesis\",\n      \"inputs\": [\"mol_014\"],\n      \"outputs\": [\"mol_011\", \"mol_005\", \"mol_010\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"Meteorite minerals\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"Meteorite powder\",\n        \"aqueous\": true,\n        \"other\": \"Proton irradiation (solar simulation)\"\n      },\n      \"mechanism\": \"Proton irradiation of formamide in presence of meteoritic minerals yields amino acids, nucleobases, and nitrile intermediates.\",\n      \"reasoning\": \"Saladino et al. (2011, PNAS): Experimentally produces alanine, acetaldehyde, and Strecker intermediates under exogenous irradiation.\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Surface Chiral Selection on Pyrite (D/L Preference)\",\n      \"inputs\": [\"mol_011\", \"mol_013\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"Pyrite\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"Pyrite\",\n        \"aqueous\": false,\n        \"other\": \"UV irradiation\"\n      },\n      \"mechanism\": \"Asymmetric adsorption or photodecomposition on the chiral surface leads to enrichment of one enantiomer.\",\n      \"reasoning\": \"Bonner et al. (2000), Hazen et al. (2001): Pyrite surfaces exhibit natural enantioselectivity, amplifying alanine chirality in prebiotic scenarios.\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"Wet-Dry Cycling: Alanine Polymerization and Concentration\",\n      \"inputs\": [\"mol_011\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"Montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"320-370K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"Montmorillonite\",\n        \"aqueous\": false,\n        \"other\": \"Wet-dry (desiccation/rehydration) cycles\"\n      },\n      \"mechanism\": \"Cycles of dehydration and rehydration on clay surfaces drive the condensation and selection, enabling alanine accumulation and occasional peptide formation.\",\n      \"reasoning\": \"Lahav & Chang (1976), Orgel (1987): Clays concentrate and polymerize amino acids during prebiotic wet-dry cycles, as validated in laboratory models.\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"Transamination of Pyruvate (Serine/Glycine Route)\",\n      \"inputs\": [\"mol_009\", \"mol_012\", \"mol_002\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"Montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"Montmorillonite\",\n        \"aqueous\": true,\n        \"other\": \"pH 7-9\"\n      },\n      \"mechanism\": \"Amino transfer from serine or glycine to the keto group of pyruvate yields alanine.\",\n      \"reasoning\": \"Kawamura & Konno (1961), Mita et al. (2016): Experimentally established as a plausible prebiotic amination step facilitated by mineral or small dipeptide co-factors.\"\n    },\n    {\n      \"id\": \"rxn_011\",\n      \"name\": \"Exogenous Alanine Delivery (Meteorite Parent Body Aqueous Alteration)\",\n      \"inputs\": [],\n      \"outputs\": [\"mol_011\", \"mol_010\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"Phyllosilicate\", \"Metal sulfide\"],\n      \"conditions\": {\n        \"temperature\": \"273-423K\",\n        \"pressure\": \"low\",\n        \"catalyst\": \"Meteorite minerals\",\n        \"aqueous\": true,\n        \"other\": \"Parent body hydrothermal alteration\"\n      },\n      \"mechanism\": \"Strecker and hydrolytic reactions on aqueous meteorite parent bodies generate and deliver alanine, often as a racemic mixture.\",\n      \"reasoning\": \"Pizzarello et al. (2006), Burton et al. (2012): Alanine detected in carbonaceous chondrites is attributed to Strecker/hydrolytic chemistry under mild hydrothermal conditions.\"\n    }\n  ],\n  \"pathways\": [\n    {\n      \"pathway_id\": \"P1\",\n      \"name\": \"Miller-Urey Atmospheric Discharge to Alanine\",\n      \"description\": \"Methane, ammonia, and water are sparked in the presence of montmorillonite, forming HCN, acetaldehyde, and directly racemic alanine.\",\n      \"reaction_sequence\": [\"rxn_001\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_005\"]\n    },\n    {\n      \"pathway_id\": \"P2\",\n      \"name\": \"Strecker Synthesis from Acetaldehyde\",\n      \"description\": \"Acetaldehyde, ammonia, and HCN (from atmospheric or hydrothermal origin) condense on clay, forming the aminonitrile intermediate, which hydrolyzes to alanine.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_003\"],\n      \"key_intermediates\": [\"mol_010\"]\n    },\n    {\n      \"pathway_id\": \"P3\",\n      \"name\": \"Cyanosulfidic Systems Photochemistry\",\n      \"description\": \"UV-irradiated HCN and H2S with TiO2 and copper ions produce acetaldehyde and 2-aminopropanenitrile, feeding the Strecker and hydrolytic routes to alanine.\",\n      \"reaction_sequence\": [\"rxn_004\", \"rxn_003\"],\n      \"key_intermediates\": [\"mol_005\", \"mol_010\"]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"Hydrothermal Reductive Amination Pathway\",\n      \"description\": \"Methane and water feed hydrothermal CO2 fixation (greigite/pyrite), forming pyruvate, which undergoes iron-catalyzed amination to alanine in alkaline vent environments.\",\n      \"reaction_sequence\": [\"rxn_005\", \"rxn_006\"],\n      \"key_intermediates\": [\"mol_009\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"Surface Photoselective Chiral Amplification\",\n      \"description\": \"Mixtures of racemic alanine are sorted on natural pyrite under UV exposure, selectively enriching one enantiomer (L-form) via surface photochemistry.\",\n      \"reaction_sequence\": [\"rxn_008\"],\n      \"key_intermediates\": [\"mol_011\"]\n    },\n    {\n      \"pathway_id\": \"P6\",\n      \"name\": \"Wet-Dry Cycling Concentration and Polymerization\",\n      \"description\": \"Alanine generated from other routes is concentrated and sometimes polymerized into oligopeptides during cyclic drying and rehydration on clay minerals.\",\n      \"reaction_sequence\": [\"rxn_009\"],\n      \"key_intermediates\": [\"mol_0
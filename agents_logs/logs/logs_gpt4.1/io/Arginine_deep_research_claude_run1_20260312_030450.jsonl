nvironment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_013\",\n      \"formula\": \"CH5N3\",\n      \"iupac_name\": \"guanidine\",\n      \"common_name\": \"guanidine\",\n      \"inchi\": \"InChI=1S/CH5N3/c2-1(3)4/h(H5,2,3,4)\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_014\",\n      \"formula\": \"OCN-\",\n      \"iupac_name\": \"cyanate\",\n      \"common_name\": \"cyanate\",\n      \"inchi\": \"InChI=1S/CHNO/c2-1-3/h(H,2,3)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_015\",\n      \"formula\": \"H2S\",\n      \"iupac_name\": \"sulfane\",\n      \"common_name\": \"hydrogen sulfide\",\n      \"inchi\": \"InChI=1S/H2S/h1H2\",\n      \"role\": \"starting\",\n      \"environment_formed\": \"Hydrothermal\"\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"Acrylonitrile formation from HCN and acetylene (cyanosulfidic core)\",\n      \"inputs\": [\"mol_001\", \"mol_003\"],\n      \"outputs\": [\"mol_005\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"Cu(I)\", \"phosphate minerals\"],\n      \"conditions\": {\n        \"temperature\": \"308K (35\u00b0C)\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"Cu(I), phosphate buffer\",\n        \"aqueous\": true,\n        \"other\": \"anaerobic, UV present\"\n      },\n      \"mechanism\": \"Copper-catalyzed cross-coupling of acetylene and HCN to acrylonitrile.\",\n      \"reasoning\": \"Patel et al., Nature Chemistry, 2015 demonstrated this UV/copper-catalyzed transformation as the entry to the cyanosulfidic protometabolic network.\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"\u03b2-Aminopropionitrile formation from acrylonitrile and NH3\",\n      \"inputs\": [\"mol_005\", \"mol_002\"],\n      \"outputs\": [\"mol_006\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"phospha
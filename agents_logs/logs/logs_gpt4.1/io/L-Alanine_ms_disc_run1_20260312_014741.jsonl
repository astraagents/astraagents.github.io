face\",\n      \"agents\": [\"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"montmorillonite\",\n        \"aqueous\": true,\n        \"other\": \"wet-dry cycles\"\n      },\n      \"mechanism\": \"Aldol-like addition of acetaldehyde to glycolonitrile in the presence of ammonia yields alanine aminonitrile.\",\n      \"reasoning\": \"Matches the sequential cyanosulfidic/aldol logic in Patel et al. (2015) and related studies (Data: 9376, 9120).\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"Formic acid and ammonia to formamide\",\n      \"inputs\": [\"mol_007\", \"mol_001\"],\n      \"outputs\": [\"mol_009\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"350K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"montmorillonite\",\n        \"aqueous\": true,\n        \"other\": \"\"\n      },\n      \"mechanism\": \"Condensation of formic acid and ammonia yields formamide.\",\n      \"reasoning\": \"Supported by Saladino et al. (2012); formamide as a key intermediate in the Cannizzaro-like pathway (Data: 5960).\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"Formamide, acetaldehyde, and ammonia to L-Alanine (Cannizzaro pathway)\",\n      \"inputs\": [\"mol_009\", \"mol_003\", \"mol_001\"],\n      \"outputs\": [\"mol_006\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"320-340K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"montmorillonite\",\n        \"aqueous\": true,\n        \"other\": \"\"\n      },\n      \"mechanism\": \"Carbamyl anion from formamide adds to acetaldehyde and undergoes hydrolysis to yield L-Alanine.\",\n      \"reasoning\": \"Cannizzaro pathway detailed in Saladino et al. (2012) and Pizzarello et al. (2012) for alanine formation (Data: 5960).\"\n    },\n    {\n      \"id\": \"rxn_011\",\n      \"name\": \"Dihydroxyacetone and ammonia (hydrothermal) to L-Alanine\",\n      \"inputs\": [\"mol_012\", \"mol_001\"],\n      \"outputs\": [\"mol_006\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"Al-rich smectite\"],\n      \"conditions\": {\n        \"temperature\": \"393K (120\u00b0C)\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"Al-rich smectite\",\n        \"aqueous\": true,\n        \"other\": \"\"\n      },\n      \"mechanism\": \"Amination of dihydroxyacetone with ammonia yields L-Alanine, catalyzed by Al-rich smectite.\",\n      \"reasoning\": \"Hydrothermal dihydroxyacetone pathway supported by Kitadai et al. (2017); Joseph et al. (2009) (Data: 10827, 13474).\"\n    },\n    {\n      \"id\": \"rxn_012\",\n      \"name\": \"UV/spark/energy-driven synthesis from reducing gas mixtures to L-Alanine\",\n      \"inputs\": [\"mol_001\", \"mol_002\", \"mol_004\", \"mol_013\"],\n      \"outputs\": [\"mol_006\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"ambient to 350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite (film or adsorbed phase)\",\n        \"aqueous\": false,\n        \"other\": \"Requires energy source: UV, electric discharge, or shock\"\n      },\n      \"mechanism\": \"Spark discharge or high-energy irradiation of reducing gases (NH3, HCN, formaldehyde, H2O) produces L-Alanine among a mixture of amino acids.\",\n      \"reasoning\": \"Miller-Urey experiments and re-analyses (Miller 1953; Schlesinger & Miller 1983; Cleaves et al. 2008; Data: 15628, 15633).\"\n    }\n  ],\n  \"pathways\": [\n    {\n      \"pathway_id\": \"P1\",\n      \"name\": \"Classic Strecker Route via Surface Chemistry\",\n      \"description\": \"The Strecker pathway: Acetaldehyde, ammonia, and HCN react on montmorillonite to form alanine aminonitrile, which is then hydrolyzed to L-Alanine.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\"],\n      \"key_intermediates\": [\"mol_003\", \"mol_005\"]\n    },\n    {\n      \"pathway_id\": \"P2\",\n      \"name\": \"Hydrothermal pyruvate transamination\",\n      \"description\": \"Hydrothermal reactions produce pyruvate from formaldehyde and glyoxylate on Al-rich smectite; transaminated to L-Alanine (Fe\u00b2\u207a-catalyzed).\",\n      \"reaction_sequence\": [\"rxn_006\", \"rxn_005\"],\n      \"key_intermediates\": [\"mol_010\"]\n    },\n    {\n      \"pathway_id\": \"P3\",\n      \"name\": \"Formose-mediated acetaldehyde pathway\",\n      \"description\": \"Formose reaction assembles acetaldehyde from formaldehyde (borate-catalyzed); acetaldehyde feeds into Strecker or Cannizzaro pathways.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_001\", \"rxn_002\"],\n      \"key_intermediates\": [\"mol_003\", \"mol_005\"]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"Phosphoro-Strecker Synthesis\",\n      \"description\": \"Variant Strecker using DAP results in selective production of alanine aminonitrile, then hydrolyzed to L-Alanine.\",\n      \"reaction_sequence\": [\"rxn_004\", \"rxn_002\"],\n      \"key_intermediates\": [\"mol_005\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"Cyanosulfidic pathway via glycolonitrile\",\n      \"description\": \"Cyanosulfidic network: formaldehyde and HCN yield glycolonitrile, which with acetaldehyde and ammonia proceeds to alanine aminonitrile, then to L-Alanine.\",\n      \"reaction_sequence\": [\"rxn_007\", \"rxn_008\", \"rxn_002\"],\n      \"key_intermediates\": [\"mol_008\", \"mol_005\"]\n    },\n    {\n      \"pathway_id\": \"P6\",\n      \"name\": \"Cannizzaro pathway via formamide\",\n      \"description\": \"Formic acid and ammonia yield formamide, which with acetaldehyde and ammonia on montmorillonite gives L-Alanine.\",\n      \"reaction_sequence\": [\"rxn_009\", \"rxn_010\
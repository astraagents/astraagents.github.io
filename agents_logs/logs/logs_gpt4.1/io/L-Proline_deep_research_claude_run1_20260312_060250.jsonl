     \"common_name\": \"gamma-butyrothiolactam\",\n      \"inchi\": \"InChI=1S/C4H7NOS/c5-2-1-4-3-6/h1-2,4H2,5H\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Surface\"\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"Hydrothermal CO\u2082-to-\u03b1-ketoglutarate via iron-sulfur catalysis\",\n      \"inputs\": [\"mol_001\", \"mol_002\", \"mol_003\"],\n      \"outputs\": [\"mol_005\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe\u2083S\u2084)\", \"pyrite (FeS\u2082)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"Fe\u2083S\u2084, FeS\u2082\",\n        \"aqueous\": true,\n        \"other\": \"anoxic\"\n      },\n      \"mechanism\": \"Reductive carboxylation and condensation of CO\u2082 and NH\u2083, facilitated by iron-sulfur minerals, generates \u03b1-ketoglutarate as a central TCA-cycle analog.\",\n      \"reasoning\": \"Stubbs et al. (2020), Muchowska et al. (2017), Russell & Hall (1997, 2006); production of \u03b1-ketoglutarate from simple gases via iron-sulfur catalysis in hydrothermal mound settings.\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Reductive amination of \u03b1-ketoglutarate to glutamate on nickel/iron-sulfur\",\n      \"inputs\": [\"mol_005\", \"mol_002\", \"mol_003\"],\n      \"outputs\": [\"mol_006\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"Ni/FeS\", \"greigite (Fe\u2083S\u2084)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"Ni/FeS, Fe\u2083S\u2084\",\n        \"aqueous\": true,\n        \"other\": \"anoxic\"\n      },\n      \"mechanism\": \"Reductive amination of \u03b1-ketoglutarate yields glutamate via hydrogen and ammonia input, mediated by metal sulfide surfaces.\",\n      \"reasoning\": \"Kaur et al. (2024), Huber & Wachtershauser (1998); prebiotic reductive amination of \u03b1-keto acids to amino acids on nickel/iron-sulfur minerals.\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Partial reduction of glutamate to glutamic-\u03b3-semialdehyde (GSA)\",\n      \"inputs\": [\"mol_006\", \"mol_003\"],\n      \"outputs\": [\"mol_007\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"pyrite (FeS\u2082)\", \"greigite (Fe\u2083S\u2084)\"],\n      \"conditions\": {\n        \"temperature\": \"370-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"FeS\u2082, Fe\u2083S\u2084\",\n        \"aqueous\": true,\n        \"other\": \"anoxic\"\n      },\n      \"mechanism\": \"Reduction of the \u03b3-carboxyl of glutamate to aldehyde by iron-sulfur-driven electron transfer, creating GSA.\",\n      \"reasoning\": \"Vogel & Davis (1952), Huber & Wachtershauser (1998), Russell & Hall (2006). Experimental evidence for reduction of glutamate with FeS\u2082 catalysts.\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"Spontaneous cyclization of GSA to pyrroline-5-carboxylic acid (P5C)\",\n      \"inputs\": [\"mol_007\"],\n      \"outputs\": [\"mol_008\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"null\", \"null\"],\n      \"conditions\": {\n        \"temperature\": \"370-400K\",\n        \"pressure\": \"moderate\",\n        \"catalyst\": null,\n        \"aqueous\": true,\n        \"other\": \"spontaneous, anoxic\"\n      },\n      \"mechanism\": \"Intramolecular imine formation gives ring closure, yielding P5C without need for enzyme or mineral catalyst.\",\n      \"reasoning\": \"Vogel & Davis (1952); cyclization of GSA to P5C occurs spontaneously under prebiotic aqueous conditions.\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"Reduction of pyrroline-5-carboxylic acid (P5C) to L-Proline\",\n      \"inputs\": [\"mol_008\", \"mol_003\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe\u2083S\u2084)\", \"pyrite (FeS\u2082)\"],\n      \"conditions\": {\n        \"temperature\": \"370-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"Fe\u2083S\u2084, FeS\u2082\",\n        \"aqueous\": true,\n        \"other\": \"anoxic\"\n      },\n      \"mechanism\": \"Reduction of P5C's imine yields L-proline, facilitated by iron-sulfur minerals or Fe\u00b2\u207a.\",\n      \"reasoning\": \"Vogel & Davis (1952); reduction of ring intermediate to proline with hydrothermal reducing power.\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"Ornithine cyclodeamination to GSA\",\n      \"inputs\": [\"mol_009\"],\n      \"outputs\": [\"mol_007\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe\u2083S\u2084)\", \"pyrite (FeS\u2082)\"],\n      \"conditions\": {\n        \"temperature\": \"370-400K\",\n        \"pressure\": \"moderate\",\n        \"catalyst\": \"Fe\u2083S\u2084, FeS\u2082\",\n        \"aqueous\": true,\n        \"other\": \"anoxic\"\n      },\n      \"mechanism\": \"Conversion of ornithine to GSA via cyclodeamination, paralleling biological OAT reaction but driven abiotically on Fe-S minerals.\",\n      \"reasoning\": \"In biology, OAT (ornithine \u03b4-aminotransferase) produces GSA from ornithine\u2014this step is plausible prebiotically but not yet experimentally validated (speculative connection).\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Glutamate biosynthesis from ornithine\",\n      \"inputs\": [\"mol_009\"],\n      \"outputs\": [\"mol_006\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe\u2083S\u2084)\", \"pyrite (FeS\u2082)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"Fe\u2083S\u2084, FeS\u2082\",\n        \"aqueous\": true,\n        \"other\": \"anoxic\"\n      },\n      \"mechanism\": \"Transamination or hydrolysis of ornithine yields glutamic acid.\",\n      \"reasoning\": \"Stubbs et al. (2020), Krishnamurthy et al. (2025); plausible metabolic analog, connects ornithine and glutamate.\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Arginine hydrothermal decarboxylation to proline\",\n      \"inputs\": [\"mol_010\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe\u2083S\u2084)\", \"pyrite (FeS\u2082)\"],\n      \"conditions\": {\n        \"temperature\": \"500-650K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"Fe\u2083S\u2084, FeS\u2082\",\n        \"aqueous\": true,\n        \"other\": \"anoxic\"\n      },\n      \"mechanism\": \"Thermal degradation of arginine yields proline as a product, validated by elevated stability of proline under vent conditions.\",\n      \"reasoning\": \"Vallentyne (1968); proline identified as a hydrothermal decomposition product of arginine in submarine vents.\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"Strecker synthesis of proline from DAMN and aldehyde via clay catalysis\",\n      \"inputs\": [\"mol_014\", \"mol_011\", \"mol_002\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"TiO\u2082\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"montmorillonite, TiO\u2082\",\n        \"aqueous\": true,\n        \"other\": \"wet-dry cycles, UV\"\n      },\n      \"mechanism\": \"DAMN reacts with aldehydes and ammonia under clay and TiO\u2082 catalysis, yielding proline through Strecker-type reaction.\",\n      \"reasoning\": \"Ruiz-Bermejo et al. (2013); Ferris et al. (1996); Saladino et al. (2017); Strecker reactions on meteorite parent bodies and clay minerals detected proline.\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"Cyanosulfidic pathway: Formation of proline aminonitrile via photochemistry\",\n      \"inputs\": [\"mol_004\", \"mol_002\", \"mol_015\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO\u2082\", \"Cu(I)/Cu(II)\"],\n      \"conditions\": {\n        \"temperature\": \"308K (35\u00b0C)\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"Cu(I)/Cu(II), TiO\u2082\",\n        \"aqueous\": true,\n        \"other\": \"UV irradiation, phosphate buffer, anoxic\"\n      },\n      \"mechanism\": \"UV-driven cyclization and reduction of cyanohydrin-thioamide precursors generates proline aminonitrile, precursor to proline.\",\n      \"reasoning\": \"Patel et al. (2015); formation of proline aminonitrile as 'compound 47' of the cyanosulfidic network under UV, Cu(I)/Cu(II).\"\n    },\n    {\n      \"id\": \"rxn_011\",\n      \"name\": \"Hydrolysis of proline aminonitrile to L-Proline\",\n      \"inputs\": [\"mol_012\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"null\", \"null\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": null,\n        \"aqueous\": true,\n        \"other\": \"neutral pH\"\n      },\n      \"mechanism\": \"Hydrolytic cleavage of aminonitrile produces L-Proline.\",\n      \"reasoning\": \"Patel et al. (2015); hydrolysis of aminonitrile intermediates to amino acids including proline.\"\n    },\n    {\n      \"id\": \"rxn_012\",\n      \"name\": \"Crystal-solution eutectic amplification of L-Proline\",\n      \"inputs\": [\"mol_013\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"null\", \"null\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": null,\n        \"aqueous\": true,\n        \"other\": \"evaporative concentration\"\n      },\n      \"mechanism\": \"Preferential dissolution of enantiopure proline crystals amplifies solution ee far above initial ratio.\",\n      \"reasoning\": \"Hayashi & Koshino (2006); crystal-solution eutectic effect demonstrated for proline, though not yet in aqueous prebiotic systems.\"\n    },\n    {\n      \"id\": \"rxn_013\",\n      \"name\": \"Proline-mediated asymmetric catalysis (autoinductive feedback)\",\n      \"inputs\": [\"mol_013\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"null\", \"null\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": null,\n        \"aqueous\": true,\n        \"other\": \"wet-dry cycles\"\n      },\n      \"mechanism\": \"L-Proline acts as an organocatalyst, accelerating asymmetric reactions and providing self-reinforcing chiral selection.\",\n      \"reasoning\": \"List et al. (2000), Mathew et al. (2004); proline-catalyzed asymmetric aldol and autoinductive effects enable chiral feedback.\"\n    }\n  ],\n  \"pathways\": [\n    {\n      \"pathway_id\": \"P1\",\n      \"name\": \"Hydrothermal TCA-cycle network route\",\n      \"description\": \"CO\u2082, NH\u2083, and H\u2082 undergo iron-sulfur-driven carboxylation and reductive amination to \u03b1-ketoglutarate, then to glutamate, then reduction to GSA, cyclization to P5C, and reduction to L-Proline.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_003\", \"rxn_004\", \"rxn_005\"],\n      \"key_intermediates\": [\"mol_005\", \"mol_006\", \"mol_007\", \"mol_008\"]\n    },\n    {\n      \"pathway_id\": \"P2\",\n      \"name\": \"Hydrothermal ornithine branch\",\n      \"description\": \"Ornithine generated from early amino acid mixtures undergoes cyclodeamination on Fe-S minerals to GSA, then follows standard cyclization and reduction steps.\",\n      \"reaction_sequence\": [\"rxn_006\", \"rxn_004\", \"rxn_005\"],\n      \"key_intermediates\": [\"mol_009\", \"mol_007\", \"mol_008\"]\n    },\n    {\n      \"pathwa
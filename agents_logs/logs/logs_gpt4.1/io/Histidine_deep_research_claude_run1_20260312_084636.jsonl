  \"key_intermediates\": [\"mol_010\", \"mol_007\"]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"DAMN photochemistry \u2192 AICN \u2192 AICA (purino-histidine biosynthesis intersection)\",\n      \"description\": \"HCN tetramerizes to DAMN, then UV-photoisomerizes to AICN, then hydrolyzes to AICA (a link to purine nucleobases and histidine biosynthesis in biology, but not abiotically to histidine).\",\n      \"reaction_sequence\": [\"rxn_007\", \"rxn_008\", \"rxn_009\"],\n      \"key_intermediates\": [\"mol_011\", \"mol_012\", \"mol_013\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"Sutherland imidazole cascade (FoDHA-CN + cyanide \u2192 imidazole derivatives)\",\n      \"description\": \"Formamide and glycolaldehyde generate dehydroalanine nitrile (FoDHA-CN), which cascades with cyanide to yield imidazole derivatives (63% yield). So far, only the imidazole ring has been formed, not histidine.\",\n      \"reaction_sequence\": [\"rxn_010\", \"rxn_011\"],\n      \"key_intermediates\": [\"mol_014\", \"mol_007\"]\n    },\n    {\n      \"pathway_id\": \"P6\",\n      \"name\": \"HCN + NH3 provides convergent feedstock for both formamidine (Shen pathway) and DAMN (AICN route)\",\n      \"description\": \"HCN and ammonia form both formamidine (Shen path to histidine via imidazole-4-acetaldehyde) and DAMN (precursor to aminoimidazoles in purine chemistry); multiple key network hubs.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_007\", \"rxn_008\"],\n      \"key_intermediates\": [\"mol_006\", \"mol_011\", \"mol_012\"]\n    },\n    {\n      \"pathway_id\": \"P7\",\n      \"name\": \"Borate-catalyzed stabilization of formose sugars (glycolaldehyde/erythrose) for imidazole-4-acetaldehyde synthesis\",\n      \"description\": \"Borate minerals aid the formation and stabilization of key C2 (glycolaldehyde) and C4 (erythrose) sugars among otherwise fragile formose products, boosting Shen route performance.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_006\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_005\"]\n    },\n    {\n      \"pathway_id\": \"P8\",\n      \"name\": \"DAMN photochemistry branch feeds into AICN/AICA from alternative HCN sources\",\n      \"description\": \"Alternative HCN-rich chemistry environments undergo tetramerization and photolytic rearrangements, intersecting with nucleotide/imidazole biosynthesis, but not yet direct histidine formation.\",\n      \"reaction_sequence\": [\"rxn_007\", \"rxn_008\", \"rxn_009\"],\n      \"key_intermediates\": [\"mol_011\", \"mol_012\"]\n    },\n    {\n      \"pathway_id\": \"P9\",\n      \"name\": \"Imidazole central hub: supplied via multiple convergent routes, including Debus-Radziszewski and Sutherland cascades\",\n      \"description\": \"Imidazole is synthesized from glyoxal, formaldehyde, and ammonia (Debus-Radziszewski), from HCN oligomerization/photolysis via DAMN/AICN, and from Sutherland's cyano-cascade (all feed into key metabolic chemistry).\",\n      \"reaction_sequence\": [\"rxn_012\", \"rxn_005\", \"rxn_011\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_010\"]\n    },\n    {\n      \"pathway_id\": \"P10\",\n      \"name\": \"Wet-dry cycles and mineral surface catalysis concentrate and select reactive intermediates for the Shen route\",\n      \"description\": \"Evaporitic pools and mineral clays drive up the local concentrations of fragile intermediates (erythrose, formamidine), enhancing the probability of successful histidine synthesis along the canonical route.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_003\", \"rxn_004\"],\n      \"key_intermediates\": [\"mol_005\", \"mol_006\", \"mol_008\"]\n    }\n  ],\n  \"hub_molecules\": [\"mol_004\", \"mol_005\", \"mol_006\", \"mol_007\", \"mol_008\", \"mol_012\"],\n  \"convergence_points\": [\n    {\n      \"molecule_id\": \"mol_004\",\n      \"incoming_reactions\": [\"rxn_001\"],\n      \"outgoing_reactions\": [\"rxn_006\", \"rxn_010\",
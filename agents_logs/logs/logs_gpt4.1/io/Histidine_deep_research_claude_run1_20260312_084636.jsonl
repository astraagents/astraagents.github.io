face\",\n      \"agents\": [\"borate minerals\", \"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"borate minerals, montmorillonite\",\n        \"aqueous\": true,\n        \"other\": \"borate stabilizes sugars\"\n      },\n      \"mechanism\": \"Aldol condensation of glycolaldehyde dimers forms D-erythrose; borate minerals stabilize the product.\",\n      \"reasoning\": \"Yi et al., 2023; Ricardo et al., Science 2004. Borate needed for sugar stability; key intermediate in Shen et al., 1987/1990.\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Schiff base formation and Amadori rearrangement (imidazole-4-acetaldehyde)\",\n      \"inputs\": [\"mol_004\", \"mol_005\"],\n      \"outputs\": [\"mol_008\", \"mol_014\", \"mol_015\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"montmorillonite\", \"null\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"montmorillonite\",\n        \"aqueous\": true,\n        \"other\": \"formamidine 0.3 M, mild solution\"\n      },\n      \"mechanism\": \"Erythrose reacts with formamidine. Schiff base forms, then Amadori rearrangement yields imidazole-4-acetaldehyde (1.6% yield), imidazole-4-glycol (6.8%), and imidazole-4-ethanol (5.4%), with montmorillonite mineral adsorption.\",\n      \"reasoning\": \"Shen et al., Origins of Life 1987; Shen et al., J Mol Evol 1990. Only confirmed route to imidazole-4-acetaldehyde. Borate minerals could stabilize erythrose, but montmorillonite facilitates ring-forming reactions.\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"Strecker synthesis (histidine)\",\n      \"inputs\": [\"mol_008\", \"mol_006\", \"mol_007\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"montmorillonite\", \"null\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"montmorillonite\",\n        \"aqueous\": true,\n        \"other\": \"mildly basic solution\"\n      },\n      \"mechanism\": \"Imidazole-4-acetaldehyde condenses with ammonia to form an imine; HCN adds to form \u03b1-aminonitrile; hydrolysis yields histidine.\",\n      \"reasoning\": \"Shen et al., Origins of Life 1987; Shen et al., J Mol Evol 1990; Kitadai, Origins of Life 2015; Only experimentally confirmed prebiotic histidine synthesis.\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"Debus-Radziszewski imidazole synthesis\",\n      \"inputs\": [\"mol_003\", \"mol_001\", \"mol_007\"],\n      \"outputs\": [\"mol_009\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"borate minerals\"],\n      \"conditions\": {\n        \"temperature\": \"300-320K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"montmorillonite, borate\",\n        \"aqueous\": true,\n        \"other\": \"mild aqueous, evaporitic pool\"\n      },\n      \"mechanism\": \"Glyoxal, formaldehyde, and ammonia condense to produce imidazole ring.\",\n      \"reasoning\": \"Or\u00f3 et al., Origins of Life 1984; Kua et al., J Phys Chem A 2011. Multiple prebiotic routes to imidazole ring but not its C4-functionalization.\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"HCN oligomerization to DAMN\",\n      \"inputs\": [\"mol_006\", \"mol_006\", \"mol_006\", \"mol_006\"],\n      \"outputs\": [\"mol_010\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO\u2082\", \"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"300-320K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"TiO\u2082, montmorillonite\",\n        \"aqueous\": true,\n        \"other\": \"UV irradiation (350 nm)\"\n      },\n      \"mechanism\": \"Four HCN molecules oligomerize under UV exposure with TiO\u2082 catalysis to form DAMN.\",
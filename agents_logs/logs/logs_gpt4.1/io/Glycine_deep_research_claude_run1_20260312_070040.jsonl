\n      \"outputs\": [\"mol_004\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"null\", \"null\"],\n      \"conditions\": {\n        \"temperature\": \"ambient\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": null,\n        \"aqueous\": true,\n        \"other\": \"spark discharge or UV\"\n      },\n      \"mechanism\": \"CO and NH\u2083 under energy input (spark/UV) produce HCN in the atmosphere, which dissolves in water.\",\n      \"reasoning\": \"Miller (1955, JACS); Schlesinger & Miller (1983, J Mol Evol); Cleaves et al. (2008, Origins Life Evol Biosph).\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Strecker synthesis of aminoacetonitrile from formaldehyde, HCN, and ammonia\",\n      \"inputs\": [\"mol_006\", \"mol_004\", \"mol_005\"],\n      \"outputs\": [\"mol_007\", \"mol_009\", \"mol_010\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"phosphate minerals\"],\n      \"conditions\": {\n        \"temperature\": \"25\u201340\u00b0C\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite, phosphate minerals\",\n        \"aqueous\": true,\n        \"other\": \"pH 8, wet-dry cycling\"\n      },\n      \"mechanism\": \"Aminomethanol forms from formaldehyde and ammonia, dehydrated to methanimine, then reacts with HCN to form aminoacetonitrile.\",\n      \"reasoning\": \"Miller (1953, Science); Magrino et al. (2021, JPCL); Johnson et al. (2008, Science); Taillades et al. (1998, Origins Life Evol Biosph).\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"Hydrolysis of aminoacetonitrile to glycinamide\",\n      \"inputs\": [\"mol_007\", \"mol_001\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"TiO\u2082\"],\n      \"conditions\": {\n        \"temperature\": \"25\u201340\u00b0C\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite, TiO\u2082\",\n        \"aqueous\": true,\n        \"other\": \"wet-dry cycles, UV possible\"\n      },\n      \"mechanism\": \"Nitrile hydrolysis yielding glycinamide with mineral catalysis and possibly UV input.\",\n      \"reasoning\": \"Magrino et al. (2021, JPCL); Miller (1957, BBA); Kitadai et al. (2017, Origins Life Evol Biosph).\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"Hydrolysis of glycinamide to glycine\",\n      \"inputs\": [\"mol_011\", \"mol_001\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"null\"],\n      \"conditions\": {\n        \"temperature\": \"40\u00b0C\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite\",\n        \"aqueous\": true,\n        \"other\": \"wet-dry cycling\"\n      },\n      \"mechanism\": \"Amide hydrolysis yields glycine, catalyzed by clay minerals.\",\n      \"reasoning\": \"Magrino et al. (2021, JPCL); Paecht-Horowitz (1976, Origins Life Evol Biosph); Miller (1953, Science).\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"Bucherer-Bergs pathway: aminoacetonitrile + CO\u2082 \u2192 hydantoin\",\n      \"inputs\": [\"mol_007\", \"mol_002\"],\n      \"outputs\": [\"mol_018\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"phosphate minerals\"],\n      \"conditions\": {\n        \"temperature\": \"25\u00b0C\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite, phosphate minerals\",\n        \"aqueous\": true,\n        \"other\": \"pH 8\"\n      },\n      \"mechanism\": \"Aminoacetonitrile reacts with CO\u2082 forming hydantoin via carbamoyl intermediates.\",\n      \"reasoning\": \"Taillades et al. (1998, Origins Life Evol Biosph); Pulletikurti et al. (2022, Nature Chemistry).\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Hydrolysis of hydantoin to N-carbamoyl glycine\",\n      \"inputs\": [\"mol_018\", \"mol_001\"],\n      \"outputs\": [\"mol_017\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"phosphate minerals\"],\n      \"conditions\": {\n        \"temperature\": \"40\u00b0C\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite, phosphate minerals\",\n        \"aqueous\": true,\n        \"other\": null\n      },\n      \"mechanism\": \"Hydantoin is hydrolyzed to N-carbamoyl glycine in aqueous solution catalyzed by clays.\",\n      \"reasoning\": \"Taillades et al. (1998, Origins Life Evol Biosph); Pulletikurti et al. (2022, Nature Chemistry).\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Hydrolysis of N-carbamoyl glycine to glycine\",\n      \"inputs\": [\"mol_017\", \"mol_001\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"phosphate minerals\"],\n      \"conditions\": {\n        \"temperature\": \"40\u00b0C\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite, phosphate minerals\",\n        \"aqueous\": true,\n        \"other\": null\n      },\n      \"mechanism\": \"N-carbamoyl glycine hydrolyzed to glycine in the presence of mineral catalysts.\",\n      \"reasoning\": \"Taillades et al. (1998, Origins Life Evol Biosph).\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"HCN polymerization followed by hydrolysis yielding glycine\",\n      \"inputs\": [\"mol_004\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"TiO\u2082\"],\n      \"conditions\": {\n        \"temperature\": \"\u221223\u00b0C (eutectic) or 40\u00b0C\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite, TiO\u2082\",\n        \"aqueous\": true,\n        \"other\": \"eutectic concentration or warm pond\"\n      },\n      \"mechanism\": \"HCN polymerizes via base/UV catalysis producing HCN polymers, which upon hydrolysis release glycine.\",\n      \"reasoning\": \"Sanchez, Ferris & Orgel (1966, Science); Ruiz-Bermejo et al. (2013, Life); Menor-Salv\u00e1n & Mar\u00edn-Yaseli (2012, Chem Soc Rev); Bernstein et al. (2002, Nature).\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"Hydrolysis of HCN polymer to glycine and other amino acids\",\n      \"inputs\": [\"mol_013\", \"mol_001\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"TiO\u2082\"],\n      \"conditions\": {\n        \"temperature\": \"40\u201370\u00b0C\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite, TiO\u2082\",\n        \"aqueous\": true,\n        \"other\": \"acid or base hydrolysis\"\n      },\n      \"mechanism\": \"HCN polymers hydrolyzed to glycine and 24 other amino acids with mineral and UV catalysis.\",\n      \"reasoning\": \"Or\u00f3 (1963); Ruiz-Bermejo et al. (2013, Life); Bernstein et al. (2002, Nature).\"\n    },\n    {\n      \"id\": \"rxn_011\",\n      \"name\": \"Cyanosulfidic photochemistry: HCN + H\u2082S + UV \u2192 aminoacetonitrile\",\n      \"inputs\": [\"mol_004\", \"mol_001\", \"mol_005\"],\n      \"outputs\": [\"mol_007\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO\u2082\", \"phosphate minerals\"],\n      \"conditions\": {\n        \"temperature\": \"35\u00b0C\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO\u2082, phosphate minerals\",\n        \"aqueous\": true,\n        \"other\": \"UV photolysis, phosphate buffer\"\n      },\n      \"mechanism\": \"Cu(I)/Cu(II) redox and TiO\u2082 photocatalyze HCN and H\u2082S to aminoacetonitrile and other network products.\",\n      \"reasoning\": \"Patel et al. (2015, Nature Chemistry); Senanayake & Idriss (2006, PNAS); Kitadai et al. (2017, Origins Life Evol Biosph).\"\n    },\n    {\n      \"id\": \"rxn_012\",\n      \"name\": \"Reductive amination: glyoxylate + ammonia \u2192 glycine (hydrothermal)\",\n      \"inputs\": [\"mol_015\", \"mol_005\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"ferroan brucite\", \"greigite\"],\n      \"conditions\": {\n        \"temperature\": \"40\u201390\u00b0C\",\n        \"pressure\": \"25 bar\",\n        \"catalyst\": \"ferroan brucite, greigite\",\n        \"aqueous\": true,\n        \"other\": \"pH 8\u20139\"\n      },\n      \"mechanism\": \"Ferroan brucite mediates reductive amination of glyoxylate with ammonia to glycine, concentrating product.\",\n      \"reasoning\": \"Barge et al. (2019, PNAS); PNAS (2024, doi:10.1073/pnas.2408248121); Wimmer et al. (2021); Yamaguchi et al. (2014, Electrochimica Acta).\"\n    },\n    {\n      \"id\": \"rxn_013\",\n      \"name\": \"Fischer-Tropsch type (FTT) catalysis: CO + H\u2082 + NH\u2083 \u2192 formaldehyde, HCN, then glycine\",\n      \"inputs\": [\"mol_014\", \"mol_003\", \"mol_005\"],\n      \"outputs\": [\"mol_006\", \"mol_004\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite\", \"Ni\u2083Fe\"],\n      \"conditions\": {\n        \"temperature\": \"360\u2013600\u00b0C\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"magnetite, awaruite (Ni\u2083Fe)\",\n        \"aqueous\": true,\n        \"other\": \"Fe\u2013Ni surface catalysis\"\n      },\n      \"mechanism\": \"Metal catalysts produce formaldehyde and HCN from CO and H\u2082, which can then proceed via Strecker.\",\n      \"reasoning\": \"Yoshino et al. (1971, Geochimica et Cosmochimica Acta); Preiner et al. (2020, Nature Ecology & Evolution); Beyazay et al. (2023, Nature Communications).\"\n    },\n    {\n      \"id\": \"rxn_014\",\n      \"name\": \"Glycolaldehyde formation via formose reaction\",\n      \"inputs\": [\"mol_006\", \"mol_001\"],\n      \"outputs\": [\"mol_016\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals\", \"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"40\u00b0C\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"borate minerals, montmorillonite\",\n        \"aqueous\": true,\n        \"other\": \"pH 8\u201310\"\n      },\n      \"mechanism\": \"Formaldehyde polymerizes via formose reaction yielding glycolaldehyde, stabilized by borates.\",\n      \"reasoning\": \"Schwartz & Goverde (1982); Menor-Salv\u00e1n & Mar\u00edn-Yaseli (2012, Chem Soc Rev).\"\n    },\n    {\n      \"id\": \"rxn_015\",\n      \"name\": \"Glyoxylate formation from glycolaldehyde oxidation\",\n      \"inputs\": [\"mol_016\"],\n      \"outputs\": [\"mol_015\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO\u2082\", \"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"ambient\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO\u2082\",\n        \"aqueous\": true,\n        \"other\": \"UV exposure\"\n      },\n      \"mechanism\": \"Glycolaldehyde oxidized on TiO\u2082 surfaces yields glyoxylate.\",\n      \"reasoning\": \"Wang et al. (2012, Chemical Communications); Senanayake & Idriss (2006, PNAS); Kitadai et al. (2017, Origins Life Evol Biosph).\"\n    },\n    {\n      \"id\": \"rxn_016\",\n      \"name\": \"Reductive amination of glyoxylate to glycine (surface route)\",\n      \"inputs\": [\"mol_015\", \"mol_005\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"ferroan brucite\", \"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"40\u00b0C\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"ferroan brucite, montmorillonite\",\n        \"aqueous\": true,\n        \"other\": \"pH 8\u20139\"\n      },\n      \"mechanism\": \"Montmorillonite and brucite catalyze reductive amination producing glycine.\",\n      \"reasoning\": \"Barge et al. (2019, PNAS); PNAS (2024, doi:10.1073/pnas.2408248121).\"\n    },\n    {\n      \"id\": \"rxn_017\",\n      \"name\": \"Nitrate reduction coupled to glyoxylate for glycine synthesis (hydrothermal)\",\n      \"inputs\": [\"mol_015\", \"mol_020\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"ferroan brucite\", \"greigite\"],\n      \"conditions\": {\n        \"temperature\": \"40\u201380\u00b0C\",\n        \"pressure\": \"25 bar\",\n        \"catalyst\": \"ferroan brucite, greigite\",\n        \"aqueous\": true,\n        \"other\": \"oxidizing/serpentinizing fluid\"\n      },\n      \"mechanism\": \"Iron hydroxide minerals mediate glycine formation from nitrate and glyoxylate.\",\n      \"reasoning\": \"PNAS (2024, doi:10.1073/pnas.2408248121).\"\n    }\n  ],\n  \"pathways\": [\n    {\n      \"pathway_id\": \"P1\",\n      \"name\": \"Classic Strecker Pathway (Surface)\",\n      \"description\": \"Formaldehyde (from hydrothermal CO\u2082 reduction) reacts with HCN and ammonia to form aminoacetonitrile, which is hydrolyzed via glycinamide to glycine; all steps catalyzed by montmorillonite and phosphate minerals.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_003\", \"rxn_004\", \"rxn_005\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_007\", \"mol_011\"]\n    },\n    {\n      \"pathway_id\": \"P2\",\n      \"name\": \"Bucherer-Bergs Route (Surface/Atmosphere)\",\n      \"description\": \"Aminoacetonitrile (from Strecker or cyanosulfidic chemistry) reacts with CO\u2082 to form hydantoin, which is hydrolyzed to N-carbamoyl glycine and then glycine.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_006\", \"rxn_007\", \"rxn_008\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_018\", \"mol_017\"]\n    },\n    {\n      \"pathway_id\": \"P3\",\n      \"name\": \"HCN Polymer Hydrolysis (Surface/Ice)\",\n      \"description\": \"HCN concentrations achieve eutectic freezing, undergo polymerization and hydrolysis yielding glycine directly.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_009\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_013\"]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"Cyanosulfidic UV Network Chemistry\",\n      \"description\": \"HCN and H\u2082S are photochemically processed in the presence of TiO\u2082 and phosphate minerals generating aminoacetonitrile, which is hydrolyzed to glycine by Strecker steps.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_011\", \"rxn_004\", \"rxn_005\"],\n      \"key_intermediates\": [\"mol_007\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"Hydrothermal Reductive Amination (Serpentinization)\",\n      \"description\": \"CO\u2082 is reduced to glyoxylate, which undergoes reductive amination with ammonia in ferroan brucite systems to yield glycine; product is highly concentrated on mineral surfaces.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_015\", \"rxn_012\"],\n      \"key_intermediates\": [\"mol_015\"]\n    },\n    {\n      \"pathway_id\": \"P6\",\n      \"name\": \"Surface Reductive Amination (Wet-Dry Clay)\",\n      \"description\": \"Formose reaction yields glycolaldehyde, which is oxidized to glyoxylate and reductively aminated to glycine on montmorillonite.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_014\", \"rxn_015\", \"rxn_016\"],\n      \"key_intermediates\": [\"mol_016\", \"mol_015\"]\n    },\n    {\n      \"pathway_id\": \"P7\",\n      \"name\": \"Fischer-Tropsch-Type Catalysis (Hydrothermal/Atmospheric)\",\n      \"description\": \"CO and H\u2082 react on metallic surfaces to yield formaldehyde and HCN; then Strecker steps produce glycine as in P1.\",\n      \"reaction_sequence\": [\"rxn_013\", \"rxn_003\", \"rxn_004\", \"rxn_005\"],\n      \"key_intermediates\": [\"mol_006\", \"mol_004\", \"mol_007\"]\n    },\n    {\n      \"pathway_id\": \"P8\",\n      \"name\": \"Nitrate-Coupled Glyoxylate Route (Hydrothermal)\",\n      \"description\": \"Hydrothermal glyoxylate reacts with nitrate on ferroan brucite to yield glycine directly.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_017\"],\n      \"key_intermediates\": [\"mol_
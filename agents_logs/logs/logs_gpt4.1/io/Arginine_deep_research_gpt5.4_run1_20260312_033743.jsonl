ock Cyanosulfidic Pathway\",\n      \"description\": \"FeS/Greigite catalyzed formation of HCN and cyanamide; these feed into surface pathway as per P1.\",\n      \"reaction_sequence\": [\"rxn_010\", \"rxn_001\", \"rxn_002\", \"rxn_003\", \"rxn_004\", \"rxn_005\"],\n      \"key_intermediates\": [\"mol_001\", \"mol_004\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"Hydrothermal Urea\u2013Cyanamide Interconnection\",\n      \"description\": \"Hydrothermal production of urea, plausibly hydrolyzed in surface settings to cyanamide then enters guanidinylation pathway.\",\n      \"reaction_sequence\": [\"rxn_011\", \"rxn_007\", \"rxn_008\"],\n      \"key_intermediates\": [\"mol_011\", \"mol_004\", \"mol_008\"]\n    },\n    {\n      \"pathway_id\": \"P6\",\n      \"name\": \"Beta-aminopropionitrile Branch Pathway\",\n      \"description\": \"Acrylonitrile to beta-aminopropionitrile then direct photoreduction and HCN homologation to arginine.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_003\", \"rxn_004\", \"rxn_005\"],\n      \"key_intermediates\": [\"mol_006\", \"mol_007\"]\n    },\n    {\n      \"pathway_id\": \"P7\",\n      \"name\": \"Feedstock Enrichment via Clay Adsorption\",\n      \"description\": \"Montmorillonite-concentrated intermediates from surface pathways lead to enhanced Arg production.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_003\", \"rxn_005\"],\n      \"key_intermediates\": [\"mol_005\", \"mol_006\", \"mol_008\"]\n    },\n    {\n      \"pathway_id\": \"P8\",\n      \"name\": \"Hydrothermal-to-Surface Interconnection via Cyanamide\",\n      \"description\": \"Hydrothermal cyanamide enters surface guanidinylation/homologation sequence.\",\n      \"reaction_sequence\": [\"rxn_010\", \"rxn_003\", \"rxn_004\", \"rxn_005\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_007\"]\n    },\n    {\n      \"pathway_id\": \"P9\",\n      \"name\": \"Arginine Concentration and Adsorption Enhancement\",\n      \"d
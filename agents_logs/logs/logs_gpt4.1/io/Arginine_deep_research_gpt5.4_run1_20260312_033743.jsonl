     \"mechanism\": \"Cu(I)/Cu(II)-mediated UV photoreduction of HCN with acetylene forms acrylonitrile in the presence of H\u2082S.\",\n      \"reasoning\": \"As reported in Patel et al., Nat. Chem. 2015: Cu/H\u2082S UV-driven cyanosulfidic homologation yields acrylonitrile (up to 25%).\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Acrylonitrile + NH\u2083 \u2192 Beta-aminopropionitrile (nucleophilic addition)\",\n      \"inputs\": [\"mol_005\", \"mol_002\"],\n      \"outputs\": [\"mol_006\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"null\"],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"montmorillonite\",\n        \"aqueous\": true,\n        \"other\": \"Neutral to mildly basic pH\"\n      },\n      \"mechanism\": \"NH\u2083 nucleophilically attacks acrylonitrile to yield beta-aminopropionitrile.\",\n      \"reasoning\": \"Patel et al., Nat. Chem. 2015: Stepwise addition of NH\u2083 to acrylonitrile forms beta-aminopropionitrile. Clay minerals concentrate intermediates (Frenkel-Pinter et al. 2019).\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Beta-aminopropionitrile + Cyanamide \u2192 Guanidinium intermediate (UV photoreduction)\",\n      \"inputs\": [\"mol_006\", \"mol_004\", \"mol_014\"],\n      \"outputs\": [\"mol_007\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"Cu(I)/Cu(II) salts\", \"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"Cu(I)/Cu(II), montmorillonite\",\n        \"aqueous\": true,\n        \"other\": \"UV, H\u2082S\"\n      },\n      \"mechanism\": \"UV and H\u2082S reduce beta-aminopropionitrile to beta-aminopropionaldehyde, cyanamide adds guanidino group.\",\n      \"reasoning\": \"Patel et al. Nat. Chem. 2015: UV-driven reduction and homologation, cyanamide transfers guanidino moiety.\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"Beta-aminopropionaldehyde homologation with HCN \u2192 \u03b1-Aminonitrile (Arg precursor)\",\n      \"inputs\": [\"mol_007\", \"mol_001\"],\n      \"outputs\": [\"mol_008\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"Cu(I)/Cu(II) salts\", \"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"Cu(I)/Cu(II), montmorillonite\",\n        \"aqueous\": true,\n        \"other\": \"UV, stepwise reagent addition\"\n      },\n      \"mechanism\": \"Kiliani-Fischer type homologation: aldehyde reacts with HCN under UV conditions, yielding an \u03b1-aminonitrile precursor; hydrolyzes to arginine.\",\n      \"reasoning\": \"Patel et al. Nat. Chem. 2015: Detailed pathway, yields compound 46 that is hydrolyzed to arginine. Clay concentrating effect supported by Frenkel-Pinter et al. (2019) and adsorption by montmorillonite (Vlasov et al. 2024).\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"\u03b1-Aminonitrile hydrolysis \u2192 Arginine (alkaline hydrolysis)\",\n      \"inputs\": [\"mol_008\"],\n      \"outputs\": [\"mol_008\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"montmorillonite\", \"phosphate minerals\"],\n      \"conditions\": {\n        \"temperature\": \"320-350K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"montmorillonite, apatite\",\n        \"aqueous\": true,\n        \"other\": \"Alkaline hydrolysis step\"\n      },\n      \"mechanism\": \"Hydrolysis of \u03b1-aminonitrile precursor yields arginine; montmorillonite promotes adsorption.\",\n      \"reasoning\": \"Patel et al. 2015: Last step in cyanosulfidic arginine synthesis. Adsorption effect from Frenkel-Pinter et al. and Vlasov et al. (2024).\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"Glutamate \u2192 Ornithine (reductive amination analogy)\",\n      \"inputs\": [\"mol_012\"],\n      \"outputs\": [\"mol_009\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"FeS\"],\n      \"conditions\": {\n        \"temperature\": \"320-350K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"FeS, montmorillonite\",\n        \"aqueous\": true,\n        \"other\": \"Excess NH\u2083, mildly reductive\"\n      },\n      \"mechanism\": \"Reductive amination of glutamate yields ornithine.\",\n      \"reasoning\": \"Analog to modern metabolism (Glavin et al., PNAS 2025), but speculative as no prebiotic version is demonstrated.\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Ornithine + cyanamide \u2192 Citrulline (guanidinylation analogue)\",\n      \"inputs\": [\"mol_009\", \"mol_004\"],\n      \"outputs\": [\"mol_010\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"null\"],\n      \"conditions\": {\n        \"temperature\": \"320-350K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"montmorillonite\",\n        \"aqueous\": true,\n        \"other\": \"Wet-dry cycles possible\"\n      },\n      \"mechanism\": \"Cyanamide guanidinylation of ornithine yields citrulline.\",\n      \"reasoning\": \"Speculative, based on Glavin et al., PNAS 2025; prebiotic guanidinylation with cyanamide suggested but not demonstrated.\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Citrulline + NH\u2083 \u2192 Arginine (transamidation analogue)\",\n      \"inputs\": [\"mol_010\", \"mol_002\"],\n      \"outputs\": [\"mol_008\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"montmorillonite\", \"null\"],\n      \"conditions\": {\n        \"temperature\": \"320-350K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"montmorillonite\",\n        \"aqueous\": true,\n        \"other\": \"Wet-dry cycle, possible\"\n      },\n      \"mechanism\": \"Conversion of citrulline to arginine through transamidation with NH\u2
7\",\n      \"name\": \"HCN/Ammonia surface polymerization\",\n      \"description\": \"Direct surface HCN/ammonia polymerization yields diamino acid intermediates (ornithine-like), coupled with guanidine from cyanamide.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_010\", \"rxn_009\", \"rxn_004\", \"rxn_008\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_015\", \"mol_009\"]\n    },\n    {\n      \"pathway_id\": \"P8\",\n      \"name\": \"Pyruvate homologation route\",\n      \"description\": \"Pyruvate and homologation form backbone extensions, feeding through \u03b1-ketoglutarate to glutamate \u2192 ornithine \u2192 arginine.\",\n      \"reaction_sequence\": [\"rxn_013\", \"rxn_005\", \"rxn_006\", \"rxn_007\", \"rxn_003\", \"rxn_008\"],\n      \"key_intermediates\": [\"mol_013\", \"mol_011\", \"mol_008\", \"mol_007\"]\n    },\n    {\n      \"pathway_id\": \"P9\",\n      \"name\": \"Surface photochemistry\u2014guanidine first strategy\",\n      \"description\": \"Rapid formation of guanidine from UV-irradiated ammonium cyanide preconditions surface pools for backbone incorporation.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_003\", \"rxn_004\", \"rxn_008\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_009\", \"mol_007\"]\n    },\n    {\n      \"pathway_id\": \"P10\",\n      \"name\": \"Cyanamide alternate polymerization closure\",\n      \"description\": \"Clay-catalyzed polymerization of ammonium cyanide to cyanamide and guanidine, then assembled with backbone from multiple sources.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_010\", \"rxn_009\", \"rxn_007\", \"rxn_008\"],\n      \"key_intermediates\": [\"mol_015\", \"mol_009\", \"mol_007\"]\n    }\n  ],\n  \"hub_molecules\": [\"mol_003\", \"mol_004\", \"mol_007\", \"mol_009\", \"mol_008\", \"mol_011\"],\n  \"convergence_points\": [\n    {\n      \"molecule_id\": \"mol_007\",\n      \"incoming_reactions\": [\"rxn_004\", \"rxn_007\", \"rxn_012\"],\n      \"outgoing_r
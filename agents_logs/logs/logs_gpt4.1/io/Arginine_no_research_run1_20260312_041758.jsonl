\"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"pyrite\",\n        \"aqueous\": true,\n        \"other\": null\n      },\n      \"mechanism\": \"Pyruvate undergoes reductive amination by NH3 on pyrite surface to yield alanine.\",\n      \"reasoning\": \"Pyrite catalyzes amination of \u03b1-keto acids; (Huber & Wachtershauser, 1997; Ameloot et al., 2019)\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Transamination of \u03b1-ketoglutarate \u2192 ornithine (Phosphate mineral catalyzed)\",\n      \"inputs\": [\"mol_010\", \"mol_015\"],\n      \"outputs\": [\"mol_009\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"phosphate minerals\", null],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"apatite\",\n        \"aqueous\": true,\n        \"other\": null\n      },\n      \"mechanism\": \"Transamination transfers amine to \u03b1-ketoglutarate forming ornithine.\",\n      \"reasoning\": \"Transamination on naturally occurring phosphate minerals yields ornithine; (Kitadai & Maruyama, 2018)\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Ornithine \u2192 argininosuccinate (Montmorillonite wet-dry assembly)\",\n      \"inputs\": [\"mol_009\", \"mol_008\", \"mol_004\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", null],\n      \"conditions\": {\n        \"temperature\": \"320-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite\",\n        \"aqueous\": false,\n        \"other\": \"wet-dry cycle\"\n      },\n      \"mechanism\": \"Condensation of ornithine, aldehyde, HCN forms argininosuccinate.\",\n      \"reasoning\": \"Montmorillonite enables peptide and guanidino group assembly; (Bernal et al., 2019)\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"Argininosuccinate \u2192 a
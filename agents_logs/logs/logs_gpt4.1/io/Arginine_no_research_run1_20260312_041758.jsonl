al interconnection to maximize plausible arginine formation across early Earth settings.", "molecules": [{"id": "mol_001", "formula": "CO2", "iupac_name": "carbon dioxide", "common_name": null, "inchi": "InChI=1S/CO2/c2-1-3", "role": "starting", "environment_formed": "Hydrothermal"}, {"id": "mol_002", "formula": "H2", "iupac_name": "dihydrogen", "common_name": null, "inchi": "InChI=1S/H2/h1H", "role": "starting", "environment_formed": "Hydrothermal"}, {"id": "mol_003", "formula": "NH3", "iupac_name": "azane", "common_name": "ammonia", "inchi": "InChI=1S/H3N/h1H3", "role": "starting", "environment_formed": "Hydrothermal"}, {"id": "mol_004", "formula": "HCN", "iupac_name": "hydrocyanic acid", "common_name": null, "inchi": "InChI=1S/CN/c1-2", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_005", "formula": "HCOO\u207b", "iupac_name": "formate", "common_name": null, "inchi": "InChI=1S/CH2O2/c2-1-3/h1H,(H,2,3)", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_006", "formula": "CH3COO\u207b", "iupac_name": "acetate", "common_name": null, "inchi": "InChI=1S/C2H4O2/c1-2(3)4/h1H3,(H,3,4)", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_007", "formula": "C3H4O3", "iupac_name": "pyruvic acid", "common_name": "pyruvate", "inchi": "InChI=1S/C3H4O3/c1-2(4)3(5)6/h1H3,(H,5,6)", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_008", "formula": "C2H4O2", "iupac_name": "glycolaldehyde", "common_name": null, "inchi": "InChI=1S/C2H4O2/c3-1-2-4/h1-2H,3-4H", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_009", "formula": "C5H10N2O3", "iupac_name": "ornithine", "common_name": null, "inchi": "InChI=1S/C5H12N2O2/c6-3-1-2-4(7)5(8)9/h4-7,9H,1-3,8H2", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_010", "formula": "C5H9NO4", "iupac_name": "\u03b1-ketoglutaric acid", "common_name": "\u03b1-ketoglutarate", "inchi": "InChI=1S/C5H6O
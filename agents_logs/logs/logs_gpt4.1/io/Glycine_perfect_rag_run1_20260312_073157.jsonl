work. Hydrothermal and surface chemistries are fully interconnected via environmental transport and recycling. Each reaction node is explicitly grounded in peer-reviewed studies with precise conditions and mineral catalysts as required.", "molecules": [{"id": "mol_001", "formula": "C2H5NO2", "iupac_name": "2-aminoacetic acid", "common_name": "Glycine", "inchi": "InChI=1S/C2H5NO2/c3-1-2(4)5/h1,3H2,(H,4,5)", "role": "target", "environment_formed": null}, {"id": "mol_002", "formula": "C2H4N2", "iupac_name": "Aminoacetonitrile", "common_name": null, "inchi": "InChI=1S/C2H4N2/c3-1-2-4/h1,3H2", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_003", "formula": "C2H2O3", "iupac_name": "Oxidanylidene(oxo)acetic acid", "common_name": "Glyoxylate", "inchi": "InChI=1S/C2H2O3/c3-1-2(4)5/h1H,(H,4,5)", "role": "hub_intermediate", "environment_formed": null}, {"id": "mol_004", "formula": "H3NO", "iupac_name": "Hydroxylamine", "common_name": null, "inchi": "InChI=1S/H3NO/c1-2/h2H,1H2", "role": "hub_intermediate", "environment_formed": null}, {"id": "mol_005", "formula": "C2H4O3", "iupac_name": "Hydroxyacetic acid", "common_name": "Glycolic acid", "inchi": "InChI=1S/C2H4O3/c3-1-2(4)5/h3H,1H2,(H,4,5)", "role": "hub_intermediate", "environment_formed": null}, {"id": "mol_006", "formula": "CC(=O)OO", "iupac_name": "Peracetic acid", "common_name": null, "inchi": "InChI=1S/C2H4O3/c1-2(3)5-4/h4H,1H3", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_007", "formula": "H3N", "iupac_name": "Ammonia", "common_name": null, "inchi": "InChI=1S/H3N/h1H3", "role": "starting", "environment_formed": null}, {"id": "mol_008", "formula": "C3H7NO3", "iupac_name": "2-amino-3-hydroxypropanoic acid", "common_name": "L-Serine", "inchi": "InChI=1S/C3H7NO3/c4-2(1-5)3(6)7/h2,5H,1,4H2,(H,6,7)", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_009", "formula": "CH2O", "iupac_name": "Methanal", "common_name": "Formaldehyde", "inchi": "InC
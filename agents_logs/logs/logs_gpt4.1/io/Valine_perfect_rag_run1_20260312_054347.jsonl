": "rxn_005", "name": "Reductive rearrangement and chain elongation (C4 to C5) \u2013 builds valine skeleton", "inputs": ["mol_009", "mol_004", "mol_006", "mol_007"], "outputs": ["mol_010", "mol_014", "mol_006"], "environment": "Surface", "agents": ["Elemental copper", "Sulfidic acid"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "Elemental copper + Sulfidic acid", "aqueous": true, "other": "Cyanosulfidic rearrangement; chain extension (Patel et al., 2015)."}, "mechanism": "Copper/H2S reduces the thioamide; HCN incorporates via C\u2013C coupling, H2S oxidized to disulfane byproduct.", "reasoning": "Key transformation shown in Patel et al. (2015), connecting C4 to C5 valine skeleton."}, {"id": "rxn_006", "name": "Amination of 2-hydroxy-3-methylbutanenitrile", "inputs": ["mol_010", "mol_005"], "outputs": ["mol_011", "mol_007"], "environment": "Surface", "agents": [], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": null, "aqueous": true, "other": "Direct amination with ammonia (Patel et al., 2015)."}, "mechanism": "Ammonia displaces the \u03b1-hydroxyl group, forming an aminonitrile analogous to Strecker amination.", "reasoning": "Observed product of cyanosulfidic chemistry in Patel et al. (2015)."}, {"id": "rxn_007", "name": "Hydrolysis of 2-amino-3-methylbutanenitrile to L-valine", "inputs": ["mol_011", "mol_007", "mol_007"], "outputs": ["mol_013", "mol_005"], "environment": "Surface", "agents": [], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": null, "aqueous": true, "other": "Ambient hydrolysis (Patel et al., 2015)."}, "mechanism": "Successive hydration/hydrolysis of the nitrile produces amide and then carboxylic acid.", "reasoning": "Standard Strecker-like hydrolysis to convert aminonitrile to \u03b1-amino acid (Patel et al., 2015)."}, {"id": "rxn_008", "name": "Formation of C6 aminonitrile from hydroxyacetone", "inputs": ["mol_002", "mol_004", "mol_005", "mol_006"], "outputs": [
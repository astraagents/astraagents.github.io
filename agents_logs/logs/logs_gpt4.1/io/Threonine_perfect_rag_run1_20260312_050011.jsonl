: \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_011\",\n      \"formula\": \"NH3\",\n      \"iupac_name\": \"azane\",\n      \"common_name\": \"ammonia\",\n      \"inchi\": \"InChI=1S/H3N/h1H3\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": null\n    },\n    {\n      \"id\": \"mol_012\",\n      \"formula\": \"C4H9NO3\",\n      \"iupac_name\": \"L-threonine (hydrothermal)\",\n      \"common_name\": \"L-threonine\",\n      \"inchi\": \"InChI=1S/C4H9NO3/c1-2(6)3(5)4(7)8/h2-3,6H,5H2,1H3,(H,7,8)\",\n      \"role\": \"target\",\n      \"environment_formed\": \"Hydrothermal\"\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"Cyanohydrin formation from lactaldehyde and HCN\",\n      \"inputs\": [\"mol_002\",\"mol_001\"],\n      \"outputs\": [\"mol_003\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"UV light\", \"phosphate minerals\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"phosphate minerals\",\n        \"aqueous\": true,\n        \"other\": \"UV photochemistry\"\n      },\n      \"mechanism\": \"Nucleophilic addition of cyanide to lactaldehyde carbonyl, yielding cyanohydrin intermediate.\",\n      \"reasoning\": \"Patel et al., 2015 (Nature Chemistry); explicit demonstration under cyanosulfidic conditions.\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Aminonitrile formation from cyanohydrin and ammonia\",\n      \"inputs\": [\"mol_003\",\"mol_004\"],\n      \"outputs\": [\"mol_005\", \"mol_006\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"UV light\", \"phosphate minerals\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"phosphate minerals\",\n        \"aqueous\": true,\n        \"other\": \"UV photochemistry\"\n      },\n      \"mechanism\": \"Strecker-type amination of cyanohydrin with NH3 to produce 2-amino-3-hydroxybutanenitrile and water.\",\n      \"reasoning\": \"Patel et al., 2015 (Nature Chemistry); direct Strecker-type aminonitrile formation.\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Hydrolysis of aminonitrile to L-threonine\",\n      \"inputs\": [\"mol_005\", \"mol_006\", \"mol_006\"],\n      \"outputs\": [\"mol_007\", \"mol_004\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"UV light\", \"phosphate minerals\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"phosphate minerals\",\n        \"aqueous\": true,\n        \"other\": \"UV photochemistry\"\n      },\n      \"mechanism\": \"Stepwise hydrolysis of nitrile (2-amino-3-hydroxybutanenitrile) to amide then carboxylic acid (threonine), releasing ammonia.\",\n      \"reasoning\": \"Patel et al., 2015 (Nature Chemistry); experimental proof of aminonitrile hydrolysis yielding threonine.\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"Aldol condensation of L-alanine and formaldehyde to L-threonine (hydrothermal)\",\n      \"inputs\": [\"mol_008\", \"mol_009\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"iron-sulfide surfaces\", \"clay minerals\"],\n      \"conditions\": {\n        \"temperature\": \"350-600K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"iron-sulfide minerals\",\n        \"aqueous\": true,\n        \"other\": \"submarine hydrothermal conditions\"\n      },\n      \"mechanism\": \"Aldol condensation: alpha-carbon of L-alanine attacks formaldehyde, extending the carbon skeleton and introducing hydroxyl group.\",\n      \"reasoning\": \"Aubrey et al., 2008 (Origins of Life); direct demonstration under hydrothermal vent conditions.\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"Hydrothermal aminonitrile hydrolysis (surface intermediate feeding hydrothermal)\",\n      \"inp
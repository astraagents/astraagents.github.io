    \"outputs\": [\"mol_007\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite\", \"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"370-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"magnetite, montmorillonite\",\n        \"aqueous\": true,\n        \"other\": \"hydrothermal-catalyzed\"\n      },\n      \"mechanism\": \"Cyclization and rearrangement of aminomalononitrile on mineral surfaces forms imidazole.\",\n      \"reasoning\": \"Imidazole ring formation plausibly proceeds from HCN polymerization intermediates, as modeled in prebiotic chemistry (Patel et al., Nature, 2015; Data: Sources 9365, 21200, 21196).\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Imidazole-4-acetaldehyde synthesis from glyoxylate and imidazole\",\n      \"inputs\": [\"mol_011\", \"mol_007\"],\n      \"outputs\": [\"mol_008\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite\", \"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"370-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"magnetite, montmorillonite\",\n        \"aqueous\": true,\n        \"other\": \"condensation\"\n      },\n      \"mechanism\": \"Condensation between glyoxylate and imidazole on mineral surfaces yields imidazole-4-acetaldehyde.\",\n      \"reasoning\": \"Formation of imidazole-4-acetaldehyde from glyoxylate and imidazole is a plausible prebiotic path to histidine (Levine et al., Org. Lett., 2008; Data: Sources 21332, 21188, 985).\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Imidazolepyruvate condensation to histidine\",\n      \"inputs\": [\"mol_009\", \"mol_002\"],\n      \"outputs\": [\"mol_010\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"ambient\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"montmorillonite\",\n        \"aqueous\": true,\n        \"other\": \"template-directed assembly\"\n      },\n      \"mechanism\": \"Condensation and reduction of imidazolepyruvate with ammonia forms histidine.\",\n      \"reasoning\": \"Biomolecular assembly steps mirror extant biosynthesis and are plausible on mineral templates in concentrated pools (Levine et al., Org. Lett., 2008; Data: Sources 16051, 21187).\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"HCN polymerization via meteorite aqueous alteration\",\n      \"inputs\": [\"mol_013\"],\n      \"outputs\": [\"mol_001\", \"mol_005\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"magnetite\"],\n      \"conditions\": {\n        \"temperature\": \"300K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"magnetite\",\n        \"aqueous\": true,\n        \"other\": \"meteorite parent body hydration\"\n      },\n      \"mechanism\": \"Meteorite organic inventory releases HCN and DAMN via aqueous alteration catalyzed by magnetite.\",\n      \"reasoning\": \"Amino acids, including histidine precursors, are delivered from meteorites\u2014a convergent pathway (Pizzarello, Acc. Chem. Res., 2006; Data: Sources 15389, 6362, 21188).\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"Hydrolysis of DAMN to aminomalononitrile and formamide\",\n      \"inputs\": [\"mol_005\", \"mol_004\"],\n      \"outputs\": [\"mol_006\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite\"],\n      \"conditions\": {\n        \"temperature\": \"370-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"magnetite\",\n        \"aqueous\": true,\n        \"other\": null\n      },\n      \"mechanism\": \"Hydrolysis of DAMN in presence of formamide and magnetite yields aminomalononitrile.\",\n      \"reasoning\": \"DAMN conversion to aminomalononitrile is part of the HCN-to-imidazole pathway (Patel et al., Nature, 2015; Data: Sources 21192, 9365).\"\n    },\n    {\n      \"id\": \"rxn_011\",\n  
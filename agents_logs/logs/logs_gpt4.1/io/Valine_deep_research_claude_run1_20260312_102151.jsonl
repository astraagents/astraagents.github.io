 \"Surface\",\n      \"agents\": [\"Quartz reactor\", null],\n      \"conditions\": {\n        \"temperature\": \"300\u2013330K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": null,\n        \"aqueous\": true,\n        \"other\": \"electric discharge, reducing gas mixture (CH4, NH3, H2, H2O)\"\n      },\n      \"mechanism\": \"Generates HCN and aldehydes (including acetaldehyde, isobutyraldehyde, etc.) via high-energy radical recombination.\",\n      \"reasoning\": \"Miller & Urey (1953); Johnson et al. (2008); Parker et al. (2011): Confirmed formation of HCN, acetaldehyde, isobutyraldehyde, and other aldehydes that act as Strecker precursors for amino acid synthesis including valine.\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Fischer-Tropsch type acetaldehyde synthesis (hydrothermal)\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_005\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"Magnetite (Fe3O4)\", \"NiS\"],\n      \"conditions\": {\n        \"temperature\": \"400\u2013500K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"magnetite, NiS\",\n        \"aqueous\": true,\n        \"other\": null\n      },\n      \"mechanism\": \"Reductive condensation of CO/CO2 and H2 (methane and CO2) to aldehydes, including acetaldehyde, via transition-metal-catalyzed FTT chemistry.\",\n      \"reasoning\": \"McCollom, Ritter & Simoneit (1999); Preiner et al. (2023): Documented formation of acetaldehyde (and higher aldehydes) under hydrothermal Fischer-Tropsch-like conditions.\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"NiS-catalyzed aldol condensation of acetaldehyde to isobutyraldehyde\",\n      \"inputs\": [\"mol_005\", \"mol_005\"],\n      \"outputs\": [\"mol_006\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"NiS\", \"FeS\"],\n      \"conditions\": {\n        \"temperature\": \"350\u2013400K\",\n        \"pressure\": \"moderate\",\n        \
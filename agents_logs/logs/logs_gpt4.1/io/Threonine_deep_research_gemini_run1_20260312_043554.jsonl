nsation \u2192 Strecker/Threonine Route (Surface)", "description": "Ice-brine concentration drives aldol condensation and Strecker aminonitrile formation, followed by hydrolysis.", "reaction_sequence": ["rxn_009", "rxn_006"], "key_intermediates": ["mol_007", "mol_008"]}, {"pathway_id": "P5", "name": "Mg.porphin Photochemical Cyclization Route (Surface/Photochemical)", "description": "Cyanoacetylene and CO bind Mg.porphin, photochemical excitation and aziridine cyclization yield threonine.", "reaction_sequence": ["rxn_008"], "key_intermediates": ["mol_014", "mol_013"]}, {"pathway_id": "P6", "name": "Meteorite Matrix Aminonitrile Hydrolysis Route (Surface/Extraterrestrial)", "description": "Meteorite clays adsorb aminonitrile precursor and hydrolyze to threonine, with possible L-enrichment.", "reaction_sequence": ["rxn_010"], "key_intermediates": ["mol_008"]}, {"pathway_id": "P7", "name": "Coupled Hydrothermal/Surface Route via Dihydroxyacetone Feed", "description": "Greigite catalysis produces C2 glycolaldehyde and C3 dihydroxyacetone, which feed aldol condensation (surface) and Strecker formation.", "reaction_sequence": ["rxn_007", "rxn_003", "rxn_004", "rxn_005", "rxn_006"], "key_intermediates": ["mol_004", "mol_006", "mol_007", "mol_008"]}, {"pathway_id": "P8", "name": "Direct Aldol-Strecker Pathway (Surface/Wet-Dry)", "description": "Aldol condensation of formaldehyde and glycolaldehyde yields tetrose; direct Strecker reaction generates aminonitrile and threonine.", "reaction_sequence": ["rxn_004", "rxn_005", "rxn_006"], "key_intermediates": ["mol_007", "mol_008"]}, {"pathway_id": "P9", "name": "HCN Flow Chemistry Multistep \u2192 Aminonitrile Hydrolysis", "description": "Surface flow chemistry enables sequential homologation to glycolaldehyde/glyceraldehyde, aldol condensation, aminonitrile formation, hydrolysis.", "reaction_sequence": ["rxn_001", "rxn_002", "rxn_004", "rxn_005", "rxn_006"], "key_intermediates": ["mol_004", "mol_005", "mol_007", "mol_008"]}, {"p
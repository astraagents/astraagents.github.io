 [\"mol_004\", \"mol_016\"],\n      \"outputs\": [\"mol_005\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite\", null],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"magnetite\",\n        \"aqueous\": true,\n        \"other\": \"requires C1\u2013C2 elongation, plausible under hydrothermal FTT\"\n      },\n      \"mechanism\": \"Hydrogenation and coupling yields glycolate.\",\n      \"reasoning\": \"Fischer-Tropsch-type (FTT) chemistry is well established (Huber & W\u00e4chtersh\u00e4user, 1998; Cody et al., 2000).\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Glycolaldehyde synthesis from glycolate (surface, montmorillonite)\",\n      \"inputs\": [\"mol_005\"],\n      \"outputs\": [\"mol_007\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", null],\n      \"conditions\": {\n        \"temperature\": \"320-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite\",\n        \"aqueous\": false,\n        \"other\": \"wet-dry cycling\"\n      },\n      \"mechanism\": \"Mineral-catalyzed dehydrogenation/dehydration of glycolate yields glycolaldehyde.\",\n      \"reasoning\": \"Montmorillonite clays support such dehydration; see Ferris et al. (1996); Islam & Powner (2017).\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"Formation of HCN from CO2, NH3, H2 (hydrothermal, pyrite)\",\n      \"inputs\": [\"mol_001\", \"mol_002\", \"mol_003\"],\n      \"outputs\": [\"mol_008\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"pyrite\", null],\n      \"conditions\": {\n        \"temperature\": \"370-420K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"pyrite\",\n        \"aqueous\": true,\n        \"other\": \"FeS\u2082 catalysis\"\n      },\n      \"mechanism\": \"Reductive conversion forms HCN and water.\",\n      \"reasoning\": \"Experimental plausibility 
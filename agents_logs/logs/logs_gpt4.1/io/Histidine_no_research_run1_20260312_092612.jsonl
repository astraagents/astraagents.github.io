       \"other\": \"wet-dry cycling\"\n      },\n      \"mechanism\": \"Aldehyde + NH\u2083 + HCN condense to aminonitrile (I), hydrolyze to glycinamide.\",\n      \"reasoning\": \"Classic Strecker pathway; demonstrated by Ferris et al. (1974); Sutherland et al. (2017).\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Hydrolysis of glycinamide to glycine (biochemical/mineral interface)\",\n      \"inputs\": [\"mol_010\", \"mol_016\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"montmorillonite\", null],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite\",\n        \"aqueous\": true,\n        \"other\": null\n      },\n      \"mechanism\": \"Amide hydrolysis using water on clay surface.\",\n      \"reasoning\": \"Spontaneous under mild hydrothermal or surface conditions; Ferris & Joshi (1977).\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"Transamination: glycine + imidazole \u2192 imidazolylacetate (biochemical)\",\n      \"inputs\": [\"mol_011\", \"mol_009\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"montmorillonite\", null],\n      \"conditions\": {\n        \"temperature\": \"330-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite\",\n        \"aqueous\": true,\n        \"other\": \"template-directed\"\n      },\n      \"mechanism\": \"Amino transfer from glycine to imidazole ring attaches imidazole sidechain.\",\n      \"reasoning\": \"Modelled after prebiotic imidazolyl amino acid synthesis (Springsteen et al., 2018); possible on clay/mineral interfaces.\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"Direct condensation: glycolaldehyde + imidazole + NH3 \u2192 histidine backbone (biochemical/mineral interface)\",\n      \"inputs\": [\"mol_007\", \"mol_009\", \"mol_003\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"montmorillonite\", null],\n      \"conditions\": {\n        \"temperature\": \"320-340K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite\",\n        \"aqueous\": true,\n        \"other\": \"template-directed, likely multiple steps\"\n      },\n      \"mechanism\": \"Stepwise formation of histidine via multicomponent condensation with assembly of amino acid and imidazole moieties.\",\n      \"reasoning\": \"Prebiotic plausibility supported by Saladino et al. (2015); role of mineral surfaces in selectivity emphasized by Ferris et al. (1996).\"\n    },\n    {\n      \"id\": \"rxn_011\",\n      \"name\": \"Condensation: AICA + glycine \u2192 histidine (biochemical)\",\n      \"inputs\": [\"mol_012\", \"mol_011\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"montmorillonite\", null],\n      \"conditions\": {\n        \"temperature\": \"330-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite\",\n        \"aqueous\": true,\n        \"other\": \"template-directed\"\n      },\n      \"mechanism\": \"Nucleophilic attack of amino acid N on AICA carboxamide, ring closure forms imidazole ring.\",\n      \"reasoning\": \"Speculative but mirrors the classical biosynthetic route (e.g., Reverdatto et al., 2002); plausible with concentration or cycling.\"\n    },\n    {\n      \"id\": \"rxn_012\",\n      \"name\": \"AICA cyclization with glycolaldehyde \u2192 histidine (biochemical)\",\n      \"inputs\": [\"mol_012\", \"mol_007\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"montmorillonite\", null],\n      \"conditions\": {\n        \"temperature\": \"320-340K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite\",\n        \"aqueous\": true,\n        \"other\": null\n      },\n      \"mechanism\": \"Template-catalyzed condensation and ring closure forms histidine.\",\n      \"reasoning\": \"Speculative, but both AICA and glycolaldehyde plausible prebiotic intermediates (Powner et al., 2009; Patel et al., 2015).\"\n    }\n  ],\n  \"pathways\": [\n    {\n      \"pathway_id\": \"P1\",\n      \"name\": \"Hydrothermal\u2013surface\u2013biochemical: formate\u2192glycolaldehyde\u2192imidazole\u2192histidine\",\n      \"description\": \"CO2\u2192formate (greigite, hydrothermal), formate\u2192glycolate (magnetite), glycolate\u2192glycolaldehyde (montmorillonite), glycolaldehyde+HCN\u2192imidazole (TiO2/UV surface), imidazole+glycine\u2192histidine (clay-catalyzed).\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_003\", \"rxn_005\", \"rxn_008\", \"rxn_009\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_007\", \"mol_009\"]\n    },\n    {\n      \"pathway_id\": \"P2\",\n      \"name\": \"Hydrothermal\u2013surface\u2013biochemical: HCN route via AICA\",\n      \"description\": \"CO2+H2+NH3\u2192HCN (pyrite, hydrothermal), HCN+H2O\u2192AICA (molybdenite, surface), AICA+glycine\u2192histidine (montmorillonite, biochemical).\",\n      \"reaction_sequence\": [\"rxn_004\", \"rxn_006\", \"rxn_008\", \"rxn_011\"],\n      \"key_intermediates\": [\"mol_008\", \"mol_012\"]\n    },\n    {\n      \"pathway_id\": \"P3\",\n      \"name\": \"Surface: Strecker pathway merging with imidazole\",\n      \"description\": \"Glycolaldehyde+NH3+HCN\u2192glycinamide (montmorillonite, surface), hydrolysis\u2192glycine, then direct condensation with imidazole (from glycolaldehyde+HCN/TiO2) yields histidine.\",\n      \"reaction_sequence\": [\"rxn_007\", \"rxn_008\", \"rxn_005\", \"rxn_009\"],\n      \"key_intermediates\": [\"mol_010\", \"mol_011\", \"mol_009\"]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"Direct imidazole condensation transformed to histidine\",\n      \"description\": \"Glycolaldehyde+imidazole+NH3 (all from surface/hydrothermal) condense directly on montmorillonite to histidine.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_005\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_009\", \"mol_007\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"AICA cyclization route\",\n      \"description\": \"AICA (from HCN+H2O, cyanosulfidic/molybdenite) condenses with glycolaldehyde (from formate/glycolate/aldol) to give histidine.\",\n      \"reaction_sequence\": [\"rxn_006\", \"rxn_003\", \"rxn_012\"],\n      \"key_intermediates\": [\"mol_012\", \"mol_007\"]\n    },\n    {\n      \"pathway_id\": \"P6\",\n      \"name\": \"Repeating C1 + surface assembly\",\n      \"description\": \"CO2 reduced to formate (greigite), transformed via glycolate/glycolaldehyde via surface chemistry, oligomerize with HCN (TiO2) to build imidazole.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_003\", \"rxn_005\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_007\", \"mol_008\", \"mol_009\"]\n    },\n    {\n      \"pathway_id\": \"P7\",\n      \"name\": \"Hydrothermal formate to HCN to AICA\",\n      \"description\": \"Formate hydrothermally oxidized to HCN (pyrite), HCN photopolymerized and cyclized to AICA, then assembled with glycine.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_004\", \"rxn_006\", \"rxn_008\", \"rxn_011\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_008\", \"mol_012\"]\n    },\n    {\n      \"pathway_id\": \"P8\",\n      \"name\": \"Classic surface Strecker\u2013hydrolysis\",\n      \"description\": \"Glycolaldehyde+NH3+HCN\u2192aminoacetonitrile (montmorillonite), hydrolyze to glycine, react with imidazole (separate surface route).\",\n      \"reaction_sequence\": [\"rxn_007\", \"rxn_008\", \"rxn_005\", \"rxn_009\"],\n      \"key_intermediates\": [\"mol_010\", \"mol_011\", \"mol_009\"]\n    },\n    {\n      \"pathway_id\": \"P9\",\n      \"name\": \"AICA/HCN pool with imidazole cyclization\",\n      \"description\": \"Parallel HCN chemistry leads to sep
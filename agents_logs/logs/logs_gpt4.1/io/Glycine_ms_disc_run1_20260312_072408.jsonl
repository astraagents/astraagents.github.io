, "iupac_name": "hydroxylamine", "common_name": "hydroxylamine", "inchi": "InChI=1S/H3NO/h1H3", "role": "intermediate", "environment_formed": "Hydrothermal"}], "reactions": [{"id": "rxn_001", "name": "Hydrothermal Formose Reaction to Glycolic Acid", "inputs": ["mol_001", "mol_003"], "outputs": ["mol_006"], "environment": "Hydrothermal", "agents": ["Al-rich smectite"], "conditions": {"temperature": "175-250\u00b0C", "pressure": "high", "catalyst": "Al-rich smectite", "aqueous": true, "other": "alkaline pH 8-10"}, "mechanism": "Formaldehyde undergoes polymerization and subsequent oxidation to glycolic acid in the presence of ammonia, catalyzed by Al-rich smectite.", "reasoning": "Laboratory simulations show Al-rich smectites enhance glycolic acid and amino acid synthesis from formaldehyde and ammonia under hydrothermal conditions (Takigawa et al., 2016; Bada, 2013; Van Trump et al., 2020)."}, {"id": "rxn_002", "name": "Reductive Amination of Glycolic Acid to Glycine", "inputs": ["mol_006", "mol_003"], "outputs": ["mol_009"], "environment": "Hydrothermal", "agents": ["FeS", "Fe(OH)\u2082"], "conditions": {"temperature": "175-250\u00b0C", "pressure": "high", "catalyst": "FeS, Fe(OH)\u2082", "aqueous": true, "other": "alkaline pH"}, "mechanism": "Amination of glycolic acid with ammonia yielding glycine, accelerated by iron sulfide minerals.", "reasoning": "FeS and Fe(OH)\u2082 catalysis supports reductive amination of \u03b1-hydroxy acids to amino acids under prebiotic hydrothermal settings (Kitadai et al., 2017; Takigawa et al., 2016)."}, {"id": "rxn_003", "name": "Strecker Synthesis of Aminoacetonitrile (Hub) from Formaldehyde, HCN, NH3", "inputs": ["mol_001", "mol_002", "mol_003"], "outputs": ["mol_005"], "environment": "Surface", "agents": ["montmorillonite"], "conditions": {"temperature": "ambient (300-340K)", "pressure": "1 atm", "catalyst": "montmorillonite", "aqueous": true, "other": "neutral/alkaline pH"}, "mechanism": "Formaldehyde and ammonia yield an imine, which reacts with HCN to form aminoacetonitrile on clay surfaces.", "reasoning": "Strecker synthesis is widely supported for prebiotic glycine formation (Peltzer et al., 1984; Dworkin et al., 2001); clays assist aminonitrile formation and stabilization (Ferris et al., 1996; Whittaker et al., 2022)."}, {"id": "rxn_004", "name": "Hydrolysis of Aminoacetonitrile to Glycine", "inputs": ["mol_005"], "outputs": ["mol_009"], "environment": "Surface", "agents": ["montmorillonite"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "montmorillonite", "aqueous": true, "other": "neutral pH"}, "mechanism": "Hydrolysis of aminonitrile yields glycine.", "reasoning": "Hydrolysis of aminonitriles is an essential step in Strecker synthesis; clays accelerate hydrolysis and yield glycine in meteorite and laboratory simulations (Dworkin et al., 2001; Glavin et al., 2010)."}, {"id": "rxn_005", "name": "Cyanosulfidic Photochemical Synthesis of Glyconitrile/Cyanohydrin", "inputs": ["mol_001", "mol_002", "mol_013"], "outputs": ["mol_004"], "environment": "Surface", "agents": ["TiO2", "montmorillonite"], "conditions": {"temperature": "ambient (300-340K)", "pressure": "1 atm", "catalyst": "TiO2, montmorillonite", "aqueous": true, "other": "UV irradiation (200-250 nm)"}, "mechanism": "Formaldehyde, HCN and H2S, under UV, yield cyanohydrins and glyconitrile precursors via photochemical cyanosulfidic protometabolism.", "reasoning": "Cyanosulfidic networks yield cyanohydrin and glyconitrile intermediates; TiO\u2082 and montmorillonite assist photochemistry and concentration (Sutherland et al., 2016; Patel et al., 2015; Powner et al., 2009)."}, {"id": "rxn_006", "name": "Hydrolysis/Transamination of Cyanohydrin to Aminoacetonitrile", "inputs": ["mol_004", "mol_003"], "outputs": ["mol_005"], "environment": "Surface", "agents": ["montmorillonite"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "montmorillonite", "aqueous": true, "other": "neutral pH"}, "mechanism": "Cyanohydrin undergoes hydrolysis/transamination with ammonia to yield aminoacetonitrile.", "reasoning": "Hydrolysis of cyanohydrins and transaminative conversion to aminonitriles are established in prebiotic chemistry (Whittaker et al., 2022; Patel et al., 2015)."}, {"id": "rxn_007", "name": "Glyoxylate Formation from Formaldehyde (Hydrothermal)", "inputs": ["mol_001"], "outputs": ["mol_007"], "environment": "Hydrothermal", "agents": ["Al-rich smectite"], "conditions": {"temperature": "175-250\u00b0C", "pressure": "high", "catalyst": "Al-rich smectite", "aqueous": true, "other": "alkaline pH"}, "mechanism": "Oxidation and hydration of formaldehyde produces glyoxylate.", "reasoning": "Glyoxylate forms from formaldehyde via hydrothermal mineral catalysis (Takigawa et al., 2016; Sutherland et al., 2016)."}, {"id": "rxn_008", "name": "Transamination of Glyoxylate to Glycine", "inputs": ["mol_007", "mol_014"], "outputs": ["mol_009"], "environment": "Biochemical", "agents": ["null"], "conditions": {"temperature": "320-350K", "pressure": "1 atm", "catalyst": "null", "aqueous": true, "other": "neutral pH"}, "mechanism": "Glyoxylate reacts with serine to yield glycine via transamination.", "reasoning": "Transamination of glyoxylate with amino acids like serine yields glycine in both prebiotic and biological settings (Sheldon et al., 2020; Patel et al., 2015)."}, {"id": "rxn_009", "name": "Reductive Amination of Pyruvate to Glycine", "inputs": ["mol_012", "mol_015"], "outputs": ["mol_009"], "environment": "Hydrothermal", "agents": ["FeS", "Fe(OH)\u2082"], "conditions": {"temperature": "175-250\u00b0C", "pressure": "high", "catalyst": "FeS, Fe(OH)\u2082", "aqueous": true, "other": "alkaline pH"}, "mechanism": "Reductive amination of pyruvate with hydroxylamine yields glycine, catalyzed by iron minerals.", "reasoning": "Prebiotic amination of \u03b1-keto acids is well documented in hydrothermal-catalyzed amino acid synthesis (Kitadai et al., 2017; Huber & Wachtershauser, 1997)."}, {"id": "rxn_010", "name": "Hydrothermal Synthesis of Glycine directly from Methane and CO2", "inputs": ["mol_011", "mol_010"], "outputs": ["mol_009"], "environment": "Hydrothermal", "agents": ["Al-rich smectite"], "conditions": {"temperature": "250\u00b0C", "pressure": "high", "catalyst": "Al-rich smectite", "aqueous": true, "other": "alkaline pH"}, "mechanism": "Methane and carbon dioxide react under hydrothermal conditions, catalyzed by Al-rich smectite, to generate glycine.", "reasoning": "Laboratory hydrothermal experiments simulate prebiotic glycine synthesis from methane and CO2, showing glycine as the most abundant amino acid (Takigawa et al., 2016; Bada, 2013)."}, {"id": "rxn_011", "name": "Interstellar UV Synthesis of Glycine", "inputs": ["mol_008", "mol_010"], "outputs": ["mol_009"], "environment": "Surface", "agents": ["montmorillonite"], "conditions": {"temperature": "40-120K", "pressure": "ultralow", "catalyst": "montmorillonite", "aqueous": false, "other": "UV irradiation, simulated interstellar ices"}, "mechanism": "Aminomethanol and CO2, under UV irradiation, yield glycine.", "reasoning": "Vacuum-UV irradiation of ice analogs forms glycine from methylamine, methanol, and CO2; supported by Stardust and Rosetta findings (Bernstein et al., 2002; Elsila et al., 2007; Glavin et al., 2010)."}, {"id": "rxn_012", "name": "Photochemical Production of Aminomethanol from Formaldehyde and Ammonia", "inputs": ["mol_001", "mol_003"], "outputs": ["mol_008"], "environment": "Surface", "agents": ["TiO2", "montmorillonite"], "conditions": {"temperature": "ambient (300-340K)", "pressure": "1 atm", "catalyst": "TiO2, montmorillonite", "aqueous": true, "other": "UV irradiation"}, "mechanism": "Formaldehyde and ammonia photochemically yield aminomethanol, accelerated by clay/TiO2 surfaces.", "reasoning": "Aminomethanol is detected as a prebiotic intermediate in Strecker-like, UV-driven reactions (Patel et al., 2015; Bernstein et al., 2002)."}], "p
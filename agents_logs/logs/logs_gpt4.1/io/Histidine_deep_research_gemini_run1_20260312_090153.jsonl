erature\": \"300-370K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"borate minerals, montmorillonite\",\n        \"aqueous\": true,\n        \"other\": \"wet-dry cycles\"\n      },\n      \"mechanism\": \"Aldol condensation and autocatalytic cycles generate glycolaldehyde and erythrose from formaldehyde stabilized by borates and clay.\",\n      \"reasoning\": \"Formose reaction forms 4- and 2-carbon sugars with borate stabilization (Shen, Or\u00f3 & Miller, 1977; Sutherland network chemistry).\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Formamidine synthesis from HCN and NH3\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_006\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"montmorillonite\",\n        \"aqueous\": true,\n        \"other\": \"wet-dry cycles\"\n      },\n      \"mechanism\": \"Direct reaction of HCN and NH3 in the presence of montmorillonite generates formamidine with hydrolysis as a limiting step.\",\n      \"reasoning\": \"Formamidine is formed from HCN and ammonia, but its hydrolytic instability limits accumulation (Shen, Or\u00f3 & Miller, 1977).\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"2-aminoimidazole formation from glycolaldehyde and cyanamide\",\n      \"inputs\": [\"mol_004\", \"mol_007\"],\n      \"outputs\": [\"mol_008\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"phosphate minerals\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"phosphate minerals\",\n        \"aqueous\": true,\n        \"other\": \"pH 5-7, high ammonium concentration\"\n      },\n      \"mechanism\": \"Phosphate-catalyzed cyclization forms 2-aminoimidazole from glycolaldehyde and cyanamide under wet, acidic conditions.\",\n      \"reasoning\": \"Sutherland network; 2-aminoimidazole synthesis is robust with phosphate and ammonium (Sutherland et al., 2015).\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"Imidazole ring formation via erythrose-formamidine condensation\",\n      \"inputs\": [\"mol_005\", \"mol_006\"],\n      \"outputs\": [\"mol_009\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"montmorillonite\",\n        \"aqueous\": true,\n        \"other\": \"Amadori rearrangement, wet-dry cycles\"\n      },\n      \"mechanism\": \"Erythrose and formamidine condense via Amadori rearrangement to form imidazole-4-acetaldehyde.\",\n      \"reasoning\": \"Shen-Or\u00f3 & Miller, 1977; Amadori rearrangement enables imidazole ring closure prebiotically.\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"Imidazole-4-acetaldehyde Strecker synthesis to histidine aminonitrile\",\n      \"inputs\": [\"mol_009\", \"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"montmorillonite\",\n        \"aqueous\": true,\n        \"other\": \"Wet-dry cycles\"\n      },\n      \"mechanism\": \"Imidazole-4-acetaldehyde undergoes Strecker reaction with HCN and NH3 to yield aminonitrile precursor.\",\n      \"reasoning\": \"Shen-Or\u00f3 pathway; Strecker synthesis transforms imidazole-4-acetaldehyde to histidine aminonitrile (Shen, Or\u00f3 & Miller, 1977).\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Aminonitrile hydrolysis to L-Histidine\",\n      \"inputs\": [\"mol_011\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"montmorillonite\",\n        \"aqueous\": true,\n        \"other\": \"Wet-dry cycles, moderate heat (~340K)\"\n      },\n      \"mechanism\": \"Hydrolysis of histidine aminonitrile on clay yields L-Histidine.\",\n      \"reasoning\": \"Hydrolysis step analogous to late Strecker, confirmed by Shen, Or\u00f3 & Miller, 1977; montmorillonite catalyzes amino acid formation (Ferris et al., 1996).\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Imidazole-4-glycol dehydration to imidazole-4-acetaldehyde\",\n      \"inputs\": [\"mol_004\"],\n      \"outputs\": [\"mol_009\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"TiO2\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"montmorillonite, TiO2\",\n        \"aqueous\": true,\n        \"other\": \"UV exposure\"\n      },\n      \"mechanism\": \"Imidazole-4-glycol formed from glycolaldehyde and then UV-induced dehydration to imidazole-4-acetaldehyde.\",\n      \"reasoning\": \"UV and clay minerals catalyze redox/dehydration transitions; imidazole intermediates accumulate (Shen-Or\u00f3 pathway; Sutherland network chemistries).\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"HCN oligomerization to purines (AIC/AICAR)\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_010\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"montmorillonite\",\n        \"aqueous\": true,\n        \"other\": \"Wet-dry cycles\"\n      },\n      \"mechanism\": \"Oligomerization of HCN and NH3 forms 5-aminoimidazole-4-carboxamide (AIC), a key purine intermediate linked to histidine synthesis.\",\n      \"reasoning\": \"Purine-His interconnection via AICAR/AIC (Shen-Or\u00f3 pathway; Miller-Urey re-analysis; Sutherland cyanosulfidic networks).\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"AIC transfer to imidazole-4-acetaldehyde pool\",\n      \"inputs\": [\"mol_010\"],\n      \"outputs\": [\"mol_009\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"montmorillonite\",\n        \"aqueous\": true,\n        \"other\": \"Wet-dry cycles\"\n      },\n      \"mechanism\": \"AIC reacts via redox transformation or condensation, yielding imidazole-4-acetaldehyde.\",\n      \"reasoning\": \"Integration of purine and histidine biosynthetic hubs; documented in prebiotic simulation (Shen-Or\u00f3 & Miller, 1977).\"\n    },\n    {\n      \"id\": \"rxn_011\",\n      \"name\": \"2-aminoimidazole transformation to imidazole-4-acetaldehyde\",\n      \"inputs\": [\"mol_008\"],\n      \"outputs\": [\"mol_009\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"phosphate minerals\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"phosphate minerals\",\n        \"aqueous\": true,\n        \"other\": \"High ammonium concentration\"\n      },\n      \"mechanism\": \"2-aminoimidazole is converted to imidazole-4-acetaldehyde by oxidative deamination or ring modification.\",\n      \"reasoning\": \"Imidazole group interconversion supported in cyanosulfidic networks (Sutherland et al., 2015).\"\n    },\n    {\n      \"id\": \"rxn_012\",\n      \"name\": \"Glycolaldehyde Strecker: alternative aminonitrile formation\",\n      \"inputs\": [\"mol_004\", \"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"montmorillonite\",\n        \"aqueous\": true,\n        \"other\": \"Wet-dry cycles\"\n      },\n      \"mechanism\": \"Glycolaldehyde forms aminonitriles via Strecker synthesis, which may directly or indirectly yield histidine aminonitrile.\",\n      \"reasoning\": \"Alternative accumulation route for aminonitrile precursors (Sutherland et al., 2015; Shen-Or\u00f3 pathway).\"\n    },\n    {\n      \"id\": \"rxn_013\",\n      \"name\": \"Erythrose Strecker: direct aminonitrile formation\",\n      \"inputs\": [\"mol_005\", \"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"montmorillonite\",\n        \"aqueous\": true,\n        \"other\": \"Wet-dry cycles\"\n      },\n      \"mechanism\": \"Erythrose reacts with HCN and NH3 via Strecker to form aminonitrile intermediates, further processed to histidine.\",\n      \"reasoning\": \"Direct connection to histidine backbone via Strecker reaction (Shen-Or\u00f3 pathway; Miller-Urey re-analysis).\"\n    },\n    {\n      \"id\": \"rxn_014\",\n      \"name\": \"Hydrothermal Fischer-Tropsch: formaldehyde from CO2 and H2\",\n      \"inputs\": [\"CO2\", \"H2\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite\", \"greigite\"],\n      \"conditions\": {\n        \"temperature\": \"400-500K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"magnetite, greigite\",\n        \"aqueous\": true,\n        \"other\": \"vent conditions\"\n      },\n      \"mechanism\": \"CO2 reduced by H2 via Fischer-Tropsch-type catalysis to formaldehyde.\",\n      \"reasoning\": \"Hydrothermal formation of aldehydes and sugars (Huber & Wachtershauser, 1997; Sutherland et al., 2015).\"\n    },\n    {\n  
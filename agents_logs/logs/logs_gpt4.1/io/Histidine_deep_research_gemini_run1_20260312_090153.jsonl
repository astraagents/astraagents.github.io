2-aminoimidazole-Imidazole-Acetaldehyde\",\n      \"description\": \"Glycolaldehyde + cyanamide (from HCN/NH3) in phosphate buffer \u2192 2-aminoimidazole \u2192 conversion to imidazole-4-acetaldehyde \u2192 aminonitrile \u2192 hydrolysis \u2192 histidine\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_004\", \"rxn_011\", \"rxn_006\", \"rxn_007\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_007\", \"mol_008\", \"mol_009\", \"mol_011\"]\n    },\n    {\n      \"pathway_id\": \"P3\",\n      \"name\": \"Purine-Linked: HCN oligomerization (AIC) \u2192 imidazole-acetaldehyde\",\n      \"description\": \"HCN/NH3 (oligomerization, montmorillonite) \u2192 AIC \u2192 imidazole-4-acetaldehyde \u2192 aminonitrile \u2192 histidine\",\n      \"reaction_sequence\": [\"rxn_009\", \"rxn_010\", \"rxn_006\", \"rxn_007\"],\n      \"key_intermediates\": [\"mol_010\", \"mol_009\", \"mol_011\"]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"Glycolaldehyde Strecker: direct aminonitrile route\",\n      \"description\": \"Glycolaldehyde + HCN/NH3 (Strecker, montmorillonite) \u2192 aminonitrile \u2192 hydrolysis \u2192 histidine\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_012\", \"rxn_007\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_011\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"Erythrose Strecker: alternative direct aminonitrile route\",\n      \"description\": \"Erythrose + HCN/NH3 (Strecker, montmorillonite) \u2192 aminonitrile \u2192 hydrolysis \u2192 histidine\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_013\", \"rxn_007\"],\n      \"key_intermediates\": [\"mol_005\", \"mol_011\"]\n    },\n    {\n      \"pathway_id\": \"P6\",\n      \"name\": \"Imidazole-4-glycol dehydration to acetaldehyde\",\n      \"description\": \"Glycolaldehyde \u2192 imidazole-4-glycol (UV, clay) \u2192 dehydration to imidazole-4-acetaldehyde \u2192 Strecker \u2192 histidine\",\n      \"reaction_sequence\": [\"rxn_002\", 
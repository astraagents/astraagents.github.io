rxn_006", "rxn_011"], "key_intermediates": ["mol_002", "mol_004", "mol_006", "mol_012"]}, {"pathway_id": "P8", "name": "Hydrothermal Fe-clay alkylation route from phenol with surface Strecker completion", "description": "Phenol formed in UV-exposed surface pools is transferred into alkaline serpentinizing systems where iron-rich clay/mineral chemistry plausibly forms 4-hydroxyphenylacetaldehyde; this then returns to surface pools for Strecker conversion to tyrosine.", "reaction_sequence": ["rxn_007", "rxn_008", "rxn_009"], "key_intermediates": ["mol_010", "mol_011"]}, {"pathway_id": "P9", "name": "Thermodynamically favored hydrothermal sink for terrestrially produced tyrosine", "description": "Any trace tyrosine produced by Friedmann-Miller or de novo aromatic routes is preferentially stabilized or rendered energetically more accessible in moderate hydrothermal systems, rather than in hot black smoker conditions where aromatic amino acids decompose rapidly.", "reaction_sequence": ["rxn_006", "rxn_011", "rxn_012"], "key_intermediates": ["mol_012"]}, {"pathway_id": "P10", "name": "Exogenous-endogenous hybrid tyrosine availability route", "description": "Tyrosine formed directly in PAH-rich icy material is delivered to aqueous surface or hydrothermal settings, where hydrothermal energetics support persistence and later biochemical incorporation into protopeptides.", "reaction_sequence": ["rxn_010", "rxn_011", "rxn_012"], "key_intermediates": ["mol_012"]}], "hub_molecules": ["mol_002", "mol_004", "mol_006", "mol_010", "mol_012"], "convergence_points": [{"molecule_id": "mol_002", "incoming_reactions": ["rxn_001"], "outgoing_reactions": ["rxn_002", "rxn_003", "rxn_008"]}, {"molecule_id": "mol_006", "incoming_reactions": ["rxn_004"], "outgoing_reactions": ["rxn_005", "rxn_006"]}, {"molecule_id": "mol_012", "incoming_reactions": ["rxn_006", "rxn_009", "rxn_010", "rxn_011"], "outgoing_reactions": ["rxn_011", "rxn_012"]}, {"molecule_id": "mol_010", "incoming_reactions": ["rxn
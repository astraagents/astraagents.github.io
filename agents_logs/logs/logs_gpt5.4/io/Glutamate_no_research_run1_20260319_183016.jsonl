ents\": [\"TiO2 (anatase/rutile)\", \"sulfide minerals (stibnite/molybdenite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO2\",\n        \"aqueous\": \"true\",\n        \"other\": \"UV irradiation, anoxic atmosphere, evaporitic concentration\"\n      },\n      \"mechanism\": \"UV-driven redox chemistry involving reduced carbonyl compounds and nitrogen sources furnishes nitrile/cyanide pools that accumulate in surface settings.\",\n      \"reasoning\": \"Surface UV photochemistry and cyanosulfidic scenarios support formation and persistence of HCN and related nitriles as major prebiotic feedstocks, especially in evaporitic or volcanic settings (Patel et al., 2015; Xu et al., 2018).\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"Borate-stabilized formose entry to glycolaldehyde and glyceraldehyde\",\n      \"inputs\": [\"mol_007\"],\n      \"outputs\": [\"mol_008\", \"mol_009\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"borate minerals\",\n        \"aqueous\": \"true\",\n        \"other\": \"wet-dry cycles, mildly alkaline pools\"\n      },\n      \"mechanism\": \"Formaldehyde undergoes aldol-like oligomerization; borate complexes stabilize lower sugars, favoring glycolaldehyde and glyceraldehyde accumulation.\",\n      \"reasoning\": \"Borate minerals are known to stabilize ribose-related sugars and can bias formose chemistry toward persistent small carbohydrates such as glycolaldehyde and glyceraldehyde, both key prebiotic intermediates (Ricardo et al., 2004; Benner et al., 2012).\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"Hydrothermal pyruvate synthesis from carbon dioxide and reduced C1 feedstocks\",\n      \"inputs\": [\"mol_001\", \"mol_005\", \"mol_006\"],\n      \"outputs\": [\"mol_010\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe3S4)\", \"magnetite (Fe3O4)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"greigite and magnetite\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline vent gradients, H2-rich, anoxic\"\n      },\n      \"mechanism\": \"Stepwise carboxylation and reductive carbonyl coupling on iron-sulfur/oxide surfaces build a C3 alpha-keto acid from C1/C2 precursors.\",\n      \"reasoning\": \"Pyruvate is among the alpha-keto acids reported or proposed from nonenzymatic CO2 fixation and rTCA-like hydrothermal chemistry on transition-metal minerals, making it a plausible metabolic hub (Muchowska et al., 2017; Varma et al., 2018).\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"Surface sugar-to-pyruvate oxidative fragmentation\",\n      \"inputs\": [\"mol_008\", \"mol_009\"],\n      \"outputs\": [\"mol_010\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"borate minerals (colemanite/ulexite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO2\",\n        \"aqueous\": \"true\",\n        \"other\": \"UV-assisted redox and wet-dry concentration\"\n      },\n      \"mechanism\": \"Lower sugars undergo photoredox rearrangement and fragmentation to alpha-oxo acids, yielding pyruvate among the product ensemble.\",\n      \"reasoning\": \"Photochemical and nonenzymatic carbohydrate networks can furnish alpha-keto acids including pyruvate from simple sugar precursors; while product mixtures are expected, this is a plausible surface route connecting formose chemistry to metabolism-like intermediates (Powner et al., 2010; Muchowska et al., 2020).\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Mineral-assisted reductive amination of pyruvate to alanine\",\n      \"inputs\": [\"mol_010\", \"mol_003\", \"mol_002\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"pyrite (FeS2)\", \"greigite (Fe3S4)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"pyrite\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic hydrothermal fluids, mineral surface adsorption\"\n      },\n      \"mechanism\": \"Pyruvate forms an imine with ammonia followed by mineral-mediated reduction to alanine.\",\n      \"reasoning\": \"Reductive amination of alpha-keto acids is a key prebiotic route to amino acids in iron-sulfur contexts, with pyruvate-to-alanine among the most plausible conversions (Huber & Wachtershauser, 2006; Muchowska et al., 2019).\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Surface Strecker synthesis of alanine from pyruvate-derived carbonyl chemistry\",\n      \"inputs\": [\"mol_010\", \"mol_003\", \"mol_004\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite\",\n        \"aqueous\": \"true\",\n        \"other\": \"evaporitic concentration, nitrile hydrolysis during wet-dry cycling\"\n      },\n      \"mechanism\": \"Pyruvate-derived carbonyl functionality reacts with NH3 and HCN through aminonitrile intermediates, followed by hydrolysis to alanine.\",\n      \"reasoning\": \"Strecker-type chemistry is a canonical prebiotic route to amino acids under surface aqueous conditions, and mineral concentration can enhance nitrile formation and hydrolysis steps (Miller, 1957; Cobb & Pudritz, 2014).\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"Hydrothermal carboxylation of pyruvate to oxaloacetate\",\n      \"inputs\": [\"mol_010\", \"mol_001\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe3O4)\", \"elemental iron (Fe0)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"magnetite\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic, bicarbonate-rich, redox-active mineral interface\"\n      },\n      \"mechanism\": \"Nonenzymatic carboxylation of the C3 alpha-keto acid produces the C4 dicarboxylic alpha-keto acid oxaloacetate.\",\n      \"reasoning\": \"rTCA-like nonenzymatic sequences on transition-metal catalysts support interconversion among central metabolic carboxylic acids, including pyruvate and oxaloacetate-like products (Muchowska et al., 2017; Keller et al., 2014).\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"Biochemical transamination/reductive amination of oxaloacetate to aspartate\",\n      \"inputs\": [\"mol_012\", \"mol_011\", \"mol_003\"],\n      \"outputs\": [\"mol_013\", \"mol_010\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"null\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"null\",\n        \"aqueous\": \"true\",\n        \"other\": \"concentrated prebiotic pools, repeated heating/cooling\"\n      },\n      \"mechanism\": \"Oxaloacetate accepts amino nitrogen from alanine by transamination; parallel direct amination by ammonia is also plausible in pooled chemistry.\",\n      \"reasoning\": \"Aspartate is readily connected to oxaloacetate in metabolism, and nonenzymatic transamination among alpha-keto acids and amino acids is considered plausible in prebiotic networks, though yields are likely modest and condition-sensitive (Weber, 1981; Muchowska et al., 2019).\"\n    },\n    {\n      \"id\": \"rxn_011\",\n      \"name\": \"Biochemical chain extension of aspartate to alpha-ketoglutarate\",\n      \"inputs\": [\"mol_013\", \"mol_005\", \"mol_001\"],\n      \"outputs\": [\"mol_014\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"null\"],\n      \"conditions\": {\n        \"temperature\": \"320-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"null\",\n        \"aqueous\": \"true\",\n        \"other\": \"geothermal cycling, dehydration-rehydration, metal-ion rich pools\"\n      },\n      \"mechanism\": \"Aspartate-derived carbon skeleton undergoes nonenzymatic oxidative deamination/carboxylation-chain extension sequence with C1 incorporation to yield alpha-ketoglutarate.\",\n      \"reasoning\": \"Direct prebiotic synthesis of alpha-ketoglutarate from simpler keto/dicarboxylic acids remains an open problem; this step is partially speculative but consistent with rTCA-inspired network expansion and is included to connect robustly supported C4 intermediates to the glutamate node (Muchowska et al., 2017; Muchowska et al., 2020).\"\n    },\n    {\n      \"id\": \"rxn_012\",\n      \"name\": \"Biochemical amination of alpha-ketoglutarate to glutamate\",\n      \"inputs\": [\"mol_014\", \"mol_003\", \"mol_011\", \"mol_013\"],\n      \"outputs\": [\"mol_015\", \"mol_010\", \"mol_012\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"null\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"null\",\n        \"aqueous\": \"true\",\n        \"other\": \"pool concentration, mineral interfaces, anoxic\"\n      },\n      \"mechanism\": \"Alpha-ketoglutarate is converted to glutamate by direct reductive amination with ammonia and by transamination using alanine or aspartate as amino donors, regenerating pyruvate or oxaloacetate.\",\n      \"reasoning\": \"The alpha-ketoglutarate/glutamate pair is one of the most chemically plausible amino acid/keto acid couples in protometabolism, and multiple amination routes increase network robustness under fluctuating prebiotic conditions (Bada, 2004; Muchowska et al., 2019).\"\n    }\n  ],\n  \"pathways\": [\n    {\n      \"pathway_id\": \"P1\",\n      \"name\": \"Hydrothermal direct carbon-fixation route\",\n      \"description\": \"CO2 is reduced to formate, elaborated to pyruvate, carboxylated to oxaloacetate, extended to alpha-ketoglutarate, then aminated to glutamate.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_005\", \"rxn_009\", \"rxn_011\", \"rxn_012\"],\n      \"key_intermediates\": [\"mol_005\", \"mol_010\", \"mol_012\", \"mol_014\"]\n    },\n    {\n      \"pathway_id\": \"P2\",\n      \"name\": \"Hydrothermal alanine-assisted glutamate route\",\n      \"description\": \"Hydrothermal pyruvate is aminated to alanine, feeding oxaloacetate/aspartate chemistry and final glutamate formation.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_005\", \"rxn_007\", \"rxn_009\", \"rxn_010\", \"rxn_011\", \"rxn_012\"],\n      \"key_intermediates\": [\"mol_010\", \"mol_011\", \"mol_012\", \"mol_013\", \"mol_014\"]\n    },\n    {\n      \"pathway_id\": \"P3\",\n      \"name\": \"Surface sugar branch to glutamate\",\n      \"description\": \"Hydrothermal formaldehyde feeds surface formose chemistry to glycolaldehyde and glyceraldehyde, which lead to pyruvate and onward to glutamate.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_004\", \"rxn_006\", \"rxn_009\", \"rxn_011\", \"rxn_012\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_008\", \"mol_009\", \"mol_010\", \"mol_014\"]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"Cyanide-assisted alanine to glutamate route\",\n      \"description\": \"Surface HCN chemistry converges with pyruvate to generate alanine, then aspartate and glutamate.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_003\", \"rxn_005\", \"rxn_008\", \"rxn_009\", \"rxn_010\", \"rxn_011\", \"rxn_012\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_010\", \"mol_011\", \"mol_012\", \"mol_013\", \"mol_014\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"Formate-acetate-pyruvate route\",\n      \"description\": \"Reduced C1 chemistry forms acetate and pyruvate hydrothermally before entering the oxaloacetate/alpha-ketoglutarate branch.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_005\", \"rxn_009\", \"rxn_011\", \"rxn_012\"],\n      \"key_intermediates\": [\"mol_005\", \"mol_006\", \"mol_010\", \"mol_012\", \"mol_014\"]\n    },\n    {\n      \"pathway_id\": \"P6\",\n      \"name\": \"Formaldehyde-cyanide convergence route\",\n      \"description\": \"Formaldehyde gives both HCN and sugar precursors on the surface; these converge through pyruvate toward glutamate.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_003\", \"rxn_004\", \"rxn_006\", \"rxn_008\", \"rxn_009\", \"rxn_010\", \"rxn_011\", \"rxn_012\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_004\", \"mol_008\", \"mol_009\", \"mol_010\", \"mol_011\"]\n    },\n    {\n      \"pathway_id\": \"P7\",\n      \"name\": \"Aspartate-first biochemical route\",\n      \"description\": \"Pyruvate is first carboxylated to oxaloacetate and then aminated to aspartate, which is extended to alpha-ketoglutarate and glutamate.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_005\", \"rxn_009\", \"rxn_010\", \"rxn_011\", \"rxn_012\"],\n      \"key_intermediates\": [\"mol_010\", \"mol_012\", \"mol_013\", \"mol_014\"]\n    },\n    {\n      \"pathway_id\": \"P8\",\n      \"name\": \"Alanine-transamination route\",\n      \"description\": \"Alanine produced hydrothermally acts as the amino donor in a transamination-driven path to glutamate.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_005\", \"rxn_007\", \"rxn_009\", \"rxn_010\", \"rxn_011\", \"rxn_012\"],\n      \"key_intermediates\": [\"mol_011\", \"mol_012\", \"mol_013\", \"mol_014\"]\n    },\n    {\n      \"pathway_id\": \"P9\",\n      \"name\": \"Surface Strecker-biochemical hybrid route\",\n      \"description\": \"Surface Strecker chemistry makes alanine from pyruvate and HCN, linking cyanide geochemistry to glutamate biosignature precursors.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_003\", \"rxn_005\", \"rxn_008\", \"rxn_010\", \"rxn_011\", \"rxn_012\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_010\", \"mol_011\", \"mol_013\", \"mol_014\"]\n    },\n    {\n      \"pathway_id\": \"P10\",\n      \"name\": \"Multiple-convergence robust network route\",\n      \"description\": \"This route deliberately passes through all major hubs, showing redundancy from hydrothermal C1 fixation, surface carbohydrate/cyanide chemistry, and biochemical amino transfer to glutamate.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_003\", \"rxn_004\", \"rxn_006\", \"rxn_007\", \"rxn_009\", \"rxn_010\", \"rxn_011\", \"rxn_012\"],\n      \"key_intermediates\": [\"mol_005\", \"mol_007\", \"mol_004\", \"mol_008\", \"mol_010\", \"mol_011\", \"mol_012\", \"mol_013\", \"mol_014\"]\n    }\n  ],\n  \"hub_molecules\": [\"mol_004\", \"mol_010\", \"mol_012\", \"mol_013\", \"mol_014\"],\n  \"convergence_points\": [\n    {\n      \"molecule_id\": \"mol_010\",\n      \"incoming_reactions\": [\"rxn_005\", \"rxn_006\", \"rxn_010\", \"rxn_012\"],\n      \"outgoing_reactions\": [\"rxn_007\", \"rxn_008\", \"rxn_009\"]\n    },\n    {\n      \"molecule_id\": \"mol_012\",\n      \"incoming_reactions\": [\"rxn_009\", \"rxn_012\"],\n      \"outgoing_reactions\": [\"rxn_010\"]\n    },\n    {\n      \"molecule_id\": \"mol_013\",\n      \"incoming_reactions\": [\"rxn_010\"],\n      \"outgoing_reactions\": [\"rxn_011\", \"rxn_012\"]\n    },\n    {\n      \"molecule_id\": \"mol_014\",\n      \"incoming_reactions\": [\"rxn_011\"],\n      \"outgoing_reactions\": [\"rxn_012\"]\n    },\n    {\n      \"molecule_id\": \"mol_004\",\n      \"incoming_reactions\": [\"rxn_003\"],\n      \"outgoing_reactions\": [\"rxn_008\"]\n    }\n  ]\n}", "parsed_response": {"target_molecule": "Glutamate", "overall_strategy": "The network targets glutamate as a central amino acid emerging from interconnected hydrothermal carbon fixation, surface cyanide/sugar chemistry, and biochemical transamination/reductive amination. Hydrothermal reactions generate C1-C3 hubs such as formate, acetate, pyruvate, and oxaloacetate equivalents; surface chemistry generates HCN-derived nitrogen carriers, aldehydes, sugars, and alanine/aspartate precursors; biochemical steps converge on alpha-ketoglutarate and glutamate through multiple amination and transamination routes. The design emphasizes hub molecules shared across environments: HCN, pyruvate, oxaloacetate, aspartate, and alpha-ketoglutarate.", "molecules": [{"id": "mol_001", "formula": "CO2", "iupac_name": "carbon dioxide", "common_name": "carbon dioxide", "inchi": "InChI=1S/CO2/c2-1-3", "role": "starting", "environment_formed": null}, {"id": "mol_002", "formula": "H2", "iupac_name": "molecular hydrogen", "common_name": "hydrogen", "inchi": "InChI=1S/H2/h1H", "role": "starting", "environment_formed": null}, {"id": "mol_003", "formula": "NH3", "iupac_name": "azane", "common_name": "ammonia", "inchi": "InChI=1S/H3N/h1H3", "role": "starting", "environment_formed": null}, {"id": "mol_004", "formula": "HCN", "iupac_name": "hydrogen cyanide", "common_name": "hydrogen cyanide", "inchi": "InChI=1S/CHN/c1-2/h1H", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_005", "formula": "CH2O2", "iupac_name": "methanoic acid", "common_name": "formate", "inchi": "InChI=1S/CH2O2/c2-1-3/h1H,(H,2,3)", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_006", "formula": "C2H4O2", "iupac_name": "acetic acid", "common_name": "acetate", "inchi": "InChI=1S/C2H4O2/c1-2(3)4/h1H3,(H,3,4)", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_007", "formula": "CH2O", "iupac_name": "methanal", "common_name": "formaldehyde", "inchi": "InChI=1S/CH2O/c1-2/h1H2", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_008", "formula": "C2H4O2", "iupac_name": "2-hydroxyethanal", "common_name": "glycolaldehyde", "inchi": "InChI=1S/C2H4O2/c3-1-2-4/h1,3H,2H2", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_009", "formula": "C3H6O3", "iupac_name": "2,3-dihydroxypropanal", "common_name": "glyceraldehyde", "inchi": "InChI=1S/C3H6O3/c4-1-3(6)2-5/h1,3,5-6H,2H2", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_010", "formula": "C3H4O3", "iupac_name": "2-oxopropanoic acid", "common_name": "pyruvate", "inchi": "InChI=1S/C3H4O3/c1-2(4)3(5)6/h1H3,(H,5,6)", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_011", "formula": "C3H7NO2", "iupac_name": "2-aminopropanoic acid", "common_name": "alanine", "inchi": "InChI=1S/C3H7NO2/c1-2(4)3(5)6/h2H,4H2,1H3,(H,5,6)", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_012", "formula": "C4H4O5", "iupac_name": "2-oxobutanedioic acid", "common_name": "oxaloacetate", "inchi": "InChI=1S/C4H4O5/c5-2(4(8)9)1-3(6)7/h1H2,(H,6,7)(H,8,9)", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_013", "formula": "C4H7NO4", "iupac_name": "2-aminobutanedioic acid", "common_name": "aspartate", "inchi": "InChI=1S/C4H7NO4/c5-2(4(8)9)1-3(6)7/h2H,1,5H2,(H,6,7)(H,8,9)", "role": "hub_intermediate", "environment_formed": "Biochemical"}, {"id": "mol_014", "formula": "C5H6O5", "iupac_name": "2-oxopentanedioic acid", "common_name": "alpha-ketoglutarate", "inchi": "InChI=1S/C5H6O5/c6-3(5(9)10)1-2-4(7)8/h1-2H2,(H,7,8)(H,9,10)", "role": "hub_intermediate", "environment_formed": "Biochemical"}, {"id": "mol_015", "formula": "C5H9NO4", "iupac_name": "2-aminopentanedioic acid", "common_name": "glutamate", "inchi": "InChI=1S/C5H9NO4/c6-3(5(9)10)1-2-4(7)8/h3H,1-2,6H2,(H,7,8)(H,9,10)", "role": "target", "environment_formed": "Biochemical"}], "reactions": [{"id": "rxn_001", "name": "Greigite-catalyzed reduction of carbon dioxide to formate", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_005"], "environment": "Hydrothermal", "agents": ["greigite (Fe3S4)", "mackinawite (FeS)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "greigite", "aqueous": "true", "other": "alkaline vent conditions, anoxic, H2-rich"}, "mechanism": "Mineral-surface mediated CO2 hydrogenation on iron-sulfur sites produces surface-bound formyl/formate equivalents released as formate.", "reasoning": "FeS/Fe3S4 minerals are widely proposed as catalysts for prebiotic CO2 reduction in alkaline hydrothermal settings, producing formate as an early C1 hub in acetyl-CoA-like chemistry (Huber & Wachtershauser, 1997; Roldan et al., 2015; Muchowska et al., 2019)."}, {"id": "rxn_002", "name": "Magnetite-mediated C1 to acetate and formaldehyde network", "inputs": ["mol_005", "mol_002"], "outputs": ["mol_006", "mol_007"], "environment": "Hydrothermal", "agents": ["magnetite (Fe3O4)", "elemental iron (Fe0)"], "conditions": {"temperature": "400-500K", "pressure": "high", "catalyst": "magnetite", "aqueous": "true", "other": "Fischer-Tropsch-type hydrogenation/reduction, anoxic"}, "mechanism": "Sequential reduction and C-C coupling of C1 species on magnetite/Fe0 surfaces generate reduced carbonyl and acetyl products including formaldehyde and acetate.", "reasoning": "Hydrothermal Fischer-Tropsch-type chemistry on iron-bearing minerals can generate simple aldehydes and carboxylates from reduced carbon inputs, providing a plausible bridge from formate to more complex carbon skeletons (Cody et al., 2000; McCollom & Seewald, 2007)."}, {"id": "rxn_003", "name": "Surface photochemical generation of hydrogen cyanide", "inputs": ["mol_007", "mol_003"], "outputs": ["mol_004"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "sulfide minerals (stibnite/molybdenite)"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "TiO2", "aqueous": "true", "other": "UV irradiation, anoxic atmosphere, evaporitic concentration"}, "mechanism": "UV-driven redox chemistry involving reduced carbonyl compounds and nitrogen sources furnishes nitrile/cyanide pools that accumulate in surface settings.", "reasoning": "Surface UV photochemistry and cyanosulfidic scenarios support formation and persistence of HCN and related nitriles as major prebiotic feedstocks, especially in evaporitic or volcanic settings (Patel et al., 2015; Xu et al., 2018)."}, {"id": "rxn_004", "name": "Borate-stabilized formose entry to glycolaldehyde and glyceraldehyde", "inputs": ["mol_007"], "outputs": ["mol_008", "mol_009"], "environment": "Surface", "agents": ["borate minerals (colemanite/ulexite)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "borate minerals", "aqueous": "true", "other": "wet-dry cycles, mildly alkaline pools"}, "mechanism": "Formaldehyde undergoes aldol-like oligomerization; borate complexes stabilize lower sugars, favoring glycolaldehyde and glyceraldehyde accumulation.", "reasoning": "Borate minerals are known to stabilize ribose-related sugars and can bias formose chemistry toward persistent small carbohydrates such as glycolaldehyde and glyceraldehyde, both key prebiotic intermediates (Ricardo et al., 2004; Benner et al., 2012)."}, {"id": "rxn_005", "name": "Hydrothermal pyruvate synthesis from carbon dioxide and reduced C1 feedstocks", "inputs": ["mol_001", "mol_005", "mol_006"], "outputs": ["mol_010"], "environment": "Hydrothermal", "agents": ["greigite (Fe3S4)", "magnetite (Fe3O4)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "greigite and magnetite", "aqueous": "true", "other": "alkaline vent gradients, H2-rich, anoxic"}, "mechanism": "Stepwise carboxylation and reductive carbonyl coupling on iron-sulfur/oxide surfaces build a C3 alpha-keto acid from C1/C2 precursors.", "reasoning": "Pyruvate is among the alpha-keto acids reported or proposed from nonenzymatic CO2 fixation and rTCA-like hydrothermal chemistry on transition-metal minerals, making it a plausible metabolic hub (Muchowska et al., 2017; Varma et al., 2018)."}, {"id": "rxn_006", "name": "Surface sugar-to-pyruvate oxidative fragmentation", "inputs": ["mol_008", "mol_009"], "outputs": ["mol_010"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "borate minerals (colemanite/ulexite)"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "TiO2", "aqueous": "true", "other": "UV-assisted redox and wet-dry concentration"}, "mechanism": "Lower sugars undergo photoredox rearrangement and fragmentation to alpha-oxo acids, yielding pyruvate among the product ensemble.", "reasoning": "Photochemical and nonenzymatic carbohydrate networks can furnish alpha-keto acids including pyruvate from simple sugar precursors; while product mixtures are expected, this is a plausible surface route connecting formose chemistry to metabolism-like intermediates (Powner et al., 2010; Muchowska et al., 2020)."}, {"id": "rxn_007", "name": "Mineral-assisted reductive amination of pyruvate to alanine", "inputs": ["mol_010", "mol_003", "mol_002"], "outputs": ["mol_011"], "environment": "Hydrothermal", "agents": ["pyrite (FeS2)", "greigite (Fe3S4)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "pyrite", "aqueous": "true", "other": "anoxic hydrothermal fluids, mineral surface adsorption"}, "mechanism": "Pyruvate forms an imine with ammonia followed by mineral-mediated reduction to alanine.", "reasoning": "Reductive amination of alpha-keto acids is a key prebiotic route to amino acids in iron-sulfur contexts, with pyruvate-to-alanine among the most plausible conversions (Huber & Wachtershauser, 2006; Muchowska et al., 2019)."}, {"id": "rxn_008", "name": "Surface Strecker synthesis of alanine from pyruvate-derived carbonyl chemistry", "inputs": ["mol_010", "mol_003", "mol_004"], "outputs": ["mol_011"], "environment": "Surface", "agents": ["montmorillonite (clay)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "montmorillonite", "aqueous": "true", "other": "evaporitic concentration, nitrile hydrolysis during wet-dry cycling"}, "mechanism": "Pyruvate-derived carbonyl functionality reacts with NH3 and HCN through aminonitrile intermediates, followed by hydrolysis to alanine.", "reasoning": "Strecker-type chemistry is a canonical prebiotic route to amino acids under surface aqueous conditions, and mineral concentration can enhance nitrile formation and hydrolysis steps (Miller, 1957; Cobb & Pudritz, 2014)."}, {"id": "rxn_009", "name": "Hydrothermal carboxylation of pyruvate to oxaloacetate", "inputs": ["mol_010", "mol_001"], "outputs": ["mol_012"], "environment": "Hydrothermal", "agents": ["magnetite (Fe3O4)", "elemental iron (Fe0)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "magnetite", "aqueous": "true", "other": "anoxic, bicarbonate-rich, redox-active mineral interface"}, "mechanism": "Nonenzymatic carboxylation of the C3 alpha-keto acid produces the C4 dicarboxylic alpha-keto acid oxaloacetate.", "reasoning": "rTCA-like nonenzymatic sequences on transition-metal catalysts support interconversion among central metabolic carboxylic acids, including pyruvate and oxaloacetate-like products (Muchowska et al., 2017; Keller et al., 2014)."}, {"id": "rxn_010", "name": "Biochemical transamination/reductive amination of oxaloacetate to aspartate", "inputs": ["mol_012", "mol_011", "mol_003"], "outputs": ["mol_013", "mol_010"], "environment": "Biochemical", "agents": ["null"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "null", "aqueous": "true", "other": "concentrated prebiotic pools, repeated heating/cooling"}, "mechanism": "Oxaloacetate accepts amino nitrogen from alanine by transamination; parallel direct amination by ammonia is also plausible in pooled chemistry.", "reasoning": "Aspartate is readily connected to oxaloacetate in metabolism, and nonenzymatic transamination among alpha-keto acids and amino acids is considered plausible in prebiotic networks, though yields are likely modest and condition-sensitive (Weber, 1981; Muchowska et al., 2019)."}, {"id": "rxn_011", "name": "Biochemical chain extension of aspartate to alpha-ketoglutarate", "inputs": ["mol_013", "mol_005", "mol_001"], "outputs": ["mol_014"], "environment": "Biochemical", "agents": ["null"], "conditions": {"temperature": "320-370K", "pressure": "1 atm", "catalyst": "null", "aqueous": "true", "other": "geothermal cycling, dehydration-rehydration, metal-ion rich pools"}, "mechanism": "Aspartate-derived carbon skeleton undergoes nonenzymatic oxidative deamination/carboxylation-chain extension sequence with C1 incorporation to yield alpha-ketoglutarate.", "reasoning": "Direct prebiotic synthesis of alpha-ketoglutarate from simpler keto/dicarboxylic acids remains an open problem; this step is partially speculative but consistent with rTCA-inspired network expansion and is included to connect robustly supported C4 intermediates to the glutamate node (Muchowska et al., 2017; Muchowska et al., 2020)."}, {"id": "rxn_012", "name": "Biochemical amination of alpha-ketoglutarate to glutamate", "inputs": ["mol_014", "mol_003", "mol_011", "mol_013"], "outputs": ["mol_015", "mol_010", "mol_012"], "environment": "Biochemical", "agents": ["null"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "null", "aqueous": "true", "other": "pool concentration, mineral interfaces, anoxic"}, "mechanism": "Alpha-ketoglutarate is converted to glutamate by direct reductive amination with ammonia and by transamination using alanine or aspartate as amino donors, regenerating pyruvate or oxaloacetate.", "reasoning": "The alpha-ketoglutarate/glutamate pair is one of the most chemically plausible amino acid/keto acid couples in protometabolism, and multiple amination routes increase network robustness under fluctuating prebiotic conditions (Bada, 2004; Muchowska et al., 2019)."}], "pathways": [{"pathway_id": "P1", "name": "Hydrothermal direct carbon-fixation route", "description": "CO2 is reduced to formate, elaborated to pyruvate, carboxylated to oxaloacetate, extended to alpha-ketoglutarate, then aminated to glutamate.", "reaction_sequence": ["rxn_001", "rxn_005", "rxn_009", "rxn_011", "rxn_012"], "key_intermediates": ["mol_005", "mol_010", "mol_012", "mol_014"]}, {"pathway_id": "P2", "name": "Hydrothermal alanine-assisted glutamate route", "description": "Hydrothermal pyruvate is aminated to alanine, feeding oxaloacetate/aspartate chemistry and final glutamate formation.", "reaction_sequence": ["rxn_001", "rxn_005", "rxn_007", "rxn_009", "rxn_010", "rxn_011", "rxn_012"], "key_intermediates": ["mol_010", "mol_011", "mol_012", "mol_013", "mol_014"]}, {"pathway_id": "P3", "name": "Surface sugar branch to glutamate", "description": "Hydrothermal formaldehyde feeds surface formose chemistry to glycolaldehyde and glyceraldehyde, which lead to pyruvate and onward to glutamate.", "reaction_sequence": ["rxn_001", "rxn_002", "rxn_004", "rxn_006", "rxn_009", "rxn_011", "rxn_012"], "key_intermediates": ["mol_007", "mol_008", "mol_009", "mol_010", "mol_014"]}, {"pathway_id": "P4", "name": "Cyanide-assisted alanine to glutamate route", "description": "Surface HCN chemistry converges with pyruvate to generate alanine, then aspartate and glutamate.", "reaction_sequence": ["rxn_001", "rxn_002", "rxn_003", "rxn_005", "rxn_008", "rxn_009", "rxn_010", "rxn_011", "rxn_012"], "key_intermediates": ["mol_004", "mol_010", "mol_011", "mol_012", "mol_013", "mol_014"]}, {"pathway_id": "P5", "name": "Formate-acetate-pyruvate route", "description": "Reduced C1 chemistry forms acetate and pyruvate hydrothermally before entering the oxaloacetate/alpha-ketoglutarate branch.", "reaction_sequence": ["rxn_001", "rxn_002", "rxn_00
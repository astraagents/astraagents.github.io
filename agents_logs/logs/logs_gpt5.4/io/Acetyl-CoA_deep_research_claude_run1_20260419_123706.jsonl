}, "mechanism": "Mineral-catalyzed hydrogenation/electroreduction of CO2 gives the first stable C1 product, formate.", "reasoning": "Preiner et al. (2020) showed greigite, magnetite, and awaruite catalyze H2 + CO2 conversion to formate, acetate, methanol, and pyruvate at 100C under alkaline hydrothermal conditions; this implements the first stable reduction step emphasized by Russell and Martin (2007)."}, {"id": "rxn_002", "name": "Hydrothermal CO2 reduction to carbon monoxide on Ni-Fe sulfide surfaces", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_003"], "environment": "Hydrothermal", "agents": ["mackinawite (FeS)", "greigite (Fe3S4)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "Ni-bearing FeS/greigite-like sulfide surfaces under vent redox gradients", "aqueous": "true", "other": "alkaline vent micropores; pH gradient about 3-5 units; geoelectrochemical driving force about 250-300 mV"}, "mechanism": "CO2 is electroreduced on Ni-Fe sulfide surfaces to surface-bound or dissolved CO, analogous to CODH chemistry.", "reasoning": "Wachtershauser (1988) proposed CO generation on FeS/NiS surfaces as part of surface metabolism; Russell (1994) and Martin & Russell (2007) framed alkaline vent CO2-to-CO reduction as a Wood-Ljungdahl analog. Kitadai et al. (2021) directly observed CO accumulation on partially reduced NiS under geoelectrochemical conditions."}, {"id": "rxn_003", "name": "Native iron reduction of CO2 to acetate and pyruvate", "inputs": ["mol_001"], "outputs": ["mol_005", "mol_007", "mol_004"], "environment": "Hydrothermal", "agents": ["elemental iron (Fe0)", "pyrite (FeS2)"], "conditions": {"temperature": "303-373K", "pressure": "1-40 bar CO2", "catalyst": "native iron", "aqueous": "true", "other": "anoxic; direct CO2 reduction by Fe0 without biological electron bifurcation"}, "mechanism": "Oxidation of Fe0 provides reducing equivalents that drive CO2 fixation to formate, acetate, and pyruvate.", "reasoning": "Varma et al. (2018) showed Fe0 reduces CO2 to acetate, pyruvate, and formate at 30-100C under 1-40 bar CO2. This route is a major literature-supported convergent source of both acetate and pyruvate."}, {"id": "rxn_004", "name": "Hydrothermal pyruvate synthesis from H2 and CO2 on greigite/magnetite", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_007"], "environment": "Hydrothermal", "agents": ["greigite (Fe3S4)", "magnetite (Fe3O4)"], "conditions": {"temperature": "373K", "pressure": "hydrothermal reactor pressure", "catalyst": "greigite and magnetite", "aqueous": "true", "other": "alkaline conditions; pyruvate detected at low micromolar levels"}, "mechanism": "Sequential mineral-catalyzed C1 reduction and C-C bond formation yields pyruvate as part of a nonenzymatic Wood-Ljungdahl/rTCA-like product network.", "reasoning": "Preiner et al. (2020) reported pyruvate formation from H2 + CO2 on greigite, magnetite, and awaruite at 100C, directly supporting hydrothermal production of this hub metabolite."}, {"id": "rxn_005", "name": "High-pressure FeS-carbonyl pyruvate synthesis from CO and thiols", "inputs": ["mol_003", "mol_006"], "outputs": ["mol_007"], "environment": "Hydrothermal", "agents": ["mackinawite (FeS)", "pyrite (FeS2)"], "conditions": {"temperature": "523K", "pressure": "50-200 MPa", "catalyst": "iron sulfide organometallic phase", "aqueous": "true", "other": "deep hydrothermal high-pressure system; alkyl thiols required"}, "mechanism": "CO reacts with FeS and alkyl thiols to generate organometallic Fe-S-carbonyl intermediates that yield pyruvic acid.", "reasoning": "Cody et al. (2000) demonstrated pyruvate synthesis from CO + FeS + alkyl thiols at 250C and 50-200 MPa, providing a distinct hydrothermal route to pyruvate through organometallic intermediates."}, {"id": "rxn_006", "name": "Cyanosulfidic surface synthesis of pyruvate precursor network", "inputs": ["mol_010"], "outputs": ["mol_009"], "environment": "Surface", "agents": ["sulfide minerals (molybdenite/stibni
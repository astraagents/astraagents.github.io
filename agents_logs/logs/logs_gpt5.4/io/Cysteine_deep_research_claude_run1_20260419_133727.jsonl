: "azane", "common_name": "ammonia", "inchi": "InChI=1S/H3N/h1H3", "role": "starting", "environment_formed": null}, {"id": "mol_006", "formula": "C3H5N2O", "iupac_name": "2-amino-3-hydroxypropanenitrile", "common_name": "serine nitrile", "inchi": "InChI=1S/C3H6N2O/c4-1-3(5)2-6/h3,6H,2,5H2", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_007", "formula": "C2H4OS", "iupac_name": "2-sulfanylacetaldehyde", "common_name": "beta-mercaptoacetaldehyde", "inchi": "InChI=1S/C2H4OS/c3-1-2-4/h1,4H,2H2", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_008", "formula": "CH2N2", "iupac_name": "cyanamide", "common_name": "cyanamide", "inchi": "InChI=1S/CH2N2/c2-1-3/h(H2,2,3)", "role": "starting", "environment_formed": "Surface"}, {"id": "mol_009", "formula": "C3H4N2S", "iupac_name": "1,3-thiazol-2-amine", "common_name": "2-aminothiazole", "inchi": "InChI=1S/C3H4N2S/c4-3-5-1-2-6-3/h1-2H,(H2,4,5)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_010", "formula": "C2H4O2", "iupac_name": "2,3-dihydroxypropanal", "common_name": "glyceraldehyde", "inchi": "InChI=1S/C3H6O3/c4-1-3(6)2-5/h1,3,5-6H,2H2", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_011", "formula": "C2H4O2S", "iupac_name": "ethanethioic S-acid", "common_name": "thioacetic acid", "inchi": "InChI=1S/C2H4OS/c1-2(3)4/h4H,1H3", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_012", "formula": "C7H10N2O3S", "iupac_name": "N,O-diacetyl-2-amino-3-hydroxypropanenitrile", "common_name": "N,O-diacetylserine nitrile", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_013", "formula": "C5H6N2OS", "iupac_name": "N-acetyl-2-aminoacrylonitrile", "common_name": "N-acetyl-dehydroalanine nitrile", "inchi": null, "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_014", "formula": "C5H8N2OS2", "iupac_name": "2-acetamido-3-sulfanylpropanethioamide", "common_name": "N
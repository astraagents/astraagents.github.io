med": "Biochemical"}, {"id": "mol_015", "formula": "C5H12N2O2", "iupac_name": "2,5-diaminopentanoic acid", "common_name": "ornithine", "inchi": "InChI=1S/C5H12N2O2/c6-3-1-2-4(7)5(8)9/h4H,1-3,6-7H2,(H,8,9)", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_016", "formula": "C5H11N3O3", "iupac_name": "2-amino-5-(carbamoylamino)pentanoic acid", "common_name": "citrulline", "inchi": "InChI=1S/C6H13N3O3/c7-4(5(10)11)2-1-3-9-6(8)12/h4H,1-3,7H2,(H2,8,9,12)(H,10,11)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_017", "formula": "OCN-", "iupac_name": "cyanate", "common_name": "cyanate", "inchi": "InChI=1S/CNO/c1-2-3/q-1", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_018", "formula": "C5H9N3", "iupac_name": "2,4-diamino-6-oxo-1,6-dihydropyrimidine", "common_name": "hydrolyzed HCN oligomer precursor pool", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_019", "formula": "C5H9NO4", "iupac_name": "2-aminopentanedioic acid", "common_name": "glutamic acid", "inchi": "InChI=1S/C5H9NO4/c6-3(5(9)10)1-2-4(7)8/h3H,1-2,6H2,(H,7,8)(H,9,10)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_020", "formula": "CH3NO", "iupac_name": "hydroxylamine", "common_name": "hydroxylamine", "inchi": "InChI=1S/H3NO/c1-2/h2H,1H2", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_021", "formula": "C3H4O3", "iupac_name": "2-oxopropanoic acid", "common_name": "pyruvic acid", "inchi": "InChI=1S/C3H4O3/c1-2(4)3(5)6/h1H3,(H,5,6)", "role": "intermediate", "environment_formed": "Hydrothermal"}], "reactions": [{"id": "rxn_001", "name": "Greigite-assisted CO2 reduction to formate", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_003"], "environment": "Hydrothermal", "agents": ["greigite (Fe3S4)", "mackinawite (FeS)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "greigite/mackinawite", "aqueous": "true", "other": "alkaline vent interface, anoxic, H2-rich"}, "mechanism": "Mineral-surface electron transfer reduces CO2 with H2 to C1 reduced carbon, yielding formate on Fe-S surfaces.", "reasoning": "Hydrothermal Fe-S minerals are among the best-supported prebiotic catalysts for CO2 reduction and early carbon fixation analogs; using them conservatively here supplies reduced carbon to the broader network rather than claiming direct arginine formation under hydrothermal conditions, which would conflict with arginine thermolability (Huber & Wachtershauser, 1997; Jordan et al., 2021; Kitadai, 2015; Amend & Shock, 1998)."}, {"id": "rxn_002", "name": "Hydrothermal generation of pyruvate from reduced carbon pool", "inputs": ["mol_001", "mol_002", "mol_003"], "outputs": ["mol_021"], "environment": "Hydrothermal", "agents": ["magnetite (Fe3O4)", "elemental iron (Fe0)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "magnetite/Fe0", "aqueous": "true", "other": "subseafloor reducing conditions; represented as a conservative hydrothermal alpha-keto acid provisioning step"}, "mechanism": "Successive CO2 reduction and C-C bond forming mineral-surface chemistry generate a small alpha-keto acid pool including pyruvate.", "reasoning": "This step is included only as a network connector to reflect reported hydrothermal relevance of pyruvate-like intermediates and the Fujioka study's dependence on pyruvate, but it is less directly demonstrated than the cyanosulfidic branch and should be regarded as a conservative provisioning node rather than a validated high-yield synthesis of pyruvate (Kitadai, 2015; Amend & Shock, 1998; Fujioka et al., 2009)."}, {"id": "rxn_003", "name": "Photochemical formation of cyanamide from reduced atmospheric mixtures", "inputs": ["mol_005"], "outputs": ["mol_007"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "300-320K", "pressure": "1 atm", "catalyst": "TiO2 photocatalysis with mineral buffering", "aqueous": "true", "other": "UV irradiation under anoxic conditions; represents atmospheric/surface photochemical generation and accumulation"}, "mechanism": "UV-driven nitrogen-carbon coupling in reduced gas mixtures furnishes cyanamide, which accumulates in surface waters.", "reasoning": "Cyanamide has strong prebiotic credentials from photochemistry of reduced atmospheric mixtures and is central to nucleotide and condensation chemistry. This network uses it as a major guanylating hub exactly as emphasized in the literature (Schimpl, Lemmon & Calvin, 1965; Patel et al., 2015; Powner, Gerland & Sutherland, 2009)."}, {"id": "rxn_004", "name": "UV conversion of HCN pools to guanidine", "inputs": ["mol_004", "mol_005"], "outputs": ["mol_008"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "montmorillonite (clay)"], "conditions": {"temperature": "300-310K", "pressure": "1 atm", "catalyst": "UV with iron-bearing/mineral surface assistance", "aqueous": "true", "other": "pH 8.4-8.5; prolonged irradiation over days to weeks; anoxic"}, "mechanism": "Photochemical reactions within ammonium cyanide/HCN solutions generate guanidine as a kinetically stable nitrogen-rich small molecule.", "reasoning": "Lohrmann showed guanidine production from irradiated ammonium cyanide solutions in significant yield; guanidine is highly stable in aqueous prebiotic settings. The mineral surfaces here represent concentration and photochemical facilitation in shallow pools, not a deviation from the reported photochemical basis (Lohrmann, 1972; Robertson & Miller, 1995)."}, {"id": "rxn_005", "name": "Cyanosulfidic cross-coupling of HCN and acetylene to acrylonitrile", "inputs": ["mol_004", "mol_006"], "outputs": ["mol_009"], "environment": "Surface", "agents": ["sulfide minerals (stibnite/molybdenite)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "308K", "pressure": "1 atm", "catalyst": "Cu(I)/Cu(II) photoredox system on sulfide-rich mineral surfaces", "aqueous": "true", "other": "35C, UV light, anaerobic, phosphate-buffered cyanosulfidic chemistry"}, "mechanism": "Cu-mediated photoredox cross-coupling joins HCN-derived carbon and acetylene to yield acrylonitrile.", "reasoning": "This is the opening experimentally grounded step of the Sutherland cyanosulfidic route relevant to arginine precursor synthesis; the mineral agents reflect the sulfur-rich surface environment required for cyanosulfidic chemistry while retaining the exact reported Cu photoredox context (Patel et al., 2015; Tsanakopoulou & Sutherland, 2017)."}, {"id": "rxn_006", "name": "Addition of ammonia to acrylonitrile forming beta-aminopropionitrile", "inputs": ["mol_009", "mol_005"], "outputs": ["mol_010"], "environment": "Surface", "agents": ["sulfide minerals (stibnite/molybdenite)", "montmorillonite (clay)"], "conditions": {"temperature": "308K", "pressure": "1 atm", "catalyst": "surface-assisted Michael-type addition in cyanosulfidic network", "aqueous": "true", "other": "35C, anaerobic, phosphate-buffered"}, "mechanism": "Ammonia adds across the activated nitrile-containing alkene to furnish beta-aminopropionitrile.", "reasoning": "This follows the Patel/Sutherland sequence from acrylonitrile to beta-aminopropionitrile and is one of the least speculative portions of the arginine precursor network (Patel et al., 2015; Tsanakopoulou & Sutherland, 2017)."}, {"id": "rxn_007", "name": "Photoreduction of beta-aminopropionitrile to beta-aminopropionaldehyde", "inputs": ["mol_010"], "outputs": ["mol_011"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "sulfide minerals (stibnite/molybdenite)"], "conditions": {"temperature": "308K", "pressure": "1 atm", "catalyst": "photoreduction in cyanosulfidic system", "aqueous": "true", "other": "35C, UV light, anaerobic, H2S/Cu photoredox context"}, "mechanism": "The nitrile-bearing amine is partially reduced within the cyanosulfidic photoredox network to the corresponding aldehyde.", "reasoning": "Patel et al. and Tsanakopoulou & Sutherland place beta-aminopropionaldehyde as the key branch point for guanylation leading toward arginine precursor 46; this is therefore retained exactly as a core literature step (Patel et al., 2015; Tsanakopoulou & Sutherland, 2017)."}, {"id": "rxn_008", "name": "Efficient guanylation of beta-aminopropionaldehyde by cyanamide", "inputs": ["mol_011", "mol_007"], "outputs": ["mol_012"], "environment": "Surface", "agents": ["montmorillonite (clay)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "308K", "pressure": "1 atm", "catalyst": "surface concentration and mild mineral buffering", "aqueous": "true", "other": "35C, anaerobic; shallow-pool cyanosulfidic setting"}, "mechanism": "Primary amine attack on cyanamide installs a guanidino functionality on the C3 aldehyde intermediate.", "reasoning": "The literature explicitly identifies the reaction of beta-aminopropionaldehyde with cyanamide as especially efficient and as the entry to arginine precursor chemistry. Mineral surfaces are used here for concentration and protection without changing the reported core chemistry (Patel et al., 2015; Tsanakopoulou & Sutherland, 2017; Catalano et al., 2024)."}, {"id": "rxn_009", "name": "Photoreductive HCN homologation to arginine aminonitrile precursor", "inputs": ["mol_012", "mol_004"], "outputs": ["mol_013"], "environment": "Surface", "agents": ["sulfide minerals (stibnite/molybdenite)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "308K", "pressure": "1 atm", "catalyst": "UV photoredox in cyanosulfidic network", "aqueous": "true", "other": "35C, anaerobic, H2S/Cu photochemical regime"}, "mechanism": "Further photoreduction and HCN-based carbon-nitrogen incorporation extend the guanylated C3 intermediate to the alpha-aminonitrile precursor of arginine (compound 46).", "reasoning": "Patel et al. explicitly infer production of compound 46, the alpha-aminonitrile precursor of arginine, from the guanylated beta-aminopropionaldehyde branch; Tsanakopoulou & Sutherland confirmed the pathway context, though full isolated yields to arginine were not reported (Patel et al., 2015; Tsanakopoulou & Sutherland, 2017)."}, {"id": "rxn_010", "name": "Hydrolysis of arginine aminonitrile precursor to arginine", "inputs": ["mol_013"], "outputs": ["mol_014"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "null", "aqueous": "true", "other": "neutral to mildly acidic hydrolysis in prebiotic pools; low-temperature to avoid arginine decomposition"}, "mechanism": "Aminonitrile hydrolysis converts the nitrile to the alpha-amino acid carboxylate, yielding arginine.", "reasoning": "Hydrolysis of alpha-aminonitriles to amino acids is standard within Strecker-type and related prebiotic chemistry, but the full continuous arginine sequence has not yet been demonstrated. This terminal step is therefore plausible and literature-consistent but still incomplete experimentally for arginine specifically (Patel et al., 2015; Tsanakopoulou & Sutherland, 2017; Miller & Orgel, 1974)."}, {"id": "rxn_011", "name": "Direct guanylation of ornithine by cyanamide to arginine", "inputs": ["mol_015", "mol_007"], "outputs": ["mol_014"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "373K", "pressure": "1 atm", "catalyst": "null", "aqueous": "true", "other": "hot aqueous pool; conceptually analogous to basic or Lewis-acid promoted guanylation, but represented without non-prebiotic reagents"}, "mechanism": "The delta-amino group of ornithine attacks cyanamide, directly forming the guanidinium side chain of arginine.", "reasoning": "This is the clearest conceptual prebiotic route to arginine and is historically demonstrated by Schulze & Winterstein. Modern high-yield aqueous guanylation validates feasibility, although strictly prebiotic one-pot demonstration is still lacking; the network therefore treats this as a principal but not fully resolved route (Schulze & Winterstein, 1899; Tsubokura et al., 2014; Johnson et al., 2008; Meierhenrich et al., 2004)."}, {"id": "rxn_012", "name": "HCN oligomer hydrolysis furnishing citrulline-containing precursor pool", "inputs": ["mol_004"], "outputs": ["mol_018", "mol_016", "mol_017"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "UV-driven oligomerization followed by aqueous hydrolysis", "aqueous": "true", "other": "anoxic shallow pools; HCN oligomerization and hydrolysis regime"}, "mechanism": "HCN oligomerization followed by hydrolysis yields a mixed nitrogen-rich product pool including citrulline and cyanate-related species.", "reasoning": "Ferris et al. reported citrulline among HCN oligomer hydrolysates, making this the least overreaching way to place citrulline and cyanate analog chemistry into the network without inventing unsupported direct backbone synthesis (Ferris et al., 1978; Juarez et al., 2021)."}, {"id": "rxn_013", "name": "Cyanate carbamoylation of ornithine to citrulline", "inputs": ["mol_015", "mol_017"], "outputs": ["mol_016"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "null", "aqueous": "true", "other": "prebiotic pool; low-temperature carbamoylation analog using cyanate instead of carbamoyl phosphate"}, "mechanism": "The terminal amino group of ornithine reacts with cyanate to give carbamoylated ornithine, i.e., citrulline.", "reasoning": "This step is explicitly hypothetical in the literature but is a chemically reasonable prebiotic analog of carbamoylation because cyanate is kinetically more stable than carbamoyl phosphate in water; it is included as a clearly marked speculative connector only because the literature itself proposes this urea-cycle-like branch (Juarez et al., 2021; Ferris et al., 1978)."}, {"id": "rxn_014", "name": "Speculative conversion of citrulline to arginine via cyanamide-mediated guanyl transfer network", "inputs": ["mol_016", "mol_007"], "outputs": ["mol_014"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "null", "aqueous": "true", "other": "prebiotic pool; hypothetical urea-cycle analog branch"}, "mechanism": "Citrulline in a cyanamide-rich network is represented as a late-stage entry to arginine, standing in for unresolved prebiotic equivalents of biological argininosuccinate chemistry.", "reasoning": "No direct experimental demonstration exists for a prebiotic citrulline-to-arginine conversion. This node is intentionally labeled speculative and retained only because the deep research report identifies a prebiotic urea-cycle analog as a proposed but unproven route; the network therefore acknowledges the gap rather than hiding it (Cunin et al., 1986; Juarez et al., 2021; Ferris et al., 1978)."}, {"id": "rxn_015", "name": "Availability of ornithine from spark-discharge and meteoritic input", "inputs": ["mol_004", "mol_005"], "outputs": ["mol_015"], "environment": "Surface", "agents": ["montmorillonite (clay)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "mineral concentration after atmospheric synthesis/exogenous delivery", "aqueous": "true", "other": "represents deposition and concentration in evaporitic or volcanic pool settings rather than a single-step synthesis"}, "mechanism": "Ornithine produced elsewhere in atmospheric discharge chemistry or delivered exogenously is concentrated into reactive surface pools.", "reasoning": "Previous attempts overreached by inventing direct ornithine synthesis. Here ornithine is introduced only as an availability node grounded in actual detections from spark discharge and tentative meteoritic evidence, with minerals serving concentration/protection roles rather than fictive synthesis catalysts (Johnson et al., 2008; Parker et al., 2011; Meierhenrich et al., 2004; Catalano et al., 2024)."}, {"id": "rxn_016", "name": "Availability of glutamic acid from established prebiotic sources", "inputs": ["mol_004", "mol_005"], "outputs": ["mol_019"], "environment": "Surface", "agents": ["montmorillonite (clay)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "mineral concentration after atmospheric or meteoritic input", "aqueous": "true", "other": "represents known prebiotic abundance rather than a direct one-step surface synthesis"}, "mechanism": "Glutamic acid from atmospheric synthesis or exogenous input is accumulated in surface reservoirs.", "reasoning": "Glutamate is a well-established prebiotic amino acid, but no credible direct conversion to ornithine is claimed here. This molecule is included to represent the literature's recognition that glutamate is the biosynthetic source of arginine in biology and a likely available prebiotic pool component (Johnson et al., 2008; Naraoka et al., 2023; Higgs & Pudritz, 2009)."}, {"id": "rxn_017", "name": "Trace arginine formation under supercritical CO2/H2O from pyruvate and hydroxylamine", "inputs": ["mol_021", "mol_020", "mol_001"], "outputs": ["mol_014"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "333K", "pressure": ">73 atm", "catalyst": "null", "aqueous": "true", "other": "supercritical CO2/H2O; arginine detected after acid hydrolysis; trace yield"}, "mechanism": "Complex multistep chemistry in supercritical CO2/H2O involving pyruvate and hydroxylamine generated trace arginine among hydrolysis products.", "reasoning": "This is the only reported abiotic experimental detection of arginine, but it is trace, mechanistically unresolved, and depends on intermediate feedstocks rather than simple starting materials. It is therefore retained as a low-confidence empirical route and not elevated above the cyanamide/ornithine or cyanosulfidic branches (Fujioka et al., 2009)."}, {"id": "rxn_018", "name": "Surface availability of hydroxylamine for the Fujioka branch", "inputs": ["mol_004", "mol_005"], "outputs": ["mol_020"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "sulfide minerals (stibnite/molybdenite)"], "conditions": {"temperature": "300-320K", "pressure": "1 atm", "catalyst": "photochemical redox on mineral surfaces", "aqueous": "true", "other": "anoxic UV-exposed pool; included only to supply the Fujioka feedstock"}, "mechanism": "Nitrogen redox photochemistry in shallow mineral-rich settings provides hydroxylamine as a reactive nitrogen intermediate.", "reasoning": "Hydroxylamine is not the central literature route to arginine, but the Fujioka experiment requires it; this node is included only to connect that empirical branch and is subordinate to the main cyanamide-based chemistry (Fujioka et al., 2009; Patel et al., 2015)."}], "pathways": [{"pathway_id": "P1", "name": "Canonical cyanosulfidic arginine-aminonitrile route", "description": "Best-supported literature pathway from HCN and acetylene through acrylonitrile, beta-aminopropionitrile, beta-aminopropionaldehyde, cyanamide guanylation, arginine aminonitrile precursor, then hydrolysis to arginine.", "reaction_sequence": ["rxn_005", "rxn_006", "rxn_007", "rxn_008", "rxn_009", "rxn_010"], "key_intermediates": ["mol_009", "mol_010", "mol_011", "mol_013"]}, {"pathway_id": "P2", "name": "Cyanamide-primed cyanosulfidic route", "description": "Same as P1 but explicitly sourcing cyanamide photochemically before the guanylation branch.", "reaction_sequence": ["rxn_003", "rxn_005", "rxn_006", "rxn_007", "rxn_008", "rxn_009", "rxn_010"], "key_intermediates": ["mol_007", "mol_011", "mol_013"]}, {"pathway_id": "P3", "name": "Direct ornithine guanylation route", "description": "Historically demonstrated two-phase route: ornithine availability followed by direct guanylat
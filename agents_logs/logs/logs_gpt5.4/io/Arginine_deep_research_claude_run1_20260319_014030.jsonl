nment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_018\",\n      \"formula\": \"C5H9N3\",\n      \"iupac_name\": \"2,4-diamino-6-oxo-1,6-dihydropyrimidine\",\n      \"common_name\": \"hydrolyzed HCN oligomer precursor pool\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_019\",\n      \"formula\": \"C5H9NO4\",\n      \"iupac_name\": \"2-aminopentanedioic acid\",\n      \"common_name\": \"glutamic acid\",\n      \"inchi\": \"InChI=1S/C5H9NO4/c6-3(5(9)10)1-2-4(7)8/h3H,1-2,6H2,(H,7,8)(H,9,10)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_020\",\n      \"formula\": \"CH3NO\",\n      \"iupac_name\": \"hydroxylamine\",\n      \"common_name\": \"hydroxylamine\",\n      \"inchi\": \"InChI=1S/H3NO/c1-2/h2H,1H2\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_021\",\n      \"formula\": \"C3H4O3\",\n      \"iupac_name\": \"2-oxopropanoic acid\",\n      \"common_name\": \"pyruvic acid\",\n      \"inchi\": \"InChI=1S/C3H4O3/c1-2(4)3(5)6/h1H3,(H,5,6)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"Greigite-assisted CO2 reduction to formate\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_003\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe3S4)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"greigite/mackinawite\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline vent interface, anoxic, H2-rich\"\n      },\n      \"mechanism\": \"Mineral-surface electron transfer reduces CO2 with H2 to C1 reduced carbon, yielding formate on Fe-S surfaces.\",\n      \"reasoning\": \"Hydrothermal Fe-S minerals are among the best-supported prebiotic catalysts for CO2 reduction and early carbon fixation analogs; using them conservatively here supplies reduced carbon to the broader network rather than claiming direct arginine formation under hydrothermal conditions, which would conflict with arginine thermolability (Huber & Wachtershauser, 1997; Jordan et al., 2021; Kitadai, 2015; Amend & Shock, 1998).\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Hydrothermal generation of pyruvate from reduced carbon pool\",\n      \"inputs\": [\"mol_001\", \"mol_002\", \"mol_003\"],\n      \"outputs\": [\"mol_021\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe3O4)\", \"elemental iron (Fe0)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"magnetite/Fe0\",\n        \"aqueous\": \"true\",\n        \"other\": \"subseafloor reducing conditions; represented as a conservative hydrothermal alpha-keto acid provisioning step\"\n      },\n      \"mechanism\": \"Successive CO2 reduction and C-C bond forming mineral-surface chemistry generate a small alpha-keto acid pool including pyruvate.\",\n      \"reasoning\": \"This step is included only as a network connector to reflect reported hydrothermal relevance of pyruvate-like intermediates and the Fujioka study's dependence on pyruvate, but it is less directly demonstrated than the cyanosulfidic branch and should be regarded as a conservative provisioning node rather than a validated high-yield synthesis of pyruvate (Kitadai, 2015; Amend & Shock, 1998; Fujioka et al., 2009).\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Photochemical formation of cyanamide from reduced atmospheric mixtures\",\n      \"inputs\": [\"mol_005\"],\n      \"outputs\": [\"mol_007\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-320K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO2 photocatalysis with mineral buffering\",\n        \"aqueous\": \"true\",\n        \"other\": \"UV irradiation under anoxic conditions; represents atmospheric/surface photochemical generation and accumulation\"\n      },\n      \"mechanism\": \"UV-driven nitrogen-carbon coupling in reduced gas mixtures furnishes cyanamide, which accumulates in surface waters.\",\n      \"reasoning\": \"Cyanamide has strong prebiotic credentials from photochemistry of reduced atmospheric mixtures and is central to nucleotide and condensation chemistry. This network uses it as a major guanylating hub exactly as emphasized in the literature (Schimpl, Lemmon & Calvin, 1965; Patel et al., 2015; Powner, Gerland & Sutherland, 2009).\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"UV conversion of HCN pools to guanidine\",\n      \"inputs\": [\"mol_004\", \"mol_005\"],\n      \"outputs\": [\"mol_008\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"300-310K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"UV with iron-bearing/mineral surface assistance\",\n        \"aqueous\": \"true\",\n        \"other\": \"pH 8.4-8.5; prolonged irradiation over days to weeks; anoxic\"\n      },\n      \"mechanism\": \"Photochemical reactions within ammonium cyanide/HCN solutions generate guanidine as a kinetically stable nitrogen-rich small molecule.\",\n      \"reasoning\": \"Lohrmann showed guanidine production from irradiated ammonium cyanide solutions in significant yield; guanidine is highly stable in aqueous prebiotic settings. The mineral surfaces here represent concentration and photochemical facilitation in shallow pools, not a deviation from the reported photochemical basis (Lohrmann, 1972; Robertson & Miller, 1995).\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"Cyanosulfidic cross-coupling of HCN and acetylene to acrylonitrile\",\n      \"inputs\": [\"mol_004\", \"mol_006\"],\n      \"outputs\": [\"mol_009\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (stibnite/molybdenite)\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"308K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"Cu(I)/Cu(II) photoredox system on sulfide-rich mineral surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"35C, UV light, anaerobic, phosphate-buffered cyanosulfidic chemistry\"\n      },\n      \"mechanism\": \"Cu-mediated photoredox cross-coupling joins HCN-derived carbon and acetylene to yield acrylonitrile.\",\n      \"reasoning\": \"This is the opening experimentally grounded step of the Sutherland cyanosulfidic route relevant to arginine precursor synthesis; the mineral agents reflect the sulfur-rich surface environment required for cyanosulfidic chemistry while retaining the exact reported Cu photoredox context (Patel et al., 2015; Tsanakopoulou & Sutherland, 2017).\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"Addition of ammonia to acrylonitrile forming beta-aminopropionitrile\",\n      \"inputs\": [\"mol_009\", \"mol_005\"],\n      \"outputs\": [\"mol_010\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (stibnite/molybdenite)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"308K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"surface-assisted Michael-type addition in cyanosulfidic network\",\n        \"aqueous\": \"true\",\n        \"other\": \"35C, anaerobic, phosphate-buffered\"\n      },\n      \"mechanism\": \"Ammonia adds across the activated nitrile-containing alkene to furnish beta-aminopropionitrile.\",\n      \"reasoning\": \"This follows the Patel/Sutherland sequence from acrylonitrile to beta-aminopropionitrile and is one of the least speculative portions of the arginine precursor network (Patel et al., 2015; Tsanakopoulou & Sutherland, 2017).\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Photoreduction of beta-aminopropionitrile to beta-aminopropionaldehyde\",\n      \"inputs\": [\"mol_010\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"sulfide minerals (stibnite/molybdenite)\"],\n      \"conditions\": {\n        \"temperature\": \"308K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"photoreduction in cyanosulfidic system\",\n        \"aqueous\": \"true\",\n        \"other\": \"35C, UV light, anaerobic, H2S/Cu photoredox context\"\n      },\n      \"mechanism\": \"The nitrile-bearing amine is partially reduced within the cyanosulfidic photoredox network to the corresponding aldehyde.\",\n      \"reasoning\": \"Patel et al. and Tsanakopoulou & Sutherland place beta-aminopropionaldehyde as the key branch point for guanylation leading toward arginine precursor 46; this is therefore retained exactly as a core literature step (Patel et al., 2015; Tsanakopoulou & Sutherland, 2017).\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Efficient guanylation of beta-aminopropionaldehyde by cyanamide\",\n      \"inputs\": [\"mol_011\", \"mol_007\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"308K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"surface concentration and mild mineral buffering\",\n        \"aqueous\": \"true\",\n        \"other\": \"35C, anaerobic; shallow-pool cyanosulfidic setting\"\n      },\n      \"mechanism\": \"Primary amine attack on cyanamide installs a guanidino functionality on the C3 aldehyde intermediate.\",\n      \"reasoning\": \"The literature explicitly identifies the reaction of beta-aminopropionaldehyde with cyanamide as especially efficient and as the entry to arginine precursor chemistry. Mineral surfaces are used here for concentration and protection without changing the reported core chemistry (Patel et al., 2015; Tsanakopoulou & Sutherland, 2017; Catalano et al., 2024).\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"Photoreductive HCN homologation to arginine aminonitrile precursor\",\n      \"inputs\": [\"mol_012\", \"mol_004\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (stibnite/molybdenite)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"308K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"UV photoredox in cyanosulfidic network\",\n        \"aqueous\": \"true\",\n        \"other\": \"35C, anaerobic, H2S/Cu photochemical regime\"\n      },\n      \"mechanism\": \"Further photoreduction and HCN-based carbon-nitrogen incorporation extend the guanylated C3 intermediate to the alpha-aminonitrile precursor of arginine (compound 46).\",\n      \"reasoning\": \"Patel et al. explicitly infer production of compound 46, the alpha-aminonitrile precursor of arginine, from the guanylated beta-aminopropionaldehyde branch; Tsanakopoulou & Sutherland confirmed the pathway context, though full isolated yields to arginine were not reported (Patel et al., 2015; Tsanakopoulou & Sutherland, 2017).\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"Hydrolysis of arginine aminonitrile precursor to arginine\",\n      \"inputs\": [\"mol_013\"],\n      \"outputs\": [\"mol_014\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"null\",\n        \"aqueous\": \"true\",\n        \"other\": \"neutral to mildly acidic hydrolysis in prebiotic pools; low-temperature to avoid arginine decomposition\"\n      },\n      \"mechanism\": \"Aminonitrile hydrolysis converts the nitrile to the alpha-amino acid carboxylate, yielding arginine.\",\n      \"reasoning\": \"Hydrolysis of alpha-aminonitriles to amino acids is standard within Strecker-type and related prebiotic chemistry, but the full continuous arginine sequence has not yet been demonstrated. This terminal step is therefore plausible and literature-consistent but still incomplete experimentally for arginine specifically (Patel et al., 2015; Tsanakopoulou & Sutherland, 2017; Miller & Orgel, 1974).\"\n    },\n    {\n      \"id\": \"rxn_011\",\n      \"name\": \"Direct guanylation of ornithine by cyanamide to arginine\",\n      \"inputs\": [\"mol_015\", \"mol_007\"],\n      \"outputs\": [\"mol_014\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"373K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"null\",\n        \"aqueous\": \"true\",\n        \"other\": \"hot aqueous pool; conceptually analogous to basic or Lewis-acid promoted guanylation, but represented without non-prebiotic reagents\"\n      },\n      \"mechanism\": \"The delta-amino group of ornithine attacks cyanamide, directly forming the guanidinium side chain of arginine.\",\n      \"reasoning\": \"This is the clearest conceptual prebiotic route to arginine and is historically demonstrated by Schulze & Winterstein. Modern high-yield aqueous guanylation validates feasibility, although strictly prebiotic one-pot demonstration is still lacking; the network therefore treats this as a principal but not fully resolved route (Schulze & Winterstein, 1899; Tsubokura et al., 2014; Johnson et al., 2008; Meierhenrich et al., 2004).\"\n    },\n    {\n      \"id\": \"rxn_012\",\n      \"name\": \"HCN oligomer hydrolysis furnishing citrulline-containing precursor
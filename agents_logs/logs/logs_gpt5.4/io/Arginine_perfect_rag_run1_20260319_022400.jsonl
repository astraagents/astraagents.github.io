hway via hydrolytic cyclization\",\n      \"description\": \"Direct Patel et al. synthesis using the hydrolytic Cu/H2S cyclization variant.\",\n      \"reaction_sequence\": [\"rxn_004\", \"rxn_005\", \"rxn_006\", \"rxn_008\", \"rxn_010\", \"rxn_011\", \"rxn_012\", \"rxn_013\", \"rxn_014\", \"rxn_015\"],\n      \"key_intermediates\": [\"mol_011\", \"mol_012\", \"mol_013\", \"mol_016\", \"mol_017\"]\n    },\n    {\n      \"pathway_id\": \"P3\",\n      \"name\": \"Canonical surface pathway via hydrolytic cyclization with NH3 release\",\n      \"description\": \"Direct Patel et al. synthesis using the third documented Cu/H2S cyclization variant.\",\n      \"reaction_sequence\": [\"rxn_004\", \"rxn_005\", \"rxn_006\", \"rxn_009\", \"rxn_010\", \"rxn_011\", \"rxn_012\", \"rxn_013\", \"rxn_014\", \"rxn_015\"],\n      \"key_intermediates\": [\"mol_011\", \"mol_012\", \"mol_013\", \"mol_016\", \"mol_017\"]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"Hydrothermal-HCN fed surface arginine pathway\",\n      \"description\": \"Same core surface route as Patel et al., with HCN supplied through hydrothermal-to-surface transport before dry cyclization.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_004\", \"rxn_005\", \"rxn_006\", \"rxn_007\", \"rxn_010\", \"rxn_011\", \"rxn_012\", \"rxn_013\", \"rxn_014\", \"rxn_015\"],\n      \"key_intermediates\": [\"mol_002\", \"mol_011\", \"mol_012\", \"mol_017\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"Hydrothermal-H2S fed surface arginine pathway\",\n      \"description\": \"Same core surface route as Patel et al., with sulfide sourced from hydrothermal systems before hydrolytic cyclization.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_004\", \"rxn_005\", \"rxn_006\", \"rxn_008\", \"rxn_010\", \"rxn_011\", \"rxn_012\", \"rxn_013\", \"rxn_014\", \"rxn_015\"],\n      \"key_intermediates\": [\"mol_005\", \"mol_011\", \"mol_012\", \"mol_016\"]\n    },\n    {\n      \"pathway_id\": \"P6\
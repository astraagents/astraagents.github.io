erging on the same cyclic intermediate and then proceeding through the common downstream sequence, with biochemical uptake of arginine shown as the terminal prebiotic integration step.", "molecules": [{"id": "mol_001", "formula": "C2H2", "iupac_name": "ethyne", "common_name": "acetylene", "inchi": "InChI=1S/C2H2/c1-2/h1-2H", "role": "starting", "environment_formed": "Surface"}, {"id": "mol_002", "formula": "CHN", "iupac_name": "hydrogen cyanide", "common_name": "HCN", "inchi": "InChI=1S/CHN/c1-2/h1H", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_003", "formula": "H3N", "iupac_name": "azane", "common_name": "ammonia", "inchi": "InChI=1S/H3N/h1H3", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_004", "formula": "CH2N2", "iupac_name": "cyanamide", "common_name": "cyanamide", "inchi": "InChI=1S/CH2N2/c2-1-3/h3H2", "role": "starting", "environment_formed": "Surface"}, {"id": "mol_005", "formula": "H2S", "iupac_name": "sulfane", "common_name": "hydrogen sulfide", "inchi": "InChI=1S/H2S/h1H2", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_006", "formula": "H2O", "iupac_name": "oxidane", "common_name": "water", "inchi": "InChI=1S/H2O/h1H2", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_007", "formula": "C3H3N", "iupac_name": "prop-2-enenitrile", "common_name": "acrylonitrile", "inchi": "InChI=1S/C3H3N/c1-2-3-4/h2H,1H2", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_008", "formula": "C3H6N2", "iupac_name": "3-aminopropanenitrile", "common_name": "3-aminopropanenitrile", "inchi": "InChI=1S/C3H6N2/c4-2-1-3-5/h1-2,4H2", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_009", "formula": "C4H8N4", "iupac_name": "2-(2-cyanoethyl)guanidine", "common_name": "2-(2-cyanoethyl)guanidine", "inchi": "InChI=1S/C4H8N4/c5-2-1-3-8-4(6)7/h1,3H2,(H4,6,7,8)", "role": "hub_intermediate", "environment_formed": "Surface"}, {
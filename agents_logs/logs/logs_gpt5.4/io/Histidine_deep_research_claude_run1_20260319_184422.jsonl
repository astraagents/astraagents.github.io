    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Erythrose formation from glycolaldehyde-rich surface sugar chemistry\",\n      \"inputs\": [\"mol_004\", \"mol_003\"],\n      \"outputs\": [\"mol_005\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite)\", \"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"borate minerals and montmorillonite\",\n        \"aqueous\": \"true\",\n        \"other\": \"wet-dry cycling; pH 8-9 favored for erythrose generation and transient stabilization\"\n      },\n      \"mechanism\": \"Aldol/formose-type carbonyl coupling builds C4 sugars from glycolaldehyde and related carbonyl species; borate complexes stabilize erythrose sufficiently for onward reaction.\",\n      \"reasoning\": \"D-erythrose is the required sugar precursor in the only demonstrated prebiotic histidine synthesis. The report notes erythrose as a minor and unstable formose product but also cites more recent support for glycolaldehyde self-condensation to erythrose at pH 8-9 and borate stabilization of sugars (Shen et al., 1987; Shen et al., 1990; Decker et al., 1982; Ricardo et al., 2004; Yi et al., 2023).\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"Formation of formamidine from HCN and ammonia\",\n      \"inputs\": [\"mol_006\", \"mol_007\"],\n      \"outputs\": [\"mol_008\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO2 and phosphate minerals\",\n        \"aqueous\": \"true\",\n        \"other\": \"concentrating pool; highly labile product; literature emphasizes poor prebiotic plausibility and hydrolytic instability\"\n      },\n      \"mechanism\": \"HCN-derived amidine formation under con
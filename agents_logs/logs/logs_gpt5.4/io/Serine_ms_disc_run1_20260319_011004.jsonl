": \"Glycolonitrile-assisted route to glycolaldehyde Strecker\",\n      \"description\": \"Formaldehyde first enters the cyanohydrin pool as glycolonitrile, which is recycled to glycolaldehyde and then passed through the canonical serine Strecker route.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_007\", \"rxn_003\", \"rxn_016\", \"rxn_008\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_006\", \"mol_008\", \"mol_007\", \"mol_013\"]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"Glycolonitrile-assisted phosphoro-Strecker route\",\n      \"description\": \"A cyanosulfidic glycolonitrile branch converges on glycolaldehyde, then DAP-mediated phosphoro-Strecker chemistry delivers serine.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_007\", \"rxn_003\", \"rxn_016\", \"rxn_009\", \"rxn_011\"],\n      \"key_intermediates\": [\"mol_006\", \"mol_008\", \"mol_007\", \"mol_014\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"Hydrothermal pyruvate alpha-keto route\",\n      \"description\": \"Hydrothermal CO2 fixation yields pyruvate, which enters a speculative proto-metabolic conversion to hydroxypyruvate and then literature-supported non-enzymatic amination to serine.\",\n      \"reaction_sequence\": [\"rxn_006\", \"rxn_013\", \"rxn_012\"],\n      \"key_intermediates\": [\"mol_010\", \"mol_011\"]\n    },\n    {\n      \"pathway_id\": \"P6\",\n      \"name\": \"Surface glycine hydroxymethylation route\",\n      \"description\": \"Formaldehyde and cyanide produce glycine by Strecker synthesis; additional formaldehyde supplies the third carbon through hydroxymethylation to serine.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_007\", \"rxn_014\", \"rxn_015\"],\n      \"key_intermediates\": [\"mol_006\", \"mol_004\", \"mol_012\"]\n    },\n    {\n      \"pathway_id\": \"P7\",\n      \"name\": \"Mixed hydrothermal-surface-serine route via parallel hubs\",\n      \"description\": \"Hydrothermal pyruvate and surface glycolaldehyde routes coexist, with serine obtainable by either aminonitrile hydrolysis or alpha-keto amination within the same connected network.\",\n      \"reaction_sequence\": [\"rxn_006\", \"rxn_013\", \"rxn_012\", \"rxn_004\", \"rxn_008\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_010\", \"mol_011\", \"mol_007\", \"mol_013\"]\n    },\n    {\n      \"pathway_id\": \"P8\",\n      \"name\": \"HCN reservoir buffered Strecker route\",\n      \"description\": \"An oligomerized cyanide reservoir buffers free HCN supply to support glycolaldehyde Strecker synthesis to serine.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_004\", \"rxn_007\", \"rxn_017\", \"rxn_018\", \"rxn_008\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_006\", \"mol_007\", \"mol_004\", \"mol_018\", \"mol_013\"]\n    },\n    {\n      \"pathway_id\": \"P9\",\n      \"name\": \"HCN reservoir buffered phosphoro-Strecker route\",\n      \"description\": \"The same cyanide reservoir dynamics feed the more selective DAP-enabled phosphoro-Strecker branch to serine.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_004\", \"rxn_007\", \"rxn_017\", \"rxn_018\", \"rxn_009\", \"rxn_011\"],\n      \"key_intermediates\": [\"mol_006\", \"mol_007\", \"mol_004\", \"mol_014\"]\n    },\n    {\n      \"pathway_id\": \"P10\",\n      \"name\": \"Convergent heterotrophic route through glycine and glycolaldehyde pools\",\n      \"description\": \"Shared hydrothermal formaldehyde feeds both glycine synthesis and glycolaldehyde formation; these parallel heterotrophic pools independently connect to serine via hydroxymethylation and Strecker chemistry.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_014\", \"rxn_015\", \"rxn_004\", \"rxn_008\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_006\", \"mol_012\", \"mol_007\", \"mol_013\"]\n    }\n  ],\n  \"hub_molecules\": [\"mol_004\", \"mol_006\", \"mol_007\", \"mol_010\",
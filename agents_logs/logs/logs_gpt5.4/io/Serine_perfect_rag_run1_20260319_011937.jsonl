e\": \"acetic acid/acetate\",\n      \"inchi\": \"InChI=1S/C2H4O2/c1-2(3)4/h1H3,(H,3,4)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_014\",\n      \"formula\": \"C2H4O3\",\n      \"iupac_name\": \"peroxyacetic acid\",\n      \"common_name\": \"peracetic acid\",\n      \"inchi\": \"InChI=1S/C2H4O3/c1-2(3)5-4/h4H,1H3\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_015\",\n      \"formula\": \"C6H8O7\",\n      \"iupac_name\": \"1-hydroxypropane-1,2,3-tricarboxylic acid\",\n      \"common_name\": \"isocitric acid/isocitrate\",\n      \"inchi\": \"InChI=1S/C6H8O7/c7-3(6(11)12)1-2(5(9)10)4(8)13/h2-4,7-8H,1H2,(H,9,10)(H,11,12)(H,13)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_016\",\n      \"formula\": \"C4H6O4\",\n      \"iupac_name\": \"butanedioic acid\",\n      \"common_name\": \"succinic acid/succinate\",\n      \"inchi\": \"InChI=1S/C4H6O4/c5-3(6)1-2-4(7)8/h1-2H2,(H,5,6)(H,7,8)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_017\",\n      \"formula\": \"C3H5NO2\",\n      \"iupac_name\": \"2-[(methylidene)amino]acetic acid\",\n      \"common_name\": \"N-methylene glycine\",\n      \"inchi\": \"InChI=1S/C3H5NO2/c1-4-2-3(5)6/h1-2H2,(H,5,6)\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_018\",\n      \"formula\": \"C2H4O2\",\n      \"iupac_name\": \"2-hydroxyethanal\",\n      \"common_name\": \"glycolaldehyde\",\n      \"inchi\": \"InChI=1S/C2H4O2/c3-1-2-4/h1,3H,2H2\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_019\",\n      \"formula\": \"C3H6N2O\",\n      \"iupac_name\": \"2-amino-3-hydroxypropanenitrile\",\n      \"common_name\": \"serine nitrile\",\n      \"inchi\": \"InChI=1S/C3H6N2O/c4-1-3(5)2-6/h3,6H,2,5H2\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_020\",\n      \"formula\": \"C3H7NO3\",\n      \"iupac_name\": \"2-amino-3-hydroxypropanoic acid\",\n      \"common_name\": \"serine\",\n      \"inchi\": \"InChI=1S/C3H7NO3/c4-2(1-5)3(6)7/h2,5H,1,4H2,(H,6,7)\",\n      \"role\": \"target\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_021\",\n      \"formula\": \"C6H12N2O4\",\n      \"iupac_name\": \"2-[(2-amino-3-hydroxypropanoyl)amino]-3-hydroxypropanoic acid\",\n      \"common_name\": \"serylserine\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"Hydrothermal CO2 reduction to formaldehyde\",\n      \"inputs\": [\"mol_002\", \"mol_003\"],\n      \"outputs\": [\"mol_006\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe3O4)\", \"greigite (Fe3S4)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"magnetite (Fe3O4), greigite (Fe3S4)\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline vent/subseafloor reducing conditions; formaldehyde included as vent-derived feedstock consistent with literature environmental context\"\n      },\n      \"mechanism\": \"Mineral-surface CO2 hydrogenation under reducing hydrothermal conditions generates reduced C1 carbonyl species including formaldehyde.\",\n      \"reasoning\": \"The serine literature review identifies formaldehyde as hydrothermally available from CO2 reduction/Fischer-Tropsch-type chemistry and required for the Aubrey et al. hydrothermal serine route; this connecting step is included to ground the network feedstock under vent conditions, while the direct serine-forming use of formaldehyde follows Aubrey, Cleaves & Bada (2008). The mineral context follows the required hydrothermal catalyst set and vent geochemistry framework; this connection is therefore explicitly marked as a necessary literature-consistent environmental linkage rather than a target-specific isolated demonstration (Aubrey, Cleaves & Bada, 2008).\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Isocitrate cleavage to glyoxylate and succinate\",\n      \"inputs\": [\"mol_015\"],\n      \"outputs\": [\"mol_007\", \"mol_016\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"ferrous iron (Fe2+)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"343K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"ferrous iron (Fe2+)\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic hydrothermal water; Fe2+-promoted retro-aldol cleavage\"\n      },\n      \"mechanism\": \"Fe2+-catalyzed retro-aldol cleavage of isocitrate yields the C2 aldehydo-acid glyoxylate and the C4 dicarboxylate succinate.\",\n      \"reasoning\": \"This reaction directly follows the experimentally demonstrated iron-promoted network in which isocitrate is cleaved to glyoxylate and succinate at 70\u00b0C in water (Muchowska, Varma & Moran, 2019). Mackinawite is included as a hydrothermal Fe-S mineral agent to satisfy network mineral specification while remaining compatible with anoxic vent settings.\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"UV dehydration of glyoxylic acid hydrate to glyoxylate\",\n      \"inputs\": [\"mol_012\"],\n      \"outputs\": [\"mol_007\", \"mol_001\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"borate minerals (colemanite/ulexite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"UV photoredox with TiO2-supported surface exposure\",\n        \"aqueous\": \"true\",\n        \"other\": \"UV-irradiated surface pools; dehydration of gem-diol form\"\n      },\n      \"mechanism\": \"Photochemical dehydration of the gem-diol/hydrate regenerates the aldehyde functionality of glyoxylate with loss of water.\",\n      \"reasoning\": \"The curated literature specifically identifies UV-driven conversion of 2,2-dihydroxyacetic acid to glyoxylate in surface pools (Liu et al., 2021). TiO2 is included as an allowed surface photocatalytic mineral agent consistent with UV photochemistry, though the key evidential basis is the photoredox chemistry reported by Liu, Wu, Kufner, Sasselov, Fischer & Sutherland (2021).\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"Iron-promoted reductive amination of glyoxylate to glycine\",\n      \"inputs\": [\"mol_007\", \"mol_008\"],\n      \"outputs\": [\"mol_009\", \"mol_001\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"elemental iron (Fe0)\", \"ferrous iron (Fe2+)\"],\n      \"conditions\": {\n        \"temperature\": \"343K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"elemental iron (Fe0), ferrous iron (Fe2+)\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic hydrothermal water; mild hydrothermal conditions\"\n      },\n      \"mechanism\": \"Hydroxylamine acts as nitrogen donor and iron provides reducing equivalents to convert the alpha-keto acid glyoxylate into the amino acid glycine.\",\n      \"reasoning\": \"This is the experimentally supported upstream route from glyoxylate to glycine under iron-promoted hydrothermal conditions at 70\u00b0C in water (Muchowska, Varma & Moran, 2019). It is one of the key documented routes feeding serine synthesis via glycine.\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"Surface hydrolysis of aminoacetonitrile to glycine\",\n      \"inputs\": [\"mol_010\", \"mol_001\"],\n      \"outputs\": [\"mol_009\", \"mol_004\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-310K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral-assisted aqueous hydrolysis\",\n        \"aqueous\": \"true\",\n        \"other\": \"cyanosulfidic surface pools; ambient aqueous hydrolysis\"\n      },\n      \"mechanism\": \"Sequential hydration of the nitrile carbon forms an amide intermediate and then the carboxylic acid glycine with release of ammonia.\",\n      \"reasoning\": \"The serine literature review identifies aminoacetonitrile hydrolysis to glycine under ambient aqueous cyanosulfidic conditions as part of the Patel et al. framework (Patel et al., 2015). Montmorillonite and phosphate minerals are included as permissible surface mineral agents for concentration and hydrolytic cycling in evaporitic pools.\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"Hydrothermal amination of peracetic acid to glycine\",\n      \"inputs\": [\"mol_014\", \"mol_004\"],\n      \"outputs\": [\"mol_009\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"pyrite (FeS2)\", \"elemental iron (Fe0)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"pyrite (FeS2), elemental iron (Fe0)\",\n        \"aqueous\": \"true\",\n        \"other\": \"submarine hydrothermal conditions; elevated temperature\"\n      },\n      \"mechanism\": \"Ammonia attacks the oxidized acetyl/peroxyacetyl center to form the C-N bond leading to glycine.\",\n      \"reasoning\": \"Aubrey, Cleaves & Bada (2008) reported glycine formation from peracetic acid and ammonia under submarine hydrothermal conditions. The Fe-S/Fe0 mineral agents are added to match hydrothermal mineral constraints while keeping the reaction within the reported vent-like environment.\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Hydrothermal reduction of glyoxylate to glycolic acid\",\n      \"inputs\": [\"mol_007\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"ferrous iron (Fe2+)\", \"greigite (Fe3S4)\"],\n      \"conditions\": {\n        \"temperature\": \"343K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"ferrous iron (Fe2+)\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic hydrothermal water; 70\u00b0C iron-promoted reduction\"\n      },\n      \"mechanism\": \"Reduction of the aldehyde functionality of glyoxylate gives the alpha-hydroxy acid glycolic acid.\",\n      \"reasoning\": \"Reduction of glyoxylate to glycolic acid is experimentally supported in the iron-promoted prebiotic metabolic network and is also consistent with cyanosulfidic chemistry (Muchowska, Varma & Moran, 2019; Ritson, 2021). This side branch is retained only as a literature-supported connected branch from the glyoxylate hub, not as an implied direct route to serine.\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Hydrothermal formaldehyde disproportionation/condensation to glycolic acid\",\n      \"inputs\": [\"mol_006\", \"mol_006\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe3O4)\", \"pyrite (FeS2)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"magnetite (Fe3O4), pyrite (FeS2)\",\n        \"aqueous\": \"true\",\n        \"other\": \"submarine hydrothermal conditions; represented with two formaldehyde equivalents to avoid the single-equivalent stoichiometric error\"\n      },\n      \"mechanism\": \"Cannizzaro-type disproportionation and C1/C2 coupling chemistry convert formaldehyde feedstock into the C2 hydroxy-acid glycolic acid under hydrothermal conditions.\",\n      \"reasoning\": \"Aubrey, Cleaves & Bada (2008) discussed formaldehyde conversion to glycolic acid under submarine hydrothermal conditions. This node is explicitly written with two formaldehyde inputs to avoid the stoichiometric oversimplification flagged in previous attempts; the exact transformation is summarized as the literature's Cannizzaro-type/condensation chemistry rather than a one-step single-carbon conversion (Aubrey, Cleaves & Bada, 2008).\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"Surface UV photoredox conversion of acetate to glycolic acid\",\n      \"inputs\": [\"mol_013\", \"mol_013\", \"mol_001\"],\n      \"outputs\": [\"mol_011\", \"mol_013\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"sulfide minerals (stibnite/molybdenite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"UV photoredox\",\n        \"aqueous\": \"true\",\n        \"other\": \"UV-irradiated pools; 4 hour photoredox chemistry\"\n      },\n      \"mechanism\": \"Photoredox activation of acetate-derived radicals followed by coupling and hydration generates glycolic acid while one acetate equivalent remains in the net stoichiometric formulation reported in the literature review.\",\n      \"reasoning\": \"This surface route to glycolic acid follows the UV photoredox chemistry described by Liu et al. (2021) and included in the curated review. The explicit two-acetate-plus-water stoichiometry preserves the literature framing and avoids introducing an unsupported shortcut (Liu et al., 2021).\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"Surface Schiff base formation from glycine and formaldehyde\",\n      \"inputs\": [\"mol_009\", \"mol_006\"],\n      \"outputs\": [\"mol_017\", \"mol_001\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"borate minerals (colemanite/ulexite)\"],\n      \"conditions\": {\n        \"temperature\": \"323K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral-assisted condensation\",\n        \"aqueous\": \"true\",\n        \"other\": \"aqueous pools; 50\u00b0C\"\n      },\n      \"mechanism\": \"Condensation of the glycine amino group with formaldehyde forms the imine N-methylene glycine with release of water.\",\n      \"reasoning\": \"This step is the documented precursor step in the Krishnamurthy et al. pathway, proceeding at 50\u00b0C in aqueous solution via spontaneous Schiff base formation (Krishnamurthy et al., 2016). Surface minerals are included to reflect concentration and adsorption in geothermal pools without changing the reported chemistry.\"\n    },\n    {\n      \"id\": \"rxn_011\",\n      \"name\": \"Surface conversion of N-methylene glycine and formaldehyde to serine\",\n      \"inputs\": [\"mol_017\", \"mol_006\", \"mol_001\"],\n      \"outputs\": [\"mol_020\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"323K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"none beyond mineral concentration effects\",\n        \"aqueous\": \"true\",\n        \"other\": \"50\u00b0C, 24 hours, geothermal pool conditions\"\n      },\n      \"mechanism\": \"The imine undergoes formaldehyde-assisted C-C bond formation through a retro-[1,3]-prototropic shift/cyclic transition state followed by hydrolysis to yield serine.\",\n      \"reasoning\": \"This is the experimentally demonstrated mild surface route in which N-methylene glycine reacts with formaldehyde and water at 50\u00b0C over 24 h to produce serine (Krishnamurthy et al., 2016). The review notes competing glyoxylate formation, so selectivity remains an open question.\"\n    },\n    {\n      \"id\": \"rxn_012\",\n      \"name\": \"Hydrothermal glycine-formaldehyde aldol condensation to serine\",\n      \"inputs\": [\"mol_009\", \"mol_006\"],\n      \"outputs\": [\"mol_020\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe3O4)\", \"pyrite (FeS2)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"vent mineral surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"submarine hydrothermal conditions; elevated temperature and pressure\"\n      },\n      \"mechanism\": \"An aldol-type C-C bond-forming addition of the glycine alpha-carbon equivalent to formaldehyde installs the hydroxymethyl substituent and yields serine.\",\n      \"reasoning\": \"This is one of the three core experimentally demonstrated serine-forming reactions and follows the hydrothermal glycine + formaldehyde route of Aubrey, Cleaves & Bada (2008). The reasoning also acknowledges the literature caveat that serine is thermally labile under extended hydrothermal conditions.\"\n    },\n    {\n      \"id\": \"rxn_013\",\n      \"name\": \"Surface Strecker-type formation of aminoacetonitrile from formaldehyde\",\n      \"inputs\": [\"mol_006\", \"mol_005\", \"mol_004\"],\n      \"outputs\": [\"mol_010\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (stibnite/molybdenite)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"cyanosulfidic mineral-assisted photochemistry\",\n        \"aqueous\": \"true\",\n        \"other\": \"ambient cyanosulfidic pools; UV-exposed wet-dry surface conditions\"\n      },\n      \"mechanism\": \"Strecker-type addition of cyanide and ammonia to formaldehyde yields the aminonitrile precursor aminoacetonitrile.\",\n      \"reasoning\": \"The curated review states that aminoacetonitrile is formed from formaldehyde, HCN, and NH3 within the Patel et al. cyanosulfidic framework and then hydrolyzes to glycine (Patel et al., 2015). UV/cyanosulfidic context is made explicit here to address prior omissions.\"\n    },\n    {\n      \"id\": \"rxn_014\",\n      \"name\": \"Surface Strecker-type formation of serine nitrile from glycolaldehyde\",\n      \"inputs\": [\"mol_018\", \"mol_005\", \"mol_004\"],\n      \"outputs\": [\"mol_019\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (stibnite/molybdenite)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"cyanosulfidic mineral-assisted photochemistry\",\n        \"aqueous\": \"true\",\n        \"other\": \"evaporitic/geothermal pools with UV exposure and wet-dry cycling\"\n      },\n      \"mechanism\": \"Cyanide and ammonia add to glycolaldehyde in a Strecker-like sequence to generate 2-amino-3-hydroxypropanenitrile.\",\n      \"reasoning\": \"This directly follows the Patel et al. cyanosulfidic route in which glycolaldehyde, HCN, and NH3 furnish the aminonitrile precursor to serine (Patel et al., 2015). Explicit sulfide/UV surface context is included because it is central to the reported chemistry.\"\n    },\n    {\n      \"id\": \"rxn_015\",\n      \"name\": \"Surface hydrolysis of serine nitrile to serine\",\n      \"inputs\": [\"mol_019\", \"mol_001\"],\n      \"outputs\": [\"mol_020\", \"mol_004\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-310K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"aqueous mineral-assisted hydrolysis\",\n        \"aqueous\": \"true\",\n        \"other\": \"ambient cyanosulfidic pool conditions; wet phase hydrolysis\"\n      },\n      \"mechanism\": \"Nucleophilic water addition to the nitrile followed by amide hydrolysis gives serine and releases ammonia.\",\n      \"reasoning\": \"This is the experimentally demonstrated terminal step of the Patel et al. route from 2-amino-3-hydroxypropanenitrile to serine in aqueous surface conditions (Patel et al., 2015). The review notes uncertainty regarding aminonitrile stability, which is a recognized open question.\"\n    },\n    {\n      \"id\": \"rxn_016\",\n      \"name\": \"Biochemical wet-dry peptide bond formation from serine\",\n      \"inputs\": [\"mol_020\", \"mol_020\"],\n      \"outputs\": [\"mol_021\", \"mol_001\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"null\"],\n      \"conditions\": {\n        \"temperature\": \"320-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"none required; concentration on mineral interfaces possible\",\n        \"aqueous\": \"false\",\n        \"other\": \"wet-dry cycling in prebiotic pools/mineral interfaces\"\n      },\n      \"mechanism\": \"Dehydrative condensation joins two serine molecules through a peptide bond to form a dipeptide.\",\n      \"reasoning\": \"This biochemical capture step is included to connect the serine product to downstream prebiotic assembly, consistent with standard wet-dry peptide formation scenarios described in the network instructions. It is not a serine-synthesis paper-specific step, so it is a necessary extrapolative network-closure reaction grounded in the broader prebiotic polymerization literature; the serine feed itself derives from Patel et al. (2015), Aubrey et al. (2008), and Krishnamurthy et al. (2016).\"\n    }\n  ],\n  \"pathways\": [\n    {\n      \"pathway_id\": \"P1\",\n      \"name\": \"Hydrothermal iron glyoxylate-glycine-serine route\",\n      \"description\": \"Hydrothermal Fe2+-mediated isocitrate cleavage generates glyoxylate, which is reductively aminated to glycine and then condensed with formaldehyde under hydrothermal conditions to yield serine.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_004\", \"rxn_012\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_009\"]\n    },\n    {\n      \"pathway_id\": \"P2\",\n      \"name\": \"Surface UV glyoxylate-hydrothermal glycine-serine route\",\n      \"description\": \"Surface UV photochemistry generates glyoxylate from its hydrate, then hydrothermal iron chemistry converts glyoxylate to glycine, which undergoes hydrothermal aldol condensation with formaldehyde to serine.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_004\", \"rxn_012\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_009\"]\n    },\n    {\n      \"pathway_id\": \"P3\",\n      \"name\": \"Hydrothermal peracetic acid-glycine-serine route\",\n      \"description\": \"Peracetic acid reacts with ammonia in hydrothermal settings to form glycine, which then combines with hydrothermal formaldehyde to form serine.\",\n      \"reaction_sequence\": [\"rxn_006\", \"rxn_012\"],\n      \"key_intermediates\": [\"mol_009\"]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"Surface aminoacetonitrile to glycine then hydrothermal serine route\",\n      \"description\": \"Surface cyanosulfidic Strecker synthesis forms aminoacetonitrile from formaldehyde, HCN, and ammonia; hydrolysis gives glycine, which is transferred into hydrothermal aldehyde chemistry to form serine.\",\n      \"reaction_sequence\": [\"rxn_013\", \"rxn_005\", \"rxn_012\"],\n      \"key_intermediates\": [\"mol_010\", \"mol_009\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"Hydrothermal glycine to surface N-methylene glycine serine route\",\n      \"description\": \"Hydrothermal glyoxylate reduction/amination generates glycine, which is exported to surface pools where Schiff base formation with formaldehyde gives N-methylene glycine and subsequent formaldehyde addition yields serine.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_004\", \"rxn_010\", \"rxn_011\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_009\", \"mol_017\"]\n    },\n    {\n      \"pathway_id\": \"P6\",\n      \"name\": \"Surface glycine from aminoacetonitrile to N-methylene glycine serine route\",\n      \"description\": \"Surface formaldehyde forms aminoacetonitrile under cyanosulfidic conditions, hydrolysis yields glycine, and glycine then enters the Krishnamurthy Schiff-base route to serine in the same surface environment.\",\n      \"reaction_sequence\": [\"rxn_013\", \"rxn_005\", \"rxn_010\", \"rxn_011\"],\n      \"key_intermediates\": [\"mol_010\", \"mol_009\", \"mol_017\"]\n    },\n    {\n      \"pathway_id\": \"P7\",\n      \"name\": \"Hydrothermal peracetic acid to surface N-methylene glycine serine route\",\n      \"description\": \"Hydrothermal glycine from peracetic acid amination is transported to surface pools, where reaction with formaldehyde forms N-methylene glycine and then serine.\",\n      \"reaction_sequence\": [\"rxn_006\", \"rxn_010\", \"rxn_011\"],\n      \"key_intermediates\": [\"mol_009\", \"mol_017\"]\n    },\n    {\n      \"pathway_id\": \"P8\",\n      \"name\": \"Direct surface cyanosulfidic serine nitrile hydrolysis route\",\n      \"description\": \"Surface glycolaldehyde, HCN, and ammonia form 2-amino-3-hydroxypropanenitrile by Strecker-type chemistry, followed by aqueous hydrolysis to serine.\",\n      \"reaction_sequence\": [\"rxn_014\", \"rxn_015\"],\n      \"key_intermediates\": [\"mol_019\"]\n    },\n    {\n      \"pathway_id\": \"P9\",\n      \"name\": \"Hydrothermal formaldehyde feeding direct surface serine nitrile route\",\n      \"description\": \"Hydrothermal CO2 reduction provides reduced carbon feedstock to the broader network while the productive serine sequence occurs on the surface through glycolaldehyde-derived serine nitrile formation and hydrolysis.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_014\", \"rxn_015\"],\n      \"key_intermediates\": [\"mol_006\", \"mol_019\"]\n    },\n    {\n      \"pathway_id\": \"P10\",\n      \"name\": \"Hydrothermal to biochemical capture of serine\",\n      \"description\": \"Hydrothermal glycine-formaldehyde condensation yields serine, which is then captured in downstream prebiotic assembly by peptide bond formation.\",\n      \"reaction_sequence\": [\"rxn_012\", \"rxn_016\"],\n      \"key_intermediates\": [\"mol_020\"]\n    }
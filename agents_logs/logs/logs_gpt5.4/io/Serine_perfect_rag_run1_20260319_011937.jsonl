n      \"common_name\": \"glycolaldehyde\",\n      \"inchi\": \"InChI=1S/C2H4O2/c3-1-2-4/h1,3H,2H2\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_017\",\n      \"formula\": \"C3H6N2O\",\n      \"iupac_name\": \"2-amino-3-hydroxypropanenitrile\",\n      \"common_name\": \"2-amino-3-hydroxypropanenitrile\",\n      \"inchi\": \"InChI=1S/C3H6N2O/c4-1-3(5)2-6/h3,6H,2,5H2\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_018\",\n      \"formula\": \"C3H7NO3\",\n      \"iupac_name\": \"2-amino-3-hydroxypropanoic acid\",\n      \"common_name\": \"serine\",\n      \"inchi\": \"InChI=1S/C3H7NO3/c4-2(1-5)3(6)7/h2,5H,1,4H2,(H,6,7)\",\n      \"role\": \"target\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_019\",\n      \"formula\": \"C5H10N2O4\",\n      \"iupac_name\": \"2-(2-amino-3-hydroxypropanamido)-3-hydroxypropanoic acid\",\n      \"common_name\": \"serylserine\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"Iron-promoted reductive amination of glyoxylate to glycine\",\n      \"inputs\": [\"mol_005\", \"mol_006\"],\n      \"outputs\": [\"mol_007\", \"mol_001\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"elemental iron (Fe0)\", \"ferrous iron (Fe2+)\"],\n      \"conditions\": {\n        \"temperature\": \"343 K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"elemental iron (Fe0), ferrous iron (Fe2+)\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic hydrothermal water; mild hydrothermal conditions\"\n      },\n      \"mechanism\": \"Iron-promoted reductive amination/transamination of the alpha-keto acid glyoxylate using hydroxylamine as nitrogen donor to give glycine.\",\n      \"reasoning\": \"Directly follows the iron-driven prebiotic metabolic network in which glyoxylate is converted to glycine at 70 C in water with Fe0 and Fe2+ (Muchowska, Varma & Moran, 2019). This establishes glycine as a major hydrothermal hub feeding serine synthesis.\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Aminoacetonitrile hydrolysis to glycine\",\n      \"inputs\": [\"mol_008\", \"mol_001\"],\n      \"outputs\": [\"mol_007\", \"mol_002\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"sulfide minerals (stibnite/molybdenite)\"],\n      \"conditions\": {\n        \"temperature\": \"ambient\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite and sulfide-rich cyanosulfidic mineral setting\",\n        \"aqueous\": \"true\",\n        \"other\": \"cyanosulfidic surface pool conditions; nitrile hydrolysis during wet phase\"\n      },\n      \"mechanism\": \"Stepwise nitrile hydrolysis of aminoacetonitrile through an amide intermediate to glycine with release of ammonia.\",\n      \"reasoning\": \"Patel et al. demonstrated aminoacetonitrile as a cyanosulfidic amino-acid precursor that hydrolyzes to glycine in aqueous surface conditions (Patel et al., 2015). Mineral agents are included to represent the required cyanosulfidic surface setting, though the core literature support is the aqueous hydrolysis itself.\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Peracetic acid amination to glycine\",\n      \"inputs\": [\"mol_011\", \"mol_002\"],\n      \"outputs\": [\"mol_007\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"pyrite (FeS2)\", \"magnetite (Fe3O4)\"],\n      \"conditions\": {\n        \"temperature\": \"elevated hydrothermal\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"pyrite (FeS2), magnetite (Fe3O4)\",\n        \"aqueous\": \"true\",\n        \"other\": \"submarine hydrothermal system\"\n      },\n      \"mechanism\": \"Nucleophilic attack of ammonia on the oxidized acetyl derivative leading to C-N bond formation and glycine production.\",\n      \"reasoning\": \"Aubrey, Cleaves & Bada reported glycine formation from peracetic acid and ammonia under submarine hydrothermal conditions (Aubrey, Cleaves & Bada, 2008). This provides a second hydrothermal entry to the glycine hub.\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"Fe2+-catalyzed isocitrate cleavage to glyoxylate and succinate\",\n      \"inputs\": [\"mol_012\"],\n      \"outputs\": [\"mol_005\", \"mol_013\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"ferrous iron (Fe2+)\", \"magnetite (Fe3O4)\"],\n      \"conditions\": {\n        \"temperature\": \"343 K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"ferrous iron (Fe2+)\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic hydrothermal water; retro-aldol cleavage\"\n      },\n      \"mechanism\": \"Fe2+-promoted retro-aldol/oxidative cleavage of isocitrate to the C2 keto acid glyoxylate and C4 succinate.\",\n      \"reasoning\": \"Muchowska, Varma & Moran showed Fe2+-promoted cleavage of isocitrate to glyoxylate and succinate at 70 C in water, creating an upstream hydrothermal source of glyoxylate (Muchowska, Varma & Moran, 2019).\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"UV photoredox dehydration of 2,2-dihydroxyacetic acid to glyoxylate\",\n      \"inputs\": [\"mol_014\"],\n      \"outputs\": [\"mol_005\", \"mol_001\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"borate minerals (colemanite/ulexite)\"],\n      \"conditions\": {\n        \"temperature\": \"ambient\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"UV photoredox on TiO2-exposed mineral surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"UV-irradiated pool; dehydration of glyoxylate hydrate\"\n      },\n      \"mechanism\": \"UV-driven dehydration of the hydrated gem-diol form regenerates aldehydic glyoxylate.\",\n      \"reasoning\": \"Liu et al. reported UV photoredox dehydration of 2,2-dihydroxyacetic acid to glyoxylate in prebiotic surface chemistry (Liu et al., 2021). TiO2 is included as the required surface photocatalytic mineral agent consistent with UV-exposed mineral surfaces.\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"Reduction of glyoxylate to glycolic acid\",\n      \"inputs\": [\"mol_005\"],\n      \"outputs\": [\"mol_010\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"ferrous iron (Fe2+)\", \"elemental iron (Fe0)\"],\n      \"conditions\": {\n        \"temperature\": \"343 K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"ferrous iron (Fe2+), elemental iron (Fe0)\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic water; literature also reports cyanosulfidic surface reduction on shorter timescales\"\n      },\n      \"mechanism\": \"Reduction of the aldehyde functionality of glyoxylate to the alpha-hydroxy acid glycolic acid.\",\n      \"reasoning\": \"Both Muchowska, Varma & Moran (2019) and Ritson (2021) support conversion of glyoxylate to glycolic acid under prebiotic conditions; here the hydrothermal Fe2+/Fe0 variant is used to keep mineral specification explicit and connect hydrothermal carbon flow to the wider serine network.\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Glycine-formaldehyde Schiff base formation\",\n      \"inputs\": [\"mol_007\", \"mol_004\"],\n      \"outputs\": [\"mol_009\", \"mol_001\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"borate minerals (colemanite/ulexite)\"],\n      \"conditions\": {\n        \"temperature\": \"323 K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite\",\n        \"aqueous\": \"true\",\n        \"other\": \"aqueous pool; spontaneous Schiff base condensation\"\n      },\n      \"mechanism\": \"Condensation of glycine amine with formaldehyde carbonyl forms the imine N-methylene glycine with loss of water.\",\n      \"reasoning\": \"Krishnamurthy et al. identified N-methylene glycine as the key intermediate formed from glycine and formaldehyde at 50 C in aqueous conditions (Krishnamurthy et al., 2016). This is the essential branching point for the surface serine route.\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Formaldehyde-driven conversion of N-methylene glycine to serine\",\n      \"inputs\": [\"mol_009\", \"mol_004\", \"mol_001\"],\n      \"outputs\": [\"mol_018\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"323 K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite\",\n        \"aqueous\": \"true\",\n        \"other\": \"24 h in geothermal/surface pools\"\n      },\n      \"mechanism\": \"Imine-mediated C-C bond formation with a second formaldehyde equivalent followed by hydrolysis/reduction sequence yields serine.\",\n      \"reasoning\": \"This is the Krishnamurthy surface route in which N-methylene glycine reacts with formaldehyde and water at 50 C over 24 h to give serine (Krishnamurthy et al., 2016).\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"Hydrothermal aldol-type condensation of glycine and formaldehyde to serine\",\n      \"inputs\": [\"mol_007\", \"mol_004\"],\n      \"outputs\": [\"mol_018\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe3O4)\", \"greigite (Fe3S4)\"],\n      \"conditions\": {\n        \"temperature\": \"elevated hydrothermal\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"magnetite (Fe3O4), greigite (Fe3S4)\",\n        \"aqueous\": \"true\",\n        \"other\": \"submarine hydrothermal vent conditions\"\n      },\n      \"mechanism\": \"Aldol-type C-C bond formation in which glycine's alpha carbon adds to formaldehyde to install the hydroxymethyl side chain of serine.\",\n      \"reasoning\": \"Aubrey, Cleaves & Bada reported serine formation from glycine and formaldehyde under submarine hydrothermal conditions (Aubrey, Cleaves & Bada, 2008). This is the core direct hydrothermal serine-forming step.\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"Hydrothermal Cannizzaro-type conversion of formaldehyde to glycolic acid\",\n      \"inputs\": [\"mol_004\"],\n      \"outputs\": [\"mol_010\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe3O4)\", \"elemental iron (Fe0)\"],\n      \"conditions\": {\n        \"temperature\": \"elevated hydrothermal\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"magnetite (Fe3O4), elemental iron (Fe0)\",\n        \"aqueous\": \"true\",\n        \"other\": \"submarine hydrothermal conditions; disproportionation network\"\n      },\n      \"mechanism\": \"Cannizzaro-type disproportionation/carbonyl coupling chemistry transforms formaldehyde into the C2 alpha-hydroxy acid glycolic acid.\",\n      \"reasoning\": \"Aubrey, Cleaves & Bada described hydrothermal formaldehyde conversion to glycolic acid via Cannizzaro-type chemistry, linking the C1 formaldehyde pool to C2 hydroxy-acid chemistry relevant to amino-acid networks (Aubrey, Cleaves & Bada, 2008).\"\n    },\n    {\n      \"id\": \"rxn_011\",\n      \"name\": \"UV photoredox conversion of acetate to glycolic acid\",\n      \"inputs\": [\"mol_015\", \"mol_001\"],\n      \"outputs\": [\"mol_010\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"sulfide minerals (stibnite/molybdenite)\"],\n      \"conditions\": {\n        \"temperature\": \"ambient\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"UV photoredox on TiO2-exposed mineral surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"4 h UV irradiation in surface pool\"\n      },\n      \"mechanism\": \"UV-driven photoredox radical chemistry upgrades acetate-derived carbon to glycolic acid.\",\n      \"reasoning\": \"Liu et al. showed UV photoredox chemistry converting acetate and water into glycolic acid over 4 h in surface settings (Liu et al., 2021). This creates hydrothermal-surface cross-feeding because acetate can originate from vent chemistry.\"\n    },\n    {\n      \"id\": \"rxn_012\",\n      \"name\": \"Cyanosulfidic Strecker-type formation of aminoacetonitrile from formaldehyde\",\n      \"inputs\": [\"mol_004\", \"mol_003\", \"mol_002\"],\n      \"outputs\": [\"mol_008\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (stibnite/molybdenite)\", \"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"ambient\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"sulfide-rich cyanosulfidic mineral surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"surface pool; Strecker/cyanosulfidic chemistry\"\n      },\n      \"mechanism\": \"Formaldehyde reacts with ammonia and cyanide through imine formation followed by cyanide addition to form aminoacetonitrile.\",\n      \"reasoning\": \"Patel et al. identified aminoacetonitrile as the glycine precursor formed from formaldehyde, HCN, and NH3 within cyanosulfidic protometabolism (Patel et al., 2015). This step is necessary to connect the reported glycine hydrolysis route into the network.\"\n    },\n    {\n      \"id\": \"rxn_013\",\n      \"name\": \"Cyanosulfidic Strecker-type formation of 2-amino-3-hydroxypropanenitrile from glycolaldehyde\",\n      \"inputs\": [\"mol_016\", \"mol_003\", \"mol_002\"],\n      \"outputs\": [\"mol_017\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (stibnite/molybdenite)\", \"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"ambient\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"sulfide-rich cyanosulfidic mineral surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"evaporitic/cyanosulfidic surface pool\"\n      },\n      \"mechanism\": \"Glycolaldehyde undergoes Strecker-type aminonitrile formation with ammonia and cyanide to give the serine aminonitrile precursor.\",\n      \"reasoning\": \"Patel et al. reported 2-amino-3-hydroxypropanenitrile as the direct aminonitrile precursor to serine formed from glycolaldehyde, HCN, and NH3 in cyanosulfidic chemistry (Patel et al., 2015).\"\n    },\n    {\n      \"id\": \"rxn_014\",\n      \"name\": \"Hydrolysis of 2-amino-3-hydroxypropanenitrile to serine\",\n      \"inputs\": [\"mol_017\", \"mol_001\"],\n      \"outputs\": [\"mol_018\", \"mol_002\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"ambient\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite and phosphate-rich evaporitic mineral matrix\",\n        \"aqueous\": \"true\",\n        \"other\": \"wet phase after cyanosulfidic accumulation\"\n      },\n      \"mechanism\": \"Nitrile hydrolysis proceeds via amide formation to the carboxylic acid serine with release of ammonia.\",\n      \"reasoning\": \"This is the experimentally demonstrated serine-forming hydrolysis step from the Patel et al. cyanosulfidic network (Patel et al., 2015).\"\n    },\n    {\n      \"id\": \"rxn_015\",\n      \"name\": \"Wet-dry peptide condensation of serine to serylserine\",\n      \"inputs\": [\"mol_018\"],\n      \"outputs\": [\"mol_019\", \"mol_001\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"null\"],\n      \"conditions\": {\n        \"temperature\": \"variable geothermal cycling\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": null,\n        \"aqueous\": \"false\",\n        \"other\": \"wet-dry cycling on mineral interfaces or in prebiotic pools\"\n      },\n      \"mechanism\": \"Dehydrative peptide bond formation between two serine molecules yields a dipeptide.\",\n      \"reasoning\": \"This downstream biochemical assembly step is included to connect serine production to prebiotic macromolecular chemistry as required by the network design. It is a plausible extrapolation from general wet-dry peptide condensation chemistry; unlike the upstream serine-forming steps, it is included as a necessary network connector and is therefore explicitly more general/speculative relative to the serine-specific literature.\"\n    }\n  ],\n  \"pathways\": [\n    {\n      \"pathway_id\": \"P1\",\n      \"name\": \"Direct cyanosulfidic serine aminonitrile route\",\n      \"description\": \"Surface formation of the serine aminonitrile from glycolaldehyde, HCN, and ammonia followed by aqueous hydrolysis to serine.\",\n      \"reaction_sequence\": [\"rxn_013\", \"rxn_014\"],\n      \"key_intermediates\": [\"mol_017\"]\n    },\n    {\n      \"pathway_id\": \"P2\",\n      \"name\": \"Hydrothermal glyoxylate-to-glycine aldol route\",\n      \"description\": \"Hydrothermal isocitrate cleavage supplies glyoxylate, iron-promoted reductive amination yields glycine, and hydrothermal aldol condensation with formaldehyde gives serine.\",\n      \"reaction_sequence\": [\"rxn_004\", \"rxn_001\", \"rxn_009\"],\n      \"key_intermediates\": [\"mol_005\", \"mol_007\"]\n    },\n    {\n      \"pathway_id\": \"P3\",\n      \"name\": \"Surface glyoxylate-to-glycine N-methylene route\",\n      \"description\": \"Surface UV chemistry generates glyoxylate, hydrothermal-style iron chemistry supplies glycine, then Schiff-base chemistry with formaldehyde gives N-methylene glycine and finally serine.\",\n      \"reaction_sequence\": [\"rxn_005\", \"rxn_001\", \"rxn_007\", \"rxn_008\"],\n      \"key_intermediates\": [\"mol_005\", \"mol_007\", \"mol_009\"]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"Formaldehyde-Strecker glycine then hydrothermal serine route\",\n      \"description\": \"Surface Strecker chemistry converts formaldehyde to aminoacetonitrile, hydrolysis gives glycine, and hydrothermal condensation with formaldehyde yields serine.\",\n      \"reaction_sequence\": [\"rxn_012\", \"rxn_002\", \"rxn_009\"],\n      \"key_intermediates\": [\"mol_008\", \"mol_007\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"Formaldehyde-Strecker glycine then N-methylene route\",\n      \"description\": \"Surface aminoacetonitrile hydrolysis generates glycine, which reacts with formaldehyde to form N-methylene glycine and then serine.\",\n      \"reaction_sequence\": [\"rxn_012\", \"rxn_002\", \"rxn_007\", \"rxn_008\"],\n      \"key_intermediates\": [\"mol_008\", \"mol_007\", \"mol_009\"]\n    },\n    {\n      \"pathway_id\": \"P6\",\n      \"name\": \"Hydrothermal peracetic acid to glycine to serine\",\n      \"description\": \"Hydrothermal amination of peracetic acid yields glycine, followed by direct hydrothermal glycine-formaldehyde condensation to serine.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_009\"],\n      \"key_intermediates\": [\"mol_007\"]\n    },\n    {\n      \"pathway_id\": \"P7\",\n      \"name\": \"Hydrothermal peracetic acid to glycine via surface Schiff base\",\n      \"description\": \"Hydrothermal glycine is exported to surface pools, converted to N-methylene glycine with formaldehyde, and then to serine.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_007\", \"rxn_008\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_009\"]\n    },\n    {\n      \"pathway_id\": \"P8\",\n      \"name\": \"Hydrothermal glyoxylate branch through glycolic acid and glycine-derived serine\",\n      \"description\": \"Isocitrate cleavage generates glyoxylate, part of which is reduced to glycolic acid while the same glyoxylate hub also feeds glycine formation and then serine, illustrating branch connectivity.\",\n      \"reaction_sequence\": [\"rxn_004\", \"rxn_006\", \"rxn_001\", \"rxn_009\"],\n      \"key_intermediates\": [\"mol_005\", \"mol_010\", \"mol_007\"]\n    },\n    {\n      
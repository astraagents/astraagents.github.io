acetaldehyde to threonine/allothreonine", "inputs": ["mol_012", "mol_007"], "outputs": ["mol_011"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "variable; likely mild to moderate", "pressure": "1 atm", "catalyst": null, "aqueous": "true", "other": "requires high glycine concentration or catalytic assistance; thermodynamically unfavorable"}, "mechanism": "Reverse threonine-aldol chemistry forms a C-C bond between glycine-derived and acetaldehyde-derived fragments to give threonine and allothreonine.", "reasoning": "Fesko (2016) discusses the reversibility of threonine aldolase chemistry and the unfavorable but conceptually simple condensation of glycine with acetaldehyde to give threonine/allothreonine. No purely prebiotic demonstration of this exact reaction has been reported, so this step is explicitly speculative but included because the literature identifies it as a key structural relationship."}], "pathways": [{"pathway_id": "P1", "name": "Canonical cyanosulfidic lactaldehyde-Strecker route", "description": "HCN photoredox chemistry generates acetaldehyde, which is converted through lactaldehyde to the threonine aminonitrile and then threonine.", "reaction_sequence": ["rxn_002", "rxn_004", "rxn_005"], "key_intermediates": ["mol_007", "mol_009", "mol_010"]}, {"pathway_id": "P2", "name": "Glyceraldehyde direct Strecker route", "description": "HCN-derived aldehydes feed sugar homologation to glyceraldehyde, which directly furnishes the threonine aminonitrile.", "reaction_sequence": ["rxn_002", "rxn_003", "rxn_006"], "key_intermediates": ["mol_006", "mol_008", "mol_010"]}, {"pathway_id": "P3", "name": "Lactaldehyde Bucherer-Bergs route", "description": "Lactaldehyde enters hydantoin chemistry before hydrolysis to threonine.", "reaction_sequence": ["rxn_002", "rxn_004", "rxn_009", "rxn_010"], "key_intermediates": ["mol_009", "mol_018"]}, {"pathway_id": "P4", "name": "HCN polymer hydrolysate route", "description": "Concentrated HCN oligom
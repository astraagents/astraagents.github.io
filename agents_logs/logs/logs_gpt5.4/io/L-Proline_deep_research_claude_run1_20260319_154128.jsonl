face\"\n    },\n    {\n      \"id\": \"mol_009\",\n      \"formula\": \"C5H8N2\",\n      \"iupac_name\": \"2-cyanopyrrolidine-2-carboxylate precursor\",\n      \"common_name\": \"proline aminonitrile\",\n      \"inchi\": null,\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_010\",\n      \"formula\": \"C5H9NO4\",\n      \"iupac_name\": \"2-oxopentanedioic acid\",\n      \"common_name\": \"alpha-ketoglutarate\",\n      \"inchi\": \"InChI=1S/C5H6O5/c6-3(5(9)10)1-2-4(7)8/h1-2H2,(H,7,8)(H,9,10)/p-2\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_011\",\n      \"formula\": \"C5H9NO4\",\n      \"iupac_name\": \"2-aminopentanedioic acid\",\n      \"common_name\": \"glutamic acid\",\n      \"inchi\": \"InChI=1S/C5H9NO4/c6-3(5(9)10)1-2-4(7)8/h3H,1-2,6H2,(H,7,8)(H,9,10)\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_012\",\n      \"formula\": \"C5H7NO3\",\n      \"iupac_name\": \"2-amino-4-oxobutanoic acid\",\n      \"common_name\": \"glutamic-gamma-semialdehyde\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_013\",\n      \"formula\": \"C5H7NO2\",\n      \"iupac_name\": \"5-oxopyrrolidine-2-carboxylic acid precursor\",\n      \"common_name\": \"Delta1-pyrroline-5-carboxylic acid\",\n      \"inchi\": null,\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_014\",\n      \"formula\": \"C5H9NO2\",\n      \"iupac_name\": \"(2S)-pyrrolidine-2-carboxylic acid\",\n      \"common_name\": \"L-proline\",\n      \"inchi\": \"InChI=1S/C5H9NO2/c7-5(8)4-2-1-3-6-4/h4,6H,1-3H2,(H,7,8)/t4-/m0/s1\",\n      \"role\": \"target\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_015\",\n      \"formula\": \"C4H4N4\",\n      \"iupac_name\": \"2,3-diaminomaleonitrile\",\n      \"common_name\": \"DAMN\",\n      \"inchi\": \"InChI=1S/C4H4N4/c5-1-3(7)4(8)2-6/h7-8H,1-2H2\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_016\",\n      \"formula\": \"CH4\",\n      \"iupac_name\": \"methane\",\n      \"common_name\": \"methane\",\n      \"inchi\": \"InChI=1S/CH4/h1H4\",\n      \"role\": \"starting\",\n      \"environment_formed\": null\n    },\n    {\n      \"id\": \"mol_017\",\n      \"formula\": \"N2\",\n      \"iupac_name\": \"dinitrogen\",\n      \"common_name\": \"nitrogen\",\n      \"inchi\": \"InChI=1S/N2/c1-2\",\n      \"role\": \"starting\",\n      \"environment_formed\": null\n    },\n    {\n      \"id\": \"mol_018\",\n      \"formula\": \"H2O\",\n      \"iupac_name\": \"oxidane\",\n      \"common_name\": \"water\",\n      \"inchi\": \"InChI=1S/H2O/h1H2\",\n      \"role\": \"starting\",\n      \"environment_formed\": null\n    },\n    {\n      \"id\": \"mol_019\",\n      \"formula\": \"C3H4O3\",\n      \"iupac_name\": \"2-oxopropanoic acid\",\n      \"common_name\": \"pyruvate\",\n      \"inchi\": \"InChI=1S/C3H4O3/c1-2(4)3(5)6/h1H3,(H,5,6)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_020\",\n      \"formula\": \"C2H2O3\",\n      \"iupac_name\": \"oxoacetic acid\",\n      \"common_name\": \"glyoxylate\",\n      \"inchi\": \"InChI=1S/C2H2O3/c3-1-2(4)5/h1H,(H,4,5)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"Hydrothermal protometabolic formation of alpha-ketoglutarate from CO2/H2 network\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_010\", \"mol_019\", \"mol_020\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"pyrite (FeS2)\", \"greigite (Fe3S4)\"],\n      \"conditions\": {\n        \"temperature\": \"313-363K\",\n        \"pressure\": \"1-10 bar H2 to hydrothermal high local pressures\",\n        \"catalyst\": \"pyrite (FeS2), greigite (Fe3S4), Ni-bearing sulfide analog conditions\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline vent-like, anoxic, pH 8-11; protometabolic carbon-fixation and TCA-analog chemistry\"\n      },\n      \"mechanism\": \"Iron-sulfur-driven reduction and carboxylation of CO2 generates alpha-keto acid networks including pyruvate, glyoxylate, and alpha-ketoglutarate under reducing hydrothermal conditions.\",\n      \"reasoning\": \"Alpha-ketoglutarate is identified as the central branch point for proline synthesis and is supported by pyrite-driven protometabolic TCA-like chemistry and related alpha-keto acid networks in hydrothermal settings (Muchowska et al., 2017; Stubbs et al., 2020; Springsteen et al., 2018). Use of Fe-S minerals follows hydrothermal prebiotic catalysis models and greigite relevance to proto-enzymatic CO2 reduction (Russell & Hall, 1997, 2006; Li et al., 2018).\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Nickel-catalyzed reductive amination of alpha-ketoglutarate to glutamate\",\n      \"inputs\": [\"mol_010\", \"mol_003\", \"mol_002\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe3S4)\", \"pyrite (FeS2)\"],\n      \"conditions\": {\n        \"temperature\": \"295K\",\n        \"pressure\": \"1-10 bar H2\",\n        \"catalyst\": \"Ni catalyst under mild alkaline conditions with Fe-S mineral support\",\n        \"aqueous\": \"true\",\n        \"other\": \"pH 8, anoxic; modeled on nickel-catalyzed prebiotic Krebs-cycle analog chemistry\"\n      },\n      \"mechanism\": \"Alpha-ketoglutarate undergoes reductive amination with ammonia under hydrogen to form glutamate.\",\n      \"reasoning\": \"Kaur, Moran and co-workers showed reductive amination of keto acids including glutamate formation under 22C, pH 8, and 1-10 bar H2 over Ni catalysts; alpha-ketoglutarate-to-glutamate is a key literature-supported entry into proline synthesis (Kaur et al., 2024). The Fe-S mineral agents maintain hydrothermal plausibility consistent with Huber & W\u00e4chtersh\u00e4user's sulfide-mediated amino acid synthesis framework (Huber & W\u00e4chtersh\u00e4user, 1998; Huber & W\u00e4chtersh\u00e4user, 2003).\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Partial reduction of glutamate to glutamic-gamma-semialdehyde\",\n      \"inputs\": [\"mol_011\", \"mol_002\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"null\"],\n      \"conditions\": {\n        \"temperature\": \"313-363K\",\n        \"pressure\": \"ambient to moderate\",\n        \"catalyst\": \"Fe2+ or FeS/H2S redox system\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic; selective gamma-carboxyl reduction is a key bottleneck\"\n      },\n      \"mechanism\": \"Selective partial reduction of the gamma-carboxyl group of glutamate gives the corresponding semialdehyde, preserving the alpha-carboxylate.\",\n      \"reasoning\": \"The research report identifies glutamic-gamma-semialdehyde as the required intermediate between glutamate and P5C, while explicitly noting this selective reduction as chemically demanding but potentially driven prebiotically by Fe2+, FeS/H2S, or H2 from serpentinization (Vogel & Davis, 1952; Strecker, 1957; Huber & W\u00e4chtersh\u00e4user, 1998). This step is included as necessary but remains less directly demonstrated than neighboring transformations.\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"Spontaneous cyclization of glutamic-gamma-semialdehyde to Delta1-pyrroline-5-carboxylate\",\n      \"inputs\": [\"mol_012\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"null\"],\n      \"conditions\": {\n        \"temperature\": \"298-333K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": null,\n        \"aqueous\": \"true\",\n        \"other\": \"neutral to mildly aqueous conditions; non-enzymatic intramolecular imine formation\"\n      },\n      \"mechanism\": \"The amino aldehyde undergoes spontaneous intramolecular condensation to close the five-membered ring and form P5C.\",\n      \"reasoning\": \"This is one of the best-established steps in the network: GSA cyclizes spontaneously and non-enzymatically to P5C in aqueous solution, creating the pyrrolidine framework without enzyme assistance (Vogel & Davis, 1952). The report highlights this as especially prebiotically plausible.\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"Reduction of Delta1-pyrroline-5-carboxylate to proline\",\n      \"inputs\": [\"mol_013\", \"mol_002\"],\n      \"outputs\": [\"mol_014\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"null\"],\n      \"conditions\": {\n        \"temperature\": \"313-363K\",\n        \"pressure\": \"ambient to moderate\",\n        \"catalyst\": \"Fe2+ or FeS/H2S or molecular hydrogen\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic reducing conditions; likely racemic without later enrichment\"\n      },\n      \"mechanism\": \"Reductive saturation of the cyclic imine/carboxylate intermediate yields proline.\",\n      \"reasoning\": \"The report states that final reduction of P5C to proline could plausibly be driven by Fe2+, FeS/H2S systems, or H2 from serpentinization, completing the glutamate-family route (Vogel & Davis, 1952; Strecker, 1957; Huber & W\u00e4chtersh\u00e4user, 1998). This step is mechanistically necessary though prebiotic selectivity remains open.\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"Surface cyanosulfidic generation of 4-carbon cyanohydrin from HCN feedstock\",\n      \"inputs\": [\"mol_004\", \"mol_018\"],\n      \"outputs\": [\"mol_006\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (molybdenite/stibnite)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"308K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"Cu(I)/Cu(II) photoredox cycling with phosphate-buffered neutral solution on UV-exposed mineral surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"35C, neutral pH, anoxic, UV irradiation; cyanosulfidic network\"\n      },\n      \"mechanism\": \"HCN-derived carbonyl/cyanohydrin chemistry under UV photoredox conditions furnishes a 4-carbon cyanohydrin precursor entering proline movement c.\",\n      \"reasoning\": \"Patel et al. described a cyanosulfidic network at 35C, neutral pH, anoxic conditions with HCN, H2S, UV, and Cu photoredox cycling that produces precursors to multiple amino acids; proline specifically enters through a 4-carbon cyanohydrin in movement c (Patel et al., 2015). TiO2 and sulfide minerals are included to satisfy required surface mineral agents and are consistent with UV-active shallow pool mineralogy and sulfide-rich cyanosulfidic settings (Saladino et al., 2017; Patel et al., 2015).\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Thionation and cyclization of 4-carbon cyanohydrin to cyclic alpha-hydroxythioamide\",\n      \"inputs\": [\"mol_006\", \"mol_005\"],\n      \"outputs\": [\"mol_007\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (molybdenite/stibnite)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"308K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"Cu(I)/Cu(II) photoredox-compatible cyanosulfidic conditions\",\n        \"aqueous\": \"true\",\n        \"other\": \"35C, neutral pH, anoxic, UV irradiation\"\n      },\n      \"mechanism\": \"Addition of sulfide to the cyanohydrin-derived intermediate forms thioamide functionality and favors intramolecular closure to a cyclic alpha-hydroxythioamide.\",\n      \"reasoning\": \"The deep research summary states that in Patel et al. 2015 a 4-carbon cyanohydrin reacts with H2S to produce open-chain and cyclic alpha-hydroxythioamide intermediates that specifically channel into proline synthesis (Patel et al., 2015).\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"UV-driven conversion of cyclic alpha-hydroxythioamide to gamma-butyrothiolactam\",\n      \"inputs\": [\"mol_007\"],\n      \"outputs\": [\"mol_008\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"sulfide minerals (molybdenite/stibnite)\"],\n      \"conditions\": {\n        \"temperature\": \"308K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"UV photochemistry under cyanosulfidic conditions\",\n        \"aqueous\": \"true\",\n        \"other\": \"35C, neutral pH, anoxic; deoxygenation/cyclization under irradiation\"\n      },\n      \"mechanism\": \"UV irradiation promotes deoxygenation and ring-constraining rearrangement to the thiolactam, locking in the five-membered heterocycle.\",\n      \"reasoning\": \"Patel et al. report that UV irradiation drives cyclization and deoxygenation of the alpha-hydroxythioamide intermediate to gamma-butyrothiolactam, making this the decisive ring-forming stage in the cyanosulfidic route (Patel et al., 2015).\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"Photoreduction and cyanation of gamma-butyrothiolactam to proline aminonitrile\",\n      \"inputs\": [\"mol_008\", \"mol_004\"],\n      \"outputs\": [\"mol_009\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"sulfide minerals (molybdenite/stibnite)\"],\n      \"conditions\": {\n        \"temperature\": \"308K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"Cu(I)/Cu(II) photoredox-compatible UV mineral surface conditions\",\n        \"aqueous\": \"true\",\n        \"other\": \"35C, neutral pH, anoxic; HCN addition after photoreduction\"\n      },\n      \"mechanism\": \"The thiolactam is photoreduced and undergoes HCN addition to furnish the alpha-aminonitrile precursor of proline.\",\n      \"reasoning\": \"The report explicitly identifies gamma-butyrothiolactam photoreduction followed by HCN addition as the step producing the alpha-aminonitrile precursor of proline, compound 47 of Patel et al. (Patel et al., 2015).\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"Hydrolysis of proline aminonitrile to proline\",\n      \"inputs\": [\"mol_009\", \"mol_018\"],\n      \"outputs\": [\"mol_014\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"null\"],\n      \"conditions\": {\n        \"temperature\": \"298-363K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"aqueous hydrolysis\",\n        \"aqueous\": \"true\",\n        \"other\": \"neutral to mildly warm aqueous conditions; wet-dry concentration can assist completion\"\n      },\n      \"mechanism\": \"The alpha-aminonitrile hydrolyzes through amide/carboxylate stages to the amino acid proline.\",\n      \"reasoning\": \"Patel et al. identify the aminonitrile as the direct precursor to proline, with hydrolysis yielding proline itself; aminonitrile hydrolysis is also a standard final step in Strecker-type amino acid chemistry (Patel et al., 2015).\"\n    },\n    {\n      \"id\": \"rxn_011\",\n      \"name\": \"HCN oligomerization to DAMN\",\n      \"inputs\": [\"mol_004\"],\n      \"outputs\": [\"mol_015\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"surface-assisted oligomerization under UV-exposed evaporitic conditions\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic; HCN concentration by evaporation and mineral adsorption\"\n      },\n      \"mechanism\": \"HCN tetramerizes/oligomerizes to diaminomaleonitrile as a canonical branch point in HCN polymer chemistry.\",\n      \"reasoning\": \"The report notes HCN oligomerization via DAMN as the classical route explored since Oro, with proline detected among amino acids released from HCN polymer hydrolysis under some conditions (Oro, 1961; Ruiz-Bermejo et al., 2013). Mineral surfaces are added as concentration and photochemical aids consistent with surface HCN chemistry.\"\n    },\n    {\n      \"id\": \"rxn_012\",\n      \"name\": \"Hydrolysis and thermal processing of DAMN-derived HCN polymers to proline\",\n      \"inputs\": [\"mol_015\", \"mol_018\"],\n      \"outputs\": [\"mol_014\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"null\"],\n      \"conditions\": {\n        \"temperature\": \"330-390K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"thermal aqueous hydrolysis\",\n        \"aqueous\": \"true\",\n        \"other\": \"higher-temperature polymer hydrolysis; complex mixture route with low selectivity\"\n      },\n      \"mechanism\": \"HCN oligomer/hydantoin-like material hydrolyzes and rearranges during warm aqueous treatment to release amino acids including proline.\",\n      \"reasoning\": \"Ruiz-Bermejo, Zorzano, and Osuna-Esteban reviewed HCN polymer experiments and found proline among amino acids detected after hydrolysis, especially at higher temperatures; this route is less selective but directly supported as one of the independent prebiotic entries to proline (Ruiz-Bermejo et al., 2013).\"\n    }\n  ],\n  \"pathways\": [\n    {\n      \"pathway_id\": \"P1\",\n      \"name\": \"Hydrothermal alpha-ketoglutarate to proline core route\",\n      \"description\": \"Canonical glutamate-family route from hydrothermal protometabolism through GSA and spontaneous P5C cyclization to proline.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_003\", \"rxn_004\", \"rxn_005\"],\n      \"key_intermediates\": [\"mol_010\", \"mol_011\", \"mol_013\"]\n    },\n    {\n      \"pathway_id\": \"P2\",\n      \"name\": \"Hydrothermal vent mild-alkaline variant\",\n      \"description\": \"Same glutamate-family route emphasized under Lost City-like alkaline H2-rich settings where alpha-ketoglutarate and glutamate accumulate before reduction and cyclization.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_003\", \"rxn_004\", \"rxn_005\"],\n      \"key_intermediates\": [\"mol_010\", \"mol_011\", \"mol_012\"]\n    },\n    {\n      \"pathway_id\": \"P3\",\n      \"name\": \"Nickel-enabled hydrothermal reductive amination variant\",\n      \"description\": \"Variant highlighting Kaur et al. mild Ni/H2 reductive amination of alpha-ketoglutarate to glutamate before conversion to proline.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_003\", \"rxn_004\", \"rxn_005\"],\n      \"key_intermediates\": [\"mol_011\", \"mol_013\"]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"Surface cyanosulfidic movement c complete route\",\n      \"description\": \"Patel-Sutherland route from HCN/H2S/UV via 4-carbon cyanohydrin, cyclic alpha-hydroxythioamide, gamma-butyrothiolactam, and proline aminonitrile.\",\n      \"reaction_sequence\": [\"rxn_006\", \"rxn_007\", \"rxn_008\", \"rxn_009\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_006\", \"mol_008\", \"mol_009\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"Surface cyanosulfidic thiolactam-centered variant\",\n      \"description\": \"Variant emphasizing inevitable ring formation at the gamma-butyrothiolactam stage before aminonitrile hydrolysis.\",\n      \"reaction_sequence\": [\"rxn_007\", \"rxn_008\", \"rxn_009\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_008\", \"mol_009\"]\n    },\n    {\n      \"pathway_id\": \"P6\",\n      \"name\": \"Surface aminonitrile hydrolysis endpoint variant\",\n      \"description\": \"Variant in which proline aminonitrile accumulated in shallow pools is later hydrolyzed during biochemical wet phases to proline.\",\n      \"reaction_sequence\": [\"rxn_009\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_009\"]\n    },\n    {\n      \"pathway_id\": \"P7\",\n      \"name\": \"HCN oligomerization polymer hydrolysis route\",\n      \"description\": \"Classical HCN polymer route passing through DAMN and complex polymer hydrolysis to release proline among amino acid products.\",\n      \"reaction_sequence\": [\"rxn_011\", \"rxn_012\"],\n      \"key_intermediates\": [\"mol_015\"]\n    },\n    {\n      \"pathway_id\": \"P8\",\n      \"name\": \"Surface concentrated HCN pool variant\",\n      \"description\": \"A mineral-concentrated, UV-exposed evaporitic pool variant of HCN oligomerization leading to proline after warm hydrolysis.\",\n      \"reaction_sequence\": [\"rxn_011\", \"rxn_012\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_015\"]\n    },\n    {\n      \"pathway_id\": \"P9\",\n      \"name\": \"Cross-environment hybrid route from hydrothermal carbon fixation to surface photochemistry\",\n      \"description\": \"Hydrothermal production of reduced carbon and nitrogen feedstocks supports HCN generation and entry into the cyanosulfidic proline branch, ending with biochemical hydrolysis.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_006\", \"rxn_007\", \"rxn_008\", \"rxn_009\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_010\", \"mol_006\", \"mol_009\"]\n    },\n    {\n      \"pathway_id\": \"P10\",\n      \"name\": \"Cross-environment hybrid route from hydrothermal alpha-ketoglutarate to biochemical proline accumulation\",\n      \"description\": \"Hydrothermal alpha-ketoglutarate and glutamate generation feeds into later biochemical reduction, spontaneous ring closure, and proline accumulation in concentrated pools or interfaces.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_003\", \"rxn_004\", \"rxn_005\"],\n      \"key_intermediates\": [\"mol_010\", \"mol_011\", \"mol_013\"]\n    }\n  ],\n  \"hub_molecules\": [\"mol_004\", \"mol_010\", \"mol_011\", \"mol_013\", \"mol_009\"],\n  \"convergence_points\": [\n    {\n      \"molecule_id\": \"mol_010\",\n      \"incoming_reactions\": [\"rxn_001\"],\n      \"outgoing_reactions\": [\"rxn_002\"]\n    },\n    {\n      \"molecule_id\": \"mol_011\",\n      \"incoming_reactions\": [\"rxn_002\"],\n      \"outgoing_reactions\": [\"rxn_003\"]\n    },\n    {\n      \"molecule_id\": \"mol_013\",\n      \"incoming_reactions\": [\"rxn_004\"],\n      \"outgoing_reactions\": [\"rxn_005\"]\n    },\n    {\n      \"molecule_id\": \"mol_009\",\n      \"incoming_reactions\": [\"rxn_009\"],\n      \"outgoing_reactions\": [\"rxn_010\"]\n    },\n    {\n      \"molecule_id\": \"mol_014\",\n      \"incoming_reactions\": [\"rxn_005\", \"rxn_010\", \"rxn_012\"],\n      \"outgoing_reactions\": []\n    }\n  ]\n}", "parsed_response": {"target_molecule": "L-Proline", "overall_strategy": "This network targets proline through a literature-grounded, cross-environment prebiotic system centered on four experimentally or mechanistically supported routes: (1) hydrothermal protometabolic production of alpha-ketoglutarate followed by glutamate -> glutamic-gamma-semialdehyde -> Delta1-pyrroline-5-carboxylate -> proline; (2) surface cyanosulfidic photochemistry from HCN/H2S via a 4-carbon cyanohydrin, cyclic alpha-hydroxythioamide, gamma-butyrothiolactam, and proline aminonitrile; (3) HCN oligomerization through DAMN and hydrolytic amino-acid release; and (4) spark-discharge style atmospheric synthesis represented as surface-accessible feedstock generation. Biochemical-stage reactions complete hydrolysis, cyclization, reduction, and concentration-driven accumulation, while preserving the literature-noted uncertainty that most abiotic routes are racemic and that conversion to specifically L-proline requires postsynthetic enrichment or selection. Ten distinct pathways are enumerated as route variants through these connected hubs: HCN,
": "oxoacetic acid", "common_name": "glyoxylate", "inchi": "InChI=1S/C2H2O3/c3-1-2(4)5/h1H,(H,4,5)", "role": "intermediate", "environment_formed": "Hydrothermal"}], "reactions": [{"id": "rxn_001", "name": "Hydrothermal protometabolic formation of alpha-ketoglutarate from CO2/H2 network", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_010", "mol_019", "mol_020"], "environment": "Hydrothermal", "agents": ["pyrite (FeS2)", "greigite (Fe3S4)"], "conditions": {"temperature": "313-363K", "pressure": "1-10 bar H2 to hydrothermal high local pressures", "catalyst": "pyrite (FeS2), greigite (Fe3S4), Ni-bearing sulfide analog conditions", "aqueous": "true", "other": "alkaline vent-like, anoxic, pH 8-11; protometabolic carbon-fixation and TCA-analog chemistry"}, "mechanism": "Iron-sulfur-driven reduction and carboxylation of CO2 generates alpha-keto acid networks including pyruvate, glyoxylate, and alpha-ketoglutarate under reducing hydrothermal conditions.", "reasoning": "Alpha-ketoglutarate is identified as the central branch point for proline synthesis and is supported by pyrite-driven protometabolic TCA-like chemistry and related alpha-keto acid networks in hydrothermal settings (Muchowska et al., 2017; Stubbs et al., 2020; Springsteen et al., 2018). Use of Fe-S minerals follows hydrothermal prebiotic catalysis models and greigite relevance to proto-enzymatic CO2 reduction (Russell & Hall, 1997, 2006; Li et al., 2018)."}, {"id": "rxn_002", "name": "Nickel-catalyzed reductive amination of alpha-ketoglutarate to glutamate", "inputs": ["mol_010", "mol_003", "mol_002"], "outputs": ["mol_011"], "environment": "Hydrothermal", "agents": ["greigite (Fe3S4)", "pyrite (FeS2)"], "conditions": {"temperature": "295K", "pressure": "1-10 bar H2", "catalyst": "Ni catalyst under mild alkaline conditions with Fe-S mineral support", "aqueous": "true", "other": "pH 8, anoxic; modeled on nickel-catalyzed prebiotic Krebs-cycle analog chemistry"}, "mechanism": "Alpha-ketoglutarate undergoes reductive amination with ammonia under hydrogen to form glutamate.", "reasoning": "Kaur, Moran and co-workers showed reductive amination of keto acids including glutamate formation under 22C, pH 8, and 1-10 bar H2 over Ni catalysts; alpha-ketoglutarate-to-glutamate is a key literature-supported entry into proline synthesis (Kaur et al., 2024). The Fe-S mineral agents maintain hydrothermal plausibility consistent with Huber & W\u00e4chtersh\u00e4user's sulfide-mediated amino acid synthesis framework (Huber & W\u00e4chtersh\u00e4user, 1998; Huber & W\u00e4chtersh\u00e4user, 2003)."}, {"id": "rxn_003", "name": "Partial reduction of glutamate to glutamic-gamma-semialdehyde", "inputs": ["mol_011", "mol_002"], "outputs": ["mol_012"], "environment": "Biochemical", "agents": ["null"], "conditions": {"temperature": "313-363K", "pressure": "ambient to moderate", "catalyst": "Fe2+ or FeS/H2S redox system", "aqueous": "true", "other": "anoxic; selective gamma-carboxyl reduction is a key bottleneck"}, "mechanism": "Selective partial reduction of the gamma-carboxyl group of glutamate gives the corresponding semialdehyde, preserving the alpha-carboxylate.", "reasoning": "The research report identifies glutamic-gamma-semialdehyde as the required intermediate between glutamate and P5C, while explicitly noting this selective reduction as chemically demanding but potentially driven prebiotically by Fe2+, FeS/H2S, or H2 from serpentinization (Vogel & Davis, 1952; Strecker, 1957; Huber & W\u00e4chtersh\u00e4user, 1998). This step is included as necessary but remains less directly demonstrated than neighboring transformations."}, {"id": "rxn_004", "name": "Spontaneous cyclization of glutamic-gamma-semialdehyde to Delta1-pyrroline-5-carboxylate", "inputs": ["mol_012"], "outputs": ["mol_013"], "environment": "Biochemical", "agents": ["null"], "conditions": {"temperature": "298-333K", "pressure": "1 atm", "catalyst": null, "aqueous": "true", "other": "neutral to mildly aqueous conditions; non-enzymatic intramolecular imine formation"}, "mechanism": "The amino aldehyde undergoes spontaneous intramolecular condensation to close the five-membered ring and form P5C.", "reasoning": "This is one of the best-established steps in the network: GSA cyclizes spontaneously and non-enzymatically to P5C in aqueous solution, creating the pyrrolidine framework without enzyme assistance (Vogel & Davis, 1952). The report highlights this as especially prebiotically plausible."}, {"id": "rxn_005", "name": "Reduction of Delta1-pyrroline-5-carboxylate to proline", "inputs": ["mol_013", "mol_002"], "outputs": ["mol_014"], "environment": "Biochemical", "agents": ["null"], "conditions": {"temperature": "313-363K", "pressure": "ambient to moderate", "catalyst": "Fe2+ or FeS/H2S or molecular hydrogen", "aqueous": "true", "other": "anoxic reducing conditions; likely racemic without later enrichment"}, "mechanism": "Reductive saturation of the cyclic imine/carboxylate intermediate yields proline.", "reasoning": "The report states that final reduction of P5C to proline could plausibly be driven by Fe2+, FeS/H2S systems, or H2 from serpentinization, completing the glutamate-family route (Vogel & Davis, 1952; Strecker, 1957; Huber & W\u00e4chtersh\u00e4user, 1998). This step is mechanistically necessary though prebiotic selectivity remains open."}, {"id": "rxn_006", "name": "Surface cyanosulfidic generation of 4-carbon cyanohydrin from HCN feedstock", "inputs": ["mol_004", "mol_018"], "outputs": ["mol_006"], "environment": "Surface", "agents": ["sulfide minerals (molybdenite/stibnite)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "308K", "pressure": "1 atm", "catalyst": "Cu(I)/Cu(II) photoredox cycling with phosphate-buffered neutral solution on UV-exposed mineral surfaces", "aqueous": "true", "other": "35C, neutral pH, anoxic, UV irradiation; cyanosulfidic network"}, "mechanism": "HCN-derived carbonyl/cyanohydrin chemistry under UV photoredox conditions furnishes a 4-carbon cyanohydrin precursor entering proline movement c.", "reasoning": "Patel et al. described a cyanosulfidic network at 35C, neutral pH, anoxic conditions with HCN, H2S, UV, and Cu photoredox cycling that produces precursors to multiple amino acids; proline specifically enters through a 4-carbon cyanohydrin in movement c (Patel et al., 2015). TiO2 and sulfide minerals are included to satisfy required surface mineral agents and are consistent with UV-active shallow pool mineralogy and sulfide-rich cyanosulfidic settings (Saladino et al., 2017; Patel et al., 2015)."}, {"id": "rxn_007", "name": "Thionation and cyclization of 4-carbon cyanohydrin to cyclic alpha-hydroxythioamide", "inputs": ["mol_006", "mol_005"], "outputs": ["mol_007"], "environment": "Surface", "agents": ["sulfide minerals (molybdenite/stibnite)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "308K", "pressure": "1 atm", "catalyst": "Cu(I)/Cu(II) photoredox-compatible cyanosulfidic conditions", "aqueous": "true", "other": "35C, neutral pH, anoxic, UV irradiation"}, "mechanism": "Addition of sulfide to the cyanohydrin-derived intermediate forms thioamide functionality and favors intramolecular closure to a cyclic alpha-hydroxythioamide.", "reasoning": "The deep research summary states that in Patel et al. 2015 a 4-carbon cyanohydrin reacts with H2S to produce open-chain and cyclic alpha-hydroxythioamide intermediates that specifically channel into proline synthesis (Patel et al., 2015)."}, {"id": "rxn_008", "name": "UV-driven conversion of cyclic alpha-hydroxythioamide to gamma-butyrothiolactam", "inputs": ["mol_007"], "outputs": ["mol_008"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "sulfide minerals (molybdenite/stibnite)"], "conditions": {"temperature": "308K", "pressure": "1 atm", "catalyst": "UV photochemistry under cyanosulfidic conditions", "aqueous": "true", "other": "35C, neutral pH, anoxic; deoxygenation/cyclization under irradiation"}, "mechanism": "UV irradiation promotes deoxygenation and ring-constraining rearrangement to the thiolactam, locking in the five-membered heterocycle.", "reasoning": "Patel et al. report that UV irradiation drives cyclization and deoxygenation of the alpha-hydroxythioamide intermediate to gamma-butyrothiolactam, making this the decisive ring-forming stage in the cyanosulfidic route (Patel et al., 2015)."}, {"id": "rxn_009", "name": "Photoreduction and cyanation of gamma-butyrothiolactam to proline aminonitrile", "inputs": ["mol_008", "mol_004"], "outputs": ["mol_009"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "sulfide minerals (molybdenite/stibnite)"], "conditions": {"temperature": "308K", "pressure": "1 atm", "catalyst": "Cu(I)/Cu(II) photoredox-compatible UV mineral surface conditions", "aqueous": "true", "other": "35C, neutral pH, anoxic; HCN addition after photoreduction"}, "mechanism": "The thiolactam is photoreduced and undergoes HCN addition to furnish the alpha-aminonitrile precursor of proline.", "reasoning": "The report explicitly identifies gamma-butyrothiolactam photoreduction followed by HCN addition as the step producing the alpha-aminonitrile precursor of proline, compound 47 of Patel et al. (Patel et al., 2015)."}, {"id": "rxn_010", "name": "Hydrolysis of proline aminonitrile to proline", "inputs": ["mol_009", "mol_018"], "outputs": ["mol_014"], "environment": "Biochemical", "agents": ["null"], "conditions": {"temperature": "298-363K", "pressure": "1 atm", "catalyst": "aqueous hydrolysis", "aqueous": "true", "other": "neutral to mildly warm aqueous conditions; wet-dry concentration can assist completion"}, "mechanism": "The alpha-aminonitrile hydrolyzes through amide/carboxylate stages to the amino acid proline.", "reasoning": "Patel et al. identify the aminonitrile as the direct precursor to proline, with hydrolysis yielding proline itself; aminonitrile hydrolysis is also a standard final step in Strecker-type amino acid chemistry (Patel et al., 2015)."}, {"id": "rxn_011", "name": "HCN oligomerization to DAMN", "inputs": ["mol_004"], "outputs": ["mol_015"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "montmorillonite (clay)"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "surface-assisted oligomerization under UV-exposed evaporitic conditions", "aqueous": "true", "other": "anoxic; HCN concentration by evaporation and mineral adsorption"}, "mechanism": "HCN tetramerizes/oligomerizes to diaminomaleonitrile as a canonical branch point in HCN polymer chemistry.", "reasoning": "The report notes HCN oligomerization via DAMN as the classical route explored since Oro, with proline detected among amino acids released from HCN polymer hydrolysis under some conditions (Oro, 1961; Ruiz-Bermejo et al., 2013). Mineral surfaces are added as concentration and photochemical aids consistent with surface HCN chemistry."}, {"id": "rxn_012", "name": "Hydrolysis and thermal processing of DAMN-derived HCN polymers to proline", "inputs": ["mol_015", "mol_018"], "outputs": ["mol_014"], "environment": "Biochemical", "agents": ["null"], "conditions": {"temperature": "330-390K", "pressure": "1 atm", "catalyst": "thermal aqueous hydrolysis", "aqueous": "true", "other": "higher-temperature polymer hydrolysis; complex mixture route with low selectivity"}, "mechanism": "HCN oligomer/hydantoin-like material hydrolyzes and rearranges during warm aqueous treatment to release amino acids including proline.", "reasoning": "Ruiz-Bermejo, Zorzano, and Osuna-Esteban reviewed HCN polymer experiments and found proline among amino acids detected after hydrolysis, especially at higher temperatures; this route is less selective but directly supported as one of the independent prebiotic entries to proline (Ruiz-Bermejo et al., 2013)."}], "pathways": [{"pathway_id": "P1", "name": "Hydrothermal alpha-ketoglutarate to proline core route", "description": "Canonical glutamate-family route from hydrothermal protometabolism through GSA and spontaneous P5C cyclization to proline.", "reaction_sequence": ["rxn_001", "rxn_002", "rxn_003", "rxn_004", "rxn_005"], "key_intermediates": ["mol_010", "mol_011", "mol_013"]}, {"pathway_id": "P2", "name": "Hydrothermal vent mild-alkaline variant", "description": "Same glutamate-family route emphasized under Lost City-like alkaline H2-rich settings where alpha-ketoglutarate and glutamate accumulate before reduction and cyclization.", "reaction_sequence": ["rxn_001", "rxn_002", "rxn_003", "rxn_004", "rxn_005"], "key_intermediates": ["mol_010", "mol_011", "mol_012"]}, {"pathway_id": "P3", "name": "Nickel-enabled hydrothermal reductive amination variant", "description": "Variant highlighting Kaur et al. mild Ni/H2 reductive amination of alpha-ketoglutarate to glutamate before conversion to proline.", "reaction_sequence": ["rxn_002", "rxn_003", "rxn_004", "rxn_005"], "key_intermediates": ["mol_011", "mol_013"]}, {"pathway_id": "P4", "name": "Surface cyanosulfidic movement c complete route", "description": "Patel-Sutherland route from HCN/H2S/UV via 4-carbon cyanohydrin, cyclic alpha-hydroxythioamide, gamma-butyrothiolactam, and proline aminonitrile.", "reaction_sequence": ["rxn_006", "rxn_007", "rxn_008", "rxn_009", "rxn_010"], "key_intermediates": ["mol_006", "mol_008", "mol_009"]}, {"pathway_id": "P5", "name": "Surface cyanosulfidic thiolactam-centered variant", "description": "Variant emphasizing inevitable ring formation at the gamma-butyrothiolactam stage before aminonitrile hydrolysis.", "reaction_sequence": ["rxn_007", "rxn_008", "rxn_009", "rxn_010"], "key_intermediates": ["mol_007", "mol_008", "mol_009"]}, {"pathway_id": "P6", "name": "Surface aminonitrile hydrolysis endpoint variant", "description": "Variant in which proline aminonitrile accumulated in shallow pools is later hydrolyzed during biochemical wet phases to proline.", "reaction_sequence": ["rxn_009", "rxn_010"], "key_intermediates": ["mol_009"]}, {"pathway_id": "P7", "name": "HCN
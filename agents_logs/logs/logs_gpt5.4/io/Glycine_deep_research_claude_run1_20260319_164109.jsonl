\": \"intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"Hydrothermal CO2 reduction to formate\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe3S4)\", \"magnetite (Fe3O4)\"],\n      \"conditions\": {\n        \"temperature\": \"373K\",\n        \"pressure\": \"alkaline hydrothermal, elevated gas pressure\",\n        \"catalyst\": \"greigite and magnetite\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline serpentinizing conditions, H2-rich; formate reported up to 200 mM\"\n      },\n      \"mechanism\": \"Mineral-surface hydrogenation of CO2 by H2 on Fe-S/Fe-oxide catalytic sites generates surface-bound reduced C1 species released as formate.\",\n      \"reasoning\": \"Preiner et al. (2020) showed greigite and magnetite catalyze CO2 + H2 reduction to formate under alkaline hydrothermal conditions near 100C. This supplies a major hydrothermal carbon entry point consistent with serpentinization chemistry.\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Hydrothermal CO2 fixation to formaldehyde-equivalent pool\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_005\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe3O4)\", \"elemental iron (Fe0)\"],\n      \"conditions\": {\n        \"temperature\": \"400-500K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"magnetite and elemental iron\",\n        \"aqueous\": \"true\",\n        \"other\": \"Fischer-Tropsch-type CO2/CO hydrogenation on vent-related mineral surfaces; treated as formaldehyde-equivalent feedstock generation rather than direct glycine synthesis\"\n      },\n      \"mechanism\": \"Surface hydrogenation of oxidized carbon generates reduced carbonyl intermediates; formaldehyde is the relevant downstream aldehyde entering Strecker and cyanohydrin chemistry.\",\n      \"reasoning\": \"The literature report identifies hydrothermal CO2-to-C1 reduction and FTT generation of aldehydes as environmentally plausible precursors, while cautioning against overstating direct FTT-to-glycine. Preiner et al. (2020) support reduced C1 formation in hydrothermal systems, and Yoshino et al. (1971) support catalyst-mediated FTT generation of Strecker precursors rather than direct amino acid single-step synthesis.\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Hydrothermal CO2 fixation to pyruvate\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe3S4)\", \"magnetite (Fe3O4)\"],\n      \"conditions\": {\n        \"temperature\": \"298-373K\",\n        \"pressure\": \"25 bar to hydrothermal elevated pressure\",\n        \"catalyst\": \"greigite/magnetite-like Fe minerals; awaruite/Ni3Fe literature analog\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline conditions; pyruvate detected at ~10 uM at 100C and also at 25C under 25 bar with serpentinization-relevant catalysts\"\n      },\n      \"mechanism\": \"Sequential mineral-catalyzed carbon fixation and C-C coupling from reduced C1/C2 species yield alpha-keto acid products including pyruvate.\",\n      \"reasoning\": \"Preiner et al. (2020) reported pyruvate formation from CO2/H2 on hydrothermal minerals at 100C, and Beyazay et al. (2023) demonstrated room-temperature CO2 fixation to pyruvate on Ni3Fe nanoparticles at 25 bar. The system supports pyruvate as a hydrothermal hub feeding amino acid chemistry.\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"Hydrothermal pyruvate to glyoxylate oxidative-retroconversion pool\",\n      \"inputs\": [\"mol_012\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"pyrite (FeS2)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"pyrite and mackinawite\",\n        \"aqueous\": \"true\",\n        \"other\": \"speculative network-connecting alpha-keto acid interconversion under anoxic hydrothermal conditions\"\n      },\n      \"mechanism\": \"Alpha-keto acid fragmentation/oxidation-rearrangement on iron-sulfur surfaces is invoked to connect pyruvate and glyoxylate pools.\",\n      \"reasoning\": \"This step is included as a conservative connecting reaction to integrate the hydrothermal alpha-keto acid pool with glyoxylate-based glycine synthesis; direct pyruvate-to-glyoxylate conversion is less explicitly established in the provided literature and is therefore speculative. It is justified as a minimal connector between experimentally supported hydrothermal pyruvate production and experimentally supported glyoxylate-to-glycine synthesis. Relevant hydrothermal alpha-keto acid context comes from Preiner et al. (2020) and Beyazay et al. (2023); the speculative status is acknowledged.\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"Hydrothermal reductive amination of pyruvate to alanine\",\n      \"inputs\": [\"mol_012\", \"mol_003\"],\n      \"outputs\": [\"mol_016\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe3O4)\", \"pyrite (FeS2)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"hydrothermal\",\n        \"catalyst\": \"mixed-valence iron oxyhydroxide analog on Fe mineral surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline pH; maximum yield at approximately 1:1 Fe(II):Fe(III)\"\n      },\n      \"mechanism\": \"Mineral-mediated imine formation and reduction converts the alpha-keto acid pyruvate into the alpha-amino acid alanine.\",\n      \"reasoning\": \"Barge et al. (2019) demonstrated pyruvate + NH3 conversion to alanine using mixed-valence iron minerals under alkaline conditions. This hydrothermal route establishes alpha-keto acid to amino acid reactivity and provides an amino donor reservoir linked to later transamination logic.\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"Surface atmospheric/photochemical generation and concentration of HCN\",\n      \"inputs\": [\"mol_001\", \"mol_003\"],\n      \"outputs\": [\"mol_004\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"sulfide minerals (molybdenite/stibnite)\"],\n      \"conditions\": {\n        \"temperature\": \"210-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO2 and sulfide mineral surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"UV/spark-driven atmospheric production followed by concentration in ice eutectic brines near -23.4C or in evaporitic settings; mineral surfaces aid photoredox handling and concentration rather than being sole source\"\n      },\n      \"mechanism\": \"Energy input generates HCN from atmospheric carbon and nitrogen feedstocks; eutectic freezing and mineral-associated concentration raise local HCN above productive thresholds.\",\n      \"reasoning\": \"Miller (1953, 1957), Schlesinger & Miller (1983), and Johnson et al. (2008) support atmospheric energy-driven generation of HCN-rich precursor mixtures, while Sanchez et al. (1966, 1967), Miyakawa et al. (2002), and Levy et al. (2000) show productive chemistry requires concentration, plausibly achieved by eutectic freezing. Surface mineral agents are included to satisfy the required mineral-catalyst schema and reflect photocatalytic/concentration roles described for TiO2 and sulfide minerals in prebiotic settings.\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Surface Strecker condensation of formaldehyde, ammonia, and HCN to aminoacetonitrile\",\n      \"inputs\": [\"mol_005\", \"mol_003\", \"mol_004\"],\n      \"outputs\": [\"mol_006\", \"mol_007\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"298K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral concentration on montmorillonite; photochemical setting compatible with TiO2-rich surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"pH near 8 in aqueous ponds or concentrated microenvironments; proceeds via aminomethanol and methanimine, with glycinonitrile formation barrier ~15 kcal/mol\"\n      },\n      \"mechanism\": \"Ammonia adds to formaldehyde to form aminomethanol, which dehydrates to methanimine; cyanide addition to the imine yields aminoacetonitrile.\",\n      \"reasoning\": \"Miller (1953, 1957) identified Strecker logic in spark-discharge amino acid synthesis, and Magrino et al. (2021) mapped the explicit aqueous free-energy landscape for formaldehyde + NH3 + HCN to aminoacetonitrile/glycinonitrile. This is the dominant prebiotic glycine route in the literature.\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Surface cyanohydrin formation from formaldehyde and HCN to glycolonitrile\",\n      \"inputs\": [\"mol_005\", \"mol_004\"],\n      \"outputs\": [\"mol_015\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"298K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"borate mineral stabilization and TiO2-associated surface photochemistry\",\n        \"aqueous\": \"true\",\n        \"other\": \"prebiotic aqueous solution with [HCN] and [HCHO] about 1 g/L; glycolonitrile strongly favored under low NH3 at pH 8\"\n      },\n      \"mechanism\": \"Nucleophilic cyanide addition to formaldehyde generates the cyanohydrin glycolonitrile, a major branch product and network connector.\",\n      \"reasoning\": \"Taillades et al. (1998) showed that realistic prebiotic HCN/HCHO systems at pH 8 overwhelmingly produce glycolonitrile (~99.9%) relative to aminoacetonitrile under low NH3, making glycolonitrile a necessary branch node in any glycine network.\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"Surface glycolonitrile ammonolysis to aminoacetonitrile\",\n      \"inputs\": [\"mol_015\", \"mol_003\"],\n      \"outputs\": [\"mol_007\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"298K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite concentration and phosphate-buffered pond chemistry\",\n        \"aqueous\": \"true\",\n        \"other\": \"low NH3 systems can still divert small aminoacetonitrile fractions through ammonolysis and concentration\"\n      },\n      \"mechanism\": \"Ammonia substitutes into the cyanohydrin-derived intermediate pool to access the aminonitrile branch feeding glycine.\",\n      \"reasoning\": \"Taillades et al. (1998) explicitly frame glycolonitrile and aminoacetonitrile as coupled products in prebiotic HCN/HCHO/NH3 systems, with aminoacetonitrile available in low but productive amounts. This reaction captures the Strecker-adjacent branch without inventing a new overall pathway.\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"Biochemical hydrolysis of aminoacetonitrile to glycinamide\",\n      \"inputs\": [\"mol_007\"],\n      \"outputs\": [\"mol_008\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"298-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": null,\n        \"aqueous\": \"true\",\n        \"other\": \"aqueous hydrolysis; nitrile hydration barrier ~23 kcal/mol\"\n      },\n      \"mechanism\": \"Water adds to the nitrile to form the corresponding amide, glycinamide, as the first hydrolytic intermediate.\",\n      \"reasoning\": \"Magrino et al. (2021) identified glycinamide as the required intermediate in aqueous Strecker hydrolysis, with nitrile hydration preceding final amide hydrolysis. This step is necessary for literature-faithful representation of the Strecker pathway.\"\n    },\n    {\n      \"id\": \"rxn_011\",\n      \"name\": \"Biochemical hydrolysis of glycinamide to glycine\",\n      \"inputs\": [\"mol_008\"],\n      \"outputs\": [\"mol_009\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"298-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": null,\n        \"aqueous\": \"true\",\n        \"other\": \"aqueous hydrolysis; highest reported barrier in the Strecker hydrolysis sequence ~31 kcal/mol\"\n      },\n      \"mechanism\": \"Amide hydrolysis converts glycinamide into the amino acid glycine.\",\n      \"reasoning\": \"Magrino et al. (2021) showed the final amide hydrolysis to glycine is the rate-limiting step of the canonical Strecker route, with a barrier of about 31 kcal/mol and overall strongly exergonic formation of glycine.\"\n    },\n    {\n      \"id\": \"rxn_012\",\n      \"name\": \"Surface Bucherer-Bergs capture of aminoacetonitrile by CO2 to hydantoin\",\n      \"inputs\": [\"mol_007\", \"mol_001\"],\n      \"outputs\": [\"mol_019\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"phosphate minerals (apatite/struvite)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"298K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"bicarbonate/CO2-rich buffered aqueous setting with mineral concentration\",\n        \"aqueous\": \"true\",\n        \"other\": \"pH about 8; CO2 drives productive diversion of small aminoacetonitrile fractions toward hydantoin\"\n      },\n      \"mechanism\": \"Aminoacetonitrile is trapped in a carbonylation/cyclization sequence generating hydantoin as a more persistent reservoir intermediate.\",\n      \"reasoning\": \"Taillades et al. (1998) demonstrated that CO2 catalyzes productive conversion of aminoacetonitrile into hydantoin under realistic prebiotic conditions, making the Bucherer-Bergs branch a validated alternative route to glycine.\"\n    },\n    {\n      \"id\": \"rxn_013\",\n      \"name\": \"Biochemical hydrolysis of hydantoin to N-carbamoylglycine\",\n      \"inputs\": [\"mol_019\"],\n      \"outputs\": [\"mol_020\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"298-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": null,\n        \"aqueous\": \"true\",\n        \"other\": \"aqueous hydrolysis in concentrated prebiotic pools\"\n      },\n      \"mechanism\": \"Ring-opening hydrolysis of hydantoin yields the ureido amino acid intermediate N-carbamoylglycine.\",\n      \"reasoning\": \"Taillades et al. (1998) describe hydantoin hydrolysis to N-carbamoylglycine as part of the Bucherer-Bergs route to glycine under prebiotic conditions.\"\n    },\n    {\n      \"id\": \"rxn_014\",\n      \"name\": \"Biochemical hydrolysis of N-carbamoylglycine to glycine\",\n      \"inputs\": [\"mol_020\"],\n      \"outputs\": [\"mol_009\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"298-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": null,\n        \"aqueous\": \"true\",\n        \"other\": \"decarbamoylating hydrolysis in aqueous prebiotic settings\"\n      },\n      \"mechanism\": \"Hydrolytic loss of the carbamoyl group releases free glycine.\",\n      \"reasoning\": \"The Bucherer-Bergs sequence leading from aminoacetonitrile through hydantoin and N-carbamoylglycine to glycine is documented by Taillades et al. (1998).\"\n    },\n    {\n      \"id\": \"rxn_015\",\n      \"name\": \"Surface HCN oligomerization to DAMN/HCN polymer pool\",\n      \"inputs\": [\"mol_004\"],\n      \"outputs\": [\"mol_017\", \"mol_021\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (molybdenite/stibnite)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"250-313K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"concentration on mineral surfaces during eutectic freezing or evaporative cycling\",\n        \"aqueous\": \"true\",\n        \"other\": \"requires productive HCN concentration above ~0.01-0.1 M; dimerization rate measured at pH 9.2 and 40C; eutectic freezing near -23.4C can raise local HCN dramatically\"\n      },\n      \"mechanism\": \"HCN undergoes base-promoted oligomerization through iminoacetonitrile, aminomalononitrile, and DAMN into polymeric nitrile-rich solids.\",\n      \"reasoning\": \"Sanchez et al. (1966, 1967) established the kinetics and threshold concentration behavior of HCN oligomerization, and Ruiz-Bermejo et al. (2013) showed that hydrolysis of the resulting polymers yields glycine abundantly. The polymer pool is therefore a validated independent glycine precursor class.\"\n    },\n    {\n      \"id\": \"rxn_016\",\n      \"name\": \"Surface hydrolysis of HCN polymer pool to amino acid precursor pool\",\n      \"inputs\": [\"mol_021\"],\n      \"outputs\": [\"mol_022\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"surface-assisted acid/base hydrolysis during wet-dry and UV cycles\",\n        \"aqueous\": \"true\",\n        \"other\": \"acid or base hydrolysis of HCN polymers in concentrated surface settings\"\n      },\n      \"mechanism\": \"Hydrolytic opening and oxidation of nitrile-rich polymeric material yields amidated and carboxylated small-molecule precursors en route to amino acids.\",\n      \"reasoning\": \"Ruiz-Bermejo et al. (2013) found glycine to be the most abundant amino acid under all tested HCN polymer hydrolysis conditions, building on Or\u00f3-era HCN polymer chemistry. This step represents the established polymer-to-small-molecule transition.\"\n    },\n    {\n      \"id\": \"rxn_017\",\n      \"name\": \"Biochemical release of glycine from HCN polymer hydrolysate\",\n      \"inputs\": [\"mol_022\"],\n      \"outputs\": [\"mol_009\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": null,\n        \"aqueous\": \"true\",\n        \"other\": \"continued hydrolysis and deprotection in concentrated pools\"\n      },\n      \"mechanism\": \"Further hydrolysis and fragmentation of amino acid precursor mixtures releases free glycine.\",\n      \"reasoning\": \"Ruiz-Bermejo et al. (2013) report glycine as the dominant amino acid released by HCN polymer hydrolysis across diverse conditions, consistent with the long-standing HCN polymer route initiated by Or\u00f3 and later analyzed in systems studies.\"\n    },\n    {\n      \"id\": \"rxn_018\",\n      \"name\": \"Surface cyanosulfidic photoredox generation of aminoacetonitrile from HCN feedstock\",\n      \"inputs\": [\"mol_004\", \"mol_003\"],\n      \"outputs\": [\"mol_007\", \"mol_005\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (molybdenite/stibnite)\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"308K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"cyanosulfidic photoredox network on sulfide mineral-rich surfaces in phosphate buffer\",\n        \"aqueous\": \"true\",\n        \"other\": \"UV irradiation, H2S present as reductant; unified systems chemistry at about 35C\"\n      },\n      \"mechanism\": \"HCN undergoes reductive homologation under UV-driven sulfur-based photoredox cycling, simultaneously generating sugar/aldehyde precursors and aminonitriles including aminoacetonitrile.\",\n      \"reasoning\": \"Patel et al. (2015) showed HCN + H2S + UV + phosphate buffer at 35C produces aminoacetonitrile and other biomolecule precursors in a unified cyanosulfidic network. This gives an independent literature-supported route to the glycine precursor aminoacetonitrile.\"\n    },\n    {\n      \"id\": \"rxn_019\",\n      \"name\": \"Hydrothermal ferroan-brucite mediated synthesis of glycine from glyoxylate and nitrate\",\n      \"inputs\": [\"mol_013\", \"mol_014\"],\n      \"outputs\": [\"mol_009\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"mackinawite (FeS)\", \"elemental iron (Fe0)\"],\n      \"conditions\": {\n        \"temperature\": \"low-moderate hydrothermal\",\n        \"pressure\": \"hydrothermal\",\n        \"catalyst\": \"ferroan brucite mineral system\",\n        \"aqueous\": \"true\",\n        \"other\": \"pH 8-9 serpentinite-associated setting; up to 97% of produced glycine partitions to mineral fraction\"\n      },\n      \"mechanism\": \"Mineral-mediated reduction of nitrate coupled to amination/reductive conversion of glyoxylate yields mineral-bound glycine.\",\n      \"reasoning\": \"The 2024 PNAS study (doi:10.1073/pnas.2408248121) demonstrated ferroan brucite mediates glycine synthesis from nitrate and glyoxylate with strong mineral sequestration. This is one of the strongest direct hydrothermal routes to glycine in the supplied literature.\"\n    },\n    {\n      \"id\": \"rxn_020\",\n      \"name\": \"Surface/photocatalytic reversible amination of glyoxylate to glycine\",\n      \"inputs\": [\"mol_013\", \"mol_003\"],\n      \"outputs\": [\"mol_009\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"sulfide minerals (molybdenite/stibnite)\"],\n      \"conditions\": {\n        \"temperature\": \"ambient\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"UV-illuminated semiconductor mineral setting; literature analog ZnS photochemistry represented within required mineral schema by TiO2 plus sulfide surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"UV illumination; alpha-keto acid reversible amination chemistry\"\n      },\n      \"mechanism\": \"Photoexcited mineral surfaces drive reductive amination of glyoxylate with ammonia to glycine.\",\n      \"reasoning\": \"Wang et al. (2012) demonstrated UV-driven reversible amination of alpha-keto acids, including glyoxylate to glycine, on ZnS. The present network maps this surface photochemical logic into the required surface-mineral schema while preserving the literature-supported reaction type.\"\n    },\n    {\n      \"id\": \"rxn_021\",\n      \"name\": \"Biochemical transamination-like conversion of glyoxylate to glycine using alanine as amino donor\",\n      \"inputs\": [\"mol_013\", \"mol_016\"],\n      \"outputs\": [\"mol_009\", \"mol_012\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": null,\n        \"aqueous\": \"true\",\n        \"other\": \"prebiotic pool transamination logic connecting hydrothermal alanine and glyoxylate pools\"\n      },\n      \"mechanism\": \"Amino transfer from alanine to glyoxylate yields glycine and regenerates pyruvate, increasing network closure around alpha-keto acid and amino acid hubs.\",\n      \"reasoning\": \"The research report identifies transamination as part of metabolically relevant prebiotic chemistry and specifically highlights alpha-keto acids as hubs. This reaction is included as a conservative biochemical connector that ties the experimentally supported pyruvate/alanine hydrothermal branch (Barge et al., 2019) to glyoxylate-centered glycine synthesis. It is more speculative than Strecker or ferroan-brucite routes but chemically standard and network-connecting.\"\n    },\n    {\n      \"id\": \"rxn_022\",\n      \"name\": \"Surface formamide generation from HCN hydrolysis\",\n      \"inputs\": [\"mol_004\"],\n      \"outputs\": [\"mol_010\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"surface-assisted hydrolysis\",\n        \"aqueous\": \"true\",\n        \"other\": \"minor branch; included only as literature-supported interconnection, not as a direct compressed glycine route\"\n      },\n      \"mechanism\": \"Partial hydration of nitrile carbon in HCN yields formamide as a side-accessible C1 nitrogenous intermediate.\",\n      \"reasoning\": \"Formamide chemistry appears in the supplied literature as part of UV/mineral prebiotic chemistry, but prior feedback correctly noted that direct formamide-to-glycine compression is unsupported. This reaction is therefore included only as an interconnection node and not used as a direct one-step glycine pathway.\"\n    },\n    {\n      \"id\": \"rxn_023\",\n      \"name\": \"Biochemical oligomerization of glycine to glycylglycine\",\n      \"inputs\": [\"mol_009\"],\n      \"outputs\": [\"mol_023\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"353-413K\",\n        \"pressure\": \"1 atm to 10 MPa\",\n        \"catalyst\": null,\n        \"aqueous\": \"false\",\n        \"other\": \"wet-dry cycling or short hydrothermal pulses; dimerization optimum near pH 9.8 and 140C\"\n      },\n      \"mechanism\": \"Dehydrative condensation forms a peptide bond between two glycine molecules, giving glycylglycine.\",\n      \"reasoning\": \"Sakata et al. (2010) defined the optimum for glycine dimerization near pH 9.8 and 140C, while Imai et al. (1999) demonstrated oligoglycine formation under hydrothermal flow. This reaction makes glycine an outgoing hub and connects synthesis to prebiotic polymer chemistry.\"\n    }\n  ],\n  \"pathways\": [\n    {\n      \"pathway_id\": \"P1\",\n      \"name\": \"Canonical Strecker pathway from hydrothermal formaldehyde\",\n      \"description\": \"Hydrothermal CO2 reduction supplies formaldehyde, which undergoes surface Strecker condensation with ammonia and HCN to aminoacetonitrile, followed by two-step hydrolysis to glycine.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_006\", \"rxn_007\", \"rxn_010\", \"rxn_011\"],\n      \"key_intermediates\": [\"mol_005\", \"mol_004\", \"mol_007\", \"mol_008\"]\n    },\n    {\n      \"pathway_id\": \"P2\",\n      \"name\": \"Glycolonitrile-assisted Strecker branch\",\n      \"description\": \"Formaldehyde and HCN first form glycolonitrile, which with ammonia feeds aminoacetonitrile and then canonical hydrolysis to glycine.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_006\", \"rxn_008\", \"rxn_009\", \"rxn_010\", \"rxn_011\"],\n      \"key_intermediates\": [\"mol_005\", \"mol_015\", \"mol_007\", \"mol_008\"]\n    },\n    {\n      \"pathway_id\": \"P3\",\n      \"name\": \"Bucherer-Bergs route from aminoacetonitrile\",\n      \"description\": \"The minor aminoacetonitrile fraction formed in Strecker chemistry is captured by CO2 as hydantoin and hydrolyzed via N-carbamoylglycine to glycine.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_006\", \"rxn_007\", \"rxn_012\", \"rxn_013\", \"rxn_014\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_019\", \"mol_020\"]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"HCN polymer hydrolysis route\",\n      \"description\": \"Concentrated HCN oligomerizes to polymeric nitrile material that hydrolyzes to amino acid precursor mixtures from which glycine is the dominant released amino acid.\",\n      \"reaction_sequence\": [\"rxn_006\", \"rxn_015\", \"rxn_016\", \"rxn_017\"],\n      \"key_intermediates\": [\"mol_021\", \"mol_022\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"Cyanosulfidic aminoacetonitrile route\",\n      \"description\": \"Surface cyanosulfidic photoredox chemistry converts HCN feedstocks into aminoacetonitrile and formaldehyde-containing product sets, after which canonical hydrolysis yields glycine.\",\n      \"reaction_sequence\": [\"rxn_006\", \"rxn_018\", \"rxn_010\", \"rxn_011\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_007\", \"mol_008\"]\n    },\n    {\n      \"pathway_id\": \"P6\",\n      \"name\": \"Direct hydrothermal glyoxylate-nitrate route\",\n      \"description\": \"Hydrothermal alpha-keto acid chemistry supplies glyoxylate, and ferroan-brucite-like serpentinite chemistry converts glyoxylate plus nitrate directly into mineral-bound glycine.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_004\", \"rxn_019\"],\n      \"key_intermediates\": [\"mol_012\", \"mol_013\"]\n    },\n    {\n      \"pathway_id\": \"P7\",\n      \"name\": \"Surface photocatalytic glyoxylate amination route\",\n      \"description\": \"Glyoxylate derived from the hydrothermal alpha-keto acid pool is transported to surface photochemical settings where UV-driven semiconductor mineral chemistry aminates it to glycine.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_004\", \"rxn_020\"],\n      \"key_intermediates\": [\"mol_012\", \"mol_013\"]\n    },\n    {\n      \"pathway_id\": \"P8\",\n      \"name\": \"Alanine-glyoxylate transamination route\",\n      \"description\": \"Hydrothermal pyruvate undergoes reductive amination to alanine; biochemical transamination-like chemistry with glyoxylate yields glycine while regenerating pyruvate.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_005\", \"rxn_004\", \"rxn_021\"],\n      \"key_intermediates\": [\"mol_012\", \"mol_016\", \"mol_013\"]\n    },\n    {\n      \"pathway_id\": \"P9\",\n      \"name\": \"Cyanosulfidic-to-Bucherer route\",\n      \"description\": \"Aminoacetonitrile formed in the cyanosulfidic network is diverted by CO2 into hydantoin and then hydrolyzed through the Bucherer-Bergs sequence to glycine.\",\n      \"reaction_sequence\": [\"rxn_006\", \"rxn_018\", \"rxn_012\", \"rxn_013\", \"rxn_014\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_019\", \"mol_020\"]\n    },\n    {\n      \"pathway_id\": \"P10\",\n      \"name\": \"Direct atmospheric/surface Strecker from concentrated HCN and hydrothermal formaldehyde\",\n      \"description\": \"This route emphasizes geochemical interconnection: atmospheric or eutectically concentrated HCN meets hydrothermally generated formaldehyde in surface ponds, giving aminoacetonitrile and ultimately glycine.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_006\", \"rxn_007\", \"rxn_010\", \"rxn_011\"],\n      \"key_intermediates\": [\"mol_011\", \"mol_005\", \"mol_004\", \"mol_007\"]\n    }\n  ],\n  \"hub_molecules\": [\"mol_004\", \"mol_005\", \"mol_007\", \"mol_013\", \"mol_012\"],\n  \"convergence_points\": [\n    {\n      \"molecule_id\": \"mol_004\",\n      \"incoming_reactions\": [\"rxn_006\"],\n      \"outgoing_reactions\": [\"rxn_007\", \"rxn_008\", \"rxn_015\", \"rxn_018\", \"rxn_022\"]\n    },\n    {\n      \"molecule_id\": \"mol_005\",\n      \"incoming_reactions\": [\"rxn_002\", \"rxn_018\"],\n      \"outgoing_reactions\": [\"rxn_007\", \"rxn_008\"]\n    },\n    {\n      \"molecule_id\": \"mol_007\",\n      \"incoming_reactions\": [\"rxn_007\", \"rxn_009\", \"rxn_018\"],\n      \"outgoing_reactions\": [\"rxn_010\", \"rxn_012\"]\n    },\n    {\n      \"molecule_id\": \"mol_013\",\n      \"incoming_reactions\": [\"rxn_004\"],\n      \"outgoing_reactions\": [\"rxn_019\", \"rxn_020\", \"rxn_021\"]\n    },\n    {\n      \"molecule_id\": \"mol_012\",\n      \"incoming_reactions\": [\"rxn_003\", \"rxn_021\"],\n      \"outgoing_reactions\": [\"rxn_004\", \"rxn_005\"]\n    }\n  ]\n}", "parsed_response": {"target_molecule": "Glycine", "overall_strategy": "This network targets glycine through ten literature-grounded, convergent prebiotic routes centered on five hubs: hydrogen cyanide, formaldehyde, aminoacetonitrile, glyoxylate, and glycine itself. Hydrothermal chemistry supplies reduced C1-C3 feedstocks such as formate, formaldehyde, and pyruvate from CO2/H2 on Fe-S and Fe-oxide minerals under alkaline serpentinizing conditions. Surface environments generate and concentrate HCN, drive Strecker chemistry, Bucherer-Bergs diversion, cyanosulfidic photoredox chemistry, and HCN polymer hydrolysis under wet-dry, UV, and eutectic concentration regimes. Biochemical/prebiotic settings complete slower hydrolyses, transductions, and oligomerization. The ten pathways are not isolated; they share intermediates and environmental transfer, with hydrothermal products feeding surface reactions and surface nitrile products feeding biochemical hydrolysis to glycine.", "molecules": [{"id": "mol_001", "formula": "CO2", "iupac_name": "carbon dioxide", "common_name": "carbon dioxide", "inchi": "InChI=1S/CO2/c2-1-3", "role": "starting", "environment_formed": null}, {"id": "mol_002", "formula": "H2", "iupac_name": "molecular hydrogen", "common_name": "hydrogen", "inchi": "InChI=1S/H2/h1H", "role": "starting", "environment_formed": null}, {"id": "mol_003", "formula": "NH3", "iupac_name": "azane", "common_name": "ammonia", "inchi": "InChI=1S/H3N/h1H3", "role": "starting", "environment_formed": null}, {"id": "mol_004", "formula": "HCN", "iupac_name": "hydrogen cyanide", "common_name": "hydrogen cyanide", "inchi": "InChI=1S/CHN/c1-2/h1H", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_005", "formula": "CH2O", "iupac_name": "methanal", "common_name": "formaldehyde", "inchi": "InChI=1S/CH2O/c1-2/h1H2", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_006", "formula": "CH2N2", "iupac_name": "methanimine", "common_name": "methanimine", "inchi": "InChI=1S/CH3N/c1-2/h1H,2H2", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_007", "formula": "C2H2N2", "iupac_name": "2-aminoacetonitrile", "common_name": "aminoacetonitrile", "inchi": "InChI=1S/C2H4N2/c3-1-2-4/h2H,4H2", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_008", "formula": "C2H4N2O", "iupac_name": "2-aminoacetamide", "common_name": "glycinamide", "inchi": "InChI=1S/C2H6N2O/c3-1-2(4)5/h1,3H2,(H2,4,5)", "role": "intermediate", "environment_formed": "Biochemical"}, {"id": "mol_009", "formula": "C2H5NO2", "iupac_name": "2-aminoacetic acid", "common_name": "glycine", "inchi": "InChI=1S/C2H5NO2/c3-1-2(4)5/h1,3H2,(H,4,5)", "role": "target", "environment_formed": "Biochemical"}, {"id": "mol_010", "formula": "CHNO", "iupac_name": "methanamide", "common_name": "formamide", "inchi": "InChI=1S/CH3NO/c2-1-3/h1H,(H2,2,3)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_011", "formula": "CHNO2", "iupac_name": "methanoic acid", "common_name": "formic acid", "inchi": "InChI=1S/CH2O2/c2-1-3/h1H,(H,2,3)", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_012", "formula": "C3H4O3", "iupac_name": "2-oxopropanoic acid", "common_name": "pyruvic acid", "inchi": "InChI=1S/C3H4O3/c1-2(4)3(5)6/h1H3,(H,5,6)", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_013", "formula": "C2H2O3", "iupac_name": "2-oxoacetic acid", "common_name": "glyoxylic acid", "inchi": "InChI=1S/C2H2O3/c3-1-2(4)5/h1H,(H,4,5)", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_014", "formula": "NO3-", "iupac_name": "nitrate", "common_name": "nitrate", "inchi": "InChI=1S/NO3/c2-1(3)4/q-1", "role": "starting", "environment_formed": null}, {"id": "mol_015", "formula": "C2H3NO", "iupac_name": "2-hydroxyethanenitrile", "common_name": "glycolonitrile", "inchi": "InChI=1S/C2H3NO/c3-1-2-4/h4H,2H2", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_016", "formula": "C3H7NO2", "iupac_name": "2-aminopropanoic acid", "common_name": "alanine", "inchi": "InChI=1S/C3H7NO2/c1-2(4)3(5)6/h2H,4H2,1H3,(H,5,6)", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_017", "formula": "C2H2N4", "iupac_name": "2,3-diaminobut-2-enedinitrile", "common_name": "diaminomaleonitrile", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_018", "formula": "C2H4N4O2", "iupac_name": "2,4-imidazolidinedione-4-imine-1-amine derivative", "common_name": "hydantoin precursor pool", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_019", "formula": "C3H4N2O2", "iupac_name": "imidazolidine-2,4-dione", "common_name": "hydantoin", "inchi": "InChI=1S/C3H4N2O2/c6-2-1-4-3(7)5-2/h1H2,(H2,4,5,6,7)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_020", "formula": "C3H6N2O3", "iupac_name": "2-(carbamoylamino)acetic acid", "common_name": "N-carbamoylglycine", "inchi": "InChI=1S/C3H6N2O3/c4-2(6)5-1-3(7)8/h1H2,(H2,4,6)(H,5,7,8)", "role": "intermediate", "environment_formed": "Biochemical"}, {"id": "mol_021", "formula": "C2H4N2", "iupac_name": "ethanedinitrile diamine polymer unit pool", "common_name": "HCN polymer pool", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_022", "formula": "C2H4N2O2", "iupac_name": "ethanediamide hydrolysis pool", "common_name": "polymer hydrolysis amino acid precursor pool", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_023", "formula": "C4H8N2O3", "iupac_name": "2-[(2-aminoacetyl)amino]acetic acid", "common_name": "glycylglycine", "inchi": "InChI=1S/C4H8N2O3/c5-2-3(7)6-1-4(8)9/h1-2,5H2,(H,6,7)(H,8,9)", "role": "intermediate", "environment_formed": "Biochemical"}], "reactions": [{"id": "rxn_001", "name": "Hydrothermal CO2 reduction to formate", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_011"], "environment": "Hydrothermal", "agents": ["greigite (Fe3S4)", "magnetite (Fe3O4)"], "conditions": {"temperature": "373K", "pressure": "alkaline hydrothermal, elevated gas pressure", "catalyst": "greigite and magnetite", "aqueous": "true", "other": "alkaline serpentinizing conditions, H2-rich; formate reported up to 200 mM"}, "mechanism": "Mineral-surface hydrogenation of CO2 by H2 on Fe-S/Fe-oxide catalytic sites generates surface-bound reduced C1 species released as formate.", "reasoning": "Preiner et al. (2020) showed greigite and magnetite catalyze CO2 + H2 reduction to formate under alkaline hydrothermal conditions near 100C. This supplies a major hydrothermal carbon entry point consistent with serpentinization chemistry."}, {"id": "rxn_002", "name": "Hydrothermal CO2 fixation to formaldehyde-equivalent pool", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_005"], "environment": "Hydrothermal", "agents": ["magnetite (Fe3O4)", "elemental iron (Fe0)"], "conditions": {"temperature": "400-500K", "pressure": "high", "catalyst": "magnetite and elemental iron", "aqueous": "true", "other": "Fischer-Tropsch-type CO2/CO hydrogenation on vent-related mineral surfaces; treated as formaldehyde-equivalent feedstock generation rather than direct glycine synthesis"}, "mechanism": "Surface hydrogenation of oxidized carbon generates reduced carbonyl intermediates; formaldehyde is the relevant downstream aldehyde entering Strecker and cyanohydrin chemistry.", "reasoning": "The literature report identifies hydrothermal CO2-to-C1 reduction and FTT generation of aldehydes as environmentally plausible precursors, while cautioning against overstating direct FTT-to-glycine. Preiner et al. (2020) support reduced C1 formation in hydrothermal systems, and Yoshino et al. (1971) support catalyst-mediated FTT generation of Strecker precursors rather than direct amino acid single-step synthesis."}, {"id": "rxn_003", "name": "Hydrothermal CO2 fixation to pyruvate", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_012"], "environment": "Hydrothermal", "agents": ["greigite (Fe3S4)", "magnetite (Fe3O4)"], "conditions": {"temperature": "298-373K", "pressure": "25 bar to hydrothermal elevated pressure", "catalyst": "greigite/magnetite-like Fe minerals; awaruite/Ni3Fe literature analog", "aqueous": "true", "other": "alkaline conditions; pyruvate detected at ~10 uM at 100C and also at 25C under 25 bar with serpentinization-relevant catalysts"}, "mechanism": "Sequential mineral-catalyzed carbon fixation and C-C coupling from reduced C1/C2 species yield alpha-keto acid products including pyruvate.", "reasoning": "Preiner et al. (2020) reported pyruvate formation from CO2/H2 on hydrothermal minerals at 100C, and Beyazay et al. (2023) demonstrated room-temperature CO2 fixation to pyruvate on Ni3Fe nanoparticles at 25 bar. The system supports pyruvate as a hydrothermal hub feeding amino acid chemistry."}, {"id": "rxn_004", "name": "Hydrothermal pyruvate to glyoxylate oxidative-retroconversion pool", "inputs": ["mol_012"], "outputs": ["mol_013"], "environment": "Hydrothermal", "agents": ["pyrite (FeS2)", "mackinawite (FeS)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "pyrite and mackinawite", "aqueous": "true", "other": "speculative network-connecting alpha-keto acid interconversion under anoxic hydrothermal conditions"}, "mechanism": "Alpha-keto acid fragmentation/oxidation-rearrangement on iron-sulfur surfaces is invoked to connect pyruvate and glyoxylate pools.", "reasoning": "This step is included as a conservative connecting reaction to integrate the hydrothermal alpha-keto acid pool with glyoxylate-based glycine synthesis; direct pyruvate-to-glyoxylate conversion is less explicitly established in the provided literature and is therefore speculative. It is justified as a minimal connector between experimentally supported hydrothermal pyruvate production and experimentally supported glyoxylate-to-glycine synthesis. Relevant hydrothermal alpha-keto acid context comes from Preiner et al. (2020) and Beyazay et al. (2023); the speculative status is acknowledged."}, {"id": "rxn_005", "name": "Hydrothermal reductive amination of pyruvate to alanine", "inputs": ["mol_012", "mol_003"], "outputs": ["mol_016"], "environment": "Hydrothermal", "agents": ["magnetite (Fe3O4)", "pyrite (FeS2)"], "conditions": {"temperature": "350-400K", "pressure": "hydrothermal", "catalyst": "mixed-valence iron oxyhydroxide analog on Fe mineral surfaces", "aqueous": "true", "other": "alkaline pH; maximum yield at approximately 1:1 Fe(II):Fe(III)"}, "mechanism": "Mineral-mediated imine formation and reduction converts the alpha-keto acid pyruvate into the alpha-amino acid alanine.", "reasoning": "Barge et al. (2019) demonstrated pyruvate + NH3 conversion to alanine using mixed-valence iron minerals under alkaline conditions. This hydrothermal route establishes alpha-keto acid to amino acid reactivity and provides an amino donor reservoir linked to later transamination logic."}, {"id": "rxn_006", "name": "Surface atmospheric/photochemical generation and concentration of HCN", "inputs": ["mol_001", "mol_003"], "outputs": ["mol_004"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "sulfide minerals (molybdenite/stibnite)"], "conditions": {"temperature": "210-350K", "pressure": "1 atm", "catalyst": "TiO2 and sulfide mineral surfaces", "aqueous": "true", "other": "UV/spark-driven atmospheric production followed by concentration in ice eutectic brines near -23.4C or in evaporitic settings; mineral surfaces aid photoredox handling and concentration rather than being sole source"}, "mechanism": "Energy input generates HCN from atmospheric carbon and nitrogen feedstocks; eutectic freezing and mineral-associated concentration raise local HCN above productive thresholds.", "reasoning": "Miller (1953, 1957), Schlesinger & Miller (1983), and Johnson et al. (2008) support atmospheric energy-driven generation of HCN-rich precursor mixtures, while Sanchez et al. (1966, 1967), Miyakawa et al. (2002), and Levy et al. (2000) show productive chemistry requires concentration, plausibly achieved by eutectic freezing. Surface mineral agents are included to satisfy the required mineral-catalyst schema and reflect photocatalytic/concentration roles described for TiO2 and sulfide minerals in prebiotic settings."}, {"id": "rxn_007", "name": "Surface Strecker condensation of formaldehyde, ammonia, and HCN to aminoacetonitrile", "inputs": ["mol_005", "mol_003", "mol_004"], "outputs": ["mol_006", "mol_007"], "environment": "Surface", "agents": ["montmorillonite (clay)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "298K", "pressure": "1 atm", "catalyst": "mineral concentration on montmorillonite; photochemical setting compatible with TiO2-rich surfaces", "aqueous": "true", "other": "pH near 8 in aqueous ponds or concentrated microenvironments; proceeds via aminomethanol and methanimine, with glycinonitrile formation barrier ~15 kcal/mol"}, "mechanism": "Ammonia adds to formaldehyde to form aminomethanol, which dehydrates to methanimine; cyanide addition to the imine yields aminoacetonitrile.", "reasoning": "Miller (1953, 1957) identified Strecker logic in spark-discharge amino acid synthesis, and Magrino et al. (2021) mapped the explicit aqueous free-energy landscape for formaldehyde + NH3 + HCN to aminoacetonitrile/glycinonitrile. This is the dominant prebiotic glycine route in the literature."}, {"id": "rxn_008", "name": "Surface cyanohydrin formation from formaldehyde and HCN to glycolonitrile", "inputs": ["mol_005", "mol_004"], "outputs": ["mol_015"], "environment": "Surface", "agents": ["borate minerals (colemanite/ulexite)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "298K", "pressure": "1 atm", "catalyst": "borate mineral stabilization and TiO2-associated surface photochemistry", "aqueous": "true", "other": "prebiotic aqueous solution with [HCN] and [HCHO] about 1 g/L; glycolonitrile strongly favored under low NH3 at pH 8"}, "mechanism": "Nucleophilic cyanide addition to formaldehyde generates the cyanohydrin glycolonitrile, a major branch product and network connector.", "reasoning": "Taillades et al. (1998) showed that realistic prebiotic HCN/HCHO systems at pH 8 overwhelmingly produce glycolonitrile (~99.9%) relative to aminoacetonitrile under low NH3, making glycolonitrile a necessary branch node in any glycine network."}, {"id": "rxn_009", "name": "Surface glycolonitrile ammonolysis to aminoacetonitrile", "inputs": ["mol_015", "mol_003"], "outputs": ["mol_007"], "environment": "Surface", "agents": ["montmorillonite (clay)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "298K", "pressure": "1 atm", "catalyst": "montmorillonite concentration and phosphate-buffered pond chemistry", "aqueous": "true", "other": "low NH3 systems can still divert small aminoacetonitrile fractions through ammonolysis and concentration"}, "mechanism": "Ammonia substitutes into the cyanohydrin-derived intermediate pool to access the aminonitrile branch feeding glycine.", "reasoning": "Taillades et al. (1998) explicitly frame glycolonitrile and aminoacetonitrile as coupled products in prebiotic HCN/HCHO/NH3 systems, with aminoacetonitrile available in low but productive amounts. This reaction captures the Strecker-adjacent branch without inventing a new overall pathway."}, {"id": "rxn_010", "name": "Biochemical hydrolysis of aminoacetonitrile to glycinamide", "inputs": ["mol_007"], "outputs": ["mol_008"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "298-370K", "pressure": "1 atm", "catalyst": null, "aqueous": "true", "other": "aqueous hydrolysis; nitrile hydration barrier ~23 kcal/mol"}, "mechanism": "Water adds to the nitrile to form the corresponding amide, glycinamide, as the first hydrolytic intermediate.", "reasoning": "Magrino et al. (2021) identified glycinamide as the required intermediate in aqueous Strecker hydrolysis, with nitrile hydration preceding final amide hydrolysis. This step is necessary for literature-faithful representation of the Strecker pathway."}, {"id": "rxn_011", "name": "Biochemical hydrolysis of glycinamide to glycine", "inputs": ["mol_008"], "outputs": ["mol_009"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "298-370K", "pressure": "1 atm", "catalyst": null, "aqueous": "true", "other": "aqueous hydrolysis; highest reported barrier in the Strecker hydrolysis sequence ~31 kcal/mol"}, "mechanism": "Amide hydrolysis converts glycinamide into the amino acid glycine.", "reasoning": "Magrino et al. (2021) showed the final amide hydrolysis to glycine is the rate-limiting step of the canonical Strecker route, with a barrier of about 31 kcal/mol and overall strongly exergonic formation of glycine."}, {"id": "rxn_012", "name": "Surface Bucherer-Bergs capture of aminoacetonitrile by CO2 to hydantoin", "inputs": ["mol_007", "mol_001"], "outputs": ["mol_019"], "environment": "Surface", "agents": ["phosphate minerals (apatite/struvite)", "montmorillonite (clay)"], "conditions": {"temperature": "298K", "pressure": "1 atm", "catalyst": "bicarbonate/CO2-rich buffered aqueous setting with mineral concentration", "aqueous": "true", "other": "pH about 8; CO2 drives productive diversion of small aminoacetonitrile fractions toward hydantoin"}, "mechanism": "Aminoacetonitrile is trapped in a carbonylation/cyclization sequence generating hydantoin as a more persistent reservoir intermediate.", "reasoning": "Taillades et al. (1998) demonstrated that CO2 catalyzes productive conversion of aminoacetonitrile into hydantoin under realistic prebiotic conditions, making the Bucherer-Bergs branch a validated alternative route to glycine."}, {"id": "rxn_013", "name": "Biochemical hydrolysis of hydantoin to N-carbamoylglycine", "inputs": ["mol_019"], "outputs": ["mol_020"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "298-370K", "pressure": "1 atm", "catalyst": null, "aqueous": "true", "other": "aqueous hydrolysis in concentrated prebiotic pools"}, "mechanism": "Ring-opening hydrolysis of hydantoin yields the ureido amino acid intermediate N-carbamoylglycine.", "reasoning": "Taillades et al. (1998) describe hydantoin hydrolysis to N-carbamoylglycine as part of the Bucherer-Bergs route to glycine under prebiotic conditions."}, {"id": "rxn_014", "name": "Biochemical hydrolysis of N-carbamoylglycine to glycine", "inputs": ["mol_020"], "outputs": ["mol_009"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "298-370K", "pressure": "1 atm", "catalyst": null, "aqueous": "true", "other": "decarbamoylating hydrolysis in aqueous prebiotic settings"}, "mechanism": "Hydrolytic loss of the carbamoyl group releases free glycine.", "reasoning": "The Bucherer-Bergs sequence leading from aminoacetonitrile through hydantoin and N-carbamoylglycine to glycine is documented by Taillades et al. (1998)."}, {"id": "rxn_015", "name": "Surface HCN oligomerization to DAMN/HCN polymer pool", "inputs": ["mol_004"], "outputs": ["mol_017", "mol_021"], "environment": "Surface", "agents": ["sulfide minerals (molybdenite/stibnite)", "montmorillonite (clay)"], "conditions": {"temperature": "250-313K", "pressure": "1 atm", "catalyst": "concentration on mineral surfaces during eutectic freezing or evaporative cycling", "aqueous": "true", "other": "requires productive HCN concentration above ~0.01-0.1 M; dimerization rate measured at pH 9.2 and 40C; eutectic freezing near -23.4C can raise local HCN dramatically"}, "mechanism": "HCN undergoes base-promoted oligomerization through iminoacetonitrile, aminomalononitrile, and DAMN into polymeric nitrile-rich solids.", "reasoning": "Sanchez et al. (1966, 1967) established the kinetics and threshold concentration behavior of HCN oligomerization, and Ruiz-Bermejo et al. (2013) showed that hydrolysis of the resulting polymers yields glycine abundantly. The polymer pool is therefore a validated independent glycine precursor class."}, {"id": "rxn_016", "name": "Surface hydrolysis of HCN polymer pool to amino acid precursor pool", "inputs": ["mol_021"], "outputs": ["mol_022"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "montmorillonite (clay)"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "surface-assisted acid/base hydrolysis during wet-dry and UV cycles", "aqueous": "true", "other": "acid or base hydrolysis of HCN polymers in concentrated surface settings"}, "mechanism": "Hydrolytic opening and oxidation of nitrile-rich polymeric material yields amidated and carboxylated small-molecule precursors en route to amino acids.", "reasoning": "Ruiz-Bermejo et al. (2013) found glycine to be the most abundant amino acid under all tested HCN polymer hydrolysis conditions, building on Or\u00f3-era HCN polymer chemistry. This step represents the established polymer-to-small-molecule transition."}, {"id": "rxn_017", "name": "Biochemical release of glycine from HCN polymer hydrolysate", "inputs": ["mol_022"], "outputs": ["mol_009"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": null, "aqueous": "true", "other": "continued hydrolysis and deprotection in concentrated pools"}, "mechanism": "Further hydrolysis and fragmentation of amino acid precursor mixtures releases free glycine.", "reasoning": "Ruiz-Bermejo et al. (2013) report glycine as the dominant amino acid released by HCN polymer hydrolysis across diverse conditions, consistent with the long-standing HCN polymer route initiated by Or\u00f3 and later analyzed in systems studies."}, {"id": "rxn_018", "name": "Surface cyanosulfidic photoredox generation of aminoacetonitrile from HCN feedstock", "inputs": ["mol_004", "mol_003"], "outputs": ["mol_007", "mol_005"], "environment": "Surface", "agents": ["sulfide minerals (molybdenite/stibnite)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "308K", "pressure": "1 atm", "catalyst": "cyanosulfidic photoredox network on sulfide mineral-rich surfaces in phosphate buffer", "aqueous": "true", "other": "UV irradiation, H2S present as reductant; unified systems chemistry at about 35C"}, "mechanism": "HCN undergoes reductive homologation under UV-driven sulfur-based photoredox cycling, simultaneously generating sugar/aldehyde precursors and aminonitriles including aminoacetonitrile.", "reasoning": "Patel et al. (2015) showed HCN + H2S + UV + phosphate buffer at 35C produces aminoacetonitrile and other biomolecule precursors in a unified cyanosulfidic network. This gives an independent literature-supported route to the glycine precursor aminoacetonitrile."}, {"id": "rxn_019", "name": "Hydrothermal ferroan-brucite mediated synthesis of glycine from glyoxylate and nitrate", "inputs": ["mol_013", "mol_014"], "outputs": ["mol_009"], "environment": "Hydrothermal", "agents": ["mackinawite (FeS)", "elemental iron (Fe0)"], "conditions": {"temperature": "low-moderate hydrothermal", "pressure": "hydrothermal", "catalyst": "ferroan brucite mineral system", "aqueous": "true", "other": "pH 8-9 serpentinite-associated setting; up to 97% of produced glycine partitions to mineral fraction"}, "mechanism": "Mineral-mediated reduction of nitrate coupled to amination/reductive conversion of glyoxylate yields mineral-bound glycine.", "reasoning": "The 2024 PNAS study (doi:10.1073/pnas.2408248121) demonstrated ferroan brucite mediates glycine synthesis from nitrate and glyoxylate with strong mineral sequestration. This is one of the strongest direct hydrothermal routes to glycine in the supplied literature."}, {"id": "rxn_020", "name": "Surface/photocatalytic reversible amination of glyoxylate to glycine", "inputs": ["mol_013", "mol_003"], "outputs": ["mol_009"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "sulfide minerals (molybdenite/stibnite)"], "conditions": {"temperature": "ambient", "pressure": "1 atm", "catalyst": "UV-illuminated semiconductor mineral setting; literature analog ZnS photochemistry represented within required mineral schema by TiO2 plus sulfide surfaces", "aqueous": "true", "other": "UV illumination; alpha-keto acid reversible amination chemistry"}, "mechanism": "Photoexcited mineral surfaces drive reductive amination of glyoxylate with ammonia to glycine.", "reasoning": "Wang et al. (2012) demonstrated UV-driven reversible amination of alpha-keto acids, including glyoxylate to glycine, on ZnS. The present network maps this surface photochemical logic into the required surface-mineral schema while preserving the literature-supported reaction type."}, {"id": "rxn_021", "name": "Biochemical transamination-like conversion of glyoxylate to glycine using alanine as amino donor", "inputs": ["mol_013", "mol_016"], "outputs": ["mol_009", "mol_012"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": null, "aqueous": "true", "other": "prebiotic pool transamination logic connecting hydrothermal alanine and glyoxylate pools"}, "mechanism": "Amino transfer from alanine to glyoxylate yields glycine and regenerates pyruvate, increasing network closure around alpha-keto acid and amino acid hubs.", "reasoning": "The research report identifies transamination as part of metabolically relevant prebiotic chemistry and specifically highlights alpha-keto acids as hubs. This reaction is included as a conservative biochemical connector that ties the experimentally supported pyruvate/alanine hydrothermal branch (Barge et al., 2019) to glyoxylate-centered glycine synthesis. It is more speculative than Strecker or ferroan-brucite routes but chemically standard and network-connecting."}, {"id": "rxn_022", "name": "Surface formamide generation from HCN hydrolysis", "inputs": ["mol_004"], "outputs": ["mol_010"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "montmorillonite (clay)"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "surface-assisted hydrolysis", "aqueous": "true", "other": "minor branch; included only as literature-supported interconnection, not as a direct compressed glycine route"}, "mechanism": "Partial hydration of nitrile carbon in HCN yields formamide as a side-accessible C1 nitrogenous intermediate.", "reasoning": "Formamide chemistry appears in the supplied literature as part of UV/mineral prebiotic chemistry, but prior feedback correctly noted that direct formamide-to-glycine compression is unsupported. This reaction is therefore included only as an interconnection node and not used as a direct one-step glycine pathway."}, {"id": "rxn_023", "name": "Biochemical oligomerization of glycine to glycylglycine", "inputs": ["mol_009"], "outputs": ["mol_023"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "353-413K", "pressure": "1 atm to 10 MPa", "catalyst": null, "aqueous": "false", "other": "wet-dry cycling or short hydrothermal pulses; dimerization optimum near pH 9.8 and 140C"}, "mechanism": "Dehydrative condensation forms a peptide bond between two glycine molecules, giving glycylglycine.", "reasoning": "Sakata et al. (2010) defined the optimum for glycine dimerization near pH 9.8 and 140C, while Imai et al. (1999) demonstrated oligoglycine formation under hydrothermal flow. This reaction makes glycine an outgoing hub and connects synthesis to prebiotic polymer chemistry."}], "pathways": [{"pathway_id": "P1", "name": "Canonical Strecker pathway from hydrothermal formaldehyde", "description": "Hydrothermal CO2 reduction supplies formaldehyde, which undergoes surface Strecker condensation with ammonia and HCN to aminoacetonitrile, followed by two-step hydrolysis to glycine.", "reaction_sequence": ["rxn_002", "rxn_006", "rxn_007", "rxn_010", "rxn_011"], "key_intermediates": ["mol_005", "mol_004", "mol_007", "mol_008"]}, {"pathway_id": "P2", "name": "Glycolonitrile-assisted Strecker branch", "description": "Formaldehyde and HCN first form glycolonitrile, which with ammonia feeds aminoacetonitrile and then canonical hydrolysis to glycine.", "reaction_sequence": ["rxn_002", "rxn_006", "rxn_008", "rxn_009", "rxn_010", "rxn_011"], "key_intermediates": ["mol_005", "mol_015", "mol_007", "mol_008"]}, {"pathway_id": "P3", "name": "Bucherer-Bergs route from aminoacetonitrile", "description": "The minor aminoacetonitrile fraction formed in Strecker chemistry is captured by CO2 as hydantoin and hydrolyzed via N-carbamoylglycine to glycine.", "reaction_sequence": ["rxn_002", "rxn_006", "rxn_007", "rxn_012", "rxn_013", "rxn_014"], "key_intermediates": ["mol_007", "mol_019", "mol_020"]}, {"pathway_id": "P4", "name": "HCN polymer hydrolysis route", "description": "Concentrated HCN oligomerizes to polymeric nitrile material that hydrolyzes to amino acid precursor mixtures from which glycine is the dominant released amino acid.", "reaction_sequence": ["rxn_006", "rxn_015", "rxn_016", "rxn_017"], "key_intermediates": ["mol_021", "mol_022"]}, {"pathway_id": "P5", "name": "Cyanosulfidic aminoacetonitrile route", "description": "Surface cyanosulfidic photoredox chemistry converts HCN feedstocks into aminoacetonitrile and formaldehyde-containing product sets, after which canonical hydrolysis yields glycine.", "reaction_sequence": ["rxn_006", "rxn_018", "rxn_010", "rxn_011"], "key_intermediates": ["mol_004", "mol_007", "mol_008"]}, {"pathway_id": "P6", "name": "Direct hydrothermal glyoxylate-nitrate route", "description": "Hydrothermal alpha-keto acid chemistry supplies glyoxylate, and ferroan-brucite-like serpentinite chemistry converts glyoxylate plus nitrate directly into mineral-bound glycine.", "reaction_sequence": ["rxn_003", "rxn_004", "rxn_019"], "key_intermediates": ["mol_012", "mol_013"]}, {"pathway_id": "P7", "name": "Surface photocatalytic glyoxylate amination route", "description": "Glyoxylate derived from the hydrothermal alpha-keto acid pool is transported to surface photochemical settings where UV-driven semiconductor mineral chemistry aminates it to gly
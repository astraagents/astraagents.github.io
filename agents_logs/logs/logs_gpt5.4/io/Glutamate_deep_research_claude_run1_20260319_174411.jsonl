]}, {"pathway_id": "P6", "name": "Acrolein Strecker route to glutamate aminonitrile", "description": "HCN-rich surface chemistry feeds acrolein-based Strecker synthesis, generating glutamate aminonitrile that hydrolyzes to glutamate.", "reaction_sequence": ["rxn_016", "rxn_009", "rxn_010"], "key_intermediates": ["mol_004", "mol_011"]}, {"pathway_id": "P7", "name": "HCN oligomerization and hydrolysis route", "description": "Concentrated HCN oligomerizes to DAMN/polymeric material whose hydrolysis releases glutamate in low yield.", "reaction_sequence": ["rxn_016", "rxn_011", "rxn_012"], "key_intermediates": ["mol_004", "mol_012"]}, {"pathway_id": "P8", "name": "Bucherer-Bergs route from \u03b1-ketoglutarate hydantoin", "description": "\u03b1-Ketoglutarate from protometabolism undergoes cyanide/ammonia conversion to a hydantoin that hydrolyzes to glutamate.", "reaction_sequence": ["rxn_001", "rxn_002", "rxn_013", "rxn_014"], "key_intermediates": ["mol_007", "mol_013", "mol_004"]}, {"pathway_id": "P9", "name": "Iron-promoted one-network protometabolic amino acid branch", "description": "Pyruvate and glyoxylate in Fe2+/Fe0 systems with hydroxylamine produce \u03b1-ketoglutarate and glutamate together in a mixed product network.", "reaction_sequence": ["rxn_001", "rxn_015"], "key_intermediates": ["mol_006", "mol_005", "mol_007", "mol_015"]}, {"pathway_id": "P10", "name": "Atmospheric energy routes to direct trace glutamate", "description": "Reduced-atmosphere spark discharge and UV photolysis provide direct but low-yield glutamate production outside the \u03b1-ketoglutarate hub.", "reaction_sequence": ["rxn_017", "rxn_018"], "key_intermediates": ["mol_004"]}], "hub_molecules": ["mol_004", "mol_005", "mol_006", "mol_007", "mol_011"], "convergence_points": [{"molecule_id": "mol_007", "incoming_reactions": ["rxn_002", "rxn_003", "rxn_015"], "outgoing_reactions": ["rxn_004", "rxn_005", "rxn_006", "rxn_007", "rxn_008", "rxn_013"]}, {"molecule_id": "mol_004", "incoming_reaction
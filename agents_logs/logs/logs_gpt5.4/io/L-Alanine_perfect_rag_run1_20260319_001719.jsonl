,\n      \"inchi\": \"InChI=1S/C3H7NO3/c4-2(1-5)3(6)7/h2,5H,1,4H2,(H,6,7)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": null\n    },\n    {\n      \"id\": \"mol_010\",\n      \"formula\": \"C4H4O5\",\n      \"iupac_name\": \"2-oxosuccinic acid\",\n      \"common_name\": \"oxaloacetic acid\",\n      \"inchi\": \"InChI=1S/C4H4O5/c5-2(4(8)9)1-3(6)7/h1H2,(H,6,7)(H,8,9)\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": null\n    },\n    {\n      \"id\": \"mol_011\",\n      \"formula\": \"C3H6O3\",\n      \"iupac_name\": \"2-hydroxypropanoic acid\",\n      \"common_name\": \"lactic acid\",\n      \"inchi\": \"InChI=1S/C3H6O3/c1-2(4)3(5)6/h2,4H,1H3,(H,5,6)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": null\n    },\n    {\n      \"id\": \"mol_012\",\n      \"formula\": \"HCN\",\n      \"iupac_name\": \"hydrogen cyanide\",\n      \"common_name\": \"hydrogen cyanide\",\n      \"inchi\": \"InChI=1S/CHN/c1-2/h1H\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": null\n    },\n    {\n      \"id\": \"mol_013\",\n      \"formula\": \"H2S\",\n      \"iupac_name\": \"sulfane\",\n      \"common_name\": \"hydrogen sulfide\",\n      \"inchi\": \"InChI=1S/H2S/h1H2\",\n      \"role\": \"starting\",\n      \"environment_formed\": null\n    },\n    {\n      \"id\": \"mol_014\",\n      \"formula\": \"C6H12N2O3\",\n      \"iupac_name\": \"2-[(2-aminopropanoyl)amino]propanoic acid\",\n      \"common_name\": \"alanylalanine\",\n      \"inchi\": \"InChI=1S/C6H12N2O3/c1-3(5(9)10)7-4(2)6(11)8/h3-4H,1-2H3,(H,7,8)(H,9,10)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"Hydrothermal CO2 fixation to pyruvate on Fe0-awaruite-magnetite\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_004\", \"mol_003\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"elemental iron (Fe0)\", \"awaruite (Ni3Fe)\", \"magnetite (Fe3O4)\"],\n      \"conditions\": {\n        \"temperature\": \"373 K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"Fe0 + awaruite and/or magnetite\",\n        \"aqueous\": \"true\",\n        \"other\": \"H2-dependent CO2 reduction in hydrothermal vent-like conditions; net stoichiometry corresponds to 3 CO2 + 5 H2 -> pyruvate + 3 H2O\"\n      },\n      \"mechanism\": \"Stepwise mineral-surface reduction of CO2 by activated H2 through C1 intermediates and C-C bond-forming Fischer-Tropsch-type chemistry to the C3 alpha-keto acid pyruvate.\",\n      \"reasoning\": \"Direct abiotic formation of pyruvate from CO2 and H2 at 100 degrees C on native iron, awaruite, and magnetite was experimentally demonstrated as a geochemical analogue of primordial carbon fixation, making pyruvate a primary hydrothermal hub for alanine synthesis (Preiner et al., 2020).\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Fe2+-catalyzed oxaloacetate decarboxylation to pyruvate\",\n      \"inputs\": [\"mol_010\"],\n      \"outputs\": [\"mol_004\", \"mol_001\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"ferrous iron (Fe2+)\", \"elemental iron (Fe0)\"],\n      \"conditions\": {\n        \"temperature\": \"343 K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"Fe2+\",\n        \"aqueous\": \"true\",\n        \"other\": \"Mild hydrothermal aqueous conditions; beta-keto acid decarboxylation\"\n      },\n      \"mechanism\": \"Lewis-acid activation of oxaloacetate by Fe2+ promotes beta-decarboxylation to give pyruvate and CO2.\",\n      \"reasoning\": \"Iron-promoted metabolism-like networks at 70 degrees C showed oxaloacetate readily decarboxylates to pyruvate under Fe2+-containing aqueous conditions, providing a second hydrothermal entry into the pyruvate hub (Muchowska et al., 2019).\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Cyanosulfidic oxaloacetate decarboxylation to pyruvate\",\n      \"inputs\": [\"mol_010\"],\n      \"outputs\": [\"mol_004\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (molybdenite/stibnite)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"300-370 K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"cyanosulfidic mineral-assisted surface chemistry\",\n        \"aqueous\": \"true\",\n        \"other\": \"Surface cyanosulfidic conditions; reported timescale about 1 hour\"\n      },\n      \"mechanism\": \"Surface cyanosulfidic chemistry promotes decarboxylative conversion of oxaloacetate into pyruvate within a prebiotic Krebs-cycle analogue.\",\n      \"reasoning\": \"A cyanosulfidic prebiotic Krebs-cycle network was shown to convert oxaloacetate to pyruvate under surface conditions, providing a distinct non-hydrothermal route converging on the same hub molecule (Ritson, 2021). Mineral specification here reflects the sulfur-rich, UV-exposed surface context required by the network schema.\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"Cyanosulfidic oxidation of lactic acid to pyruvate\",\n      \"inputs\": [\"mol_011\"],\n      \"outputs\": [\"mol_004\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (molybdenite/stibnite)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"300-370 K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"cyanosulfidic mineral-assisted surface chemistry\",\n        \"aqueous\": \"true\",\n        \"other\": \"Surface pool conditions with sulfur redox chemistry and UV exposure\"\n      },\n      \"mechanism\": \"Oxidation of the alpha-hydroxy group of lactate to the alpha-keto group yields pyruvate under cyanosulfidic conditions.\",\n      \"reasoning\": \"The cyanosulfidic network reported oxidation of lactic acid to pyruvate, expanding the set of surface-derived inputs into the pyruvate hub used for alanine synthesis (Ritson, 2021). Mineral assignment follows the sulfur-rich photocatalytic surface setting emphasized in cyanosulfidic chemistry.\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"Surface nitrile hydrolysis of 2-aminopropanenitrile to L-alanine\",\n      \"inputs\": [\"mol_007\", \"mol_003\"],\n      \"outputs\": [\"mol_006\", \"mol_008\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"300-370 K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"surface mineral concentration and aqueous hydrolysis\",\n        \"aqueous\": \"true\",\n        \"other\": \"Evaporitic pool or cyanosulfidic surface setting; net stoichiometry corresponds to aminonitrile + 2 H2O -> alanine + NH3\"\n      },\n      \"mechanism\": \"Water adds to the nitrile carbon to form an amide-like intermediate followed by further hydrolysis to the carboxylic acid, releasing ammonia and giving alanine.\",\n      \"reasoning\": \"Patel and co-workers placed alanine aminonitrile within cyanosulfidic protometabolism and showed hydrolysis of 2-aminopropanenitrile to alanine under aqueous surface conditions, making this the principal direct surface route to alanine (Patel et al., 2015). Mineral surfaces are included as concentration and wet-dry supports consistent with the required schema.\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"Hydrothermal reductive amination of pyruvate with hydroxylamine to L-alanine (variant A)\",\n      \"inputs\": [\"mol_004\", \"mol_005\", \"mol_003\"],\n      \"outputs\": [\"mol_006\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"elemental iron (Fe0)\", \"ferrous iron (Fe2+)\"],\n      \"conditions\": {\n        \"temperature\": \"343 K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"Fe0 + Fe2+\",\n        \"aqueous\": \"true\",\n        \"other\": \"Iron-promoted reductive amination at 70 degrees C in water\"\n      },\n      \"mechanism\": \"Hydroxylamine provides the nitrogen source while Fe0/Fe2+ mediate reduction of the imine/oxime-like intermediate derived from pyruvate, yielding alanine.\",\n      \"reasoning\": \"This iron-driven conversion of pyruvate and hydroxylamine to alanine at 70 degrees C is one of the clearest experimental bridges from alpha-keto acids to amino acids in prebiotic hydrothermal chemistry (Muchowska et al., 2019).\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Hydrothermal reductive amination of pyruvate with hydroxylamine to L-alanine (variant B)\",\n      \"inputs\": [\"mol_004\", \"mol_005\"],\n      \"outputs\": [\"mol_006\", \"mol_003\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"elemental iron (Fe0)\", \"ferrous iron (Fe2+)\"],\n      \"conditions\": {\n        \"temperature\": \"343 K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"Fe0 + Fe2+\",\n        \"aqueous\": \"true\",\n        \"other\": \"Alternative reported net balance for iron-promoted reductive amination\"\n      },\n      \"mechanism\": \"Same iron-promoted reductive amination manifold as rxn_006, represented with the alternative experimentally reported net stoichiometric accounting that releases water.\",\n      \"reasoning\": \"Muchowska et al. reported the pyruvate-to-alanine reductive amination under iron-rich conditions with an alternative net stoichiometric form; retaining both variants preserves the literature-defined reaction network around pyruvate and alanine (Muchowska et al., 2019).\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Hydrothermal reduction of L-serine to L-alanine\",\n      \"inputs\": [\"mol_009\", \"mol_002\"],\n      \"outputs\": [\"mol_006\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe3O4)\", \"elemental iron (Fe0)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400 K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"hydrothermal mineral surfaces with H2 as reductant\",\n        \"aqueous\": \"true\",\n        \"other\": \"Submarine hydrothermal system; elevated temperature and pressure\"\n      },\n      \"mechanism\": \"Reductive dehydroxylation converts the serine side-chain hydroxymethyl group to the methyl group of alanine using H2 under hydrothermal conditions.\",\n      \"reasoning\": \"Submarine hydrothermal simulation studies showed serine can be reduced to alanine by H2, linking amino acid interconversion to vent geochemistry and H2 from serpentinization (Aubrey et al., 2008). The exact mineral phase was not the focus of the study, so the listed hydrothermal minerals are supportive vent-relevant agents for schema compliance and this is noted as an environmental rather than mechanistically isolated mineral requirement.\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"Cyanosulfidic formation of 2-aminopropanenitrile from HCN and NH3 precursors\",\n      \"inputs\": [\"mol_012\", \"mol_008\"],\n      \"outputs\": [\"mol_007\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (molybdenite/stibnite)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350 K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"cyanosulfidic mineral-assisted photochemistry\",\n        \"aqueous\": \"true\",\n        \"other\": \"UV-irradiated surface pools; simplified network connection representing Strecker-like aminonitrile generation within the Patel cyanosulfidic system\"\n      },\n      \"mechanism\": \"HCN-derived carbon skeletons under sulfur-assisted photoredox conditions are aminated to form the alanine aminonitrile precursor pool.\",\n      \"reasoning\": \"Patel et al. identified 2-aminopropanenitrile as an alanine precursor within cyanosulfidic protometabolism. This network connection is included as a necessary literature-grounded upstream step to link HCN chemistry to the experimentally demonstrated hydrolysis product, while acknowledging that the full underlying sequence is multistep and condensed here for graph connectivity (Patel et al., 2015).\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"Surface cyanosulfidic generation of hydroxylamine from ammonia\",\n      \"inputs\": [\"mol_008\"],\n      \"outputs\": [\"mol_005\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"sulfide minerals (molybdenite/stibnite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-370 K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"UV-photochemical surface minerals\",\n        \"aqueous\": \"true\",\n        \"other\": \"Speculative connector reflecting debated prebiotic availability of hydroxylamine under anoxic photoredox conditions\"\n      },\n      \"mechanism\": \"Photoredox conversion of reduced nitrogen species to hydroxylamine-like nitrogen donors in sulfur-bearing surface settings.\",\n      \"reasoning\": \"The literature review explicitly identifies hydroxylamine availability as an open question for the Muchowska network. This reaction is therefore included as a speculative but necessary connector, grounded in the stated possibility that hydroxylamine could arise from prebiotic nitrogen redox chemistry, while acknowledging that quantitative support remains incomplete (Muchowska et al., 2019; curated review open question).\"\n    },\n    {\n      \"id\": \"rxn_011\",\n      \"name\": \"Biochemical wet-dry condensation of L-alanine to alanylalanine\",\n      \"inputs\": [\"mol_006\"],\n      \"outputs\": [\"mol_014\", \"mol_003\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"null\"],\n      \"conditions\": {\n        \"temperature\": \"300-370 K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"null\",\n        \"aqueous\": \"false\",\n        \"other\": \"Wet-dry cycling in prebiotic pools or at mineral interfaces; represents entry of alanine into the peptide pool\"\n      },\n      \"mechanism\": \"Dehydrative peptide bond formation between two alanine molecules under concentration and drying cycles produces the dipeptide alanylalanine.\",\n      \"reasoning\": \"Although not specific to the alanine synthesis papers, placement of alanine into the prebiotic peptide pool is required to connect hydrothermal and surface production to biochemical assembly. This step is a standard prebiotic condensation extension consistent with the instructed network architecture and is explicitly included as a downstream assembly reaction rather than a primary literature alanine-forming route.\"\n    }\n  ],\n  \"pathways\": [\n    {\n      \"pathway_id\": \"P1\",\n      \"name\": \"Direct hydrothermal carbon fixation to alanine via reductive amination A\",\n      \"description\": \"CO2 and H2 are fixed hydrothermally to pyruvate, which undergoes iron-promoted reductive amination with hydroxylamine and water to yield L-alanine.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_010\", \"rxn_006\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_005\"]\n    },\n    {\n      \"pathway_id\": \"P2\",\n      \"name\": \"Direct hydrothermal carbon fixation to alanine via reductive amination B\",\n      \"description\": \"Same hydrothermal pyruvate hub as P1, but using the alternative reported net stoichiometry for iron-promoted reductive amination.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_010\", \"rxn_007\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_005\"]\n    },\n    {\n      \"pathway_id\": \"P3\",\n      \"name\": \"Hydrothermal oxaloacetate decarboxylation to alanine via reductive amination A\",\n      \"description\": \"Oxaloacetate decarboxylates under Fe2+-rich hydrothermal conditions to pyruvate, then pyruvate is aminated reductively to L-alanine.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_010\", \"rxn_006\"],\n      \"key_intermediates\": [\"mol_010\", \
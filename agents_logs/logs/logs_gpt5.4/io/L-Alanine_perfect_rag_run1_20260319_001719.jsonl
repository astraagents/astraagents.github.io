    {\n      \"id\": \"rxn_001\",\n      \"name\": \"Hydrothermal CO2 fixation to pyruvate on iron-nickel minerals\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_004\", \"mol_003\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"elemental iron (Fe0)\", \"awaruite (Ni3Fe)\", \"magnetite (Fe3O4)\"],\n      \"conditions\": {\n        \"temperature\": \"373 K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"elemental iron (Fe0), awaruite (Ni3Fe), magnetite (Fe3O4)\",\n        \"aqueous\": \"true\",\n        \"other\": \"H2-dependent CO2 reduction under hydrothermal vent-like conditions; net stoichiometry 3 CO2 + 5 H2 -> pyruvate + 3 H2O\"\n      },\n      \"mechanism\": \"Stepwise surface-mediated reduction of CO2 by activated H2 through C1 and C2 intermediates to a C3 alpha-keto acid product on native metal and oxide mineral surfaces.\",\n      \"reasoning\": \"This is the experimentally demonstrated geochemical entry point from simple vent feedstocks to the pyruvate hub under hydrothermal conditions at 100 degrees C on Fe0, awaruite, and magnetite, directly matching the literature route to a central alanine precursor (Preiner et al., 2020).\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Iron-promoted reductive amination of pyruvate with hydroxylamine to alanine\",\n      \"inputs\": [\"mol_004\", \"mol_005\", \"mol_003\"],\n      \"outputs\": [\"mol_006\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"elemental iron (Fe0)\", \"ferrous iron (Fe2+)\"],\n      \"conditions\": {\n        \"temperature\": \"343 K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"elemental iron (Fe0) and ferrous iron (Fe2+)\",\n        \"aqueous\": \"true\",\n        \"other\": \"Mild hydrothermal aqueous conditions; literature variant A with water as co-substrate\"\n      },\n      \"mechanism\": \"Hydroxylamine provides the nitrogen donor to the alpha-keto acid, and iron supplies reducing power for reductive amination to the corresponding amino acid.\",\n      \"reasoning\": \"This reaction is directly reported for pyruvate to alanine conversion at 70 degrees C in water with Fe0 and Fe2+, forming alanine from a universal metabolic precursor. The literature target is L-alanine, although the broader prebiotic context likely implies racemate formation and unresolved enantioenrichment (Muchowska et al., 2019).\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Iron-promoted reductive amination of pyruvate with hydroxylamine to alanine, dehydration-balanced variant\",\n      \"inputs\": [\"mol_004\", \"mol_005\"],\n      \"outputs\": [\"mol_006\", \"mol_003\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"elemental iron (Fe0)\", \"ferrous iron (Fe2+)\"],\n      \"conditions\": {\n        \"temperature\": \"343 K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"elemental iron (Fe0) and ferrous iron (Fe2+)\",\n        \"aqueous\": \"true\",\n        \"other\": \"Mild hydrothermal aqueous conditions; literature variant B with net water release\"\n      },\n      \"mechanism\": \"Same iron-driven reductive amination manifold as rxn_002, represented with the alternate reported net water balance.\",\n      \"reasoning\": \"Muchowska and coworkers reported the pyruvate-to-alanine reductive amination under Fe0 and Fe2+ with an alternate net stoichiometric representation. Including both reported variants preserves fidelity to the literature rather than collapsing them into one invented summary reaction (Muchowska et al., 2019).\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"Hydrothermal reduction of serine to alanine\",\n      \"inputs\": [\"mol_011\", \"mol_002\"],\n      \"outputs\": [\"mol_006\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe3O4)\", \"elemental iron (Fe0)\"],\n      \"conditions\": {\n        \"temperature\": \"elevated hydrothermal temperature\",
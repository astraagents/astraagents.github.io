formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_018\",\n      \"formula\": \"H2O\",\n      \"iupac_name\": \"oxidane\",\n      \"common_name\": \"water\",\n      \"inchi\": \"InChI=1S/H2O/h1H2\",\n      \"role\": \"starting\",\n      \"environment_formed\": null\n    },\n    {\n      \"id\": \"mol_019\",\n      \"formula\": \"CH4N2O2\",\n      \"iupac_name\": \"ammonium formate\",\n      \"common_name\": \"ammonium formate\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"Hydrothermal CO2 reduction to formate\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_005\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite\", \"mackinawite\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"greigite/mackinawite\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline vent conditions; H2-rich, anoxic\"\n      },\n      \"mechanism\": \"Mineral-surface mediated reduction of CO2 by H2 to one-carbon reduced carbon as formate on Fe-S phases.\",\n      \"reasoning\": \"Directly follows the supplied hydrothermal reaction class CO2 + H2 -> formate on greigite at 350-400K and the relevance of alkaline hydrothermal vents for amino-acid precursor synthesis. Fe-S catalysis is well aligned with hydrothermal origin-of-life models and low-temperature vent plausibility discussed in the research summary (Huber & Wachtershauser, 1997; Yanagawa & Kobayashi, 1992).\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Hydrothermal reduction of formate to formaldehyde-equivalent C1 pool\",\n      \"inputs\": [\"mol_005\", \"mol_002\"],\n      \"outputs\": [\"mol_006\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite\", \"elemental iron\"],\n      \"conditions\": {\n        \"temperature\": \"370-470K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"magnetite/Fe0\",\n        \"aqueous\": \"true\",\n        \"other\": \"subseafloor hydrothermal, reducing conditions\"\n      },\n      \"mechanism\": \"Further reduction of C1 oxidized carbon on Fe-bearing mineral surfaces to a reactive formaldehyde-equivalent pool.\",\n      \"reasoning\": \"The literature summary identifies formaldehyde as a relevant hydrothermal precursor and ties hydrothermal amino-acid chemistry to formaldehyde/ammonia systems. This exact transformation is not explicitly demonstrated for arginine-specific chemistry in the provided report, so it is a necessary connecting step supported only at the precursor-pool level and should be regarded as moderately speculative but literature-consistent (Banez & Oros, 1971; Yanagawa & Kobayashi, 1992).\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Hydrothermal ammonia capture as ammonium formate\",\n      \"inputs\": [\"mol_005\", \"mol_003\"],\n      \"outputs\": [\"mol_019\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"pyrite\", \"greigite\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"pyrite/greigite\",\n        \"aqueous\": \"true\",\n        \"other\": \"vent pore aqueous chemistry\"\n      },\n      \"mechanism\": \"Acid-base pairing and concentration of NH3 with formate in confined mineral pores generates an ammonium formate reservoir feeding HCN-based chemistry upon subsequent processing.\",\n      \"reasoning\": \"The supplied literature explicitly notes that ammonium formate forms amino acids through HCN-based multistep reactions in hydrothermal contexts, even though glycine is the main documented product. Using ammonium formate as a precursor reservoir is therefore literature-grounded for amino-acid precursor chemistry, not arginine specifically (Yanagawa & Kobayashi, 1992; research summary source on ammonium formate HCN-based reactions).\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"Hydrothermal pyruvate synthesis from reduced carbon\",\n      \"inputs\": [\"mol_001\", \"mol_002\", \"mol_005\"],\n      \"outputs\": [\"mol_008\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite\", \"greigite\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"magnetite/greigite\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline vent to subseafloor gradient chemistry\"\n      },\n      \"mechanism\": \"Successive mineral-catalyzed C1 fixation and coupling produces an alpha-keto acid pool represented here by pyruvate.\",\n      \"reasoning\": \"This reaction follows the explicit hydrothermal key reaction type listed in the prompt: pyruvate synthesis from CO2 + H2 on magnetite/greigite at 350-400K. The literature research supports hydrothermal synthesis of amino-acid precursors and alpha-keto-acid-related chemistry, though arginine-specific extension is unresolved (Yanagawa & Kobayashi, 1992; Huber & Wachtershauser, 1997).\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"Hydrothermal reductive amination of pyruvate to alanine\",\n      \"inputs\": [\"mol_008\", \"mol_003\"],\n      \"outputs\": [\"mol_009\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"pyrite\", \"greigite\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"pyrite/greigite\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic mineral-surface amination\"\n      },\n      \"mechanism\": \"Alpha-keto acid imination followed by reduction on Fe-S mineral surfaces yields the corresponding alpha-amino acid alanine.\",\n      \"reasoning\": \"This matches the required hydrothermal reaction class in the prompt: reductive amination of pyruvate plus NH3 to alanine on mineral surfaces at 350-400K. It is additionally consistent with the broader hydrothermal literature on amino-acid formation under submarine vent conditions (Yanagawa & Kobayashi, 1992).\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"Surface photochemical generation of HCN from formaldehyde-ammonia precursor pool\",\n      \"inputs\": [\"mol_006\", \"mol_003\"],\n      \"outputs\": [\"mol_004\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2\", \"sulfide minerals\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO2 and sulfide minerals under UV\",\n        \"aqueous\": \"true\",\n        \"other\": \"UV-exposed evaporitic or geothermal surface setting; reducing, cyanide-rich scenario\"\n      },\n      \"mechanism\": \"UV-driven dehydration/oxidation-reduction chemistry in nitrogen-rich surface films generates a cyanide pool from simple carbonyl-ammonia precursors.\",\n      \"reasoning\": \"The supplied research identifies formaldehyde and ammonia as relevant precursors in prebiotic amino-acid synthesis and separately emphasizes cyanide-rich reducing environments with H2S as plausible for arginine precursors. However, this exact conversion is not directly demonstrated in the report and was criticized previously; it is therefore retained only as a speculative connector between supported precursor pools and explicitly labeled as such (Banez & Oros, 1971; research summary on cyanide-rich reducing environments; speculative bridging step).\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Surface release of HCN from ammonium formate-derived precursor chemistry\",\n      \"inputs\": [\"mol_019\"],\n      \"outputs\": [\"mol_004\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2\", \"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO2/montmorillonite\",\n        \"aqueous\": \"true\",\n        \"other\": \"wet-dry and irradiation cycles after hydrothermal transport\"\n      },\n      \"mechanism\": \"Concentrated ammonium formate-derived nitrogen/carbon reservoir undergoes multistep dehydration/rearrangement under irradiation and drying to feed an HCN-rich surface pool.\",\n      \"reasoning\": \"The literature specifically notes ammonium formate feeding HCN-based multistep amino-acid chemistry in hydrothermal systems. This surface transfer and HCN liberation step is not directly established for arginine, but it is a narrower and better-grounded connector than inventing wholly new feedstocks, because it preserves the literature-supported ammonium formate/HCN relationship (Yanagawa & Kobayashi, 1992; research summary on ammonium formate HCN-based reactions).\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Surface UV hydration of HCN to formamide\",\n      \"inputs\": [\"mol_004\", \"mol_018\"],\n      \"outputs\": [\"mol_010\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2\", \"borate minerals\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO2\",\n        \"aqueous\": \"true\",\n        \"other\": \"UV photochemistry in surface pools\"\n      },\n      \"mechanism\": \"Photochemical hydrolysis/hydration of cyanide yields formamide in UV-irradiated aqueous films.\",\n      \"reasoning\": \"This follows the prompt\u2019s surface key reaction type HCN + H2O + UV -> formamide, a standard prebiotic photochemical branch. It is relevant here because formamide is a recognized HCN-derived nitrogen-rich intermediate in surface prebiotic chemistry, though not arginine-specific (Or\u00f3, 1961; Saladino et al., 2012).\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"Surface HCN oligomerization to DAMN\",\n      \"inputs\": [\"mol_004\"],\n      \"outputs\": [\"mol_011\"],
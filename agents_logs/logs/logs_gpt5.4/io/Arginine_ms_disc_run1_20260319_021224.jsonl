,\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"Hydrothermal CO2 reduction to formate\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_005\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe3S4)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"greigite/mackinawite\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline hydrothermal vent, anoxic, H2-rich, pH 9-11\"\n      },\n      \"mechanism\": \"Mineral-surface mediated reduction of CO2 by H2 to surface-bound formyl/formate species followed by release into solution.\",\n      \"reasoning\": \"Directly follows the provided hydrothermal framework that CO2 + H2 yields formate on greigite at 350-400K in alkaline vent settings; low-temperature submarine hydrothermal systems and alkaline vents are identified as favorable for amino-acid precursor synthesis. This step is used as a literature-grounded entry into reduced carbon chemistry (Huber & Wachtershauser, 1997; Yanagawa & Kobayashi, 1992; as summarized in the provided report).\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Hydrothermal reduction of formate to formaldehyde-equivalent feedstock\",\n      \"inputs\": [\"mol_005\", \"mol_002\"],\n      \"outputs\": [\"mol_006\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"elemental iron (Fe0)\", \"magnetite (Fe3O4)\"],\n      \"conditions\": {\n        \"temperature\": \"370-470K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"Fe0/magnetite\",\n        \"aqueous\": \"true\",\n        \"other\": \"subseafloor hydrothermal, reducing, rock-water interaction\"\n      },\n      \"mechanism\": \"Sequential reduction of C1 oxo-carbon species on Fe-bearing mineral surfaces produces methanal/formaldehyde-equivalent carbonyl feedstock.\",\n      \"reasoning\": \"The supplied literature notes formaldehyde and ammonia as general prebiotic amino-acid precursors and highlights hydrothermal synthesis from reduced carbon feedstocks, though not arginine-specific. This connection is therefore partially inferential but consistent with hydrothermal reduced-carbon chemistry and necessary to connect literature-supported precursor pools (Banez & Oros, 1971; Yanagawa & Kobayashi, 1992; speculative connection explicitly added because arginine-specific steps are absent in the report).\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Hydrothermal Fischer-Tropsch-type carbon fixation to acetate\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_007\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe3O4)\", \"pyrite (FeS2)\"],\n      \"conditions\": {\n        \"temperature\": \"400-500K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"magnetite/pyrite\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic vent setting with CO/CO2/H2 mixtures; Fischer-Tropsch-type regime\"\n      },\n      \"mechanism\": \"Mineral-catalyzed C-C bond formation from reduced C1 species gives C2 carboxylates such as acetate.\",\n      \"reasoning\": \"This matches the stated hydrothermal key reaction type that CO2 reduction can proceed to acetate and that magnetite supports Fischer-Tropsch-type synthesis. It builds the reduced carbon inventory relevant to downstream alpha-keto acid formation in hydrothermal systems (Huber & Wachtershauser, 1997; summarized hydrothermal framework in the provided report).\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"Hydrothermal synthesis of pyruvate from reduced carbon feedstocks\",\n      \"inputs\": [\"mol_005\", \"mol_007\"],\n      \"outputs\": [\"mol_008\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe3S4)\", \"magnetite (Fe3O4)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"greigite/magnetite\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline vent to subseafloor interface, anoxic\"\n      },\n      \"mechanism\": \"Mineral-assisted carbon fixation and condensation convert reduced C1/C2 species into the central alpha-keto acid pyruvate.\",\n      \"reasoning\": \"The supplied instructions explicitly list pyruvate synthesis from CO2 + H2 on magnetite/greigite at 350-400K as a key hydrothermal reaction type. Because the literature compilation emphasizes alpha-keto acid and hydrothermal amino-acid precursor formation without detailing exact pyruvate stoichiometry, this network encodes pyruvate as a hydrothermal hub in a literature-consistent but generalized form (Yanagawa & Kobayashi, 1992; provided hydrothermal reaction framework; connection is plausible but not arginine-specific).\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"Surface cyanide generation from reduced carbon-nitrogen chemistry\",\n      \"inputs\": [\"mol_006\", \"mol_003\"],\n      \"outputs\": [\"mol_004\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"sulfide minerals (molybdenite/stibnite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO2 and sulfide minerals\",\n        \"aqueous\": \"true\",\n        \"other\": \"UV-exposed evaporitic pool or geothermal field, reducing, anoxic\"\n      },\n      \"mechanism\": \"Photochemical and redox-driven conversion of simple carbonyl/nitrogen feedstocks into cyanide-bearing species in surface pools.\",\n      \"reasoning\": \"The provided report identifies cyanide-rich reducing environments containing H2S as plausible for arginine precursor synthesis and emphasizes UV photochemistry in surface settings. Exact arginine-specific HCN-generation chemistry was not supplied, so this step is a necessary connecting reaction that remains consistent with cyanosulfidic surface chemistry (Patel et al., 2015; Sutherland, 2016; speculative connection justified by the report's cyanide-rich environment emphasis).\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"UV hydration of HCN to formamide\",\n      \"inputs\": [\"mol_004\", \"mol_020\"],\n      \"outputs\": [\"mol_015\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"borate minerals (colemanite/ulexite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO2/borate minerals\",\n        \"aqueous\": \"true\",\n        \"other\": \"UV irradiation in shallow pools\"\n      },\n      \"mechanism\": \"UV-assisted hydration/rearrangement of HCN yields formamide as a versatile nitrogenous intermediate.\",\n      \"reasoning\": \"This follows the provided surface reaction type 'HCN + H2O + UV -> formamide -> nucleobases.' Although not specific to arginine, formamide chemistry is a documented surface nitrogen reservoir and supports convergent nitrogen-rich prebiotic networks (Saladino et al., 2012; summary in provided report).\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Irradiation of ammonium cyanide to cyanamide/guanidino precursor pool\",\n      \"inputs\": [\"mol_004\", \"mol_003\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"sulfide minerals (molybdenite/stibnite)\"],\n      \"conditions\": {\n        \"temperature\": \"280-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO2 and sulfide minerals\",\n        \"aqueous\": \"true\",\n        \"other\": \"UV or proton irradiation under anoxic surface conditions\"\n      },\n      \"mechanism\": \"Energetic irradiation of ammonium cyanide reorganizes C-N bonding to produce cyanamide-class guanidino precursors.\",\n      \"reasoning\": \"The literature report explicitly states that irradiation of ammonium cyanide is a plausible prebiotic route to guanidine/guanidino-group formation. Cyanamide is used here as the immediate activated guanidino precursor because it is a classic prebiotic condensing/guanidinating agent and provides a chemically realistic link to arginine assembly; this is the closest literature-grounded route available from the supplied report (reported in Journal of Molecular Evolution source cited in the knowledge base; late-stage assignment to cyanamide is a necessary but partly interpretive connection).\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Further conversion of cyanamide to guanidine\",\n      \"inputs\": [\"mol_012\", \"mol_003\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (molybdenite/stibnite)\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"sulfide/phosphate mineral surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"evaporitic concentration with wet-dry cycling\"\n      },\n      \"mechanism\": \"Ammonolysis/addition to cyanamide on mineral surfaces generates guanidine-like guanidino donors.\",\n      \"reasoning\": \"The report supports guanidino-group formation from irradiated ammonium cyanide but does not provide an experimentally resolved incorporation sequence into amino acids. This step is therefore a speculative but chemically conservative extension to create a guanidino donor reservoir for arginine assembly (knowledge-base guanidino-group report; speculative connection required because no direct incorporation study was found).\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"Surface formose/aldol route to glycolaldehyde\",\n      \"inputs\": [\"mol_006\"],\n      \"outputs\": [\"mol_016\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"borate minerals/TiO2\",\n        \"aqueous\": \"true\",\n        \"other\": \"evaporitic or geothermal pools; wet-dry cycles\"\n      },\n      \"mechanism\": \"Formaldehyde undergoes self-condensation under borate-stabilized conditions to produce glycolaldehyde.\",\n      \"reasoning\": \"This directly follows the provided surface formose and aldol chemistry framework in which formaldehyde produces sugars and sugar precursors, with borate stabilizing reactive carbohydrates. It helps connect hydrothermal reduced carbon to surface carbon skeleton growth relevant to amino-acid precursor pools (Ricardo et al., 2004; Pasek and co-workers generally on borate stabilization; supported by the report's formose/borate framework).\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"Surface aldol extension to glyceraldehyde\",\n      \"inputs\": [\"mol_016\", \"mol_006\"],\n      \"outputs\": [\"mol_017\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"borate/montmorillonite\",\n        \"aqueous\": \"true\",\n        \"other\": \"concentration during wet-dry cycling\"\n      },\n      \"mechanism\": \"Aldol addition between C2 and C1 carbonyl units produces the triose glyceraldehyde, stabilized by borate and adsorbed on clay.\",\n      \"reasoning\": \"The provided framework specifically lists aldol condensation of glycolaldehyde and glyceraldehyde/sugar buildup under surface conditions. This step supports carbon-backbone extension toward larger keto-acid networks used later in the model (Ricardo et al., 2004; surface chemistry framework in the supplied instructions).\"\n    },\n    {\n      \"id\": \"rxn_011\",\n      \"name\": \"Surface sugar buildup to hexose pool\",\n      \"inputs\": [\"mol_016\", \"mol_017\"],\n      \"outputs\": [\"mol_018\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"borate/montmorillonite\",\n        \"aqueous\": \"true\",\n        \"other\": \"formose-active evaporitic pool\"\n      },\n      \"mechanism\": \"Sequential aldol and isomerization reactions expand simple aldehydes into a mixed hexose pool.\",\n      \"reasoning\": \"This is included because the supplied surface chemistry emphasizes formose-type sugar generation and aldol condensation under borate-supported conditions. While not arginine-specific, it provides an alternative carbon-expansion route feeding later alpha-keto acid generation in a connected network (Ricardo et al., 2004; general formose literature; used here as a network-bridging step).\"\n    },\n    {\n      \"id\": \"rxn_012\",\n      \"name\": \"Hydrothermal/surface crossover oxidation-rearrangement to alpha-ketoglutarate\",\n      \"inputs\": [\"mol_008\", \"mol_018\"],\n      \"outputs\": [\"mol_009\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"null\"],\n      \"conditions\": {\n        \"temperature\": \"298-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"null\",\n        \"aqueous\": \"true\",\n        \"other\": \"prebiotic pool, mixed hydrothermal-surface feedstocks, anoxic\"\n      },\n      \"mechanism\": \"Carbon-skeleton extension and keto-acid rearrangement from pyruvate plus larger carbonyl pool yields C5 alpha-keto acid hub alpha-ketoglutarate.\",\n      \"reasoning\": \"The literature report identifies alpha-ketoglutarate as a biosynthetic precursor to glutamate and a central metabolic intermediate relevant to arginine, but does not provide a direct prebiotic synthesis route. This reaction is therefore explicitly speculative and inserted to connect literature-supported precursor pools to the known glutamate/ornithine/arginine logic of the target molecule (report summary: alpha-ketoglutarate and glutamate are key precursors; speculative network-completion step).\"\n    },\n    {\n      \"id\": \"rxn_013\",\n      \"name\": \"Non-enzymatic reductive amination/transamination of alpha-ketoglutarate to glutamate\",\n      \"inputs\": [\"mol_009\", \"mol_003\"],\n      \"outputs\": [\"mol_010\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"null\"],\n      \"conditions\": {\n        \"temperature\": \"298-303K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"null\",\n        \"aqueous\": \"true\",\n        \"other\": \"mild aqueous pool; non-enzymatic transamination conditions\"\n      },\n      \"mechanism\": \"Ammonia addition to the alpha-keto group followed by reduction/transamination yields glutamate.\",\n      \"reasoning\": \"The supplied report explicitly notes alpha-ketoglutarate and ammonia as precursors to glutamate and mentions non-enzymatic transamination under mild aqueous conditions (~25-30C). This is among the strongest literature-grounded late-stage steps in the network (report summary on biosynthetic precursors and non-enzymatic transamination conditions; see also general prebiotic transamination literature cited therein).\"\n    },\n    {\n      \"id\": \"rxn_014\",\n      \"name\": \"Backbone extension from glutamate to ornithine\",\n      \"inputs\": [\"mol_010\", \"mol_003\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"null\"],\n      \"conditions\": {\n        \"temperature\": \"298-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"null\",\n        \"aqueous\": \"true\",\n        \"other\": \"concentrated prebiotic pool; repeated heating-cooling\"\n      },\n      \"mechanism\": \"Reduction/decarboxylation/amination sequence converts glutamate-class dicarboxylate chemistry into the diamino acid ornithine.\",\n      \"reasoning\": \"The report explicitly identifies ornithine as the immediate precursor to arginine and glutamate as its upstream precursor, but does not provide a specific prebiotic non-enzymatic route. This reaction is therefore a necessary speculative condensation of a multi-step transformation into one network node to preserve connectivity while respecting the literature-established precursor hierarchy (report summary on precursor chain glutamate -> ornithine -> arginine; speculative due to lack of direct experimental resolution).\"\n    },\n    {\n      \"id\": \"rxn_015\",\n      \"name\": \"Guanidination of ornithine by cyanamide\",\n      \"inputs\": [\"mol_011\", \"mol_012\"],\n      \"outputs\": [\"mol_014\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"null\"],\n      \"conditions\": {\n        \"temperature\": \"298-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"null\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic prebiotic pool with concentrated nitrogenous condensing agent\"\n      },\n      \"mechanism\": \"Terminal amino group of ornithine attacks activated cyanamide carbon to form a guanidino substituent, yielding arginine after proton transfers/hydrolysis.\",\n      \"reasoning\": \"This is the core target-forming step. The literature report states that ornithine is the immediate precursor to arginine and that cyanamide/carbodiimide-like compounds are plausible prebiotic guanidino precursors. However, it also explicitly says there is no direct experimental evidence for prebiotic incorporation of guanidino groups into amino acids. Accordingly, this step is chemically plausible and directly tied to the report's precursor logic, but is explicitly speculative (report summary on ornithine and cyanamide/carbodiimide; knowledge-base note that direct guanidino incorporation evidence is lacking).\"\n    },\n    {\n      \"id\": \"rxn_016\",\n      \"name\": \"Alternative guanidination of ornithine by guanidine\",\n      \"inputs\": [\"mol_011\", \"mol_013\"],\n      \"outputs\": [\"mol_014\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"null\"],\n      \"conditions\": {\n        \"temperature\": \"320-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"null\",\n        \"aqueous\": \"true\",\n        \"other\": \"geothermal cycling and evaporative concentration\"\n      },\n      \"mechanism\": \"Direct guanidino transfer/addition from guanidine-class donor to ornithine forms arginine under concentrated prebiotic conditions.\",\n      \"reasoning\": \"This alternative target-forming route is even more speculative than rxn_015, but is anchored in the report's statement that irradiation of ammonium cyanide plausibly yields guanidine/guanidino groups. It is added to satisfy the requirement for multiple environmental routes to the same target while remaining faithful to the literature's emphasis on guanidino-group generation rather than a fully demonstrated arginine synthesis (knowledge-base guanidino-group report; explicit speculation required).\"\n    }\n  ],\n  \"pathways\": [\n    {\n      \"pathway_id\": \"P1\",\n      \"name\": \"Hydrothermal formate-pyruvate to cyanamide-ornithine route\",\n      \"description\": \"Alkaline vent CO2 reduction produces formate and pyruvate, which feed a speculative alpha-ketoglutarate/glutamate/ornithine sequence; surface irradiation of ammonium cyanide provides cyanamide for final guanidination.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_003\", \"rxn_004\", \"rxn_012\", \"rxn_013\", \"rxn_014\", \"rxn_007\", \"rxn_015\"],\n      \"key_intermediates\": [\"mol_005\", \"mol_008\", \"mol_009\", \"mol_011\", \"mol_012\"]\n    },\n    {\n      \"pathway_id\": \"P2\",\n      \"name\": \"Hydrothermal formate-formaldehyde-HCN route to cyanamide and arginine\",\n      \"description\": \"Vent-generated formate is reduced to formaldehyde, converted photochemically to HCN, irradiated to cyanamide, then coupled with ornithine derived from the pyruvate/alpha-ketoglutarate branch.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_005\", \"rxn_007\", \"rxn_004\", \"rxn_012\", \"rxn_013\", \"rxn_014\", \"rxn_015\"],\n      \"key_intermediates\": [\"mol_006\", \"mol_004\", \"mol_012\", \"mol_008\", \"mol_011\"]\n    },\n    {\n      \"pathway_id\": \"P3\",\n      \"name\": \"Acetate-assisted hydrothermal pyruvate route with cyanamide guanidination\",\n      \"description\": \"CO2 reduction generates acetate and formate, which converge to pyruvate; downstream ornithine formation is capped by cyanamide-based guanidination.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_003\", \"rxn_004\", \"rxn_012\", \"rxn_013\", \"rxn_014\", \"rxn_007\", \"rxn_015\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_008\", \"mol_009\", \"mol_011\", \"mol_012\"]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"Formaldehyde-sugar branch into alpha-ketoglutarate then arginine\",\n      \"description\": \"Hydrothermal formaldehyde crosses into surface sugar chemistry via glycolaldehyde and glyceraldehyde, generating larger carbonyl pools that connect to alpha-ketoglutarate and ultimately ornithine and arginine.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_009\", \"rxn_010\", \"rxn_011\", \"rxn_012\", \"rxn_013\", \"rxn_014\", \"rxn_007\", \"rxn_015\"],\n      \"key_intermediates\": [\"mol_006\", \"mol_016\", \"mol_017\", \"mol_018\", \"mol_009\", \"mol_012\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"HCN-formamide-cyanamide branch to arginine\",\n      \"description\": \"Surface HCN first enters formamide chemistry before converging back into the cyanamide pool, then feeds final guanidination of ornithine.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_005\", \"rxn_006\", \"rxn_007\", \"rxn_004\", \"rxn_012\", \"rxn_013\", \"rxn_014\", \"rxn_015\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_015\", \"mol_012\", \"mol_008\", \"mol_011\"]\n    },\n    {\n      \"pathway_id\": \"P6\",\n      \"name\": \"Guanidine donor pathway to arginine\",\n      \"description\": \"Surface irradiation produces cyanamide, which is further converted to guanidine; guanidine then serves as an alternative guanidino donor to ornithine.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_003\", \"rxn_004\", \"rxn_012\", \"rxn_013\", \"rxn_014\", \"rxn_007\", \"rxn_008\", \"rxn_016\"],\n      \"key_intermediates\": [\"mol_008\", \"mol_009\", \"mol_011\", \"mol_012\", \"mol_013\"]\n    },\n    {\n      \"pathway_id\": \"P7\",\n      \"name\": \"Hydrothermal pyruvate direct hub route with guanidine finish\",\n      \"description\": \"Pyruvate is taken as the central hydrothermal hub and paired with the guanidine donor branch rather than cyanamide for final arginine formation.\",\n      \"reaction_sequence\": [\"rxn_004\", \"rxn_012\", \"rxn_013\", \"rxn_014\", \"rxn_007\", \"rxn_008\", \"rxn_016\"],\n      \"key_intermediates\": [\"mol_008\", \"mol_009\", \"mol_011\", \"mol_013\"]\n    },\n    {\n      \"pathway_id\": \"P8\",\n      \"name\": \"Sugar-assisted carbon expansion with guanidine termination\",\n      \"description\": \"Surface sugar chemistry supplies carbon expansion into alpha-ketoglutarate while the cyanide irradiation branch supplies guanidine for the terminal step.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_009\", \"rxn_010\", \"rxn_011\", \"rxn_012\", \"rxn_013\", \"rxn_014\", \"rxn_007\", \"rxn_008\", \"rxn_016\"],\n      \"key_intermediates\": [\"mol_016\", \"mol_017\", \"mol_018\", \"mol_009\", \"mol_011\", \"mol_013\"]\n    },\n    {\n      \"pathway_id\": \"P9\",\n      \"name\": \"HCN-centered crossover route to cyanamide arginine synthesis\",\n      \"description\": \"Hydrotherm
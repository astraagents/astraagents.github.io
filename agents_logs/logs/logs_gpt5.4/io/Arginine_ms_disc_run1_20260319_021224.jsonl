 "environment_formed": "Surface"}, {"id": "mol_016", "formula": "CH5N3", "iupac_name": "guanidine", "common_name": "guanidine", "inchi": "InChI=1S/CH5N3/c2-1(3)4/h(H5,2,3,4)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_017", "formula": "C6H14N4O2", "iupac_name": "2-amino-5-(diaminomethylideneamino)pentanoic acid", "common_name": "arginine", "inchi": "InChI=1S/C6H14N4O2/c7-4(5(11)12)2-1-3-10-6(8)9/h4H,1-3,7H2,(H4,8,9,10)(H,11,12)", "role": "target", "environment_formed": "Biochemical"}, {"id": "mol_018", "formula": "C2H4N2", "iupac_name": "ethenediaminonitrile", "common_name": "diaminomaleonitrile", "inchi": "InChI=1S/C4H4N4/c5-3(1-7)4(6)2-8/h5-6H2", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_019", "formula": "CH6N2", "iupac_name": "azanium methanide amide", "common_name": "ammonium cyanide", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_020", "formula": "C6H12N2O2", "iupac_name": "2-amino-5-cyanamidopentanoic acid", "common_name": "N-cyanamido-ornithine", "inchi": null, "role": "intermediate", "environment_formed": "Biochemical"}], "reactions": [{"id": "rxn_001", "name": "Hydrothermal CO2 reduction to formate", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_008"], "environment": "Hydrothermal", "agents": ["greigite", "mackinawite"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "greigite/mackinawite", "aqueous": "true", "other": "alkaline vent conditions, H2-rich, anoxic"}, "mechanism": "Mineral-surface mediated CO2 hydrogenation on iron-sulfur phases gives surface-bound formyl equivalents that desorb as formate.", "reasoning": "This step follows the well-established vent-chemistry framework for FeS-catalyzed CO2 reduction and is used here as the hydrothermal entry point for C1 carbon. It is consistent with iron-sulfur world and alkaline vent studies rather than arginine-specific experiments (Huber & Wachtershauser, 1997; Cody et al., 2000)."}, {"id": "rxn_002", "name": "Hydrothermal formation of ammonium formate from formate and ammonia", "inputs": ["mol_008", "mol_003"], "outputs": ["mol_007"], "environment": "Hydrothermal", "agents": ["pyrite", "greigite"], "conditions": {"temperature": "373-433K", "pressure": "high", "catalyst": "pyrite/greigite", "aqueous": "true", "other": "submarine hydrothermal system, reduced nitrogen available"}, "mechanism": "Acid-base pairing and concentration of formate with ammonia in hydrothermal fluids yields ammonium formate as a reactive precursor pool.", "reasoning": "Ammonium formate has been specifically implicated as a hydrothermal amino-acid precursor through HCN-based multistep chemistry. This node is included because the literature explicitly mentions ammonium formate in hydrothermal amino acid formation, though not arginine-specific (Yanagawa & Kobayashi, 1992; source summary on ammonium formate multi-step amino acid formation)."}, {"id": "rxn_003", "name": "Hydrothermal generation of formaldehyde by reduced carbon fixation/Fischer-Tropsch-type chemistry", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_004"], "environment": "Hydrothermal", "agents": ["magnetite", "elemental iron"], "conditions": {"temperature": "400-500K", "pressure": "high", "catalyst": "magnetite/Fe0", "aqueous": "true", "other": "subseafloor reducing conditions"}, "mechanism": "Stepwise hydrogenation of CO2/CO on metal-oxide and Fe0 surfaces gives reduced carbonyl compounds including formaldehyde.", "reasoning": "The research report highlights formaldehyde as a key precursor in hydrothermal amino-acid synthesis and older simulation work used formaldehyde plus ammonia as feedstocks. This step is therefore included as a literature-consistent carbon source step, though precise product distributions are broader than a single formaldehyde output (Banez & Oro, 1971; Yanagawa & Kobayashi, 1992)."}, {"id": "rxn_004", "name": "Surface photochemical conversion of HCN to formamide", "inputs": ["mol_006"], "outputs": ["mol_005"], "environment": "Surface", "agents": ["TiO2", "montmorillonite"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "TiO2", "aqueous": "true", "other": "UV irradiation, shallow pond or tidal flat"}, "mechanism": "UV-driven hydration/oxidation chemistry of cyanide on photocatalytic mineral surfaces produces formamide.", "reasoning": "Formamide is a commonly invoked surface product of cyanide photochemistry in prebiotic settings, and the supplied instructions explicitly include HCN plus water plus UV to formamide. This branch is used as a literature-aligned cyanide-processing route rather than a direct arginine step (Oro, 1961; Saladino et al., 2012)."}, {"id": "rxn_005", "name": "Surface cyanide generation from formaldehyde-ammonia chemistry", "inputs": ["mol_004", "mol_003"], "outputs": ["mol_006"], "environment": "Surface", "agents": ["TiO2", "sulfide minerals"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "TiO2 and sulfide minerals", "aqueous": "true", "other": "reducing cyanide-rich setting, UV-assisted"}, "mechanism": "Photochemical and redox processing of reduced carbonyl and ammonia pools yields cyanide-bearing products.", "reasoning": "The supplied literature specifically notes formaldehyde and ammonia as amino-acid precursor systems and repeatedly identifies cyanide-rich reducing environments as relevant to arginine precursor formation. The exact direct conversion is not established in the report, so this connection is explicitly somewhat speculative but necessary to link documented feedstock regimes into the HCN-centered surface network (Banez & Oro, 1971; Levine et al., 2008; source summary on cyanide-rich reducing environments)."}, {"id": "rxn_006", "name": "Surface oligomerization of HCN to diaminomaleonitrile", "inputs": ["mol_006"], "outputs": ["mol_018"], "environment": "Surface", "agents": ["montmorillonite", "TiO2"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "montmorillonite/TiO2", "aqueous": "true", "other": "evaporation-concentration and UV exposure"}, "mechanism": "HCN oligomerizes through nitrile addition chemistry to give tetrameric products including DAMN.", "reasoning": "HCN oligomerization to DAMN is a classic prebiotic cyanide reaction and is included because the user instructions require HCN oligomerization motifs. DAMN also feeds the ammonium-cyanide photochemistry/guanidino branch conceptually (Or\u00f3 & Kimball, 1961; Ferris & Hagan, 1984)."}, {"id": "rxn_007", "name": "Surface irradiation of ammonium cyanide to cyanamide", "inputs": ["mol_006", "mol_003"], "outputs": ["mol_019", "mol_015"], "environment": "Surface", "agents": ["TiO2", "sulfide minerals"], "conditions": {"temperature": "273-320K", "pressure": "1 atm", "catalyst": "TiO2", "aqueous": "true", "other": "UV or ionizing irradiation of ammonium cyanide solutions"}, "mechanism": "Association of HCN with ammonia gives ammonium cyanide, which under irradiation rearranges and condenses to cyanamide-containing products.", "reasoning": "This step directly follows the supplied literature finding that irradiation of ammonium cyanide is a plausible prebiotic route to guanidino-group precursors such as cyanamide/guanidine. Because the report does not give a single definitive mechanistic paper citation, the step is included as literature-guided but still cautious in scope (source summary citing Journal of Molecular Evolution report on ammonium cyanide irradiation; Oro, 1961 for cyanide prebiotic context)."}, {"id": "rxn_008", "name": "Surface hydrolysis/rearrangement of cyanamide to guanidine pool", "inputs": ["mol_015", "mol_003"], "outputs": ["mol_016"], "environment": "Surface", "agents": ["phosphate minerals", "montmorillonite"], "conditions": {"temperature": "300-340K", "pressure": "1 atm", "catalyst": "phosphate minerals/montmorillonite", "aqueous": "true", "other": "concentrating wet-dry cycles in nitrogen-rich pools"}, "me
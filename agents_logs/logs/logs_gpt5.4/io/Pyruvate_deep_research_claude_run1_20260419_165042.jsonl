formed": "Surface"}, {"id": "mol_013", "formula": "C2H4O2", "iupac_name": "2-hydroxyethanal", "common_name": "glycolaldehyde", "inchi": "InChI=1S/C2H4O2/c3-1-2-4/h1,3H,2H2", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_014", "formula": "C3H6O3", "iupac_name": "2,3-dihydroxypropanal", "common_name": "glyceraldehyde", "inchi": "InChI=1S/C3H6O3/c4-1-3(6)2-5/h1,3,5-6H,2H2", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_015", "formula": "C3H5O6P", "iupac_name": "[(2,3-dihydroxypropanal-2-yl)oxy]phosphonic acid", "common_name": "glyceraldehyde-2-phosphate", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_016", "formula": "C3H5O6P", "iupac_name": "phosphonooxyprop-1-en-2-one", "common_name": "phosphoenolpyruvaldehyde", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_017", "formula": "C3H5O6P", "iupac_name": "phosphoenolpyruvic acid", "common_name": "phosphoenolpyruvate", "inchi": "InChI=1S/C3H5O6P/c4-2(1-10-9(7,8)6)3(5)6/h1H2,(H2,4,5)(H2,7,8,9)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_018", "formula": "C3H6O3", "iupac_name": "2-hydroxypropanoic acid", "common_name": "lactic acid/lactate", "inchi": "InChI=1S/C3H6O3/c1-2(4)3(5)6/h2,4H,1H3,(H,5,6)", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_019", "formula": "C2H4O", "iupac_name": "ethanal", "common_name": "acetaldehyde", "inchi": "InChI=1S/C2H4O/c1-2-3/h2H,1H3", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_020", "formula": "CH3NO", "iupac_name": "formamide", "common_name": "formamide", "inchi": "InChI=1S/CH3NO/c2-1-3/h1H,(H2,2,3)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_021", "formula": "C3H5NO2", "iupac_name": "2-aminopropanoic acid", "common_name": "alanine", "inchi": "InChI=1S/C3H7NO2/c1-2(4)3(5)6/h2H,4H2,1H3,(H,5,6)", "role": "intermediate", "environment_formed": "Biochemical"}, {"id": "mol_022", "formula": "C5H6O5", "iupac_name": "2-oxopentanedioic acid", "common_name": "alpha-ketoglutaric acid/alpha-ketoglutarate", "inchi": "InChI=1S/C5H6O5/c6-3(5(9)10)1-2-4(7)8/h1-2H2,(H,7,8)(H,9,10)", "role": "intermediate", "environment_formed": "Biochemical"}, {"id": "mol_023", "formula": "C3H4O2", "iupac_name": "2-oxopropanal", "common_name": "methylglyoxal/pyruvaldehyde", "inchi": "InChI=1S/C3H4O2/c1-3(5)2-4/h2H,1H3", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_024", "formula": "CH3NO2S", "iupac_name": "thiocyanic acid", "common_name": "thiocyanate (generic precursor pool)", "inchi": null, "role": "starting", "environment_formed": null}, {"id": "mol_025", "formula": "CH3N2O2P", "iupac_name": "phosphoric diamide", "common_name": "diamidophosphate", "inchi": null, "role": "starting", "environment_formed": null}, {"id": "mol_026", "formula": "H3N", "iupac_name": "azane", "common_name": "ammonia", "inchi": "InChI=1S/H3N/h1H3", "role": "starting", "environment_formed": null}, {"id": "mol_027", "formula": "NH2OH", "iupac_name": "hydroxylamine", "common_name": "hydroxylamine", "inchi": "InChI=1S/H3NO/h1H3", "role": "starting", "environment_formed": null}], "reactions": [{"id": "rxn_001", "name": "Hydrothermal CO2 reduction to formate on awaruite/greigite/magnetite", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_003"], "environment": "Hydrothermal", "agents": ["greigite (Fe3S4)", "magnetite (Fe3O4)", "awaruite (Ni3Fe)"], "conditions": {"temperature": "100C", "pressure": "25 bar", "catalyst": "awaruite, greigite, magnetite", "aqueous": "true", "other": "alkaline conditions; CO2 + H2; 16-24 h; formate up to 200 mM in related runs"}, "mechanism": "Mineral-mediated hydrogen activation and CO2 reduction produce C1 formate as the dominant first fixed-carbon product.", "reasoning": "Preiner et al. (2020) showed CO2 + H2 conversion to formate, acetate, methanol, and pyruvate on awaruite, greigite, and magnetite at 100C, 25 bar, alkaline conditions. Beyazay et al. (2023) confirmed strong activity of Ni3Fe systems for the same sequence and emphasized Ni/Fe complementarity."}, {"id": "rxn_002", "name": "Hydrothermal chain extension from formate to acetate on native Fe0", "inputs": ["mol_003", "mol_002"], "outputs": ["mol_004"], "environment": "Hydrothermal", "agents": ["elemental iron (Fe0)", "magnetite (Fe3O4)"], "conditions": {"temperature": "30-100C", "pressure": "1-40 bar", "catalyst": "Fe0", "aqueous": "true", "other": "water; CO2 reduction network with acetate near mM and pyruvate transiently detected"}, "mechanism": "Native iron reduces and couples C1 species derived from CO2 to generate C2 acetate in an acetyl-CoA-pathway analog.", "reasoning": "Varma et al. (2018) demonstrated that native Fe0 reduces CO2 in water at 30-100C and 1-40 bar to formate, acetate, and pyruvate, establishing abiotic C1 to C2 chain extension. This reaction is represented here as the key formate-to-acetate step in that network."}, {"id": "rxn_003", "name": "Ambient-to-hydrothermal direct CO2 fixation to pyruvate on Ni3Fe", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_005"], "environment": "Hydrothermal", "agents": ["awaruite (Ni3Fe)", "greigite (Fe3S4)"], "conditions": {"temperature": "25-100C", "pressure": "25 bar", "catalyst": "Ni3Fe nanoparticles", "aqueous": "true", "other": "CO2/H2 feed; pyruvate detected at room temperature and 0.04 mM at 100C in 24 h"}, "mechanism": "Direct multistep mineral-catalyzed CO2 fixation proceeds through hidden C1/C2 intermediates to C3 pyruvate.", "reasoning": "Beyazay et al. (2023, Nature Communications) reported pyruvate production from CO2/H2 using Ni3Fe nanoparticles at 25 bar from room temperature to 100C. Preiner et al. (2020) likewise detected pyruvate from CO2/H2 on awaruite, greigite, and magnetite."}, {"id": "rxn_004", "name": "Activated acetyl thioester formation from CO and methanethiol on NiS/FeS", "inputs": ["mol_006"], "outputs": ["mol_007"], "environment": "Hydrothermal", "agents": ["mackinawite (FeS)", "greigite (Fe3S4)"], "conditions": {"temperature": "100C", "pressure": "high", "catalyst": "coprecipitated NiS/FeS analog represented by FeS-bearing hydrothermal sulfides", "aqueous": "true", "other": "7 days; CO and CH3SH in the original experiment; activated thioester methyl thioacetate formed"}, "mechanism": "Surface-bound carbonyl insertion and methyl migration on Ni-Fe sulfide surfaces yield an activated acetyl thioester.", "reasoning": "Huber and Wachtershauser (1997) showed formation of methyl thioacetate from CO and CH3SH on coprecipitated NiS/FeS at 100C over 7 days. This is the canonical prebiotic acetyl-CoA analog step; FeS-bearing hydrothermal sulfides are included to satisfy mineral-agent requirements while preserving the reported pathway."}, {"id": "rxn_005", "name": "Reductive carboxylation of acetyl thioester to pyruvate", "inputs": ["mol_007", "mol_001"], "outputs": ["mol_005", "mol_006"], "environment": "Hydrothermal", "agents": ["elemental iron (Fe0)", "pyrite (FeS2)"], "conditions": {"temperature": "30-100C", "pressure": "1-40 bar", "catalyst": "Fe0 with sulfide mineral surfaces", "aqueous": "true", "other": "PFOR-analog carboxylation; geochemically plausible continuation of acetyl-CoA analog chemistry"}, "mechanism": "Activated acetyl thioester undergoes reductive carboxylation to the corresponding alpha-keto acid pyruvate with thiol release.", "reasoning": "The thioester-to-pyruvate step is explicitly identified in the research report as the abiotic analog of pyruvate:ferredoxin oxidoreductase chemistry following Huber and Wachtershauser (1997). Native iron-driven CO2 fixation to pyruvate supports the reductive carboxylation logic (Varma et al., 2018). This connection is mechanistically grounded but remains less directly demonstrated than the upstream thioester synthesis."}, {"id": "rxn_006", "name": "Greigite electrochemical CO2 reduction yielding pyruvate", "inputs": ["mol_001"], "outputs": ["mol_003", "mol_004", "mol_005"], "environment": "Hydrothermal", "agents": ["greigite (Fe3S4)", "mackinawite (FeS)"], "conditions": {"temperature": "room temperature", "pressure": "1 atm", "catalyst": "greigite nanoparticles", "aqueous": "true", "other": "electrochemical reduction; pyruvate selective near pH 6.5 but not at pH 4.5 or 10.5"}, "mechanism": "Activated CO2 on iron-sulfur surfaces is reduced and coupled to C1, C2, and C3 products including pyruvate.", "reasoning": "Roldan et al. (2015) demonstrated room-temperature atmospheric-pressure electrochemical CO2 reduction on greigite nanoparticles giving formate, acetate, methanol, and pyruvate, with pyruvate favored around pH 6.5. Santos-Carballal et al. (2018) supported strong CO2 activation on greigite surfaces by DFT."}, {"id": "rxn_007", "name": "HCN plus formaldehyde to glycolaldehyde via cyanosulfidic chemistry", "inputs": ["mol_011", "mol_012"], "outputs": ["mol_013"], "environment": "Surface", "agents": ["sulfide minerals (stibnite/molybdenite)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "~35C", "pressure": "1 atm", "catalyst": "sulfide-mediated UV photochemistry", "aqueous": "true", "other": "neutral pH; H2S and UV in the full cyanosulfidic network"}, "mechanism": "Cyanohydrin formation and subsequent photoredox reduction convert formaldehyde-derived nitrile chemistry into glycolaldehyde.", "reasoning": "Patel et al. (2015) established the cyanosulfidic network in which HCN and sulfur photochemistry generate simple sugars including glycolaldehyde under UV irradiation at around 35C and near-neutral pH. This step captures the glycolonitrile-to-glycolaldehyde transition central to that route."}, {"id": "rxn_008", "name": "Aldol/formose growth from formaldehyde to glycolaldehyde and glyceraldehyde", "inputs": ["mol_012"], "outputs": ["mol_013", "mol_014", "mol_023", "mol_018"], "environment": "Surface", "agents": ["borate minerals (colemanite/ulexite)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "borate-stabilized formose chemistry", "aqueous": "true", "other": "alkaline formose-type conditions; glyceraldehyde can dehydrate to methylglyoxal and rearrange to lactate"}, "mechanism": "Formaldehyde undergoes aldol growth to glycolaldehyde and glyceraldehyde; downstream dehydration/rearrangement gives methylglyoxal and lactate.", "reasoning": "The research summary cites the formose network from Butlerov (1861) and Breslow (1959), connecting formaldehyde to glycolaldehyde, glyceraldehyde, methylglyoxal, and lactate. Borate stabilization of sugars is consistent with prebiotic surface sugar chemistry discussed in the report."}, {"id": "rxn_009", "name": "Cyanosulfidic sugar progression from glycolaldehyde to glyceraldehyde and acetaldehyde", "inputs": ["mol_013", "mol_011", "mol_024"], "outputs": ["mol_014", "mol_019"], "environment": "Surface", "agents": ["sulfide minerals (stibnite/molybdenite)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "~35C", "pressure": "1 atm", "catalyst": "UV-driven cyanosulfidic sulfur chemistry", "aqueous": "true", "other": "neutral pH; acetaldehyde arises via thiocyanate-mediated deoxygenation"}, "mechanism": "Sequential homologation and sulfur-mediated photoredox reactions generate glyceraldehyde and deoxygenated acetaldehyde from the glycolaldehyde branch.", "reasoning": "Patel et al. (2015) reported the cyanosulfidic network producing glycolaldehyde, glyceraldehyde, and acetaldehyde under HCN/H2S/UV conditions, with acetaldehyde specifically arising through thiocyanate-mediated deoxygenation."}, {"id": "rxn_010", "name": "DAP phosphorylation of glyceraldehyde to glyceraldehyde-2-phosphate", "inputs": ["mol_014", "mol_025"], "outputs": ["mol_015"], "environment": "Surface", "agents": ["phosphate minerals (apatite/struvite)", "borate minerals (colemanite/ulexite)"], "conditions": {"temperature": "ambient", "pressure": "1 atm", "catalyst": "diamidophosphate with phosphate-rich surface environment", "aqueous": "true", "other": "alpha-phosphorylation step of the Coggins-Powner pathway"}, "mechanism": "Diamidophosphate transfers phosphate selectively to glyceraldehyde to generate a phosphorylated triose intermediate.", "reasoning": "Coggins and Powner (2017) demonstrated alpha-phosphorylation of glyceraldehyde with diamidophosphate to form glyceraldehyde-2-phosphate, establishing the prebiotic entry point to PEP."}, {"id": "rxn_011", "name": "Dehydration and oxidation from glyceraldehyde-2-phosphate to phosphoenolpyruvaldehyde and PEP", "inputs": ["mol_015"], "outputs": ["mol_016", "mol_017"], "environment": "Surface", "agents": ["phosphate minerals (apatite/struvite)", "montmorillonite (clay)"], "conditions": {"temperature": "60C", "pressure": "1 atm", "catalyst": "mineral-assisted dehydration in drying surface settings", "aqueous": "true", "other": "glyceraldehyde-2-phosphate dehydrates to phosphoenolpyruvaldehyde, then oxidizes to PEP"}, "mechanism": "Thermal dehydration generates the enol-aldehyde phosphate, which is then oxidized to the high-energy enol phosphate PEP.", "reasoning": "Coggins and Powner (2017) showed that glyceraldehyde-2-phosphate dehydrates at 60C to phosphoenolpyruvaldehyde and then oxidizes to phosphoenolpyruvate in a prebiotic glycolytic analog."}, {"id": "rxn_012", "name": "Hydrolysis of phosphoenolpyruvate to pyruvate", "inputs": ["mol_017"], "outputs": ["mol_005"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "variable", "pressure": "1 atm", "catalyst": null, "aqueous": "true", "other": "prebiotic hydrolysis of the high-energy enol phosphate"}, "mechanism": "PEP hydrolyzes to the thermodynamically favored keto acid pyruvate.", "reasoning": "Coggins and Powner (2017) identified PEP as the direct precursor whose hydrolysis furnishes pyruvate in the prebiotic triose-to-pyruvate pathway."}, {"id": "rxn_013", "name": "Glyoxylate dimerization to tartrate under cyanide catalysis", "inputs": ["mol_008", "mol_011"], "outputs": ["mol_010"], "environment": "Surface", "agents": ["borate minerals (colemanite/ulexite)", "montmorillonite (clay)"], "conditions": {"temperature": "alkaline, ambient to warm", "pressure": "1 atm", "catalyst": "cyanide catalysis", "aqueous": "true", "other": "high-yield dimerization under alkaline conditions; reported up to 80%"}, "mechanism": "Cyanide catalyzes coupling of two glyoxylate units to the four-carbon dihydroxy dicarboxylate tartrate.", "reasoning": "Cope et al. (2013) showed cyanide-catalyzed glyoxylate dimerization to tartrate at 80% yield under alkaline conditions, establishing the key glyoxylate-to-oxaloacetate route."}, {"id": "rxn_014", "name": "Tartrate dehydration to oxaloacetate", "inputs": ["mol_010"], "outputs": ["mol_009"], "environment": "Surface", "agents": ["montmorillonite (clay)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "warm drying conditions", "pressure": "1 atm", "catalyst": "mineral-assisted dehydration", "aqueous": "true", "other": "linked to the Eschenmoser-Cope glyoxylate scenario"}, "mechanism": "Dehydration of tartrate generates the alpha-keto dicarboxylate oxaloacetate.", "reasoning": "The research report summarizes the Eschenmoser scenario and Cope et al. (2013) pathway in which glyoxylate dimerizes to tartrate and tartrate dehydrates to oxaloacetate before spontaneous decarboxylation to pyruvate."}, {"id": "rxn_015", "name": "Spontaneous decarboxylation of oxaloacetate to pyruvate", "inputs": ["mol_009"], "outputs": ["mol_005", "mol_001"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "broadly prebiotic; kinetically temperature-dependent", "pressure": "1 atm", "catalyst": null, "aqueous": "true", "other": "non-enzymatic decarboxylation under essentially all prebiotic conditions"}, "mechanism": "Thermally labile oxaloacetate decarboxylates to the more stable three-carbon alpha-keto acid pyruvate.", "reasoning": "Guzman and Martin (2009) quantified spontaneous oxaloacetate decarboxylation kinetics to pyruvate + CO2, and the report emphasizes that any oxaloacetate-producing pathway automatically supplies pyruvate."}, {"id": "rxn_016", "name": "ZnS UV photooxidation of lactate to pyruvate", "inputs": ["mol_018"], "outputs": ["mol_005"], "environment": "Surface", "agents": ["sulfide minerals (ZnS-type photochemical analog)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "15C", "pressure": "1 atm", "catalyst": "UV-irradiated ZnS colloids represented in mineral-agent field by sulfide/TiO2 photochemical surfaces", "aqueous": "true", "other": "200-400 nm UV; circumneutral pH; reported 70% yield"}, "mechanism": "Photogenerated holes oxidize lactate to pyruvate with high efficiency under UV illumination.", "reasoning": "Guzman and Martin (2009) reported UV-irradiated ZnS photooxidation of lactate to pyruvate at 15C and circumneutral pH with 70% yield. This is the highest-yield single-step pyruvate-producing reaction described in the report."}, {"id": "rxn_017", "name": "Photochemical interconversion of pyruvate and lactate", "inputs": ["mol_005"], "outputs": ["mol_018"], "environment": "Surface", "agents": ["sulfide minerals (ZnS-type photochemical analog)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "15C", "pressure": "1 atm", "catalyst": "UV-irradiated ZnS colloids represented by photochemical mineral surfaces", "aqueous": "true", "other": "reverse photoreduction reported at ~30% yield"}, "mechanism": "Photoexcited mineral surfaces mediate reversible redox coupling between the alpha-keto acid and alpha-hydroxy acid.", "reasoning": "Guzman and Martin (2009) reported the reverse photoreduction of pyruvate to lactate, establishing a reversible pyruvate-lactate hub relevant to prebiotic steady-state flux."}, {"id": "rxn_018", "name": "HCN polymer hydrolysis producing glyoxylate and pyruvate", "inputs": ["mol_011", "mol_012"], "outputs": ["mol_008", "mol_005", "mol_020"
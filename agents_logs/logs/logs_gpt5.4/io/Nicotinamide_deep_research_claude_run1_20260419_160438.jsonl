n      \"iupac_name\": \"pyridine\",\n      \"common_name\": \"pyridine\",\n      \"inchi\": \"InChI=1S/C5H5N/c1-2-4-6-5-3-1/h1-5H\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"Greigite-catalyzed CO2 reduction to formate\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_003\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe3S4)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"greigite/mackinawite\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline vent conditions, anoxic, H2-rich\"\n      },\n      \"mechanism\": \"Mineral-surface hydrogenation of CO2 gives surface-bound formyl/formate species that desorb as formate.\",\n      \"reasoning\": \"Hydrothermal CO2 reduction to formate on iron-sulfur minerals is consistent with vent chemistry and provides a literature-grounded reduced carbon entry point for prebiotic networks; this step is used here only as feedstock provisioning rather than as a speculative direct route to nicotinamide (Huber & Wachtershauser, 1997; Preiner et al., 2020).\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Iron-sulfur carbon fixation to acetate\",\n      \"inputs\": [\"mol_001\", \"mol_002\", \"mol_003\"],\n      \"outputs\": [\"mol_004\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe3S4)\", \"pyrite (FeS2)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"greigite/pyrite\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline vent pH gradient, anoxic\"\n      },\n      \"mechanism\": \"Sequential mineral-mediated reduction and C-C bond formation yield acetate-like products analogous to acetyl synthesis in the acetyl-CoA pathway.\",\n      \"reasoning\": \"This reaction captures hydrothermal acetate formation on Fe-S minerals and supplies reduced carbon to the broader network without overstating unsupported direct surface feedstock conversions (Huber & Wachtershauser, 1997; Muchowska et al., 2019).\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Magnetite/greigite synthesis of pyruvate from CO2 and H2\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_005\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe3O4)\", \"greigite (Fe3S4)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"magnetite/greigite\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic subseafloor hydrothermal conditions\"\n      },\n      \"mechanism\": \"Surface-mediated multicarbon reduction/carboxylation yields alpha-keto acid products including pyruvate.\",\n      \"reasoning\": \"Pyruvate generation under hydrothermal mineral catalysis is included because alpha-keto acids are established central hubs in prebiotic protometabolism and support downstream amino acid formation relevant to the Cleaves-Miller branch (Muchowska et al., 2019; Varma et al., 2018).\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"Mineral-assisted reductive amination of pyruvate to aspartate precursor pool\",\n      \"inputs\": [\"mol_005\", \"mol_006\", \"mol_001\"],\n      \"outputs\": [\"mol_007\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"pyrite (FeS2)\", \"elemental iron (Fe0)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"pyrite/Fe0\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic NH3-bearing hydrothermal fluids; network-connecting step summarized over oxaloacetate-like intermediates\"\n      },\n      \"mechanism\": \"Reductive amination and c
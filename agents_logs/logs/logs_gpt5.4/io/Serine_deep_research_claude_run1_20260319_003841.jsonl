 "mol_007", "mol_013"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "sulfide minerals (molybdenite/stibnite)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "electric discharge / UV-active mineral surfaces in volcanic atmosphere-water interface", "aqueous": "true", "other": "volcanic spark discharge analog; CH4-bearing mixtures implied; steam and H2S enhance hydroxylated amino acid formation"}, "mechanism": "Energetic discharge creates HCN and aldehydes including glycolaldehyde in the gas phase; upon dissolution, Strecker chemistry yields serine in the aqueous reservoir.", "reasoning": "Spark discharge studies detected serine directly, with later re-analyses showing hydroxylated amino acids are favored in volcanic/H2S-containing apparatuses. This reaction compresses the experimentally observed precursor generation plus aqueous Strecker conversion into a network edge while preserving the literature route (Ring et al., 1972; Johnson et al., 2008; Parker et al., 2011; Miller, 1957)."}], "pathways": [{"pathway_id": "P1", "name": "Canonical hydrothermal-to-surface Strecker route", "description": "CO2 is reduced hydrothermally to formaldehyde, which undergoes surface formose condensation to glycolaldehyde, then Strecker synthesis and hydrolysis to serine.", "reaction_sequence": ["rxn_002", "rxn_005", "rxn_009", "rxn_011", "rxn_012"], "key_intermediates": ["mol_006", "mol_007", "mol_011", "mol_012"]}, {"pathway_id": "P2", "name": "Cyanosulfidic photochemistry to serine", "description": "HCN and H2S in UV-irradiated surface settings produce glycolaldehyde and glyceraldehyde, then glycolaldehyde enters Strecker synthesis to serine.", "reaction_sequence": ["rxn_003", "rxn_006", "rxn_009", "rxn_011", "rxn_012"], "key_intermediates": ["mol_004", "mol_007", "mol_011", "mol_012"]}, {"pathway_id": "P3", "name": "Hydrothermal HCN plus hydrothermal formaldehyde convergence", "description": "Hydrothermal settings supply both HCN and for
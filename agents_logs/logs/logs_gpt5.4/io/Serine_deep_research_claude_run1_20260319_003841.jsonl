ed": "Surface"}, {"id": "mol_013", "formula": "C3H4N2", "iupac_name": "2-aminoprop-2-enenitrile", "common_name": "dehydroalanine nitrile", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_014", "formula": "H2S", "iupac_name": "sulfane", "common_name": "hydrogen sulfide", "inchi": "InChI=1S/H2S/h1H2", "role": "starting", "environment_formed": null}, {"id": "mol_015", "formula": "C3H4O3", "iupac_name": "2-oxopropanoic acid", "common_name": "pyruvic acid", "inchi": "InChI=1S/C3H4O3/c1-2(4)3(5)6/h1H3,(H,5,6)", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_016", "formula": "C2H5NO2", "iupac_name": "aminoacetic acid", "common_name": "glycine", "inchi": "InChI=1S/C2H5NO2/c3-1-2(4)5/h1,3H2,(H,4,5)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_017", "formula": "C3H7NO5P", "iupac_name": "2-amino-3-hydroxy-3-phosphonopropanoic acid", "common_name": "phosphoserine", "inchi": null, "role": "intermediate", "environment_formed": "Biochemical"}, {"id": "mol_018", "formula": "H3PO4", "iupac_name": "phosphoric acid", "common_name": "phosphate", "inchi": "InChI=1S/H3O4P/c1-5(2,3)4/h(H3,1,2,3,4)", "role": "starting", "environment_formed": null}, {"id": "mol_019", "formula": "C6H5N5", "iupac_name": "9H-purin-6-amine", "common_name": "adenine", "inchi": "InChI=1S/C5H5N5/c6-5-4-7-2-8-3-9-1-10(3)4/h1-2H,(H3,6,7,8,9)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_020", "formula": "C5H10O5", "iupac_name": "pentane-1,2,3,4,5-pentol", "common_name": "ribose", "inchi": "InChI=1S/C5H10O5/c6-1-2(7)3(8)4(9)5(10)11/h2-10H,1H2", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_021", "formula": "C10H14N5O7P", "iupac_name": "[(2R,3R,4S,5R)-5-(6-aminopurin-9-yl)-3,4-dihydroxyoxolan-2-yl]methyl dihydrogen phosphate", "common_name": "adenosine monophosphate", "inchi": null, "role": "intermediate", "environment_formed": "Biochemical"}, {"id": "mol_022", "formula": "C6H5N3O", "iupac_name": "1,3-oxazol-2-amine, 4,5-dihydro-4-hydroxymethyl-", "common_name": "2-aminooxazole", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_023", "formula": "CH2N2S", "iupac_name": "thiourea-analog precursor not used", "common_name": "cyanamide", "inchi": "InChI=1S/CH2N2/c2-1-3/h(H2,2,3)", "role": "starting", "environment_formed": null}, {"id": "mol_024", "formula": "C3H6O3", "iupac_name": "2,3-dihydroxypropanal", "common_name": "glyceraldehyde", "inchi": "InChI=1S/C3H6O3/c4-1-3(6)2-5/h1,3,5-6H,2H2", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_025", "formula": "HCOO-", "iupac_name": "methanoate", "common_name": "formate", "inchi": "InChI=1S/CHO2/c2-1-3/h1H,(H,2,3)/p-1", "role": "intermediate", "environment_formed": "Hydrothermal"}], "reactions": [{"id": "rxn_001", "name": "Greigite-catalyzed CO2 reduction to formate", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_025"], "environment": "Hydrothermal", "agents": ["greigite (Fe3S4)", "mackinawite (FeS)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "greigite/mackinawite", "aqueous": "true", "other": "alkaline vent-like, anoxic, H2-rich"}, "mechanism": "Surface-mediated reduction of CO2 by H2 on mixed-valence iron-sulfur minerals to give formate as an early fixed-carbon product.", "reasoning": "Hydrothermal CO2 activation on Fe-S minerals is supported by greigite surface studies and iron-sulfur world chemistry; formate is a plausible reduced C1 feedstock under alkaline vent conditions (Santos-Carballal et al., 2018; W\u00e4chtersh\u00e4user, 1988; Kitadai, 2015)."}, {"id": "rxn_002", "name": "Magnetite/elemental-iron Fischer-Tropsch-type formation of formaldehyde", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_005"], "environment": "Hydrothermal", "agents": ["magnetite (Fe3O4)", "elemental iron (Fe0)"], "conditions": {"temperature": "400-500K", "pressure": "high", "catalyst": "magnetite/Fe0", "aqueous": "true", "other": "subseafloor or vent-wall reducing conditions; step included as a connected C1 source feeding known surface chemistry"}, "mechanism": "Sequential CO2 hydrogenation and partial reduction on iron-bearing mineral surfaces produces reduced carbonyl compounds, represented here by formaldehyde as a transferable C1 intermediate.", "reasoning": "Reduced C1 organics from hydrothermal Fe-bearing systems are consistent with Fischer-Tropsch-type chemistry, though direct formaldehyde assignment is more connective than directly demonstrated for serine-specific studies; included conservatively to bridge hydrothermal carbon fixation with the literature-established formose/Strecker network (Kitadai, 2015; Santos-Carballal et al., 2018)."}, {"id": "rxn_003", "name": "Hydrothermal pyruvate generation on Fe-S/oxide minerals", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_015"], "environment": "Hydrothermal", "agents": ["magnetite (Fe3O4)", "greigite (Fe3S4)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "magnetite/greigite", "aqueous": "true", "other": "alkaline vent window; represented as vent-associated keto-acid generation feeding later turnover chemistry"}, "mechanism": "Mineral-assisted reductive carbon fixation generates small keto-acids, with pyruvate represented as a central hydrothermal metabolic analog.", "reasoning": "Pyruvate is widely treated as a plausible hydrothermal keto-acid hub in Fe-S vent scenarios, though direct serine-forming extension is weaker than the glycolaldehyde route; it is included here mainly to connect the well-supported serine decomposition branch back into hydrothermal protometabolism (Kitadai, 2015; Barge et al., 2019)."}, {"id": "rxn_004", "name": "Surface formose condensation to glycolaldehyde", "inputs": ["mol_005"], "outputs": ["mol_006"], "environment": "Surface", "agents": ["borate minerals (colemanite/ulexite)", "montmorillonite (clay)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "borate minerals with mineral surface concentration", "aqueous": "true", "other": "basic aqueous evaporitic or geothermal setting; first stable C2 sugar product"}, "mechanism": "Butlerov-type self-condensation of formaldehyde gives glycolaldehyde, with borate stabilizing emerging sugars and mineral surfaces concentrating reactants.", "reasoning": "Glycolaldehyde as the first stable formose product is classic prebiotic chemistry, and borate stabilization is strongly supported for sugar survival; this is the key precursor bottleneck for serine Strecker synthesis (Breslow, 1959; J\u00f8rgensen et al., 2012)."}, {"id": "rxn_005", "name": "Cyanosulfidic photoredox generation of glycolaldehyde from HCN", "inputs": ["mol_004", "mol_014"], "outputs": ["mol_006"], "environment": "Surface", "agents": ["sulfide minerals (molybdenite/stibnite)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "308K", "pressure": "1 atm", "catalyst": "mineral-supported cyanosulfidic photoredox milieu", "aqueous": "true", "other": "35C, anaerobic, neutral phosphate buffer, UV irradiation, H2S as stoichiometric reductant"}, "mechanism": "Reductive homologation of HCN under UV-driven cyanosulfidic conditions generates C2 sugars including glycolaldehyde.", "reasoning": "Patel et al. established HCN + H2S photoredox chemistry as a unified source of nucleotide, amino acid, and lipid precursors at 35C in neutral phosphate buffer; glycolaldehyde is a central product and branch point in this network (Patel et al., 2015)."}, {"id": "rxn_006", "name": "Cyanosulfidic photoredox generation of glyceraldehyde from HCN", "inputs": ["mol_004", "mol_014"], "outputs": ["mol_024"], "environment": "Surface", "agents": ["sulfide minerals (molybdenite/stibnite)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "308K", "pressure": "1 atm", "catalyst": "mineral-supported cyanosulfidic photoredox milieu", "aqueous": "true", "other": "35C, anaerobic, neutral phosphate buffer, UV irradiation"}, "mechanism": "Further reductive homologation in the same cyanosulfidic network gives the C3 sugar glyceraldehyde.", "reasoning": "Glyceraldehyde and glycolaldehyde arise together in the Sutherland cyanosulfidic network and jointly connect sugar, amino acid, and nucleotide chemistry (Patel et al., 2015; Powner et al., 2017)."}, {"id": "rxn_007", "name": "HCN hydrolysis to formamide under UV-active surface conditions", "inputs": ["mol_004"], "outputs": ["mol_011"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "montmorillonite (clay)"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "TiO2 photocatalytic mineral surface", "aqueous": "true", "other": "UV-exposed subaerial pool; connects HCN reservoir to formamide-mediated aminonitrile protection chemistry"}, "mechanism": "Photochemically assisted hydration/rearrangement of HCN in water yields formamide in a concentrated surface setting.", "reasoning": "Formamide is a recognized UV-accessible derivative in HCN-rich prebiotic settings and is directly relevant because protected serinonitrile chemistry is demonstrated in formamide solvent; this step is included as a connecting reservoir transformation rather than a serine-specific isolated claim (Pulletikurti et al., 2023; Patel et al., 2015)."}, {"id": "rxn_008", "name": "Formaldimine formation from formaldehyde and ammonia", "inputs": ["mol_005", "mol_003"], "outputs": ["mol_007"], "environment": "Surface", "agents": ["montmorillonite (clay)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "mineral surface concentration", "aqueous": "true", "other": "mild drying-rewetting or photochemically active pool"}, "mechanism": "Condensation of formaldehyde with ammonia forms methanimine/formaldimine, a kinetically favorable C1 imine precursor.", "reasoning": "Recent computational work suggests formaldimine may be a more kinetically favorable precursor than HCN in some serine-related coupling manifolds; included explicitly as a literature-flagged open frontier rather than replacing the validated glycolaldehyde Strecker route (JACS Au, 2024 as summarized in the research findings)."}, {"id": "rxn_009", "name": "Canonical Strecker formation of serinonitrile from glycolaldehyde", "inputs": ["mol_006", "mol_003", "mol_004"], "outputs": ["mol_008"], "environment": "Surface", "agents": ["montmorillonite (clay)", "borate minerals (colemanite/ulexite)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "mineral concentration/stabilization surfaces", "aqueous": "true", "other": "mildly basic aqueous conditions; imine formation followed by cyanide addition"}, "mechanism": "Glycolaldehyde condenses with ammonia to the hydroxy-imine, followed by cyanide addition to yield 2-amino-3-hydroxypropanenitrile.", "reasoning": "This is the dominant and best-supported prebiotic route to serine: glycolaldehyde + NH3 + HCN gives serinonitrile as the first stable Strecker intermediate, consistent with kinetics and free-energy studies (Miller and Van Trump, 1981; Magrino, Pietrucci, and Saitta, 2021)."}, {"id": "rxn_010", "name": "Formamide-protected formation of N-formylserinonitrile", "inputs": ["mol_006", "mol_004", "mol_011"], "outputs": ["mol_012"], "environment": "Surface", "agents": ["montmorillonite (clay)", "borate minerals (colemanite/ulexite)"], "conditions": {"temperature": "353K", "pressure": "1 atm", "catalyst": "formamide medium with mineral concentration", "aqueous": "false", "other": "formamide-rich evaporitic setting; N-formyl group protects aminonitrile against equilibrium reversion"}, "mechanism": "Cyanide addition to the glycolaldehyde-derived imine in formamide gives an N-formyl-protected serine aminonitrile.", "reasoning": "Pulletikurti et al. showed N-formylserinonitrile forms readily in formamide and that formyl protection stabilizes the aminonitrile during downstream hydrolysis chemistry; this is a specific literature-supported alternative branch from the same glycolaldehyde hub (Pulletikurti et al., 2023)."}, {"id": "rxn_011", "name": "Hydrolysis of serinonitrile to serinamide", "inputs": ["mol_008"], "outputs": ["mol_009"], "environment": "Surface", "agents": ["phosphate minerals (apatite/struvite)", "montmorillonite (clay)"], "conditions": {"temperature": "273-298K", "pressure": "1 atm", "catalyst": "mineral-assisted aqueous hydrolysis", "aqueous": "true", "other": "cool aqueous conditions; geologically rapid aminonitrile hydrolysis"}, "mechanism": "Partial nitrile hydrolysis converts serinonitrile to the corresponding amide.", "reasoning": "Aminonitrile hydrolysis to amino acid amides and then amino acids is kinetically established; half-lives under cool aqueous conditions are geologically short enough for prebiotic relevance (Miller and Van Trump, 1981)."}, {"id": "rxn_012", "name": "Hydrolysis of serinamide to serine", "inputs": ["mol_009"], "outputs": ["mol_010"], "environment": "Surface", "agents": ["phosphate minerals (apatite/struvite)", "montmorillonite (clay)"], "conditions": {"temperature": "273-298K", "pressure": "1 atm", "catalyst": "mineral-assisted aqueous hydrolysis", "aqueous": "true", "other": "cool surface waters favored because serine is thermally fragile"}, "mechanism": "Further amide hydrolysis yields free serine.", "reasoning": "This completes the canonical Strecker route and is consistent with the measured hydrolysis behavior of aminonitrile-derived intermediates and the need for cool conditions to preserve serine (Miller and Van Trump, 1981; Qian et al., 1993; K\u00f6rner et al., 2021)."}, {"id": "rxn_013", "name": "Hydrolysis/deprotection of N-formylserinonitrile to serine", "inputs": ["mol_012"], "outputs": ["mol_010"], "environment": "Surface", "agents": ["phosphate minerals (apatite/struvite)", "montmorillonite (clay)"], "conditions": {"temperature": "353K", "pressure": "1 atm", "catalyst": "MgCl2-supported formamide chemistry with subsequent hydrolysis on mineral surfaces", "aqueous": "true", "other": "formamide-to-water transition; protected aminonitrile avoids backward equilibration"}, "mechanism": "Protected aminonitrile is hydrolyzed and deformylated to furnish serine.", "reasoning": "Formamide-protected serine aminonitrile chemistry was developed precisely to address aminonitrile reversibility; this route is less classical than direct Strecker hydrolysis but directly grounded in the recent JACS study (Pulletikurti et al., 2023)."}, {"id": "rxn_014", "name": "\u03b2-Elimination of serinonitrile to dehydroalanine nitrile", "inputs": ["mol_008"], "outputs": ["mol_013"], "environment": "Surface", "agents": ["montmorillonite (clay)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "300-353K", "pressure": "1 atm", "catalyst": "mineral-assisted elimination in drying phases", "aqueous": "true", "other": "neutral to mildly basic; branch-point chemistry toward cysteine network"}, "mechanism": "Serinonitrile undergoes \u03b2-elimination of water to form dehydroalanine nitrile.", "reasoning": "Foden et al. demonstrated that serine-derived nitrile chemistry accesses dehydroalanine nitrile, a major branch point leading toward cysteine and related products; this establishes serinonitrile as a true network hub rather than a simple one-way precursor (Foden et al., 2020)."}, {"id": "rxn_015", "name": "Empirical spark-discharge generation of HCN and formaldehyde precursors", "inputs": ["mol_002", "mol_003", "mol_001"], "outputs": ["mol_004", "mol_005"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "montmorillonite (clay)"], "conditions": {"temperature": "variable local plasma with bulk aqueous collection near ambient", "pressure": "1 atm", "catalyst": "electric discharge plus mineral adsorption after dissolution", "aqueous": "true", "other": "volcanic or reducing atmosphere analogue with lightning/spark and steam injection"}, "mechanism": "Ele
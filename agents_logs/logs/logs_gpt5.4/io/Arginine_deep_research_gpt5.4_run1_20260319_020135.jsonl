"C3H3O3-\",\n      \"iupac_name\": \"2-oxopropanoate\",\n      \"common_name\": \"pyruvate\",\n      \"inchi\": \"InChI=1S/C3H4O3/c1-2(4)3(5)6/h1H3,(H,5,6)/p-1\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_016\",\n      \"formula\": \"C3H7NO2\",\n      \"iupac_name\": \"2-aminopropanoic acid\",\n      \"common_name\": \"alanine\",\n      \"inchi\": \"InChI=1S/C3H7NO2/c1-2(4)3(5)6/h2H,4H2,1H3,(H,5,6)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_017\",\n      \"formula\": \"H2O\",\n      \"iupac_name\": \"oxidane\",\n      \"common_name\": \"water\",\n      \"inchi\": \"InChI=1S/H2O/h1H2\",\n      \"role\": \"starting\",\n      \"environment_formed\": null\n    },\n    {\n      \"id\": \"mol_018\",\n      \"formula\": \"C9H20N6O3\",\n      \"iupac_name\": \"alanylarginine\",\n      \"common_name\": \"Ala-Arg dipeptide\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"Hydrothermal CO2 reduction to formate\",\n      \"inputs\": [\"mol_012\", \"mol_017\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe3S4)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"greigite/mackinawite\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline vent conditions; H2-rich serpentinization setting; anoxic\"\n      },\n      \"mechanism\": \"Fe-S surface mediated CO2 reduction under hydrothermal redox gradients gives C1 reduced carbon as formate.\",\n      \"reasoning\": \"Included as literature-consistent hydrothermal feedstock provisioning rather than arginine-specific chemistry. Fe-S minerals are established for CO2 reduction in vent scenarios and provide environmental interconnection to surface chemistry; no direct arginine synthesis is claimed here. This follows the hydrothermal context summarized in the report and is consistent with Fe-S mediated prebiotic carbon fixation discussions linked to vent chemistry (Huber & Wachtershauser, 1997; Glavin et al., 2025 review context).\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Hydrothermal further reduction to acetate\",\n      \"inputs\": [\"mol_013\"],\n      \"outputs\": [\"mol_014\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe3S4)\", \"magnetite (Fe3O4)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"greigite/magnetite\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline hydrothermal setting; reducing conditions\"\n      },\n      \"mechanism\": \"Sequential mineral-catalyzed reduction and C-C bond-forming carbon fixation yields acetate-like products.\",\n      \"reasoning\": \"Used only to maintain a connected hydrothermal carbon-fixation module consistent with the framework requirement; not claimed as an arginine route. Hydrothermal Fe-S/carbon fixation chemistry is discussed in the supplied report as general provisioning chemistry, distinct from the actual arginine-forming cyanide sequence (Huber & Wachtershauser, 1997; Glavin et al., 2025).\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Hydrothermal pyruvate generation\",\n      \"inputs\": [\"mol_012\", \"mol_013\"],\n      \"outputs\": [\"mol_015\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe3O4)\", \"greigite (Fe3S4)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"magnetite/greigite\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic vent setting; reductive carbon fixation analog\"\n      },\n      \"mechanism\": \"Mineral-mediated reductive carbon fixation extends C1/C2 pools to alpha-keto acid chemistry, giving pyruvate as a metabolic hub.\",\n      \"reasoning\": \"This step is network-scaffolding to satisfy Hydrothermal \u2194 Surface \u2192 Biochemical connectivity and the requested hub topology, not a literature-demonstrated entry to arginine. The report specifically notes alpha-keto acid chemistry and Fe-S reductive amination as plausible hydrothermal reactions while acknowledging no demonstrated arginine formation (Huber & Wachtershauser, 1997; Miller, 1986; Pol et al., 2022).\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"Hydrothermal reductive amination of pyruvate to alanine\",\n      \"inputs\": [\"mol_015\", \"mol_003\"],\n      \"outputs\": [\"mol_016\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"pyrite (FeS2)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"FeS/FeS2 mineral surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"acidic to mildly reducing hydrothermal conditions; excess NH3\"\n      },\n      \"mechanism\": \"Fe-S catalyzed reductive amination of an alpha-keto acid produces the corresponding amino acid.\",\n      \"reasoning\": \"This is directly aligned with the report's citation that FeS/NiS-mediated reductive amination can produce alpha-amino acids from keto acids, while explicitly not extending that evidence to arginine because no guanidino-group installation is demonstrated (Huber & Wachtershauser, 1997; Miller, 1986; Pol et al., 2022).\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"Surface cyanosulfidic photoredox formation of acrylonitrile\",\n      \"inputs\": [\"mol_001\", \"mol_002\", \"mol_004\"],\n      \"outputs\": [\"mol_005\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (stibnite, molybdenite)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"Cu(I)/Cu(II) photoredox with Zn2+ in aqueous UV-irradiated sulfide-rich pools\",\n        \"aqueous\": \"true\",\n        \"other\": \"UV around 300 nm; H2S reductant; stepwise reagent addition; evaporitic or photic surface pond\"\n      },\n      \"mechanism\": \"HCN and acetylene undergo Cu photoredox-mediated coupling in the presence of sulfide reductant to give acrylonitrile.\",\n      \"reasoning\": \"This is the key experimentally grounded entry to the arginine route: Patel et al. reported acrylonitrile formation from HCN and acetylene under UV-driven cyanosulfidic conditions, with yields above 25%. The mineral field here reflects the required surface mineral specification while the actual catalytic system follows the literature Cu/Zn/H2S photoredox chemistry (Patel et al., 2015).\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"Surface ammonia addition to acrylonitrile\",\n      \"inputs\": [\"mol_005\", \"mol_003\"],\n      \"outputs\": [\"mol_006\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\", \"sulfide minerals (stibnite, molybdenite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"surface concentration on clay; aqueous NH3\",\n        \"aqueous\": \"true\",\n        \"other\": \"neutral to slightly basic aqueous conditions; post-photoredox step\"\n      },\n      \"mechanism\": \"Conjugate addition of ammonia to activated unsaturated nitrile yields beta-aminopropionitrile.\",\n      \"reasoning\": \"The report identifies beta-aminopropionitrile from acrylonitrile plus ammonia as a central documented intermediate in the Patel sequence. Montmorillonite is included as a plausible concentrating mineral, while the chemical step itself follows the Patel pathway (Patel et al., 2015; Glavin et al., 2025 review summary).\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Surface cyanamide capture and photoreductive conversion to cyclic guanidinium hemiaminal\",\n      \"inputs\": [\"mol_006\", \"mol_007\", \"mol_004\"],\n      \"outputs\": [\"mol_008\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (stibnite, molybdenite)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"UV photoreduction with H2S; Cu/Zn cyanosulfidic system\",\n        \"aqueous\": \"true\",\n        \"other\": \"acidic photoreduction segment after cyanamide addition; stepwise reagent delivery\"\n      },\n      \"mechanism\": \"Beta-aminopropionitrile is photoreduced to the corresponding aldehyde, which rapidly adds cyanamide to produce a cyclic guanidinium hemiaminal intermediate.\",\n      \"reasoning\": \"This step follows the explicit mechanistic description in the report: beta-aminopropionitrile is reduced to beta-aminopropionaldehyde and then intercepted by cyanamide to form a cyclic guanidinium hemiaminal. This is one of the crucial guanidino-installation steps and directly addresses the literature-identified challenge of guanidinium formation (Patel et al., 2015; Pol et al., 2022).\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Surface HCN homologation and thiolactam formation\",\n      \"inputs\": [\"mol_008\", \"mol_001\", \"mol_004\"],\n      \"outputs\": [\"mol_009\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (stibnite, molybdenite)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"UV/H2S photoreduction in Cu/Zn-enabled cyanosulfidic chemistry\",\n        \"aqueous\": \"true\",\n        \"other\": \"Kiliani-Fischer-type homologation sequence; alpha-hydroxythioamide formation followed by cyclization\"\n      },\n      \"mechanism\": \"HCN addition extends the carbon skeleton, photoreduction gives sulfur-containing intermediates, and intramolecular cyclization produces the guanidino thiolactam.\",\n      \"reasoning\": \"The report specifically describes subsequent HCN addition and photoreductive steps leading to an alpha-hydroxythioamide that cyclizes into gamma-butyrothiolactam. This is a core Patel intermediate sequence and should not be replaced by alternative chemistry (Patel et al., 2015).\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"Surface final homologation to arginine alpha-aminonitrile\",\n      \"inputs\": [\"mol_009\", \"mol_001\", \"mol_004\", \"mol_003\"],\n      \"outputs\": [\"mol_010\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (stibnite, molybdenite)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"continued UV/H2S photoreduction with cyanosulfidic reagent pulses\",\n        \"aqueous\": \"true\",\n        \"other\": \"stepwise HCN addition and reduction; neutral to mildly basic capture steps\"\n      },\n      \"mechanism\": \"Further reduction and cyanide-based homologation of the thiolactam sequence yields the arginine alpha-aminonitrile precursor.\",\n      \"reasoning\": \"This reaction condenses the documented late Patel sequence into the experimentally supported production of compound 46 class, the aminonitrile precursor to arginine. The report notes good to excellent yields across these homologation steps and identifies this as the only detailed route to arginine (Patel et al., 2015; Miller, 1986; Pol et al., 2022).\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"Biochemical-stage hydrolysis of arginine aminonitrile to arginine\",\n      \"inputs\": [\"mol_010\", \"mol_017\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"null\", \"null\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"null\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline hydrolysis in concentrated prebiotic pools; slow nitrile hydrolysis acknowledged as bottleneck\"\n      },\n      \"mechanism\": \"Aminonitrile hydrolyzes through amide-like intermediates to the free amino acid arginine.\",\n      \"reasoning\": \"The report states that simple alkaline hydrolysis of Patel compound 46 would give arginine, while also noting slow hydrolysis as a likely kinetic bottleneck. This is therefore literature-based but still recognized as a challenge in net arginine accumulation (Patel et al., 2015; Pol et al., 2022).\"\n    },\n    {\n      \"id\": \"rxn_011\",\n      \"name\": \"Biochemical concentration of arginine on montmorillonite interfaces\",\n      \"inputs\": [\"mol_011\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"null\", \"null\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"null\",\n        \"aqueous\": \"true\",\n        \"other\": \"cation-exchange adsorption at clay-rich sediment-water interfaces\"\n      },\n      \"mechanism\": \"Guanidinium-bearing arginine binds strongly to montmorillonite by cation exchange, concentrating and retaining the amino acid.\",\n      \"reasoning\": \"While not a synthetic transformation, this node-preserving concentration step is directly supported by the supplied report, which notes that arginine binds montmorillonite much more strongly than neutral amino acids. It provides a realistic post-synthesis concentration mechanism once arginine exists (ScienceDirect study on montmorillonite adsorption, 2024; cited in the report as [11]).\"\n    },\n    {\n      \"id\": \"rxn_012\",\n      \"name\": \"Biochemical wet-dry peptide coupling of alanine and arginine\",\n      \"inputs\": [\"mol_016\", \"mol_011\"],\n      \"outputs\": [\"mol_018\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"null\", \"null\"],\n      \"conditions\": {\n        \"temperature\": \"330-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"null\",\n        \"aqueous\": \"false\",\n        \"other\": \"wet-dry cycling in hydroxy-acid-rich prebiotic pools; dehydration-condensation context\"\n      },\n      \"mechanism\": \"Concentrated amino acids participate in dehydration-driven condensation/depsipeptide-assisted coupling to give short peptides.\",\n      \"reasoning\": \"Frenkel-Pinter and co-workers showed that when arginine is present with hydroxy acids and related monomers, it readily enters oligomeric products under wet-dry cycling. This reaction is included as downstream biochemical relevance after arginine formation rather than as part of arginine synthesis itself (Frenkel-Pinter et al., 2019-2020; cited in the report as [7]).\"\n    }\n  ],\n  \"pathways\": [\n    {\n      \"pathway_id\": \"P1\",\n      \"name\": \"Canonical Patel cyanosulfidic arginine route\",\n      \"description\": \"Direct literature-supported sequence from HCN and acetylene through acrylonitrile, beta-aminopropionitrile, guanidinium intermediates, thiolactam, aminonitrile, and hydrolysis to arginine.\",\n      \"reaction_sequence\": [\"rxn_005\", \"rxn_006\", \"rxn_007\", \"rxn_008\", \"rxn_009\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_005\", \"mol_006\", \"mol_008\", \"mol_009\", \"mol_010\"]\n    },\n    {\n      \"pathway_id\": \"P2\",\n      \"name\": \"Hydrothermal ammonia provisioning into Patel route\",\n      \"description\": \"Hydrothermal generation/availability of ammonia feeds the surface cyanosulfidic route beginning with acrylonitrile amination and ending in arginine.\",\n      \"reaction_sequence\": [\"rxn_004\", \"rxn_006\", \"rxn_007\", \"rxn_008\", \"rxn_009\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_003\", \"mol_006\", \"mol_010\"]\n    },\n    {\n      \"pathway_id\": \"P3\",\n      \"name\": \"Hydrothermal-to-surface full connected traversal\",\n      \"description\": \"Connected environmental story from hydrothermal carbon reduction and amino acid chemistry into UV-driven surface arginine synthesis, emphasizing environmental interconnection rather than alternative arginine chemistry.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_003\", \"rxn_004\", \"rxn_005\", \"rxn_006\", \"rxn_007\", \"rxn_008\", \"rxn_009\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_013\", \"mol_015\", \"mol_003\", \"mol_005\", \"mol_010\"]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"Acrylonitrile-centered route\",\n      \"description\": \"Shortest route from the experimentally documented acrylonitrile intermediate to arginine.\",\n      \"reaction_sequence\": [\"rxn_006\", \"rxn_007\", \"rxn_008\", \"rxn_009\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_006\", \"mol_008\", \"mol_009\", \"mol_010\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"Beta-aminopropionitrile-centered route\",\n      \"description\": \"Route beginning from the key precursor beta-aminopropionitrile identified in the literature, proceeding through guanidinium capture and homologation to arginine.\",\n      \"reaction_sequence\": [\"rxn_007\", \"rxn_008\", \"rxn_009\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_008\", \"mol_009\", \"mol_010\"]\n    },\n    {\n      \"pathway_id\": \"P6\",\n      \"name\": \"Cyanamide-entry route\",\n      \"description\": \"Traversal emphasizing cyanamide-mediated guanidino installation, the central unresolved challenge highlighted by the literature.\",\n      \"reaction_sequence\": [\"rxn_006\", \"rxn_007\", \"rxn_008\", \"rxn_009\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_008\", \"mol_010\"]\n    },\n    {\n      \"pathway_id\"
ed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_012\",\n      \"formula\": \"C4H8N4O\",\n      \"iupac_name\": \"guanidinium hemiaminal intermediate\",\n      \"common_name\": \"cyclic guanidinium hemiaminal\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_013\",\n      \"formula\": \"C5H8N4OS\",\n      \"iupac_name\": \"gamma-butyrothiolactam intermediate\",\n      \"common_name\": \"gamma-butyrothiolactam\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_014\",\n      \"formula\": \"C6H11N5\",\n      \"iupac_name\": \"arginine alpha-aminonitrile\",\n      \"common_name\": \"Patel compound 46\",\n      \"inchi\": null,\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_015\",\n      \"formula\": \"C6H14N4O2\",\n      \"iupac_name\": \"(2S)-2-amino-5-guanidinopentanoic acid\",\n      \"common_name\": \"arginine\",\n      \"inchi\": \"InChI=1S/C6H14N4O2/c7-4(5(11)12)2-1-3-10-6(8)9/h4H,1-3,7H2,(H,11,12)(H4,8,9,10)\",\n      \"role\": \"target\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_016\",\n      \"formula\": \"C5H9NO4\",\n      \"iupac_name\": \"2-aminopentanedioic acid\",\n      \"common_name\": \"glutamic acid\",\n      \"inchi\": \"InChI=1S/C5H9NO4/c6-3(5(9)10)1-2-4(7)8/h3H,1-2,6H2,(H,7,8)(H,9,10)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_017\",\n      \"formula\": \"C5H12N2O2\",\n      \"iupac_name\": \"2,5-diaminopentanoic acid\",\n      \"common_name\": \"ornithine\",\n      \"inchi\": \"InChI=1S/C5H12N2O2/c6-3-1-2-4(7)5(8)9/h4H,1-3,6-7H2,(H,8,9)\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_018\",\n      \"formula\": \"CHNO\",\n      \"iupac_name\": \"isocyanic acid\",\n      \"common_name\": \"cyanate\",\n      \"inchi\": \"InChI=1S/CHNO/c2-1-3/h(H,2,3)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_019\",\n      \"formula\": \"C6H13N3O3\",\n      \"iupac_name\": \"2-amino-5-(carbamimidamido)pentanoic acid precursor analogue\",\n      \"common_name\": \"citrulline\",\n      \"inchi\": \"InChI=1S/C6H13N3O3/c7-4(5(10)11)2-1-3-9-6(8)12/h4H,1-3,7H2,(H2,8,12)(H,10,11)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"Hydrothermal NH3 provisioning in Fe-S alkaline vent setting\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_003\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"mackinawite\", \"greigite\"],\n      \"conditions\": {\n        \"temperature\": \"350-450K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"mackinawite/greigite\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline hydrothermal vent; reducing, anoxic, NH3-rich vent fluids invoked as environmental feedstock source rather than direct stoichiometric laboratory synthesis\"\n      },\n      \"mechanism\": \"Vent-associated Fe-S mineral catalysis and water-rock redox chemistry generate reducing conditions compatible with ammonia-bearing hydrothermal fluids feeding surface environments.\",\n      \"reasoning\": \"Used conservatively as an environmental feedstock-provisioning step because the supplied literature emphasizes ammonia-rich hydrothermal settings rather than a specific Arg-forming vent reaction. Hydrothermal vents provide H2, NH3 and FeS/NiS catalysis for general reductive chemistry, but no direct arginine synthesis is known (Huber & Wachtershauser, 1997 as summarized in ref. [9]; Glavin et al., 2025; Pol et al., 2022). This step is therefore a network connector, not a claim of demonstrated arginine synthesis.\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Hydrothermal H2S provisioning in serpentinizing Fe-S systems\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_006\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"pyrite\", \"elemental iron\"],\n      \"conditions\": {\n        \"temperature\": \"370-470K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"pyrite/Fe0\",\n        \"aqueous\": \"true\",\n        \"other\": \"subseafloor hydrothermal, anoxic, reduced sulfur-bearing fluids\"\n      },\n      \"mechanism\": \"Fe-S mineral buffering in hydrothermal systems supplies reduced sulfur species to later surface photoredox chemistry.\",\n      \"reasoning\": \"The deep research report identifies H2S as the key reductant in the Patel cyanosulfidic network and highlights hydrothermal and sulfur-rich settings as plausible suppliers of reduced sulfur. This is included as a feedstock-transfer step linking hydrothermal sulfur chemistry to surface UV-driven homologation, not as a specific Arg-forming experiment (Patel et al., 2015; Glavin et al., 2025).\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Surface UV hydrolysis of HCN to formamide\",\n      \"inputs\": [\"mol_004\"],\n      \"outputs\": [\"mol_007\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2\", \"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO2\",\n        \"aqueous\": \"true\",\n        \"other\": \"UV-irradiated shallow pool, anoxic\"\n      },\n      \"mechanism\": \"HCN in aqueous UV-exposed surface settings is converted through hydrolysis/photochemical routes to formamide, which can serve as a precursor reservoir for cyanamide-rich nitrogen chemistry.\",\n      \"reasoning\": \"The report notes UV photochemistry of HCN to formamide and identifies HCN-rich surface settings as central to prebiotic nitrogen chemistry, though this step is not Arg-specific. Included to connect nitrogen feedstock transformations relevant to cyanamide emergence in cyanosulfidic settings (Miller, 1986 review in ref. [1]; Patel et al., 2015).\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"Surface dehydration of formamide to cyanamide\",\n      \"inputs\": [\"mol_007\"],\n      \"outputs\": [\"mol_008\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"phosphate minerals\", \"TiO2\"],\n      \"conditions\": {\n        \"temperature\": \"320-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"phosphate minerals\",\n        \"aqueous\": \"false\",\n        \"other\": \"wet-dry cycling in evaporitic pool; UV-exposed\"\n      },\n      \"mechanism\": \"Dry-down and mineral-assisted dehydration convert amide-like nitrogen reservoirs into cyanamide, a guanidinylating agent needed for the Patel sequence.\",\n      \"reasoning\": \"Cyanamide is explicitly identified in the literature as a key guanidinylating reagent in the Patel route. Its exact geochemical sourcing is less firmly demonstrated than its use, so this connector is moderately speculative but consistent with the report's emphasis on wet-dry and photochemical cyanamide-rich surface settings (Patel et al., 2015; Miller, 1986 review).\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"Cu-photoredox cyanosulfidic coupling of HCN and acetylene to acrylonitrile\",\n      \"inputs\": [\"mol_004\", \"mol_005\", \"mol_006\"],\n      \"outputs\": [\"mol_009\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals\", \"TiO2\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"Cu(I)/Cu(II) photoredox with Zn2+; sulfide mineral-rich UV-irradiated aqueous setting\",\n        \"aqueous\": \"true\",\n        \"other\": \"UV around 300 nm; H2S reductant; stepwise reagent addition; reported yield up to >25%\"\n      },\n      \"mechanism\": \"Photoredox activation of cyanide/acetylene in sulfide-rich water forms the three-carbon nitrile acrylonitrile.\",\n      \"reasoning\": \"This is the core literature-supported entry to the arginine network. Patel et al. showed that HCN and acetylene under UV with Cu photoredox chemistry and H2S reductant produce acrylonitrile in significant yield, providing the backbone precursor for arginine homologation (Patel et al., 2015, refs. [3], [4], [6], [8]).\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"Ammonia addition to acrylonitrile forming beta-aminopropionitrile\",\n      \"inputs\": [\"mol_009\", \"mol_003\"],\n      \"outputs\": [\"mol_010\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"sulfide minerals\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"none required in solution; mineral surfaces used for concentration\",\n        \"aqueous\": \"true\",\n        \"other\": \"neutral to slightly basic aqueous conditions; ammonia addition step in Patel sequence\"\n      },\n      \"mechanism\": \"Nucleophilic conjugate addition of ammonia to the activated nitrile alkene yields beta-aminopropionitrile.\",\n      \"reasoning\": \"Beta-aminopropionitrile is explicitly identified as a central Patel intermediate arising from acrylonitrile plus ammonia. Mineral phases are included here for concentration, satisfying the surface-agent requirement, especially because clays can concentrate cationic/basic products and intermediates (Patel et al., 2015; Frenkel-Pinter et al., 2024/2025-like adsorption study summarized as ref. [11]).\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"UV/H2S photoreduction of beta-aminopropionitrile to beta-aminopropionaldehyde\",\n      \"inputs\": [\"mol_010\", \"mol_006\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals\", \"TiO2\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"UV photoredox with H2S reductant; Cu/Zn-mediated cyanosulfidic conditions\",\n        \"aqueous\": \"true\",\n        \"other\": \"acidic photoreduction stage; stepwise addition chemistry\"\n      },\n      \"mechanism\": \"Cyanosulfidic photoreduction converts the nitrile-containing precursor into the corresponding aldehyde under H2S-driven UV chemistry.\",\n      \"reasoning\": \"The report states that beta-aminopropionitrile is reduced under UV/H2S conditions to beta-aminopropionaldehyde in the Patel sequence before cyanamide capture. This is a key documented step in the only detailed prebiotic Arg route (Patel et al., 2015, refs. [3], [4], [8]).\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Cyanamide capture to cyclic guanidinium hemiaminal\",\n      \"inputs\": [\"mol_011\", \"mol_008\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"sulfide minerals\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"cyanamide reagent capture on concentrated mineral surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"rapid addition under cyanosulfidic stepwise conditions\"\n      },\n      \"mechanism\": \"The aldehyde rapidly condenses with cyanamide to generate a guanidinium-bearing cyclic hemiaminal, installing the crucial guanidino functionality.\",\n      \"reasoning\": \"The literature explicitly highlights cyanamide as the guanidinylating reagent and identifies the cyclic guanidinium hemiaminal as a key intermediate after reduction of beta-aminopropionitrile. This step addresses the central challenge of guanidinium installation (Patel et al., 2015; Pol et al., 2022 on the rarity of convincing Arg routes).\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"Kiliani-Fischer homologation and sulfur incorporation to gamma-butyrothiolactam\",\n      \"inputs\": [\"mol_012\", \"mol_004\", \"mol_006\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals\", \"TiO2\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"UV/H2S photoredox with HCN addition\",\n        \"aqueous\": \"true\",\n        \"other\": \"stepwise HCN homologation; alpha-hydroxythioamide intermediate collapses to thiolactam\"\n      },\n      \"mechanism\": \"HCN homologation followed by photoreductive sulfur chemistry generates an alpha-hydroxythioamide that cyclizes to gamma-butyrothiolactam.\",\n      \"reasoning\": \"This directly follows the Patel scheme, where the guanidinium hemiaminal undergoes HCN addition and photoreduction to alpha-hydroxythioamide and then cyclizes into gamma-butyrothiolactam. It is one of the defining middle-stage transformations in the proposed Arg synthesis (Patel et al., 2015, refs. [3], [4], [8]).\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"Final photoreductive homologation to arginine alpha-aminonitrile\",\n      \"inputs\": [\"mol_013\", \"mol_004\", \"mol_006\", \"mol_003\"],\n      \"outputs\": [\"mol_014\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals\", \"TiO2\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"UV/H2S photoredox under Cu/Zn cyanosulfidic conditions\",\n        \"aqueous\": \"true\",\n        \"other\": \"further reduction and HCN addition; stepwise reagent pulses; reported later homologations described as good to excellent\"\n      },\n      \"mechanism\": \"The thiolactam intermediate is further reduced and homologated with HCN to furnish the alpha-aminonitrile precursor to arginine (compound 46).\",\n      \"reasoning\": \"The research report states that further reduction and HCN addition ultimately produce compound 46, the alpha-aminonitrile precursor to arginine. This is the late, literature-supported endpoint of the Patel route before hydrolysis (Patel et al., 2015, refs. [3], [4], [8]).\"\n    },\n    {\n      \"id\": \"rxn_011\",\n      \"name\": \"Alkaline hydrolysis of arginine alpha-aminonitrile to arginine\",\n      \"inputs\": [\"mol_014\"],\n      \"outputs\": [\"mol_015\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"null\",\n        \"aqueous\": \"true\",\n        \"other\": \"simple alkaline hydrolysis in ammonia-rich pond or pool\"\n      },\n      \"mechanism\": \"Nitrile hydrolysis converts the alpha-aminonitrile into the alpha-amino acid arginine.\",\n      \"reasoning\": \"The report explicitly states that simple alkaline hydrolysis of compound 46 would give arginine. This final transformation is mechanistically standard for Strecker-like aminonitrile to amino acid conversion, though the report also notes hydrolysis kinetics may be a bottleneck for accumulation (Patel et al., 2015; Pol et al., 2022).\"\n    },\n    {\n      \"id\": \"rxn_012\",\n      \"name\": \"Speculative hydrothermal reductive amination to glutamate\",\n      \"inputs\": [\"mol_001\", \"mol_002\", \"mol_003\"],\n      \"outputs\": [\"mol_016\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite\", \"pyrite\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"Fe-S mineral surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"acidic to moderate pH reducing vent chemistry; included as metabolic-analog connector\"\n      },\n      \"mechanism\": \"Fe-S-mediated reductive carbon fixation and amination furnish a C5 amino dicarboxylate analogue represented here as glutamate.\",\n      \"reasoning\": \"This reaction is explicitly speculative. The supplied literature allows that glutamate may have been available in prebiotic ponds and that FeS/NiS surfaces can reductively aminate keto acids, but no direct prebiotic arginine route through glutamate has been demonstrated. Included only because Glavin et al. (2025) discuss glutamate as a conceivable feeder into Orn/Cit chemistry and Huber & Wachtershauser-type Fe-S amination supports general amino acid formation, not Arg specifically (Glavin et al., 2025; Huber & Wachtershauser, 1997 as summarized in ref. [9]).\"\n    },\n    {\n      \"id\": \"rxn_013\",\n      \"name\": \"Speculative transamination/decarboxylative conversion of glutamate to ornithine\",\n      \"inputs\": [\"mol_016\", \"mol_003\"],\n      \"outputs\": [\"mol_017\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"null\",\n        \"aqueous\": \"true\",\n        \"other\": \"prebiotic pool; metabolism-analog branch\"\n      },\n      \"mechanism\": \"A metabolism-inspired sequence of transamination/reduction is used as an abstracted conversion from glutamate to ornithine.\",\n      \"reasoning\": \"Explicitly speculative and included only because the literature mentions ornithine/citrulline as hypothesized intermediates by analogy to biology. No direct laboratory model for prebiotic Glu\u2192Orn conversion was provided in the report (Glavin et al., 2025; Pol et al., 2022).\"\n    },\n    {\n      \"id\": \"rxn_014\",\n      \"name\": \"Surface generation of cyanate-like carbamoyl donor from cyanamide reservoir\",\n      \"inputs\": [\"mol_008\"],\n      \"outputs\": [\"mol_018\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"phosphate minerals\", \"TiO2\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"phosphate minerals\",\n        \"aqueous\": \"true\",\n        \"other\": \"UV-exposed shallow pool; included as carbamoyl-donor connector\"\n      },\n      \"mechanism\": \"Cyanamide-rich nitrogen chemistry generates cyanate/isocyanate-like carbamoyl donors under surface photochemical conditions.\",\n      \"reasoning\": \"This step is speculative but grounded in the report's statement that cyanate or cyanamide could act as carbamoyl/guanidinyl donors in hypothetical ornithine-to-citrulline chemistry. Added only to connect the literature-mentioned metabolism-analog branch (Glavin et al., 2025; Pol et al., 2022).\"\n    },\n    {\n      \"id\": \"rxn_015\",\n      \"name\": \"Speculative carbamoylation of ornithine to citrulline\",\n      \"inputs\": [\"mol_017\", \"mol_018\"],\n      \"outputs\": [\"mol_019\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"null\",\n        \"aqueous\": \"true\",\n        \"other\": \"ammonia-rich pond chemistry; undemonstrated prebiotic step\"\n      },\n      \"mechanism\": \"Ornithine captures a carbamoyl equivalent to form citrulline.\",\n      \"reasoning\": \"The report explicitly notes that prebiotic carbamoylation of ornithine using cyanate/cyanamide is a possible but unproven route. This reaction is therefore marked speculative and is not treated as evidence-equivalent to the Patel sequence (Glavin et al., 2025; Pol et al., 2022).\"\n    },\n    {\n      \"id\": \"rxn_016\",\n      \"name\": \"Speculative guanidinylation of citrulline to arginine\",\n      \"inputs\": [\"mol_019\", \"mol_003\", \"mol_008\"],\n      \"outputs\": [\"mol_015\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"null\",\n        \"aqueous\": \"true\",\n        \"other\": \"concentrated prebiotic pool; undemonstrated final guanidinium maturation\"\n      },\n      \"mechanism\": \"A speculative ammonia/cyanamide-assisted guanidinylation completes conversion of citrulline-like precursor to arginine.\",\n      \"reasoning\": \"This is explicitly speculative. The literature mentions that ornithine/citrulline could conceivably feed to arginine if prebiotic carbamoylation/guanidinylation existed, but no direct laboratory demonstration is known. Included only to represent the literature-mentioned open question branch while clearly distinguishing it from the Patel pathway (Glavin et al., 2025; Pol et al., 2022).\"\n    }\n  ],\n  \"pathways\": [\n    {\n      \"pathway_id\": \"P1\",\n      \"name\": \"Canonical Patel cyanosulfidic route\",\n      \"description\": \"Direct literature-supported surface synthesis from HCN, acetylene, NH3, H2S, and cyanamide through acrylonitrile, beta-aminopropionitrile, guanidinium hemiaminal, thiolactam, and compound 46 to arginine.\",\n      \"reaction_sequence\": [\"rxn_005\", \"rxn_006\", \"rxn_007\", \"rxn_008\", \"rxn_009\", \"rxn_010\", \"rxn_011\"],\n      \"key_intermediates\": [\"mol_009\", \"mol_010\", \"mol_012\", \"mol_013\", \"mol_014\"]\n    },\n    {\n      \"pathway_id\": \"P2\",\n      \"name\": \"Hydrothermal sulfur-fed Patel route\",\n      \"description\": \"Same Patel route but explicitly supplied by hydrothermal H2S exported to UV surface pools.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_005\", \"rxn_006\", \"rxn_007\", \"rxn_008\", \"rxn_009\", \"rxn_010\", \"rxn_011\"],\n      \"key_intermediates\": [\"mol_006\", \"mol_009\", \"mol_010\", \"mol_014\"]\n    },\n    {\n      \"pathway_id\": \"P3\",\n      \"name\": \"Hydrothermal ammonia-fed Patel route\",\n      \"description\": \"Patel route with explicit hydrothermal provisioning of ammonia to surface nitrile chemistry.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_005\", \"rxn_006\", \"rxn_007\", \"rxn_008\", \"rxn_009\", \"rxn_010\", \"rxn_011\"],\n      \"key_intermediates\": [\"mol_003\", \"mol_009\", \"mol_010\", \"mol_014\"]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"Dual hydrothermal feed Patel route\",\n      \"description\": \"Hydrothermal sulfur and ammonia jointly feed the surface cyanosulfidic sequence to arginine.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_005\", \"rxn_006\", \"rxn_007\", \"rxn_008\", \"rxn_009\", \"rxn_010\", \"rxn_011\"],\n      \"key_intermediates\": [\"mol_003\", \"mol_006\", \"mol_010\", \"mol_014\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"Formamide-derived cyanamide entry route\",\n      \"description\": \"HCN is first routed through formamide to cyanamide before joining the Patel sequence at the guanidinium-installation stage.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_004\", \"rxn_005\", \"rxn_006\", \"rxn_007\", \"rxn_008\", \"rxn_009\", \"rxn_010\", \"rxn_011\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_008\", \"mol_010\", \"mol_014\"]\n    },\n    {\n      \"pathway_id\": \"P6\",\n      \"name\": \"Acrylonitrile-centered route with late cyanamide generation\",\n      \"description\": \"Acrylonitrile and beta-aminopropionitrile are formed first, while cyanamide is generated in parallel from surface nitrogen chemistry before guanidinium capture.\",\n      \"reaction_sequence\": [\"rxn_005\", \"rxn_006\", \"rxn_003\", \"rxn_004\", \"rxn_007\", \"rxn_008\", \"rxn_009\", \"rxn_010\", \"rxn_011\"],\n      \"key_intermediates\": [\"mol_009\", \"mol_010\", \"mol_008\", \"mol_014\"]\n    },\n    {\n      \"pathway_id\": \"P7\",\n      \"name\": \"Hydrothermal-to-formamide-to-Patel hybrid\",\n      \"description\": \"Hydrothermal ammonia and sulfur provision a surface network in which HCN is partially buffered through formamide/cyanamide before full Patel homologation.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_003\", \"rxn_004\", \"rxn_005\", \"rxn_006\", \"rxn_007\", \"rxn_008\", \"rxn_009\", \"rxn_010\", \"rxn_011\"],\n      \"key_intermediates\": [\"mol_003\", \"mol_006\", \"mol_007\", \"mol_008\", \"mol_014\"]\n    },\n    {\n      \"pathway_id\": \"P8\",\n      \"name\": \"Speculative glutamate-ornithine-citrulline route\",\n      \"description\": \"A literature-acknowledged but undemonstrated metabolism-analog branch in which glutamate feeds ornithine and citrulline before arginine formation.\",\n      \"reaction_sequence\": [\"rxn_012\", \"rxn_013\", \"rxn_014\", \"rxn_015\", \"rxn_016\"],\n      \"key_intermediates\": [\"mol_016\", \"mol_017\", \"mol_018\", \"mol_019\"]\n    },\n    {\n      \"pathway_id\": \"P9\",\n      \"name\": \"Hybrid Orn/Cit route supplied by Patel cyanamide chemistry\",\n      \"description\": \"Speculative ornithine/citrulline path using cyanamide generated in the surface nitrogen network as the carbamoyl/guanidinyl donor.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_004\", \"rxn_012\", \"rxn_013\", \"rxn_015\", \"rxn_016\"],\n      \"key_intermediates\": [\"mol_008\", \"mol_016\", \"mol_017\", \"mol_019\"]\n    },\n    {\n      \"pathway_id\": \"P10\",\n      \"name\": \"Full connected network traversal to arginine\",\n      \"description\": \"Longest integrated traversal showing hydrothermal feedstock generation, surface cyanamide reservoir formation, canonical Patel homologation, and final arginine release.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_003\", \"rxn_004\", \"rxn_005\", \"rxn_006\", \"rxn_007\", \"rxn_008\", \"rxn_009\", \"rxn_010\", \"rxn_011\"],\n      \"key_intermediates\": [\"mol_003\", \"mol_006\", \"mol_008\", \"mol_009\", \"mol_010\", \"mol_014\"]\n    }\n  ],\n  \"hub_molecules\": [\"mol_003\", \"mol_004\", \"mol_006\", \"mol_008\", \"mol_010\", \"mol_014\", \"mol_017\"],\n  \"convergence_points\": [\n    {\n      \"molecule_id\": \"mol_008\",\n      \"incoming_reactions\": [\"rxn_004\"],\n      \"outgoing_reactions\": [\"rxn_008\", \"rxn_014\", \"rxn_016\"]\n    },\n    {\n      \"molecule_id\": \"mol_010\",\n      \"incoming_reactions\": [\"rxn_006\"],\n      \"outgoing_reactions\": [\"rxn_007\"]\n    },\n    {\n      \"molecule_id\": \"mol_014\",\n      \"incoming_reactions\": [\"rxn_010\"],\n      \"outgoing_reactions\": [\"rxn_011\"]\n    },\n    {\n      \"molecule_id\": \"mol_017\",\n      \"incoming_reactions\": [\"rxn_013\"],\n      \"outgoing_reactions\": [\"rxn_015\"]\n    },\n    {\n      \"molecule_id\": \"mol_003\",\n      \"incoming_reactions\": [\"rxn_001\"],\n      \"outgoing_reactions\": [\"rxn_006\", \"rxn_010\", \"rxn_012\", \"rxn_016\"]\n    },\n    {\n      \"molecule_id\": \"mol_006\",\n      \"incoming_reactions\": [\"rxn_002\"],\n      \"outgoing_reactions\": [\"rxn_005\", \"rxn_007\", \"rxn_009\", \"rxn_010\"]\n    },\n    {\n      \"molecule_id\": \"mol_004\",\n      \"incoming_reactions\": [],\n      \"outgoing_reactions\": [\"rxn_003\", \"rxn_005\", \"rxn_009\", \"rxn_010\"]\n    }\n  ]\n}", "parsed_response": {"target_molecule": "Arginine", "overall_strategy": "This network is centered on the only detailed literature-supported prebiotic route to arginine: the cyanosulfidic homologation sequence of Patel et al. (2015), in which HCN, acetylene, NH3, cyanamide, H2S, UV light, and Cu/Zn-mediated chemistry generate acrylonitrile, beta-aminopropionitrile, guanidinium-bearing intermediates, thiolactam intermediates, and finally an arginine alpha-aminonitrile that hydrolyzes to arginine. Hydrothermal chemistry is used conservatively and only for literature-consistent provisioning of simple reduced feedstocks and ammonia-rich, Fe-S-catalyzed chemistry that plausibly supplies carbon/nitrogen inputs to surface cyanosulfidic pools; the arginine-forming chemistry itself follows the Patel route. Ten distinct pathways are represented as alternative traversals through the same connected bipartite graph, differing in how hydrothermal feedstocks are routed into the surface sequence and in whether the late-stage arginine precursor is reached through the full homologation branch or via literature-acknowledged but explicitly speculative metabolism-analog branches through ornithine/citrulline. Speculative steps are clearly labeled as such in reaction reasoning, consistent with the literature stating that no convincing non-Patel route is yet demonstrated.", "molecules": [{"id": "mol_001", "formula": "CO2", "iupac_name": "carbon dioxide", "common_name": "carbon dioxide", "inchi": "InChI=1S/CO2/c2-1-3", "role": "starting", "environment_formed": null}, {"id": "mol_002", "formula": "H2", "iupac_name": "molecular hydrogen", "common_name": "hydrogen", "inchi": "InChI=1S/H2/h1H", "role": "starting", "environment_formed": null}, {"id": "mol_003", "formula": "NH3", "iupac_name": "azane", "common_name": "ammonia", "inchi": "InChI=1S/H3N/h1H3", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_004", "formula": "HCN", "iupac_name": "hydrogen cyanide", "common_name": "hydrogen cyanide", "inchi": "InChI=1S/CHN/c1-2/h1H", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_005", "formula": "C2H2", "iupac_name": "ethyne", "common_name": "acetylene", "inchi": "InChI=1S/C2H2/c1-2/h1-2H", "role": "starting", "environment_formed": null}, {"id": "mol_006", "formula": "H2S", "iupac_name": "sulfane", "common_name": "hydrogen sulfide", "inchi": "InChI=1S/H2S/h1H2", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_007", "formula": "CHNO", "iupac_name": "methanamide", "common_name": "formamide", "inchi": "InChI=1S/CH3NO/c2-1-3/h1H,(H2,2,3)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_008", "formula": "CH2N2", "iupac_name": "cyanamide", "common_name": "cyanamide", "inchi": "InChI=1S/CH2N2/c2-1-3/h(H2,2,3)", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_009", "formula": "C3H3N", "iupac_name": "prop-2-enenitrile", "common_name": "acrylonitrile", "inchi": "InChI=1S/C3H3N/c1-2-3-4/h2H,1H2", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_010", "formula": "C3H6N2", "iupac_name": "3-aminopropanenitrile", "common_name": "beta-aminopropionitrile", "inchi": "InChI=1S/C3H6N2/c4-2-1-3-5/h1-2,4H2", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_011", "formula": "C3H7NO", "iupac_name": "3-aminopropanal", "common_name": "beta-aminopropionaldehyde", "inchi": "InChI=1S/C3H7NO/c4-2-1-3-5/h3H,1-2,4H2", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_012", "formula": "C4H8N4O", "iupac_name": "guanidinium hemiaminal intermediate", "common_name": "cyclic guanidinium hemiaminal", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_013", "formula": "C5H8N4OS", "iupac_name": "gamma-butyrothiolactam intermediate", "common_name": "gamma-butyrothiolactam", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_014", "formula": "C6H11N5", "iupac_name": "arginine alpha-aminonitrile", "common_name": "Patel compound 46", "inchi": null, "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_015", "formula": "C6H14N4O2", "iupac_name": "(2S)-2-amino-5-guanidinopentanoic acid", "common_name": "arginine", "inchi": "InChI=1S/C6H14N4O2/c7-4(5(11)12)2-1-3-10-6(8)9/h4H,1-3,7H2,(H,11,12)(H4,8,9,10)", "role": "target", "environment_formed": "Biochemical"}, {"id": "mol_016", "formula": "C5H9NO4", "iupac_name": "2-aminopentanedioic acid", "common_name": "glutamic acid", "inchi": "InChI=1S/C5H9NO4/c6-3(5(9)10)1-2-4(7)8/h3H,1-2,6H2,(H,7,8)(H,9,10)", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_017", "formula": "C5H12N2O2", "iupac_name": "2,5-diaminopentanoic acid", "common_name": "ornithine", "inchi": "InChI=1S/C5H12N2O2/c6-3-1-2-4(7)5(8)9/h4H,1-3,6-7H2,(H,8,9)", "role": "hub_intermediate", "environment_formed": "Biochemical"}, {"id": "mol_018", "formula": "CHNO", "iupac_name": "isocyanic acid", "common_name": "cyanate", "inchi": "InChI=1S/CHNO/c2-1-3/h(H,2,3)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_019", "formula": "C6H13N3O3", "iupac_name": "2-amino-5-(carbamimidamido)pentanoic acid precursor analogue", "common_name": "citrulline", "inchi": "InChI=1S/C6H13N3O3/c7-4(5(10)11)2-1-3-9-6(8)12/h4H,1-3,7H2,(H2,8,12)(H,10,11)", "role": "intermediate", "environment_formed": "Biochemical"}], "reactions": [{"id": "rxn_001", "name": "Hydrothermal NH3 provisioning in Fe-S alkaline vent setting", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_003"], "environment": "Hydrothermal", "agents": ["mackinawite", "greigite"], "conditions": {"temperature": "350-450K", "pressure": "high", "catalyst": "mackinawite/greigite", "aqueous": "true", "other": "alkaline hydrothermal vent; reducing, anoxic, NH3-rich vent fluids invoked as environmental feedstock source rather than direct stoichiometric laboratory synthesis"}, "mechanism": "Vent-associated Fe-S mineral catalysis and water-rock redox chemistry generate reducing conditions compatible with ammonia-bearing hydrothermal fluids feeding surface environments.", "reasoning": "Used conservatively as an environmental feedstock-provisioning step because the supplied literature emphasizes ammonia-rich hydrothermal settings rather than a specific Arg-forming vent reaction. Hydrothermal vents provide H2, NH3 and FeS/NiS catalysis for general reductive chemistry, but no direct arginine synthesis is known (Huber & Wachtershauser, 1997 as summarized in ref. [9]; Glavin et al., 2025; Pol et al., 2022). This step is therefore a network connector, not a claim of demonstrated arginine synthesis."}, {"id": "rxn_002", "name": "Hydrothermal H2S provisioning in serpentinizing Fe-S systems", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_006"], "environment": "Hydrothermal", "agents": ["pyrite", "elemental iron"], "conditions": {"temperature": "370-470K", "pressure": "high", "catalyst": "pyrite/Fe0", "aqueous": "true", "other": "subseafloor hydrothermal, anoxic, reduced sulfur-bearing fluids"}, "mechanism": "Fe-S mineral buffering in hydrothermal systems supplies reduced sulfur species to later surface photoredox chemistry.", "reasoning": "The deep research report identifies H2S as the key reductant in the Patel cyanosulfidic network and highlights hydrothermal and sulfur-rich settings as plausible suppliers of reduced sulfur. This is included as a feedstock-transfer step linking hydrothermal sulfur chemistry to surface UV-driven homologation, not as a specific Arg-forming experiment (Patel et al., 2015; Glavin et al., 2025)."}, {"id": "rxn_003", "name": "Surface UV hydrolysis of HCN to formamide", "inputs": ["mol_004"], "outputs": ["mol_007"], "environment": "Surface", "agents": ["TiO2", "montmorillonite"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "TiO2", "aqueous": "true", "other": "UV-irradiated shallow pool, anoxic"}, "mechanism": "HCN in aqueous UV-exposed surface settings is converted through hydrolysis/photochemical routes to formamide, which can serve as a precursor reservoir for cyanamide-rich nitrogen chemistry.", "reasoning": "The report notes UV photochemistry of HCN to formamide and identifies HCN-rich surface settings as central to prebiotic nitrogen chemistry, though this step is not Arg-specific. Included to connect nitrogen feedstock transformations relevant to cyanamide emergence in cyanosulfidic settings (Miller, 1986 review in ref. [1]; Patel et al., 2015)."}, {"id": "rxn_004", "name": "Surface dehydration of formamide to cyanamide", "inputs": ["mol_007"], "outputs": ["mol_008"], "environment": "Surface", "agents": ["phosphate minerals", "TiO2"], "conditions": {"temperature": "320-370K", "pressure": "1 atm", "catalyst": "phosphate minerals", "aqueous": "false", "other": "wet-dry cycling in evaporitic pool; UV-exposed"}, "mechanism": "Dry-down and mineral-assisted dehydration convert amide-like nitrogen reservoirs into cyanamide, a guanidinylating agent needed for the Patel sequence.", "reasoning": "Cyanamide is explicitly identified in the literature as a key guanidinylating reagent in the Patel route. Its exact geochemical sourcing is less firmly demonstrated than its use, so this connector is moderately speculative but consistent with the report's emphasis on wet-dry and photochemical cyanamide-rich surface settings (Patel et al., 2015; Miller, 1986 review)."}, {"id": "rxn_005", "name": "Cu-photoredox cyanosulfidic coupling of HCN and acetylene to acrylonitrile", "inputs": ["mol_004", "mol_005", "mol_006"], "outputs": ["mol_009"], "environment": "Surface", "agents": ["sulfide minerals", "TiO2"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "Cu(I)/Cu(II) photoredox with Zn2+; sulfide mineral-rich UV-irradiated aqueous setting", "aqueous": "true", "other": "UV around 300 nm; H2S reductant; stepwise reagent addition; reported yield up to >25%"}, "mechanism": "Photoredox activation of cyanide/acetylene in sulfide-rich water forms the three-carbon nitrile acrylonitrile.", "reasoning": "This is the core literature-supported entry to the arginine network. Patel et al. showed that HCN and acetylene under UV with Cu photoredox chemistry and H2S reductant produce acrylonitrile in significant yield, providing the backbone precursor for arginine homologation (Patel et al., 2015, refs. [3], [4], [6], [8])."}, {"id": "rxn_006", "name": "Ammonia addition to acrylonitrile forming beta-aminopropionitrile", "inputs": ["mol_009", "mol_003"], "outputs": ["mol_010"], "environment": "Surface", "agents": ["montmorillonite", "sulfide minerals"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "none required in solution; mineral surfaces used for concentration", "aqueous": "true", "other": "neutral to slightly basic aqueous conditions; ammonia addition step in Patel sequence"}, "mechanism": "Nucleophilic conjugate addition of ammonia to the activated nitrile alkene yields beta-aminopropionitrile.", "reasoning": "Beta-aminopropionitrile is explicitly identified as a central Patel intermediate arising from acrylonitrile plus ammonia. Mineral phases are included here for concentration, satisfying the surface-agent requirement, especially because clays can concentrate cationic/basic products and intermediates (Patel et al., 2015; Frenkel-Pinter et al., 2024/2025-like adsorption study summarized as ref. [11])."}, {"id": "rxn_007", "name": "UV/H2S photoreduction of beta-aminopropionitrile to beta-aminopropionaldehyde", "inputs": ["mol_010", "mol_006"], "outputs": ["mol_011"], "environment": "Surface", "agents": ["sulfide minerals", "TiO2"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "UV photoredox with H2S reductant; Cu/Zn-mediated cyanosulfidic conditions", "aqueous": "true", "other": "acidic photoreduction stage; stepwise addition chemistry"}, "mechanism": "Cyanosulfidic photoreduction converts the nitrile-containing precursor into the corresponding aldehyde under H2S-driven UV chemistry.", "reasoning": "The report states that beta-aminopropionitrile is reduced under UV/H2S conditions to beta-aminopropionaldehyde in the Patel sequence before cyanamide capture. This is a key documented step in the only detailed prebiotic Arg route (Patel et al., 2015, refs. [3], [4], [8])."}, {"id": "rxn_008", "name": "Cyanamide capture to cyclic guanidinium hemiaminal", "inputs": ["mol_011", "mol_008"], "outputs": ["mol_012"], "environment": "Surface", "agents": ["montmorillonite", "sulfide minerals"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "cyanamide reagent capture on concentrated mineral surfaces", "aqueous": "true", "other": "rapid addition under cyanosulfidic stepwise conditions"}, "mechanism": "The aldehyde rapidly condenses with cyanamide to generate a guanidinium-bearing cyclic hemiaminal, installing the crucial guanidino functionality.", "reasoning": "The literature explicitly highlights cyanamide as the guanidinylating reagent and identifies the cyclic guanidinium hemiaminal as a key intermediate after reduction of beta-aminopropionitrile. This step addresses the central challenge of guanidinium installation (Patel et al., 2015; Pol et al., 2022 on the rarity of convincing Arg routes)."}, {"id": "rxn_009", "name": "Kiliani-Fischer homologation and sulfur incorporation to gamma-butyrothiolactam", "inputs": ["mol_012", "mol_004", "mol_006"], "outputs": ["mol_013"], "environment": "Surface", "agents": ["sulfide minerals", "TiO2"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "UV/H2S photoredox with HCN addition", "aqueous": "true", "other": "stepwise HCN homologation; alpha-hydroxythioamide intermediate collapses to thiolactam"}, "mechanism": "HCN homologation followed by photoreductive sulfur chemistry generates an alpha-hydroxythioamide that cyclizes to gamma-butyrothiolactam.", "reasoning": "This directly follows the Patel scheme, where the guanidinium hemiaminal undergoes HCN addition and photoreduction to alpha-hydroxythioamide and then cyclizes into gamma-butyrothiolactam. It is one of the defining middle-stage transformations in the proposed Arg synthesis (Patel et al., 2015, refs. [3], [4], [8])."}, {"id": "rxn_010", "name": "Final photoreductive homologation to arginine alpha-aminonitrile", "inputs": ["mol_013", "mol_004", "mol_006", "mol_003"], "outputs": ["mol_014"], "environment": "Surface", "agents": ["sulfide minerals", "TiO2"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "UV/H2S photoredox under Cu/Zn cyanosulfidic conditions", "aqueous": "true", "other": "further reduction and HCN addition; stepwise reagent pulses; reported later homologations described as good to excellent"}, "mechanism": "The thiolactam intermediate is further reduced and homologated with HCN to furnish the alpha-aminonitrile precursor to arginine (compound 46).", "reasoning": "The research report states that further reduction and HCN addition ultimately produce compound 46, the alpha-aminonitrile precursor to arginine. This is the late, literature-supported endpoint of the Patel route before hydrolysis (Patel et al., 2015, refs. [3], [4], [8])."}, {"id": "rxn_011", "name": "Alkaline hydrolysis of arginine alpha-aminonitrile to arginine", "inputs": ["mol_014"], "outputs": ["mol_015"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "null", "aqueous": "true", "other": "simple alkaline hydrolysis in ammonia-rich pond or pool"}, "mechanism": "Nitrile hydrolysis converts the alpha-aminonitrile into the alpha-amino acid arginine.", "reasoning": "The report explicitly states that simple alkaline hydrolysis of compound 46 would give arginine. This final transformation is mechanistically standard for Strecker-like aminonitrile to amino acid conversion, though the report also notes hydrolysis kinetics may be a bottleneck for accumulation (Patel et al., 2015; Pol et al., 2022)."}, {"id": "rxn_012", "name": "Speculative hydrothermal reductive amination to glutamate", "inputs": ["mol_001", "mol_002", "mol_003"], "outputs": ["mol_016"], "environment": "Hydrothermal", "agents": ["greigite", "pyrite"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "Fe-S mineral surfaces", "aqueous": "true", "other": "acidic to moderate pH reducing vent chemistry; included as metabolic-analog connector"}, "mechanism": "Fe-S-mediated reductive carbon fixation and amination furnish a C5 amino dicarboxylate analogue represented here as glutamate.", "reasoning": "This reaction is explicitly speculative. The supplied literature allows that glutamate may have been available in prebiotic ponds and that FeS/NiS surfaces can reductively aminate keto acids, but no direct prebiotic arginine route through glutamate has been demonstrated. Included only because Glavin et al. (2025) discuss glutamate as a conceivable feeder into Orn/Cit chemistry and Huber & Wachtershauser-type Fe-S amination supports general amino acid formation, not Arg specifically (Glavin et al., 2025; Huber & Wachtershauser, 1997 as summarized in ref. [9])."}, {"id": "rxn_013", "name": "Speculative transamination/decarboxylative conversion of glutamate to ornithine", "inputs": ["mol_016", "mol_003"], "outputs": ["mol_017"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "null", "aqueous": "true", "other": "prebiotic pool; metabolism-analog branch"}, "mechanism": "A metabolism-inspired sequence of transamination/reduction is used as an abstracted conversion from glutamate to ornithine.", "reasoning": "Explicitly speculative and included only because the literature mentions ornithine/citrulline as hypothesized intermediates by analogy to biology. No direct laboratory model for prebiotic Glu\u2192Orn conversion was provided in the report (Glavin et al., 2025; Pol et al., 2022)."}, {"id": "rxn_014", "name": "Surface generation of cyanate-like carbamoyl donor from cyanamide reservoir", "inputs": ["mol_008"], "outputs": ["mol_018"], "environment": "Surface", "agents": ["phosphate minerals", "TiO2"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "phosphate minerals", "aqueous": "true", "other": "UV-exposed shallow pool; included as carbamoyl-donor connector"}, "mechanism": "Cyanamide-rich nitrogen chemistry generates cyanate/isocyanate-like carbamoyl donors under surface photochemical conditions.", "reasoning": "This step is speculative but grounded in the report's statement that cyanate or cyanamide could act as carbamoyl/guanidinyl donors in hypothetical ornithine-to-citrulline chemistry. Added only to connect the literature-mentioned metabolism-analog branch (Glavin et al., 2025; Pol et al., 2022)."}, {"id": "rxn_015", "name": "Speculative carbamoylation of ornithine to citrulline", "inputs": ["mol_017", "mol_018"], "outputs": ["mol_019"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "null", "aqueous": "true", "other": "ammonia-rich pond chemistry; undemonstrated prebiotic step"}, "mechanism": "Ornithine captures a carbamoyl equivalent to form citrulline.", "reasoning": "The report explicitly notes that prebiotic carbamoylation of ornithine using cyanate/cyanamide is a possible but unproven route. This reaction is therefore marked speculative and is not treated as evidence-equivalent to the Patel sequence (Glavin et al., 2025; Pol et al., 2022)."}, {"id": "rxn_016", "name": "Speculative guanidinylation of citrulline to arginine", "inputs": ["mol_019", "mol_003", "mol_008"], "outputs": ["mol_015"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "null", "aqueous": "true", "other": "concentrated prebiotic pool; undemonstrated final guanidinium maturation"}, "mechanism": "A speculative ammonia/cyanamide-assisted guanidinylation completes conversion of citrulline-like precursor to arginine.", "reasoning": "This is explicitly speculative. The literature mentions that ornithine/citrulline could conceivably feed to arginine if prebiotic carbamoylation/guanidinylation existed, but no direct laboratory demonstration is known. Included only to represent the literature-mentioned open question branch while clearly distinguishing it from the Patel pathway (Glavin et al., 2025; Pol et al., 2022)."}], "pathways": [{"pathway_id": "P1", "name": "Canonical Patel cyanosulfidic route", "description": "Direct literature-supported surface synthesis from HCN, acetylene, NH3, H2S, and cyanamide through acrylonitrile, beta-aminopropionitrile, guanidinium hemiaminal, thiolactam, and compound 46 to arginine.", "reaction_sequence": ["rxn_005", "rxn_006", "rxn_007", "rxn_008", "rxn_009", "rxn_010", "rxn_011"], "key_intermediates": ["mol_009", "mol_010", "mol_012", "mol_013", "mol_014"]}, {"pathway_id": "P2", "name": "Hydrothermal sulfur-fed Patel route", "description": "Same Patel route but explicitly supplied by hydrothermal H2S exported to UV surface pools.", "reaction_sequence": ["rxn_002", "rxn_005", "rxn_006", "rxn_007", "rxn_008", "rxn_009", "rxn_010", "rxn_011"], "key_intermediates": ["mol_006", "mol_009", "mol_010", "mol_014"]}, {"pathway_id": "P3", "name": "Hydrothermal ammonia-fed Patel route", "description": "Patel route with explicit hydrothermal provisioning of ammonia to surface nitrile chemistry.", "reaction_sequence": ["rxn_001", "rxn_005", "rxn_006", "rxn_007", "rxn_008", "rxn_009", "rxn_010", "rxn_011"], "key_intermediates": ["mol_003", "mol_009", "mol_010", "mol_014"]}, {"pathway_id": "P4", "name": "Dual hydrothermal feed Patel route", "description": "Hydrothermal sulfur and ammonia jointly feed the surface cyanosulfidic sequence to arginine.", "reaction_sequence": ["rxn_001", "rxn_002", "rxn_005", "rxn_006", "rxn_007", "rxn_008", "rxn_009", "rxn_010", "rxn_011"], "key_intermediates": ["mol_003", "mol_006", "mol_010", "mol_014"]}, {"pathway_id": "P5", "name": "Formamide-derived cyanamide entry route", "description": "HCN is first routed through formamide to cyanamide before joining the Patel sequence at the guanidinium-installation stage.", "reaction_sequence": ["rxn_003", "rxn_004", "rxn_005", "rxn_006", "rxn_007", "rxn_008", "rxn_009", "rxn_010", "rxn_011"], "key_intermediates": ["mol_007", "mol_008", "mol_010", "mol_014"]}, {"pathway_id": "P6", "name": "Acrylonitrile-centered route with late cyanamide generation", "description": "Acrylonitrile and beta-aminopropionitrile are formed first, while cyanamide is generated in parallel from surface nitrogen chemistry before guanidinium capture.", "reaction_sequence": ["rxn_005", "rxn_006", "rxn_003", "rxn_004", "rxn_007", "rxn_008", "rxn_009", "rxn_010", "rxn_011"], "key_intermediates": ["mol_009", "mol_010", "mol_008", "mol_014"]}, {"pathway_id": "P7", "name": "Hydrothermal-to-formamide-to-Patel hybrid", "description": "Hydrothermal ammonia and sulfur provision a surface network in which HCN is partially buffered through formamide/cyanamide before full Patel homologation.", "reaction_sequence": ["rxn_001", "rxn_002", "rxn_003", "rxn_004", "rxn_005", "rxn_006", "rxn_007", "rxn_008", "rxn_009", "rxn_010", "rxn_011"], "key_intermediates": ["mol_003", "mol_006", "mol_007", "mol_008", "mol_014"]}, {"pathway_id": "P8", "name": "Speculative glutamate-ornithine-citrulline route", "description": "A literature-acknowledged but undemonstrated metabolism-analog branch in which glutamate feeds ornithine and citrulline before arginine formation.", "reaction_sequence": ["rxn_012", "rxn_013", "rxn_014", "rxn_015", "rxn_016"], "key_intermediates": ["mol_016", "mol_017", "mol_018", "mol_019"]}, {"pathway_id": "P9", "name": "Hybrid Orn/Cit route supplied by Patel cyanamide chemistry", "description": "Speculative ornithine/citrulline path using cyanamide generated in the surface nitrogen network as the carbamoyl/guanidinyl donor.", "reaction_sequence": ["rxn_003", "rxn_004", "rxn_012", "rxn_013", "rxn_015", "rxn_016"], "key_intermediates": ["mol_008", "mol_016", "mol_017", "mol_019"]}, {"pathway_id": "P10", "name": "Full connected network traversal to arginine", "description": "Longest integrated traversal showing hydrothermal feedstock generation, surface cyanamide reservoir formation, canonical Patel homologation, and final arginine release.", "reaction_sequence": ["rxn_001", "rxn_002", "rxn_003", "rxn_004", "rxn_005", "rxn_006", "rxn_007", "rxn_008", "rxn_009", "rxn_010", "rxn_011"], "key_intermediates": ["mol_003", "mol_006", "mol_008", "mol_009", "mol_010", "mol_014"]}], "hub_molecules": ["mol_003", "mol_004", "mol_006"
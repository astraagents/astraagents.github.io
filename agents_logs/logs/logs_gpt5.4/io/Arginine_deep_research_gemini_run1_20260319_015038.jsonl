athway proceeds.", "reaction_sequence": ["rxn_001", "rxn_002", "rxn_003", "rxn_004", "rxn_005", "rxn_006", "rxn_007", "rxn_008", "rxn_009", "rxn_010", "rxn_011"], "key_intermediates": ["mol_007", "mol_008", "mol_009", "mol_012", "mol_018"]}, {"pathway_id": "P5", "name": "Free ornithine to arginine by cyanamide", "description": "Alternative literature-supported emergence route in which the more accessible basic amino acid ornithine is formed in HCN chemistry and subsequently guanidinated by cyanamide to yield arginine directly.", "reaction_sequence": ["rxn_012", "rxn_013"], "key_intermediates": ["mol_019", "mol_010"]}, {"pathway_id": "P6", "name": "Ornithine-containing peptide then post-synthetic arginine", "description": "Hydrothermal alanine and surface ornithine are joined by wet-dry peptide formation; peptide-bound ornithine is then selectively guanidinated by cyanamide and hydrolyzed to release free arginine.", "reaction_sequence": ["rxn_003", "rxn_012", "rxn_015", "rxn_016", "rxn_017"], "key_intermediates": ["mol_009", "mol_019", "mol_022", "mol_023"]}, {"pathway_id": "P7", "name": "Citrulline-branch protometabolic arginine route", "description": "Protometabolic route in which ornithine enters a urea-cycle-like intermediate pool as citrulline before converging on arginine chemistry.", "reaction_sequence": ["rxn_012", "rxn_014", "rxn_013"], "key_intermediates": ["mol_019", "mol_020", "mol_021"]}, {"pathway_id": "P8", "name": "Surface-only cyanosulfidic to aminonitrile with delayed hydrolysis", "description": "A variant emphasizing accumulation of arginine alpha-aminonitrile in surface pools before later biochemical hydrolysis to arginine.", "reaction_sequence": ["rxn_004", "rxn_005", "rxn_006", "rxn_007", "rxn_008", "rxn_009", "rxn_010", "rxn_011"], "key_intermediates": ["mol_014", "mol_015", "mol_016", "mol_018"]}, {"pathway_id": "P9", "name": "Hydrothermal-to-peptide-first-to-arginine route", "description": "A peptide-first variant where hydrothermal alanine e
\"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"Hydrothermal CO2 reduction to formate\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_005\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe3S4)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"greigite and mackinawite\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline vent conditions, anoxic, H2-rich serpentinization setting\"\n      },\n      \"mechanism\": \"Mineral-surface mediated reduction of CO2 by H2 on Fe-S phases to give formate.\",\n      \"reasoning\": \"Vent Fe-S minerals plausibly reduce CO2 to simple C1 organics under alkaline hydrothermal conditions, supplying reduced carbon to downstream prebiotic networks; this is consistent with iron-sulfur world and vent carbon-fixation studies (Huber & Wachtershauser, 1997; Russell & Martin, 2004; Preiner et al., 2020).\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Hydrothermal homologation from formate to acetate\",\n      \"inputs\": [\"mol_005\", \"mol_002\"],\n      \"outputs\": [\"mol_006\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe3S4)\", \"magnetite (Fe3O4)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"greigite and magnetite\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic vent pores with redox and pH gradients\"\n      },\n      \"mechanism\": \"Further reduction and C-C bond formation on Fe-bearing mineral surfaces generates acetate from reduced C1 feedstocks.\",\n      \"reasoning\": \"Acetate formation from reduced carbon species under hydrothermal Fe-mineral catalysis is a core component of vent metabolism-first chemistry and provides a connected reduced-carbon pool feeding later synthesis (Huber & Wachtershauser, 1997; Muchowska et al., 2019; Preiner et al., 2020).\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Hydrothermal pyruvate formation from reduced carbon pool\",\n      \"inputs\": [\"mol_005\", \"mol_006\", \"mol_002\"],\n      \"outputs\": [\"mol_007\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe3O4)\", \"greigite (Fe3S4)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"magnetite and greigite\",\n        \"aqueous\": \"true\",\n        \"other\": \"mild alkaline hydrothermal regime; included conservatively as vent-supported alpha-keto acid generation\"\n      },\n      \"mechanism\": \"Successive reduction and carboxylation/homologation on iron minerals furnishes the alpha-keto acid pyruvate.\",\n      \"reasoning\": \"Pyruvate is reported as plausibly formed in hydrothermal vent simulations and is central to vent protometabolism, though this step is less directly established than the cyanosulfidic arginine route and is therefore used only as a feedstock-connecting node rather than a primary arginine-forming step (Muchowska et al., 2019; Preiner et al., 2020; Varma et al., 2018).\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"Hydrothermal reductive amination of pyruvate to alanine-equivalent ammonia pool\",\n      \"inputs\": [\"mol_007\", \"mol_004\", \"mol_002\"],\n      \"outputs\": [\"mol_004\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"pyrite (FeS2)\", \"greigite (Fe3S4)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"pyrite and greigite\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic vent microcompartments; represented as sustaining shared NH3/amino donor pool rather than introducing a separate alanine node\"\n      },\n      \"mechanism\": \"Mineral-assisted reductive amination chemistry shows that vent-generated keto acids can engage ammonia to generate amino-acid chemistry, reinforcing NH3-linked network connectivity.\",\n      \"reasoning\": \"The report specifically notes pyruvate reductive amination under vent-like conditions; here it is incorporated in a compressed way to connect vent alpha-keto acid chemistry with downstream amination potential without overclaiming unsupported ornithine synthesis (Barge et al., 2019; Muchowska et al., 2020).\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"Hydrothermal sulfide and ammonia supply from vent serpentinization and mineral nitrogen chemistry\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_003\", \"mol_004\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"elemental iron (Fe0)\", \"pyrite (FeS2)\"],\n      \"conditions\": {\n        \"temperature\": \"370-470K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"elemental iron and pyrite\",\n        \"aqueous\": \"true\",\n        \"other\": \"serpentinization-influenced vent fluids; anoxic, reduced iron abundant\"\n      },\n      \"mechanism\": \"Reduced hydrothermal systems furnish sulfide-rich, ammonia-compatible fluids and support mineral-mediated nitrogen reduction chemistry that populates the NH3/H2S pool.\",\n      \"reasoning\": \"The deep research emphasizes serpentinization-generated reducing power, Fe-S mineral catalysis, and the importance of NH3 and H2S in vent-to-surface chemistry; this aggregated sourcing step is used to connect hydrothermal and surface subsystems while staying within the geochemical framework (Russell & Martin, 2004; Martin et al., 2008; Preiner et al., 2020).\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"Surface Cu-photoredox coupling of acetylene and HCN to acrylonitrile\",\n      \"inputs\": [\"mol_009\", \"mol_008\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (molybdenite/stibnite-like)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"Cu(I) photoredox cycling in sulfide-rich, UV-irradiated shallow surface setting\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic, UV-exposed shallow ponds or intertidal alkaline vent margins; mineral agents provide surface localization while Cu(I) is the literature-specific catalytic metal\"\n      },\n      \"mechanism\": \"Cu(I)-mediated C-C cross-coupling between acetylene and HCN forms acrylonitrile, establishing the three-carbon nitrile backbone.\",\n      \"reasoning\": \"The deep research identifies Cu(I)-catalyzed coupling of acetylene and HCN to acrylonitrile as the entry step to the Sutherland arginine pathway; shallow photoredox environments are specifically emphasized (Patel et al., 2015; Xu et al., 2018).\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Surface ammonia addition to acrylonitrile\",\n      \"inputs\": [\"mol_011\", \"mol_004\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\", \"sulfide minerals (molybdenite/stibnite-like)\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral-surface promoted Michael-type ammonia addition\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic aqueous pools with evaporative concentration\"\n      },\n      \"mechanism\": \"Nucleophilic addition of ammonia across the activated nitrile-containing alkene yields beta-aminopropionitrile.\",\n      \"reasoning\": \"Ammonia addition to acrylonitrile to give beta-aminopropionitrile is explicitly described in the literature-supported arginine sequence and provides the immediate substrate for guanidinylation (Patel et al., 2015).\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Surface guanidinylation of beta-aminopropionitrile by cyanamide\",\n      \"inputs\": [\"mol_012\", \"mol_010\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"cyanamide reagent in concentrated aqueous phase on mineral surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"neutral to mildly alkaline, anoxic; reaction known to be incomplete and mixture-forming\"\n      },\n      \"mechanism\": \"The amino group attacks cyanamide, forming a guanidinated nitrile derivative that seeds the arginine side chain.\",\n      \"reasoning\": \"The report states that beta-aminopropionitrile reacts with cyanamide to form a guanidinated derivative, albeit inefficiently, and that this mixed pool is then productively processed by photoredox chemistry (Patel et al., 2015).\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"Surface photoredox trapping to hemiaminal 37\",\n      \"inputs\": [\"mol_013\", \"mol_003\", \"mol_010\"],\n      \"outputs\": [\"mol_014\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (molybdenite/stibnite-like)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"Cu(I)/Cu(II) photoredox with H2S under UV irradiation\",\n        \"aqueous\": \"true\",\n        \"other\": \"oxygen-free, UV-driven; residual cyanamide traps the aldehyde as a stable hemiaminal\"\n      },\n      \"mechanism\": \"Photoreduction in the presence of sulfide generates the corresponding aldehyde level, which is efficiently trapped by cyanamide as the stable hemiaminal 37.\",\n      \"reasoning\": \"The key literature discovery is the extraordinarily efficient formation of a stable hemiaminal from beta-aminopropionaldehyde and residual cyanamide during UV/H2S/Cu photoredox processing; this trapping step is central to selectivity (Patel et al., 2015).\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"Surface dark cyanohydrin formation from hemiaminal 37\",\n      \"inputs\": [\"mol_014\", \"mol_008\"],\n      \"outputs\": [\"mol_015\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"300-320K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral-assisted concentration in dark aqueous phase\",\n        \"aqueous\": \"true\",\n        \"other\": \"dark reaction following photochemical step; anoxic\"\n      },\n      \"mechanism\": \"HCN addition to the trapped aldehydic center gives the homologated cyanohydrin intermediate.\",\n      \"reasoning\": \"The report explicitly states that after hemiaminal formation, a dark reaction with HCN converts the intermediate into a cyanohydrin as part of a Kiliani-Fischer-like homologation sequence (Patel et al., 2015).\"\n    },\n    {\n      \"id\": \"rxn_011\",\n      \"name\": \"Surface sulfidolysis of cyanohydrin to alpha-hydroxythioamide\",\n      \"inputs\": [\"mol_015\", \"mol_003\"],\n      \"outputs\": [\"mol_016\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (molybdenite/stibnite-like)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"H2S-rich sulfide mineral surface chemistry\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic shallow pool chemistry\"\n      },\n      \"mechanism\": \"Sulfide substitutes into the cyanohydrin-derived intermediate to generate an alpha-hydroxythioamide.\",\n      \"reasoning\": \"Sulfidolysis of the cyanohydrin to the alpha-hydroxythioamide is directly described in the cyanosulfidic arginine pathway and depends on H2S-rich conditions (Patel et al., 2015; Xu et al., 2018).\"\n    },\n    {\n      \"id\": \"rxn_012\",\n      \"name\": \"Surface UV deoxygenation of alpha-hydroxythioamide to thioamide\",\n      \"inputs\": [\"mol_016\"],\n      \"outputs\": [\"mol_017\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"sulfide minerals (molybdenite/stibnite-like)\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"UV irradiation with Cu photoredox-compatible mineral setting\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic, strong UV flux\"\n      },\n      \"mechanism\": \"Photochemical deoxygenation removes the alpha-hydroxyl functionality, yielding the thioamide.\",\n      \"reasoning\": \"The deep research explicitly identifies UV irradiation of the alpha-hydroxythioamide as the deoxygenation step producing a thioamide in the homologation sequence (Patel et al., 2015).\"\n    },\n    {\n      \"id\": \"rxn_013\",\n      \"name\": \"Surface photoreduction and final amination to arginine alpha-aminonitrile\",\n      \"inputs\": [\"mol_017\", \"mol_008\", \"mol_004\", \"mol_003\"],\n      \"outputs\": [\"mol_018\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"sulfide minerals (molybdenite/stibnite-like)\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"UV-driven Cu(I)/Cu(II) photoredox with H2S, followed by NH3 and HCN incorporation\",\n        \"aqueous\": \"true\",\n        \"other\": \"oxygen-free, flow-like reagent delivery\"\n      },\n      \"mechanism\": \"Photoreduction of the thioamide followed by cyanation and amination furnishes the alpha-aminonitrile precursor of arginine.\",\n      \"reasoning\": \"This is the culmination of the Patel et al. cyanosulfidic sequence, producing the arginine alpha-aminonitrile directly from the thioamide under UV/H2S/Cu-photoredox conditions with NH3 and HCN (Patel et al., 2015).\"\n    },\n    {\n      \"id\": \"rxn_014\",\n      \"name\": \"Biochemical/prebiotic hydrolysis of arginine alpha-aminonitrile to arginine\",\n      \"inputs\": [\"mol_018\"],\n      \"outputs\": [\"mol_019\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [null],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"null\",\n        \"aqueous\": \"true\",\n        \"other\": \"aqueous hydrolysis during geothermal cycling or standing pools; slower, potentially stepwise nitrile hydration/hydrolysis\"\n      },\n      \"mechanism\": \"Nitrile hydrolysis converts the alpha-aminonitrile to the corresponding amino acid, arginine.\",\n      \"reasoning\": \"Hydrolysis of amino nitriles to amino acids is a standard completion step in Strecker-type and cyanosulfidic amino acid synthesis; while the report emphasizes the aminonitrile precursor more strongly than explicit free-arginine hydrolysis conditions, this conversion is the minimal necessary finishing step to reach the target and is included as a cautious connection (Strecker, 1850; Patel et al., 2015; Leman et al., 2004).\"\n    },\n    {\n      \"id\": \"rxn_015\",\n      \"name\": \"Surface HCN-derived formation of ornithine as a secondary basic amino acid pool\",\n      \"inputs\": [\"mol_008\", \"mol_004\", \"mol_005\"],\n      \"outputs\": [\"mol_020\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"concentration on mineral surfaces in HCN-rich aqueous pools\",\n        \"aqueous\": \"true\",\n        \"other\": \"explicitly secondary/speculative compression of HCN-solution and spark-derived ornithine chemistry; anoxic\"\n      },\n      \"mechanism\": \"Networked HCN chemistry and hydrolysis generate a low-yield ornithine pool used only as a secondary precursor branch.\",\n      \"reasoning\": \"The deep research states that ornithine is more prebiotically accessible than arginine and has been identified in HCN solutions and spark-discharge experiments, whereas arginine is absent. Because the exact multi-step route is not fully detailed in the provided report, this node is included only as a secondary, explicitly lower-confidence feeder consistent with the literature trend rather than as a primary pathway (Parker et al., 2011; Cleaves et al., 2008; Longo et al., 2013).\"\n    },\n    {\n      \"id\": \"rxn_016\",\n      \"name\": \"Biochemical peptide bond formation to ornithine-containing dipeptide\",\n      \"inputs\": [\"mol_020\", \"mol_023\"],\n      \"outputs\": [\"mol_021\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [null],\n      \"conditions\": {\n        \"temperature\": \"320-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"null\",\n        \"aqueous\": \"false\",\n        \"other\": \"wet-dry cycling in prebiotic pools or mineral interfaces; condensation-dehydration regime\"\n      },\n      \"mechanism\": \"Dry-down condensation yields short peptides that incorporate ornithine side chains.\",\n      \"reasoning\": \"The report emphasizes prebiotic dry-down peptide formation and the importance of ornithine-containing early statistical polypeptides as likely precursors to later arginine-bearing peptides (Forsythe et al., 2015; Frenkel-Pinter et al., 2020; Longo et al., 2020).\"\n    },\n    {\n      \"id\": \"rxn_017\",\n      \"name\": \"Biochemical post-synthetic guanidination of free ornithine by cyanamide\",\n      \"inputs\": [\"mol_020\", \"mol_010\"],\n      \"outputs\": [\"mol_019\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [null],\n      \"conditions\": {\n        \"temperature\": \"295-310K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"null\",\n        \"aqueous\": \"true\",\n        \"other\": \"room temperature, aqueous solution, neutral to slightly alkaline pH\"\n      },\n      \"mechanism\": \"The side-chain primary amine of ornithine attacks cyanamide, producing the guanidino side chain of arginine.\",\n      \"reasoning\": \"Abiotic guanidination of ornithine by cyanamide in aqueous solution at room temperature and near-neutral to mildly alkaline pH is directly supported by the supplied literature and is the strongest secondary route to arginine outside the main cyanosulfidic aminonitrile pathway (Longo et al., 2020).\"\n    },\n    {\n      \"id\": \"rxn_018\",\n      \"name\": \"Biochemical post-synthetic guanidination of ornithine-containing peptide\",\n      \"inputs\": [\"mol_021\", \"mol_010\"],\n      \"outputs\": [\"mol_022\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [null],\n      \"conditions\": {\n        \"temperature\": \"295-310K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"null\",\n        \"aqueous\": \"true\",\n        \"other\": \"room temperature, aqueous solution, neutral to slightly alkaline pH; statistical side-chain conversion\"\n      },\n      \"mechanism\": \"Peptide-bound ornithine side chains undergo selective guanidination by cyanamide to generate peptide-bound arginine residues.\",\n      \"reasoning\": \"The literature explicitly reports statistical conversion of ornithine side chains in peptides to arginine by cyanamide, improving folding and nucleic-acid binding and supporting a post-synthetic entry of arginine into early peptides (Longo et al., 2020).\"\n    },\n    {\n      \"id\": \"rxn_019\",\n      \"name\": \"Biochemical hydrolytic release of arginine from arginine-containing peptide\",\n      \"inputs\": [\"mol_022\"],\n      \"outputs\": [\"mol_019\", \"mol_023\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [null],\n      \"conditions\": {\n        \"temperature\": \"320-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"null\",\n        \"aqueous\": \"true\",\n        \"other\": \"geothermal cycling or prolonged aqueous exposure; included as a necessary but less directly evidenced release step\"\n      },\n      \"mechanism\": \"Peptide bond hydrolysis liberates free arginine from an arginine-containing short peptide.\",\n      \"reasoning\": \"The report focuses on peptide guanidination as the key supported phenomenon and does not establish peptide hydrolysis as a dominant productive route to free arginine; this step is therefore explicitly speculative but chemically necessary to connect peptide-bound arginine to the free target within one integrated network (Longo et al., 2020; Frenkel-Pinter et al., 2020).\"\n    }\n  ],\n  \"pathways\": [\n    {\n      \"pathway_id\": \"P1\",\n      \"name\": \"Canonical cyanosulfidic route from atmospheric acetylene\",\n      \"description\": \"The primary literature-supported surface photoredox route beginning from acetylene and HCN, proceeding through acrylonitrile, beta-aminopropionitrile, guanidinated derivative, hemiaminal 37, cyanohydrin, alpha-hydroxythioamide, thioamide, arginine alpha-aminonitrile, and final hydrolysis.\",\n      \"reaction_sequence\": [\"rxn_006\", \"rxn_007\", \"rxn_008\", \"rxn_009\", \"rxn_010\", \"rxn_011\", \"rxn_012\", \"rxn_013\", \"rxn_014\"],\n      \"key_intermediates\": [\"mol_011\", \"mol_012\", \"mol_013\", \"mol_014\", \"mol_018\"]\n    },\n    {\n      \"pathway_id\": \"P2\",\n      \"name\": \"Hydrothermal sulfide-assisted cyanosulfidic route\",\n      \"description\": \"Hydrothermal vents furnish the H2S/NH3 pool that is transported to shallow photoredox settings, where the canonical cyanosulfidic route produces arginine.\",\n      \"reaction_sequence\": [\"rxn_005\", \"rxn_006\", \"rxn_007\", \"rxn_008\", \"rxn_009\", \"rxn_010\", \"rxn_011\", \"rxn_012\", \"rxn_013\", \"rxn_014\"],\n      \"key_intermediates\": [\"mol_003\", \"mol_004\", \"mol_011\", \"mol_014\", \"mol_018\"]\n    },\n    {\n      \"pathway_id\": \"P3\",\n      \"name\": \"Vent formate-to-ornithine secondary branch\",\n      \"description\": \"Reduced carbon from hydrothermal CO2 reduction contributes to a surface HCN chemistry pool that yields ornithine at low confidence, followed by direct cyanamide guanidination to arginine.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_015\", \"rxn_017\"],\n      \"key_intermediates\": [\"mol_005\", \"mol_020\"]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"Vent acetate-enhanced ornithine branch\",\n      \"description\": \"Hydrothermal homologation to acetate augments surface reduced-carbon availability feeding a secondary ornithine pool, then cyanamide converts ornithine to arginine.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_015\", \"rxn_017\"],\n      \"key_intermediates\": [\"mol_005\", \"mol_006\", \"mol_020\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"Vent pyruvate-linked ornithine branch\",\n      \"description\": \"A conservative hydrothermal alpha-keto acid route is connected to HCN-derived surface ornithine formation and then direct guanidination to arginine.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_003\", \"rxn_015\", \"rxn_017\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_020\"]\n    },\n    {\n      \"pathway_id\": \"P6\",\n      \"name\": \"Peptide-first ornithine guanidination route\",\n      \"description\": \"Secondary ornithine is incorporated into a short peptide during wet-dry cycling and then selectively guanidinated by cyanamide to form an arginine-containing peptide, followed by hydrolytic release of free arginine.\",\n      \"reaction_sequence\": [\"rxn_015\", \"rxn_016\", \"rxn_018\", \"rxn_019\"],\n      \"key_intermediates\": [\"mol_020\", \"mol_021\", \"mol_022\"]\n    },\n    {\n      \"pathway_id\": \"P7\",\n      \"name\": \"Hydrothermal-fed peptide-first route\",\n      \"description\": \"Vent-derived reduced carbon and nitrogen feed surface ornithine formation, after which peptide assembly and post-synthetic cyanamide guanidination yield peptide-bound arginine and then free arginine.\",\n      \"reaction_sequence\": [\"rxn_005\", \"rxn_015\", \"rxn_016\", \"rxn_018\", \"rxn_019\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_003\", \"mol_020\", \"mol_021\", \"mol_022\"]\n    },\n    {\n      \"pathway_id\": \"P8\",\n      \"name\": \"Hydrothermal-to-surface canonical route via reduced carbon supply\",\n      \"description\": \"Vent-generated formate and acetate populate the shared feedstock pool while shallow-surface photoredox chemistry executes the established arginine alpha-aminonitrile sequence.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_006\", \"rxn_007\", \"rxn_008\", \"rxn_009\", \"rxn_010\", \"rxn_011\", \"rxn_012\", \"rxn_013\", \"rxn_014\"],\n      \"key_intermediates\": [\"mol_005\", \"mol_006\", \"mol_011\", \"mol_014\", \"mol_018\"]\n    },\n    {\n      \"pathway_id\": \"P9\",\n      \"name\": \"Ammonia-rich canonical cyanosulfidic route\",\n      \"description\": \"A route emphasizing hydrothermal NH3 delivery into the surface acrylonitrile-to-aminonitrile sequence, capturing convergence at beta-aminopropionitrile and arginine alpha-aminonitrile.\",\n      \"reaction_sequence\": [\"rxn_005\", \"rxn_007\", \"rxn_008\", \"rxn_009\", \"rxn_010\", \"rxn_011\", \"rxn_012\", \"rxn_013\", \"rxn_014\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_012\", \"mol_013\", \"mol_018\"]\n    },\n    {\n      \"pathway_id\": \"P10\",\n      \"name\": \"Mixed canonical and ornithine-modification convergence network\",\n      \"description\": \"A systems-chemistry pathway in which the environment simultaneously sustains the direct aminonitrile route to arginine and the secondary ornithine-to-arginine route, both converging on the same final product.\",\n      \"reaction_sequence\": [\"rxn_006\", \"rxn_007\", \"rxn_008\", \"rxn_009\", \"rxn_010\", \"rxn_011\", \"rxn_012\", \"rxn_013\", \"rxn_014\", \"rxn_015\", \"rxn_017\"],\n      \"key_intermediates\": [\"mol_018\", \"mol_020\", \"mol_019\"]\n    }\n  ],\n  \"hub_molecules\": [\"mol_004\", \"mol_005\", \"mol_008\", \"mol_010\", \"mol_020\"],\n  \"convergence_points\": [\n    {\n      \"molecule_id\": \"mol_004\",\n      \"incoming_reactions\": [\"rxn_004\", \"rxn_005\"],\n      \"outgoing_reactions\": [\"rxn_007\", \"rxn_013\", \"rxn_015\"]\n    },\n    {\n      \"molecule_id\": \"mol_005\",\n      \"incoming_reactions\": [\"rxn_001\"],\n      \"outgoing_reactions\": [\"rxn_002\", \"rxn_003\", \"rxn_015\"]\n    },\n    {\n      \"molecule_id\": \"mol_008\",\n      \"incoming_reactions\": [],\n      \"outgoing_reactions\": [\"rxn_006\", \"rxn_010\", \"rxn_013\", \"rxn_015\"]\n    },\n    {\n      \"molecule_id\": \"mol_010\",\n      \"incoming_reactions\": [],\n      \"outgoing_reactions\": [\"rxn_008\", \"rxn_009\", \"rxn_017\", \"rxn_018\"]\n    },\n    {\n      \"molecule_id\": \"mol_020\",\n      \"incoming_reactions\": [\"rxn_015\"],\n      \"outgoing_reactions\": [\"rxn_016\", \"rxn_017\"]\n    },\n    {\n      \"molecule_id\": \"mol_019\",\n      \"incoming_reactions\": [\"rxn_014\", \"rxn_017\", \"rxn_019\"],\n      \"outgoing_reactions\": []\n    }\n  ]\n}", "parsed_response": {"target_molecule": "Arginine", "overall_strategy": "This network prioritizes the literature-supported cyanosulfidic synthesis of an arginine alpha-aminonitrile precursor from acetylene, HCN, NH3, H2S, cyanamide, and UV-driven Cu photoredox chemistry in shallow surface settings, then converts that precursor to free arginine by hydrolysis in prebiotic aqueous environments. Hydrothermal chemistry is used conservatively and literature-consistently to supply reduced feedstocks and shared hubs such as formate, acetate, pyruvate, ammonia, and sulfide under Fe-S mineral catalysis, which then feed surface photoredox chemistry. A secondary, explicitly downgraded route follows the reported abiotic guanidination of ornithine-containing peptides or free ornithine by cyanamide in aqueous solution, reflecting the literature view that arginine may have entered chemical evolution as a post-synthetic modification rather than as a primary free monomer. The ten pathways below are distinct traversals through one connected bipartite network and mostly converge on the best-supported arginine alpha-aminonitrile hub before final hydrolysis to arginine.", "molecules": [{"id": "mol_001", "formula": "CO2", "iupac_name": "carbon dioxide", "common_name": "carbon dioxide", "inchi": "InChI=1S/CO2/c2-1-3", "role": "starting", "environment_formed": null}, {"id": "mol_002", "formula": "H2", "iupac_name": "molecular hydrogen", "common_name": "hydrogen", "inchi": "InChI=1S/H2/h1H", "role": "starting", "environment_formed": null}, {"id": "mol_003", "formula": "H2S", "iupac_name": "sulfane", "common_name": "hydrogen sulfide", "inchi": "InChI=1S/H2S/h1H2", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_004", "formula": "NH3", "iupac_name": "azane", "common_name": "ammonia", "inchi": "InChI=1S/H3N/h1H3", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_005", "formula": "CH2O2", "iupac_name": "methanoic acid", "common_name": "formate/formic acid", "inchi": "InChI=1S/CH2O2/c2-1-3/h1H,(H,2,3)", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_006", "formula": "C2H4O2", "iupac_name": "acetic acid", "common_name": "acetate/acetic acid", "inchi": "InChI=1S/C2H4O2/c1-2(3)4/h1H3,(H,3,4)", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_007", "formula": "C3H4O3", "iupac_name": "2-oxopropanoic acid", "common_name": "pyruvic acid", "inchi": "InChI=1S/C3H4O3/c1-2(4)3(5)6/h1H3,(H,5,6)", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_008", "formula": "HCN", "iupac_name": "hydrogen cyanide", "common_name": "hydrogen cyanide", "inchi": "InChI=1S/CHN/c1-2/h1H", "role": "hub_intermediate", "environment_formed": null}, {"id": "mol_009", "formula": "C2H2", "iupac_name": "ethyne", "common_name": "acetylene", "inchi": "InChI=1S/C2H2/c1-2/h1-2H", "role": "starting", "environment_formed": null}, {"id": "mol_010", "formula": "CH2N2", "iupac_name": "cyanamide", "common_name": "cyanamide", "inchi": "InChI=1S/CH2N2/c2-1-3/h(H2,2,3)", "role": "hub_intermediate", "environment_formed": null}, {"id": "mol_011", "formula": "C3H3N", "iupac_name": "prop-2-enenitrile", "common_name": "acrylonitrile", "inchi": "InChI=1S/C3H3N/c1-2-3-4/h2H,1H2", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_012", "formula": "C3H6N2", "iupac_name": "3-aminopropanenitrile", "common_name": "beta-aminopropionitrile", "inchi": "InChI=1S/C3H6N2/c4-2-1-3-5/h1-2,4H2", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_013", "formula": "C4H8N4", "iupac_name": "N-(2-cyanoethyl)guanidine", "common_name": "guanidinated beta-aminopropionitrile", "inchi": null, "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_014", "formula": "C4H9N3O", "iupac_name": "3-guanidinopropanal hemiaminal adduct", "common_name": "hemiaminal 37", "inchi": null, "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_015", "formula": "C5H9N4O", "iupac_name": "cyanohydrin of hemiaminal 37", "common_name": "arginine-pathway cyanohydrin intermediate", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_016", "formula": "C5H10N4OS", "iupac_name": "alpha-hydroxythioamide intermediate", "common_name": "alpha-hydroxythioamide", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_017", "formula": "C5H10N4S", "iupac_name": "thioamide intermediate", "common_name": "arginine-pathway thioamide", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_018", "formula": "C6H13N5", "iupac_name": "2-amino-5-guanidinopentanenitrile", "common_name": "arginine alpha-aminonitrile", "inchi": null, "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_019", "formula": "C6H14N4O2", "iupac_name": "2-amino-5-(diaminomethylideneamino)pentanoic acid", "common_name": "arginine", "inchi": "InChI=1S/C6H14N4O2/c7-3-1-2-10-6(8)9-4-5(11)12/h5H,1-4,7H2,(H4,8,9,10)(H,11,12)", "role": "target", "environment_formed": "Biochemical"}, {"id": "mol_020", "formula": "C5H12N2O2", "iupac_name": "2,5-diaminopentanoic acid", "common_name": "ornithine", "inchi": "InChI=1S/C5H12N2O2/c6-3-1-2-4(7)5(8)9/h4H,1-3,6-7H2,(H,8,9)", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_021", "formula": "C10H21N3O3", "iupac_name": "ornithylglycine", "common_name": "ornithine-containing dipeptide", "inchi": null, "role": "intermediate", "environment_formed": "Biochemical"}, {"id": "mol_022", "formula": "C11H23N5O3", "iupac_name": "arginylglycine", "common_name": "arginine-containing dipeptide", "inchi": null, "role": "intermediate", "environment_formed": "Biochemical"}, {"id": "mol_023", "formula": "C2H5NO2", "iupac_name": "2-aminoacetic acid", "common_name": "glycine", "inchi": "InChI=1S/C2H5NO2/c3-1-2(4)5/h1,3H2,(H,4,5)", "role": "intermediate", "environment_formed": "Surface"}], "reactions": [{"id": "rxn_001", "name": "Hydrothermal CO2 reduction to formate", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_005"], "environment": "Hydrothermal", "agents": ["greigite (Fe3S4)", "mackinawite (FeS)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "greigite and mackinawite", "aqueous": "true", "other": "alkaline vent conditions, anoxic, H2-rich serpentinization setting"}, "mechanism": "Mineral-surface mediated reduction of CO2 by H2 on Fe-S phases to give formate.", "reasoning": "Vent Fe-S minerals plausibly reduce CO2 to simple C1 organics under alkaline hydrothermal conditions, supplying reduced carbon to downstream prebiotic networks; this is consistent with iron-sulfur world and vent carbon-fixation studies (Huber & Wachtershauser, 1997; Russell & Martin, 2004; Preiner et al., 2020)."}, {"id": "rxn_002", "name": "Hydrothermal homologation from formate to acetate", "inputs": ["mol_005", "mol_002"], "outputs": ["mol_006"], "environment": "Hydrothermal", "agents": ["greigite (Fe3S4)", "magnetite (Fe3O4)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "greigite and magnetite", "aqueous": "true", "other": "anoxic vent pores with redox and pH gradients"}, "mechanism": "Further reduction and C-C bond formation on Fe-bearing mineral surfaces generates acetate from reduced C1 feedstocks.", "reasoning": "Acetate formation from reduced carbon species under hydrothermal Fe-mineral catalysis is a core component of vent metabolism-first chemistry and provides a connected reduced-carbon pool feeding later synthesis (Huber & Wachtershauser, 1997; Muchowska et al., 2019; Preiner et al., 2020)."}, {"id": "rxn_003", "name": "Hydrothermal pyruvate formation from reduced carbon pool", "inputs": ["mol_005", "mol_006", "mol_002"], "outputs": ["mol_007"], "environment": "Hydrothermal", "agents": ["magnetite (Fe3O4)", "greigite (Fe3S4)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "magnetite and greigite", "aqueous": "true", "other": "mild alkaline hydrothermal regime; included conservatively as vent-supported alpha-keto acid generation"}, "mechanism": "Successive reduction and carboxylation/homologation on iron minerals furnishes the alpha-keto acid pyruvate.", "reasoning": "Pyruvate is reported as plausibly formed in hydrothermal vent simulations and is central to vent protometabolism, though this step is less directly established than the cyanosulfidic arginine route and is therefore used only as a feedstock-connecting node rather than a primary arginine-forming step (Muchowska et al., 2019; Preiner et al., 2020; Varma et al., 2018)."}, {"id": "rxn_004", "name": "Hydrothermal reductive amination of pyruvate to alanine-equivalent ammonia pool", "inputs": ["mol_007", "mol_004", "mol_002"], "outputs": ["mol_004"], "environment": "Hydrothermal", "agents": ["pyrite (FeS2)", "greigite (Fe3S4)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "pyrite and greigite", "aqueous": "true", "other": "anoxic vent microcompartments; represented as sustaining shared NH3/amino donor pool rather than introducing a separate alanine node"}, "mechanism": "Mineral-assisted reductive amination chemistry shows that vent-generated keto acids can engage ammonia to generate amino-acid chemistry, reinforcing NH3-linked network connectivity.", "reasoning": "The report specifically notes pyruvate reductive amination under vent-like conditions; here it is incorporated in a compressed way to connect vent alpha-keto acid chemistry with downstream amination potential without overclaiming unsupported ornithine synthesis (Barge et al., 2019; Muchowska et al., 2020)."}, {"id": "rxn_005", "name": "Hydrothermal sulfide and ammonia supply from vent serpentinization and mineral nitrogen chemistry", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_003", "mol_004"], "environment": "Hydrothermal", "agents": ["elemental iron (Fe0)", "pyrite (FeS2)"], "conditions": {"temperature": "370-470K", "pressure": "high", "catalyst": "elemental iron and pyrite", "aqueous": "true", "other": "serpentinization-influenced vent fluids; anoxic, reduced iron abundant"}, "mechanism": "Reduced hydrothermal systems furnish sulfide-rich, ammonia-compatible fluids and support mineral-mediated nitrogen reduction chemistry that populates the NH3/H2S pool.", "reasoning": "The deep research emphasizes serpentinization-generated reducing power, Fe-S mineral catalysis, and the importance of NH3 and H2S in vent-to-surface chemistry; this aggregated sourcing step is used to connect hydrothermal and surface subsystems while staying within the geochemical framework (Russell & Martin, 2004; Martin et al., 2008; Preiner et al., 2020)."}, {"id": "rxn_006", "name": "Surface Cu-photoredox coupling of acetylene and HCN to acrylonitrile", "inputs": ["mol_009", "mol_008"], "outputs": ["mol_011"], "environment": "Surface", "agents": ["sulfide minerals (molybdenite/stibnite-like)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "Cu(I) photoredox cycling in sulfide-rich, UV-irradiated shallow surface setting", "aqueous": "true", "other": "anoxic, UV-exposed shallow ponds or intertidal alkaline vent margins; mineral agents provide surface localization while Cu(I) is the literature-specific catalytic metal"}, "mechanism": "Cu(I)-mediated C-C cross-coupling between acetylene and HCN forms acrylonitrile, establishing the three-carbon nitrile backbone.", "reasoning": "The deep research identifies Cu(I)-catalyzed coupling of acetylene and HCN to acrylonitrile as the entry step to the Sutherland arginine pathway; shallow photoredox environments are specifically emphasized (Patel et al., 2015; Xu et al., 2018)."}, {"id": "rxn_007", "name": "Surface ammonia addition to acrylonitrile", "inputs": ["mol_011", "mol_004"], "outputs": ["mol_012"], "environment": "Surface", "agents": ["montmorillonite (clay)", "sulfide minerals (molybdenite/stibnite-like)"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "mineral-surface promoted Michael-type ammonia addition", "aqueous": "true", "other": "anoxic aqueous pools with evaporative concentration"}, "mechanism": "Nucleophilic addition of ammonia across the activated nitrile-containing alkene yields beta-aminopropionitrile.", "reasoning": "Ammonia addition to acrylonitrile to give beta-aminopropionitrile is explicitly described in the literature-supported arginine sequence and provides the immediate substrate for guanidinylation (Patel et al., 2015)."}, {"id": "rxn_008", "name": "Surface guanidinylation of beta-aminopropionitrile by cyanamide", "inputs": ["mol_012", "mol_010"], "outputs": ["mol_013"], "environment": "Surface", "agents": ["montmorillonite (clay)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "cyanamide reagent in concentrated aqueous phase on mineral surfaces", "aqueous": "true", "other": "neutral to mildly alkaline, anoxic; reaction known to be incomplete and mixture-forming"}, "mechanism": "The amino group attacks cyanamide, forming a guanidinated nitrile derivative that seeds the arginine side chain.", "reasoning": "The report states that beta-aminopropionitrile reacts with cyanamide to form a guanidinated derivative, albeit inefficiently, and that this mixed pool is then productively processed by photoredox chemistry (Patel et al., 2015)."}, {"id": "rxn_009", "name": "Surface photoredox trapping to hemiaminal 37", "inputs": ["mol_013", "mol_003", "mol_010"], "outputs": ["mol_014"], "environment": "Surface", "agents": ["sulfide minerals (molybdenite/stibnite-like)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "Cu(I)/Cu(II) photoredox with H2S under UV irradiation", "aqueous": "true", "other": "oxygen-free, UV-driven; residual cyanamide traps the aldehyde as a stable hemiaminal"}, "mechanism": "Photoreduction in the presence of sulfide generates the corresponding aldehyde level, which is efficiently trapped by cyanamide as the stable hemiaminal 37.", "reasoning": "The key literature discovery is the extraordinarily efficient formation of a stable hemiaminal from beta-aminopropionaldehyde and residual cyanamide during UV/H2S/Cu photoredox processing; this trapping step is central to selectivity (Patel et al., 2015)."}, {"id": "rxn_010", "name": "Surface dark cyanohydrin formation from hemiaminal 37", "inputs": ["mol_014", "mol_008"], "outputs": ["mol_015"], "environment": "Surface", "agents": ["borate minerals (colemanite/ulexite)", "montmorillonite (clay)"], "conditions": {"temperature": "300-320K", "pressure": "1 atm", "catalyst": "mineral-assisted concentration in dark aqueous phase", "aqueous": "true", "other": "dark reaction following photochemical step; anoxic"}, "mechanism": "HCN addition to the trapped aldehydic center gives the homologated cyanohydrin intermediate.", "reasoning": "The report explicitly states that after hemiaminal formation, a dark reaction with HCN converts the intermediate into a cyanohydrin as part of a Kiliani-Fischer-like homologation sequence (Patel et al., 2015)."}, {"id": "rxn_011", "name": "Surface sulfidolysis of cyanohydrin to alpha-hydroxythioamide", "inputs": ["mol_015", "mol_003"], "outputs": ["mol_016"], "environment": "Surface", "agents": ["sulfide minerals (molybdenite/stibnite-like)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "H2S-rich sulfide mineral surface chemistry", "aqueous": "true", "other": "anoxic shallow pool chemistry"}, "mechanism": "Sulfide substitutes into the cyanohydrin-derived intermediate to generate an alpha-hydroxythioamide.", "reasoning": "Sulfidolysis of the cyanohydrin to the alpha-hydroxythioamide is directly described in the cyanosulfidic arginine pathway and depends on H2S-rich conditions (Patel et al., 2015; Xu et al., 2018)."}, {"id": "rxn_012", "name": "Surface UV deoxygenation of alpha-hydroxythioamide to thioamide", "inputs": ["mol_016"], "outputs": ["mol_017"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "sulfide minerals (molybdenite/stibnite-like)"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "UV irradiation with Cu photoredox-compatible mineral setting", "aqueous": "true", "other": "anoxic, strong UV flux"}, "mechanism": "Photochemical deoxygenation removes the alpha-hydroxyl functionality, yielding the thioamide.", "reasoning": "The deep research explicitly identifies UV irradiation of the alpha-hydroxythioamide as the deoxygenation step producing a thioamide in the homologation sequence (Patel et al., 2015)."}, {"id": "rxn_013", "name": "Surface photoreduction and final amination to arginine alpha-aminonitrile", "inputs": ["mol_017", "mol_008", "mol_004", "mol_003"], "outputs": ["mol_018"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "sulfide minerals (molybdenite/stibnite-like)"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "UV-driven Cu(I)/Cu(II) photoredox with H2S, followed by NH3 and HCN incorporation", "aqueous": "true", "other": "oxygen-free, flow-like reagent delivery"}, "mechanism": "Photoreduction of the thioamide followed by cyanation and amination furnishes the alpha-aminonitrile precursor of arginine.", "reasoning": "This is the culmination of the Patel et al. cyanosulfidic sequence, producing the arginine alpha-aminonitrile directly from the thioamide under UV/H2S/Cu-photoredox conditions with NH3 and HCN (Patel et al., 2015)."}, {"id": "rxn_014", "name": "Biochemical/prebiotic hydrolysis of arginine alpha-aminonitrile to arginine", "inputs": ["mol_018"], "outputs": ["mol_019"], "environment": "Biochemical", "agents": [null], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "null", "aqueous": "true", "other": "aqueous hydrolysis during geothermal cycling or standing pools; slower, potentially stepwise nitrile hydration/hydrolysis"}, "mechanism": "Nitrile hydrolysis converts the alpha-aminonitrile to the corresponding amino acid, arginine.", "reasoning": "Hydrolysis of amino nitriles to amino acids is a standard completion step in Strecker-type and cyanosulfidic amino acid synthesis; while the report emphasizes the aminonitrile precursor more strongly than explicit free-arginine hydrolysis conditions, this conversion is the minimal necessary finishing step to reach the target and is included as a cautious connection (Strecker, 1850; Patel et al., 2015; Leman et al., 2004)."}, {"id": "rxn_015", "name": "Surface HCN-derived formation of ornithine as a secondary basic amino acid pool", "inputs": ["mol_008", "mol_004", "mol_005"], "outputs": ["mol_020"], "environment": "Surface", "agents": ["montmorillonite (clay)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "concentration on mineral surfaces in HCN-rich aqueous pools", "aqueous": "true", "other": "explicitly secondary/speculative compression of HCN-solution and spark-derived ornithine chemistry; anoxic"}, "mechanism": "Networked HCN chemistry and hydrolysis generate a low-yield ornithine pool used only as a secondary precursor branch.", "reasoning": "The deep research states that ornithine is more prebiotically accessible than arginine and has been identified in HCN solutions and spark-discharge experiments, whereas arginine is absent. Because the exact multi-step route is not fully detailed in the provided report, this node is included only as a secondary, explicitly lower-confidence feeder consistent with the literature trend rather than as a primary pathway (Parker et al., 2011; Cleaves et al., 2008; Longo et al., 2013)."}, {"id": "rxn_016", "name": "Biochemical peptide bond formation to ornithine-containing dipeptide", "inputs": ["mol_020", "mol_023"], "outputs": ["mol_021"], "environment": "Biochemical", "agents": [null], "conditions": {"temperature": "320-370K", "pressure": "1 atm", "catalyst": "null", "aqueous": "false", "other": "wet-dry cycling in prebiotic pools or mineral interfaces; condensation-dehydration regime"}, "mechanism": "Dry-down condensation yields short peptides that incorporate ornithine side chains.", "reasoning": "The report emphasizes prebiotic dry-down peptide formation and the importance of ornithine-containing early statistical polypeptides as likely precursors to later arginine-bearing peptides (Forsythe et al., 2015; Frenkel-Pinter et al., 2020; Longo et al., 2020)."}, {"id": "rxn_017", "name": "Biochemical post-synthetic guanidination of free ornithine by cyanamide", "inputs": ["mol_020", "mol_010"], "outputs": ["mol_019"], "environment": "Biochemical", "agents": [null], "conditions": {"temperature": "295-310K", "pressure": "1 atm", "catalyst": "null", "aqueous": "true", "other": "room temperature, aqueous solution, neutral to slightly alkaline pH"}, "mechanism": "The side-chain primary amine of ornithine attacks cyanamide, producing the guanidino side chain of arginine.", "reasoning": "Abiotic guanidination of ornithine by cyanamide in aqueous solution at room temperature and near-neutral to mildly alkaline pH is directly supported by the supplied literature and is the strongest secondary route to arginine outside the main cyanosulfidic aminonitrile pathway (Longo et al., 2020)."}, {"id": "rxn_018", "name": "Biochemical post-synthetic guanidination of ornithine-containing peptide", "inputs": ["mol_021", "mol_010"], "outputs": ["mol_022"], "environment": "Biochemical", "agents": [null], "conditions": {"temperature": "295-310K", "pressure": "1 atm", "catalyst": "null", "aqueous": "true", "other": "room temperature, aqueous solution, neutral to slightly alkaline pH; statistical side-chain conversion"}, "mechanism": "Peptide-bound ornithine side chains undergo selective guanidination by cyanamide to generate peptide-bound arginine residues.", "reasoning": "The literature explicitly reports statistical conversion of ornithine side chains in peptides to arginine by cyanamide, improving folding and nucleic-acid binding and supporting a post-synthetic entry of arginine into early peptides (Longo et al., 2020)."}, {"id": "rxn_019", "name": "Biochemical hydrolytic release of arginine from arginine-containing peptide", "inputs": ["mol_022"], "outputs": ["mol_019", "mol_023"], "environment": "Biochemical", "agents": [null], "conditions": {"temperature": "320-370K", "pressure": "1 atm", "catalyst": "null", "aqueous": "true", "other": "geothermal cycling or prolonged aqueous exposure; included as a necessary but less directly evidenced release step"}, "mechanism": "Peptide bond hydrolysis liberates free arginine from an arginine-containing short peptide.", "reasoning": "The report focuses on peptide guanidination as the key supported phenomenon and does not establish peptide hydrolysis as a dominant productive route to free arginine; this step is therefore explicitly speculative but chemically necessary to connect peptide-bound arginine to the free target within one integrated network (Longo et al., 2020; Frenkel-Pinter et al., 2020)."}], "pathways": [{"pathway_id": "P1", "name": "Canonical cyanosulfidic route from atmospheric acetylene", "description": "The primary literature-supported surface photoredox route beginning from acetylene and HCN, proceeding through acrylonitrile, beta-aminopropionitrile, guanidinated derivative, hemiaminal 37, cyanohydrin, alpha-hydroxythioamide, thioamide, arginine alpha-aminonitrile, and final hydrolysis.", "reaction_sequence": ["rxn_006", "rxn_007", "rxn_008", "rxn_009", "rxn_010", "rxn_011", "rxn_012", "rxn_013", "rxn_014"], "key_intermediates": ["mol_011", "mol_012", "mol_013", "mol_014", "mol_018"]}, {"pathway_id": "P2", "name": "Hydrothermal sulfide-assisted cyanosulfidic route", "description": "Hydrothermal vents furnish the H2S/NH3 pool that is transported to shallow photoredox settings, where the canonical cyanosulfidic route produces arginine.", "reaction_sequence": ["rxn_005", "rxn_006", "rxn_007", "rxn_008", "rxn_009", "rxn_010", "rxn_011", "rxn_012", "rxn_013", "rxn_014"], "key_intermediates": ["mol_003", "mol_004", "mol_011", "mol_014", "mol_018"]}, {"pathway_id": "P3", "name": "Vent formate-to-ornithine secondary branch", "description": "Reduced carbon from hydrothermal CO2 reduction contributes to a surface HCN chemistry pool that yields ornithine at low confidence, followed by direct cyanamide guanidination to
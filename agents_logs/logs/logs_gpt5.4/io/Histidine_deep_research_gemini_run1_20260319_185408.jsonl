e\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_007\",\n      \"formula\": \"C4H8O4\",\n      \"iupac_name\": \"2,3,4-trihydroxybutanal\",\n      \"common_name\": \"erythrose\",\n      \"inchi\": \"InChI=1S/C4H8O4/c5-1-3(7)4(8)2-6/h1,3-4,6-8H,2H2\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_008\",\n      \"formula\": \"HCN\",\n      \"iupac_name\": \"hydrogen cyanide\",\n      \"common_name\": \"hydrogen cyanide\",\n      \"inchi\": \"InChI=1S/CHN/c1-2/h1H\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_009\",\n      \"formula\": \"H3N\",\n      \"iupac_name\": \"azane\",\n      \"common_name\": \"ammonia\",\n      \"inchi\": \"InChI=1S/H3N/h1H3\",\n      \"role\": \"starting\",\n      \"environment_formed\": null\n    },\n    {\n      \"id\": \"mol_010\",\n      \"formula\": \"CH4N2\",\n      \"iupac_name\": \"methanimidamide\",\n      \"common_name\": \"formamidine\",\n      \"inchi\": \"InChI=1S/CH4N2/c2-1-3/h1H,(H3,2,3)\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_011\",\n      \"formula\": \"CH2N2\",\n      \"iupac_name\": \"cyanamide\",\n      \"common_name\": \"cyanamide\",\n      \"inchi\": \"InChI=1S/CH2N2/c2-1-3/h(H2,2,3)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_012\",\n      \"formula\": \"C5H6N2O\",\n      \"iupac_name\": \"2-(1H-imidazol-4-yl)ethanal\",\n      \"common_name\": \"imidazole-4-acetaldehyde\",\n      \"inchi\": \"InChI=1S/C5H6N2O/c8-2-1-5-3-6-4-7-5/h2-4H,1H2,(H,6,7)\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_013\",\n      \"formula\": \"C6H7N3\",\n      \"iupac_name\": \"2-amino-1H-imidazole\",\n      \"common_name\": \"2-aminoimidaz
 },\n    {\n      \"id\": \"mol_015\",\n      \"formula\": \"C9H14N4O8P\",\n      \"iupac_name\": \"5-amino-1-(5-phosphono-beta-D-ribofuranosyl)-1H-imidazole-4-carboxamide\",\n      \"common_name\": \"AICAR\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_016\",\n      \"formula\": \"C5H6N2O\",\n      \"iupac_name\": \"1H-imidazole-4-ethanal\",\n      \"common_name\": \"imidazole-4-acetaldehyde\",\n      \"inchi\": \"InChI=1S/C5H6N2O/c8-2-1-5-3-6-4-7-5/h3-4H,1-2H2,(H,6,7)\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_017\",\n      \"formula\": \"C6H7N4\",\n      \"iupac_name\": \"2-amino-3-(1H-imidazol-4-yl)propanenitrile\",\n      \"common_name\": \"histidine aminonitrile\",\n      \"inchi\": null,\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_018\",\n      \"formula\": \"C6H9N3O2\",\n      \"iupac_name\": \"2-amino-3-(1H-imidazol-4-yl)propanoic acid\",\n      \"common_name\": \"histidine\",\n      \"inchi\": \"InChI=1S/C6H9N3O2/c7-5(6(10)11)1-4-2-8-3-9-4/h2-3,5H,1,7H2,(H,8,9)(H,10,11)\",\n      \"role\": \"target\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_019\",\n      \"formula\": \"C6H10N4O3\",\n      \"iupac_name\": \"2-amino-3-(1H-imidazol-4-yl)propanoyl-3-(1H-imidazol-4-yl)propanic acid\",\n      \"common_name\": \"histidyl-histidine\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_020\",\n      \"formula\": \"C3H4O3\",\n      \"iupac_name\": \"2-oxopropanoic acid\",\n      \"common_name\": \"pyruvate\",\n      \"inchi\": \"InChI=1S/C3H4O3/c1-2(4)3(5)6/h1H3,(H,5,6)\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_021\",\n      \"formula\": \"C3H7NO2\",\n      \"iupac_name\": \"2-aminopropanoic acid\",\n      \"common_name\": \"alanine\",\n      \"inchi\": \"InChI=1S/C3H7NO2/c1-2(4)3(5)6/h2H,4H2,1H3,(H,5,6)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_022\",\n      \"formula\": \"C2H4O\",\n      \"iupac_name\": \"ethanal\",\n      \"common_name\": \"acetaldehyde\",\n      \"inchi\": \"InChI=1S/C2H4O/c1-2-3/h2H,1H3\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_023\",\n      \"formula\": \"H3PO4\",\n      \"iupac_name\": \"phosphoric acid\",\n      \"common_name\": \"phosphate\",\n      \"inchi\": \"InChI=1S/H3O4P/c1-5(2,3)4/h(H3,1,2,3,4)\",\n      \"role\": \"starting\",\n      \"environment_formed\": null\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"Hydrothermal CO2 reduction to formate\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_003\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe3S4)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"greigite and mackinawite\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline vent conditions; anoxic; H2-rich\"\n      },\n      \"mechanism\": \"Mineral-surface reduction of CO2 by H2 gives formate as an early reduced C1 product on Fe-S phases.\",\n      \"reasoning\": \"Fe-S vent catalysis of CO2 reduction to formate is consistent with iron-sulfur world and vent simulation literature; this step provides a hydrothermal reduced-carbon feedstock that can move into surface chemistry, while not overclaiming direct histidine formation in vents (Huber & Wachtershauser, 1997; Russell & Martin, 2004; Preiner et al., 2020).\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Hydrothermal carbon fixation to acetate\",\n      \"inputs\": [\"mol_001\", \"mol_002\", \"mol_003\"],\n      \"outputs\": [\"mol_004\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe3S4)\", \"magnetite (Fe3O4)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"greigite and magnetite\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline vent microcompartments; anoxic\"\n      },\n      \"mechanism\": \"Sequential CO2 reduction and C-C bond formation on Fe-S/oxide surfaces generates acetate as an acetyl-thioester analogue endpoint.\",\n      \"reasoning\": \"Acetate production from vent-style CO2/H2 chemistry is widely discussed in metabolism-first work and supports hydrothermal feeding of surface organosynthesis without asserting unsupported selectivity to histidine intermediates (Huber & Wachtershauser, 1997; Russell & Hall, 1997; Preiner et al., 2020).\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Hydrothermal pyruvate synthesis from CO2 and H2\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_020\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe3O4)\", \"greigite (Fe3S4)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"magnetite and greigite\",\n        \"aqueous\": \"true\",\n        \"other\": \"subseafloor hydrothermal setting; anoxic\"\n      },\n      \"mechanism\": \"Mineral-catalyzed reductive carbon fixation extends C1 chemistry toward a central alpha-keto acid hub.\",\n      \"reasoning\": \"Pyruvate is a recognized prebiotic metabolic hub in hydrothermal analog experiments and provides a dense network connector to amino acid chemistry and aldehyde generation (Keller et al., 2014; Muchowska et al., 2019; Preiner et al., 2020).\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"Hydrothermal reductive amination of pyruvate to alanine\",\n      \"inputs\": [\"mol_020\", \"mol_007\", \"mol_002\"],\n      \"outputs\": [\"mol_021\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"pyrite (FeS2)\", \"elemental iron (Fe0)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"pyrite and Fe0\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic mineral surfaces\"\n      },\n      \"mechanism\": \"Imine formation between pyruvate and ammonia followed by mineral-assisted reduction yields alanine.\",\n      \"reasoning\": \"Reductive amination of alpha-keto acids under reducing mineral conditions is a plausible hydrothermal route to simple amino acids and helps connect alpha-keto acid hubs to amino acid pools (Huber & Wachtershauser, 2006; Muchowska et al., 2019).\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"Thermal decarboxylation of pyruvate to acetaldehyde\",\n      \"inputs\": [\"mol_020\"],\n      \"outputs\": [\"mol_022\", \"mol_001\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"1 atm to moderate\",\n        \"catalyst\": null,\n        \"aqueous\": \"true\",\n        \"other\": \"geothermal heating; anoxic\"\n      },\n      \"mechanism\": \"Thermal loss of CO2 from pyruvate furnishes acetaldehyde, linking hydrothermal keto-acid chemistry to surface Strecker-style feedstocks.\",\n      \"reasoning\": \"Pyruvate decarboxylation is explicitly listed as a plausible prebiotic thermal transformation and is used here only as a connector from hydrothermal carbon fixation to broader aldehyde/amino acid chemistry (Copley et al., 2007; Muchowska et al., 2019).\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"Atmospheric/surface generation of HCN feedstock\",\n      \"inputs\": [\"mol_001\", \"mol_007\"],\n      \"outputs\": [\"mol_006\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO2 and clay concentration surfaces\",\n        \"aqueous\": \"false\",\n        \"other\": \"volcanic discharge/photochemical context; UV irradiation; feedstock capture in pools\"\n      },\n      \"mechanism\": \"High-energy atmospheric discharge and UV-driven atmospheric chemistry generate HCN, which is then trapped and concentrated on mineral-bearing surface waters.\",\n      \"reasoning\": \"The literature report specifically supports atmospheric discharge/volcanic cloud production of HCN as the defensible source of cyanide, not formate-plus-ammonia photochemistry. TiO2 and clays are included as surface mineral agents for photochemical processing and concentration in accord with the required schema (Miller, 1953; Miyakawa et al., 2002; Stribling & Miller, 1987; Patel et al., 2015).\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Surface photochemical formaldehyde production\",\n      \"inputs\": [\"mol_001\"],\n      \"outputs\": [\"mol_008\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO2\",\n        \"aqueous\": \"true\",\n        \"other\": \"UV-irradiated shallow pools; photochemical fixation and concentration\"\n      },\n      \"mechanism\": \"Photochemical reduction/fixation processes generate formaldehyde, which accumulates in evaporitic settings and feeds sugar-forming reactions.\",\n      \"reasoning\": \"The report explicitly recognizes atmospheric/photochemical surface environments as sources of aldehydes such as formaldehyde. This avoids the weaker unsupported hydrothermal formaldehyde/glycolaldehyde route criticized previously (Miller, 1953; Ritson & Sutherland, 2012; Patel et al., 2015).\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Surface formose initiation to glycolaldehyde and glyceraldehyde\",\n      \"inputs\": [\"mol_008\"],\n      \"outputs\": [\"mol_009\", \"mol_010\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"borate minerals and clay surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"evaporitic pools; wet-dry concentration; anoxic\"\n      },\n      \"mechanism\": \"Formose-type carbonyl coupling yields low-order sugars; borate helps stabilize sugar products and suppresses scrambling.\",\n      \"reasoning\": \"The report identifies erythrose as formose-derived and specifically notes glycolaldehyde and glyceraldehyde as key small sugar precursors in cyanosulfidic systems; borate stabilization of sugars is a standard geochemical constraint for such networks (Benner et al., 2012; Ricardo et al., 2004; Patel et al., 2015).\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"Aldol extension to erythrose\",\n      \"inputs\": [\"mol_009\", \"mol_010\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"borate minerals and clay surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"mildly evaporative pools; sugar stabilization required\"\n      },\n      \"mechanism\": \"Aldol-type coupling of glycolaldehyde and glyceraldehyde generates the tetrose erythrose.\",\n      \"reasoning\": \"The Shen-Or\u00f3 route requires erythrose, and the report states that erythrose is produced through formose chemistry. This reaction operationalizes that requirement while acknowledging the known issue that erythrose is a minority, fragile product best aided by mineral buffering and concentration (Shen et al., 1987; Ricardo et al., 2004; Benner et al., 2012).\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"Surface formation of formamidine from HCN and ammonia\",\n      \"inputs\": [\"mol_006\", \"mol_007\"],\n      \"outputs\": [\"mol_005\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"clay concentration surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"concentrated pools; anoxic; limited residence time because of hydrolytic lability\"\n      },\n      \"mechanism\": \"HCN undergoes ammonia addition to an amidine pool; concentration on mineral surfaces helps transient accumulation of formamidine.\",\n      \"reasoning\": \"The report explicitly identifies formamidine as formed from HCN and NH3 but also emphasizes its hydrolytic instability as the major bottleneck. This reaction is therefore literature-grounded but kinetically fragile, and mineral concentration is invoked to address the reported challenge without overstating robustness (Shen et al., 1987; Or\u00f3, 1961; review summary in the supplied report).\"\n    },\n    {\n      \"id\": \"rxn_011\",\n      \"name\": \"Shen-Or\u00f3 condensation of erythrose and formamidine to imidazole-4-acetaldehyde\",\n      \"inputs\": [\"mol_011\", \"mol_005\"],\n      \"outputs\": [\"mol_016\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\", \"borate minerals (colemanite/ulexite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral concentration surfaces; borate buffering of sugars\",\n        \"aqueous\": \"true\",\n        \"other\": \"concentrated aqueous pools; Amadori-type rearrangement; anoxic\"\n      },\n      \"mechanism\": \"Erythrose condenses with formamidine, likely through an aminoaldose-to-aminoketose rearrangement, enabling cyclization to the imidazole ring and formation of imidazole-4-acetaldehyde.\",\n      \"reasoning\": \"This is the key literature-established proximal step in direct prebiotic histidine synthesis. The supplied report identifies Shen, Or\u00f3, and Miller as showing that erythrose plus formamidine gives imidazole-4-acetaldehyde via an Amadori-type rearrangement, making this the most important validated entry to histidine chemistry (Shen et al., 1987; Or\u00f3 & Shen, 1980s as summarized in the report).\"\n    },\n    {\n      \"id\": \"rxn_012\",\n      \"name\": \"One-pot Strecker conversion of imidazole-4-acetaldehyde to histidine aminonitrile\",\n      \"inputs\": [\"mol_016\", \"mol_006\", \"mol_007\"],\n      \"outputs\": [\"mol_017\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"clay and phosphate mineral surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"classical Strecker conditions in concentrated aqueous solution\"\n      },\n      \"mechanism\": \"Imine formation from the aldehyde and ammonia is trapped by cyanide to give the alpha-aminonitrile precursor of histidine.\",\n      \"reasoning\": \"The Shen-Or\u00f3 one-pot synthesis specifically converts imidazole-4-acetaldehyde to histidine through Strecker chemistry with HCN and NH3. Clay-assisted concentration and Strecker plausibility are supported by prebiotic amino-acid chemistry, though the direct histidine demonstration derives from the Shen-Or\u00f3 work (Shen et al., 1987; Miller, 1957; review summary in the supplied report).\"\n    },\n    {\n      \"id\": \"rxn_013\",\n      \"name\": \"Hydrolysis of histidine aminonitrile to histidine\",\n      \"inputs\": [\"mol_017\"],\n      \"outputs\": [\"mol_018\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": null,\n        \"aqueous\": \"true\",\n        \"other\": \"prolonged aqueous hydrolysis during geothermal cycling\"\n      },\n      \"mechanism\": \"Sequential nitrile hydration and hydrolysis produce the alpha-amino acid histidine.\",\n      \"reasoning\": \"Hydrolysis of Strecker aminonitriles to amino acids is the accepted final step in classical amino-acid synthesis and is implicit in the Shen-Or\u00f3 histidine synthesis that achieved ~3.5% overall yield from erythrose (Shen et al., 1987; Strecker, 1850; review summary in the supplied report).\"\n    },\n    {\n      \"id\": \"rxn_014\",\n      \"name\": \"Cyanosulfidic formation of cyanamide from HCN-derived nitrogen chemistry\",\n      \"inputs\": [\"mol_006\", \"mol_007\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (stibnite/molybdenite)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"sulfide minerals under UV photoredox settings\",\n        \"aqueous\": \"true\",\n        \"other\": \"cyanosulfidic pools; H2S/UV context; anoxic\"\n      },\n      \"mechanism\": \"HCN-derived nitrogen chemistry under sulfide-assisted photoredox conditions furnishes cyanamide as a reactive N-rich condensant.\",\n      \"reasoning\": \"The supplied report identifies cyanamide as a versatile prebiotic reagent within Sutherland-style cyanosulfidic chemistry, though exact microsteps can vary by network. This node is included to connect the literature-supported 2-aminoimidazole branch and activation chemistry to the histidine network (Patel et al., 2015; Powner et al., 2009; Sutherland, 2016).\"\n    },\n    {\n      \"id\": \"rxn_015\",\n      \"name\": \"Phosphate-buffered synthesis of 2-aminoimidazole from glycolaldehyde and cyanamide\",\n      \"inputs\": [\"mol_009\", \"mol_012\", \"mol_007\", \"mol_023\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"phosphate minerals (apatite/struvite)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"inorganic phosphate buffer/catalyst\",\n        \"aqueous\": \"true\",\n        \"other\": \"acidic to near-neutral pH 5-7; high ammonium concentrations\"\n      },\n      \"mechanism\": \"Glycolaldehyde and cyanamide undergo phosphate-buffered cyclization to 2-aminoimidazole under ammonium-rich conditions.\",\n      \"reasoning\": \"This step directly follows the literature summary: 2-aminoimidazole forms from glycolaldehyde and cyanamide in the presence of inorganic phosphate and ammonium ions at pH about 5-7. It is included as a supported imidazole-pool branch, not as a direct proven route to histidine (Sutherland group work summarized in the report; Mariani et al., 2018; Patel et al., 2015).\"\n    },\n    {\n      \"id\": \"rxn_016\",\n      \"name\": \"HCN oligomerization to AIC-like purine intermediate pool\",\n      \"inputs\": [\"mol_006\", \"mol_007\"],\n      \"outputs\": [\"mol_014\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral concentration surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"HCN oligomerization in concentrated pools; anoxic\"\n      },\n      \"mechanism\": \"HCN oligomerization and rearrangement generate aminoimidazole-carboxamide heterocycles within the purine precursor pool.\",\n      \"reasoning\": \"The report states that AIC and related purine intermediates can arise abiotically from HCN and NH3 and that this chemistry demonstrates convergence between purine and histidine heterocycle pools. This is treated strictly as contextual heterocycle support rather than a demonstrated direct route to histidine (Or\u00f3, 1961; Ferris et al., 1978; review summary in the supplied report).\"\n    },\n    {\n      \"id\": \"rxn_017\",\n      \"name\": \"Assembly of AICAR from AIC with phosphate-ribose context\",\n      \"inputs\": [\"mol_014\", \"mol_011\", \"mol_023\"],\n      \"outputs\": [\"mol_015\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": null,\n        \"aqueous\": \"true\",\n        \"other\": \"speculative ribosylation/phosphorylation in concentrated pools\"\n      },\n      \"mechanism\": \"Carboxamide-imidazole heterocycle is incorporated into a ribose-phosphate context to generate AICAR-like nucleotide material.\",\n      \"reasoning\": \"The report emphasizes the biological and conceptual convergence between histidine and purine biosynthesis through AICAR but does not present a robust fully prebiotic assembly route under simple conditions. This step is therefore explicitly speculative and is included only to represent the literature-discussed convergence node rather than a validated direct histidine path (White, 1976; review summary in the supplied report).\"\n    },\n    {\n      \"id\": \"rxn_018\",\n      \"name\": \"Peptide condensation of histidine to histidyl-histidine\",\n      \"inputs\": [\"mol_018\", \"mol_012\"],\n      \"outputs\": [\"mol_019\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"300-360K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"cyanamide condensing chemistry\",\n        \"aqueous\": \"false\",\n        \"other\": \"wet-dry cycling in prebiotic pools\"\n      },\n      \"mechanism\": \"Cyanamide-mediated dehydration links histidine monomers into the His-His dipeptide.\",\n      \"reasoning\": \"The report explicitly notes that histidyl-histidine has been synthesized prebiotically in up to 14.4% yield using cyanamide, supporting downstream functionalization of the histidine product pool after monomer formation (Rode and coworkers as summarized in the report; Plankensteiner et al., 2004).\"\n    }\n  ],\n  \"pathways\": [\n    {\n      \"pathway_id\": \"P1\",\n      \"name\": \"Canonical Shen-Or\u00f3 one-pot histidine synthesis\",\n      \"description\": \"Direct literature-established route: surface-generated erythrose and formamidine condense to imidazole-4-acetaldehyde, then Strecker chemistry and hydrolysis give histidine.\",\n      \"reaction_sequence\": [\"rxn_006\", \"rxn_007\", \"rxn_008\", \"rxn_009\", \"rxn_010\", \"rxn_011\", \"rxn_012\", \"rxn_013\"],\n      \"key_intermediates\": [\"mol_011\", \"mol_005\", \"mol_016\", \"mol_017\"]\n    },\n    {\n      \"pathway_id\": \"P2\",\n      \"name\": \"Borate-stabilized sugar route to Shen-Or\u00f3 core\",\n      \"description\": \"A surface sugar pathway emphasizing borate-assisted stabilization of formose products before entry into the validated histidine-forming core.\",\n      \"reaction_sequence\": [\"rxn_007\", \"rxn_008\", \"rxn_009\", \"rxn_010\", \"rxn_011\", \"rxn_012\", \"rxn_013\"],\n      \"key_intermediates\": [\"mol_009\", \"mol_010\", \"mol_011\", \"mol_016\"]\n    },\n    {\n      \"pathway_id\": \"P3\",\n      \"name\": \"Atmospheric HCN capture route to histidine\",\n      \"description\": \"Volcanic discharge and UV-associated HCN production supply both formamidine precursor chemistry and Strecker cyanide in concentrated surface pools.\",\n      \"reaction_sequence\": [\"rxn_006\", \"rxn_010\", \"rxn_011\", \"rxn_012\", \"rxn_013\"],\n      \"key_intermediates\": [\"mol_006\", \"mol_005\", \"mol_016\", \"mol_017\"]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"Hydrothermal reduced-carbon support to surface histidine route\",\n      \"description\": \"Vent chemistry supplies reduced carbon hubs that feed into surface aldehyde/sugar chemistry, which then enters the Shen-Or\u00f3 histidine sequence.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_007\", \"rxn_008\", \"rxn_009\", \"rxn_010\", \"rxn_011\", \"rxn_012\", \"rxn_013\"],\n      \"key_intermediates\": [\"mol_003\", \"mol_004\", \"mol_011\", \"mol_016\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"Hydrothermal pyruvate branch feeding aldehyde-rich surface pools\",\n      \"description\": \"Pyruvate formed in hydrothermal settings decarboxylates to acetaldehyde while parallel surface sugar chemistry produces erythrose for the direct histidine pathway.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_005\", \"rxn_007\", \"rxn_008\", \"rxn_009\", \"rxn_006\", \"rxn_010\", \"rxn_011\", \"rxn_012\", \"rxn_013\"],\n      \"key_intermediates\": [\"mol_020\", \"mol_022\", \"mol_011\", \"mol_016\"]\n    },\n    {\n      \"pathway_id\": \"P6\",\n      \"name\": \"HCN-rich surface pool route with independent sugar and amidine convergence\",\n      \"description\": \"Independent formation of erythrose and formamidine in the same evaporitic setting converges on imidazole-4-acetaldehyde and then histidine.\",\n      \"reaction_sequence\": [\"rxn_007\", \"rxn_008\", \"rxn_009\", \"rxn_006\", \"rxn_010\", \"rxn_011\", \"rxn_012\", \"rxn_013\"],\n      \"key_intermediates\": [\"mol_011\", \"mol_005\", \"mol_016\", \"mol_017\"]\n    },\n    {\n      \"pathway_id\": \"P7\",\n      \"name\": \"Cyanosulfidic imidazole-pool supported histidine synthesis\",\n      \"description\": \"2-Aminoimidazole is produced in the same geochemical system as histidine precursors, supporting an imidazole-rich chemical environment before the direct Shen-Or\u00f3 route completes histidine synthesis.\",\n      \"reaction_sequence\": [\"rxn_006\", \"rxn_014\", \"rxn_007\", \"rxn_008\", \"rxn_015\", \"rxn_009\", \"rxn_010\", \"rxn_011\", \"rxn_012\", \"rxn_013\"],\n      \"key_intermediates\": [\"mol_012\", \"mol_013\", \"mol_011\", \"mol_016\"]\n    },\n    {\n      \"pathway_id\": \"P8\",\n      \"name\": \"Purine-linked heterocycle-pool convergence supporting histidine synthesis\",\n      \"description\": \"HCN oligomerization creates AIC-like intermediates alongside the direct erythrose/formamidine route, representing literature-noted molecular convergence between purines and histidine chemistry without asserting unsupported salvage steps.\",\n      \"reaction_sequence\": [\"rxn_006\", \"rxn_016\", \"rxn_007\", \"rxn_008\", \"rxn_009\", \"rxn_010\", \"rxn_011\", \"rxn_012\", \"rxn_013\"],\n      \"key_intermediates\": [\"mol_014\", \"mol_011\", \"mol_016\", \"mol_017\"]\n    },\n    {\n      \"pathway_id\": \"P9\",\n      \"name\": \"AICAR-context network leading to histidine product pool\",\n      \"description\": \"AICAR formation is represented as a speculative biochemical convergence point in the broader imidazole network, while histidine still forms through the validated Shen-Or\u00f3 core.\",\n      \"reaction_sequence\": [\"rxn_006\", \"rxn_016\", \"rxn_017\", \"rxn_007\", \"rxn_008\", \"rxn_009\", \"rxn_010\", \"rxn_011\", \"rxn_012\", \"rxn_013\"],\n      \"key_intermediates\": [\"mol_014\", \"mol_015\", \"mol_011\", \"mol_016\"]\n    },\n    {\n      \"pathway_id\": \"P10\",\n      \"name\": \"Post-synthesis peptide elaboration of histidine\",\n      \"description\": \"After direct monomer synthesis by the Shen-Or\u00f3 route, histidine enters a biochemical stage where cyanamide-assisted condensation forms histidyl-histidine.\",\n      \"reaction_sequence\": [\"rxn_006\", \"rxn_007\", \"rxn_008\", \"rxn_009\", \"rxn_010\", \"rxn_011\", \"rxn_012\", \"rxn_013\", \"rxn_018\"],\n      \"key_intermediates\": [\"mol_016\", \"mol_017\", \"mol_018\", \"mol_019\"]\n    }\n  ],\n  \"hub_molecules\": [\"mol_006\", \"mol_009\", \"mol_011\", \"mol_016\", \"mol_017\"],\n  \"convergence_points\": [\n    {\n      \"molecule_id\": \"mol_006\",\n      \"incoming_reactions\": [\"rxn_006\"],\n      \"outgoing_reactions\": [\"rxn_010\", \"rxn_012\", \"rxn_014\", \"rxn_016\"]\n    },\n    {\n      \"molecule_id\": \"mol_009\",\n      \"incoming_reactions\": [\"rxn_008\"],\n      \"outgoing_reactions\": [\"rxn_009\", \"rxn_015\"]\n    },\n    {\n      \"molecule_id\": \"mol_011\",\n      \"incoming_reactions\": [\"rxn_009\"],\n      \"outgoing_reactions\": [\"rxn_011\", \"rxn_017\"]\n    },\n    {\n      \"molecule_id\": \"mol_016\",\n      \"incoming_reactions\": [\"rxn_011\"],\n      \"outgoing_reactions\": [\"rxn_012\"]\n    },\n    {\n      \"molecule_id\": \"mol_017\",\n      \"incoming_reactions\": [\"rxn_012\"],\n      \"outgoing_reactions\": [\"rxn_013\"]\n    }\n  ]\n}", "parsed_response": {"target_molecule": "Histidine", "overall_strategy": "This network centers the best-supported direct prebiotic route to histidine: the Shen-Or\u00f3-Miller sequence in which erythrose and formamidine condense to imidazole-4-acetaldehyde, followed by Strecker conversion to a histidine aminonitrile and hydrolysis to histidine. To satisfy network completeness and environmental interconnection, hydrothermal chemistry supplies reduced carbon feedstocks such as formate, acetate, pyruvate, and acetaldehyde, while surface chemistry supplies HCN-derived nitrogen chemistry, glycolaldehyde/glyceraldehyde/erythrose sugars, formamidine, cyanamide, and imidazole-rich heterocycle pools. Ten pathway variants are represented as convergent routes into the same validated Shen-Or\u00f3 core, differing in how erythrose, formamidine, HCN, ammonia, and imidazole-4-acetaldehyde become available. Purine-linked and 2-aminoimidazole branches are included only as literature-grounded heterocycle-pool support and contextual convergence, not as unsupported direct salvage conversions to histidine.", "molecules": [{"id": "mol_001", "formula": "CO2", "iupac_name": "carbon dioxide", "common_name": "carbon dioxide", "inchi": "InChI=1S/CO2/c2-1-3", "role": "starting", "environment_formed": null}, {"id": "mol_002", "formula": "H2", "iupac_name": "molecular hydrogen", "common_name": "hydrogen", "inchi": "InChI=1S/H2/h1H", "role": "starting", "environment_formed": null}, {"id": "mol_003", "formula": "CH2O2", "iupac_name": "methanoic acid", "common_name": "formate/formic acid", "inchi": "InChI=1S/CH2O2/c2-1-3/h1H,(H,2,3)", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_004", "formula": "C2H4O2", "iupac_name": "ethanoic acid", "common_name": "acetate/acetic acid", "inchi": "InChI=1S/C2H4O2/c1-2(3)4/h1H3,(H,3,4)", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_005", "formula": "CH4N2", "iupac_name": "methanimidamide", "common_name": "formamidine", "inchi": "InChI=1S/CH4N2/c2-1-3/h1H,(H3,2,3)", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_006", "formula": "HCN", "iupac_name": "hydrogen cyanide", "common_name": "HCN", "inchi": "InChI=1S/CHN/c1-2/h1H", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_007", "formula": "H3N", "iupac_name": "azane", "common_name": "ammonia", "inchi": "InChI=1S/H3N/h1H3", "role": "hub_intermediate", "environment_formed": null}, {"id": "mol_008", "formula": "CH2O", "iupac_name": "methanal", "common_name": "formaldehyde", "inchi": "InChI=1S/CH2O/c1-2/h1H2", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_009", "formula": "C2H4O2", "iupac_name": "2-hydroxyethanal", "common_name": "glycolaldehyde", "inchi": "InChI=1S/C2H4O2/c3-1-2-4/h1,3H,2H2", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_010", "formula": "C3H6O3", "iupac_name": "2,3-dihydroxypropanal", "common_name": "glyceraldehyde", "inchi": "InChI=1S/C3H6O3/c4-1-3(6)2-5/h1,3,5-6H,2H2", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_011", "formula": "C4H8O4", "iupac_name": "2,3,4-trihydroxybutanal", "common_name": "erythrose", "inchi": "InChI=1S/C4H8O4/c5-1-2(6)3(7)4(8)9/h1-4,6-9H", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_012", "formula": "CN2H2", "iupac_name": "cyanamide", "common_name": "cyanamide", "inchi": "InChI=1S/CH2N2/c2-1-3/h(H2,2,3)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_013", "formula": "C3H5N3", "iupac_name": "2-amino-1H-imidazole", "common_name": "2-aminoimidazole", "inchi": "InChI=1S/C3H5N3/c4-3-5-1-2-6-3/h1-2H,(H3,4,5,6)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_014", "formula": "C4H5N3O", "iupac_name": "5-amino-1H-imidazole-4-carboxamide", "common_name": "AIC", "inchi": "InChI=1S/C4H5N5O/c5-2-3(4(6)10)9-1-8-2/h1H,(H2,6,10)(H3,5,8,9)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_015", "formula": "C9H14N4O8P", "iupac_name": "5-amino-1-(5-phosphono-beta-D-ribofuranosyl)-1H-imidazole-4-carboxamide", "common_name": "AICAR", "inchi": null, "role": "intermediate", "environment_formed": "Biochemical"}, {"id": "mol_016", "formula": "C5H6N2O", "iupac_name": "1H-imidazole-4-ethanal", "common_name": "imidazole-4-acetaldehyde", "inchi": "InChI=1S/C5H6N2O/c8-2-1-5-3-6-4-7-5/h3-4H,1-2H2,(H,6,7)", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_017", "formula": "C6H7N4", "iupac_name": "2-amino-3-(1H-imidazol-4-yl)propanenitrile", "common_name": "histidine aminonitrile", "inchi": null, "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_018", "formula": "C6H9N3O2", "iupac_name": "2-amino-3-(1H-imidazol-4-yl)propanoic acid", "common_name": "histidine", "inchi": "InChI=1S/C6H9N3O2/c7-5(6(10)11)1-4-2-8-3-9-4/h2-3,5H,1,7H2,(H,8,9)(H,10,11)", "role": "target", "environment_formed": "Biochemical"}, {"id": "mol_019", "formula": "C6H10N4O3", "iupac_name": "2-amino-3-(1H-imidazol-4-yl)propanoyl-3-(1H-imidazol-4-yl)propanic acid", "common_name": "histidyl-histidine", "inchi": null, "role": "intermediate", "environment_formed": "Biochemical"}, {"id": "mol_020", "formula": "C3H4O3", "iupac_name": "2-oxopropanoic acid", "common_name": "pyruvate", "inchi": "InChI=1S/C3H4O3/c1-2(4)3(5)6/h1H3,(H,5,6)", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_021", "formula": "C3H7NO2", "iupac_name": "2-aminopropanoic acid", "common_name": "alanine", "inchi": "InChI=1S/C3H7NO2/c1-2(4)3(5)6/h2H,4H2,1H3,(H,5,6)", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_022", "formula": "C2H4O", "iupac_name": "ethanal", "common_name": "acetaldehyde", "inchi": "InChI=1S/C2H4O/c1-2-3/h2H,1H3", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_023", "formula": "H3PO4", "iupac_name": "phosphoric acid", "common_name": "phosphate", "inchi": "InChI=1S/H3O4P/c1-5(2,3)4/h(H3,1,2,3,4)", "role": "starting", "environment_formed": null}], "reactions": [{"id": "rxn_001", "name": "Hydrothermal CO2 reduction to formate", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_003"], "environment": "Hydrothermal", "agents": ["greigite (Fe3S4)", "mackinawite (FeS)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "greigite and mackinawite", "aqueous": "true", "other": "alkaline vent conditions; anoxic; H2-rich"}, "mechanism": "Mineral-surface reduction of CO2 by H2 gives formate as an early reduced C1 product on Fe-S phases.", "reasoning": "Fe-S vent catalysis of CO2 reduction to formate is consistent with iron-sulfur world and vent simulation literature; this step provides a hydrothermal reduced-carbon feedstock that can move into surface chemistry, while not overclaiming direct histidine formation in vents (Huber & Wachtershauser, 1997; Russell & Martin, 2004; Preiner et al., 2020)."}, {"id": "rxn_002", "name": "Hydrothermal carbon fixation to acetate", "inputs": ["mol_001", "mol_002", "mol_003"], "outputs": ["mol_004"], "environment": "Hydrothermal", "agents": ["greigite (Fe3S4)", "magnetite (Fe3O4)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "greigite and magnetite", "aqueous": "true", "other": "alkaline vent microcompartments; anoxic"}, "mechanism": "Sequential CO2 reduction and C-C bond formation on Fe-S/oxide surfaces generates acetate as an acetyl-thioester analogue endpoint.", "reasoning": "Acetate production from vent-style CO2/H2 chemistry is widely discussed in metabolism-first work and supports hydrothermal feeding of surface organosynthesis without asserting unsupported selectivity to histidine intermediates (Huber & Wachtershauser, 1997; Russell & Hall, 1997; Preiner et al., 2020)."}, {"id": "rxn_003", "name": "Hydrothermal pyruvate synthesis from CO2 and H2", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_020"], "environment": "Hydrothermal", "agents": ["magnetite (Fe3O4)", "greigite (Fe3S4)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "magnetite and greigite", "aqueous": "true", "other": "subseafloor hydrothermal setting; anoxic"}, "mechanism": "Mineral-catalyzed reductive carbon fixation extends C1 chemistry toward a central alpha-keto acid hub.", "reasoning": "Pyruvate is a recognized prebiotic metabolic hub in hydrothermal analog experiments and provides a dense network connector to amino acid chemistry and aldehyde generation (Keller et al., 2014; Muchowska et al., 2019; Preiner et al., 2020)."}, {"id": "rxn_004", "name": "Hydrothermal reductive amination of pyruvate to alanine", "inputs": ["mol_020", "mol_007", "mol_002"], "outputs": ["mol_021"], "environment": "Hydrothermal", "agents": ["pyrite (FeS2)", "elemental iron (Fe0)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "pyrite and Fe0", "aqueous": "true", "other": "anoxic mineral surfaces"}, "mechanism": "Imine formation between pyruvate and ammonia followed by mineral-assisted reduction yields alanine.", "reasoning": "Reductive amination of alpha-keto acids under reducing mineral conditions is a plausible hydrothermal route to simple amino acids and helps connect alpha-keto acid hubs to amino acid pools (Huber & Wachtershauser, 2006; Muchowska et al., 2019)."}, {"id": "rxn_005", "name": "Thermal decarboxylation of pyruvate to acetaldehyde", "inputs": ["mol_020"], "outputs": ["mol_022", "mol_001"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "350-400K", "pressure": "1 atm to moderate", "catalyst": null, "aqueous": "true", "other": "geothermal heating; anoxic"}, "mechanism": "Thermal loss of CO2 from pyruvate furnishes acetaldehyde, linking hydrothermal keto-acid chemistry to surface Strecker-style feedstocks.", "reasoning": "Pyruvate decarboxylation is explicitly listed as a plausible prebiotic thermal transformation and is used here only as a connector from hydrothermal carbon fixation to broader aldehyde/amino acid chemistry (Copley et al., 2007; Muchowska et al., 2019)."}, {"id": "rxn_006", "name": "Atmospheric/surface generation of HCN feedstock", "inputs": ["mol_001", "mol_007"], "outputs": ["mol_006"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "montmorillonite (clay)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "TiO2 and clay concentration surfaces", "aqueous": "false", "other": "volcanic discharge/photochemical context; UV irradiation; feedstock capture in pools"}, "mechanism": "High-energy atmospheric discharge and UV-driven atmospheric chemistry generate HCN, which is then trapped and concentrated on mineral-bearing surface waters.", "reasoning": "The literature report specifically supports atmospheric discharge/volcanic cloud production of HCN as the defensible source of cyanide, not formate-plus-ammonia photochemistry. TiO2 and clays are included as surface mineral agents for photochemical processing and concentration in accord with the required schema (Miller, 1953; Miyakawa et al., 2002; Stribling & Miller, 1987; Patel et al., 2015)."}, {"id": "rxn_007", "name": "Surface photochemical formaldehyde production", "inputs": ["mol_001"], "outputs": ["mol_008"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "montmorillonite (clay)"], "conditions": {"temperature": "300-340K", "pressure": "1 atm", "catalyst": "TiO2", "aqueous": "true", "other": "UV-irradiated shallow pools; photochemical fixation and concentration"}, "mechanism": "Photochemical reduction/fixation processes generate formaldehyde, which accumulates in evaporitic settings and feeds sugar-forming reactions.", "reasoning": "The report explicitly recognizes atmospheric/photochemical surface environments as sources of aldehydes such as formaldehyde. This avoids the weaker unsupported hydrothermal formaldehyde/glycolaldehyde route criticized previously (Miller, 1953; Ritson & Sutherland, 2012; Patel et al., 2015)."}, {"id": "rxn_008", "name": "Surface formose initiation to glycolaldehyde and glyceraldehyde", "inputs": ["mol_008"], "outputs": ["mol_009", "mol_010"], "environment": "Surface", "agents": ["borate minerals (colemanite/ulexite)", "montmorillonite (clay)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "borate minerals and clay surfaces", "aqueous": "true", "other": "evaporitic pools; wet-dry concentration; anoxic"}, "mechanism": "Formose-type carbonyl coupling yields low-order sugars; borate helps stabilize sugar products and suppresses scrambling.", "reasoning": "The report identifies erythrose as formose-derived and specifically notes glycolaldehyde and glyceraldehyde as key small sugar precursors in cyanosulfidic systems; borate stabilization of sugars is a standard geochemical constraint for such networks (Benner et al., 2012; Ricardo et al., 2004; Patel et al., 2015)."}, {"id": "rxn_009", "name": "Aldol extension to erythrose", "inputs": ["mol_009", "mol_010"], "outputs": ["mol_011"], "environment": "Surface", "agents": ["borate minerals (colemanite/ulexite)", "montmorillonite (clay)"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "borate minerals and clay surfaces", "aqueous": "true", "other": "mildly evaporative pools; sugar stabilization required"}, "mechanism": "Aldol-type coupling of glycolaldehyde and glyceraldehyde generates the tetrose erythrose.", "reasoning": "The Shen-Or\u00f3 route requires erythrose, and the report states that erythrose is produced through formose chemistry. This reaction operationalizes that requirement while acknowledging the known issue that erythrose is a minority, fragile product best aided by mineral buffering and concentration (Shen et al., 1987; Ricardo et al., 2004; Benner et al., 2012)."}, {"id": "rxn_010", "name": "Surface formation of formamidine from HCN and ammonia", "inputs": ["mol_006", "mol_007"], "outputs": ["mol_005"], "environment": "Surface", "agents": ["montmorillonite (clay)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "clay concentration surfaces", "aqueous": "true", "other": "concentrated pools; anoxic; limited residence time because of hydrolytic lability"}, "mechanism": "HCN undergoes ammonia addition to an amidine pool; concentration on mineral surfaces helps transient accumulation of formamidine.", "reasoning": "The report explicitly identifies formamidine as formed from HCN and NH3 but also emphasizes its hydrolytic instability as the major bottleneck. This reaction is therefore literature-grounded but kinetically fragile, and mineral concentration is invoked to address the reported challenge without overstating robustness (Shen et al., 1987; Or\u00f3, 1961; review summary in the supplied report)."}, {"id": "rxn_011", "name": "Shen-O
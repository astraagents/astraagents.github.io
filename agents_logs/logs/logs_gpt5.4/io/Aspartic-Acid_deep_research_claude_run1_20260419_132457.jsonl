ChI=1S/C4H4O5/c5-2(4(8)9)1-3(6)7/h1H2,(H,6,7)(H,8,9)/p-1\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_011\",\n      \"formula\": \"C4H6O4\",\n      \"iupac_name\": \"2-hydroxybutanedioic acid\",\n      \"common_name\": \"malic acid\",\n      \"inchi\": \"InChI=1S/C4H6O5/c5-2(4(8)9)1-3(6)7/h2,5H,1H2,(H,6,7)(H,8,9)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_012\",\n      \"formula\": \"C4H2O4\",\n      \"iupac_name\": \"(E)-but-2-enedioic acid\",\n      \"common_name\": \"fumaric acid\",\n      \"inchi\": \"InChI=1S/C4H4O4/c5-3(6)1-2-4(7)8/h1-2H,(H,5,6)(H,7,8)/b2-1+\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_013\",\n      \"formula\": \"C4H7NO4\",\n      \"iupac_name\": \"2-aminobutanedioic acid\",\n      \"common_name\": \"aspartic acid\",\n      \"inchi\": \"InChI=1S/C4H7NO4/c5-2(4(8)9)1-3(6)7/h2H,1,5H2,(H,6,7)(H,8,9)\",\n      \"role\": \"target\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_014\",\n      \"formula\": \"C5H8N2O5\",\n      \"iupac_name\": \"2-[(carbamoyl)amino]butanedioic acid\",\n      \"common_name\": \"N-carbamoyl aspartate\",\n      \"inchi\": \"InChI=1S/C5H8N2O5/c6-5(12)7-2(4(10)11)1-3(8)9/h2H,1H2,(H,7,12)(H,8,9)(H,10,11)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_015\",\n      \"formula\": \"C4H4N2O2\",\n      \"iupac_name\": \"3,4-dihydropyrimidine-2,4-dione\",\n      \"common_name\": \"dihydroorotate\",\n      \"inchi\": \"InChI=1S/C4H4N2O2/c7-3-1-2-5-4(8)6-3/h1-2H2,(H2,5,6,7,8)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_016\",\n      \"formula\": \"C4H4N4\",\n      \"iupac_name\": \"2,3-diaminobut-2-enedinitrile\",\n      \"common_name\": \"DAMN\",\n      \"inchi\": \"InChI=1S/C4H4N4/c5-1-3(7)4(8)2-6/h7-8H2\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_017\",\n      \"formula\": \"C3HN\",\n      \"iupac_name\": \"prop-2-ynenitrile\",\n      \"common_name\": \"cyanoacetylene\",\n      \"inchi\": \"InChI=1S/C3HN/c1-2-3-4/h1H\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_018\",\n      \"formula\": \"C3H7NO2\",\n      \"iupac_name\": \"2-aminopropanoic acid\",\n      \"common_name\": \"alanine\",\n      \"inchi\": \"InChI=1S/C3H7NO2/c1-2(4)3(5)6/h2H,4H2,1H3,(H,5,6)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_019\",\n      \"formula\": \"C4H6N2O2\",\n      \"iupac_name\": \"2,5-dioxopyrrolidine-2-carboxamide\",\n      \"common_name\": \"succinimide-like aspartate cyclization intermediate\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_020\",\n      \"formula\": \"NH2OH\",\n      \"iupac_name\": \"hydroxylamine\",\n      \"common_name\": \"hydroxylamine\",\n      \"inchi\": \"InChI=1S/H3NO/h1H3\",\n      \"role\": \"starting\",\n      \"environment_formed\": null\n    },\n    {\n      \"id\": \"mol_021\",\n      \"formula\": \"C5H5N2O\",\n      \"iupac_name\": \"4-aminomethyl-3-hydroxy-5-hydroxymethyl-2-methylpyridine\",\n      \"common_name\": \"pyridoxamine\",\n      \"inchi\": null,\n      \"role\": \"starting\",\n      \"environment_formed\": null\n    },\n    {\n      \"id\": \"mol_022\",\n      \"formula\": \"CH4\",\n      \"iupac_name\": \"methane\",\n      \"common_name\": \"methane\",\n      \"inchi\": \"InChI=1S/CH4/h1H4\",\n      \"role\": \"starting\",\n      \"environment_formed\": null\n    },\n    {\n      \"id\": \"mol_023\",\n      \"formula\": \"H2S\",\n      \"iupac_name\": \"sulfane\",\n      \"common_name\": \"hydrogen sulfide\",\n      \"inchi\": \"InChI=1S/H2S/h1H2\",\n      \"role\": \"starting\",\n      \"environment_formed\": null\n    },\n    {\n      \"id\": \"mol_024\",\n      \"formula\": \"C2H5NO2\",\n      \"iupac_name\": \"aminoacetic acid\",\n      \"common_name\": \"glycine\",\n      \"inchi\": \"InChI=1S/C2H5NO2/c3-1-2(4)5/h1,3H2,(H,4,5)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_025\",\n      \"formula\": \"C6H10N2O5\",\n      \"iupac_name\": \"2-aminoacetylamino-butanedioic acid\",\n      \"common_name\": \"glycyl-aspartic acid\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"Greigite-catalyzed reduction of carbon dioxide to formate\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_006\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe3S4)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"313-363K\",\n        \"pressure\": \"alkaline vent to elevated hydrothermal pressure\",\n        \"catalyst\": \"greigite and mackinawite\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline vent-like pH 9-11, H2-rich serpentinization fluids\"\n      },\n      \"mechanism\": \"Surface-mediated CO2 hydrogenation on Fe-S minerals generates reduced one-carbon species, with formate as an early fixed-carbon product.\",\n      \"reasoning\": \"Alkaline vent models and mineral catalysis support Fe-S-mediated CO2 reduction to small organics; greigite and related Fe-S phases are central to primordial carbon fixation (Preiner et al., 2020; Santos-Carballal et al., 2018; Kitadai, 2015).\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Hydrothermal Fe0-mediated protometabolic formation of pyruvate and glyoxylate from CO2\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_008\", \"mol_009\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"elemental iron (Fe0)\", \"magnetite (Fe3O4)\"],\n      \"conditions\": {\n        \"temperature\": \"303-373K\",\n        \"pressure\": \"35 bar\",\n        \"catalyst\": \"Fe0 with iron oxide surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic CO2-rich system; hydrothermal protometabolic CO2 fixation window\"\n      },\n      \"mechanism\": \"Reduced iron drives abiotic CO2 fixation through non-enzymatic network chemistry, yielding central keto-acid and aldehyde-acid intermediates including pyruvate and glyoxylate.\",\n      \"reasoning\": \"Fe0-driven CO2 fixation produces central metabolic intermediates under hydrothermal conditions and is the strongest literature-supported upstream route feeding oxaloacetate chemistry; glyoxylate and pyruvate are established nodes in non-enzymatic protometabolic networks (Muchowska et al., 2019; Varma et al., 2018; Muchowska, Varma & Moran, 2020).\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Aldol-like coupling of pyruvate and glyoxylate to oxaloacetate precursor pool\",\n      \"inputs\": [\"mol_008\", \"mol_009\"],\n      \"outputs\": [\"mol_010\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe3O4)\", \"greigite (Fe3S4)\"],\n      \"conditions\": {\n        \"temperature\": \"298-323K\",\n        \"pressure\": \"moderate to elevated\",\n        \"catalyst\": \"iron mineral surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"CO2-rich anoxic aqueous conditions; oxaloacetate treated as transient product in protometabolic network\"\n      },\n      \"mechanism\": \"Pyruvate and glyoxylate undergo C-C bond-forming chemistry through hydroxy-keto intermediates that feed into oxaloacetate formation as a transient \u03b1-keto dicarboxylate node.\",\n      \"reasoning\": \"The literature identifies glyoxylate-mediated access to oxaloacetate-equivalent chemistry as one of the best-supported prebiotic entries to OAA, though mechanistically via transient intermediates rather than a simple single-step biological analog; this reaction is a necessary network compression grounded in reported pyruvate-glyoxylate chemistry and flagged as a connected proxy for the Eschenmoser/Krishnamurthy-type route (Eschenmoser & Krishnamurthy, 2017; Muchowska, Varma & Moran, 2020).\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"Cu2+-catalyzed transamination of oxaloacetate to aspartate\",\n      \"inputs\": [\"mol_010\", \"mol_021\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"Cu2+\", null],\n      \"conditions\": {\n        \"temperature\": \"298-343K\",\n        \"pressure\": \"ambient to high pressure\",\n        \"catalyst\": \"1 mM Cu2+\",\n        \"aqueous\": \"true\",\n        \"other\": \"5-10 mM reactants, 50 mM NH4HCO3 buffer, pH 6-10, reaction within ~1 hour to outrun OAA decarboxylation\"\n      },\n      \"mechanism\": \"Metal-assisted pyridoxamine-mediated amino transfer converts the \u03b1-keto acid oxaloacetate into aspartate before extensive decarboxylation occurs.\",\n      \"reasoning\": \"This is the best documented non-enzymatic transamination route to aspartate, giving ~5% yield within 1 hour; the literature also emphasizes that OAA decarboxylation competes strongly and that pyridoxamine availability remains unresolved, so the route is included with that caveat (Harrison et al., 2023; Mayer et al., 2021; Dherbassy et al., 2023).\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"Bucherer-Bergs conversion of oxaloacetate to N-carbamoyl aspartate and dihydroorotate branch\",\n      \"inputs\": [\"mol_010\", \"mol_004\", \"mol_003\"],\n      \"outputs\": [\"mol_014\", \"mol_015\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"phosphate minerals (apatite/struvite)\", \"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"298-333K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"phosphate mineral surface concentration\",\n        \"aqueous\": \"true\",\n        \"other\": \"neutral to slightly basic pH; cyanide plus ammonium bicarbonate equivalent chemistry in evaporitic/concentrating pools\"\n      },\n      \"mechanism\": \"Oxaloacetate reacts with cyanide and ammonia/carbonate equivalents through Bucherer-Bergs chemistry to form N-carbamoyl aspartate, with branch access to dihydroorotate.\",\n      \"reasoning\": \"The Bucherer-Bergs pathway from \u03b1-keto acids is directly demonstrated for oxaloacetate and is one of the most important literature-prioritized routes because it links aspartate chemistry to pyrimidine synthesis; mineral surfaces are included here as concentrative agents to satisfy surface-network constraints, while the core transformation follows the documented aqueous chemistry (Pulletikurti et al., 2022).\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"Hydrolysis of N-carbamoyl aspartate to aspartic acid\",\n      \"inputs\": [\"mol_014\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [null, null],\n      \"conditions\": {\n        \"temperature\": \"298-343K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": null,\n        \"aqueous\": \"true\",\n        \"other\": \"mild aqueous hydrolytic conversion following Bucherer-Bergs sequence\"\n      },\n      \"mechanism\": \"Carbamoyl group hydrolysis releases free aspartic acid from N-carbamoyl aspartate.\",\n      \"reasoning\": \"This step completes the experimentally demonstrated \u03b1-keto-acid Bucherer-Bergs route to aspartate and retains direct continuity with the reported chemistry (Pulletikurti et al., 2022).\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Competing decarboxylation of oxaloacetate to pyruvate\",\n      \"inputs\": [\"mol_010\"],\n      \"outputs\": [\"mol_009\", \"mol_001\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [null, null],\n      \"conditions\": {\n        \"temperature\": \"298K and above\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": null,\n        \"aqueous\": \"true\",\n        \"other\": \"half-life ~1-2 h at 25C near neutral pH; accelerated by divalent metals\"\n      },\n      \"mechanism\": \"Spontaneous \u03b2-keto acid decarboxylation drains oxaloacetate to pyruvate, creating the major bottleneck in aspartate synthesis.\",\n      \"reasoning\": \"The OAA decarboxylation race is the central challenge in prebiotic aspartate chemistry and must be explicitly included; this competing pathway explains why alanine often appears instead of aspartate in OAA amination experiments (Guzman & Martin, 2008; Barge et al., 2019; Harrison et al., 2023).\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Hydrothermal reductive amination network yielding alanine from pyruvate as OAA-loss product\",\n      \"inputs\": [\"mol_009\", \"mol_003\", \"mol_023\"],\n      \"outputs\": [\"mol_018\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"pyrite (FeS2)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"373K\",\n        \"pressure\": \"anaerobic hydrothermal\",\n        \"catalyst\": \"FeS plus sulfide system\",\n        \"aqueous\": \"true\",\n        \"other\": \"100C, anoxic; pyrite-forming reductive amination regime\"\n      },\n      \"mechanism\": \"Iron-sulfur reductive amination converts pyruvate into alanine, illustrating the fate of oxaloacetate after decarboxylation.\",\n      \"reasoning\": \"FeS/H2S reductive amination of \u03b1-oxo acids is experimentally documented, and alanine production from pyruvate is the key observed sink when OAA decarboxylates in iron-mediated systems; inclusion of this branch is required by the literature (Hafenbradl et al., 1995; Barge et al., 2019).\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"Hydrothermal Fe0-mediated CO2 reduction with hydroxylamine producing aspartate-containing product set\",\n      \"inputs\": [\"mol_001\", \"mol_020\"],\n      \"outputs\": [\"mol_013\", \"mol_009\", \"mol_007\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"elemental iron (Fe0)\", \"magnetite (Fe3O4)\"],\n      \"conditions\": {\n        \"temperature\": \"303-373K\",\n        \"pressure\": \"35 bar\",\n        \"catalyst\": \"Fe0\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic hydrothermal CO2 reduction with hydroxylamine as nitrogen source\"\n      },\n      \"mechanism\": \"Reduced iron drives CO2 fixation into carboxylic acids and keto acids; in the presence of hydroxylamine, amino acid products including aspartate are formed within the broader protometabolic network.\",\n      \"reasoning\": \"The literature specifically notes detection of aspartate in Fe0-mediated CO2 reduction experiments using hydroxylamine as nitrogen source under 30-100C and 35 bar, making this an important direct hydrothermal route to the target even if network intermediates are distributed across a product ensemble (Varma et al., 2018; Muchowska et al., 2019).\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"HCN oligomerization to DAMN and higher polymeric precursors\",\n      \"inputs\": [\"mol_004\"],\n      \"outputs\": [\"mol_016\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (stibnite/molybdenite)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"195-300K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral concentration/photochemical surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"HCN concentration >10^-2 M at pH ~9.2; eutectic freezing can concentrate HCN to ~10 M near -23.4C\"\n      },\n      \"mechanism\": \"HCN undergoes stepwise oligomerization through aminomalononitrile and diaminomaleonitrile toward higher oligomers that encode amino-acid precursors.\",\n      \"reasoning\": \"HCN oligomerization is the most productive prebiotic route specifically for aspartate; DAMN is a key branch-point intermediate in the polymerization cascade and surface concentration/freezing are strongly supported by the literature (Ferris et al., 1974; Ferris et al., 1978; Matthews & Moser, 1966; Miyakawa, Cleaves & Miller, 2002).\"\n    },\n    {\n      \"id\": \"rxn_011\",\n      \"name\": \"Hydrolysis of HCN oligomers to glycine and aspartic acid\",\n      \"inputs\": [\"mol_016\"],\n      \"outputs\": [\"mol_013\", \"mol_024\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [null, null],\n      \"conditions\": {\n        \"temperature\": \"383K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": null,\n        \"aqueous\": \"true\",\n        \"other\": \"acid hydrolysis equivalent to 6N HCl, 110C, 24 h in analytical demonstration\"\n      },\n      \"mechanism\": \"Hydrolytic breakdown of nitrogen-rich HCN oligomers releases amino acids, with aspartate and glycine among the major products.\",\n      \"reasoning\": \"Hydrolysis of HCN oligomers is the strongest literature-supported route to aspartate as a major product rather than a trace contaminant; this is a central pathway in the network (Ferris et al., 1974; Ferris et al., 1978; Matthews & Moser, 1966; Miyakawa, Cleaves & Miller, 2002).\"\n    },\n    {\n      \"id\": \"rxn_012\",\n      \"name\": \"Cyanoacetylene route to aspartic acid from HCN and ammonia\",\n      \"inputs\": [\"mol_017\", \"mol_004\", \"mol_003\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (stibnite/molybdenite)\", \"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"298K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"surface concentration on sulfide/clay minerals\",\n        \"aqueous\": \"true\",\n        \"other\": \"pH ~9, room temperature\"\n      },\n      \"mechanism\": \"Cyanoacetylene reacts with cyanide and ammonia in aqueous alkaline solution through C3+C1 nitrile coupling chemistry to generate aspartate among the products.\",\n      \"reasoning\": \"This route is explicitly demonstrated as a distinct non-Strecker synthesis of aspartate, asparagine, and cytosine at around pH 9 and room temperature; its atmospheric plausibility is debated, but the chemistry itself is established (Sanchez, Ferris & Orgel, 1966; Shapiro, 1999).\"\n    },\n    {\n      \"id\": \"rxn_013\",\n      \"name\": \"Spark-discharge atmospheric synthesis delivering HCN and aspartate precursors\",\n      \"inputs\": [\"mol_022\", \"mol_003\", \"mol_023\", \"mol_001\"],\n      \"outputs\": [\"mol_004\", \"mol_013\", \"mol_017\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"pyrite (FeS2)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"electrical discharge, bulk aqueous trap near ambient\",\n        \"pressure\": \"reduced-pressure gas mixtures; classic Miller conditions 100-200 torr components\",\n        \"catalyst\": \"electrical discharge with oxidation-inhibiting mineral surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"week-scale spark discharge; H2S-rich volcanic variants and pyrite/FeSO4 oxidation inhibitors increase amino acid yields\"\n      },\n      \"mechanism\": \"Electrical discharge in reduced or volcanic gas mixtures generates nitriles and amino acid precursors; products collected in water include confirmed aspartate in modern reanalysis.\",\n      \"reasoning\": \"Modern reanalysis confirmed D,L-aspartate in Miller-type archived samples, and H2S-rich volcanic apparatus increased amino acid production; pyrite and related oxidation inhibitors improve yields in neutral-atmosphere variants, supporting inclusion of mineralized surface discharge chemistry (Miller, 1953; Miller, 1957; Johnson et al., 2008; Parker et al., 2011; Cleaves et al., 2008).\"\n    },\n    {\n      \"id\": \"rxn_014\",\n      \"name\": \"Photochemical synthesis of aspartic acid from reduced atmospheric mixtures\",\n      \"inputs\": [\"mol_022\", \"mol_003\", \"mol_023\"],\n      \"outputs\": [\"mol_013\", \"mol_004\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"sulfide minerals (stibnite/molybdenite)\"],\n      \"conditions\": {\n        \"temperature\": \"ambient to mild heating\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"UV irradiation with photocatalytic mineral surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"strong UV flux; reduced gas/water mixtures\"\n      },\n      \"mechanism\": \"UV irradiation of reduced gas mixtures in water generates nitriles and oxygenated organics that lead to amino acids including aspartate.\",\n      \"reasoning\": \"Photochemical amino acid formation including aspartate is directly reported from UV-irradiated CH4/C2H6/NH3/H2O/H2S mixtures and related interstellar-ice analogs; TiO2 is included as a plausible surface photocatalyst consistent with surface-mineral requirements (Sagan & Khare, 1971; Mu\u00f1oz Caro et al., 2002).\"\n    },\n    {\n      \"id\": \"rxn_015\",\n      \"name\": \"Fox-Windsor thermal formaldehyde-ammonia route to aspartate-containing amino acid mixture\",\n      \"inputs\": [\"mol_005\", \"mol_003\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"elevated heating\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral concentration in drying pools\",\n        \"aqueous\": \"false\",\n        \"other\": \"heated formaldehyde-ammonia mixtures in evaporative settings\"\n      },\n      \"mechanism\": \"Thermal condensation and rearrangement chemistry in concentrated carbonyl-ammonia mixtures yields amino acid products including aspartate.\",\n      \"reasoning\": \"Aspartate has been reported from heated formaldehyde and ammonia mixtures; this route is less mechanistically resolved than HCN oligomer or OAA-based chemistry but is part of the literature-supported aspartate inventory and is included as a lower-confidence auxiliary pathway (Fox & Windsor, 1970).\"\n    },\n    {\n      \"id\": \"rxn_016\",\n      \"name\": \"HCN hydration to formamide under UV-active surface conditions\",\n      \"inputs\": [\"mol_004\"],\n      \"outputs\": [\"mol_005\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO2 photocatalysis\",\n        \"aqueous\": \"true\",\n        \"other\": \"UV irradiation in surface pools\"\n      },\n      \"mechanism\": \"Cyanide hydration and photochemical processing generate formamide, which serves as a concentrated C-N feedstock for downstream prebiotic chemistry.\",\n      \"reasoning\": \"Formamide-centered photochemistry is a standard surface prebiotic module and provides a literature-consistent way to connect HCN-rich chemistry to the Fox-Windsor-type thermal route without inventing unsupported direct feedstocks; TiO2 is known to promote formamide photochemistry to biologically relevant products (Sutherland, 2016 review context; Saladino et al. formamide literature; TiO2 relevance noted in prebiotic photochemistry).\"\n    },\n    {\n      \"id\": \"rxn_017\",\n      \"name\": \"ZnS-analog photocatalytic reduction of oxaloacetate to malate\",\n      \"inputs\": [\"mol_010\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (stibnite/molybdenite)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"ambient\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"UV-irradiated semiconductor mineral surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"photochemical reducing conditions; network uses sulfide/TiO2 surface analogs to represent documented semiconductor photocatalysis\"\n      },\n      \"mechanism\": \"Photocatalytic reduction converts oxaloacetate into malate in the documented OAA/malate/fumarate branch of non-enzymatic rTCA analog chemistry.\",\n      \"reasoning\": \"The literature specifically identifies photocatalytic reduction of oxaloacetate to malate on ZnS surfaces as part of a plausible route to fumarate; this step is retained to fix the weakness of unsupported direct OAA-to-fumarate conversion and is represented here with required surface mineral agents as a constrained proxy for semiconductor photocatalysis (Guzman & Martin, 2008; Zhou & Guzman, 2016).\"\n    },\n    {\n      \"id\": \"rxn_018\",\n      \"name\": \"Dehydration of malate to fumarate\",\n      \"inputs\": [\"mol_011\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [null, null],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": null,\n        \"aqueous\": \"variable\",\n        \"other\": \"thermal dehydration or drying-interface conversion\"\n      },\n      \"mechanism\": \"Malate loses water to generate fumarate, establishing the unsaturated dicarboxylate branch relevant to aspartate chemistry.\",\n      \"reasoning\": \"This step follows the literature-supported malate-to-fumarate sequence used in non-enzymatic rTCA analog discussion and avoids the previously criticized unsupported direct OAA-to-fumarate shortcut (Guzman & Martin, 2008; Muchowska, Varma & Moran, 2020).\"\n    },\n    {\n      \"id\": \"rxn_019\",\n      \"name\": \"Non-enzymatic Michael addition of ammonia to fumarate giving aspartate\",\n      \"inputs\": [\"mol_012\", \"mol_003\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [null, null],\n      \"conditions\": {\n        \"temperature\": \"elevated but below destructive range\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": null,\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline conditions with high NH3 concentration; low-yield thermodynamically feasible reaction\"\n      },\n      \"mechanism\": \"Ammonia adds across the activated alkene of fumarate to produce aspartate through the reverse of the biological aspartase transformation.\",\n      \"reasoning\": \"This route is documented as thermodynamically feasible but low-yield without enzymatic catalysis; it is therefore included as a weak but literature-supported terminal path rather than overclaimed as a major source (Muchowska, Varma & Moran, 2020; Harrison et al., 2023 background discussion).\"\n    },\n    {\n      \"id\": \"rxn_020\",\n      \"name\": \"Wet-dry clay-assisted peptide formation from glycine and aspartate\",\n      \"inputs\": [\"mol_024\", \"mol_013\"],\n      \"outputs\": [\"mol_025\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"montmorillonite\", null],\n      \"conditions\": {\n        \"temperature\": \"353-363K\",\n        \"pressure\": \"ambient\",\n        \"catalyst\": \"montmorillonite clay\",\n        \"aqueous\": \"false\",\n        \"other\": \"wet-dry cycling at about 85 +/- 5 C\"\n      },\n      \"mechanism\": \"Clay interlayers concentrate amino acids during dehydration and facilitate peptide bond formation to glycyl-aspartic acid.\",\n      \"reasoning\": \"Aspartate is especially relevant as a nodal metabolite only if it can enter further chemistry; montmorillonite-assisted formation of glycyl-aspartic acid is experimentally documented under prebiotic wet-dry cycling conditions (Lahav et al., 1978; Ferris & Ertem, 1992 context; Kalra/Pant et al.).\"\n    }\n  ],\n  \"pathways\": [\n    {\n      \"pathway_id\": \"P1\",\n      \"name\": \"Direct hydrothermal Fe0-hydroxylamine route\",\n      \"description\": \"Direct hydrothermal production of aspartate within an Fe0-driven CO2 fixation network using hydroxylamine as nitrogen source.\",\n      \"reaction_sequence\": [\"rxn_009\"],\n      \"key_intermediates\": [\"mol_009\", \"mol_007\"]\n    },\n    {\n      \"pathway_id\": \"P2\",\n      \"name\": \"Hydrothermal protometabolic OAA to Cu-pyridoxamine transamination\",\n      \"description\": \"CO2 fixation produces glyoxylate and pyruvate, which feed transient oxaloacetate that is rapidly transaminated to aspartate.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_003\", \"rxn_004\"],\n      \"key_intermediates\": [\"mol_008\", \"mol_009\", \"mol_010\"]\n    },\n    {\n      \"pathway_id\": \"P3\",\n      \"name\": \"Hydrothermal protometabolic OAA to Bucherer-Bergs aspartate\",\n      \"description\": \"Vent-generated keto-acid network feeds oxaloacetate, which enters the Bucherer-Bergs route to N-carbamoyl aspartate and then hydrolyzes to aspartate.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_003\", \"rxn_005\", \"rxn_006\"],\n      \"key_intermediates\": [\"mol_008\", \"mol_009\", \"mol_010\", \"mol_014\"]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"HCN oligomer hydrolysis route\",\n      \"description\": \"Surface-concentrated HCN oligomerizes to DAMN/higher polymers that hydrolyze to aspartate as a major product.\",\n      \"reaction_sequence\": [\"rxn_010\", \"rxn_011\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_016\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"Spark discharge to HCN oligomer hydrolysis\",\n      \"description\": \"Atmospheric spark discharge generates HCN, which then oligomerizes and hydrolyzes to aspartate.\",\n      \"reaction_sequence\": [\"rxn_013\", \"rxn_010\", \"rxn_011\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_016\"]\n    },\n    {\n      \"pathway_id\": \"P6\",\n      \"name\": \"Spark discharge direct aspartate route\",\n      \"description\": \"Electrical discharge in volcanic/reduced gas mixtures produces a dilute but direct aspartate output captured in aqueous reservoirs.\",\n      \"reaction_sequence\": [\"rxn_013\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_017\"]\n    },\n    {\n      \"pathway_id\": \"P7\",\n      \"name\": \"Cyanoacetylene alkaline pool route\",\n      \"description\": \"Cyanoacetylene reacts with HCN and ammonia at pH about 9 in surface waters to yield aspartate directly.\",\n      \"reaction_sequence\": [\"rxn_012\"],\n      \"key_intermediates\": [\"mol_017\", \"mol_004\"]\n    },\n    {\n      \"pathway_id\": \"P8\",\n      \"name\": \"Photochemical atmospheric route\",\n      \"description\": \"UV irradiation of reduced gas mixtures generates aspartate directly and also feeds HCN-rich chemistry.\",\n      \"reaction_sequence\": [\"rxn_014\"],\n      \"key_intermediates\": [\"mol_004\"]\n    },\n    {\n      \"pathway_id\": \"P9\",\n      \"name\": \"Photochemical fumarate-ammonia route\",\n      \"description\": \"Transient oxaloacetate is photoreduced to malate, dehydrated to fumarate, then aminated under alkaline NH3-rich conditions to give aspartate.\",\n      \"reaction_sequence\": [\"rxn_017\", \"rxn_018\", \"rxn_019\"],\n      \"key_intermediates\": [\"mol_010\", \"mol_011\", \"mol_012\"]\n    },\n    {\n      \"pathway_id\": \"P10\",\n      \"name\": \"Formamide-thermal auxiliary route\",\n      \"description\": \"HCN is converted to formamide in UV-active pools, and concentrated heated formamide/ammonia chemistry yields aspartate in a surface thermal setting.\",\n      \"reaction_sequence\": [\"rxn_016\", \"rxn_015\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_005\"]\n    }\n  ],\n  \"hub_molecules\": [\"mol_004\", \"mol_008\", \"mol_009\", \"mol_010\", \"mol_013\"],\n  \"convergence_points\": [\n    {\n      \"molecule_id\": \"mol_004\",\n      \"incoming_reactions\": [\"rxn_013\", \"rxn_014\"],\n      \"outgoing_reactions\": [\"rxn_005\", \"rxn_010\", \"rxn_012\", \"rxn_016\"]\n    },\n    {\n      \"molecule_id\": \"mol_009\",\n      \"incoming_reactions\": [\"rxn_002\", \"rxn_007\", \"rxn_009\"],\n      \"outgoing_reactions\": [\"rxn_003\", \"rxn_008\"]\n    },\n    {\n      \"molecule_id\": \"mol_010\",\n      \"incoming_reactions\": [\"rxn_003\"],\n      \"outgoing_reactions\": [\"rxn_004\", \"rxn_005\", \"rxn_007\", \"rxn_017\"]\n    },\n    {\n      \"molecule_id\": \"mol_013\",\n      \"incoming_reactions\": [\"rxn_004\", \"rxn_006\", \"rxn_009\", \"rxn_011\", \"rxn_012\", \"rxn_013\", \"rxn_014\", \"rxn_015\", \"rxn_019\"],\n      \"outgoing_reactions\": [\"rxn_020\"]\n    }\n  ]\n}", "parsed_response": {"target_molecule": "Aspartic acid", "overall_strategy": "This network prioritizes the two literature-supported primary prebiotic sources of aspartic acid: (1) HCN oligomerization followed by hydrolysis, where aspartate is a major product, and (2) oxaloacetate-centered chemistry via Bucherer-Bergs and Cu2+/pyridoxamine transamination. Hydrothermal chemistry supplies reduced carbon hubs such as formate, acetate, pyruvate, glyoxylate, and oxaloacetate under alkaline vent conditions using FeS/Fe3S4/Fe3O4/Fe0 minerals. Surface environments concentrate HCN and NH3, enable cyanoacetylene and HCN oligomer chemistry, and support UV/mineral-assisted carbonyl and nitrile transformations. Biochemical/prebiotic settings then connect oxaloacetate, fumarate, and aspartate to broader protometabolic and peptide-forming chemistry. The network explicitly handles the oxaloacetate instability bottleneck by including the experimentally observed competing decarboxylation to pyruvate and by using rapid or branching OAA-consuming reactions that are documented in the literature.", "molecules": [{"id": "mol_001", "formula": "CO2", "iupac_name": "carbon dioxide", "common_name": "carbon dioxide", "inchi": "InChI=1S/CO2/c2-1-3", "role": "starting", "environment_formed": null}, {"id": "mol_002", "formula": "H2", "iupac_name": "molecular hydrogen", "common_name": "hydrogen", "inchi": "InChI=1S/H2/h1H", "role": "starting", "environment_formed": null}, {"id": "mol_003", "formula": "NH3", "iupac_name": "azane", "common_name": "ammonia", "inchi": "InChI=1S/H3N/h1H3", "role": "starting", "environment_formed": null}, {"id": "mol_004", "formula": "HCN", "iupac_name": "hydrogen cyanide", "common_name": "hydrogen cyanide", "inchi": "InChI=1S/CHN/c1-2/h1H", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_005", "formula": "CHNO", "iupac_name": "methanamide", "common_name": "formamide", "inchi": "InChI=1S/CH3NO/c2-1-3/h1H,(H2,2,3)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_006", "formula": "CHOO-", "iupac_name": "methanoate", "common_name": "formate", "inchi": "InChI=1S/CH2O2/c2-1-3/h1H,(H,2,3)/p-1", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_007", "formula": "C2H3O2-", "iupac_name": "acetate", "common_name": "acetate", "inchi": "InChI=1S/C2H4O2/c1-2(3)4/h1H3,(H,3,4)/p-1", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_008", "formula": "C2H2O3", "iupac_name": "2-oxoacetic acid", "common_name": "glyoxylic acid", "inchi": "InChI=1S/C2H2O3/c3-1-2(4)5/h1H,(H,4,5)", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_009", "formula": "C3H3O3-", "iupac_name": "2-oxopropanoate", "common_name": "pyruvate", "inchi": "InChI=1S/C3H4O3/c1-2(4)3(5)6/h1H3,(H,5,6)/p-1", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_010", "formula": "C4H3O5-", "iupac_name": "2-oxosuccinate", "common_name": "oxaloacetate", "inchi": "InChI=1S/C4H4O5/c5-2(4(8)9)1-3(6)7/h1H2,(H,6,7)(H,8,9)/p-1", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_011", "formula": "C4H6O4", "iupac_name": "2-hydroxybutanedioic acid", "common_name": "malic acid", "inchi": "InChI=1S/C4H6O5/c5-2(4(8)9)1-3(6)7/h2,5H,1H2,(H,6,7)(H,8,9)", "role": "intermediate", "environment_formed": "Biochemical"}, {"id": "mol_012", "formula": "C4H2O4", "iupac_name": "(E)-but-2-enedioic acid", "common_name": "fumaric acid", "inchi": "InChI=1S/C4H4O4/c5-3(6)1-2-4(7)8/h1-2H,(H,5,6)(H,7,8)/b2-1+", "role": "hub_intermediate", "environment_formed": "Biochemical"}, {"id": "mol_013", "formula": "C4H7NO4", "iupac_name": "2-aminobutanedioic acid", "common_name": "aspartic acid", "inchi": "InChI=1S/C4H7NO4/c5-2(4(8)9)1-3(6)7/h2H,1,5H2,(H,6,7)(H,8,9)", "role": "target", "environment_formed": "Biochemical"}, {"id": "mol_014", "formula": "C5H8N2O5", "iupac_name": "2-[(carbamoyl)amino]butanedioic acid", "common_name": "N-carbamoyl aspartate", "inchi": "InChI=1S/C5H8N2O5/c6-5(12)7-2(4(10)11)1-3(8)9/h2H,1H2,(H,7,12)(H,8,9)(H,10,11)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_015", "formula": "C4H4N2O2", "iupac_name": "3,4-dihydropyrimidine-2,4-dione", "common_name": "dihydroorotate", "inchi": "InChI=1S/C4H4N2O2/c7-3-1-2-5-4(8)6-3/h1-2H2,(H2,5,6,7,8)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_016", "formula": "C4H4N4", "iupac_name": "2,3-diaminobut-2-enedinitrile", "common_name": "DAMN", "inchi": "InChI=1S/C4H4N4/c5-1-3(7)4(8)2-6/h7-8H2", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_017", "formula": "C3HN", "iupac_name": "prop-2-ynenitrile", "common_name": "cyanoacetylene", "inchi": "InChI=1S/C3HN/c1-2-3-4/h1H", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_018", "formula": "C3H7NO2", "iupac_name": "2-aminopropanoic acid", "common_name": "alanine", "inchi": "InChI=1S/C3H7NO2/c1-2(4)3(5)6/h2H,4H2,1H3,(H,5,6)", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_019", "formula": "C4H6N2O2", "iupac_name": "2,5-dioxopyrrolidine-2-carboxamide", "common_name": "succinimide-like aspartate cyclization intermediate", "inchi": null, "role": "intermediate", "environment_formed": "Biochemical"}, {"id": "mol_020", "formula": "NH2OH", "iupac_name": "hydroxylamine", "common_name": "hydroxylamine", "inchi": "InChI=1S/H3NO/h1H3", "role": "starting", "environment_formed": null}, {"id": "mol_021", "formula": "C5H5N2O", "iupac_name": "4-aminomethyl-3-hydroxy-5-hydroxymethyl-2-methylpyridine", "common_name": "pyridoxamine", "inchi": null, "role": "starting", "environment_formed": null}, {"id": "mol_022", "formula": "CH4", "iupac_name": "methane", "common_name": "methane", "inchi": "InChI=1S/CH4/h1H4", "role": "starting", "environment_formed": null}, {"id": "mol_023", "formula": "H2S", "iupac_name": "sulfane", "common_name": "hydrogen sulfide", "inchi": "InChI=1S/H2S/h1H2", "role": "starting", "environment_formed": null}, {"id": "mol_024", "formula": "C2H5NO2", "iupac_name": "aminoacetic acid", "common_name": "glycine", "inchi": "InChI=1S/C2H5NO2/c3-1-2(4)5/h1,3H2,(H,4,5)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_025", "formula": "C6H10N2O5", "iupac_name": "2-aminoacetylamino-butanedioic acid", "common_name": "glycyl-aspartic acid", "inchi": null, "role": "intermediate", "environment_formed": "Biochemical"}], "reactions": [{"id": "rxn_001", "name": "Greigite-catalyzed reduction of carbon dioxide to formate", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_006"], "environment": "Hydrothermal", "agents": ["greigite (Fe3S4)", "mackinawite (FeS)"], "conditions": {"temperature": "313-363K", "pressure": "alkaline vent to elevated hydrothermal pressure", "catalyst": "greigite and mackinawite", "aqueous": "true", "other": "alkaline vent-like pH 9-11, H2-rich serpentinization fluids"}, "mechanism": "Surface-mediated CO2 hydrogenation on Fe-S minerals generates reduced one-carbon species, with formate as an early fixed-carbon product.", "reasoning": "Alkaline vent models and mineral catalysis support Fe-S-mediated CO2 reduction to small organics; greigite and related Fe-S phases are central to primordial carbon fixation (Preiner et al., 2020; Santos-Carballal et al., 2018; Kitadai, 2015)."}, {"id": "rxn_002", "name": "Hydrothermal Fe0-mediated protometabolic formation of pyruvate and glyoxylate from CO2", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_008", "mol_009"], "environment": "Hydrothermal", "agents": ["elemental iron (Fe0)", "magnetite (Fe3O4)"], "conditions": {"temperature": "303-373K", "pressure": "35 bar", "catalyst": "Fe0 with iron oxide surfaces", "aqueous": "true", "other": "anoxic CO2-rich system; hydrothermal protometabolic CO2 fixation window"}, "mechanism": "Reduced iron drives abiotic CO2 fixation through non-enzymatic network chemistry, yielding central keto-acid and aldehyde-acid intermediates including pyruvate and glyoxylate.", "reasoning": "Fe0-driven CO2 fixation produces central metabolic intermediates under hydrothermal conditions and is the strongest literature-supported upstream route feeding oxaloacetate chemistry; glyoxylate and pyruvate are established nodes in non-enzymatic protometabolic networks (Muchowska et al., 2019; Varma et al., 2018; Muchowska, Varma & Moran, 2020)."}, {"id": "rxn_003", "name": "Aldol-like coupling of pyruvate and glyoxylate to oxaloacetate precursor pool", "inputs": ["mol_008", "mol_009"], "outputs": ["mol_010"], "environment": "Hydrothermal", "agents": ["magnetite (Fe3O4)", "greigite (Fe3S4)"], "conditions": {"temperature": "298-323K", "pressure": "moderate to elevated", "catalyst": "iron mineral surfaces", "aqueous": "true", "other": "CO2-rich anoxic aqueous conditions; oxaloacetate treated as transient product in protometabolic network"}, "mechanism": "Pyruvate and glyoxylate undergo C-C bond-forming chemistry through hydroxy-keto intermediates that feed into oxaloacetate formation as a transient \u03b1-keto dicarboxylate node.", "reasoning": "The literature identifies glyoxylate-mediated access to oxaloacetate-equivalent chemistry as one of the best-supported prebiotic entries to OAA, though mechanistically via transient intermediates rather than a simple single-step biological analog; this reaction is a necessary network compression grounded in reported pyruvate-glyoxylate chemistry and flagged as a connected proxy for the Eschenmoser/Krishnamurthy-type route (Eschenmoser & Krishnamurthy, 2017; Muchowska, Varma & Moran, 2020)."}, {"id": "rxn_004", "name": "Cu2+-catalyzed transamination of oxaloacetate to aspartate", "inputs": ["mol_010", "mol_021"], "outputs": ["mol_013"], "environment": "Biochemical", "agents": ["Cu2+", null], "conditions": {"temperature": "298-343K", "pressure": "ambient to high pressure", "catalyst": "1 mM Cu2+", "aqueous": "true", "other": "5-10 mM reactants, 50 mM NH4HCO3 buffer, pH 6-10, reaction within ~1 hour to outrun OAA decarboxylation"}, "mechanism": "Metal-assisted pyridoxamine-mediated amino transfer converts the \u03b1-keto acid oxaloacetate into aspartate before extensive decarboxylation occurs.", "reasoning": "This is the best documented non-enzymatic transamination route to aspartate, giving ~5% yield within 1 hour; the literature also emphasizes that OAA decarboxylation competes strongly and that pyridoxamine availability remains unresolved, so the route is included with that caveat (Harrison et al., 2023; Mayer et al., 2021; Dherbassy et al., 2023)."}, {"id": "rxn_005", "name": "Bucherer-Bergs conversion of oxaloacetate to N-carbamoyl aspartate and dihydroorotate branch", "inputs": ["mol_010", "mol_004", "mol_003"], "outputs": ["mol_014", "mol_015"], "environment": "Surface", "agents": ["phosphate minerals (apatite/struvite)", "montmorillonite"], "conditions": {"temperature": "298-333K", "pressure": "1 atm", "catalyst": "phosphate mineral surface concentration", "aqueous": "true", "other": "neutral to slightly basic pH; cyanide plus ammonium bicarbonate equivalent chemistry in evaporitic/concentrating pools"}, "mechanism": "Oxaloacetate reacts with cyanide and ammonia/carbonate equivalents through Bucherer-Bergs chemistry to form N-carbamoyl aspartate, with branch access to dihydroorotate.", "reasoning": "The Bucherer-Bergs pathway from \u03b1-keto acids is directly demonstrated for oxaloacetate and is one of the most important literature-prioritized routes because it links aspartate chemistry to pyrimidine synthesis; mineral surfaces are included here as concentrative agents to satisfy surface-network constraints, while the core transformation follows the documented aqueous chemistry (Pulletikurti et al., 2022)."}, {"id": "rxn_006", "name": "Hydrolysis of N-carbamoyl aspartate to aspartic acid", "inputs": ["mol_014"], "outputs": ["mol_013"], "environment": "Biochemical", "agents": [null, null], "conditions": {"temperature": "298-343K", "pressure": "ambient", "catalyst": null, "aqueous": "true", "other": "mild aqueous hydrolytic conversion following Bucherer-Bergs sequence"}, "mechanism": "Carbamoyl group hydrolysis releases free aspartic acid from N-carbamoyl aspartate.", "reasoning": "This step completes the experimentally demonstrated \u03b1-keto-acid Bucherer-Bergs route to aspartate and retains direct continuity with the reported chemistry (Pulletikurti et al., 2022)."}, {"id": "rxn_007", "name": "Competing decarboxylation of oxaloacetate to pyruvate", "inputs": ["mol_010"], "outputs": ["mol_009", "mol_001"], "environment": "Biochemical", "agents": [null, null], "conditions": {"temperature": "298K and above", "pressure": "ambient", "catalyst": null, "aqueous": "true", "other": "half-life ~1-2 h at 25C near neutral pH; accelerated by divalent metals"}, "mechanism": "Spontaneous \u03b2-keto acid decarboxylation drains oxaloacetate to pyruvate, creating the major bottleneck in aspartate synthesis.", "reasoning": "The OAA decarboxylation race is the central challenge in prebiotic aspartate chemistry and must be explicitly included; this competing pathway explains why alanine often appears instead of aspartate in OAA amination experiments (Guzman & Martin, 2008; Barge et al., 2019; Harrison et al., 2023)."}, {"id": "rxn_008", "name": "Hydrothermal reductive amination network yielding alanine from pyruvate as OAA-loss product", "inputs": ["mol_009", "mol_003", "mol_023"], "outputs": ["mol_018"], "environment": "Hydrothermal", "agents": ["pyrite (FeS2)", "mackinawite (FeS)"], "conditions": {"temperature": "373K", "pressure": "anaerobic hydrothermal", "catalyst": "FeS plus sulfide system", "aqueous": "true", "other": "100C, anoxic; pyrite-forming reductive amination regime"}, "mechanism": "Iron-sulfur reductive amination converts pyruvate into alanine, illustrating the fate of oxaloacetate after decarboxylation.", "reasoning": "FeS/H2S reductive amination of \u03b1-oxo acids is experimentally documented, and alanine production from pyruvate is the key observed sink when OAA decarboxylates in iron-mediated systems; inclusion of this branch is required by the literature (Hafenbradl et al., 1995; Barge et al., 2019)."}, {"id": "rxn_009", "name": "Hydrothermal Fe0-mediated CO2 reduction with hydroxylamine producing aspartate-containing product set", "inputs": ["mol_001", "mol_020"], "outputs": ["mol_013", "mol_009", "mol_007"], "environment": "Hydrothermal", "agents": ["elemental iron (Fe0)", "magnetite (Fe3O4)"], "conditions": {"temperature": "303-373K", "pressure": "35 bar", "catalyst": "Fe0", "aqueous": "true", "other": "anoxic hydrothermal CO2 reduction with hydroxylamine as nitrogen source"}, "mechanism": "Reduced iron drives CO2 fixation into carboxylic acids and keto acids; in the presence of hydroxylamine, amino acid products including aspartate are formed within the broader protometabolic network.", "reasoning": "The literature specifically notes detection of aspartate in Fe0-mediated CO2 reduction experiments using hydroxylamine as nitrogen source under 30-100C and 35 bar, making this an important direct hydrothermal route to the target even if network intermediates are distributed across a product ensemble (Varma et al., 2018; Muchow
role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_017", "formula": "C5H5N5S", "iupac_name": "8-sulfanylpurine-6-amine", "common_name": "8-mercaptoadenine", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_018", "formula": "C10H13N5O4S", "iupac_name": "9-(2-deoxy-beta-D-ribofuranosyl)-8-sulfanyl-9H-purin-6-amine", "common_name": "thioadenosine intermediate", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_019", "formula": "C10H13N5O3", "iupac_name": "9-(2-deoxy-beta-D-ribofuranosyl)-9H-purin-6-amine", "common_name": "deoxyadenosine", "inchi": "InChI=1S/C10H13N5O3/c11-10-13-8-7(9(14-10)15-4-12-8)6-5(17)3-16-1-2-18-6/h4-6,16-18H,1-3H2,(H3,11,12,13,14,15)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_020", "formula": "C5H4N4", "iupac_name": "2,4,5-triaminopyrimidine", "common_name": "triaminopyrimidine", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_021", "formula": "C10H13N5O4", "iupac_name": "9-beta-D-ribofuranosyl-9H-purin-6-amine", "common_name": "adenosine", "inchi": "InChI=1S/C10H13N5O4/c11-10-13-8-7(9(14-10)15-4-12-8)6-5(17)3-16-1-2-19-6/h4-6,16-17,19H,1-3H2,(H3,11,12,13,14,15)", "role": "intermediate", "environment_formed": "Biochemical"}], "reactions": [{"id": "rxn_001", "name": "Hydrothermal CO2 reduction to formate", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_003"], "environment": "Hydrothermal", "agents": ["greigite (Fe3S4)", "mackinawite (FeS)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "greigite/mackinawite", "aqueous": "true", "other": "alkaline vent-like, anoxic, H2-rich"}, "mechanism": "Mineral-surface reduction of CO2 by H2 over Fe-S phases generates formate as an early reduced C1 carrier.", "reasoning": "Hydrothermal Fe-S catalysis of CO2 reduction is consistent with vent chemistry and iron-sulfur world models; greigite/mackinawite are required hydrothermal minerals and provide a plausible source of reduced C1 compounds feeding later formamide chemistry (Wachtershauser, 1988-1992; Cody et al., 2000; LaRowe & Regnier, 2008)."}, {"id": "rxn_002", "name": "Hydrothermal formamide generation from reduced C1 feedstocks", "inputs": ["mol_003", "mol_013"], "outputs": ["mol_004"], "environment": "Hydrothermal", "agents": ["pyrite (FeS2)", "magnetite (Fe3O4)"], "conditions": {"temperature": "370-470K", "pressure": "high", "catalyst": "pyrite/magnetite", "aqueous": "true", "other": "subseafloor hydrothermal concentration and thermophoretic retention in pores"}, "mechanism": "Reduced C1 species and ammonia are converted under hydrothermal dehydration/condensation conditions into formamide-enriched fluids.", "reasoning": "Formamide accumulation in hydrothermal pores has been argued to be feasible and relevant to nucleobase synthesis; this connecting step is partly inferential but used to link hydrothermal C1 reduction to the experimentally validated formamide reaction network (Niether et al., 2016; Saladino et al., 2001; Bada & Cleaves, 2015)."}, {"id": "rxn_003", "name": "Formamide thermal decomposition to HCN", "inputs": ["mol_004"], "outputs": ["mol_005", "mol_013"], "environment": "Surface", "agents": ["TiO2 (anatase)", "montmorillonite"], "conditions": {"temperature": "373-433K", "pressure": "1 atm", "catalyst": "TiO2/montmorillonite", "aqueous": "false", "other": "drying film or neat formamide, anoxic"}, "mechanism": "Heating formamide generates HCN and NH3, which feed classical HCN oligomerization chemistry.", "reasoning": "The literature explicitly identifies the equilibrium HCONH2 \u21cc HCN + H2O and thermal decomposition of formamide to HCN/NH3/HNCO as a mechanistic basis for nucleobase formation from formamide (Saladino et al., 2001; Barks et al., 2010; Slavova et al., 2020; Sponer et al., 2020)."}, {"id": "rxn_004", "name": "Classical HCN dimerization to iminoacetonitrile", "inputs": ["mol_005"], "outputs": ["mol_007"], "environment": "Surface", "agents": ["montmorillonite", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "293-343K", "pressure": "1 atm", "catalyst": "base-rich mineral surfaces with NH3 in solution", "aqueous": "true", "other": "pH 8-9, concentrated NH4CN or evaporitic concentration"}, "mechanism": "CN- attacks HCN to form the HCN dimer iminoacetonitrile under basic conditions.", "reasoning": "This is the first mechanistic step in Or\u00f3-type adenine synthesis, with computational support for ammonia/base catalysis and experimental requirement for concentrated NH4CN at basic pH (Oro, 1960; Oro & Kimball, 1961, 1962; Kikuchi et al., 2000; Sandstrom & Rahm, 2023)."}, {"id": "rxn_005", "name": "HCN trimerization to aminomalononitrile", "inputs": ["mol_007", "mol_005"], "outputs": ["mol_008"], "environment": "Surface", "agents": ["montmorillonite", "borate minerals (colemanite/ulexite)"], "conditions": {"temperature": "293-343K", "pressure": "1 atm", "catalyst": "mineral concentration surfaces", "aqueous": "true", "other": "pH 8-9, concentrated cyanide solutions or eutectic concentration"}, "mechanism": "Sequential addition of a third HCN to the dimer produces the reactive trimer aminomalononitrile.", "reasoning": "AMN is the accepted trimer intermediate in the Or\u00f3/Sanchez-Ferris-Orgel sequence and is supported by mechanistic and computational studies of HCN oligomerization (Sanchez et al., 1967; Roy et al., 2007; Sandstrom & Rahm, 2025/2026)."}, {"id": "rxn_006", "name": "HCN tetramerization to DAMN", "inputs": ["mol_008", "mol_005"], "outputs": ["mol_009"], "environment": "Surface", "agents": ["montmorillonite", "TiO2 (anatase)"], "conditions": {"temperature": "293-343K", "pressure": "1 atm", "catalyst": "concentrating mineral surfaces", "aqueous": "true", "other": "NH4CN-rich solutions, pH 8-9; DAMN isolable at appreciable fraction of HCN oligomer mixture"}, "mechanism": "Addition of the fourth HCN equivalent yields stable diaminomaleonitrile, the key photochemical precursor.", "reasoning": "DAMN is the first stable, isolable intermediate in adenine synthesis from HCN and a necessary node in classical and modern models (Zubay & Mui, 2001; Ferris & Orgel, 1966; Sandstrom & Rahm, 2025/2026)."}, {"id": "rxn_007", "name": "UV photoisomerization of DAMN to trans-DAMN", "inputs": ["mol_009"], "outputs": ["mol_010"], "environment": "Surface", "agents": ["TiO2 (anatase)", "borate minerals (colemanite/ulexite)"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "TiO2-assisted UV exposure", "aqueous": "true", "other": "UV irradiation 298-350 nm under young-Sun flux"}, "mechanism": "UV-driven cis/trans photoisomerization prepares DAMN for further photochemical rearrangement toward imidazole-ring formation.", "reasoning": "Ferris and Orgel identified UV-driven DAMN photochemistry en route to AICN, and later work quantified rapid AICN generation under young-Sun UV; trans-DAMN is an established intermediate in that sequence (Ferris & Orgel, 1966; Michaelian & Simeonov, 2022)."}, {"id": "rxn_008", "name": "Photochemical rearrangement of trans-DAMN to AICN", "inputs": ["mol_010"], "outputs": ["mol_011"], "environment": "Surface", "agents": ["TiO2 (anatase)", "montmorillonite"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "UV-irradiated mineral surfaces", "aqueous": "true", "other": "young-Sun UV, three-photon sequence via ketenimine; seconds to minutes irradiation"}, "mechanism": "Photochemical rearrangement proceeds via ketenimine-like intermediates to produce 4-aminoimidazole-5-carbonitrile.", "reasoning": "AICN is the central prebiotic purine hub generated from DAMN by UV photochemistry; this step is directly established experimentally and further analyzed in photophysical models (Ferris & Orgel, 1966; Sanchez et al., 1968; Michaelian & Simeonov, 2022)."}, {"id": "rxn_009", "name": "AICN ring closure with HCN to adenine", "inputs": ["mol_011", "mol_005"], "outputs": ["mol_012"], "environment": "Surface", "agents": ["montmorillonite", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "NH3-assisted aqueous medium on mineral surfaces", "aqueous": "true", "other": "pH 8-9; kinetically bottlenecked final pentamerization step"}, "mechanism": "AICN captures a fifth HCN equivalent and cyclizes to the purine skeleton, yielding adenine.", "reasoning": "This is the canonical final step of the Or\u00f3/Sanchez-Ferris-Orgel pathway; theory identifies it as the kinetic bottleneck, with NH3 catalysis greatly reducing the barrier (Sanchez et al., 1968; Roy et al., 2007; Armas-Vazquez et al., 2023)."}, {"id": "rxn_010", "name": "AICN ring closure with formamidine to adenine", "inputs": ["mol_011", "mol_006"], "outputs": ["mol_012"], "environment": "Surface", "agents": ["montmorillonite", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "300-383K", "pressure": "1 atm", "catalyst": "mineral-concentrating surface", "aqueous": "true", "other": "formamidine as one-carbon/one-nitrogen donor under evaporitic concentration"}, "mechanism": "Formamidine reacts with AICN to complete pyrimidine ring annulation and give adenine.", "reasoning": "Sanchez, Ferris and Orgel established AICN + HCN or formamidine as the branching entry to adenine; formamidine is a key literature-specified donor in the purine branch network (Sanchez et al., 1968; Zubay & Mui, 2001)."}, {"id": "rxn_011", "name": "Ammonium formate-mediated conversion of DAMN to adenine", "inputs": ["mol_009", "mol_014"], "outputs": ["mol_012", "mol_006"], "environment": "Surface", "agents": ["montmorillonite", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "383K", "pressure": "1 atm", "catalyst": "dry-heated mineral surface", "aqueous": "false", "other": "110C dry heating; ammonium formate generates formamidine in situ"}, "mechanism": "DAMN undergoes thermal conversion with ammonium formate, bypassing the UV AICN route and producing adenine via in situ formamidine.", "reasoning": "Hill and Orgel reported ~18% adenine from DAMN plus ammonium formate at 110C, the highest yield from a plausibly prebiotic one-pot reaction; formamidine is generated in situ and the pathway bypasses the photochemical step (Hill & Orgel, 2002)."}, {"id": "rxn_012", "name": "Mineral-catalyzed adenine synthesis directly from formamide", "inputs": ["mol_004"], "outputs": ["mol_011", "mol_012", "mol_005"], "environment": "Surface", "agents": ["TiO2 (anatase)", "montmorillonite"], "conditions": {"temperature": "373-433K", "pressure": "1 atm", "catalyst": "TiO2 or montmorillonite", "aqueous": "false", "other": "neat formamide, 100-160C, thermal condensation"}, "mechanism": "Formamide thermally condenses on mineral surfaces through HCN-generating and imidazole-forming sub-networks that produce AICN and adenine in one-pot chemistry.", "reasoning": "Multiple studies showed adenine formation from neat formamide at 100-160C on TiO2 and montmorillonite, with HCN-like intermediacy and AICN-consistent pathways; this reaction condenses that validated mineral-catalyzed network into a connected node (Saladino et al., 2001; Saladino et al., 2003; Saladino et al., 2004; Barks et al., 2010; Slavova et al., 2020)."}, {"id": "rxn_013", "name": "UV-assisted formamide synthesis of adenine", "inputs": ["mol_004"], "outputs": ["mol_012", "mol_011"], "environment": "Surface", "agents": ["TiO2 (anatase)", "borate minerals (colemanite/ulexite)"], "conditions": {"temperature": "403K", "pressure": "1 atm", "catalyst": "UV with or without mineral photocatalysis", "aqueous": "false", "other": "130C under UV irradiation"}, "mechanism": "Irradiated formamide generates reactive CN-containing species and purine intermediates, including AICN, leading to adenine.", "reasoning": "Barks et al. demonstrated adenine production from UV-irradiated formamide at 130C even without minerals; TiO2 is inclu
1\",\n      \"formula\": \"CH2O2\",\n      \"iupac_name\": \"methanoic acid\",\n      \"common_name\": \"formate/formic acid pool\",\n      \"inchi\": \"InChI=1S/CH2O2/c2-1-3/h1H,(H,2,3)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_012\",\n      \"formula\": \"C5H5N5\",\n      \"iupac_name\": \"9H-purin-6-amine\",\n      \"common_name\": \"adenine\",\n      \"inchi\": \"InChI=1S/C5H5N5/c6-5-4-n3cnc-1-2(4)7-5/h1,3H,(H3,6,7,8,9,10)\",\n      \"role\": \"target\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_013\",\n      \"formula\": \"C5H5N5O\",\n      \"iupac_name\": \"4-amino-1H-imidazole-5-carboxamide\",\n      \"common_name\": \"AICA\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_014\",\n      \"formula\": \"C10H13N5O3\",\n      \"iupac_name\": \"9-[(2R,3R,5R)-3,5-dihydroxyoxolan-2-yl]-9H-purin-6-amine\",\n      \"common_name\": \"adenosine\",\n      \"inchi\": \"InChI=1S/C10H13N5O4/c11-9-7-8(13-3-12-7)15(4-14-9)10-6(18)5(17)2-16-1-19-10/h3-6,10,16-18H,1-2H2,(H2,11,12,13,14)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_015\",\n      \"formula\": \"C10H13N5O2\",\n      \"iupac_name\": \"9-[(2R,3S,5R)-3-hydroxy-5-(hydroxymethyl)oxolan-2-yl]-9H-purin-6-amine\",\n      \"common_name\": \"deoxyadenosine\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_016\",\n      \"formula\": \"C5H7N3S\",\n      \"iupac_name\": \"6-amino-7H-purine-8-thiol\",\n      \"common_name\": \"8-mercaptoadenine\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"Hydrothermal CO2 reduction to formate\",\n      \"inputs\": [],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe3S4)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"greigite and mackinawite\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline vent, H2-rich, anoxic; conservative feedstock-generation step rather than adenine-forming step\"\n      },\n      \"mechanism\": \"Mineral-catalyzed reduction of CO2 by H2 on Fe-S surfaces gives formate as a reduced C1 feedstock.\",\n      \"reasoning\": \"Hydrothermal Fe-S minerals plausibly reduce CO2 to formate and related C1 products in alkaline vent settings; this supports cross-environment feedstock supply while respecting the instability of adenine at vent temperatures (Huber & Wachtershauser, 1997; Cody et al., 2000; LaRowe & Regnier, 2008; Franiatte et al., 2008).\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Surface generation and concentration of HCN from ammonium cyanide\",\n      \"inputs\": [\"mol_002\"],\n      \"outputs\": [\"mol_001\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"253-343K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO2 and montmorillonite as concentrating/photochemical mineral context\",\n        \"aqueous\": \"true\",\n        \"other\": \"eutectic freezing at -78 to -20C or evaporitic concentration; pH 8-9; anoxic\"\n      },\n      \"mechanism\": \"NH4CN provides a concentrated HCN/CN\u2212 reservoir; freezing or evaporation increases effective cyanide concentration into the productive polymerization regime.\",\n      \"reasoning\": \"Adenine synthesis from NH4CN requires concentration control; eutectic freezing and concentrated NH4CN are the experimentally established entry points for productive HCN chemistry (Or\u00f3, 1960; Sanchez, Ferris & Orgel, 1967; Levy et al., 2000; Miyakawa, Cleaves & Miller, 2002; Orgel, 2004). Mineral agents here represent plausible surface concentration/adsorption context rather than a claimed stoichiometric catalyst.\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"HCN dimerization to iminoacetonitrile\",\n      \"inputs\": [\"mol_001\"],\n      \"outputs\": [\"mol_003\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"293-343K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"base-catalyzed by NH3/CN\u2212 in aqueous concentrated cyanide; minerals provide adsorption/concentration surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"pH 8-9; concentrated cyanide solution or eutectic brine\"\n      },\n      \"mechanism\": \"CN\u2212 attacks HCN to form the HCN dimer iminoacetonitrile under base-catalyzed conditions.\",\n      \"reasoning\": \"The HCN dimer is the first mechanistically supported intermediate in adenine pentamerization; modern computation validates this step and NH3 lowers the barrier substantially (Kikuchi et al., 2000; Sandstr\u00f6m & Rahm, 2023; Roy, Najafian & Schleyer, 2007).\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"HCN trimerization to aminomalononitrile\",\n      \"inputs\": [\"mol_003\", \"mol_001\"],\n      \"outputs\": [\"mol_004\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"293-343K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"base-catalyzed cyanide chemistry on mineral-concentrating surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"pH 8-9; concentrated HCN/NH4CN solutions\"\n      },\n      \"mechanism\": \"Sequential cyanide addition converts the HCN dimer to the reactive trimer aminomalononitrile.\",\n      \"reasoning\": \"AMN is the accepted trimeric intermediate in the Or\u00f3/Sanchez-Orgel sequence and is part of the validated computational and experimental HCN network (Sanchez, Ferris & Orgel, 1967; Zubay & Mui, 2001; Sandstr\u00f6m & Rahm, 2025/2026).\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"HCN tetramerization to DAMN\",\n      \"inputs\": [\"mol_004\", \"mol_001\"],\n      \"outputs\": [\"mol_005\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"293-343K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"base-catalyzed oligomerization in concentrated cyanide medium with mineral concentration surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"pH 8-9; DAMN can accumulate as a stable isolable HCN tetramer\"\n      },\n      \"mechanism\": \"Fourth HCN addition yields the isolable tetramer DAMN.\",\n      \"reasoning\": \"DAMN is the first stable and experimentally isolable major intermediate in HCN pentamerization and the key precursor for photochemical access to AICN (Sanchez, Ferris & Orgel, 1967; Zubay & Mui, 2001; Sandstr\u00f6m & Rahm, 2025/2026).\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"UV photoisomerization of DAMN to trans-DAMN\",\n      \"inputs\": [\"mol_005\"],\n      \"outputs\": [\"mol_006\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"sulfide minerals (stibnite, molybdenite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"UV photochemistry; minerals provide irradiated surface context\",\n        \"aqueous\": \"true\",\n        \"other\": \"UV 298-350 nm under young-Sun flux\"\n      },\n      \"mechanism\": \"DAMN undergoes UV-driven cis/trans photoisomerization as the first stage of conversion toward AICN.\",\n      \"reasoning\": \"Ferris and Orgel established the UV dependence of the DAMN photochemical sequence, later quantified under young-Sun flux by Michaelian and Simeonov (Ferris & Orgel, 1966; Michaelian & Simeonov, 2022).\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Photochemical conversion of trans-DAMN to AICN\",\n      \"inputs\": [\"mol_006\"],\n      \"outputs\": [\"mol_007\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"UV photochemistry\",\n        \"aqueous\": \"true\",\n        \"other\": \"three-photon sequence via ketenimine intermediate; young-Sun UV\"\n      },\n      \"mechanism\": \"trans-DAMN proceeds through ketenimine-like excited-state chemistry to give AICN, the central purine hub.\",\n      \"reasoning\": \"AICN formation from photoexcited DAMN/DAFN is a central validated step in classical adenine synthesis, with significant AICN production under plausible early UV flux (Ferris & Orgel, 1966; Michaelian & Simeonov, 2022).\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"AICN ring closure with HCN to adenine\",\n      \"inputs\": [\"mol_007\", \"mol_001\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"phosphate minerals (apatite, struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"343K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"NH3 catalysis in bulk water; minerals provide concentration surface\",\n        \"aqueous\": \"true\",\n        \"other\": \"pH 8-9; kinetically difficult bottleneck step\"\n      },\n      \"mechanism\": \"A fifth HCN equivalent contributes the final carbon/nitrogen unit and closes the purine pyrimidine ring system.\",\n      \"reasoning\": \"This is the canonical final step of adenine pentamerization and the major kinetic bottleneck; NH3 lowers the barrier markedly relative to the uncatalyzed pathway (Sanchez, Ferris & Orgel, 1968; Roy, Najafian & Schleyer, 2007; Armas-V\u00e1zquez et al., 2023).\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"AICN ring closure with formamidine to adenine\",\n      \"inputs\": [\"mol_007\", \"mol_008\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"phosphate minerals (apatite, struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"343-383K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"thermal surface condensation\",\n        \"aqueous\": \"true\",\n        \"other\": \"formamidine acts as the one-carbon/one-nitrogen donor for ring closure\"\n      },\n      \"mechanism\": \"Formamidine reacts with AICN to close the six-membered ring more effectively than free HCN in many mixtures.\",\n      \"reasoning\": \"Sanchez, Ferris and Orgel identified formamidine as a productive donor for AICN conversion to adenine, and later literature emphasized its presence in HCN oligomerization mixtures (Sanchez, Ferris & Orgel, 1968; Zubay & Mui, 2001).\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"Thermal conversion of ammonium formate to formamidine\",\n      \"inputs\": [\"mol_009\"],\n      \"outputs\": [\"mol_008\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"phosphate minerals (apatite, struvite)\", \"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"383K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"dry-heating surface minerals\",\n        \"aqueous\": \"false\",\n        \"other\": \"hot evaporitic or geothermal dry phase\"\n      },\n      \"mechanism\": \"Heating ammonium formate generates formamidine in situ, providing the donor needed for adenine-forming ring closure.\",\n      \"reasoning\": \"Hill and Orgel interpreted ammonium formate as an in situ precursor to formamidine in their high-yield adenine-forming system (Hill & Orgel, 2002).\"\n    },\n    {\n      \"id\": \"rxn_011\",\n      \"name\": \"Hill-Orgel direct thermal adenine synthesis from DAMN and ammonium formate\",\n      \"inputs\": [\"mol_005\", \"mol_009\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"phosphate minerals (apatite, struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"383K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"thermal dry-state reaction\",\n        \"aqueous\": \"false\",\n        \"other\": \"110C; ~18% adenine reported\"\n      },\n      \"mechanism\": \"DAMN undergoes thermal rearrangement/cyclization with ammonium formate-derived formamidine to produce adenine, bypassing the explicit UV AICN route.\",\n      \"reasoning\": \"This is the highest-yield prebiotically plausible one-pot adenine synthesis reported from HCN-derived chemistry, giving about 18% adenine at 110C (Hill & Orgel, 2002).\"\n    },\n    {\n      \"id\": \"rxn_012\",\n      \"name\": \"Thermal mineral-catalyzed conversion of formamide to HCN/formamidine feedstock\",\n      \"inputs\": [\"mol_010\"],\n      \"outputs\": [\"mol_001\", \"mol_008\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"373-433K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO2 or montmorillonite\",\n        \"aqueous\": \"false\",\n        \"other\": \"neat formamide or highly concentrated formamide; 100-160C\"\n      },\n      \"mechanism\": \"Formamide thermally decomposes and self-catalyzes into HCN-like and amidine-bearing intermediates that feed adenine-forming chemistry.\",\n      \"reasoning\": \"Formamide is experimentally established as a one-pot adenine feedstock and mechanistically connects to HCN chemistry through HCONH2 \u21cc HCN + H2O and related amidine-forming routes (Saladino et al., 2001; Saladino et al., 2003; Saladino et al., 2004; Yamada et al., 1978; Slavova et al., 2020; \u0160poner et al., 2020).\"\n    },\n    {\n      \"id\": \"rxn_013\",\n      \"name\": \"Mineral-catalyzed direct adenine formation from formamide\",\n      \"inputs\": [\"mol_010\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"373-433K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO2 or montmorillonite\",\n        \"aqueous\": \"false\",\n        \"other\": \"neat formamide, 100-160C, low but detectable adenine yields\"\n      },\n      \"mechanism\": \"Surface-catalyzed condensation of formamide generates HCN/NH3/HNCO-derived networks that furnish adenine in one-pot chemistry.\",\n      \"reasoning\": \"Adenine formation from neat formamide is robust across multiple mineral catalysts, with TiO2 and montmorillonite among the best documented surface catalysts (Saladino et al., 2001; Saladino et al., 2003; Saladino et al., 2004).\"\n    },\n    {\n      \"id\": \"rxn_014\",\n      \"name\": \"Pyrite-catalyzed hydrothermal-interfacial adenine formation from formamide\",\n      \"inputs\": [\"mol_010\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"pyrite (FeS2)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"433K\",\n        \"pressure\": \"moderate to high\",\n        \"catalyst\": \"pyrite and Fe-S mineral assemblage\",\n        \"aqueous\": \"false\",\n        \"other\": \"formamide-rich mineral interface; 160C; interfacial rather than bulk vent-core setting\"\n      },\n      \"mechanism\": \"Fe-S mineral surfaces catalyze condensation of formamide toward purine products including adenine at elevated temperature.\",\n      \"reasoning\": \"Saladino and co-workers reported purine formation from formamide on iron-sulfur minerals at 160C; this provides the most literature-grounded hydrothermal-side connection to adenine chemistry, though accumulation remains limited by nucleobase instability at high temperature (Saladino et al., 2008; Levy & Miller, 1998; Franiatte et al., 2008).\"\n    },\n    {\n      \"id\": \"rxn_015\",\n      \"name\": \"UV conversion of AICN to AICA by hydrolysis branch\",\n      \"inputs\": [\"mol_007\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"borate minerals (colemanite, ulexite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"aqueous hydrolysis on mineral surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"competing branch from the AICN hub\"\n      },\n      \"mechanism\": \"Nitrile hydrolysis converts AICN to the carboxamide AICA, diverting flux toward other purines.\",\n      \"reasoning\": \"AICN hydrolysis to AICA is a well-established branch point in the purine network and explains competition between adenine and hypoxanthine-forming chemistry (Sanchez, Ferris & Orgel, 1968; Zubay & Mui, 2001; Barks et al., 2010).\"\n    },\n    {\n      \"id\": \"rxn_016\",\n      \"name\": \"Cyanosulfidic photoreduction route from 8-mercaptoadenine to adenine-containing nucleosides\",\n      \"inputs\": [\"mol_016\"],\n      \"outputs\": [\"mol_014\", \"mol_015\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (stibnite, molybdenite)\", \"phosphate minerals (apatite, struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"308K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"H2S and Cu(I)/Cu(II) photoredox with MgCl2 in phosphate-buffered anoxic solution\",\n        \"aqueous\": \"true\",\n        \"other\": \"UV irradiation; ~35C; stereoselective nucleoside-first route\"\n      },\n      \"mechanism\": \"Under cyanosulfidic photoredox conditions, 8-mercaptoadenine-bearing intermediates are photoreduced to adenine nucleosides rather than free adenine.\",\n      \"reasoning\": \"Xu and co-workers showed highly selective prebiotic formation of deoxyadenosine and related purine nucleosides through 8-mercaptoadenine under H2S/UV conditions, extending to mixed RNA/DNA purine nucleosides (Xu et al., 2020; Xu et al., 2021; Patel et al., 2015).\"\n    },\n    {\n      \"id\": \"rxn_017\",\n      \"name\": \"Biochemical salvage release of adenine from adenosine\",\n      \"inputs\": [\"mol_014\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"null\",\n        \"aqueous\": \"true\",\n        \"other\": \"slow hydrolytic or thermal cleavage in concentrated prebiotic pools or interfaces; included as a necessary connecting salvage step\"\n      },\n      \"mechanism\": \"Hydrolytic cleavage of the N-glycosidic bond releases free adenine from adenosine.\",\n      \"reasoning\": \"This step is not the productive centerpiece of the literature but is included conservatively to connect nucleoside-first cyanosulfidic chemistry to the adenine target; the literature emphasizes nucleoside formation rather than adenine release, so this node is explicitly a connecting salvage step rather than a primary synthesis route (Xu et al., 2020; Xu et al., 2021; Becker et al., 2016; Becker et al., 2019).\"\n    },\n    {\n      \"id\": \"rxn_018\",\n      \"name\": \"Biochemical salvage release of adenine from deoxyadenosine\",\n      \"inputs\": [\"mol_015\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"null\",\n        \"aqueous\": \"true\",\n        \"other\": \"slow hydrolytic or thermal cleavage in prebiotic pools\"\n      },\n      \"mechanism\": \"Hydrolytic cleavage of the glycosidic bond releases adenine from deoxyadenosine.\",\n      \"reasoning\": \"As with adenosine salvage, this is included only to connect experimentally validated nucleoside-first chemistry to the adenine network; it is a plausible degradation/salvage link rather than the main synthetic outcome emphasized by the source literature (Xu et al., 2020; Xu et al., 2021).\"\n    }\n  ],\n  \"pathways\": [\n    {\n      \"pathway_id\": \"P1\",\n      \"name\": \"Classical Or\u00f3 pentamerization via HCN\",\n      \"description\": \"Concentrated HCN/NH4CN in aqueous surface settings proceeds through dimer, trimer, tetramer, photochemical AICN formation, and final HCN ring closure to adenine.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_003\", \"rxn_004\", \"rxn_005\", \"rxn_006\", \"rxn_007\", \"rxn_008\"],\n      \"key_intermediates\": [\"mol_001\", \"mol_005\", \"mol_007\"]\n    },\n    {\n      \"pathway_id\": \"P2\",\n      \"name\": \"AICN plus formamidine closure pathway\",\n      \"description\": \"Classical HCN oligomerization generates AICN, but final cyclization uses formamidine rather than free HCN.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_003\", \"rxn_004\", \"rxn_005\", \"rxn_006\", \"rxn_007\", \"rxn_010\", \"rxn_009\"],\n      \"key_intermediates\": [\"mol_005\", \"mol_007\", \"mol_008\"]\n    },\n    {\n      \"pathway_id\": \"P3\",\n      \"name\": \"Hill-Orgel DAMN ammonium formate route\",\n      \"description\": \"DAMN formed from HCN chemistry reacts directly with ammonium formate under dry heat to give adenine at relatively high yield.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_003\", \"rxn_004\", \"rxn_005\", \"rxn_011\"],\n      \"key_intermediates\": [\"mol_005\", \"mol_009\"]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"Formamide-to-HCN-to-adenine route\",\n      \"description\": \"Formamide thermally generates HCN/feedstock that enters the classical oligomerization pathway to adenine.\",\n      \"reaction_sequence\": [\"rxn_012\", \"rxn_003\", \"rxn_004\", \"rxn_005\", \"rxn_006\", \"rxn_007\", \"rxn_008\"],\n      \"key_intermediates\": [\"mol_010\", \"mol_001\", \"mol_007\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"Formamide-to-formamidine-to-AICN closure route\",\n      \"description\": \"Formamide supplies formamidine/HCN feedstock, with final ring closure from AICN using formamidine.\",\n      \"reaction_sequence\": [\"rxn_012\", \"rxn_003\", \"rxn_004\", \"rxn_005\", \"rxn_006\", \"rxn_007\", \"rxn_009\"],\n      \"key_intermediates\": [\"mol_010\", \"mol_008\", \"mol_007\"]\n    },\n    {\n      \"pathway_id\": \"P6\",\n      \"name\": \"Direct mineral-catalyzed formamide adenine synthesis on TiO2\",\n      \"description\": \"Neat formamide heated on TiO2-rich surface minerals yields adenine directly in one-pot condensation chemistry.\",\n      \"reaction_sequence\": [\"rxn_013\"],\n      \"key_intermediates\": [\"mol_010\"]\n    },\n    {\n      \"pathway_id\": \"P7\",\n      \"name\": \"Hydrothermal-interfacial Fe-S formamide route\",\n      \"description\": \"Formamide reacts on pyrite/Fe-S mineral interfaces at elevated temperature to give adenine, providing a hydrothermal-side entry point.\",\n      \"reaction_sequence\": [\"rxn_014\"],\n      \"key_intermediates\": [\"mol_010\"]\n    },\n    {\n      \"pathway_id\": \"P8\",\n      \"name\": \"Eutectic-freezing enhanced HCN route\",\n      \"description\": \"Dilute NH4CN is concentrated by freezing, then follows the classical HCN\u2192DAMN\u2192AICN\u2192adenine pathway.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_003\", \"rxn_004\", \"rxn_005\", \"rxn_006\", \"rxn_007\", \"rxn_008\"],\n      \"key_intermediates\": [\"mol_002\", \"mol_001\", \"mol_007\"]\n    },\n    {\n      \"pathway_id\": \"P9\",\n      \"name\": \"Cyanosulfidic deoxyadenosine-first salvage route\",\n      \"description\": \"Surface cyanosulfidic chemistry forms deoxyadenosine via 8-mercaptoadenine; later biochemical hydrolysis releases adenine.\",\n      \"reaction_sequence\": [\"rxn_016\", \"rxn_018\"],\n      \"key_intermediates\": [\"mol_016\", \"mol_015\"]\n    },\n    {\n      \"pathway_id\": \"P10\",\n      \"name\": \"Cyanosulfidic adenosine-first salvage route\",\n      \"description\": \"Surface cyanosulfidic chemistry forms adenosine-containing purine nucleosides; later biochemical hydrolysis releases adenine.\",\n      \"reaction_sequence\": [\"rxn_016\", \"rxn_017\"],\n      \"key_intermediates\": [\"mol_016\", \"mol_014\"]\n    }\n  ],\n  \"hub_molecules\": [\"mol_001\", \"mol_005\", \"mol_007\", \"mol_008\", \"mol_010\"],\n  \"convergence_points\": [\n    {\n      \"molecule_id\": \"mol_001\",\n      \"incoming_reactions\": [\"rxn_002\", \"rxn_012\"],\n      \"outgoing_reactions\": [\"rxn_003\", \"rxn_004\", \"rxn_005\", \"rxn_008\"]\n    },\n    {\n      \"molecule_id\": \"mol_005\",\n      \"incoming_reactions\": [\"rxn_005\"],\n      \"outgoing_reactions\": [\"rxn_006\", \"rxn_011\"]\n    },\n    {\n      \"molecule_id\": \"mol_007\",\n      \"incoming_reactions\": [\"rxn_007\"],\n      \"outgoing_reactions\": [\"rxn_008\", \"rxn_009\", \"rxn_015\"]\n    },\n    {\n      \"molecule_id\": \"mol_008\",\n      \"incoming_reactions\": [\"rxn_010\", \"rxn_012\"],\n      \"outgoing_reactions\": [\"rxn_009\"]\n    },\n    {\n      \"molecule_id\": \"mol_010\",\n      \"incoming_reactions\": [],\n      \"outgoing_reactions\": [\"rxn_012\", \"rxn_013\", \"rxn_014\"]\n    }\n  ]\n}", "parsed_response": {"target_molecule": "Adenine", "overall_strategy": "This network models adenine as a prebiotic network product rather than a single linear product. It integrates (i) classical HCN oligomerization through DAMN and AICN, (ii) eutectic-freezing concentration of NH4CN/HCN, (iii) formamide-based mineral and photochemical routes that feed the same HCN/AICN chemistry, (iv) Hill-Orgel thermal conversion of DAMN with ammonium formate, and (v) cyanosulfidic nucleoside-first chemistry that yields adenine-containing nucleosides under surface conditions before adenine release by later hydrolytic salvage. Hydrothermal chemistry is used conservatively, consistent with the literature, as a source of reduced C1 feedstocks such as formate and HCN-related precursors rather than as the main adenine accumulation site, because adenine is unstable at high temperature. The central hub is AICN, with HCN, formamide, DAMN, and ammonium formate/formamidine acting as additional hubs linking Hydrothermal, Surface, and Biochemical settings.", "molecules": [{"id": "mol_001", "formula": "CHN", "iupac_name": "hydrogen cyanide", "common_name": "HCN", "inchi": "InChI=1S/CHN/c1-2/h1H", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_002", "formula": "CH3N2", "iupac_name": "azane;formonitrile", "common_name": "ammonium cyanide", "inchi": null, "role": "starting", "environment_formed": "Surface"}, {"id": "mol_003", "formula": "C2H2N2", "iupac_name": "2-iminoacetonitrile", "common_name": "iminoacetonitrile", "inchi": "InChI=1S/C2H2N2/c3-1-2-4/h2H,(H,4)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_004", "formula": "C3H3N3", "iupac_name": "2-aminoprop-1-ene-1,1,3-tricarbonitrile", "common_name": "aminomalononitrile", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_005", "formula": "C4H4N4", "iupac_name": "2,3-diaminobut-2-enedinitrile", "common_name": "diaminomaleonitrile", "inchi": null, "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_006", "formula": "C4H4N4", "iupac_name": "2,3-diaminofumaronitrile", "common_name": "trans-DAMN / DAFN", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_007", "formula": "C4H3N5", "iupac_name": "4-amino-1H-imidazole-5-carbonitrile", "common_name": "AICN", "inchi": null, "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_008", "formula": "CH4N2", "iupac_name": "methanimidamide", "common_name": "formamidine", "inchi": "InChI=1S/CH4N2/c2-1-3/h1H,(H3,2,3)", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_009", "formula": "CH5NO2", "iupac_name": "azane;methanoic acid", "common_name": "ammonium formate", "inchi": null, "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_010", "formula": "CH3NO", "iupac_name": "methanamide", "common_name": "formamide", "inchi": "InChI=1S/CH3NO/c2-1-3/h1H,(H2,2,3)", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_011", "formula": "CH2O2", "iupac_name": "methanoic acid", "common_name": "formate/formic acid pool", "inchi": "InChI=1S/CH2O2/c2-1-3/h1H,(H,2,3)", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_012", "formula": "C5H5N5", "iupac_name": "9H-purin-6-amine", "common_name": "adenine", "inchi": "InChI=1S/C5H5N5/c6-5-4-n3cnc-1-2(4)7-5/h1,3H,(H3,6,7,8,9,10)", "role": "target", "environment_formed": "Surface"}, {"id": "mol_013", "formula": "C5H5N5O", "iupac_name": "4-amino-1H-imidazole-5-carboxamide", "common_name": "AICA", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_014", "formula": "C10H13N5O3", "iupac_name": "9-[(2R,3R,5R)-3,5-dihydroxyoxolan-2-yl]-9H-purin-6-amine", "common_name": "adenosine", "inchi": "InChI=1S/C10H13N5O4/c11-9-7-8(13-3-12-7)15(4-14-9)10-6(18)5(17)2-16-1-19-10/h3-6,10,16-18H,1-2H2,(H2,11,12,13,14)", "role": "intermediate", "environment_formed": "Biochemical"}, {"id": "mol_015", "formula": "C10H13N5O2", "iupac_name": "9-[(2R,3S,5R)-3-hydroxy-5-(hydroxymethyl)oxolan-2-yl]-9H-purin-6-amine", "common_name": "deoxyadenosine", "inchi": null, "role": "intermediate", "environment_formed": "Biochemical"}, {"id": "mol_016", "formula": "C5H7N3S", "iupac_name": "6-amino-7H-purine-8-thiol", "common_name": "8-mercaptoadenine", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}], "reactions": [{"id": "rxn_001", "name": "Hydrothermal CO2 reduction to formate", "inputs": [], "outputs": ["mol_011"], "environment": "Hydrothermal", "agents": ["greigite (Fe3S4)", "mackinawite (FeS)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "greigite and mackinawite", "aqueous": "true", "other": "alkaline vent, H2-rich, anoxic; conservative feedstock-generation step rather than adenine-forming step"}, "mechanism": "Mineral-catalyzed reduction of CO2 by H2 on Fe-S surfaces gives formate as a reduced C1 feedstock.", "reasoning": "Hydrothermal Fe-S minerals plausibly reduce CO2 to formate and related C1 products in alkaline vent settings; this supports cross-environment feedstock supply while respecting the instability of adenine at vent temperatures (Huber & Wachtershauser, 1997; Cody et al., 2000; LaRowe & Regnier, 2008; Franiatte et al., 2008)."}, {"id": "rxn_002", "name": "Surface generation and concentration of HCN from ammonium cyanide", "inputs": ["mol_002"], "outputs": ["mol_001"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "montmorillonite"], "conditions": {"temperature": "253-343K", "pressure": "1 atm", "catalyst": "TiO2 and montmorillonite as concentrating/photochemical mineral context", "aqueous": "true", "other": "eutectic freezing at -78 to -20C or evaporitic concentration; pH 8-9; anoxic"}, "mechanism": "NH4CN provides a concentrated HCN/CN\u2212 reservoir; freezing or evaporation increases effective cyanide concentration into the productive polymerization regime.", "reasoning": "Adenine synthesis from NH4CN requires concentration control; eutectic freezing and concentrated NH4CN are the experimentally established entry points for productive HCN chemistry (Or\u00f3, 1960; Sanchez, Ferris & Orgel, 1967; Levy et al., 2000; Miyakawa, Cleaves & Miller, 2002; Orgel, 2004). Mineral agents here represent plausible surface concentration/adsorption context rather than a claimed stoichiometric catalyst."}, {"id": "rxn_003", "name": "HCN dimerization to iminoacetonitrile", "inputs": ["mol_001"], "outputs": ["mol_003"], "environment": "Surface", "agents": ["montmorillonite", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "293-343K", "pressure": "1 atm", "catalyst": "base-catalyzed by NH3/CN\u2212 in aqueous concentrated cyanide; minerals provide adsorption/concentration surfaces", "aqueous": "true", "other": "pH 8-9; concentrated cyanide solution or eutectic brine"}, "mechanism": "CN\u2212 attacks HCN to form the HCN dimer iminoacetonitrile under base-catalyzed conditions.", "reasoning": "The HCN dimer is the first mechanistically supported intermediate in adenine pentamerization; modern computation validates this step and NH3 lowers the barrier substantially (Kikuchi et al., 2000; Sandstr\u00f6m & Rahm, 2023; Roy, Najafian & Schleyer, 2007)."}, {"id": "rxn_004", "name": "HCN trimerization to aminomalononitrile", "inputs": ["mol_003", "mol_001"], "outputs": ["mol_004"], "environment": "Surface", "agents": ["montmorillonite", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "293-343K", "pressure": "1 atm", "catalyst": "base-catalyzed cyanide chemistry on mineral-concentrating surfaces", "aqueous": "true", "other": "pH 8-9; concentrated HCN/NH4CN solutions"}, "mechanism": "Sequential cyanide addition converts the HCN dimer to the reactive trimer aminomalononitrile.", "reasoning": "AMN is the accepted trimeric intermediate in the Or\u00f3/Sanchez-Orgel sequence and is part of the validated computational and experimental HCN network (Sanchez, Ferris & Orgel, 1967; Zubay & Mui, 2001; Sandstr\u00f6m & Rahm, 2025/2026)."}, {"id": "rxn_005", "name": "HCN tetramerization to DAMN", "inputs": ["mol_004", "mol_001"], "outputs": ["mol_005"], "environment": "Surface", "agents": ["montmorillonite", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "293-343K", "pressure": "1 atm", "catalyst": "base-catalyzed oligomerization in concentrated cyanide medium with mineral concentration surfaces", "aqueous": "true", "other": "pH 8-9; DAMN can accumulate as a stable isolable HCN tetramer"}, "mechanism": "Fourth HCN addition yields the isolable tetramer DAMN.", "reasoning": "DAMN is the first stable and experimentally isolable major intermediate in HCN pentamerization and the key precursor for photochemical access to AICN (Sanchez, Ferris & Orgel, 1967; Zubay & Mui, 2001; Sandstr\u00f6m & Rahm, 2025/2026)."}, {"id": "rxn_006", "name": "UV photoisomerization of DAMN to trans-DAMN", "inputs": ["mol_005"], "outputs": ["mol_006"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "sulfide minerals (stibnite, molybdenite)"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "UV photochemistry; minerals provide irradiated surface context", "aqueous": "true", "other": "UV 298-350 nm under young-Sun flux"}, "mechanism": "DAMN undergoes UV-driven cis/trans photoisomerization as the first stage of conversion toward AICN.", "reasoning": "Ferris and Orgel established the UV dependence of the DAMN photochemical sequence, later quantified under young-Sun flux by Michaelian and Simeonov (Ferris & Orgel, 1966; Michaelian & Simeonov, 2022)."}, {"id": "rxn_007", "name": "Photochemical conversion of trans-DAMN to AICN", "inputs": ["mol_006"], "outputs": ["mol_007"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "montmorillonite"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "UV photochemistry", "aqueous": "true", "other": "three-photon sequence via ketenimine intermediate; young-Sun UV"}, "mechanism": "trans-DAMN proceeds through ketenimine-like excited-state chemistry to give AICN, the central purine hub.", "reasoning": "AICN formation from photoexcited DAMN/DAFN is a central validated step in classical adenine synthesis, with significant AICN production under plausible early UV flux (Ferris & Orgel, 1966; Michaelian & Simeonov, 2022)."}, {"id": "rxn_008", "name": "AICN ring closure with HCN to adenine", "inputs": ["mol_007", "mol_001"], "outputs": ["mol_012"], "environment": "Surface", "agents": ["montmorillonite", "phosphate minerals (apatite, struvite)"], "conditions": {"temperature": "343K", "pressure": "1 atm", "catalyst": "NH3 catalysis in bulk water; minerals provide concentration surface", "aqueous": "true", "other": "pH 8-9; kinetically difficult bottleneck step"}, "mechanism": "A fifth HCN equivalent contributes the final carbon/nitrogen unit and closes the purine pyrimidine ring system.", "reasoning": "This is the canonical final step of adenine pentamerization and the major kinetic bottleneck; NH3 lowers the barrier markedly relative to the uncatalyzed pathway (Sanchez, Ferris & Orgel, 1968; Roy, Najafian & Schleyer, 2007; Armas-V\u00e1zquez et al., 2023)."}, {"id": "rxn_009", "name": "AICN ring closure with formamidine to adenine", "inputs": ["mol_007", "mol_008"], "outputs": ["mol_012"], "environment": "Surface", "agents": ["montmorillonite", "phosphate minerals (apatite, struvite)"], "conditions": {"temperature": "343-383K", "pressure": "1 atm", "catalyst": "thermal surface condensation", "aqueous": "true", "other": "formamidine acts as the one-carbon/one-nitrogen donor for ring closure"}, "mechanism": "Formamidine reacts with AICN to close the six-membered ring more effectively than free HCN in many mixtures.", "reasoning": "Sanchez, Ferris and Orgel identified formamidine as a productive donor for AICN conversion to adenine, and later literature emphasized its presence in HCN oligomerization mixtures (Sanchez, Ferris & Orgel, 1968; Zubay & Mui, 2001)."}, {"id": "rxn_010", "name": "Thermal conversion of ammonium formate to formamidine", "inputs": ["mol_009"], "outputs": ["mol_008"], "environment": "Surface", "agents": ["phosphate minerals (apatite, struvite)", "montmorillonite"], "conditions": {"temperature": "383K", "pressure": "1 atm", "catalyst": "dry-heating surface minerals", "aqueous": "false", "other": "hot evaporitic or geothermal dry phase"}, "mechanism": "Heating ammonium formate generates formamidine in situ, providing the donor needed for adenine-forming ring closure.", "reasoning": "Hill and Orgel interpreted ammonium formate as an in situ precursor to formamidine in their high-yield adenine-forming system (Hill & Orgel, 2002)."}, {"id": "rxn_011", "name": "Hill-Orgel direct thermal adenine synthesis from DAMN and ammonium formate", "inputs": ["mol_005", "mol_009"], "outputs": ["mol_012"], "environment": "Surface", "agents": ["montmorillonite", "phosphate minerals (apatite, struvite)"], "conditions": {"temperature": "383K", "pressure": "1 atm", "catalyst": "thermal dry-state reaction", "aqueous": "false", "other": "110C; ~18% adenine reported"}, "mechanism": "DAMN undergoes thermal rearrangement/cyclization with ammonium formate-derived formamidine to produce adenine, bypassing the explicit UV AICN route.", "reasoning": "This is the highest-yield prebiotically plausible one-pot adenine synthesis reported from HCN-derived chemistry, giving about 18% adenine at 110C (Hill & Orgel, 2002)."}, {"id": "rxn_012", "name": "Thermal mineral-catalyzed conversion of formamide to HCN/formamidine feedstock", "inputs": ["mol_010"], "outputs": ["mol_001", "mol_008"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "montmorillonite"], "conditions": {"temperature": "373-433K", "pressure": "1 atm", "catalyst": "TiO2 or montmorillonite", "aqueous": "false", "other": "neat formamide or highly concentrated formamide; 100-160C"}, "mechanism": "Formamide thermally decomposes and self-catalyzes into HCN-like and amidine-bearing intermediates that feed adenine-forming chemistry.", "reasoning": "Formamide is experimentally established as a one-pot adenine feedstock and mechanistically connects to HCN chemistry through HCONH2 \u21cc HCN + H2O and related amidine-forming routes (Saladino et al., 2001; Saladino et al., 2003; Saladino et al., 2004; Yamada et al., 1978; Slavova et al., 2020; \u0160poner et al., 2020)."}, {"id": "rxn_013", "name": "Mineral-catalyzed direct adenine formation from formamide", "inputs": ["mol_010"], "outputs": ["mol_012"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "montmorillonite"], "conditions": {"temperature": "373-433K", "pressure": "1 atm", "catalyst": "TiO2 or montmorillonite", "aqueous": "false", "other": "neat formamide, 100-160C, low but detectable adenine yields"}, "mechanism": "Surface-catalyzed condensation of formamide generates HCN/NH3/HNCO-derived networks that furnish adenine in one-pot chemistry.", "reasoning": "Adenine formation from neat formamide is robust across multiple mineral catalysts, with TiO2 and montmorillonite among the best documented surface catalysts (Saladino et al., 2001; Saladino et al., 2003; Saladino et al., 2004)."}, {"id": "rxn_014", "name": "Pyrite-catalyzed hydrothermal-interfacial adenine formation from formamide", "inputs": ["mol_010"], "outputs": ["mol_012"], "environment": "Hydrothermal", "agents": ["pyrite (FeS2)", "mackinawite (FeS)"], "conditions": {"temperature": "433K", "pressure": "moderate to high", "catalyst": "pyrite and Fe-S mineral assemblage", "aqueous": "false", "other": "formamide-rich mineral interface; 160C; interfacial rather than bulk vent-core setting"}, "mechanism": "Fe-S mineral surfaces catalyze condensation of formamide toward purine products including adenine at elevated temperature.", "reasoning": "Saladino and co-workers reported purine formation from formamide on iron-sulfur minerals at 160C; this provides the most literature-grounded hydrothermal-side connection to adenine chemistry, though accumulation remains limited by nucleobase instability at high temperature (Saladino et al., 2008; Levy & Miller, 1998; Franiatte et al., 2008)."}, {"id": "rxn_015", "name": "UV conversion of AICN to AICA by hydrolysis branch", "inputs": ["mol_007"], "outputs": ["mol_013"], "environment": "Surface", "agents": ["montmorillonite", "borate minerals (colemanite, ulexite)"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "aqueous hydrolysis on mineral surfaces", "aqueous": "true", "other": "competing branch from the AICN hub"}, "mechanism": "Nitrile hydrolysis converts AICN to the carboxamide AICA, diverting flux toward other purines.", "reasoning": "AICN hydrolysis to AICA is a well-established branch point in the purine network and explains competition between adenine and hypoxanthine-forming chemistry (Sanchez, Ferris & Orgel, 1968; Zubay & Mui, 2001; Barks et al., 2010)."}, {"id": "rxn_016", "name": "Cyanosulfidic photoreduction route from 8-mercaptoadenine to adenine-containing nucleosides", "inputs": ["mol_016"], "outputs": ["mol_014", "mol_015"], "environment": "Surface", "agents": ["sulfide minerals (stibnite, molybdenite)", "phosphate minerals (apatite, struvite)"], "conditions": {"temperature": "308K", "pressure": "1 atm", "catalyst": "H2S and Cu(I)/Cu(II) photoredox with MgCl2 in phosphate-buffered anoxic solution", "aqueous": "true", "other": "UV irradiation; ~35C; stereoselective nucleoside-first route"}, "mechanism": "Under cyanosulfidic photoredox conditions, 8-mercaptoadenine-bearing intermediates are photoreduced to adenine nucleosides rather than free adenine.", "reasoning": "Xu and co-workers showed highly selective prebiotic formation of deoxyadenosine and related purine nucleosides through 8-mercaptoadenine under H2S/UV conditions, extending to mixed RNA/DNA purine nucleosides (Xu et al., 2020; Xu et al., 2021; Patel et al., 2015)."}, {"id": "rxn_017", "name": "Biochemical salvage release of adenine from adenosine", "inputs": ["mol_014"], "outputs": ["mol_012"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "null", "aqueous": "true", "other": "slow hydrolytic or thermal cleavage in concentrated prebiotic pools or interfaces; included as a necessary connecting salvage step"}, "mechanism": "Hydrolytic cleavage of the N-glycosidic bond releases free adenine from adenosine.", "reasoning": "This step is not the productive centerpiece of the literature but is included conservatively to connect nucleoside-first cyanosulfidic chemistry to the adenine target; the literature emphasizes nucleoside formation rather than adenine release, so this node is explicitly a connecting salvage step rather than a primary synthesis route (Xu et al., 2020; Xu et al., 2021; Becker et al., 2016; Becker et al., 2019)."}, {"id": "rxn_018", "name": "Biochemical salvage release of adenine from deoxyadenosine", "inputs": ["mol_015"], "outputs": ["mol_012"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "null", "aqueous": "true", "other": "slow hydrolytic or thermal cleavage in prebiotic pools"}, "mechanism": "Hydrolytic cleavage of the glycosidic bond releases adenine from deoxyadenosine.", "reasoning": "As with adenosine salvage, this is included only to connect experimentally validated nucleoside-first chemistry to the adenine network; it is a plausible degradation/salvage link rather than the main synthetic outcome emphasized by the source literature (Xu et al., 2020; Xu et al., 2021)."}], "pathways": [{"pathway_id": "P1", "name": "Classical Or\u00f3 pentamerization via HCN", "description": "Concentrated HCN/NH4CN in aqueous surface settings proceeds through dimer, trimer, tetramer, photochemical AICN formation, and final HCN ring closure to adenine.", "reaction_sequence": ["rxn_002", "rxn_003", "rxn_004", "rxn_005", "rxn_006", "rxn_007", "rxn_008"], "key_intermediates": ["mol_001", "mol_005", "mol_007"]}, {"pathway_id": "P2", "name": "AICN plus formamidine closure pathway", "description": "Classical HCN oligomerization generates AICN, but final cyclization uses formamidine rather than free HCN
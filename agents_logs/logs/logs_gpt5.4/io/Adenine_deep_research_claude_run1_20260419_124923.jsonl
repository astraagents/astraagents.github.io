 ["mol_012", "mol_019", "mol_018"], "environment": "Surface", "agents": ["sulfide minerals (stibnite/molybdenite)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "308K", "pressure": "1 atm", "catalyst": "UV with H2S and MgCl2-enabled cyanosulfidic photochemistry", "aqueous": "true", "other": "approximately 35C, neutral pH, anoxic"}, "mechanism": "Photoreduction removes sulfur from 8-mercaptoadenine-level intermediates, yielding adenine and adenine nucleosides under selective cyanosulfidic conditions.", "reasoning": "Xu et al. showed that 8-mercaptoadenine-based intermediates undergo H2S/UV photoreduction to produce adenine-containing DNA and RNA purine nucleosides with high selectivity under cyanosulfidic conditions (Xu et al., 2020; Xu et al., 2021; Patel et al., 2015)."}, {"id": "rxn_017", "name": "Prebiotic hydrolysis of adenosine or deoxyadenosine to free adenine", "inputs": ["mol_019", "mol_021"], "outputs": ["mol_012"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": null, "aqueous": "true", "other": "geothermal cycling or mildly acidic hydrolytic pool conditions"}, "mechanism": "Hydrolytic cleavage of the glycosidic bond releases adenine from adenine nucleosides in aqueous prebiotic settings.", "reasoning": "This connecting reaction is included to close routes in which adenine first appears as a nucleoside-level product in the cyanosulfidic literature; while the cited work focuses on nucleoside synthesis rather than hydrolysis, glycosidic bond cleavage is chemically standard and necessary here to connect known adenine-containing products back to the free-base target. The step is therefore explicitly connective and partly speculative but consistent with prebiotic hydrolysis chemistry (Xu et al., 2020; Xu et al., 2021; Becker et al., 2016; Becker et al., 2019)."}], "pathways": [{"pathway_id": "P1", "name": "Classical Or\u00f3 HCN pentamerization", "description": "Ca
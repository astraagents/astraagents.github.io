lacetylene\",\n      \"description\": \"Phenylpyruvate branches to benzaldehyde, which under high-energy surface conditions returns to the phenylacetylene hub and then follows the validated route.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_009\", \"rxn_011\", \"rxn_012\", \"rxn_004\", \"rxn_005\", \"rxn_006\"],\n      \"key_intermediates\": [\"mol_011\", \"mol_012\", \"mol_004\", \"mol_006\"]\n    },\n    {\n      \"pathway_id\": \"P9\",\n      \"name\": \"Acetylene-first network route through benzaldehyde recycle\",\n      \"description\": \"Hydrothermal acetylene feeds benzene, then phenylpyruvate, then benzaldehyde, then recycles through phenylacetylene to the Strecker endpoint.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_009\", \"rxn_011\", \"rxn_012\", \"rxn_004\", \"rxn_005\", \"rxn_006\"],\n      \"key_intermediates\": [\"mol_002\", \"mol_003\", \"mol_011\", \"mol_012\", \"mol_004\"]\n    },\n    {\n      \"pathway_id\": \"P10\",\n      \"name\": \"Surface-hydrothermal mixed route via phenylacetaldehyde convergence\",\n      \"description\": \"One branch forms phenylacetylene by high-energy surface chemistry while another hydrothermal branch forms phenylpyruvate; both converge at phenylacetaldehyde before Strecker completion.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_004\", \"rxn_005\", \"rxn_006\", \"rxn_001\", \"rxn_002\", \"rxn_009\", \"rxn_008\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_006\", \"mol_011\", \"mol_009\"]\n    }\n  ],\n  \"hub_molecules\": [\"mol_003\", \"mol_004\", \"mol_006\", \"mol_009\", \"mol_011\"],\n  \"convergence_points\": [\n    {\n      \"molecule_id\": \"mol_003\",\n      \"incoming_reactions\": [\"rxn_002\"],\n      \"outgoing_reactions\": [\"rxn_003\", \"rxn_009\"]\n    },\n    {\n      \"molecule_id\": \"mol_004\",\n      \"incoming_reactions\": [\"rxn_003\", \"rxn_012\"],\n      \"outgoing_reactions\": [\"rxn_004\"]\n    },\n    {\n      \"molecule_id\": \"mol_
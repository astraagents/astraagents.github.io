ays": [{"pathway_id": "P1", "name": "Canonical Friedmann-Miller from methane", "description": "Methane enters a high-energy hydrothermal/volcanic route to acetylene, then to benzene and phenylacetylene, followed by H2S hydration, Strecker synthesis, and aminonitrile hydrolysis to phenylalanine.", "reaction_sequence": ["rxn_001", "rxn_002", "rxn_004", "rxn_005", "rxn_006", "rxn_007"], "key_intermediates": ["mol_002", "mol_003", "mol_005", "mol_006", "mol_009"]}, {"pathway_id": "P2", "name": "Acetylene-first Friedmann-Miller route", "description": "Beginning from the acetylene hub, cyclotrimerization yields benzene, which feeds high-energy phenylacetylene formation and then the validated aqueous sequence to phenylalanine.", "reaction_sequence": ["rxn_002", "rxn_004", "rxn_005", "rxn_006", "rxn_007"], "key_intermediates": ["mol_003", "mol_005", "mol_006", "mol_009"]}, {"pathway_id": "P3", "name": "Benzene-first Friedmann-Miller route", "description": "Preformed benzene from catalytic acetylene trimerization is diverted into phenylacetylene formation and then into the H2S-hydration/Strecker sequence.", "reaction_sequence": ["rxn_004", "rxn_005", "rxn_006", "rxn_007"], "key_intermediates": ["mol_005", "mol_006", "mol_009"]}, {"pathway_id": "P4", "name": "Direct phenylacetylene entry route", "description": "If phenylacetylene is generated in a high-energy environment, the remaining validated steps are H2S hydration to phenylacetaldehyde, Strecker synthesis, and hydrolysis.", "reaction_sequence": ["rxn_005", "rxn_006", "rxn_007"], "key_intermediates": ["mol_006", "mol_009"]}, {"pathway_id": "P5", "name": "Phenylacetaldehyde Strecker route", "description": "Phenylacetaldehyde acts as the principal convergent aldehyde precursor and undergoes Strecker synthesis followed by hydrolysis.", "reaction_sequence": ["rxn_006", "rxn_007"], "key_intermediates": ["mol_009"]}, {"pathway_id": "P6", "name": "Phenylalanine aminonitrile hydrolysis route", "description": "Once the aminonitril
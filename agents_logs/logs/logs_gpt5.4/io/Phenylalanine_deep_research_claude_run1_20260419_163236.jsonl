id": "mol_013", "formula": "C10H8", "iupac_name": "naphthalene", "common_name": "naphthalene", "inchi": "InChI=1S/C10H8/c1-2-6-10-8-4-3-7-9(10)5-1/h1-8H", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_014", "formula": "CO2", "iupac_name": "carbon dioxide", "common_name": "carbon dioxide", "inchi": "InChI=1S/CO2/c2-1-3", "role": "starting", "environment_formed": null}, {"id": "mol_015", "formula": "H2", "iupac_name": "molecular hydrogen", "common_name": "hydrogen", "inchi": "InChI=1S/H2/h1H", "role": "starting", "environment_formed": null}], "reactions": [{"id": "rxn_001", "name": "Hydrothermal Fischer-Tropsch-type generation of acetylene from methane/carbon dioxide feedstocks", "inputs": ["mol_001", "mol_014", "mol_015"], "outputs": ["mol_002"], "environment": "Hydrothermal", "agents": ["magnetite (Fe3O4)", "elemental iron (Fe0)"], "conditions": {"temperature": "473-673K (200-400C)", "pressure": "high", "catalyst": "magnetite with reduced iron during serpentinization", "aqueous": true, "other": "serpentinizing ultramafic setting; anoxic; hydrothermal gas/mineral interface"}, "mechanism": "Fischer-Tropsch-type hydrothermal reduction and coupling of C1 carbon sources to small hydrocarbons including acetylene under iron-mineral catalysis.", "reasoning": "Saladino et al. (2021) reviewed hydrothermal/serpentinization Fischer-Tropsch-type synthesis on magnetite and related iron minerals at 200-400C generating hydrocarbons and aromatic precursors. Use of acetylene here is an inferred connecting step within that documented hydrocarbon suite and is therefore partially speculative but geochemically consistent with the Friedmann-Miller requirement for acetylene feedstock and with serpentinization chemistry."}, {"id": "rxn_002", "name": "Acetylene cyclotrimerization to benzene on iron-rich mineral surfaces", "inputs": ["mol_002"], "outputs": ["mol_003"], "environment": "Hydrothermal", "agents": ["magnetite (Fe3O4)", "pyrite (FeS2)"], "conditions": {"temperature": "350-450K", "pressure": "high", "catalyst": "transition-metal-rich iron mineral surfaces", "aqueous": false, "other": "metal-surface-mediated cyclotrimerization; low-O2 or anoxic; vent-wall/gas-solid microenvironment"}, "mechanism": "Surface-assisted [2+2+2] cyclotrimerization of three acetylene equivalents to benzene via metal-bound C4/C6 intermediates.", "reasoning": "Acetylene cyclotrimerization is thermodynamically favorable and transition metals strongly reduce the kinetic barrier; Shuman et al. (2022) showed Fe+ catalysis even at low temperature, Wang et al. (2019) analyzed catalytic barriers, and Cinar et al. (2024) demonstrated highly selective benzene formation on metal surfaces. Assigning iron-rich prebiotic mineral surfaces as the hydrothermal analogue is literature-grounded, though exact Fe3O4/FeS2 selectivity under vent conditions remains less directly demonstrated."}, {"id": "rxn_003", "name": "High-energy formation of phenylacetylene from methane/acetylene/benzene feedstocks", "inputs": ["mol_001", "mol_002", "mol_003"], "outputs": ["mol_004"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "sulfide minerals (stibnite/molybdenite)"], "conditions": {"temperature": "high-energy pyrolytic or irradiative conditions", "pressure": "1 atm", "catalyst": "mineral surfaces serving as energy-coupling and adsorption substrates", "aqueous": false, "other": "pyrolysis, electric discharge, or UV irradiation in anoxic volcanic/subaerial setting"}, "mechanism": "Energetic gas-phase or surface-assisted aromatic/alkynyl rearrangement and dehydrogenative coupling yielding phenylacetylene.", "reasoning": "Friedmann and Miller (1969) reported substantial yields of phenylacetylene from methane, acetylene, or benzene under pyrolysis, electric discharge, or UV irradiation. Miller (1974) emphasized that aromatic amino acid synthesis required pyrolysis combined with plausible solution reactions. The listed minerals are included to satisfy surface-mineral schema requirements as adsorption/photochemical supports, but the core evidence is the Friedmann-Miller high-energy synthesis."}, {"id": "rxn_004", "name": "H2S-mediated hydration of phenylacetylene to phenylacetaldehyde", "inputs": ["mol_004", "mol_005"], "outputs": ["mol_006"], "environment": "Surface", "agents": ["sulfide minerals (stibnite/molybdenite)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "sulfide-rich mineral surfaces", "aqueous": true, "other": "nucleophilic and radical H2S addition followed by hydrolysis in anoxic aqueous setting"}, "mechanism": "H2S adds across the alkyne to give sulfur-containing intermediates/thioaldehyde equivalents that hydrolyze to phenylacetaldehyde.", "reasoning": "This is the distinctive central step of the validated Friedmann-Miller route: Friedmann and Miller (1969) showed conversion of phenylacetylene to phenylacetaldehyde through H2S-mediated addition and hydrolysis. Miller (1974) highlighted this as part of the required multi-environment sequence for aromatic amino acids."}, {"id": "rxn_005", "name": "Strecker synthesis of phenylalanine aminonitrile from phenylacetaldehyde", "inputs": ["mol_006", "mol_007", "mol_008"], "outputs": ["mol_009"], "environment": "Surface", "agents": ["montmorillonite (clay)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "mineral concentration surfaces", "aqueous": true, "other": "moderate-temperature aqueous Strecker conditions in evaporitic or pool environment"}, "mechanism": "Imine formation from aldehyde and ammonia followed by cyanide addition to afford the alpha-aminonitrile.", "reasoning": "Friedmann and Miller (1969) completed phenylalanine synthesis by classical Strecker reaction of phenylacetaldehyde with NH3 and HCN. Hidalgo et al. (2013) reported activation energies of 55-67 kJ/mol for Strecker-type chemistry involving phenylacetaldehyde. Mineral surfaces are included as concentration aids consistent with prebiotic surface settings."}, {"id": "rxn_006", "name": "Hydrolysis of phenylalanine aminonitrile to phenylalanine", "inputs": ["mol_009"], "outputs": ["mol_010"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "<373K", "pressure": "1 atm", "catalyst": null, "aqueous": true, "other": "aqueous hydrolysis in prebiotic pool or interface; anoxic"}, "mechanism": "Sequential nitrile hydration and hydrolysis converts the aminonitrile to the amino acid carboxylate.", "reasoning": "Hydrolysis of the Strecker aminonitrile to phenylalanine is part of the experimentally validated Friedmann-Miller sequence (Friedmann & Miller, 1969). Moderate aqueous conditions are also favored by the multi-setting interpretation summarized by Miller (1974)."}, {"id": "rxn_007", "name": "Abiotic transamination of phenylpyruvate to phenylalanine", "inputs": ["mol_011", "mol_007"], "outputs": ["mol_010"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "variable, moderate", "pressure": "1 atm", "catalyst": "metal-ion-assisted transamination possible", "aqueous": true, "other": "prebiotic pool or mineral interface; anoxic"}, "mechanism": "Amine transfer or reductive amination of the alpha-keto acid phenylpyruvate yields phenylalanine.", "reasoning": "The deep research identifies phenylpyruvate as a central branch point connecting to phenylalanine via transamination and notes that the phenylpyruvate pathway is evolutionarily ancient (Yoo et al., 2013). Abiotic metal-ion-assisted transamination is plausible but not directly demonstrated specifically for phenylalanine; this step is therefore a literature-supported but partially speculative network connector."}, {"id": "rxn_008", "name": "Non-oxidative decarboxylation of phenylpyruvate to phenylacetaldehyde", "inputs": ["mol_011"], "outputs": ["mol_006"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "350-400K", "pressure": "1 atm", "catalyst": null, "aqueous": true, "other": "thermal decarboxylation in geothermal cycling regime"}, "mechanism": "Thermal decarboxylation of the alpha-keto acid shortens the side chain oxidation state and yields the corresponding aldehyde.", "reasoning": "The research report explicitly identifies phenylacetaldehyde as generable from phenylpyruvate via non-oxidative decarboxylation and highlights phenylpyruvate as a major branch point. This provides a literature-based second entry into the Strecker hub, although detailed prebiotic experimental conditions for this exact conversion remain underdeveloped."}, {"id": "rxn_009", "name": "Mineral-hosted aromatic functionalization from benzene to phenylpyruvate precursor pool", "inputs": ["mol_003", "mol_014"], "outputs": ["mol_011"], "environment": "Hydrothermal", "agents": ["pyrite (FeS2)", "mackinawite (FeS)"], "conditions": {"temperature": "~373K", "pressure": "high", "catalyst": "Fe-S mineral surfaces in alkaline hydrothermal microcompartments", "aqueous": true, "other": "anoxic vent mixing zones; stepwise carboxylative and side-chain functionalization represented in lumped form"}, "mechanism": "Net mineral-assisted carboxylative side-chain elaboration of an aromatic core to an alpha-keto acid branch point.", "reasoning": "This reaction is a necessary lumped connector reflecting the literature statement that phenylpyruvate is the key branch point toward phenylalanine and is more ancient than arogenate chemistry (Yoo et al., 2013), while hydrothermal amino-acid-forming energetics are favorable at vent mixing zones (Kitadai, 2015). No direct prebiotic one-step benzene-to-phenylpyruvate synthesis has been demonstrated; therefore this node-connecting transformation is explicitly speculative but included to represent the unresolved bridge identified in the report."}, {"id": "rxn_010", "name": "PAH photoprocessing route from naphthalene-containing ice residues to phenylalanine", "inputs": ["mol_013", "mol_007"], "outputs": ["mol_010"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "borate minerals (colemanite/ulexite)"], "conditions": {"temperature": "cryogenic ice photolysis precursor stage at 15K followed by surface delivery and warming", "pressure": "low to 1 atm after deposition", "catalyst": "UV-activated surface minerals as collection/concentration supports", "aqueous": false, "other": "UV/EUV irradiation of PAH + H2O + NH3 ice residues; extraterrestrial-to-surface transfer"}, "mechanism": "Photochemical functionalization and fragmentation of PAH-containing ices yields a residue containing amino acids including phenylalanine upon warming and recovery.", "reasoning": "Nuevo et al. (2007) showed that UV/EUV irradiation of naphthalene in H2O/NH3 ice at 15 K produced phenylalanine as the most abundant aromatic amino acid in the residue. Nuevo et al. (2008) further argued that pre-existing aromatic precursors are required. This route is not terrestrial hydrothermal synthesis but provides a literature-supported complementary source feeding the surface network."}, {"id": "rxn_011", "name": "Oxidative cleavage relationship between phenylpyruvate and benzaldehyde", "inputs": ["mol_011"], "outputs": ["mol_012"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "variable", "pressure": "1 atm", "catalyst": null, "aqueous": true, "other": "trace oxidant-independent bookkeeping of branch relationship under prebiotic interface conditions"}, "mechanism": "Branch decomposition/cleavage of phenylpyruvate to aromatic aldehyde pool.", "reasoning": "The research report states that phenylpyruvate connects to benzaldehyde via oxidative cleavage, establishing benzaldehyde as a related branch product. Inclusion here serves network connectivity and aromatic branch accounting; however, exact anoxic prebiotic realization is uncertain and thus this node is a speculative but literature-motivated branch representation."}, {"id": "rxn_012", "name": "High-
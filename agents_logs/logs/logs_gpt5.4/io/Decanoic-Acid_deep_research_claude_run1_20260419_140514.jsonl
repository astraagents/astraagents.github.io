nputs": ["mol_001", "mol_002"], "outputs": ["mol_003"], "environment": "Hydrothermal", "agents": ["greigite (Fe3S4)", "mackinawite (FeS)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "greigite and mackinawite", "aqueous": "true", "other": "alkaline vent to subseafloor interface; C1 organics accumulate as formate/formic acid"}, "mechanism": "Mineral-mediated reduction of dissolved inorganic carbon yields formate/formic acid as a kinetically accessible C1 reduced carbon pool.", "reasoning": "Vent systems contain measurable formate and Fe-S minerals can activate CO2 to short-chain reduced products, making formate a plausible and literature-supported C1 hub even though C10 synthesis itself is not demonstrated on sulfides; this aligns with the report's emphasis that CO-generating intermediates such as formate are likely important upstream of FTT (Proskurowski et al., 2008; Santos-Carballal et al., 2018; McCollom et al., 2010)."}, {"id": "rxn_003", "name": "Thermal CO generation from formic acid", "inputs": ["mol_003"], "outputs": ["mol_004"], "environment": "Hydrothermal", "agents": ["elemental iron (Fe0)", "magnetite (Fe3O4)"], "conditions": {"temperature": "423-523K", "pressure": "high", "catalyst": "native iron and magnetite surfaces", "aqueous": "true", "other": "subsurface/post-impact hydrothermal reactors; CO-generating intermediate step feeding FTT"}, "mechanism": "Formic acid decomposes/dehydrates on metal-rich surfaces to generate CO available for chain growth chemistry.", "reasoning": "The literature identifies CO or CO-generating precursors such as formic acid as critical because dissolved CO2 alone is ineffective for hydrocarbon-forming FTT under comparable conditions; this reaction operationalizes that constraint without asserting unsupported mild-temperature direct CO2-to-C10 synthesis (McCollom et al., 2010; McCollom and Seewald, 2001)."}, {"id": "rxn_004", "name": "Thermal CO generation from oxalic acid", "inputs": ["mol_005"], "outputs": ["mol_004"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "448K for 2-3 days", "pressure": "1 atm to confined evaporitic vessel", "catalyst": "hot mineral surfaces promoting decarboxylation/dehydration", "aqueous": "true", "other": "post-impact or geothermal pool analogue; oxalic acid/formic acid feedstocks used in heated aqueous experiments"}, "mechanism": "Oxalic acid thermally decomposes to CO2/CO-generating species under heated aqueous-drying conditions, contributing to CO feed for downstream FTT reactors.", "reasoning": "McCollom, Ritter, and Simoneit used formic and oxalic acid as productive precursors for abiotic lipid synthesis in heated steel systems; this node captures oxalate as a CO-generating precursor without claiming unsupported direct chain elongation in solution (McCollom et al., 1999)."}, {"id": "rxn_005", "name": "Aqueous Fischer-Tropsch-type amphiphile synthesis on Fe-Ni-Cr steel-like surfaces", "inputs": ["mol_003", "mol_004", "mol_002"], "outputs": ["mol_006", "mol_007", "mol_008", "mol_009", "mol_010", "mol_011"], "environment": "Hydrothermal", "agents": ["elemental iron (Fe0)", "magnetite (Fe3O4)"], "conditions": {"temperature": "448K for 2-3 days", "pressure": "high", "catalyst": "Fe-Ni-Cr steel-like metallic reactor surfaces approximated here by native Fe0 plus magnetite/Fe-Ni phases", "aqueous": "true", "other": "products span C2 to >C35 with n-alkanoic acids, n-alkanols, alkanes, alkenes, and ketones; acids favored above 200C"}, "mechanism": "Surface-bound CO insertion and hydrogenation produce an Anderson-Schulz-Flory-like homologous distribution of amphiphiles rather than deterministic stepwise free-acid elongation.", "reasoning": "This is the strongest direct literature-supported route: heated aqueous formic/oxalic acid on steel walls produced C2 to >C35 lipids, with alkanoic acids increasingly favored above 200C; the network therefore represents decanoic acid as one member of a distribution, explicitly addressing prior criticism of artificial acetate\u2192butyrate\u2192hexanoate\u2192octanoate\u2192decanoate reactions (McCollom et al., 1999; Rushdi and Simoneit, 2001)."}, {"id": "rxn_006", "name": "Gas-phase Fischer-Tropsch-type synthesis on meteoritic iron favoring C9-C10", "inputs": ["mol_004", "mol_002"], "outputs": ["mol_007", "mol_008", "mol_009", "mol_010", "mol_011"], "environment": "Hydrothermal", "agents": ["elemental iron (Fe0)", "pyrite (FeS2)"], "conditions": {"temperature": "673K for 24-48 h", "pressure": "elevated gas-phase reactor", "catalyst": "meteoritic native iron analogue; K2CO3-promoted system in the original study", "aqueous": "false", "other": "D2/CO approximately 1:1 in original experiment; Gaussian distribution peaked at C9-C10"}, "mechanism": "Gas-phase FTT chain growth on metallic iron surfaces yields saturated fatty acids and related amphiphiles with a medium-chain maximum near decanoic acid.", "reasoning": "Nooner and Oro directly observed saturated fatty acids from C5 to C18 with a distribution peaking at C9-C10 on Canyon Diablo meteoritic iron, making this the most specific experimental support for decanoic acid production; pyrite is included as a plausible natural Fe-sulfide co-mineral but the key evidence is native meteoritic iron catalysis (Nooner and Oro, 1979)."}, {"id": "rxn_007", "name": "Post-impact global FTT production on iron-rich surfaces", "inputs": ["mol_001", "mol_002", "mol_004"], "outputs": ["mol_006", "mol_007", "mol_008", "mol_009", "mol_010", "mol_011"], "environment": "Surface", "agents": ["elemental iron (Fe0)", "magnetite (Fe3O4)"], "conditions": {"temperature": ">373K", "pressure": "post-impact atmosphere", "catalyst": "iron-rich impactor-derived metallic surfaces", "aqueous": "true", "other": "reducing atmosphere containing H2, CO, and CO2; synthesis can persist for thousands of years after large impacts"}, "mechanism": "Impact-generated Fe-rich surfaces catalyze FTT conversion of reducing atmospheric gases into a broad fatty-acid distribution including decanoic acid.", "reasoning": "Quantitative modeling identifies post-impact FTT on iron-rich surfaces as the largest prebiotic source of fatty acids, about 100-fold greater than meteoritic delivery or spark/electrochemical synthesis; this route is consistent with the literature emphasis on CO-bearing reducing atmospheres rather than dissolved CO2 alone (Cohen et al., 2023)."}, {"id": "rxn_008", "name": "Extraterrestrial delivery of meteoritic monocarboxylic acids", "inputs": ["mol_006"], "outputs": ["mol_007", "mol_008", "mol_009", "mol_010", "mol_014"], "environment": "Surface", "agents": ["montmorillonite (clay)", "borate minerals (colemanite/ulexite)"], "conditions": {"temperature": "250-320K during deposition then warming", "pressure": "1 atm", "catalyst": "mineral adsorption after delivery", "aqueous": "true", "other": "meteorite parent-body synthesis delivers C2-C12 monocarboxylic acids; surface minerals capture and retain amphiphiles"}, "mechanism": "Carbonaceous meteorites deliver a preformed homologous acid mixture that becomes incorporated into surface concentrates by adsorption and evaporation.", "reasoning": "Meteorites such as Murchison contain straight and branched monocarboxylic acids up to at least C12, and meteoritic extracts form vesicles; although insufficient alone for bulk supply, delivery is a documented auxiliary source feeding the same surface amphiphile pool (Yuen and Kvenvolden, 1973; Lawless and Yuen, 1979; Huang et al., 2005; Deamer, 1985; Pearce et al., 2019)."}, {"id": "rxn_009", "name": "Surface concentration of decanoic-acid-containing amphiphile mixtures", "inputs": ["mol_010", "mol_011", "mol_006", "mol_007", "mol_008", "mol_009"], "outputs": ["mol_014"], "environment": "Surface", "agents": ["montmorillonite (clay)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "293-343K", "pressure": "1 at
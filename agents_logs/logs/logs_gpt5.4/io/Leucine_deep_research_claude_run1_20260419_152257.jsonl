inputs": ["mol_005", "mol_006"], "outputs": ["mol_009"], "environment": "Surface", "agents": ["borate minerals (colemanite/ulexite)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "borate/TiO2 mineral surfaces", "aqueous": "true", "other": "wet-dry cycling and UV-assisted aldol/radical chemistry in evaporitic or volcanic pools"}, "mechanism": "Aldol-type carbon-carbon bond formation and branching from small aldehydes generate branched C4 aldehydes such as isobutyraldehyde.", "reasoning": "The literature identifies aldol condensation cascades and radical recombination as plausible generators of branched carbon skeletons from formaldehyde and acetaldehyde, with isobutyraldehyde specifically highlighted as a branch-point intermediate. This connection remains partly speculative but is directly motivated by the reported unresolved branched-skeleton problem (Parker et al., 2011b; Sutton, Pulletikurti, & Krishnamurthy, 2025; Butlerov, 1861)."}, {"id": "rxn_007", "name": "Surface chain extension from isobutyraldehyde to isovaleraldehyde", "inputs": ["mol_009", "mol_005"], "outputs": ["mol_010"], "environment": "Surface", "agents": ["borate minerals (colemanite/ulexite)", "montmorillonite (clay)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "borate/clay mineral surfaces", "aqueous": "true", "other": "crossed aldol and dehydration/reduction sequence under wet-dry cycling"}, "mechanism": "One-carbon homologation/branch-preserving aldol chemistry extends the C4 branched aldehyde to the C5 Strecker precursor isovaleraldehyde.", "reasoning": "The deep research specifically states that isobutyraldehyde can extend by one carbon unit to yield isovaleraldehyde via further aldol chemistry or radical insertion. This is therefore retained as a necessary but explicitly non-demonstrated connecting step rather than compressed unsupported chemistry (Parker et al., 2011b; Sutton, Pulletikurti, & Krishnamurthy, 2025)."}, {"id": "rxn_008", "name": "Spark-discharge branched aldehyde production directly to isovaleraldehyde", "inputs": ["mol_006", "mol_003"], "outputs": ["mol_010", "mol_004"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "sulfide minerals (stibnite/molybdenite)"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "volcanic mineral aerosol surfaces", "aqueous": "true", "other": "H2S-rich electrical discharge with radical recombination followed by oxidation and dissolution"}, "mechanism": "Gas-phase radical recombination builds branched hydrocarbons and aldehydes, including precursors to isovaleraldehyde, while also generating HCN.", "reasoning": "Miller-type spark systems, especially H2S-containing variants, are the only classic one-pot experiments known to yield leucine, implying in situ generation of branched aldehydes like isovaleraldehyde by radical pathways before Strecker conversion (Ring et al., 1972; Parker et al., 2011; Miller & Van Trump, 1981)."}, {"id": "rxn_009", "name": "Strecker formation of leucine aminonitrile from isovaleraldehyde", "inputs": ["mol_010", "mol_003", "mol_004"], "outputs": ["mol_012"], "environment": "Surface", "agents": ["sulfide minerals (stibnite/molybdenite)", "montmorillonite (clay)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "mineral concentration surfaces", "aqueous": "true", "other": "aqueous Strecker conditions following aldehyde dissolution; anoxic"}, "mechanism": "Isovaleraldehyde forms an imine with ammonia, then cyanide addition gives the corresponding aminonitrile.", "reasoning": "This is the canonical prebiotic route to leucine from a branched aldehyde and is directly supported by Strecker theory for amino acid formation in spark experiments and by isotopic studies of amino acid Strecker products (Miller & Van Trump, 1981; Chimiak et al., 2022)."}, {"id": "rxn_010", "name": "Hydrolysis of leucine aminonitrile to leucine", "inputs": ["
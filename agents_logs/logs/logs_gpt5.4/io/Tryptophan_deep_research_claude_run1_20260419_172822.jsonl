chi\": \"InChI=1S/C11H11N3/c12-6-9(13)5-8-7-14-11-4-2-1-3-10(8)11/h1-4,7,9,14H,5,13H2\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_018\",\n      \"formula\": \"C11H12N2O2\",\n      \"iupac_name\": \"2-amino-3-(1H-indol-3-yl)propanoic acid\",\n      \"common_name\": \"tryptophan\",\n      \"inchi\": \"InChI=1S/C11H12N2O2/c12-10(11(14)15)6-7-5-13-9-4-2-1-3-8(7)9/h1-5,10,13H,6,12H2,(H,14,15)\",\n      \"role\": \"target\",\n      \"environment_formed\": \"Biochemical\"\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"Hydrothermal CO2 reduction to formate on greigite/mackinawite\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_004\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe3S4)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"greigite (Fe3S4), mackinawite (FeS)\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline vent conditions, anoxic, H2-rich\"\n      },\n      \"mechanism\": \"Mineral-surface hydrogenation of CO2 on Fe-S sites gives surface-bound reduced C1 species released as formate.\",\n      \"reasoning\": \"Supported by iron-sulfur world and hydrothermal vent studies showing CO2 reduction on FeS/Fe3S4-type minerals and favorable vent thermodynamics; used here as the network's conservative C1 entry step under alkaline hydrothermal conditions (Russell & Hall, 1997; Martin & Russell, 2007; White et al., 2015; Santos-Carballal et al., 2018; Amend & Shock, 1998).\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Hydrothermal C1 reduction from formate to formaldehyde\",\n      \"inputs\": [\"mol_004\", \"mol_002\"],\n      \"outputs\": [\"mol_005\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe3O4)\", \"elemental iron (Fe0)\"],\n      \"conditions\": {\n        \"temperature\": \"370-470K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"magnetite (Fe3O4), elemental iron (Fe0)\",\n        \"aqueous\": \"true\",\n        \"other\": \"subseafloor reducing conditions; treated as a connecting reduction step\"\n      },\n      \"mechanism\": \"Further reduction of a C1 carboxylate equivalent on iron-bearing mineral surfaces affords a more reduced aldehyde-level carbon intermediate.\",\n      \"reasoning\": \"This is a conservative connector motivated by hydrothermal CO2 hydrogenation/Fischer-Tropsch-type chemistry on iron minerals; the exact formate-to-formaldehyde conversion is less directly demonstrated than formate formation and is included as a necessary but partially speculative link to literature-supported sugar chemistry (Amend & Shock, 1998; White et al., 2015; Santos-Carballal et al., 2018).\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Formose entry: formaldehyde to glycolaldehyde\",\n      \"inputs\": [\"mol_005\"],\n      \"outputs\": [\"mol_006\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite)\", \"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"borate minerals (colemanite/ulexite), montmorillonite\",\n        \"aqueous\": \"true\",\n        \"other\": \"evaporitic pool or geothermal field, wet-dry concentration, anoxic\"\n      },\n      \"mechanism\": \"Base/mineral-assisted carbonyl coupling within formose-like chemistry generates the C2 sugar aldehyde; borate helps stabilize carbohydrate products.\",\n      \"reasoning\": \"Grounded in classic formose chemistry from formaldehyde and the literature emphasis that glyceraldehyde/serine precursors arise from formose-type networks, with borate stabilization of sugars in surface settings (Butlerow, 1861; Breslow, 1959; Li et al., 2024).\"\n    },\n    {\n      \"id\": \"
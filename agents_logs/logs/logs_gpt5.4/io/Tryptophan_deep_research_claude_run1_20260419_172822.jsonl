     \"inchi\": \"InChI=1S/C10H9NO/c12-6-5-8-7-11-10-4-2-1-3-9(8)10/h1-4,6-7,11H,5H2\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_016\",\n      \"formula\": \"C11H11N3\",\n      \"iupac_name\": \"2-amino-3-(1H-indol-3-yl)propanenitrile\",\n      \"common_name\": \"tryptophan aminonitrile\",\n      \"inchi\": \"InChI=1S/C11H11N3/c12-6-9(13)7-8-5-14-11-4-2-1-3-10(8)11/h1-5,9,14H,7,13H2\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_017\",\n      \"formula\": \"C11H12N2O2\",\n      \"iupac_name\": \"2-amino-3-(1H-indol-3-yl)propanoic acid\",\n      \"common_name\": \"tryptophan\",\n      \"inchi\": \"InChI=1S/C11H12N2O2/c12-10(11(14)15)6-7-5-13-9-4-2-1-3-8(7)9/h1-5,10,13H,6,12H2,(H,14,15)\",\n      \"role\": \"target\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_018\",\n      \"formula\": \"CH3NO\",\n      \"iupac_name\": \"formamide\",\n      \"common_name\": \"formamide\",\n      \"inchi\": \"InChI=1S/CH3NO/c2-1-3/h1H,(H2,2,3)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_019\",\n      \"formula\": \"C7H7NO2\",\n      \"iupac_name\": \"2-aminobenzoic acid\",\n      \"common_name\": \"anthranilic acid\",\n      \"inchi\": \"InChI=1S/C7H7NO2/c8-6-4-2-1-3-5(6)7(9)10/h1-4H,8H2,(H,9,10)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"Hydrothermal CO2 reduction to formate\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_005\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe3S4)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"greigite/mackinawite\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline vent, H2-rich, anoxic\"\n      },\n      \"mechanism\": \"Mineral-surface CO2 activation followed by hydrogenation to formate on Fe-S phases.\",\n      \"reasoning\": \"Hydrothermal Fe-S catalysis of CO2 reduction to formate is foundational to alkaline vent carbon fixation models and is consistent with vent chimney mineralogy and geochemical plausibility (Russell & Hall, 1997; Martin & Russell, 2007; White et al., 2015; Santos-Carballal et al., 2018).\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Hydrothermal reduced-carbon diversification to formaldehyde and pyruvate-equivalent pool\",\n      \"inputs\": [\"mol_005\", \"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_006\", \"mol_010\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe3O4)\", \"elemental iron (Fe0)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"magnetite/Fe0\",\n        \"aqueous\": \"true\",\n        \"other\": \"strongly reducing, subseafloor/alkaline vent interface; network-bridging abstraction of vent carbon fixation products\"\n      },\n      \"mechanism\": \"Successive CO2/formate reduction and C-C bond-forming vent chemistry generate a reduced carbon pool feeding aldehydes and alpha-keto acids.\",\n      \"reasoning\": \"Direct one-step experimental conversion to both formaldehyde and pyruvate is not established; this node is a conservative network abstraction representing hydrothermal reduced-carbon output that underpins prebiotic alpha-keto acid chemistry. It is included strictly to connect literature-supported vent fixation chemistry to downstream amino acid and sugar precursor chemistry; pyruvate formation from hydrothermal CO2/H2 systems is discussed in vent-origin frameworks, while amino acid formation from CO2/NH4+/H2 becomes thermodynamically favorable at hydrothermal conditions (Amend & Shock, 1998; Russell & Hall, 1997; Martin & Russell, 2007).\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Reductive amination of pyruvate to alanine\",\n      \"inputs\": [\"mol_010\", \"mol_003\", \"mol_002\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"pyrite (FeS2)\", \"greigite (Fe3S4)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"pyrite/greigite\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic, reducing vent microenvironment\"\n      },\n      \"mechanism\": \"Surface-mediated reductive amination of an alpha-keto acid to the corresponding amino acid.\",\n      \"reasoning\": \"Reductive amination of alpha-keto acids on sulfide minerals is consistent with hydrothermal amino acid synthesis models; pyrite photochemical reductive amination and Fe-S catalysis support alpha-keto acid to amino acid conversion under plausible prebiotic conditions (Amend & Shock, 1998; Nature Communications, 2024; White et al., 2015).\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"Surface UV generation and concentration of HCN/formamide cyanide pool\",\n      \"inputs\": [\"mol_006\", \"mol_003\"],\n      \"outputs\": [\"mol_004\", \"mol_018\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"sulfide minerals (molybdenite/stibnite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO2 and sulfide mineral-assisted photochemistry\",\n        \"aqueous\": \"true\",\n        \"other\": \"strong UV, evaporitic concentration, anoxic surface pools\"\n      },\n      \"mechanism\": \"Photochemical and dehydration chemistry generates a reactive nitrile/amide pool including HCN and formamide from simple C1 and nitrogen feedstocks.\",\n      \"reasoning\": \"This is a necessary connecting step rather than a single directly demonstrated reaction under the exact stoichiometry shown. The literature supports central roles for HCN and formamide in prebiotic surface chemistry and UV-driven networks, while TiO2 catalyzes formamide-derived heterocycle chemistry and sulfide photoredox systems support cyanosulfidic chemistry. Included as a cautious feedstock-pool abstraction, not as a validated dedicated HCN synthesis experiment for tryptophan (Patel et al., 2015; Saladino et al., 2012; Saladino et al., 2003).\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"Borate-stabilized formose entry to glycolaldehyde and glyceraldehyde\",\n      \"inputs\": [\"mol_006\"],\n      \"outputs\": [\"mol_007\", \"mol_008\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite)\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"borate minerals\",\n        \"aqueous\": \"true\",\n        \"other\": \"evaporitic pools, wet-dry cycling, alkaline episodes\"\n      },\n      \"mechanism\": \"Formose-type aldol network produces small sugars; borate stabilizes pentose/triose intermediates and suppresses decomposition.\",\n      \"reasoning\": \"Glycolaldehyde and glyceraldehyde are established products/intermediates in formaldehyde-derived sugar networks, although selectivity is poor. This is represented as a pooled output rather than an unrealistically single clean step, addressing prior over-compression concerns (Butlerow, 1861; Breslow, 1959; cited in the research summary for formose chemistry and sugar precursor generation).\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"Strecker-type serine synthesis from glycolaldehyde\",\n      \"inputs\": [\"mol_007\", \"mol_004\", \"mol_003\"],\n      \"outputs\": [\"mol_009\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (molybdenite/stibnite)\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral-assisted aqueous Strecker/hydrolysis sequence\",\n        \"aqueous\": \"true\",\n        \"other\": \"evaporitic pool concentration followed by hydrolytic workup\"\n      },\n      \"mechanism\": \"Aldehyde imination with ammonia, cyanide addition to aminonitrile, then hydrolysis to the amino acid.\",\n      \"reasoning\": \"Serine is one of the more plausible prebiotic amino acids and is discussed in the literature as accessible from glycolaldehyde or glyceraldehyde through Strecker logic; the displayed reaction compresses aminonitrile formation and hydrolysis into one network node for tractability (Kirschning, 2022; Li et al., 2024).\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Alternative Strecker-type serine synthesis from glyceraldehyde\",\n      \"inputs\": [\"mol_008\", \"mol_004\", \"mol_003\"],\n      \"outputs\": [\"mol_009\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (molybdenite/stibnite)\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral-assisted aqueous Strecker/hydrolysis sequence\",\n        \"aqueous\": \"true\",\n        \"other\": \"wet-dry cycles, concentration in shallow pools\"\n      },\n      \"mechanism\": \"Aldehyde-to-aminonitrile Strecker sequence followed by hydrolysis to serine.\",\n      \"reasoning\": \"The literature explicitly notes glycolaldehyde or glyceraldehyde as plausible serine precursors in prebiotic chemistry. This provides a second convergent route to the serine hub (Kirschning, 2022; Li et al., 2024).\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Hydrothermal pyrrole synthesis from acetylene and ammonia\",\n      \"inputs\": [\"mol_012\", \"mol_003\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"mackinawite (FeS)\", \"pyrite (FeS2)\"],\n      \"conditions\": {\n        \"temperature\": \"378K\",\n        \"pressure\": \"moderate\",\n        \"catalyst\": \"sulfide mineral hydrothermal analog; literature specifically used NiS/CoS\",\n        \"aqueous\": \"true\",\n        \"other\": \"anaerobic volcanic-hydrothermal setting; network uses Fe-sulfide analogs to satisfy schema while noting literature metal sulfides\"\n      },\n      \"mechanism\": \"Acetylene-ammonia coupling on metal sulfide surfaces gives N-heterocycle formation.\",\n      \"reasoning\": \"Pyrrole formation from acetylene and ammonia under aqueous anaerobic catalytic conditions is experimentally supported, though the published catalysts were NiS and CoS rather than Fe-only phases. This reaction is included because pyrrole is one of the few documented prebiotic heteroaromatic precursors relevant to indole chemistry (Seel et al., 2021).\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"Indole delivery/availability node from exogenous and hydrothermal sources\",\n      \"inputs\": [\"mol_013\", \"mol_012\", \"mol_003\"],\n      \"outputs\": [\"mol_014\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"iron-rich saponite\", \"greigite (Fe3S4)\"],\n      \"conditions\": {\n        \"temperature\": \"278-363K hydrothermal; 5-10K in interstellar precursor stage\",\n        \"pressure\": \"mixed: extraterrestrial low-pressure source plus hydrothermal emplacement\",\n        \"catalyst\": \"iron-rich saponite as concentrator; interstellar energetic processing for source formation\",\n        \"aqueous\": \"true\",\n        \"other\": \"represents two evidence lines: exogenous indole formation and natural hydrothermal occurrence; terrestrial de novo indole synthesis remains unverified\"\n      },\n      \"mechanism\": \"Network convergence node for indole availability through exogenous delivery and/or unresolved hydrothermal generation in serpentinization environments.\",\n      \"reasoning\": \"This reaction is intentionally marked as a source-availability abstraction rather than a validated terrestrial annulation reaction. Indole was directly observed from acetylene/ammonia interstellar ice chemistry, and indole was also detected in Atlantis Massif serpentinites associated with putative abiotic organosynthesis. No prebiotic Earth laboratory route from pyrrole to indole is known, so this node avoids claiming a solved mechanism (Kaiser et al., 2024; M\u00e9nez et al., 2018).\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"Fe-rich saponite nanoconfined hydrothermal tryptophan-forming branch\",\n      \"inputs\": [\"mol_014\", \"mol_011\", \"mol_009\"],\n      \"outputs\": [\"mol_017\", \"mol_015\", \"mol_019\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"iron-rich saponite\", \"pyrite (FeS2)\"],\n      \"conditions\": {\n        \"temperature\": \"313-473K\",\n        \"pressure\": \"moderate to high\",\n        \"catalyst\": \"Fe2+/Fe3+-substituted saponite nanopores\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline pH 9-11, serpentinization-derived H2/NH3, reducing nanoconfined microreactors, Lost City-type system\"\n      },\n      \"mechanism\": \"Fe-rich clay nanoconfinement promotes aromatic side-chain installation/Friedel-Crafts-like chemistry and associated aromatic amino-acid precursor formation.\",\n      \"reasoning\": \"This is the core literature-grounded but unreplicated hydrothermal hypothesis. M\u00e9nez et al. reported abiotic tryptophan together with indole, skatole, and hydroxyanthranilate in iron-rich saponite nanopores from serpentinites and proposed Fe-saponite-catalyzed Friedel-Crafts alkylation under alkaline reducing hydrothermal conditions. Because the exact sequence is unresolved, this node outputs tryptophan and two observed/related intermediates rather than asserting a fully defined stepwise mechanism (M\u00e9nez et al., 2018; Proskurowski et al., 2008).\"\n    },\n    {\n      \"id\": \"rxn_011\",\n      \"name\": \"Speculative formation of indole-3-acetaldehyde from indole in confined prebiotic media\",\n      \"inputs\": [\"mol_014\", \"mol_007\"],\n      \"outputs\": [\"mol_015\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [null, null],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"null\",\n        \"aqueous\": \"true\",\n        \"other\": \"concentrated interfaces, mineral confinement or membrane partitioning; explicitly speculative\"\n      },\n      \"mechanism\": \"Hypothetical side-chain oxidation/extension from indole to the corresponding aldehyde precursor.\",\n      \"reasoning\": \"Kirschning (2022) explicitly states that Strecker synthesis from indole-3-acetaldehyde is theoretically sound but that this aldehyde has no known prebiotic source and is unstable. This node is therefore deliberately labeled speculative and included only because the literature identifies indole-3-acetaldehyde as the key theoretical Strecker precursor to tryptophan (Kirschning, 2022).\"\n    },\n    {\n      \"id\": \"rxn_012\",\n      \"name\": \"Strecker-type tryptophan aminonitrile formation\",\n      \"inputs\": [\"mol_015\", \"mol_004\", \"mol_003\"],\n      \"outputs\": [\"mol_016\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (molybdenite/stibnite)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral-assisted concentration\",\n        \"aqueous\": \"true\",\n        \"other\": \"evaporitic or shoreline pools, anoxic, cyanide-rich\"\n      },\n      \"mechanism\": \"Canonical Strecker addition to an aldehyde gives the alpha-aminonitrile corresponding to tryptophan.\",\n      \"reasoning\": \"The literature identifies this route as chemically sensible in principle: indole-3-acetaldehyde + HCN + NH3 gives a tryptophan aminonitrile precursor. The step is included because it is the best-defined bottom-up route once the aldehyde exists, even though its precursor source remains unresolved (Kirschning, 2022).\"\n    },\n    {\n      \"id\": \"rxn_013\",\n      \"name\": \"Hydrolysis of tryptophan aminonitrile to tryptophan\",\n      \"inputs\": [\"mol_016\"],\n      \"outputs\": [\"mol_017\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [null, null],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"null\",\n        \"aqueous\": \"true\",\n        \"other\": \"geothermal cycling or prolonged aqueous hydrolysis\"\n      },\n      \"mechanism\": \"Nitrile hydration and hydrolysis convert the aminonitrile to the alpha-amino acid.\",\n      \"reasoning\": \"Hydrolysis of aminonitriles to amino acids is standard Strecker follow-up chemistry and is the most defensible late-stage conversion in a hypothetical tryptophan network. Included as the least speculative portion of the indole-3-acetaldehyde route (Kirschning, 2022).\"\n    }\n  ],\n  \"pathways\": [\n    {\n      \"pathway_id\": \"P1\",\n      \"name\": \"Lost City direct hydrothermal saponite route from alanine-supported precursor pool\",\n      \"description\": \"Hydrothermal carbon fixation yields pyruvate and alanine; indole availability converges in Fe-rich saponite nanopores where the M\u00e9nez-type hydrothermal branch gives tryptophan.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_003\", \"rxn_009\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_005\", \"mol_010\", \"mol_011\", \"mol_014\"]\n    },\n    {\n      \"pathway_id\": \"P2\",\n      \"name\": \"Lost City direct hydrothermal saponite route with serine branch\",\n      \"description\": \"Hydrothermal reduced carbon feeds surface sugar chemistry and Strecker serine synthesis; indole and serine re-enter hydrothermal nanoconfined Fe-saponite settings that yield tryptophan-like products.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_004\", \"rxn_005\", \"rxn_006\", \"rxn_009\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_006\", \"mol_004\", \"mol_007\", \"mol_009\", \"mol_014\"]\n    },\n    {\n      \"pathway_id\": \"P3\",\n      \"name\": \"Alternative serine-entry hydrothermal saponite route\",\n      \"description\": \"As in P2, but serine derives from glyceraldehyde rather than glycolaldehyde before convergence with indole in hydrothermal clay nanopores.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_004\", \"rxn_005\", \"rxn_007\", \"rxn_009\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_006\", \"mol_004\", \"mol_008\", \"mol_009\", \"mol_014\"]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"Acetylene-to-pyrrole-assisted indole availability plus hydrothermal saponite branch\",\n      \"description\": \"Hydrothermal acetylene and ammonia produce pyrrole; indole availability is treated as unresolved but supported by exogenous and natural hydrothermal occurrence; final tryptophan formation follows the M\u00e9nez scenario.\",\n      \"reaction_sequence\": [\"rxn_008\", \"rxn_009\", \"rxn_001\", \"rxn_002\", \"rxn_003\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_013\", \"mol_014\", \"mol_010\", \"mol_011\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"Exogenous indole plus hydrothermal alanine nanoconfinement route\",\n      \"description\": \"Indole is supplied by exogenous or unresolved hydrothermal sources; hydrothermal alanine production and Fe-rich saponite nanoconfinement yield tryptophan directly in the natural-setting hypothesis.\",\n      \"reaction_sequence\": [\"rxn_009\", \"rxn_001\", \"rxn_002\", \"rxn_003\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_014\", \"mol_010\", \"mol_011\"]\n    },\n    {\n      \"pathway_id\": \"P6\",\n      \"name\": \"Exogenous indole plus glycolaldehyde-Strecker to aminonitrile route\",\n      \"description\": \"Hydrothermal reduced carbon feeds HCN and glycolaldehyde production; a speculative indole-3-acetaldehyde precursor is then converted through the literature-theoretical Strecker aminonitrile route to tryptophan.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_004\", \"rxn_005\", \"rxn_009\", \"rxn_011\", \"rxn_012\", \"rxn_013\"],\n      \"key_intermediates\": [\"mol_006\", \"mol_004\", \"mol_007\", \"mol_014\", \"mol_015\", \"mol_016\"]\n    },\n    {\n      \"pathway_id\": \"P7\",\n      \"name\": \"Exogenous indole plus glyceraldehyde-assisted aldehyde precursor route\",\n      \"description\": \"A second variant of the Strecker endgame using the same unresolved aromatic aldehyde precursor but a different sugar-entry branch upstream.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_004\", \"rxn_005\", \"rxn_009\", \"rxn_011\", \"rxn_012\", \"rxn_013\"],\n      \"key_intermediates\": [\"mol_006\", \"mol_008\", \"mol_014\", \"mol_015\", \"mol_016\"]\n    },\n    {\n      \"pathway_id\": \"P8\",\n      \"name\": \"Pyrrole-enabled indole availability followed by Strecker endgame\",\n      \"description\": \"Pyrrole from acetylene/ammonia feeds the indole hub; once indole-3-acetaldehyde is admitted as a speculative precursor, Strecker aminonitrile chemistry leads to tryptophan.\",\n      \"reaction_sequence\": [\"rxn_008\", \"rxn_009\", \"rxn_011\", \"rxn_012\", \"rxn_013\"],\n      \"key_intermediates\": [\"mol_013\", \"mol_014\", \"mol_015\", \"mol_016\"]\n    },\n    {\n      \"pathway_id\": \"P9\",\n      \"name\": \"Serine-rich pool with indole hydrothermal re-entry\",\n      \"description\": \"Surface synthesis of serine from glycolaldehyde converges with hydrothermal indole availability and Fe-saponite nanoconfinement to produce tryptophan in the strongest natural-setting hypothesis.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_004\", \"rxn_005\", \"rxn_006\", \"rxn_008\", \"rxn_009\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_009\", \"mol_013\", \"mol_014\"]\n    },\n    {\n      \"pathway_id\": \"P10\",\n      \"name\": \"Dual-hub integrated route comparing hydrothermal and Strecker terminal solutions\",\n      \"description\": \"This integrated pathway passes through all major hubs and emphasizes that the field currently has two conditional terminal solutions: the natural-setting Fe-saponite route and the theoretical indole-3-acetaldehyde Strecker route. The listed sequence follows the latter for graph completeness.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_003\", \"rxn_004\", \"rxn_005\", \"rxn_007\", \"rxn_008\", \"rxn_009\", \"rxn_011\", \"rxn_012\", \"rxn_013\"],\n      \"key_intermediates\": [\"mol_010\", \"mol_011\", \"mol_004\", \"mol_008\", \"mol_009\", \"mol_013\", \"mol_014\", \"mol_015\", \"mol_016\"]\n    }\n  ],\n  \"hub_molecules\": [\"mol_004\", \"mol_009\", \"mol_011\", \"mol_014\", \"mol_015\"],\n  \"convergence_points\": [\n    {\n      \"molecule_id\": \"mol_009\",\n      \"incoming_reactions\": [\"rxn_006\", \"rxn_007\"],\n      \"outgoing_reactions\": [\"rxn_010\"]\n    },\n    {\n      \"molecule_id\": \"mol_014\",\n      \"incoming_reactions\": [\"rxn_009\"],\n      \"outgoing_reactions\": [\"rxn_010\", \"rxn_011\"]\n    },\n    {\n      \"molecule_id\": \"mol_011\",\n      \"incoming_reactions\": [\"rxn_003\"],\n      \"outgoing_reactions\": [\"rxn_010\"]\n    },\n    {\n      \"molecule_id\": \"mol_015\",\n      \"incoming_reactions\": [\"rxn_010\", \"rxn_011\"],\n      \"outgoing_reactions\": [\"rxn_012\"]\n    },\n    {\n      \"molecule_id\": \"mol_004\",\n      \"incoming_reactions\": [\"rxn_004\"],\n      \"outgoing_reactions\": [\"rxn_006\", \"rxn_007\", \"rxn_012\"]\n    }\n  ]\n}", "parsed_response": {"target_molecule": "Tryptophan", "overall_strategy": "This network is a literature-constrained hypothesis graph for prebiotic tryptophan centered on the documented bottleneck of indole generation and side-chain installation. It prioritizes the two strongest evidence lines: (1) hydrothermal Lost City-type serpentinization with Fe-rich saponite nanoconfinement, where indole-, skatole-, hydroxyanthranilate-, and tryptophan-like signals were reported, and (2) exogenous/interstellar indole formation from acetylene and ammonia. Because no fully replicated prebiotic terrestrial synthesis of tryptophan exists, the network explicitly marks unresolved links as speculative where required by connectivity. Convergence is organized around four hubs: indole, serine, alanine, and indole-3-acetaldehyde/tryptophan aminonitrile logic. Hydrothermal chemistry supplies reduced carbon and amino-acid precursors; surface chemistry concentrates, stabilizes, and photochemically diversifies feedstocks; biochemical/prebiotic settings provide confinement, hydrolysis, transamination, and aminonitrile conversion steps. The ten pathways are conditional variants through the same constrained evidence landscape rather than ten independently validated syntheses.", "molecules": [{"id": "mol_001", "formula": "CO2", "iupac_name": "carbon dioxide", "common_name": "carbon dioxide", "inchi": "InChI=1S/CO2/c2-1-3", "role": "starting", "environment_formed": null}, {"id": "mol_002", "formula": "H2", "iupac_name": "molecular hydrogen", "common_name": "hydrogen", "inchi": "InChI=1S/H2/h1H", "role": "starting", "environment_formed": null}, {"id": "mol_003", "formula": "NH3", "iupac_name": "azane", "common_name": "ammonia", "inchi": "InChI=1S/H3N/h1H3", "role": "starting", "environment_formed": null}, {"id": "mol_004", "formula": "HCN", "iupac_name": "hydrogen cyanide", "common_name": "hydrogen cyanide", "inchi": "InChI=1S/CHN/c1-2/h1H", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_005", "formula": "CH2O2", "iupac_name": "methanoic acid", "common_name": "formic acid/formate", "inchi": "InChI=1S/CH2O2/c2-1-3/h1H,(H,2,3)", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_006", "formula": "CH2O", "iupac_name": "methanal", "common_name": "formaldehyde", "inchi": "InChI=1S/CH2O/c1-2/h1H2", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_007", "formula": "C2H4O2", "iupac_name": "2-hydroxyethanal", "common_name": "glycolaldehyde", "inchi": "InChI=1S/C2H4O2/c3-1-2-4/h1,3H,2H2", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_008", "formula": "C3H6O3", "iupac_name": "2,3-dihydroxypropanal", "common_name": "glyceraldehyde", "inchi": "InChI=1S/C3H6O3/c4-1-3(6)2-5/h1,3,5-6H,2H2", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_009", "formula": "C3H6O3", "iupac_name": "2-amino-3-hydroxypropanoic acid", "common_name": "serine", "inchi": "InChI=1S/C3H7NO3/c4-2(3(6)7)1-5/h2,5H,1,4H2,(H,6,7)", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_010", "formula": "C3H6O3", "iupac_name": "2-oxopropanoic acid", "common_name": "pyruvic acid", "inchi": "InChI=1S/C3H4O3/c1-2(4)3(5)6/h1H3,(H,5,6)", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_011", "formula": "C3H7NO2", "iupac_name": "2-aminopropanoic acid", "common_name": "alanine", "inchi": "InChI=1S/C3H7NO2/c1-2(4)3(5)6/h2H,4H2,1H3,(H,5,6)", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_012", "formula": "C2H2", "iupac_name": "ethyne", "common_name": "acetylene", "inchi": "InChI=1S/C2H2/c1-2/h1-2H", "role": "starting", "environment_formed": null}, {"id": "mol_013", "formula": "C4H5N", "iupac_name": "1H-pyrrole", "common_name": "pyrrole", "inchi": "InChI=1S/C4H5N/c1-2-4-5-3-1/h1-5H", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_014", "formula": "C8H7N", "iupac_name": "1H-
"C6H12N2O2", "iupac_name": "2,6-diaminohexanoic acid", "common_name": "lysine", "inchi": "InChI=1S/C6H14N2O2/c7-4-2-1-3-5(8)6(9)10/h5H,1-4,7-8H2,(H,9,10)", "role": "target", "environment_formed": "Surface"}, {"id": "mol_013", "formula": "C6H12N2O2", "iupac_name": "diaminohexanoic acid isomer mixture", "common_name": "diaminohexanoic acid isomers", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_014", "formula": "C3H6N2O2", "iupac_name": "2,3-diaminopropanoic acid", "common_name": "diaminopropionic acid", "inchi": "InChI=1S/C3H8N2O2/c4-1-2(5)3(6)7/h2H,1,4-5H2,(H,6,7)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_015", "formula": "C4H10N2O2", "iupac_name": "2,4-diaminobutanoic acid", "common_name": "diaminobutyric acid", "inchi": "InChI=1S/C4H10N2O2/c5-2-1-3(6)4(7)8/h3H,1-2,5-6H2,(H,7,8)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_016", "formula": "C6H14N2O2", "iupac_name": "lysine adsorbed on montmorillonite", "common_name": "clay-bound lysine", "inchi": null, "role": "intermediate", "environment_formed": "Biochemical"}], "reactions": [{"id": "rxn_001", "name": "Hydrothermal CO2 reduction to formate", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_003"], "environment": "Hydrothermal", "agents": ["greigite (Fe3S4)", "mackinawite (FeS)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "greigite and mackinawite", "aqueous": "true", "other": "alkaline vent conditions, anoxic, H2-rich"}, "mechanism": "Mineral-surface mediated reduction of CO2 by H2 to formate on iron-sulfur phases.", "reasoning": "Used to connect hydrothermal reduced-carbon production to later surface inventory chemistry; FeS/Fe3S4-promoted CO2 reduction is consistent with iron-sulfur vent models and hydrothermal amino-acid precursor generation, though not lysine-specific (Huber & Wachtershauser, 1997; Barge et al., 2019; Kitadai et al., 2018)."}, {"id": "rxn_002", "name": "Hydrothermal reduced-carbon generation to formaldehyde inventory", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_004"], "environment": "Hydrothermal", "agents": ["magnetite (Fe3O4)", "elemental iron (Fe0)"], "conditions": {"temperature": "370-470K", "pressure": "high", "catalyst": "magnetite and elemental iron", "aqueous": "true", "other": "subseafloor serpentinization-linked reducing conditions; formaldehyde treated as low-yield reduced-carbon inventory feeding surface chemistry"}, "mechanism": "Fischer-Tropsch-type and serpentinization-associated CO2 hydrogenation generate reduced one-carbon species including formaldehyde-equivalent carbon.", "reasoning": "Included conservatively as a systems-chemistry bridge from hydrothermal carbon fixation to surface carbonyl chemistry; exact formaldehyde yields under these conditions are less secure than formate, so this step is partly connective and lower confidence, but consistent with hydrothermal reduced-carbon generation frameworks (Amend & Shock, 1998; Barge et al., 2019)."}, {"id": "rxn_003", "name": "Surface spark-discharge generation of HCN-rich organic inventory", "inputs": ["mol_004", "mol_005"], "outputs": ["mol_006"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "borate minerals (colemanite/ulexite)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "mineral surfaces present during atmospheric discharge deposition", "aqueous": "true", "other": "CH4/NH3/N2 atmospheric discharge analogue, strong UV and electrical energy, product collected in aqueous phase"}, "mechanism": "Electrical discharge in reduced atmospheres generates HCN and related nitriles that dissolve into surface waters.", "reasoning": "HCN generation is foundational to Miller-Urey-type chemistry and necessary for the literature-supported lysine problem space. Lysine is generally absent from such experiments, but HCN production is well established and underpins later routes (Miller, 1953; Ring et al., 1972; Johnson et al., 2008; Parker et al., 2011; Criado-Reyes et al., 2021)."}, {"id": "rxn_004", "name": "HCN hydration to formamide under surface photochemical conditions", "inputs": ["mol_006"], "outputs": ["mol_007"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "TiO2 and phosphate mineral surfaces", "aqueous": "true", "other": "UV-exposed evaporitic or geothermal pools"}, "mechanism": "Hydration and photochemical conversion of cyanide-derived species gives formamide in concentrated surface settings.", "reasoning": "Formamide is a documented prebiotic nitrogen-rich intermediate linked to UV chemistry, but not a demonstrated direct lysine precursor; here it is included only as a literature-grounded branch in the lysine problem network (Mu\u00f1oz Caro et al., 2002; Nuevo et al., 2008)."}, {"id": "rxn_005", "name": "Aminoacetonitrile formation from HCN-ammonia chemistry", "inputs": ["mol_006", "mol_005"], "outputs": ["mol_008"], "environment": "Surface", "agents": ["montmorillonite (clay)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "montmorillonite and phosphate minerals", "aqueous": "true", "other": "concentrating evaporitic pools or HCN polymerization media"}, "mechanism": "Cyanide-ammonia condensation gives aminonitrile building blocks, especially aminoacetonitrile, within cyanide-rich networks.", "reasoning": "Aminoacetonitrile is central to historical HCN polymerization claims and is a plausible cyanide-derived aminonitrile node, though modern reanalysis does not support lysine production from its polymers (Moser & Matthews, 1968; Cleaves, 2010; Ruiz-Bermejo et al., 2013)."}, {"id": "rxn_006", "name": "HCN polymerization and hydrolysis inventory branch", "inputs": ["mol_008", "mol_006"], "outputs": ["mol_014"], "environment": "Surface", "agents": ["montmorillonite (clay)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "montmorillonite and TiO2", "aqueous": "true", "other": "polymerization followed by hydrolysis; anoxic cyanide-rich conditions"}, "mechanism": "Aminoacetonitrile participates in HCN oligomerization/polymerization networks that, upon hydrolysis, yield small amino acids and diamino acid products.", "reasoning": "Historical lysine claims from HCN polymer hydrolysis are unconfirmed; modern high-resolution analysis instead supports simpler amino acids and related diamino products. This branch is explicitly a literature-supported dead-end/near-miss rather than a validated lysine route (Moser & Matthews, 1968; Cleaves, 2010; Ruiz-Bermejo et al., 2013)."}, {"id": "rxn_007", "name": "Surface discharge chemistry to acrylonitrile", "inputs": ["mol_006", "mol_004"], "outputs": ["mol_009"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "sulfide minerals (stibnite/molybdenite)"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "TiO2 and sulfide mineral surfaces", "aqueous": "true", "other": "UV/discharge-driven nitrile chemistry in evaporitic pools or atmospheric fallout solutions"}, "mechanism": "Energetic cyanide chemistry produces unsaturated nitriles including acrylonitrile as C3 homologation building blocks.", "reasoning": "Acrylonitrile is identified in the literature as a potential C3 building block relevant to the lysine problem, but not as a demonstrated route to lysine itself. It is included because the deep report explicitly identifies it as a plausible precursor class (Thoma & Powner, 2023; Ruiz-Bermejo et al., 2013)."}, {"id": "rxn_008", "name": "Ammonia addition to acrylonitrile giving beta-aminopropionaldehyde equivalent inventory", "inputs": ["mol_009", "mol_005"], "outputs": ["mol_010"], "environment": "Surface", "agents": ["sulfide minerals (stibnite/molybdenite)", "montmorillonite (clay)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "sulfide minerals and montmorillonite", "aqueous": "true", "other": "cyanide/ammonia-rich pools; step treated as idealized inventory access rather than a robust isolated reaction"}, "mechanism": "Nucleophilic nitrogen addition to an activated nitrile/unsaturated nitrile network yields beta-aminated C3 intermediates represented here by beta-aminopropionaldehyde-equivalent chemistry.", "reasoning": "The deep report identifies beta-aminopropionaldehyde as a relevant intermediate in the cyanosulfidic/HCN homologation problem, but further elongation is specifically blocked by cyclization. This step is therefore included only to map the documented bottleneck, not as a high-confidence isolated synthesis (Patel et al., 2015; Thoma & Powner, 2023)."}, {"id": "rxn_009", "name": "Attempted homologation toward 5-aminopentanal bottleneck", "inputs": ["mol_010", "mol_006"], "outputs": ["mol_011"], "environment": "Surface", "agents": ["borate minerals (colemanite/ulexite)", "sulfide minerals (stibnite/molybdenite)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "borate and sulfide minerals", "aqueous": "true", "other": "UV-assisted cyanosulfidic homologation regime; cyclization strongly competes"}, "mechanism": "Further chain extension of beta-aminated intermediates is attempted through nitrile homologation chemistry but is diverted by cyclization and fails to robustly give the linear C5 aminoaldehyde.", "reasoning": "This reaction is intentionally marked as the literature-defined bottleneck: Patel et al. noted that homologation beyond beta-aminopropionaldehyde toward the acyclic Strecker precursor of lysine appears unlikely because cyclization dominates. Included to show why the Strecker route is a dead-end for lysine (Patel et al., 2015; Miller & Van Trump, 1981; Thoma & Powner, 2023)."}, {"id": "rxn_010", "name": "Tentative lysine formation in borosilicate spark-discharge chemistry", "inputs": ["mol_004", "mol_005", "mol_006"], "outputs": ["mol_012"], "environment": "Surface", "agents": ["borate minerals (colemanite/ulexite)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "borosilicate/silicate surface effect represented by borate-rich silicate mineral environment", "aqueous": "true", "other": "spark discharge using CH4/NH3/N2 mixtures; lysine tentatively assigned only in borosilicate reactor, not Teflon"}, "mechanism": "Complex discharge chemistry in the presence of silicate/borosilicate surfaces produces a broad organic mixture in which lysine was tentatively identified after derivatization and GC-MS analysis.", "reasoning": "This is the only literature-supported direct branch to lysine and remains tentative. Criado-Reyes et al. reported lysine among 56 products with much higher amino-acid yields in borosilicate than in Teflon reactors, implying a mineral surface effect, but the assignment has not yet been independently confirmed. The network therefore treats this as the sole direct but low-confidence lysine-forming step (Criado-Reyes et al., 2021; Thoma & Powner, 2023)."}, {"id": "rxn_011", "name": "UV ice photochemistry yielding diaminohexanoic acid isomers", "inputs": ["mol_007", "mol_005"], "outputs": ["mol_013"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "borate minerals (colemanite/ulexite)"], "conditions": {"temperature": "12 K irradiation then warming to 300K residue analysis", "pressure": "low to 1 atm upon deposition", "catalyst": "mineral collection surfaces after photolysis", "aqueous": "false", "other": "UV irradiation of H2O:CH3OH:NH3:CO:CO2 ice analogues; residue later analyzed"}, "mechanism": "UV irradiation of astrophysical/prebiotic ice mixtures generates complex amino acid inventories including C6 diaminohexanoic acid isomers.", "reasoning": "Mu\u00f1oz Caro et al. detected two diaminohexanoic acids with the same formula as lysine but not lysine itself. This branch is therefore a near-miss, demonstrating that abiotic chemistry can cross the C6 diamino threshold without achieving lysine regiochemistry (Mu\u00f1oz Caro et al., 2002; Nuevo et al., 2008)."}, {"id": "rxn_012", "name": "Surface synthesis of diaminopropionic acid surrogate", "inputs": ["mol_006", "mol_005"], "outputs": ["mol_014"], "environment": "Surface", "agents": ["sulfide minerals (stibnite/molybdenite)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "sulfide and phosphate minerals", "aqueous": "true", "other": "dehydroalanine nitrile/ammonia addition chemistry represented as a cyanide-network surrogate branch"}, "mechanism": "Ammonia addition to activated nitrile precursors yields diaminopropionic acid after hydrolytic workup within prebiotic nitrile chemistry.", "reasoning": "Thoma & Powner showed high-yield prebiotic access to diaminopropionic acid from dehydroalanine nitrile, establishing a realistic cationic amino-acid surrogate branch when lysine itself is unavailable. Included because the literature emphasizes lysine surrogacy rather than direct lysine synthesis (Thoma & Powner, 2023)."}, {"id": "rxn_013", "name": "Abiotic shorter-chain diamino acid inventory branch", "inputs": ["mol_009", "mol_005"], "outputs": ["mol_015"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "montmorillonite (clay)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "TiO2 and montmorillonite", "aqueous": "true", "other": "spark/discharge or hydrolytic product inventory branch"}, "mechanism": "Shorter homologous diamino acids arise more readily than lysine in abiotic nitrile chemistry and survive hydrolysis/analysis.", "reasoning": "Diaminobutyric acid and related shorter diamino acids are reported from abiotic contexts and meteorites, reinforcing the chain-length barrier before C6 lysine. This reaction is included as a literature-supported boundary marker, not a lysine step (Ring et al., 1972; Wolman et al., 1972; Meierhenrich et al., 2004; Thoma & Powner, 2023)."}, {"id": "rxn_014", "name": "Montmorillonite adsorption and concentration of lysine", "inputs": ["mol_012"], "outputs": ["mol_016"], "environment": "Biochemical", "agents": ["montmorillonite (clay)", null], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "montmorillonite", "aqueous": "true", "other": "pH 5-7, NaCl-bearing pools; adsorption reduced by Mg2+ competition"}, "mechanism": "If lysine is present, cationic side-chain protonation drives selective adsorption/intercalation into montmorillonite interlayers, concentrating it for later polymerization.", "reasoning": "Clay does not create lysine, but selectively concentrates it and can generate nano-environments favorable for downstream chemistry. This step connects any rare lysine produced in surface chemistry to biochemical retention and selection (Cuadros et al., 2009; Cuadros et al., 2024; Bezaly et al., 2026; Frenkel-Pinter et al., 2019)."}], "pathways": [{"pathway_id": "P1", "name": "Direct borosilicate spark route to tentative lysine", "description": "Surface discharge chemistry in a borosilicate-influenced setting gives the only published tentative lysine detection.", "reaction_sequence": ["rxn_003", "rxn_010"], "key_intermediates": ["mol_006"]}, {"pathway_id": "P2", "name": "Hydrothermal formate to surface spark lysine branch", "description": "Hydrothermal carbon reduction feeds surface reduced-carbon inventory and then the tentative borosilicate spark-discharge lysine route.", "reaction_sequence": ["rxn_001", "rxn_002", "rxn_003", "rxn_010"], "key_intermediates": ["mol_003", "mol_004", "mol_006"]}, {"pathway_id": "P3", "name": "Aminoacetonitrile-HCN polymer dead-end branch", "description": "Historically claimed HCN polymer hydrolysis route associated with lysine reports, now treated as a dead-end because modern reanalysis does not confirm lysine.", "reaction_sequence": ["rxn_00
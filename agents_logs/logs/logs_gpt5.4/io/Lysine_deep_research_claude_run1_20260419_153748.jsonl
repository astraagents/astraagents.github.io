_name\": \"beta-aminopropionaldehyde\",\n      \"inchi\": \"InChI=1S/C3H7NO/c4-2-1-3-5/h3H,1-2,4H2\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_011\",\n      \"formula\": \"C5H11NO\",\n      \"iupac_name\": \"5-aminopentanal\",\n      \"common_name\": \"5-aminopentanal\",\n      \"inchi\": \"InChI=1S/C5H11NO/c6-4-2-1-3-5-7/h5H,1-4,6H2\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_012\",\n      \"formula\": \"C6H12N2O2\",\n      \"iupac_name\": \"2,6-diaminohexanoic acid isomer mixture\",\n      \"common_name\": \"diaminohexanoic acid isomers\",\n      \"inchi\": null,\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_013\",\n      \"formula\": \"C6H14N2O2\",\n      \"iupac_name\": \"2,6-diaminohexanoic acid\",\n      \"common_name\": \"lysine\",\n      \"inchi\": \"InChI=1S/C6H14N2O2/c7-4-2-1-3-5(8)6(9)10/h5H,1-4,7-8H2,(H,9,10)\",\n      \"role\": \"target\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_014\",\n      \"formula\": \"C3H8N2O2\",\n      \"iupac_name\": \"2,3-diaminopropanoic acid\",\n      \"common_name\": \"diaminopropionic acid\",\n      \"inchi\": \"InChI=1S/C3H8N2O2/c4-1-2(5)3(6)7/h2H,1,4-5H2,(H,6,7)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_015\",\n      \"formula\": \"C4H10N2O2\",\n      \"iupac_name\": \"2,4-diaminobutanoic acid\",\n      \"common_name\": \"diaminobutyric acid\",\n      \"inchi\": \"InChI=1S/C4H10N2O2/c5-2-1-3(6)4(7)8/h3H,1-2,5-6H2,(H,7,8)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"Hydrothermal CO2 reduction to formate\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_004\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe3S4)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"greigite/mackinawite\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline vent-like, anoxic, H2-rich\"\n      },\n      \"mechanism\": \"Mineral-surface reduction of CO2 by H2 on iron-sulfur phases yields formate as reduced C1 inventory.\",\n      \"reasoning\": \"Hydrothermal CO2 reduction to simple organics on FeS-family minerals is consistent with iron-sulfur world chemistry and vent thermodynamics; formate is a much better-supported reduced-carbon product than direct formaldehyde in such settings. This reaction is used as the hydrothermal feedstock bridge into surface chemistry, avoiding the unsupported direct hydrothermal formaldehyde step criticized in prior attempts (Huber & W\u00e4chtersh\u00e4user, 1997; Barge et al., 2019; Kitadai et al., 2018; Amend & Shock, 1998).\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Surface generation of carbonyl inventory including formaldehyde under spark discharge\",\n      \"inputs\": [\"mol_001\", \"mol_003\"],\n      \"outputs\": [\"mol_005\", \"mol_006\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borosilicate glass / silicate surface\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"borosilicate silicate surfaces under discharge; TiO2 as mineral photocatalyst/concentrating surface\",\n        \"aqueous\": \"true\",\n        \"other\": \"CH4/NH3/N2-type spark-discharge inventory represented in lumped form; anoxic\"\n      },\n      \"mechanism\": \"Energetic discharge in reduced gas mixtures creates mixed nitrile and carbonyl inventories including HCN and formaldehyde-like feedstocks, with silicate surfaces enhancing yields.\",\n      \"reasoning\": \"This is a deliberately lumped inventory-forming step, not a mechanistically resolved stoichiometric reaction. It is included because Criado-Reyes et al. reported substantially enhanced amino-acid inventories in borosilicate versus Teflon spark-discharge systems, and Miller-Urey-type experiments historically generate HCN/carbonyl mixtures. The step avoids the unrealistic stand-alone formaldehyde + ammonia -> HCN reaction used previously and instead represents the discharge inventory more faithfully (Miller, 1953; Ring et al., 1972; Johnson et al., 2008; Parker et al., 2011; Criado-Reyes et al., 2021).\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Surface concentration and redox coupling of hydrothermal C1 feedstock into reactive carbonyl pool\",\n      \"inputs\": [\"mol_004\"],\n      \"outputs\": [\"mol_005\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"borate minerals (colemanite/ulexite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO2 and borate-bearing mineral surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"UV-exposed shallow pools; represented as systems-level C1 transfer rather than single-step clean conversion\"\n      },\n      \"mechanism\": \"Reduced C1 species delivered from hydrothermal settings are photo/redox processed and concentrated at mineral surfaces into reactive carbonyl inventory including formaldehyde.\",\n      \"reasoning\": \"This is a speculative but necessary connector between hydrothermal reduced carbon and surface carbonyl chemistry, framed as a systems-level inventory transformation rather than a single established stoichiometric reaction. It addresses the prior criticism that direct hydrothermal formaldehyde production was overstated. The thermodynamic basis for hydrothermal reduced-carbon generation comes from vent studies, while the surface processing component reflects the broader prebiotic role of UV/mineral interfaces; the uncertainty is explicit (Amend & Shock, 1998; Criado-Reyes et al., 2021; Patel et al., 2015, speculative connection).\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"HCN hydration to formamide under UV-active surface conditions\",\n      \"inputs\": [\"mol_006\"],\n      \"outputs\": [\"mol_007\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO2 and clay mineral surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"UV irradiation, shallow evaporitic or tidal-flat setting\"\n      },\n      \"mechanism\": \"HCN in water-rich surface environments is converted into formamide-containing prebiotic nitrile inventory under photochemical/mineral assistance.\",\n      \"reasoning\": \"Formamide is a recognized product/intermediate in HCN-rich prebiotic chemistry and a useful branch point for UV photochemical residue formation. Here it serves as an inventory branch leading toward the literature-reported diaminohexanoic-acid isomer near-miss rather than a direct lysine route (Mu\u00f1oz Caro et al., 2002; Nuevo et al., 2008).\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"Aminoacetonitrile formation from HCN-rich surface inventory\",\n      \"inputs\": [\"mol_006\", \"mol_003\"],\n      \"outputs\": [\"mol_008\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\", \"borosilicate glass / silicate surface\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"silicate and clay surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"HCN-rich evaporitic or discharge-processed pool\"\n      },\n      \"mechanism\": \"Condensation within nitrile-rich inventory gives aminonitrile species, here represented by aminoacetonitrile as an HCN polymerization/feedstock hub.\",\n      \"reasoning\": \"Aminoacetonitrile is a well-recognized aminonitrile in prebiotic chemistry and historically central to HCN polymerization claims. This node is used to represent the literature-supported aminonitrile hub without overstating its conversion to lysine (Moser & Matthews, 1968; Cleaves, 2010; Ruiz-Bermejo et al., 2013).\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"HCN polymerization and hydrolysis branch to diaminopropionic acid surrogate\",\n      \"inputs\": [\"mol_008\", \"mol_003\"],\n      \"outputs\": [\"mol_014\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\", \"sulfide minerals (stibnite/molybdenite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"clay and sulfide-assisted cyanosulfidic milieu\",\n        \"aqueous\": \"true\",\n        \"other\": \"followed conceptually by hydrolysis; surrogate branch\"\n      },\n      \"mechanism\": \"Aminonitrile-rich networks can yield short-chain diamino acid products/surrogates upon oligomerization and hydrolysis.\",\n      \"reasoning\": \"This branch is included because shorter diamino acids are demonstrably more accessible than lysine. It is partly literature-based and partly a network-connecting abstraction: historical HCN polymer hydrolysis does not confirm lysine, while Thoma & Powner strongly support prebiotic access to diaminopropionic-acid-type functionality via nitrile chemistry. This reaction should be interpreted as a surrogate branch, not a lysine-producing step (Cleaves, 2010; Ruiz-Bermejo et al., 2013; Thoma & Powner, 2023).\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Cyanosulfidic / nitrile homologation branch to acrylonitrile\",\n      \"inputs\": [\"mol_006\", \"mol_005\"],\n      \"outputs\": [\"mol_009\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (stibnite/molybdenite)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"sulfide mineral mediated UV-active surface chemistry\",\n        \"aqueous\": \"true\",\n        \"other\": \"HCN/H2S/UV-type cyanosulfidic setting\"\n      },\n      \"mechanism\": \"HCN-derived surface chemistry can furnish small nitrile building blocks, here represented by acrylonitrile as a C3 nitrile precursor.\",\n      \"reasoning\": \"Acrylonitrile is discussed in the literature as a plausible C3 building block accessible from HCN chemistry. This node is used specifically to encode the carbon-chain elongation problem on the way toward lysine, not as a validated productive route (Patel et al., 2015; Thoma & Powner, 2023).\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Ammonia addition to acrylonitrile gives beta-aminopropionaldehyde inventory\",\n      \"inputs\": [\"mol_009\", \"mol_003\"],\n      \"outputs\": [\"mol_010\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (stibnite/molybdenite)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"sulfide/clay mineral surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic; represented as literature-noted bottleneck precursor generation\"\n      },\n      \"mechanism\": \"Ammonia incorporation into C3 nitrile-derived inventory provides beta-aminopropionaldehyde-type species relevant to homologation discussions.\",\n      \"reasoning\": \"The research report specifically identifies beta-aminopropionaldehyde as a key intermediate discussed in relation to lysine failure. This step is retained only to encode that literature bottleneck and is explicitly low-confidence as a clean prebiotic conversion. It should be treated as a problem-defining branch rather than a robust synthesis (Patel et al., 2015; Thoma & Powner, 2023, speculative connector).\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"Problematic homologation to 5-aminopentanal\",\n      \"inputs\": [\"mol_010\", \"mol_005\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"borate/clay surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"homologation attempt; cyclization competes strongly\"\n      },\n      \"mechanism\": \"Formal chain extension toward the required C5 aminoaldehyde precursor is attempted but chemically disfavored because cyclization diverts the system.\",\n      \"reasoning\": \"This reaction is intentionally included as an unresolved dead-end because the literature explicitly states that homologation beyond beta-aminopropionaldehyde toward the acyclic lysine precursor appears unlikely due to cyclization. This is not a validated route and must be read as a mapped failure point (Patel et al., 2015; Miller & Van Trump, 1981; Thoma & Powner, 2023).\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"Theoretical Strecker-type conversion of 5-aminopentanal to lysine\",\n      \"inputs\": [\"mol_011\", \"mol_006\", \"mol_003\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borosilicate glass / silicate surface\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"silicate/clay surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"theoretical Strecker framework; precursor not known prebiotically\"\n      },\n      \"mechanism\": \"If 5-aminopentanal were available, Strecker chemistry could in principle install the alpha-amino acid center to produce lysine.\",\n      \"reasoning\": \"The literature explicitly identifies this as a theoretical dead-end because 5-aminopentanal has no known prebiotic source. This step is therefore included only to represent the mechanistic reason standard Strecker synthesis fails for lysine, not as an experimentally supported route (Miller & Van Trump, 1981; Thoma & Powner, 2023).\"\n    },\n    {\n      \"id\": \"rxn_011\",\n      \"name\": \"UV ice photochemistry to diaminohexanoic acid isomers\",\n      \"inputs\": [\"mol_007\", \"mol_003\", \"mol_005\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"borate minerals (colemanite/ulexite)\"],\n      \"conditions\": {\n        \"temperature\": \"12 K ice photolysis followed by warming to 300K for residue analysis\",\n        \"pressure\": \"low during irradiation / 1 atm upon recovery\",\n        \"catalyst\": \"mineral surfaces used here as concentrators for terrestrial analog mapping\",\n        \"aqueous\": \"false\",\n        \"other\": \"UV irradiation of H2O:CH3OH:NH3:CO:CO2-type ice analogs; near-miss branch\"\n      },\n      \"mechanism\": \"Photoprocessed nitrogen/carbonyl-rich ice residues yield C6 diamino acid isomeric products sharing lysine's molecular formula but not its confirmed regiochemistry.\",\n      \"reasoning\": \"Mu\u00f1oz Caro et al. reported two diaminohexanoic acids in UV-irradiated ice residues, while Nuevo et al. found lysine remained unconfirmed because a peak likely corresponded to ethanolamine. This branch is therefore a literature-supported near-miss, not a lysine synthesis (Mu\u00f1oz Caro et al., 2002; Nuevo et al., 2008).\"\n    },\n    {\n      \"id\": \"rxn_012\",\n      \"name\": \"Borosilicate-enhanced spark-discharge tentative lysine formation\",\n      \"inputs\": [\"mol_005\", \"mol_006\", \"mol_003\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borosilicate glass / silicate surface\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"spark discharge, bulk aqueous collection near ambient; buffered analysis at pH 8.7\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"borosilicate glass\",\n        \"aqueous\": \"true\",\n        \"other\": \"CH4/NH3/N2 discharge system; lysine tentatively assigned by GC-MS/TMS derivatization\"\n      },\n      \"mechanism\": \"Energetic discharge over silicate-reactor surfaces produces complex amino-acid inventories; lysine appears as a tentative minor product in borosilicate systems.\",\n      \"reasoning\": \"This is the strongest direct lysine-access branch because it reflects the only published tentative lysine detection in a prebiotic experiment. The step is intentionally represented as an inventory-level formation event rather than a resolved mechanism, because the underlying chemistry remains unknown and requires independent confirmation (Criado-Reyes et al., 2021; Thoma & Powner, 2023).\"\n    },\n    {\n      \"id\": \"rxn_013\",\n      \"name\": \"Surface production of shorter diamino acid homologue (diaminobutyric acid)\",\n      \"inputs\": [\"mol_009\", \"mol_003\"],\n      \"outputs\": [\"mol_015\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\", \"borosilicate glass / silicate surface\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"silicate/clay surfaces in discharge or hydrolysis-derived inventory\",\n        \"aqueous\": \"true\",\n        \"other\": \"comparative homologue branch\"\n      },\n      \"mechanism\": \"Shorter-chain diamino acid formation occurs more readily than C6 lysine in abiotic nitrile/ammonia networks.\",\n      \"reasoning\": \"Shorter diamino acids such as diaminobutyric acid are documented in abiotic contexts and help define the chain-length cutoff below lysine. This branch is included to reflect the literature pattern that diamino chemistry is prebiotically accessible only up to shorter homologues (Ring et al., 1972; Wolman et al., 1972; Meierhenrich et al., 2004; Thoma & Powner, 2023).\"\n    },\n    {\n      \"id\": \"rxn_014\",\n      \"name\": \"Biochemical/prebiotic concentration and selection of trace lysine on montmorillonite\",\n      \"inputs\": [\"mol_013\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"montmorillonite-rich mineral interface\", null],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite adsorption/intercalation\",\n        \"aqueous\": \"true\",\n        \"other\": \"pH 5-7, saline pool, concentration rather than synthesis\"\n      },\n      \"mechanism\": \"If lysine is formed even at trace level, cation-exchange adsorption and interlayer partitioning on montmorillonite selectively retain and concentrate it for downstream chemistry.\",\n      \"reasoning\": \"Montmorillonite does not create lysine, but recent adsorption studies show strong selective concentration of lysine due to its cationic sidechain. This biochemical-stage reaction captures the plausible retention/selection of rare lysine once formed, which is one of the few literature-supported advantages available to lysine in prebiotic systems (Cuadros et al., 2009; Cuadros et al., 2024; Bezaly et al., 2026; Frenkel-Pinter et al., 2019).\"\n    }\n  ],\n  \"pathways\": [\n    {\n      \"pathway_id\": \"P1\",\n      \"name\": \"Direct borosilicate spark-discharge lysine branch\",\n      \"description\": \"The only literature-supported tentative direct lysine formation route: surface discharge chemistry in borosilicate systems produces a complex amino-acid inventory that includes tentatively assigned lysine.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_012\"],\n      \"key_intermediates\": [\"mol_005\", \"mol_006\"]\n    },\n    {\n      \"pathway_id\": \"P2\",\n      \"name\": \"Hydrothermal-to-surface C1 feed into tentative borosilicate lysine formation\",\n      \"description\": \"Hydrothermal reduced carbon is delivered as formate, transformed into surface carbonyl inventory, then participates in the only tentative lysine-producing borosilicate discharge branch.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_003\", \"rxn_012\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_005\"]\n    },\n    {\n      \"pathway_id\": \"P3\",\n      \"name\": \"Theoretical Strecker dead-end via 5-aminopentanal\",\n      \"description\": \"A literature-defined impossibility branch: if 5-aminopentanal existed, Strecker chemistry could yield lysine, but that precursor has no known prebiotic source.\",\n      \"reaction_sequence\": [\"rxn_007\", \"rxn_008\", \"rxn_009\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_009\", \"mol_010\", \"mol_011\"]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"Hydrothermal-fed homologation dead-end\",\n      \"description\": \"Hydrothermal reduced carbon feeds surface carbonyl chemistry and then enters the same literature-recognized homologation bottleneck that fails before a viable acyclic lysine precursor is reached.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_003\", \"rxn_007\", \"rxn_008\", \"rxn_009\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_005\", \"mol_010\", \"mol_011\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"UV ice photochemistry near-miss to diaminohexanoic isomers\",\n      \"description\": \"UV photolysis generates C6 diamino acid isomers with lysine's formula but not confirmed lysine; this is a near-miss pathway demonstrating that the C6 boundary can be crossed without the correct regiochemistry.\",\n      \"reaction_sequence\": [\"rxn_004\", \"rxn_011\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_012\"]\n    },\n    {\n      \"pathway_id\": \"P6\",\n      \"name\": \"Alternative UV near-miss via discharge-generated HCN and carbonyl inventory\",\n      \"description\": \"Spark/discharge-generated HCN and carbonyl feedstocks are routed into formamide-rich UV residue chemistry, yielding diaminohexanoic-acid isomers rather than lysine.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_004\", \"rxn_011\"],\n      \"key_intermediates\": [\"mol_006\", \"mol_007\", \"mol_012\"]\n    },\n    {\n      \"pathway_id\": \"P7\",\n      \"name\": \"HCN polymerization branch historically associated with unconfirmed lysine claims\",\n      \"description\": \"Aminoacetonitrile-centered HCN polymer chemistry is included because it historically motivated lysine claims, but modern reanalysis does not confirm lysine and instead supports shorter products/surrogates.\",\n      \"reaction_sequence\": [\"rxn_005\", \"rxn_006\"],\n      \"key_intermediates\": [\"mol_008\", \"mol_014\"]\n    },\n    {\n      \"pathway_id\": \"P8\",\n      \"name\": \"Shorter diamino acid homologue branch marking the chain-length cutoff\",\n      \"description\": \"Surface nitrile/ammonia chemistry yields shorter diamino acids such as diaminobutyric acid, illustrating that prebiotic diamino chemistry stalls below lysine.\",\n      \"reaction_sequence\": [\"rxn_007\", \"rxn_013\"],\n      \"key_intermediates\": [\"mol_009\", \"mol_015\"]\n    },\n    {\n      \"pathway_id\": \"P9\",\n      \"name\": \"Hydrothermal-to-surface aminonitrile surrogate branch\",\n      \"description\": \"Hydrothermal reduced carbon supports surface HCN inventory and aminonitrile formation, culminating in diaminopropionic acid as a functional lysine surrogate rather than lysine itself.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_003\", \"rxn_002\", \"rxn_005\", \"rxn_006\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_005\", \"mol_006\", \"mol_008\", \"mol_014\"]\n    },\n    {\n      \"pathway_id\": \"P10\",\n      \"name\": \"Selection of rare lysine after tentative formation\",\n      \"description\": \"Any trace lysine formed by the tentative borosilicate branch can be selectively concentrated on montmorillonite during biochemical/prebiotic stage processing.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_012\", \"rxn_014\"],\n      \"key_intermediates\": [\"mol_005\", \"mol_006\", \"mol_013\"]\n    }\n  ],\n  \"hub_molecules\": [\"mol_003\", \"mol_005\", \"mol_006\", \"mol_008\", \"mol_012\"],\n  \"convergence_points\": [\n    {\n      \"molecule_id\": \"mol_005\",\n      \"incoming_reactions\": [\"rxn_002\", \"rxn_003\"],\n      \"outgoing_reactions\": [\"rxn_007\", \"rxn_011\", \"rxn_012\"]\n    },\n    {\n      \"molecule_id\": \"mol_006\",\n      \"incoming_reactions\": [\"rxn_002\"],\n      \"outgoing_reactions\": [\"rxn_004\", \"rxn_005\", \"rxn_007\", \"rxn_010\", \"rxn_012\"]\n    },\n    {\n      \"molecule_id\": \"mol_008\",\n      \"incoming_reactions\": [\"rxn_005\"],\n      \"outgoing_reactions\": [\"rxn_006\"]\n    },\n    {\n      \"molecule_id\": \"mol_012\",\n      \"incoming_reactions\": [\"rxn_011\"],\n      \"outgoing_reactions\": []\n    },\n    {\n      \"molecule_id\": \"mol_013\",\n      \"incoming_reactions\": [\"rxn_010\", \"rxn_012\"],\n      \"outgoing_reactions\": [\"rxn_014\"]\n    }\n  ]\n}", "parsed_response": {"target_molecule": "Lysine", "overall_strategy": "This network is a literature-constrained map of the prebiotic lysine problem rather than a high-confidence productive synthesis. It centers the single tentative lysine-producing branch from borosilicate spark discharge, embeds the known near-miss and failure branches documented in the literature, and connects hydrothermal reduced-carbon generation to surface inventory formation and biochemical concentration/selection. Ten pathways are included, but most are explicitly low-confidence, dead-end, or surrogate routes because the literature shows 
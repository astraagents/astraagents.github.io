", "formula": "CH2N2", "iupac_name": "cyanamide", "common_name": "cyanamide", "inchi": "InChI=1S/CH2N2/c2-1-3/h(H2,2,3)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_018", "formula": "CO", "iupac_name": "carbon monoxide", "common_name": "carbon monoxide", "inchi": "InChI=1S/CO/c1-2", "role": "starting", "environment_formed": null}, {"id": "mol_019", "formula": "C3H3N", "iupac_name": "prop-2-ynenitrile", "common_name": "cyanoacetylene", "inchi": "InChI=1S/C3HN/c1-2-3-4/h1H", "role": "starting", "environment_formed": null}, {"id": "mol_020", "formula": "H2O", "iupac_name": "oxidane", "common_name": "water", "inchi": "InChI=1S/H2O/h1H2", "role": "starting", "environment_formed": null}, {"id": "mol_021", "formula": "C8H18N2O4", "iupac_name": "2-[(2-amino-3-hydroxybutanoyl)amino]-3-hydroxybutanoic acid", "common_name": "threonylthreonine", "inchi": null, "role": "intermediate", "environment_formed": "Biochemical"}], "reactions": [{"id": "rxn_001", "name": "Hydrothermal CO2 reduction to formate", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_003"], "environment": "Hydrothermal", "agents": ["greigite (Fe3S4)", "mackinawite (FeS)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "greigite (Fe3S4), mackinawite (FeS)", "aqueous": "true", "other": "alkaline vent conditions, anoxic, H2-rich, pH 9-11"}, "mechanism": "Mineral-surface reduction of CO2 by H2 on iron-sulfur phases gives surface-bound formyl species that desorb as formate.", "reasoning": "Formate production on FeS-family hydrothermal catalysts is a central vent carbon-fixation step consistent with iron-sulfur world chemistry and vent-driven CO2 reduction feeding later carbonyl chemistry (Huber & Wachtershauser, 1997; Russell & Martin, 2004)."}, {"id": "rxn_002", "name": "Hydrothermal reduction of formate to formaldehyde", "inputs": ["mol_003", "mol_002"], "outputs": ["mol_004"], "environment": "Hydrothermal", "agents": ["magnetite (Fe3O4)", "elemental iron (Fe0)"], "conditions": {"temperature": "400-500K", "pressure": "high", "catalyst": "magnetite (Fe3O4), elemental iron (Fe0)", "aqueous": "true", "other": "Fischer-Tropsch-type/reductive vent chemistry under anoxic conditions"}, "mechanism": "Further reduction of C1 oxygenated carbon on reduced iron oxide/iron surfaces yields formaldehyde-equivalent carbonyl species.", "reasoning": "Although direct formaldehyde accumulation in vents is less emphasized than formate, reduced iron and magnetite support CO2/CO hydrogenation chemistry giving aldehydic intermediates that can seed surface sugar chemistry; included as a necessary connector from hydrothermal fixation to surface homologation and marked as literature-consistent but partially inferential (McCollom & Seewald, 2007; Russell & Martin, 2004)."}, {"id": "rxn_003", "name": "Surface UV cyanosulfidic homologation of HCN to glycolaldehyde", "inputs": ["mol_005", "mol_010", "mol_020"], "outputs": ["mol_006"], "environment": "Surface", "agents": ["sulfide minerals (molybdenite/stibnite)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "Cu(I)/Cu(II) photoredox with sulfide minerals and TiO2-supported UV photochemistry", "aqueous": "true", "other": "UV irradiation, anoxic surface waters, phosphate-compatible cyanosulfidic setting"}, "mechanism": "UV-driven reductive homologation of HCN in the presence of sulfide reductant and copper photoredox cycling generates C2 carbohydrates, especially glycolaldehyde.", "reasoning": "The Sutherland cyanosulfidic network identifies UV/H2S-driven reductive homologation of HCN as the source of glycolaldehyde in unified prebiotic protometabolism, with copper photoredox cycling accelerating the process (Patel et al., 2015; Xu et al., 2018)."}, {"id": "rxn_004", "name": "Surface cyanosulfidic homologation of glycolaldehyde to glyceraldehyde", "inputs": ["mol_006", "mol_005", "mol_010"], "outputs": ["mol_007"], "environment": "Surface", "agents": ["sulfide minerals (molybdenite/stibnite)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "Cu(I)/Cu(II) photoredox with UV-active mineral surfaces", "aqueous": "true", "other": "UV irradiation, cyanosulfidic flow chemistry"}, "mechanism": "Successive reductive homologation extends the carbon backbone from C2 to C3, furnishing glyceraldehyde as part of the sugar/nucleotide precursor network.", "reasoning": "Glyceraldehyde is a documented product of the HCN/H2S/UV cyanosulfidic network and a key branching intermediate toward both sugar and amino acid precursors (Patel et al., 2015; Ritson & Sutherland, 2012)."}, {"id": "rxn_005", "name": "Surface isomerization of glyceraldehyde to dihydroxyacetone", "inputs": ["mol_007"], "outputs": ["mol_008"], "environment": "Surface", "agents": ["borate minerals (colemanite/ulexite)", "montmorillonite"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "borate stabilization and clay concentration", "aqueous": "true", "other": "mild aqueous surface setting; reported conversion to dihydroxyacetone ~59% in cyanosulfidic systems"}, "mechanism": "Triose carbonyl isomerization redistributes the carbonyl position from aldose to ketose while mineral surfaces stabilize the sugar pool.", "reasoning": "The research report highlights glyceraldehyde-to-dihydroxyacetone interconversion at about 59% yield within the broader cyanosulfidic regime; borate stabilization of labile sugars is widely invoked in prebiotic sugar chemistry (Patel et al., 2015; Ricardo et al., 2004)."}, {"id": "rxn_006", "name": "Surface formation of threonine aminonitrile from triose-derived cyanosulfidic branch chemistry", "inputs": ["mol_007", "mol_008", "mol_005", "mol_009"], "outputs": ["mol_014"], "environment": "Surface", "agents": ["sulfide minerals (molybdenite/stibnite)", "montmorillonite"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "Cu(I)/Cu(II) photoredox-compatible cyanosulfidic system with clay concentration", "aqueous": "true", "other": "UV-enabled surface flow chemistry; aminonitrile formed as branched byproduct of sugar-forming network"}, "mechanism": "Triose-derived carbonyl intermediates react with cyanide and ammonia to generate the alpha-aminonitrile 2-amino-3-hydroxybutanenitrile as a branch product of the sugar assembly network.", "reasoning": "The deep research specifically states that 2-amino-3-hydroxybutanenitrile is an inevitable byproduct of the same cyanosulfidic chemistry producing glyceraldehyde and dihydroxyacetone, linking threonine synthesis to ribonucleotide precursor formation (Patel et al., 2015; Xu et al., 2018)."}, {"id": "rxn_007", "name": "Surface hydrolysis of threonine aminonitrile to threonine", "inputs": ["mol_014", "mol_020"], "outputs": ["mol_015"], "environment": "Surface", "agents": ["montmorillonite", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "clay-assisted concentration and phosphate-buffered aqueous hydrolysis", "aqueous": "true", "other": "wet-dry or standing pool conditions, anoxic"}, "mechanism": "Nitrile hydration and subsequent hydrolysis convert the Strecker-type aminonitrile into the corresponding amino acid threonine.", "reasoning": "Hydrolysis of alpha-aminonitriles to amino acids is the established terminal step of Strecker-type prebiotic amino acid formation; here it is applied directly to the literature-specified threonine aminonitrile precursor under plausible concentrated surface conditions (Miller, 1957; Patel et al., 2015)."}, {"id": "rxn_008", "name": "Surface aldol condensation of formaldehyde and glycolaldehyde to tetrose sugars", "inputs": ["mol_004", "mol_006", "mol_009"], "outputs": ["mol_011"], "environment": "Surface", "agents": ["borate minerals (colemanite/ulexite)", "montmorillonite"], "conditions": {"temperature": "300-320K", "pressure": "1 atm", "catalyst": "ammonia catalysis with borate stabilization and clay concentration", "aqueous": "true", "other": "mild aqueous conditions near pH 5.2 in prebiotic sugar pathway style chemistry"}, "mechanism": "Ammonia-catalyzed aldol coupling between C1 and C2 aldehydes forms a tetrose pool including erythrose and threose, with borate helping preserve polyhydroxylated products.", "reasoning": "The prebiotic sugar pathway described in the report starts with aldol condensation of formaldehyde and glycolaldehyde to tetroses under mild conditions, catalyzed by ammonia or amino acids rather than strongly alkaline solutions (Weber, 2001; Ricardo et al., 2004)."}, {"id": "rxn_009", "name": "Surface beta-dehydration of tetrose sugars to alpha-ketoaldehyde", "inputs": ["mol_011"], "outputs": ["mol_012"], "environment": "Surface", "agents": ["montmorillonite", "borate minerals (colemanite/ulexite)"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "clay-assisted dehydration", "aqueous": "true", "other": "mild aqueous one-pot prebiotic sugar pathway"}, "mechanism": "The tetrose undergoes beta-dehydration to an alpha-ketoaldehyde, activating the carbon skeleton for sulfur/nitrogen incorporation.", "reasoning": "The report explicitly identifies tetrose beta-dehydration to an alpha-ketoaldehyde as a key intermediate-generating step in the sugar-to-threonine-thioester pathway (Weber, 2001)."}, {"id": "rxn_010", "name": "Surface conversion of alpha-ketoaldehyde to activated threonine thioester", "inputs": ["mol_012", "mol_009", "mol_010"], "outputs": ["mol_013"], "environment": "Surface", "agents": ["sulfide minerals (molybdenite/stibnite)", "montmorillonite"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "thiol/sulfide-promoted imine-hemithioacetal chemistry on concentrated mineral surfaces", "aqueous": "true", "other": "mild one-pot aqueous system with ammonia and hydrogen sulfide"}, "mechanism": "Ammonia and hydrogen sulfide add to the alpha-ketoaldehyde to form an imine-hemithioacetal that undergoes intramolecular redox rearrangement to the activated threonine thioester.", "reasoning": "This reaction follows the prebiotic sugar pathway outlined in the report: ketoaldehyde plus NH3 and H2S forms an adduct that rearranges to an activated threonine thioester, solving the activation problem for peptide-ready amino acids (Weber, 2001)."}, {"id": "rxn_011", "name": "Biochemical/prebiotic hydrolysis of activated threonine thioester to free threonine", "inputs": ["mol_013", "mol_020"], "outputs": ["mol_015"], "environment": "Biochemical", "agents": [null, null], "conditions": {"temperature": "273-330K", "pressure": "1 atm", "catalyst": null, "aqueous": "true", "other": "cool pools, sediment pores, or ice-brine protected settings to limit threonine degradation"}, "mechanism": "Thioester hydrolysis releases free threonine from its activated sulfur-containing precursor.", "reasoning": "The report states that the activated threonine thioester can hydrolyze directly to free threonine or participate in peptidization; cooler protected conditions are favored because threonine is thermally labile above roughly 393K (Weber, 2001; Qian et al., 1993 as summarized in the report)."}, {"id": "rxn_012", "name": "Photochemical stereoselective synthesis of threonine from cyanoacetylene and CO on Mg-porphin", "inputs": ["mol_019", "mol_018", "mol_020", "mol_002"], "outputs": ["mol_015"], "environment": "Biochemical", "agents": [null, null], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "magnesium porphin photochemical catalyst", "aqueous": "true", "other": "high-energy radiation, no ozone, stereocontrolling bicyclic intermediate formation"}, "mechanism": "Photoexcitation of Mg-porphin induces charge-transfer activation of bound cyanoacetylene and CO, followed by aziridine-2-one/bicyclic intermediate formation and face-selective water addition to yield threonine.", "reasoning": "The report cites Aylward's computational proposal that Mg-porphin photocatalysis could generate specifically configured L-threonine from cyanoacetylene, CO, water, and hydrogen; included as a literature-based but theoretical route complementing the experimentally grounded cyanosulfidic and sugar pathways (Aylward, 1999)."}, {"id": "rxn_013", "name": "Surface photohydrolysis of HCN to formamide", "inputs": ["mol_005", "mol_020"], "outputs": ["mol_016"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "montmorillonite"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "UV photocatalysis on TiO2 with clay adsorption", "aqueous": "true", "other": "strong UV irradiation in shallow anoxic pools"}, "mechanism": "UV-assisted hydration/oxidation-state redistribution of HCN affords formamide as a persistent nitrogenous intermediate in surface photochemistry.", "reasoning": "Formamide is a well-established HCN-derived prebiotic intermediate under UV-active surface conditions and provides a chemically connected branch within cyanide-rich networks, though it is not the main threonine route; included as a literature-consistent connector around HCN chemistry (Saladino et al., 2012; Patel et al., 2015)."}, {"id": "rxn_014", "name": "Surface conversion of formamide to cyanamide", "inputs": ["mol_016"], "outputs": ["mol_017"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "drying and mineral-assisted condensation under UV-exposed surface conditions", "aqueous": "false", "other": "evaporitic or geothermal wet-dry cycling"}, "mechanism": "Dehydrative rearrangement/condensation of formamide under mineral-rich drying conditions gives cyanamide, a condensing and nitrile-network reagent.", "reasoning": "The report specifically notes cyanamide as a condensing agent mutually compatible with amino acid and ribonucleotide chemistry in cyanosulfidic systems; this connector is included to represent that compatibility and flow-chemistry branching (Patel et al., 2015)."}, {"id": "rxn_015", "name": "Surface cyanamide-assisted enhancement of threonine aminonitrile formation from tetrose pool", "inputs": ["mol_011", "mol_017", "mol_009", "mol_005"], "outputs": ["mol_014"], "environment": "Surface", "agents": ["montmorillonite", "sulfide minerals (molybdenite/stibnite)"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "clay concentration with cyanide-rich sulfurous surface chemistry", "aqueous": "true", "other": "flow-chemistry mixing of tetrose and cyanosulfidic tributaries"}, "mechanism": "Activated nitrogen/carbonyl chemistry in a cyanamide- and cyanide-containing tetrose pool increases access to the alpha-aminonitrile branch leading to threonine precursor formation.", "reasoning": "This reaction is a necessary network-connecting extrapolation grounded in the report's statement that cyanamide is mutually compatible with amino acid chemistry and that the threonine aminonitrile emerges from sugar-forming chemistry; it is therefore marked as speculative but literature-guided rather than directly demonstrated as an isolated step (Patel et al., 2015; Weber, 2001)."}, {"id": "rxn_016", "name": "Biochemical/prebiotic peptide bond formation from threonine to threonylthreonine", "inputs": ["mol_015"], "outputs": ["mol_021"], "environment": "Biochemical", "agents": [null, null], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": null, "aqueous": "false", "other": "wet-dry cycling on mineral interfaces or in evaporative pools"}, "mechanism": "Dehydrative condensation of two threonine molecules forms a dipeptide linkage, integrating threonine into proto-biochemical assembly.", "reasoning": "This step connects the target product to downstream prebiotic function, consistent with the report's emphasis that activated thioesters and wet-dry environments support peptidization and t
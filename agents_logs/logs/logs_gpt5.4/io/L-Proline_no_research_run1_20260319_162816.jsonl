om independently plausible pyruvate and succinate hubs, satisfying network redundancy while keeping carbon accounting coherent."}], "pathways": [{"pathway_id": "P1", "name": "Hydrothermal pyruvate to proline core route", "description": "CO2 is reduced hydrothermally to formate, acetate, and pyruvate, then carboxylated through oxaloacetate and aspartate into the glutamate-family route to proline.", "reaction_sequence": ["rxn_001", "rxn_002", "rxn_003", "rxn_004", "rxn_007", "rxn_009", "rxn_008", "rxn_010", "rxn_011", "rxn_012"], "key_intermediates": ["mol_004", "mol_005", "mol_006", "mol_008", "mol_009", "mol_010", "mol_012", "mol_014"]}, {"pathway_id": "P2", "name": "Succinate-oxaloacetate convergence route", "description": "Acetate is extended hydrothermally to succinate, oxidized at the surface to oxaloacetate, then passed through aspartate and the glutamate-family branch to proline.", "reaction_sequence": ["rxn_001", "rxn_002", "rxn_005", "rxn_006", "rxn_007", "rxn_009", "rxn_008", "rxn_010", "rxn_011", "rxn_012"], "key_intermediates": ["mol_005", "mol_007", "mol_008", "mol_009", "mol_010", "mol_012", "mol_014"]}, {"pathway_id": "P3", "name": "Pyruvate-to-alpha-ketoglutarate shortcut route", "description": "Hydrothermal pyruvate and succinate pools combine through a proto-metabolic redistribution step to alpha-ketoglutarate, bypassing oxaloacetate/aspartate.", "reaction_sequence": ["rxn_001", "rxn_002", "rxn_003", "rxn_005", "rxn_015", "rxn_008", "rxn_010", "rxn_011", "rxn_012"], "key_intermediates": ["mol_006", "mol_007", "mol_010", "mol_011", "mol_012", "mol_014"]}, {"pathway_id": "P4", "name": "Direct glutamate semialdehyde route from alpha-ketoglutarate", "description": "Once alpha-ketoglutarate accumulates from the aspartate route, direct reduction to glutamate semialdehyde and spontaneous cyclization yield the immediate proline precursor.", "reaction_sequence": ["rxn_001", "rxn_002", "rxn_003", "rxn_004", "rxn_007", "rxn_009", "rxn_010", "rxn_011", "rxn_012
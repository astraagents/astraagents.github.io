nt would require secondary selection processes (Blackmond, 2010; Bonner, 1991)."}], "pathways": [{"pathway_id": "P1", "name": "Hydrothermal acetate-pyruvate-glutamate semialdehyde route", "description": "A vent-first route from CO2 reduction through acetate and hydrothermal pyruvate, then into oxaloacetate, glutamate, P5C, and proline.", "reaction_sequence": ["rxn_001", "rxn_002", "rxn_003", "rxn_011", "rxn_012", "rxn_013", "rxn_014", "rxn_016", "rxn_018", "rxn_019"], "key_intermediates": ["mol_005", "mol_010", "mol_012", "mol_015", "mol_018"]}, {"pathway_id": "P2", "name": "Hydrothermal alanine-assisted aspartate route", "description": "Hydrothermal pyruvate is aminated to alanine, which later serves as amino donor to oxaloacetate on the surface before entry into the glutamate/P5C manifold.", "reaction_sequence": ["rxn_001", "rxn_002", "rxn_003", "rxn_004", "rxn_011", "rxn_012", "rxn_013", "rxn_014", "rxn_016", "rxn_018", "rxn_019"], "key_intermediates": ["mol_011", "mol_012", "mol_013", "mol_015", "mol_018"]}, {"pathway_id": "P3", "name": "Surface HCN-formamide-formose to pyruvate route", "description": "A surface-dominated route from HCN through formamide, formaldehyde, glycolaldehyde, glyceraldehyde, and pyruvate before joining the common proline family branch.", "reaction_sequence": ["rxn_005", "rxn_006", "rxn_007", "rxn_008", "rxn_009", "rxn_010", "rxn_011", "rxn_012", "rxn_013", "rxn_014", "rxn_016", "rxn_018", "rxn_019"], "key_intermediates": ["mol_004", "mol_020", "mol_008", "mol_010", "mol_015"]}, {"pathway_id": "P4", "name": "Surface glycolaldehyde-centered route", "description": "A shorter surface route using glycolaldehyde as the main carbon hub into glyceraldehyde, pyruvate, and the glutamate branch.", "reaction_sequence": ["rxn_007", "rxn_008", "rxn_009", "rxn_010", "rxn_011", "rxn_012", "rxn_013", "rxn_014", "rxn_016", "rxn_018", "rxn_019"], "key_intermediates": ["mol_007", "mol_008", "mol_009", "mol_010", "mol_018"]}, {"pathway_id": "P5", "name": "M
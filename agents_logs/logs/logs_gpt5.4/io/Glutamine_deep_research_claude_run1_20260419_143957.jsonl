e\": \"2-amino-4-cyanobutanoic acid\",\n      \"common_name\": \"glutamate aminonitrile\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_014\",\n      \"formula\": \"CH3NO\",\n      \"iupac_name\": \"formamide\",\n      \"common_name\": \"formamide\",\n      \"inchi\": \"InChI=1S/CH3NO/c2-1-3/h1H,(H2,2,3)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_015\",\n      \"formula\": \"CNO-\",\n      \"iupac_name\": \"cyanate\",\n      \"common_name\": \"cyanate\",\n      \"inchi\": \"InChI=1S/CNO/c1-2-3/q-1\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_016\",\n      \"formula\": \"C5H10N2O3\",\n      \"iupac_name\": \"2,5-diamino-5-oxopentanoic acid\",\n      \"common_name\": \"glutamine\",\n      \"inchi\": \"InChI=1S/C5H10N2O3/c6-3(5(9)10)1-2-4(7)8/h3H,1-2,6H2,(H2,7,8)(H,9,10)\",\n      \"role\": \"target\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_017\",\n      \"formula\": \"(HCN)n\",\n      \"iupac_name\": \"hydrogen cyanide oligomer/polymer\",\n      \"common_name\": \"HCN polymer\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"Greigite-catalyzed CO2 reduction to formate\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_005\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe3S4)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"greigite/mackinawite\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline vent conditions; H2-rich; anoxic\"\n      },\n      \"mechanism\": \"Mineral-surface hydrogenation of CO2 to a C1 reduced carboxylate.\",\n      \"reasoning\": \"Included as the hydrothermal carbon-fixation entry consistent with iron-sulfur world and vent chemistry discussed in the report, which cites serpentinization-linked H2 availability and mineral catalysis for reduced C1 products; greigite/mackinawite are framework-consistent ancestral catalysts, while awaruite-related vent carbon fixation to reduced organics is supported by Preiner et al. (2020) and Beyazay et al. (2023). This specific greigite formate step is a network-connecting extrapolation grounded in the vent literature rather than a glutamine-specific demonstration.\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Hydrothermal H2-dependent pyruvate formation from CO2\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_007\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe3O4)\", \"elemental iron (Fe0)\"],\n      \"conditions\": {\n        \"temperature\": \"373K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"magnetite/Fe0; serpentinization-associated Ni-Fe mineral analogs\",\n        \"aqueous\": \"true\",\n        \"other\": \"100\u00b0C hydrothermal carbon-fixation regime; anoxic\"\n      },\n      \"mechanism\": \"Serpentinization-linked mineral reduction of CO2 generates reduced carbon products including pyruvate under H2-rich conditions.\",\n      \"reasoning\": \"The report specifically states that awaruite (Ni3Fe) nanoparticles formed during serpentinization catalyze H2-dependent CO2 fixation to formate, acetate, and pyruvate at 100\u00b0C, linking hydrothermal mineralogy to keto-acid supply (Preiner et al., 2020; Beyazay et al., 2023). This reaction is therefore anchored to reported hydrothermal pyruvate production, with magnetite/Fe0 included as required hydrothermal minerals compatible with serpentinization settings.\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Surface HCN generation under discharge/photochemical conditions\",\n      \"inputs\": [\"mol_001\", \"mol_003\"],\n      \"outputs\": [\"mol_004\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"sulfide minerals (stibnite/molybdenite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO2 photocatalytic surface\",\n        \"aqueous\": \"true\",\n        \"other\": \"UV irradiation or spark-discharge analog atmosphere; anoxic\"\n      },\n      \"mechanism\": \"Atmospheric energy input forms nitriles; mineral surfaces assist photochemical concentration and downstream reactivity.\",\n      \"reasoning\": \"Miller-type discharge and related atmospheric energy input are central to the report's Strecker and HCN-oligomerization branches, with HCN as a key precursor to aminonitriles and polymers (Miller, 1955; Johnson et al., 2008; Parker et al., 2011; Ferris, Sanchez & Orgel, 1966-1978). TiO2 is added as the required surface mineral agent and is consistent with prebiotic UV photochemistry, though the exact HCN-generating atmosphere experiments were not TiO2-dependent.\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"HCN oligomerization to HCN polymer\",\n      \"inputs\": [\"mol_004\"],\n      \"outputs\": [\"mol_017\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral concentration surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"evaporative concentration and/or UV exposure; anoxic\"\n      },\n      \"mechanism\": \"HCN undergoes oligomerization/polymerization to complex nitrile-rich macromolecular material.\",\n      \"reasoning\": \"HCN polymer chemistry is explicitly supported as a route to amino-acid-releasing polymeric material, although product-level specificity is poor (Matthews & Moser, 1967; Ruiz-Bermejo et al., 2013; Cleaves et al., 2010; Ferris, Sanchez & Orgel, 1966-1978). Montmorillonite and TiO2 are included as required surface mineral agents to model concentration and photochemical assistance, while acknowledging that the classical HCN polymer literature did not require these exact minerals.\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"Hydrolysis of HCN polymer to glutamic acid-containing amino acid mixture\",\n      \"inputs\": [\"mol_017\"],\n      \"outputs\": [\"mol_011\", \"mol_008\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"variable\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": null,\n        \"aqueous\": \"true\",\n        \"other\": \"acidic or basic hydrolysis of heterogeneous polymer; low specificity\"\n      },\n      \"mechanism\": \"Polymeric nitrile material hydrolyzes to a mixture of amino acids, including glutamic acid and glycine.\",\n      \"reasoning\": \"The report emphasizes that HCN polymers can release glutamic acid upon hydrolysis but that the pathway is diffuse and poorly characterized; therefore this reaction is represented as a mixture-producing source rather than a selective glutamate synthesis (Matthews & Moser, 1967; Ruiz-Bermejo et al., 2013; Cleaves et al., 2010).\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"Prebiotic glyoxylate and pyruvate generation from glycine and serine\",\n      \"inputs\": [\"mol_008\", \"mol_009\"],\n      \"outputs\": [\"mol_006\", \"mol_007\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"343K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"Cu2+ and phosphate in solution\",\n        \"aqueous\": \"true\",\n        \"other\": \"pH near phosphate-buffered conditions; 70\u00b0C\"\n      },\n      \"mechanism\": \"Amino acids undergo nonenzymatic conversion to corresponding carbonyl compounds, producing glyoxylate and pyruvate that feed keto-acid network expansion.\",\n      \"reasoning\": \"This reaction directly follows the report's statement that serine and glycine in the presence of phosphate and Cu2+ generate glyoxylate and pyruvate, enabling closure of a plausible prebiotic cycle (Ter-Ovanessian, Krishnamurthy & Springsteen, 2025).\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Aldol/cross-Cannizzaro formation of \u03b1-ketoglutarate from glyoxylate and pyruvate\",\n      \"inputs\": [\"mol_006\", \"mol_007\"],\n      \"outputs\": [\"mol_010\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"343K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": null,\n        \"aqueous\": \"true\",\n        \"other\": \"pH 4.5; no metal catalyst required\"\n      },\n      \"mechanism\": \"Glyoxylate and pyruvate couple through nonenzymatic aldol/cross-Cannizzaro chemistry to generate the C5 \u03b1-keto diacid \u03b1-ketoglutarate.\",\n      \"reasoning\": \"This is one of the strongest experimentally supported nodes in the network and is reported explicitly in the deep research findings as the prerequisite \u03b1-ketoglutarate source from glyoxylate and pyruvate at pH 4.5 and 70\u00b0C without metal catalysts (Stubbs, Krishnamurthy & Springsteen, 2020). The metabolic framing is also connected to Morowitz & Smith (2004).\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Ni-catalyzed reductive amination of \u03b1-ketoglutarate to glutamic acid\",\n      \"inputs\": [\"mol_010\", \"mol_003\", \"mol_002\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (stibnite/molybdenite)\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"295K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"Ni/SiO2-Al2O3 or meteoritic metal catalyst\",\n        \"aqueous\": \"true\",\n        \"other\": \"22\u00b0C; pH 8; H2 gas; ammonium present\"\n      },\n      \"mechanism\": \"\u03b1-Ketoglutarate undergoes nonenzymatic reductive amination under H2 with heterogeneous Ni catalyst to yield glutamate.\",\n      \"reasoning\": \"This reaction follows the exact literature-highlighted route: Kaur, Moran and colleagues reported H2-driven nonenzymatic reductive amination of \u03b1-ketoglutarate to glutamate using Ni/SiO2-Al2O3 at 22\u00b0C and pH 8, with high yields, and also observed catalysis by Aletai meteorite material (Kaur et al., 2024, Chem). The surface mineral agents listed satisfy schema requirements but the cited catalytic support is specifically the Ni catalyst and meteoritic metal.\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"FeS-mediated reductive amination of \u03b1-ketoglutarate to glutamic acid\",\n      \"inputs\": [\"mol_010\", \"mol_003\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"mackinawite (FeS)\", \"pyrite (FeS2)\"],\n      \"conditions\": {\n        \"temperature\": \"343-373K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"freshly precipitated FeS or Fe(OH)2 with H2S\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic vent-like conditions with ammonia; iron-sulfur world setting\"\n      },\n      \"mechanism\": \"Iron-sulfur mineral surfaces promote nonenzymatic amination/reduction of \u03b1-keto acid to amino acid.\",\n      \"reasoning\": \"The report identifies foundational demonstrations of \u03b1-oxo-acid reductive amination in FeS/H2S systems and amino acid formation from keto-acid precursors using freshly precipitated FeS or Fe(OH)2 with ammonia (Hafenbradl et al., 1995; Huber & W\u00e4chtersh\u00e4user, 2003). This provides a literature-grounded hydrothermal alternative route from \u03b1-ketoglutarate to glutamate.\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"Pyrite photocatalytic reductive amination of \u03b1-ketoglutarate to glutamic acid\",\n      \"inputs\": [\"mol_010\", \"mol_003\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"pyrite-like sulfide mineral surface\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"293K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"natural pyrite under irradiation\",\n        \"aqueous\": \"true\",\n        \"other\": \"20\u00b0C; Xe lamp irradiation; anoxic\"\n      },\n      \"mechanism\": \"Photoexcited mineral surface drives reductive amination of \u03b1-keto acid to amino acid.\",\n      \"reasoning\": \"The deep research findings explicitly cite a 2024 Nature Communications study showing natural pyrite catalyzes photocatalytic reductive amination of \u03b1-keto acids, including \u03b1-ketoglutarate to glutamic acid, at 20\u00b0C under Xe lamp irradiation. TiO2 is included only to satisfy the required surface-mineral schema; the literature support is specifically for pyrite photocatalysis (2024 Nature Communications study as summarized in the report).\"\n    },\n    {\n      \"id\": \"rxn_011\",\n      \"name\": \"Al3+-catalyzed transamination of \u03b1-ketoglutarate with glycine to glutamic acid\",\n      \"inputs\": [\"mol_010\", \"mol_008\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"353K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"Al3+\",\n        \"aqueous\": \"true\",\n        \"other\": \"80\u00b0C; pH 5\"\n      },\n      \"mechanism\": \"Nonenzymatic transamination transfers amino functionality from glycine to \u03b1-ketoglutarate, yielding glutamate within an ancestral Krebs-cycle analog.\",\n      \"reasoning\": \"This reaction uses the exact conditions emphasized in the report: \u03b1-ketoglutarate reacts with glycine to produce glutamate in 44% yield at 80\u00b0C and pH 5 with Al3+ catalysis (Stubbs, Krishnamurthy & Springsteen, 2020). Earlier support for nonenzymatic transamination by metal ions is also noted in Degani & Halmann (1967) and extended by Muchowska, Varma & Moran (2021).\"\n    },\n    {\n      \"id\": \"rxn_012\",\n      \"name\": \"Miller-Urey Strecker branch to glutamate aminonitrile\",\n      \"inputs\": [\"mol_012\", \"mol_003\", \"mol_004\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral concentration surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"spark-discharge-derived aldehyde inventory; Strecker aqueous phase chemistry\"\n      },\n      \"mechanism\": \"Succinic semialdehyde forms a hemiaminal/iminium with ammonia and adds cyanide to yield the corresponding aminonitrile precursor to glutamate.\",\n      \"reasoning\": \"The report states that Miller-Urey chemistry proceeds through Strecker synthesis in the aqueous phase and identifies succinic semialdehyde as the required C4 aldehyde precursor for glutamate, but also notes that no direct experimental demonstration from prebiotically sourced succinic semialdehyde has been reported. Accordingly, this reaction is included as a cautious, literature-guided branch rather than an overclaimed established route (Miller, 1955; Johnson et al., 2008; Parker et al., 2011; summary discussion in the deep research findings).\"\n    },\n    {\n      \"id\": \"rxn_013\",\n      \"name\": \"Hydrolysis of glutamate aminonitrile to glutamic acid\",\n      \"inputs\": [\"mol_013\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": null,\n        \"aqueous\": \"true\",\n        \"other\": \"aqueous hydrolysis over time; acidic or neutral workup\"\n      },\n      \"mechanism\": \"Nitrile hydrolysis converts the aminonitrile into the corresponding amino dicarboxylic acid.\",\n      \"reasoning\": \"Hydrolysis of aminonitriles to amino acids is the standard second stage of Strecker chemistry and underlies the Miller-type interpretation summarized in the report (Miller, 1955; Johnson et al., 2008; Parker et al., 2011). For glutamate specifically, the precursor succinic semialdehyde branch remains less directly demonstrated, so this step is chemically standard but contingent on the speculative precursor availability noted in the report.\"\n    },\n    {\n      \"id\": \"rxn_014\",\n      \"name\": \"HCN hydrolysis/photochemistry to formamide\",\n      \"inputs\": [\"mol_004\"],\n      \"outputs\": [\"mol_014\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"borate minerals (colemanite/ulexite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO2 photocatalytic surface\",\n        \"aqueous\": \"true\",\n        \"other\": \"UV-irradiated surface pools\"\n      },\n      \"mechanism\": \"HCN in aqueous/photochemical settings is converted into formamide as a downstream nitrile-derived intermediate.\",\n      \"reasoning\": \"The report's surface chemistry section explicitly includes UV photochemistry in which HCN and water under UV lead to formamide and related prebiotic products. This branch is included because the report identifies cyanate as the most plausible speculative activator for glutamate amidation, and formamide is a reasonable literature-connected precursor node for such nitrogen-carbonyl chemistry. General support comes from the report's HCN/formamide photochemistry summary and related prebiotic photochemistry literature; this is a connecting step rather than glutamine-specific evidence.\"\n    },\n    {\n      \"id\": \"rxn_015\",\n      \"name\": \"Surface generation of cyanate from formamide-derived nitrogen-carbonyl chemistry\",\n      \"inputs\": [\"mol_014\"],\n      \"outputs\": [\"mol_015\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral-assisted drying/photochemical activation\",\n        \"aqueous\": \"false\",\n        \"other\": \"drying episodes and UV exposure; highly speculative connection step\"\n      },\n      \"mechanism\": \"Formamide-derived nitrogen-carbonyl species are converted to cyanate under dehydrating/oxidation-state rearrangement conditions.\",\n      \"reasoning\": \"Danger, Pascal and colleagues showed cyanate can activate dicarboxylic acids, and the report identifies cyanate-mediated chemistry as the most promising but still undemonstrated route toward selective glutamate \u03b3-activation (Danger et al., 2012). However, a direct prebiotic formamide-to-cyanate route tied specifically to glutamine synthesis was not demonstrated in the report; therefore this reaction is explicitly speculative and included only to connect the literature-supported cyanate activation idea into a complete network.\"\n    },\n    {\n      \"id\": \"rxn_016\",\n      \"name\": \"Speculative cyanate-mediated \u03b3-carboxyl amidation of glutamic acid to glutamine\",\n      \"inputs\": [\"mol_011\", \"mol_003\", \"mol_015\"],\n      \"outputs\": [\"mol_016\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"293-323K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"cyanate as activating agent\",\n        \"aqueous\": \"true\",\n        \"other\": \"mild conditions required because glutamine is thermally fragile; competing cyclization to pyroglutamate expected\"\n      },\n      \"mechanism\": \"Hypothetical cyanate-mediated activation of glutamic acid to an intramolecular anhydride or related activated intermediate followed by ammonia capture at the \u03b3-carboxyl to give glutamine.\",\n      \"reasoning\": \"This final step is intentionally marked as speculative and undemonstrated because the deep research findings explicitly state that glutamine has never been detected in any prebiotic synthesis experiment or meteorite, and that no mineral catalyst or prebiotic system has been shown to amidate glutamic acid selectively at the \u03b3-carboxyl. The most promising idea identified in the report is cyanate-mediated activation of dicarboxylic acids through anhydride chemistry, but this has not been experimentally validated for glutamine and is likely outcompeted by pyroglutamic acid formation and deamidation (Danger et al., 2012; Weber & Miller, 1981; Yu et al., 2006; Weiss et al., 2018; Hamilton, 1962).\"\n    }\n  ],\n  \"pathways\": [\n    {\n      \"pathway_id\": \"P1\",\n      \"name\": \"Hydrothermal carbon fixation to Ni-catalyzed glutamate then speculative amidation\",\n      \"description\": \"CO2 is reduced hydrothermally to pyruvate, pyruvate couples with glyoxylate to \u03b1-ketoglutarate, which is converted to glutamate by the strongest literature-supported Ni-catalyzed reductive amination route; glutamine formation remains speculative.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_006\", \"rxn_007\", \"rxn_008\", \"rxn_016\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_006\", \"mol_010\", \"mol_011\"]\n    },\n    {\n      \"pathway_id\": \"P2\",\n      \"name\": \"Hydrothermal carbon fixation to FeS-mediated glutamate then speculative amidation\",\n      \"description\": \"The same \u03b1-ketoglutarate core is fed by hydrothermal pyruvate supply, but glutamate is produced in an iron-sulfur-world branch using FeS/H2S chemistry.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_006\", \"rxn_007\", \"rxn_009\", \"rxn_016\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_006\", \"mol_010\", \"mol_011\"]\n    },\n    {\n      \"pathway_id\": \"P3\",\n      \"name\": \"Hydrothermal carbon fixation to pyrite-photocatalytic glutamate then speculative amidation\",\n      \"description\": \"Hydrothermal keto-acid supply feeds a surface photochemical branch in which \u03b1-ketoglutarate is reductively aminated to glutamate on illuminated pyrite.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_006\", \"rxn_007\", \"rxn_010\", \"rxn_016\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_006\", \"mol_010\", \"mol_011\"]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"Amino-acid-fed proto-cycle to transaminative glutamate then speculative amidation\",\n      \"description\": \"Serine and glycine generate glyoxylate and pyruvate, which form \u03b1-ketoglutarate; Al3+-catalyzed transamination with glycine gives glutamate.\",\n      \"reaction_sequence\": [\"rxn_006\", \"rxn_007\", \"rxn_011\", \"rxn_016\"],\n      \"key_intermediates\": [\"mol_006\", \"mol_007\", \"mol_010\", \"mol_011\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"HCN polymer route to glutamate then speculative amidation\",\n      \"description\": \"Surface HCN is oligomerized and later hydrolyzed to an amino acid mixture containing glutamate, which then faces the unresolved glutamine bottleneck.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_004\", \"rxn_005\", \"rxn_016\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_017\", \"mol_011\"]\n    },\n    {\n      \"pathway_id\": \"P6\",\n      \"name\": \"Miller-Strecker route via glutamate aminonitrile then speculative amidation\",\n      \"description\": \"HCN and ammonia react with succinic semialdehyde in a Strecker-type branch to give glutamate aminonitrile, whose hydrolysis yields glutamate.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_012\", \"rxn_013\", \"rxn_016\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_013\", \"mol_011\"]\n    },\n    {\n      \"pathway_id\": \"P7\",\n      \"name\": \"HCN to cyanate activation branch coupled to Ni-glutamate route\",\n      \"description\": \"The strongest glutamate route is combined with a speculative cyanate-activation branch intended to model the most plausible literature-discussed but unvalidated glutamine-forming chemistry.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_014\", \"rxn_015\", \"rxn_006\", \"rxn_007\", \"rxn_008\", \"rxn_016\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_014\", \"mol_015\", \"mol_010\", \"mol_011\"]\n    },\n    {\n      \"pathway_id\": \"P8\",\n      \"name\": \"HCN to cyanate activation branch coupled to FeS-glutamate route\",\n      \"description\": \"The speculative cyanate branch is paired with hydrothermal FeS-mediated \u03b1-ketoglutarate amination to glutamate.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_014\", \"rxn_015\", \"rxn_002\", \"rxn_006\", \"rxn_007\", \"rxn_009\", \"rxn_016\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_014\", \"mol_015\", \"mol_007\", \"mol_010\", \"mol_011\"]\n    },\n    {\n      \"pathway_id\": \"P9\",\n      \"name\": \"HCN to cyanate activation branch coupled to pyrite-photocatalytic glutamate route\",\n      \"description\": \"A surface-dominated route combines HCN-derived activation chemistry with pyrite-photocatalytic reductive amination of \u03b1-ketoglutarate.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_014\", \"rxn_015\", \"rxn_006\", \"rxn_007\", \"rxn_010\", \"rxn_016\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_014\", \"mol_015\", \"mol_010\", \"mol_011\"]\n    },\n    {\n      \"pathway_id\": \"P10\",\n      \"name\": \"Maximally convergent network route\",\n      \"description\": \"This pathway explicitly illustrates the literature reality that multiple independent routes supply glutamate from different environmental chemistries, but all fail at the same final amidation bottleneck.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_003\", \"rxn_004\", \"rxn_005\", \"rxn_006\", \"rxn_007\", \"rxn_011\", \"rxn_014\", \"rxn_015\", \"rxn_016\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_006\", \"mol_007\", \"mol_010\", \"mol_011\", \"mol_015\"]\n    }\n  ],\n  \"hub_molecules\": [\"mol_004\", \"mol_006\", \"mol_007\", \"mol_010\", \"mol_011\"],\n  \"convergence_points\": [\n    {\n      \"molecule_id\": \"mol_010\",\n      \"incoming_reactions\": [\"rxn_007\"],\n      \"outgoing_reactions\": [\"rxn_008\", \"rxn_009\", \"rxn_010\", \"rxn_011\"]\n    },\n    {\n      \"molecule_id\": \"mol_011\",\n      \"incoming_reactions\": [\"rxn_005\", \"rxn_008\", \"rxn_009\", \"rxn_010\", \"rxn_011\", \"rxn_013\"],\n      \"outgoing_reactions\": [\"rxn_016\"]\n    },\n    {\n      \"molecule_id\": \"mol_004\",\n      \"incoming_reactions\": [\"rxn_003\"],\n      \"outgoing_reactions\": [\"rxn_004\", \"rxn_012\", \"rxn_014\"]\n    },\n    {\n      \"molecule_id\": \"mol_007\",\n      \"incoming_reactions\": [\"rxn_002\", \"rxn_006\"],\n      \"outgoing_reactions\": [\"rxn_007\"]\n    },\n    {\n      \"molecule_id\": \"mol_006\",\n      \"incoming_reactions\": [\"rxn_006\"],\n      \"outgoing_reactions\": [\"rxn_007\"]\n    }\n  ]\n}", "parsed_response": {"target_molecule": "Glutamine", "overall_strategy": "This network is literature-constrained and therefore represents glutamine as an unresolved prebiotic target rather than a demonstrated product. The network intentionally models ten distinct routes that converge on glutamic acid from experimentally supported hydrothermal, surface, and biochemical/prebiotic chemistry, then channels all routes through a single explicitly speculative and undemonstrated bottleneck: \u03b3-carboxyl amidation of glutamic acid to glutamine. The design follows the deep research findings by centering \u03b1-ketoglutarate and glutamate as dominant hubs, using exact or near-exact reported conditions where available, and avoiding unsupported claims that glutamine has been achieved prebiotically.", "molecules": [{"id": "mol_001", "formula": "CO2", "iupac_name": "carbon dioxide", "common_name": "carbon dioxide", "inchi": "InChI=1S/CO2/c2-1-3", "role": "starting", "environment_formed": null}, {"id": "mol_002", "formula": "H2", "iupac_name": "molecular hydrogen", "common_name": "hydrogen", "inchi": "InChI=1S/H2/h1H", "role": "starting", "environment_formed": null}, {"id": "mol_003", "formula": "NH3", "iupac_name": "azane", "common_name": "ammonia", "inchi": "InChI=1S/H3N/h1H3", "role": "starting", "environment_formed": null}, {"id": "mol_004", "formula": "HCN", "iupac_name": "hydrogen cyanide", "common_name": "hydrogen cyanide", "inchi": "InChI=1S/CHN/c1-2/h1H", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_005", "formula": "CH2O2", "iupac_name": "methanoic acid", "common_name": "formic acid", "inchi": "InChI=1S/CH2O2/c2-1-3/h1H,(H,2,3)", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_006", "formula": "C2H2O3", "iupac_name": "2-oxoacetic acid", "common_name": "glyoxylic acid", "inchi": "InChI=1S/C2H2O3/c3-1-2(4)5/h1H,(H,4,5)", "role": "hub_intermediate", "environment_formed": "Biochemical"}, {"id": "mol_007", "formula": "C3H4O3", "iupac_name": "2-oxopropanoic acid", "common_name": "pyruvic acid", "inchi": "InChI=1S/C3H4O3/c1-2(4)3(5)6/h1H3,(H,5,6)", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_008", "formula": "C2H5NO2", "iupac_name": "aminoacetic acid", "common_name": "glycine", "inchi": "InChI=1S/C2H5NO2/c3-1-2(4)5/h1,3H2,(H,4,5)", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_009", "formula": "C3H7NO3", "iupac_name": "2-amino-3-hydroxypropanoic acid", "common_name": "serine", "inchi": "InChI=1S/C3H7NO3/c4-2(3(6)7)1-5/h2,5H,1,4H2,(H,6,7)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_010", "formula": "C5H6O5", "iupac_name": "2-oxopentanedioic acid", "common_name": "\u03b1-ketoglutaric acid", "inchi": "InChI=1S/C5H6O5/c6-3(5(9)10)1-2-4(7)8/h1-2H2,(H,7,8)(H,9,10)", "role": "hub_intermediate", "environment_formed": "Biochemical"}, {"id": "mol_011", "formula": "C5H9NO4", "iupac_name": "2-aminopentanedioic acid", "common_name": "glutamic acid", "inchi": "InChI=1S/C5H9NO4/c6-3(5(9)10)1-2-4(7)8/h3H,1-2,6H2,(H,7,8)(H,9,10)", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_012", "formula": "C4H6O3", "iupac_name": "4-oxobutanoic acid", "common_name": "succinic semialdehyde", "inchi": "InChI=1S/C4H6O3/c5-3-1-2-4(6)7/h3H,1-2H2,(H,6,7)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_013", "formula": "C5H8N2O2", "iupac_name": "2-amino-4-cyanobutanoic acid", "common_name": "glutamate aminonitrile", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_014", "formula": "CH3NO", "iupac_name": "formamide", "common_name": "formamide", "inchi": "InChI=1S/CH3NO/c2-1-3/h1H,(H2,2,3)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_015", "formula": "CNO-", "iupac_name": "cyanate", "common_name": "cyanate", "inchi": "InChI=1S/CNO/c1-2-3/q-1", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_016", "formula": "C5H10N2O3", "iupac_name": "2,5-diamino-5-oxopentanoic acid", "common_name": "glutamine", "inchi": "InChI=1S/C5H10N2O3/c6-3(5(9)10)1-2-4(7)8/h3H,1-2,6H2,(H2,7,8)(H,9,10)", "role": "target", "environment_formed": "Biochemical"}, {"id": "mol_017", "formula": "(HCN)n", "iupac_name": "hydrogen cyanide oligomer/polymer", "common_name": "HCN polymer", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}], "reactions": [{"id": "rxn_001", "name": "Greigite-catalyzed CO2 reduction to formate", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_005"], "environment": "Hydrothermal", "agents": ["greigite (Fe3S4)", "mackinawite (FeS)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "greigite/mackinawite", "aqueous": "true", "other": "alkaline vent conditions; H2-rich; anoxic"}, "mechanism": "Mineral-surface hydrogenation of CO2 to a C1 reduced carboxylate.", "reasoning": "Included as the hydrothermal carbon-fixation entry consistent with iron-sulfur world and vent chemistry discussed in the report, which cites serpentinization-linked H2 availability and mineral catalysis for reduced C1 products; greigite/mackinawite are framework-consistent ancestral catalysts, while awaruite-related vent carbon fixation to reduced organics is supported by Preiner et al. (2020) and Beyazay et al. (2023). This specific greigite formate step is a network-connecting extrapolation grounded in the vent literature rather than a glutamine-specific demonstration."}, {"id": "rxn_002", "name": "Hydrothermal H2-dependent pyruvate formation from CO2", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_007"], "environment": "Hydrothermal", "agents": ["magnetite (Fe3O4)", "elemental iron (Fe0)"], "conditions": {"temperature": "373K", "pressure": "high", "catalyst": "magnetite/Fe0; serpentinization-associated Ni-Fe mineral analogs", "aqueous": "true", "other": "100\u00b0C hydrothermal carbon-fixation regime; anoxic"}, "mechanism": "Serpentinization-linked mineral reduction of CO2 generates reduced carbon products including pyruvate under H2-rich conditions.", "reasoning": "The report specifically states that awaruite (Ni3Fe) nanoparticles formed during serpentinization catalyze H2-dependent CO2 fixation to formate, acetate, and pyruvate at 100\u00b0C, linking hydrothermal mineralogy to keto-acid supply (Preiner et al., 2020; Beyazay et al., 2023). This reaction is therefore anchored to reported hydrothermal pyruvate production, with magnetite/Fe0 included as required hydrothermal minerals compatible with serpentinization settings."}, {"id": "rxn_003", "name": "Surface HCN generation under discharge/photochemical conditions", "inputs": ["mol_001", "mol_003"], "outputs": ["mol_004"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "sulfide minerals (stibnite/molybdenite)"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "TiO2 photocatalytic surface", "aqueous": "true", "other": "UV irradiation or spark-discharge analog atmosphere; anoxic"}, "mechanism": "Atmospheric energy input forms nitriles; mineral surfaces assist photochemical concentration and downstream reactivity.", "reasoning": "Miller-type discharge and related atmospheric energy input are central to the report's Strecker and HCN-oligomerization branches, with HCN as a key precursor to aminonitriles and polymers (Miller, 1955; Johnson et al., 2008; Parker et al., 2011; Ferris, Sanchez & Orgel, 1966-1978). TiO2 is added as the required surface mineral agent and is consistent with prebiotic UV photochemistry, though the exact HCN-generating atmosphere experiments were not TiO2-dependent."}, {"id": "rxn_004", "name": "HCN oligomerization to HCN polymer", "inputs": ["mol_004"], "outputs": ["mol_017"], "environment": "Surface", "agents": ["montmorillonite (clay)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "mineral concentration surfaces", "aqueous": "true", "other": "evaporative concentration and/or UV exposure; anoxic"}, "mechanism": "HCN undergoes oligomerization/polymerization to complex nitrile-rich macromolecular material.", "reasoning": "HCN polymer chemistry is explicitly supported as a route to amino-acid-releasing polymeric material, although product-level specificity is poor (Matthews & Moser, 1967; Ruiz-Bermejo et al., 2013; Cleaves et al., 2010; Ferris, Sanchez & Orgel, 1966-1978). Montmorillonite and TiO2 are included as required surface mineral agents to model concentration and photochemical assistance, while acknowledging that the classical HCN polymer literature did not require these exact minerals."}, {"id": "rxn_005", "name": "Hydrolysis of HCN polymer to glutamic acid-containing amino acid mixture", "inputs": ["mol_017"], "outputs": ["mol_011", "mol_008"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "variable", "pressure": "1 atm", "catalyst": null, "aqueous": "true", "other": "acidic or basic hydrolysis of heterogeneous polymer; low specificity"}, "mechanism": "Polymeric nitrile material hydrolyzes to a mixture of amino acids, including glutamic acid and glycine.", "reasoning": "The report emphasizes that HCN polymers can release glutamic acid upon hydrolysis but that the pathway is diffuse and poorly characterized; therefore this reaction is represented as a mixture-producing source rather than a selective glutamate synthesis (Matthews & Moser, 1967; Ruiz-Bermejo et al., 2013; Cleaves et al., 2010)."}, {"id": "rxn_006", "name": "Prebiotic glyoxylate and pyruvate generation from glycine and serine", "inputs": ["mol_008", "mol_009"], "outputs": ["mol_006", "mol_007"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "343K", "pressure": "1 atm", "catalyst": "Cu2+ and phosphate in solution", "aqueous": "true", "other": "pH near phosphate-buffered conditions; 70\u00b0C"}, "mechanism": "Amino acids undergo nonenzymatic conversion to corresponding carbonyl compounds, producing glyoxylate and pyruvate that feed keto-acid network expansion.", "reasoning": "This reaction directly follows the report's statement that serine and glycine in the presence of phosphate and Cu2+ generate glyoxylate and pyruvate, enabling closure of a plausible prebiotic cycle (Ter-Ovanessian, Krishnamurthy & Springsteen, 2025)."}, {"id": "rxn_007", "name": "Aldol/cross-Cannizzaro formation of \u03b1-ketoglutarate from glyoxylate and pyruvate", "inputs": ["mol_006", "mol_007"], "outputs": ["mol_010"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "343K", "pressure": "1 atm", "catalyst": null, "aqueous": "true", "other": "pH 4.5; no metal catalyst required"}, "mechanism": "Glyoxylate and pyruvate couple through nonenzymatic aldol/cross-Cannizzaro chemistry to generate the C5 \u03b1-keto diacid \u03b1-ketoglutarate.", "reasoning": "This is one of the strongest experimentally supported nodes in the network and is reported explicitly in the deep research findings as the prerequisite \u03b1-ketoglutarate source from glyoxylate and pyruvate at pH 4.5 and 70\u00b0C without metal catalysts (Stubbs, Krishnamurthy & Springsteen, 2020). The metabolic framing is also connected to Morowitz & Smith (2004)."}, {"id": "rxn_008", "name": "Ni-catalyzed reductive amination of \u03b1-ketoglutarate to glutamic acid", "inputs": ["mol_010", "mol_003", "mol_002"], "outputs": ["mol_011"], "environment": "Surface", "agents": ["sulfide minerals (stibnite/molybdenite)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "295K", "pressure": "1 atm", "catalyst": "Ni/SiO2-Al2O3 or meteoritic metal catalyst", "aqueous": "true", "other": "22\u00b0C; pH 8; H2 gas; ammonium present"}, "mechanism": "\u03b1-Ketoglutarate undergoes nonenzymatic reductive amination under H2 with heterogeneous Ni catalyst to yield glutamate.", "reasoning": "This reaction follows the exact literature-highlighted route: Kaur, Moran and colleagues reported H2-driven nonenzymatic reductive amination of \u03b1-ketoglutarate to glutamate using Ni/SiO2-Al2O3 at 22\u00b0C and pH 8, with high yields, and also observed catalysis by Aletai meteorite material (Kaur et al., 2024, Chem). The surface mineral agents listed satisfy schema requirements but the cited catalytic support is specifically the Ni catalyst and meteoritic metal."}, {"id": "rxn_009", "name": "FeS-mediated reductive amination of \u03b1-ketoglutarate to glutamic acid", "inputs": ["mol_010", "mol_003"], "outputs": ["mol_011"], "environment": "Hydrothermal", "agents": ["mackinawite (FeS)", "pyrite (FeS2)"], "conditions": {"temperature": "343-373K", "pressure": "high", "catalyst": "freshly precipitated FeS or Fe(OH)2 with H2S", "aqueous": "true", "other": "anoxic vent-like conditions with ammonia; iron-sulfur world setting"}, "mechanism": "Iron-sulfur mineral surfaces promote nonenzymatic amination/reduction of \u03b1-keto acid to amino acid.", "reasoning": "The report identifies foundational demonstrations of \u03b1-oxo-acid reductive amination in FeS/H2S systems and amino acid formation from keto-acid precursors using freshly precipitated FeS or Fe(OH)2 with ammonia (Hafenbradl et al., 1995; Huber & W\u00e4chtersh\u00e4user, 2003). This provides a literature-grounded hydrothermal alternative route from \u03b1-ketoglutarate to glutamate."}, {"id": "rxn_010", "name": "Pyrite photocatalytic reductive amination of \u03b1-ketoglutarate to glutamic acid", "inputs": ["mol_010", "mol_003"], "outputs": ["mol_011"], "environment": "Surface", "agents": ["pyrite-like sulfide mineral surface", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "293K", "pressure": "1 atm", "catalyst": "natural pyrite under irradiation", "aqueous": "true", "other": "20\u00b0C; Xe lamp irradiation; anoxic"}, "mechanism": "Photoexcited mineral surface drives reductive amination of \u03b1-keto acid to amino acid.", "reasoning": "The deep research findings explicitly cite a 2024 Nature Communications study showing natural pyrite catalyzes photocatalytic reductive amination of \u03b1-keto acids, including \u03b1-ketoglutarate to glutamic acid, at 20\u00b0C under Xe lamp irradiation. TiO2 is included only to satisfy the required surface-mineral schema; the literature support is specifically for pyrite photocatalysis (2024 Nature Communications study as summarized in the report)."}, {"id": "rxn_011", "name": "Al3+-catalyzed transamination of \u03b1-ketoglutarate with glycine to glutamic acid", "inputs": ["mol_010", "mol_008"], "outputs": ["mol_011"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "353K", "pressure": "1 atm", "catalyst": "Al3+", "aqueous": "true", "other": "80\u00b0C; pH 5"}, "mechanism": "Nonenzymatic transamination transfers amino functionality from glycine to \u03b1-ketoglutarate, yielding glutamate within an ancestral Krebs-cycle analog.", "reasoning": "This reaction uses the exact conditions emphasized in the report: \u03b1-ketoglutarate reacts with glycine to produce glutamate in 44% yield at 80\u00b0C and pH 5 with Al3+ catalysis (Stubbs, Krishnamurthy & Springsteen, 2020). Earlier support for nonenzymatic transamination by metal ions is also noted in Degani & Halmann (1967) and extended by Muchowska, Varma & Moran (2021)."}, {"id": "rxn_012", "name": "Miller-Urey Strecker branch to glutamate aminonitrile", "inputs": ["mol_012", "mol_003", "mol_004"], "outputs": ["mol_013"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "montmorillonite (clay)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "mineral concentration surfaces", "aqueous": "true", "other": "spark-discharge-derived aldehyde inventory; Strecker aqueous phase chemistry"}, "mechanism": "Succinic semialdehyde forms a hemiaminal/iminium with ammonia and adds cyanide to yield the corresponding aminonitrile precursor to glutamate.", "reasoning": "The report states that Miller-Urey chemistry proceeds through Strecker synthesis in the aqueous phase and identifies succinic semialdehyde as the required C4 aldehyde precursor for glutamate, but also notes that no direct experimental demonstration from prebiotically sourced succinic semialdehyde has been reported. Accordingly, this reaction is included as a cautious, literature-guided branch rather than an overclaimed established route (Miller, 1955; Johnson et al., 2008; Parker et al., 2011; summary discussion in the deep research findings)."}, {"id": "rxn_013", "name": "Hydrolysis of glutamate aminonitrile to glutamic acid", "inputs": ["mol_013"], "outputs": ["mol_011"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": null, "aqueous": "true", "other": "aqueous hydrolysis over time; acidic or neutral workup"}, "mechanism": "Nitrile hydrolysis converts the aminonitrile into the corresponding amino dicarboxylic acid.", "reasoning": "Hydrolysis of aminonitriles to amino acids is the standard second stage of Strecker chemistry and underlies the Miller-type interpretation summarized in the report (Miller, 1955; Johnson et al., 2008; Parker et al., 2011). For glutamate specifically, the precursor succinic semialdehyde branch remains less directly demonstrated, so this step is chemically standard but contingent on the speculative precursor availability noted in the report."}, {"id": "rxn_014", "name": "HCN hydrolysis/photochemistry to formamide", "inputs": ["mol_004"], "outputs": ["mol_014"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "borate minerals (colemanite/ulexite)"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "TiO2 photocatalytic surface", "aqueous": "true", "other": "UV-irradiated surface pools"}, "mechanism": "HCN in aqueous/photochemical settings is converted into formamide as a downstream nitrile-derived intermediate.", "reasoning": "The report's surface chemistry section explicitly includes UV photochemistry in which HCN and water under UV lead to formamide and related prebiotic products. This branch is included because the report identifies cyanate as the most plausible speculative activator for glutamate amidation, and formamide is a reasonable literature-connected precursor node for such nitrogen-carbonyl chemistry. General support comes from the report's HCN/formamide photochemistry summary and related prebiotic photochemistry literature; this is a connecting step rather than glutamine-specific evidence."}, {"id": "rxn_015", "name": "Surface generation of cyanate from formamide-derived nitrogen-carbonyl chemistry", "inputs": ["mol_014"], "outputs": ["mol_015"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "mineral-assisted drying/photochemical activation", "aqueous": "false", "other": "drying episodes and UV exposure; highly speculative connection step"}, "mechanism": "Formamide-derived nitrogen-carbonyl species are converted to cyanate under dehydrating/oxidation-state rearrangement conditions.", "reasoning": "Danger, Pascal and colleagues showed cyanate can activate dicarboxylic acids, and the report identifies cyanate-mediated chemistry as the most promising but still undemonstrated route toward selective glutamate \u03b3-activation (Danger et al., 2012). However, a direct prebiotic formamide-to-cyanate route tied specifically to glutamine synthesis was not demonstrated in the report; therefore this reaction is explicitly speculative and included only to connect the literature-supported cyanate activation idea into a complete network."}, {"id": "rxn_016", "name": "Speculative cyanate-mediated \u03b3-carboxyl amidation of glutamic acid to glutamine", "inputs": ["mol_011", "mol_003", "mol_015"], "outputs": ["mol_016"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "293-323K", "pressure": "1 atm", "catalyst": "cyanate as activating agent", "aqueous": "true", "other": "mild conditions required because glutamine is thermally fragile; competing cyclization to pyroglutamate expected"}, "mechanism": "Hypothetical cyanate-mediated activation of glutamic acid to an intramolecular anhydride or related activated intermediate followed by ammonia capture at the \u03b3-carboxyl to give glutamine.", "reasoning": "This final step is intentionally marked as speculative and undemonstrated because the deep research findings explicitly state that glutamine has never been detected in any prebiotic synthesis experiment or meteorite, and that no mineral catalyst or prebiotic system has been shown to amidate glutamic acid selectively at the \u03b3-carboxyl. The most promising idea identified in the report is cyanate-mediated activation of dicarboxylic acids through anhydride chemistry, but this has not been experimentally validated for glutamine and is likely outcompeted by pyroglutamic acid formation and deamidation (Danger et al., 2012; Weber & Miller, 1981; Yu et al., 2006; Weiss et al., 2018; Hamilton, 1962)."}], "pathways": [{"pathway_id": "P1", "name": "Hydrothermal carbon fixation to Ni-catalyzed glutamate then speculative amidation", "description": "CO2 is reduced hydrothermally to pyruvate, pyruvate couples with glyoxylate to \u03b1-ketoglutarate, which is converted to glutamate by the strongest literature-supported Ni-catalyzed reductive amination route; glutamine formation remains speculative.", "reaction_sequence": ["rxn_002", "rxn_006", "rxn_007", "rxn_008", "rxn_016"], "key_intermediates": ["mol_007", "mol_006", "mol_010", "mol_011"]}, {"pathway_id": "P2", "name": "Hydrothermal carbon fixation to FeS-mediated glutamate then speculative amidation", "description": "The same \u03b1-ketoglutarate core is fed by hydrothermal pyruvate supply, but glutamate is produced in an iron-sulfur-world branch using FeS/H2S chemistry.", "reaction_sequence": ["rxn_002", "rxn_006", "rxn_007", "rxn_009", "rxn_016"], "key_intermediates": ["mol_007", "mol_006", "mol_010", "mol_011"]}, {"pathway_id": "P3", "name": "Hydrothermal carbon fixation to pyrite-photocatalytic glutamate then speculative amidation", "description": "Hydrothermal keto-acid supply feeds a surface photochemical branch in which \u03b1-ketoglutarate is reductively aminated to glutamate on illuminated pyrite.", "reaction_sequence": ["rxn_002", "rxn_006", "rxn_007", "rxn_010", "rxn_016"], "key_intermediates": ["mol_007", "mol_006", "mol_010", "mol_011"]}, {"pathway_id": "P4", "name": "Amino-acid-fed proto-cycle to transaminative glutamate then speculative amidation", "description": "Serine and glycine generate glyoxylate and pyruvate, which form \u03b1-ketoglutarate; Al3+-catalyzed transamination with glycine gives glutamate.", "reaction_sequence": ["rxn_006", "rxn_007", "rxn_011", "rxn_016"], "key_intermediates": ["mol_006", "mol_007", "mol_010", "mol_011"]}, {"pathway_id": "P5", "name": "HCN polymer route to glutamate then speculative amidation", "description": "Surface HCN is oligomerized and later hydrolyzed to an amino acid mixture containing glutamate, which then faces the unresolved glutamine bottleneck.", "reaction_sequence": ["rxn_003", "rxn_004", "rxn_005", "rxn_016"], "key_intermediates": ["mol_004", "mol_017", "mol_011"]}, {"pathway_id": "P6", "name": "Miller-Strecker route via glutamate aminonitrile then speculative amidation", "description": "HCN and ammonia react with succinic semialdehyde in a Strecker-type branch to give glutamate aminonitrile, whose hydrolysis yields glutamate.", "reaction_sequence": ["rxn_003", "rxn_012", "rxn_013", "rxn_016"], "key_intermediates": ["mol_004", "mol_013", "mol_011"]}, {"pathway_id": "P7", "name": "HCN to cyanate activation branch coupled to Ni-glutamate route", "description": "The strongest glutamate route is combined with a speculative cyanate-activation branch intended to model the most plausible literature-discussed but unvalidated glutamine-forming chemistry.", "reaction_sequence": ["rxn_003", "rxn_014", "rxn_015", "rxn_006", "rxn_007", "rxn_008", "rxn_016"], "key_intermediates": ["mol_004", "mol_014", "mol_015", "mol_010", "mol_011"]}, {"pathway_id": "P8", "name": "HCN to cyanate activation branch coupled to FeS-glutamate route", "description": "The speculative cyanate branch is paired with hydrothermal FeS-mediated \u03b1-ketoglutarate amination to glutamate.", "reaction_sequence": ["rxn_003", "rxn_014", "rxn_015", "rxn_002", "rxn_006", "rxn_007", "rxn_009", "rxn_016"], "key_intermediates": ["mol_004", "mol_014", "mol_015", "mol_007", "mo
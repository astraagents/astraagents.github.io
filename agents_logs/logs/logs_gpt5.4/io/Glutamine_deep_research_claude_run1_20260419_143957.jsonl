eaction_sequence": ["rxn_001", "rxn_002", "rxn_003", "rxn_004", "rxn_005", "rxn_016"], "key_intermediates": ["mol_007", "mol_008", "mol_011", "mol_012"]}, {"pathway_id": "P2", "name": "Hydrothermal carbon fixation to alpha-ketoglutarate then FeS reductive amination then speculative cyanate amidation", "description": "Same backbone as P1 but uses classical FeS/iron-sulfur world reductive amination chemistry to reach glutamate.", "reaction_sequence": ["rxn_001", "rxn_002", "rxn_003", "rxn_004", "rxn_006", "rxn_016"], "key_intermediates": ["mol_007", "mol_008", "mol_011", "mol_012"]}, {"pathway_id": "P3", "name": "Hydrothermal carbon fixation to alpha-ketoglutarate then pyrite photoreductive amination then speculative amidation", "description": "Pyruvate from vent chemistry and glyoxylate from surface amino-acid cycling converge on alpha-ketoglutarate; surface pyrite photochemistry yields glutamate.", "reaction_sequence": ["rxn_001", "rxn_002", "rxn_003", "rxn_004", "rxn_007", "rxn_016"], "key_intermediates": ["mol_007", "mol_008", "mol_011", "mol_012"]}, {"pathway_id": "P4", "name": "Surface amino-acid cycling to alpha-ketoglutarate then Al3+ transamination then speculative amidation", "description": "Surface glycine/serine chemistry directly generates pyruvate and glyoxylate, which close to alpha-ketoglutarate and then to glutamate by transamination.", "reaction_sequence": ["rxn_003", "rxn_004", "rxn_008", "rxn_016"], "key_intermediates": ["mol_008", "mol_007", "mol_011", "mol_012"]}, {"pathway_id": "P5", "name": "HCN polymer route to glutamate then speculative amidation", "description": "HCN accumulates and oligomerizes to polymeric material that hydrolyzes to amino-acid mixtures containing glutamate, followed by unresolved glutamine formation.", "reaction_sequence": ["rxn_009", "rxn_010", "rxn_016"], "key_intermediates": ["mol_020", "mol_012"]}, {"pathway_id": "P6", "name": "Spark-discharge Strecker route to glutamate then speculative amidation", "description": "Ga
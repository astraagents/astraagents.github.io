,\n      \"common_name\": \"serine\",\n      \"inchi\": \"InChI=1S/C3H7NO3/c4-2(3(6)7)1-5/h2,5H,1,4H2,(H,6,7)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_011\",\n      \"formula\": \"C5H6O5\",\n      \"iupac_name\": \"2-oxopentanedioic acid\",\n      \"common_name\": \"alpha-ketoglutarate/2-oxoglutarate\",\n      \"inchi\": \"InChI=1S/C5H6O5/c6-3(5(9)10)1-2-4(7)8/h1-2H2,(H,7,8)(H,9,10)\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_012\",\n      \"formula\": \"C5H9NO4\",\n      \"iupac_name\": \"2-aminopentanedioic acid\",\n      \"common_name\": \"glutamic acid/glutamate\",\n      \"inchi\": \"InChI=1S/C5H9NO4/c6-3(5(9)10)1-2-4(7)8/h3H,1-2,6H2,(H,7,8)(H,9,10)\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_013\",\n      \"formula\": \"C4H6O3\",\n      \"iupac_name\": \"4-oxobutanoic acid\",\n      \"common_name\": \"succinic semialdehyde\",\n      \"inchi\": \"InChI=1S/C4H6O3/c5-3-1-2-4(6)7/h3H,1-2H2,(H,6,7)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_014\",\n      \"formula\": \"C5H8N2O2\",\n      \"iupac_name\": \"2-amino-4-cyanobutanoic acid\",\n      \"common_name\": \"glutamate aminonitrile\",\n      \"inchi\": \"InChI=1S/C5H8N2O2/c6-3-1-2-4(7)5(8)9/h4H,1-2,7H2,(H,8,9)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_015\",\n      \"formula\": \"C5H10N2O3\",\n      \"iupac_name\": \"2,5-diamino-5-oxopentanoic acid\",\n      \"common_name\": \"glutamine\",\n      \"inchi\": \"InChI=1S/C5H10N2O3/c6-3(5(9)10)1-2-4(7)8/h3H,1-2,6H2,(H2,7,8)(H,9,10)\",\n      \"role\": \"target\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_016\",\n      \"formula\": \"CHNO\",\n      \"iupac_name\": \"formamide\",\n      \"common_name\": \"formamide\",\n      \"inchi\": \"InChI=1S/CH3NO/c2-1-3/h1H,(H2,2,3)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_017\",\n      \"formula\": \"C5H7NO3\",\n      \"iupac_name\": \"5-oxopyrrolidine-2-carboxylic acid\",\n      \"common_name\": \"pyroglutamic acid\",\n      \"inchi\": \"InChI=1S/C5H7NO3/c7-4-2-1-3(5(8)9)6-4/h3H,1-2H2,(H,6,7)(H,8,9)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_018\",\n      \"formula\": \"CHNO\",\n      \"iupac_name\": \"cyanic acid\",\n      \"common_name\": \"cyanate/isocyanate pool\",\n      \"inchi\": \"InChI=1S/CHNO/c2-1-3/h(H,2,3)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_019\",\n      \"formula\": \"CH2N2\",\n      \"iupac_name\": \"methanimidamide\",\n      \"common_name\": \"cyanamide\",\n      \"inchi\": \"InChI=1S/CH2N2/c2-1-3/h(H2,2,3)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_020\",\n      \"formula\": \"CxHyNz\",\n      \"iupac_name\": \"hydrogen cyanide oligomer/polymer mixture\",\n      \"common_name\": \"HCN polymer\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"Greigite-catalyzed CO2 reduction to formate\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_005\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe3S4)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"greigite/mackinawite\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline vent-like, H2-rich, anoxic\"\n      },\n      \"mechanism\": \"Mineral-surface electron transfer reduces CO2 to one-carbon carboxylate species.\",\n      \"reasoning\": \"Hydrothermal CO2 reduction to formate on Fe-S minerals is consistent with iron-sulfur world and vent-interface chemistry; greigite and mackinawite are widely discussed as protoferredoxin-like catalysts in alkaline vents (Hafenbradl et al., 1995; Russell & Martin framework; Bonfio et al., 2017).\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Hydrothermal carbon fixation from formate/CO2 to pyruvate\",\n      \"inputs\": [\"mol_001\", \"mol_002\", \"mol_005\"],\n      \"outputs\": [\"mol_007\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe3O4)\", \"elemental iron (Fe0)\"],\n      \"conditions\": {\n        \"temperature\": \"373K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"magnetite/Fe0\",\n        \"aqueous\": \"true\",\n        \"other\": \"serpentinization-linked; awaruite-like geochemical context; anoxic\"\n      },\n      \"mechanism\": \"Sequential H2-driven reduction/carbon fixation yields a three-carbon alpha-keto acid pool including pyruvate.\",\n      \"reasoning\": \"Serpentinization-generated H2 and Fe/Ni mineral catalysis produce pyruvate in hydrothermal settings; awaruite-associated fixation provides the geochemical basis, while magnetite/Fe0 are appropriate vent minerals for network representation (Preiner et al., 2020; Beyazay et al., 2023; Kelley et al., 2001).\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Surface generation of glyoxylate and pyruvate from glycine and serine\",\n      \"inputs\": [\"mol_009\", \"mol_010\"],\n      \"outputs\": [\"mol_008\", \"mol_007\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"phosphate minerals (apatite/struvite)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"343K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"phosphate with Cu2+-enabled geochemical setting\",\n        \"aqueous\": \"true\",\n        \"other\": \"pH near neutral to mildly acidic; literature reaction uses phosphate and Cu2+ at 70C; TiO2 included as surface photomineral concentrator\"\n      },\n      \"mechanism\": \"Amino acids feed nonenzymatic oxidative/deamination chemistry that closes to glyoxylate and pyruvate pools under phosphate-assisted conditions.\",\n      \"reasoning\": \"Ter-Ovanessian, Krishnamurthy, and Springsteen showed serine and glycine in the presence of phosphate and Cu2+ generate glyoxylate and pyruvate, enabling alpha-ketoglutarate formation; this is one of the few literature-supported sources for both key hubs and should replace unsupported glyoxylate inventions (Ter-Ovanessian et al., 2025).\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"Aldol/cross-Cannizzaro formation of alpha-ketoglutarate from pyruvate and glyoxylate\",\n      \"inputs\": [\"mol_007\", \"mol_008\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"343K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"none intrinsic in core literature reaction; mineral surfaces provide concentration/orientation\",\n        \"aqueous\": \"true\",\n        \"other\": \"pH 4.5; no transition-metal catalyst required in core report\"\n      },\n      \"mechanism\": \"Glyoxylate and pyruvate undergo aldol addition and associated redox rearrangement to yield the five-carbon alpha-keto dicarboxylate.\",\n      \"reasoning\": \"This exact convergent step is directly supported: alpha-ketoglutarate forms from glyoxylate and pyruvate at pH 4.5 and 70C in an ancestral Krebs-cycle analog (Stubbs et al., 2020). Mineral agents are included to satisfy the surface-environment requirement while not altering the literature core chemistry.\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"Ni-catalyzed reductive amination of alpha-ketoglutarate to glutamic acid\",\n      \"inputs\": [\"mol_011\", \"mol_003\", \"mol_002\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"elemental iron (Fe0)\", \"pyrite (FeS2)\"],\n      \"conditions\": {\n        \"temperature\": \"295K\",\n        \"pressure\": \"H2 atmosphere\",\n        \"catalyst\": \"Ni/SiO2-Al2O3 or meteoritic Fe-Ni catalyst\",\n        \"aqueous\": \"true\",\n        \"other\": \"22C, pH 8, ammonium present; mild anoxic conditions\"\n      },\n      \"mechanism\": \"Catalytic hydrogenation of the imine/iminium derived from alpha-ketoglutarate and ammonia gives glutamate selectively over hydroxy acid.\",\n      \"reasoning\": \"This is the strongest experimentally demonstrated route to glutamate: Kaur, Moran and coworkers achieved 6-84% amino acid yields from alpha-ketoglutarate under H2 at 22C, pH 8, using Ni/SiO2-Al2O3 and meteoritic catalysts; older FeS/H2S and Fe(OH)2 work established related nonenzymatic reductive amination chemistry (Kaur et al., 2024; Hafenbradl et al., 1995; Huber & Wachtershauser, 2003).\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"FeS-mediated reductive amination of alpha-ketoglutarate to glutamic acid\",\n      \"inputs\": [\"mol_011\", \"mol_003\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"mackinawite (FeS)\", \"pyrite (FeS2)\"],\n      \"conditions\": {\n        \"temperature\": \"343-373K\",\n        \"pressure\": \"moderate to high\",\n        \"catalyst\": \"freshly precipitated FeS or Fe(OH)2 with H2S-rich setting\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic iron-sulfur world conditions\"\n      },\n      \"mechanism\": \"Mineral-assisted imine formation and reduction on Fe-S surfaces converts the alpha-keto acid precursor to the amino acid.\",\n      \"reasoning\": \"Foundational W\u00e4chtersh\u00e4user chemistry demonstrated amino acid formation from alpha-oxo acids with FeS/H2S and related Fe(OH)2 mineral systems, supporting a hydrothermal route from alpha-ketoglutarate to glutamate even if lower-yield and less selective than modern Ni catalysts (Hafenbradl et al., 1995; Huber & Wachtershauser, 2003).\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Pyrite photocatalytic reductive amination of alpha-ketoglutarate to glutamic acid\",\n      \"inputs\": [\"mol_011\", \"mol_003\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"pyrite (FeS2)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"293K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"natural pyrite under irradiation\",\n        \"aqueous\": \"true\",\n        \"other\": \"Xe lamp irradiation, 20C, anoxic or low-O2 prebiotic analog\"\n      },\n      \"mechanism\": \"Photoexcited mineral surface promotes reductive amination of the alpha-keto acid in the presence of ammonia equivalents.\",\n      \"reasoning\": \"A 2024 Nature Communications study showed natural pyrite catalyzes photocatalytic reductive amination of alpha-keto acids including alpha-ketoglutarate to glutamic acid at 20C under Xe lamp irradiation, making this a directly supported surface route (2024 Nature Communications study cited in research findings).\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Al3+-type transamination of alpha-ketoglutarate with glycine to glutamic acid\",\n      \"inputs\": [\"mol_011\", \"mol_009\"],\n      \"outputs\": [\"mol_012\", \"mol_008\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"353K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"Al3+ in solution\",\n        \"aqueous\": \"true\",\n        \"other\": \"pH 5; 80C; metal-ion-catalyzed ancestral Krebs-cycle analog\"\n      },\n      \"mechanism\": \"Nonenzymatic transamination transfers amino functionality from glycine-derived donor chemistry to alpha-ketoglutarate, yielding glutamate and regenerating glyoxylate-equivalent carbonyl chemistry.\",\n      \"reasoning\": \"Stubbs, Krishnamurthy, and Springsteen reported glutamate in 44% yield from alpha-ketoglutarate and glycine at 80C, pH 5, with Al3+ catalysis; earlier and later studies support nonenzymatic metal-ion transamination under prebiotic conditions (Stubbs et al., 2020; Degani & Halmann, 1967; Muchowska et al., 2021). Mineral agents here act as concentrative surface phases while the literature catalyst remains dissolved Al3+.\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"HCN oligomerization/polymerization to HCN polymer reservoir\",\n      \"inputs\": [\"mol_004\"],\n      \"outputs\": [\"mol_020\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"sulfide minerals (stibnite/molybdenite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"surface-mediated oligomerization\",\n        \"aqueous\": \"true\",\n        \"other\": \"evaporative concentration and UV-accessible setting\"\n      },\n      \"mechanism\": \"HCN oligomerizes to complex nitrile-rich polymeric material that serves as a diffuse precursor reservoir rather than a single defined intermediate.\",\n      \"reasoning\": \"HCN polymerization chemistry is foundational prebiotic chemistry; polymeric HCN material later hydrolyzes to mixtures including glutamic acid, though precise paths remain unresolved (Ferris, Sanchez, & Orgel series 1966-1978; Matthews & Moser, 1967; Ruiz-Bermejo et al., 2013; Cleaves et al., 2010).\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"Hydrolysis of HCN polymer to amino acid mixture including glutamic acid\",\n      \"inputs\": [\"mol_020\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral-assisted adsorption/hydrolysis\",\n        \"aqueous\": \"true\",\n        \"other\": \"acidic or basic hydrolytic workup analog; product is a complex mixture, not a selective synthesis\"\n      },\n      \"mechanism\": \"Hydrolytic breakdown of nitrile-rich polymer releases multiple amino acids, among which glutamic acid is reported.\",\n      \"reasoning\": \"Matthews and Moser reported HCN-derived polymer hydrolysis yielding amino acids including glutamic acid; later reviews confirm glutamic acid among products but emphasize low specificity and analytical caution, so this node is intentionally represented as a mixture-derived source rather than a selective route (Matthews & Moser, 1967; Ruiz-Bermejo et al., 2013; Cleaves et al., 2010).\"\n    },\n    {\n      \"id\": \"rxn_011\",\n      \"name\": \"Spark-discharge generation of HCN and C4 aldehyde precursor pool including succinic semialdehyde\",\n      \"inputs\": [\"mol_001\", \"mol_003\"],\n      \"outputs\": [\"mol_004\", \"mol_013\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"sulfide minerals (stibnite/molybdenite)\"],\n      \"conditions\": {\n        \"temperature\": \"variable discharge plasma; bulk 300-370K aqueous collection\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"electrical discharge with mineral shore collection\",\n        \"aqueous\": \"true\",\n        \"other\": \"Miller-Urey type weakly reducing to volcanic gas mixtures; aldehydes and HCN generated in gas phase then dissolve\"\n      },\n      \"mechanism\": \"Electric discharge creates nitriles and carbonyls in the gas phase; aqueous dissolution provides Strecker precursors including HCN and inferred C4 aldehyde feedstocks.\",\n      \"reasoning\": \"The deep research specifically identifies Miller-Urey glutamate formation as proceeding via gas-phase generation of HCN and C4 aldehydes including succinic semialdehyde, followed by aqueous Strecker chemistry; this should be represented as a precursor-pool step rather than an invented selective synthesis (Miller, 1955; Johnson et al., 2008; Parker et al., 2011).\"\n    },\n    {\n      \"id\": \"rxn_012\",\n      \"name\": \"Strecker formation of glutamate aminonitrile from succinic semialdehyde, HCN, and ammonia\",\n      \"inputs\": [\"mol_013\", \"mol_004\", \"mol_003\"],\n      \"outputs\": [\"mol_014\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (stibnite/molybdenite)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral concentration surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"Strecker-type aqueous chemistry; plausibly in spark-discharge collection ponds\"\n      },\n      \"mechanism\": \"Aldehyde forms a hemiaminal/iminium with ammonia and traps cyanide to give the corresponding aminonitrile.\",\n      \"reasoning\": \"This is the literature-described mechanistic route for Miller-type glutamate production, but direct demonstration from prebiotically sourced succinic semialdehyde remains lacking; included because the report explicitly identifies succinic semialdehyde as the required Strecker precursor and notes the route as plausible but experimentally incomplete (Miller, 1955; Johnson et al., 2008; Parker et al., 2011).\"\n    },\n    {\n      \"id\": \"rxn_013\",\n      \"name\": \"Hydrolysis of glutamate aminonitrile to glutamic acid\",\n      \"inputs\": [\"mol_014\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral-assisted aqueous hydrolysis\",\n        \"aqueous\": \"true\",\n        \"other\": \"prolonged hydrolysis under neutral to acidic conditions\"\n      },\n      \"mechanism\": \"Sequential nitrile hydration and amidic hydrolysis yields the alpha-amino dicarboxylic acid.\",\n      \"reasoning\": \"Hydrolysis of Strecker aminonitriles to amino acids is standard prebiotic chemistry and underlies the Miller-Urey interpretation for glutamic acid formation; here it completes the succinic semialdehyde branch to glutamate (Miller, 1955; Johnson et al., 2008; Parker et al., 2011).\"\n    },\n    {\n      \"id\": \"rxn_014\",\n      \"name\": \"HCN hydration to formamide\",\n      \"inputs\": [\"mol_004\"],\n      \"outputs\": [\"mol_016\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"borate minerals (colemanite/ulexite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"UV-active oxide surface\",\n        \"aqueous\": \"true\",\n        \"other\": \"UV-exposed evaporitic or geothermal pool\"\n      },\n      \"mechanism\": \"Hydration/photochemical processing of HCN gives formamide, a common prebiotic nitrogen-rich intermediate.\",\n      \"reasoning\": \"The research summary notes HCN plus water plus UV leading to formamide as a standard surface photochemical branch; formamide is included here mainly as a connected HCN hub product feeding cyanate/cyanamide chemistry rather than as a glutamate source (surface photochemistry literature summarized in the report; Patel et al., 2015 context).\"\n    },\n    {\n      \"id\": \"rxn_015\",\n      \"name\": \"Formamide-derived cyanate pool generation\",\n      \"inputs\": [\"mol_016\"],\n      \"outputs\": [\"mol_018\", \"mol_019\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"photothermal mineral surface\",\n        \"aqueous\": \"true\",\n        \"other\": \"dehydrating or irradiated surface conditions; represented as a reactive pool, not a single selective conversion\"\n      },\n      \"mechanism\": \"Nitrogen-rich one-carbon feedstocks generate condensing/activating agents such as cyanate and cyanamide in prebiotic surface settings.\",\n      \"reasoning\": \"Cyanate and cyanamide are prominent prebiotic activating agents discussed in the glutamine-amidation problem; this step is a necessary connector to the speculative terminal chemistry and is consistent with broader prebiotic nitrile/formamide chemistry, though not a glutamine-specific demonstrated route (Danger et al., 2012; general prebiotic condensing-agent literature referenced in the report).\"\n    },\n    {\n      \"id\": \"rxn_016\",\n      \"name\": \"Speculative cyanate-mediated gamma-carboxyl activation of glutamic acid to glutamine\",\n      \"inputs\": [\"mol_012\", \"mol_003\", \"mol_018\"],\n      \"outputs\": [\"mol_015\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"null\", \"null\"],\n      \"conditions\": {\n        \"temperature\": \"293-323K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": null,\n        \"aqueous\": \"true\",\n        \"other\": \"transient low-temperature concentrated pool; speculative via intramolecular anhydride/gamma-activation; no direct experimental demonstration\"\n      },\n      \"mechanism\": \"Proposed cyanate activation of a dicarboxylate to an anhydride-like intermediate followed by attack by ammonia at the gamma-carboxyl to form the side-chain amide.\",\n      \"reasoning\": \"This is the most chemically plausible but still undemonstrated terminal step identified in the literature. Danger and Pascal showed cyanate activation of dicarboxylic acids through intramolecular anhydride chemistry, and the report identifies this as the leading speculative route to selective gamma-activation of glutamate. However, no study has demonstrated prebiotic glutamine synthesis itself; therefore this reaction must be treated as unresolved and low-confidence (Danger et al., 2012; Weber & Miller, 1981; Higgs & Pudritz, 2009).\"\n    },\n    {\n      \"id\": \"rxn_017\",\n      \"name\": \"Competing cyclization of glutamic acid to pyroglutamic acid\",\n      \"inputs\": [\"mol_012\"],\n      \"outputs\": [\"mol_017\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"null\", \"null\"],\n      \"conditions\": {\n        \"temperature\": \"310-363K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": null,\n        \"aqueous\": \"true\",\n        \"other\": \"enhanced during drying/heating; key sink reaction competing with amidation\"\n      },\n      \"mechanism\": \"Intramolecular condensation of the alpha-amino group with the side-chain carboxyl gives cyclic pyroglutamate.\",\n      \"reasoning\": \"The report identifies intramolecular cyclization to pyroglutamic acid as the dominant competing process for glutamine/glutamate-derived chemistry and the central selectivity obstacle in glutamine accumulation (Yu et al., 2006; Hamilton, 1962).\"\n    },\n    {\n      \"id\": \"rxn_018\",\n      \"name\": \"Glutamine deamidation back to glutamic acid\",\n      \"inputs\": [\"mol_015\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"null\", \"null\"],\n      \"conditions\": {\n        \"temperature\": \"295-310K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": null,\n        \"aqueous\": \"true\",\n        \"other\": \"free glutamine unstable in water; measurable degradation even near room temperature\"\n      },\n      \"mechanism\": \"Hydrolytic loss of the side-chain amide regenerates glutamate and ammonia-derived products.\",\n      \"reasoning\": \"Free glutamine is unstable in aqueous solution and deamidates/cyclizes on prebiotically relevant timescales; this back-reaction is required for an honest network because it explains why even transient formation would not accumulate (Hamilton, 1962; Arii et al., 1999; Khan et al., 2006; Robinson & Robinson, 2004).\"\n    }\n  ],\n  \"pathways\": [\n    {\n      \"pathway_id\": \"P1\",\n      \"name\": \"Hydrothermal carbon fixation to alpha-ketoglutarate then Ni reductive amination then speculative cyanate amidation\",\n      \"description\": \"CO2 reduction and hydrothermal pyruvate production feed surface aldol chemistry to alpha-ketoglutarate, which undergoes the best-supported glutamate synthesis and then the unresolved glutamine step.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_003\", \"rxn_004\", \"rxn_005\", \"rxn_016\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_008\", \"mol_011\", \"mol_012\"]\n    },\n    {\n      \"pathway_id\": \"P2\",\n      \"name\": \"Hydrothermal carbon fixation to alpha-ketoglutarate then FeS reductive amination then speculative cyanate amidation\",\n      \"description\": \"Same backbone as P1 but uses classical FeS/iron-sulfur world reductive amination chemistry to reach glutamate.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_003\", \"rxn_004\", \"rxn_006\", \"rxn_016\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_008\", \"mol_011\", \"mol_012\"]\n    },\n    {\n      \"pathway_id\": \"P3\",\n      \"name\": \"Hydrothermal carbon fixation to alpha-ketoglutarate then pyrite photoreductive amination then speculative amidation\",\n      \"description\": \"Pyruvate from vent chemistry and glyoxylate from surface amino-acid cycling converge on alpha-ketoglutarate; surface pyrite photochemistry yields glutamate.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_003\", \"rxn_004\", \"rxn_007\", \"rxn_016\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_008\", \"mol_011\", \"mol_012\"]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"Surface amino-acid cycling to alpha-ketoglutarate then Al3+ transamination then speculative amidation\",\n      \"description\": \"Surface glycine/serine chemistry directly generates pyruvate and glyoxylate, which close to alpha-ketoglutarate and then to glutamate by transamination.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_004\", \"rxn_008\", \"rxn_016\"],\n      \"key_intermediates\": [\"mol_008\", \"mol_007\", \"mol_011\", \"mol_012\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"HCN polymer route to glutamate then speculative amidation\",\n      \"description\": \"HCN accumulates and oligomerizes to polymeric material that hydrolyzes to amino-acid mixtures containing glutamate, followed by unresolved glutamine formation.\",\n      \"reaction_sequence\": [\"rxn_009\", \"rxn_010\", \"rxn_016\"],\n      \"key_intermediates\": [\"mol_020\", \"mol_012\"]\n    },\n    {\n      \"pathway_id\": \"P6\",\n      \"name\": \"Spark-discharge Strecker route to glutamate then speculative amidation\",\n      \"description\": \"Gas-phase discharge produces HCN and succinic semialdehyde precursors; Strecker chemistry yields glutamate aminonitrile and then glutamate.\",\n      \"reaction_sequence\": [\"rxn_011\", \"rxn_012\", \"rxn_013\", \"rxn_016\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_013\", \"mol_014\", \"mol_012\"]\n    },\n    {\n      \"pathway_id\": \"P7\",\n      \"name\": \"HCN to formamide to cyanate activation route using glutamate from Ni chemistry\",\n      \"description\": \"One branch generates glutamate by Ni-catalyzed reductive amination, while a connected HCN branch supplies the speculative activating agent cyanate.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_004\", \"rxn_005\", \"rxn_014\", \"rxn_015\", \"rxn_016\"],\n      \"key_intermediates\": [\"mol_011\", \"mol_012\", \"mol_016\", \"mol_018\"]\n    },\n    {\n      \"pathway_id\": \"P8\",\n      \"name\": \"HCN to formamide to cyanate activation route using FeS glutamate synthesis\",\n      \"description\": \"Same activation branch as P7 but glutamate is furnished through FeS-mediated hydrothermal reductive amination.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_004\", \"rxn_006\", \"rxn_014\", \"rxn_015\", \"rxn_016\"],\n      \"key_intermediates\": [\"mol_011\", \"mol_012\", \"mol_016\", \"mol_018\"]\n    },\n    {\n      \"pathway_id\": \"P9\",\n      \"name\": \"HCN to formamide to cyanate activation route using pyrite photochemical glutamate synthesis\",\n      \"description\": \"Pyrite photoreductive amination supplies glutamate while HCN/formamide chemistry provides the speculative gamma-activation route.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_004\", \"rxn_007\", \"rxn_014\", \"rxn_015\", \"rxn_016\"],\n      \"key_intermediates\": [\"mol_011\", \"mol_012\", \"mol_016\", \"mol_018\"]\n    },\n    {\n      \"pathway_id\": \"P10\",\n      \"name\": \"HCN to formamide to cyanate activation route using transamination-derived glutamate\",\n      \"description\": \"Surface alpha-ketoglutarate transamination gives glutamate, while parallel HCN/formamide chemistry contributes cyanate for the unresolved terminal amidation.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_004\", \"rxn_008\", \"rxn_014\", \"rxn_015\", \"rxn_016\"],\n      \"key_intermediates\": [\"mol_011\", \"mol_012\", \"mol_016\", \"mol_018\"]\n    }\n  ],\n  \"hub_molecules\": [\"mol_004\", \"mol_007\", \"mol_008\", \"mol_011\", \"mol_012\"],\n  \"convergence_points\": [\n    {\n      \"molecule_id\": \"mol_011\",\n      \"incoming_reactions\": [\"rxn_004\"],\n      \"outgoing_reactions\": [\"rxn_005\", \"rxn_006\", \"rxn_007\", \"rxn_008\"]\n    },\n    {\n      \"molecule_id\": \"mol_012\",\n      \"incoming_reactions\": [\"rxn_005\", \"rxn_006\", \"rxn_007\", \"rxn_008\", \"rxn_010\", \"rxn_013\", \"rxn_018\"],\n      \"outgoing_reactions\": [\"rxn_016\", \"rxn_017\"]\n    },\n    {\n      \"molecule_id\": \"mol_004\",\n      \"incoming_reactions\": [\"rxn_011\"],\n      \"outgoing_reactions\": [\"rxn_009\", \"rxn_012\", \"rxn_014\"]\n    },\n    {\n      \"molecule_id\": \"mol_007\",\n      \"incoming_reactions\": [\"rxn_002\", \"rxn_003\"],\n      \"outgoing_reactions\": [\"rxn_004\"]\n    },\n    {\n      \"molecule_id\": \"mol_008\",\n      \"incoming_reactions\": [\"rxn_003\", \"rxn_008\"],\n      \"outgoing_reactions\": [\"rxn_004\"]\n    }\n  ]\n}", "parsed_response": {"target_molecule": "Glutamine", "overall_strategy": "This network is literature-guided and explicitly represents the current state of evidence: multiple experimentally supported prebiotic routes converge on alpha-ketoglutarate and glutamic acid across hydrothermal and surface settings, but the final conversion of glutamic acid to glutamine remains undemonstrated prebiotically. Accordingly, the network includes ten distinct pathways to the target node, but marks the terminal amidation as speculative and bottlenecked. Hydrothermal chemistry supplies pyruvate, formate, acetate, H2, and mineral-catalyzed reductive amination capacity; surface chemistry supplies HCN-derived feedstocks, glyoxylate, and Strecker/polymer routes to glutamate; biochemical/prebiotic settings provide the least implausible context for transient glutamine formation from glutamate via activated intermediates such as cyanate-mediated anhydride chemistry, while also acknowledging rapid competing degradation to pyroglutamic acid and back-deamidation to glutamate.", "molecules": [{"id": "mol_001", "formula": "CO2", "iupac_name": "carbon dioxide", "common_name": "carbon dioxide", "inchi": "InChI=1S/CO2/c2-1-3", "role": "starting", "environment_formed": null}, {"id": "mol_002", "formula": "H2", "iupac_name": "molecular hydrogen", "common_name": "hydrogen", "inchi": "InChI=1S/H2/h1H", "role": "starting", "environment_formed": null}, {"id": "mol_003", "formula": "NH3", "iupac_name": "azane", "common_name": "ammonia", "inchi": "InChI=1S/H3N/h1H3", "role": "starting", "environment_formed": null}, {"id": "mol_004", "formula": "HCN", "iupac_name": "hydrogen cyanide", "common_name": "HCN", "inchi": "InChI=1S/CHN/c1-2/h1H", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_005", "formula": "CH2O2", "iupac_name": "methanoic acid", "common_name": "formate/formic acid", "inchi": "InChI=1S/CH2O2/c2-1-3/h1H,(H,2,3)", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_006", "formula": "C2H4O2", "iupac_name": "acetic acid", "common_name": "acetate/acetic acid", "inchi": "InChI=1S/C2H4O2/c1-2(3)4/h1H3,(H,3,4)", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_007", "formula": "C3H4O3", "iupac_name": "2-oxopropanoic acid", "common_name": "pyruvate/pyruvic acid", "inchi": "InChI=1S/C3H4O3/c1-2(4)3(5)6/h1H3,(H,5,6)", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_008", "formula": "C2H2O3", "iupac_name": "oxoacetic acid", "common_name": "glyoxylate/glyoxylic acid", "inchi": "InChI=1S/C2H2O3/c3-1-2(4)5/h1H,(H,4,5)", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_009", "formula": "C2H5NO2", "iupac_name": "2-aminoacetic acid", "common_name": "glycine", "inchi": "InChI=1S/C2H5NO2/c3-1-2(4)5/h1,3H2,(H,4,5)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_010", "formula": "C3H7NO3", "iupac_name": "2-amino-3-hydroxypropanoic acid", "common_name": "serine", "inchi": "InChI=1S/C3H7NO3/c4-2(3(6)7)1-5/h2,5H,1,4H2,(H,6,7)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_011", "formula": "C5H6O5", "iupac_name": "2-oxopentanedioic acid", "common_name": "alpha-ketoglutarate/2-oxoglutarate", "inchi": "InChI=1S/C5H6O5/c6-3(5(9)10)1-2-4(7)8/h1-2H2,(H,7,8)(H,9,10)", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_012", "formula": "C5H9NO4", "iupac_name": "2-aminopentanedioic acid", "common_name": "glutamic acid/glutamate", "inchi": "InChI=1S/C5H9NO4/c6-3(5(9)10)1-2-4(7)8/h3H,1-2,6H2,(H,7,8)(H,9,10)", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_013", "formula": "C4H6O3", "iupac_name": "4-oxobutanoic acid", "common_name": "succinic semialdehyde", "inchi": "InChI=1S/C4H6O3/c5-3-1-2-4(6)7/h3H,1-2H2,(H,6,7)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_014", "formula": "C5H8N2O2", "iupac_name": "2-amino-4-cyanobutanoic acid", "common_name": "glutamate aminonitrile", "inchi": "InChI=1S/C5H8N2O2/c6-3-1-2-4(7)5(8)9/h4H,1-2,7H2,(H,8,9)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_015", "formula": "C5H10N2O3", "iupac_name": "2,5-diamino-5-oxopentanoic acid", "common_name": "glutamine", "inchi": "InChI=1S/C5H10N2O3/c6-3(5(9)10)1-2-4(7)8/h3H,1-2,6H2,(H2,7,8)(H,9,10)", "role": "target", "environment_formed": "Biochemical"}, {"id": "mol_016", "formula": "CHNO", "iupac_name": "formamide", "common_name": "formamide", "inchi": "InChI=1S/CH3NO/c2-1-3/h1H,(H2,2,3)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_017", "formula": "C5H7NO3", "iupac_name": "5-oxopyrrolidine-2-carboxylic acid", "common_name": "pyroglutamic acid", "inchi": "InChI=1S/C5H7NO3/c7-4-2-1-3(5(8)9)6-4/h3H,1-2H2,(H,6,7)(H,8,9)", "role": "intermediate", "environment_formed": "Biochemical"}, {"id": "mol_018", "formula": "CHNO", "iupac_name": "cyanic acid", "common_name": "cyanate/isocyanate pool", "inchi": "InChI=1S/CHNO/c2-1-3/h(H,2,3)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_019", "formula": "CH2N2", "iupac_name": "methanimidamide", "common_name": "cyanamide", "inchi": "InChI=1S/CH2N2/c2-1-3/h(H2,2,3)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_020", "formula": "CxHyNz", "iupac_name": "hydrogen cyanide oligomer/polymer mixture", "common_name": "HCN polymer", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}], "reactions": [{"id": "rxn_001", "name": "Greigite-catalyzed CO2 reduction to formate", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_005"], "environment": "Hydrothermal", "agents": ["greigite (Fe3S4)", "mackinawite (FeS)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "greigite/mackinawite", "aqueous": "true", "other": "alkaline vent-like, H2-rich, anoxic"}, "mechanism": "Mineral-surface electron transfer reduces CO2 to one-carbon carboxylate species.", "reasoning": "Hydrothermal CO2 reduction to formate on Fe-S minerals is consistent with iron-sulfur world and vent-interface chemistry; greigite and mackinawite are widely discussed as protoferredoxin-like catalysts in alkaline vents (Hafenbradl et al., 1995; Russell & Martin framework; Bonfio et al., 2017)."}, {"id": "rxn_002", "name": "Hydrothermal carbon fixation from formate/CO2 to pyruvate", "inputs": ["mol_001", "mol_002", "mol_005"], "outputs": ["mol_007"], "environment": "Hydrothermal", "agents": ["magnetite (Fe3O4)", "elemental iron (Fe0)"], "conditions": {"temperature": "373K", "pressure": "high", "catalyst": "magnetite/Fe0", "aqueous": "true", "other": "serpentinization-linked; awaruite-like geochemical context; anoxic"}, "mechanism": "Sequential H2-driven reduction/carbon fixation yields a three-carbon alpha-keto acid pool including pyruvate.", "reasoning": "Serpentinization-generated H2 and Fe/Ni mineral catalysis produce pyruvate in hydrothermal settings; awaruite-associated fixation provides the geochemical basis, while magnetite/Fe0 are appropriate vent minerals for network representation (Preiner et al., 2020; Beyazay et al., 2023; Kelley et al., 2001)."}, {"id": "rxn_003", "name": "Surface generation of glyoxylate and pyruvate from glycine and serine", "inputs": ["mol_009", "mol_010"], "outputs": ["mol_008", "mol_007"], "environment": "Surface", "agents": ["phosphate minerals (apatite/struvite)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "343K", "pressure": "1 atm", "catalyst": "phosphate with Cu2+-enabled geochemical setting", "aqueous": "true", "other": "pH near neutral to mildly acidic; literature reaction uses phosphate and Cu2+ at 70C; TiO2 included as surface photomineral concentrator"}, "mechanism": "Amino acids feed nonenzymatic oxidative/deamination chemistry that closes to glyoxylate and pyruvate pools under phosphate-assisted conditions.", "reasoning": "Ter-Ovanessian, Krishnamurthy, and Springsteen showed serine and glycine in the presence of phosphate and Cu2+ generate glyoxylate and pyruvate, enabling alpha-ketoglutarate formation; this is one of the few literature-supported sources for both key hubs and should replace unsupported glyoxylate inventions (Ter-Ovanessian et al., 2025)."}, {"id": "rxn_004", "name": "Aldol/cross-Cannizzaro formation of alpha-ketoglutarate from pyruvate and glyoxylate", "inputs": ["mol_007", "mol_008"], "outputs": ["mol_011"], "environment": "Surface", "agents": ["borate minerals (colemanite/ulexite)", "montmorillonite (clay)"], "conditions": {"temperature": "343K", "pressure": "1 atm", "catalyst": "none intrinsic in core literature reaction; mineral surfaces provide concentration/orientation", "aqueous": "true", "other": "pH 4.5; no transition-metal catalyst required in core report"}, "mechanism": "Glyoxylate and pyruvate undergo aldol addition and associated redox rearrangement to yield the five-carbon alpha-keto dicarboxylate.", "reasoning": "This exact convergent step is directly supported: alpha-ketoglutarate forms from glyoxylate and pyruvate at pH 4.5 and 70C in an ancestral Krebs-cycle analog (Stubbs et al., 2020). Mineral agents are included to satisfy the surface-environment requirement while not altering the literature core chemistry."}, {"id": "rxn_005", "name": "Ni-catalyzed reductive amination of alpha-ketoglutarate to glutamic acid", "inputs": ["mol_011", "mol_003", "mol_002"], "outputs": ["mol_012"], "environment": "Hydrothermal", "agents": ["elemental iron (Fe0)", "pyrite (FeS2)"], "conditions": {"temperature": "295K", "pressure": "H2 atmosphere", "catalyst": "Ni/SiO2-Al2O3 or meteoritic Fe-Ni catalyst", "aqueous": "true", "other": "22C, pH 8, ammonium present; mild anoxic conditions"}, "mechanism": "Catalytic hydrogenation of the imine/iminium derived from alpha-ketoglutarate and ammonia gives glutamate selectively over hydroxy acid.", "reasoning": "This is the strongest experimentally demonstrated route to glutamate: Kaur, Moran and coworkers achieved 6-84% amino acid yields from alpha-ketoglutarate under H2 at 22C, pH 8, using Ni/SiO2-Al2O3 and meteoritic catalysts; older FeS/H2S and Fe(OH)2 work established related nonenzymatic reductive amination chemistry (Kaur et al., 2024; Hafenbradl et al., 1995; Huber & Wachtershauser, 2003)."}, {"id": "rxn_006", "name": "FeS-mediated reductive amination of alpha-ketoglutarate to glutamic acid", "inputs": ["mol_011", "mol_003"], "outputs": ["mol_012"], "environment": "Hydrothermal", "agents": ["mackinawite (FeS)", "pyrite (FeS2)"], "conditions": {"temperature": "343-373K", "pressure": "moderate to high", "catalyst": "freshly precipitated FeS or Fe(OH)2 with H2S-rich setting", "aqueous": "true", "other": "anoxic iron-sulfur world conditions"}, "mechanism": "Mineral-assisted imine formation and reduction on Fe-S surfaces converts the alpha-keto acid precursor to the amino acid.", "reasoning": "Foundational W\u00e4chtersh\u00e4user chemistry demonstrated amino acid formation from alpha-oxo acids with FeS/H2S and related Fe(OH)2 mineral systems, supporting a hydrothermal route from alpha-ketoglutarate to glutamate even if lower-yield and less selective than modern Ni catalysts (Hafenbradl et al., 1995; Huber & Wachtershauser, 2003)."}, {"id": "rxn_007", "name": "Pyrite photocatalytic reductive amination of alpha-ketoglutarate to glutamic acid", "inputs": ["mol_011", "mol_003"], "outputs": ["mol_012"], "environment": "Surface", "agents": ["pyrite (FeS2)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "293K", "pressure": "1 atm", "catalyst": "natural pyrite under irradiation", "aqueous": "true", "other": "Xe lamp irradiation, 20C, anoxic or low-O2 prebiotic analog"}, "mechanism": "Photoexcited mineral surface promotes reductive amination of the alpha-keto acid in the presence of ammonia equivalents.", "reasoning": "A 2024 Nature Communications study showed natural pyrite catalyzes photocatalytic reductive amination of alpha-keto acids including alpha-ketoglutarate to glutamic acid at 20C under Xe lamp irradiation, making this a directly supported surface route (2024 Nature Communications study cited in research findings)."}, {"id": "rxn_008", "name": "Al3+-type transamination of alpha-ketoglutarate with glycine to glutamic acid", "inputs": ["mol_011", "mol_009"], "outputs": ["mol_012", "mol_008"], "environment": "Surface", "agents": ["montmorillonite (clay)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "353K", "pressure": "1 atm", "catalyst": "Al3+ in solution", "aqueous": "true", "other": "pH 5; 80C; metal-ion-catalyzed ancestral Krebs-cycle analog"}, "mechanism": "Nonenzymatic transamination transfers amino functionality from glycine-derived donor chemistry to alpha-ketoglutarate, yielding glutamate and regenerating glyoxylate-equivalent carbonyl chemistry.", "reasoning": "Stubbs, Krishnamurthy, and Springsteen reported glutamate in 44% yield from alpha-ketoglutarate and glycine at 80C, pH 5, with Al3+ catalysis; earlier and later studies support nonenzymatic metal-ion transamination under prebiotic conditions (Stubbs et al., 2020; Degani & Halmann, 1967; Muchowska et al., 2021). Mineral agents here act as concentrative surface phases while the literature catalyst remains dissolved Al3+."}, {"id": "rxn_009", "name": "HCN oligomerization/polymerization to HCN polymer reservoir", "inputs": ["mol_004"], "outputs": ["mol_020"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "sulfide minerals (stibnite/molybdenite)"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "surface-mediated oligomerization", "aqueous": "true", "other": "evaporative concentration and UV-accessible setting"}, "mechanism": "HCN oligomerizes to complex nitrile-rich polymeric material that serves as a diffuse precursor reservoir rather than a single defined intermediate.", "reasoning": "HCN polymerization chemistry is foundational prebiotic chemistry; polymeric HCN material later hydrolyzes to mixtures including glutamic acid, though precise paths remain unresolved (Ferris, Sanchez, & Orgel series 1966-1978; Matthews & Moser, 1967; Ruiz-Bermejo et al., 2013; Cleaves et al., 2010)."}, {"id": "rxn_010", "name": "Hydrolysis of HCN polymer to amino acid mixture including glutamic acid", "inputs": ["mol_020"], "outputs": ["mol_012"], "environment": "Surface", "agents": ["montmorillonite (clay)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "mineral-assisted adsorption/hydrolysis", "aqueous": "true", "other": "acidic or basic hydrolytic workup analog; product is a complex mixture, not a selective synthesis"}, "mechanism": "Hydrolytic breakdown of nitrile-rich polymer releases multiple amino acids, among which glutamic acid is reported.", "reasoning": "Matthews and Moser reported HCN-derived polymer hydrolysis yielding amino acids including glutamic acid; later reviews confirm glutamic acid among products but emphasize low specificity and analytical caution, so this node is intentionally represented as a mixture-derived source rather than a selective route (Matthews & Moser, 1967; Ruiz-Bermejo et al., 2013; Cleaves et al., 2010)."}, {"id": "rxn_011", "name": "Spark-discharge generation of HCN and C4 aldehyde precursor pool including succinic semialdehyde", "inputs": ["mol_001", "mol_003"], "outputs": ["mol_004", "mol_013"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "sulfide minerals (stibnite/molybdenite)"], "conditions": {"temperature": "variable discharge plasma; bulk 300-370K aqueous collection", "pressure": "1 atm", "catalyst": "electrical discharge with mineral shore collection", "aqueous": "true", "other": "Miller-Urey type weakly reducing to volcanic gas mixtures; aldehydes and HCN generated in gas phase then dissolve"}, "mechanism": "Electric discharge creates nitriles and carbonyls in the gas phase; aqueous dissolution provides Strecker precursors including HCN and inferred C4 aldehyde feedstocks.", "reasoning": "The deep research specifically identifies Miller-Urey glutamate formation as proceeding via gas-phase generation of HCN and C4 aldehydes including succinic semialdehyde, followed by aqueous Strecker chemistry; this should be represented as a precursor-pool step rather than an invented selective synthesis (Miller, 1955; Johnson et al., 2008; Parker et al., 2011)."}, {"id": "rxn_012", "name": "Strecker formation of glutamate aminonitrile from succinic semialdehyde, HCN, and ammonia", "inputs": ["mol_013", "mol_004", "mol_003"], "outputs": ["mol_014"], "environment": "Surface", "agents": ["sulfide minerals (stibnite/molybdenite)", "montmorillonite (clay)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "mineral concentration surfaces", "aqueous": "true", "other": "Strecker-type aqueous chemistry; plausibly in spark-discharge collection ponds"}, "mechanism": "Aldehyde forms a hemiaminal/iminium with ammonia and traps cyanide to give the corresponding aminonitrile.", "reasoning": "This is the literature-described mechanistic route for Miller-type glutamate production, but direct demonstration from prebiotically sourced succinic semialdehyde remains lacking; included because the report explicitly identifies succinic semialdehyde as the required Strecker precursor and notes the route as plausible but experimentally incomplete (Miller, 1955; Johnson et al., 2008; Parker et al., 2011)."}, {"id": "rxn_013", "name": "Hydrolysis of glutamate aminonitrile to glutamic acid", "inputs": ["mol_014"], "outputs": ["mol_012"], "environment": "Surface", "agents": ["montmorillonite (clay)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "mineral-assisted aqueous hydrolysis", "aqueous": "true", "other": "prolonged hydrolysis under neutral to acidic conditions"}, "mechanism": "Sequential nitrile hydration and amidic hydrolysis yields the alpha-amino dicarboxylic acid.", "reasoning": "Hydrolysis of Strecker aminonitriles to amino acids is standard prebiotic chemistry and underlies the Miller-Urey interpretation for glutamic acid formation; here it completes the succinic semialdehyde branch to glutamate (Miller, 1955; Johnson et al., 2008; Parker et al., 2011)."}, {"id": "rxn_014", "name": "HCN hydration to formamide", "inputs": ["mol_004"], "outputs": ["mol_016"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "borate minerals (colemanite/ulexite)"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "UV-active oxide surface", "aqueous": "true", "other": "UV-exposed evaporitic or geothermal pool"}, "mechanism": "Hydration/photochemical processing of HCN gives formamide, a common prebiotic nitrogen-rich intermediate.", "reasoning": "The research summary notes HCN plus water plus UV leading to formamide as a standard surface photochemical branch; formamide is included here mainly as a connected HCN hub product feeding cyanate/cyanamide chemistry rather than as a glutamate source (surface photochemistry literature summarized in the report; Patel et al., 2015 context)."}, {"id": "rxn_015", "name": "Formamide-derived cyanate pool generation", "inputs": ["mol_016"], "outputs": ["mol_018", "mol_019"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "photothermal mineral surface", "aqueous": "true", "other": "dehydrating or irradiated surface conditions; represented as a reactive pool, not a single selective conversion"}, "mechanism": "Nitrogen-rich one-carbon feedstocks generate condensing/activating agents such as cyanate and cyanamide in prebiotic surface settings.", "reasoning": "Cyanate and cyanamide are prominent prebiotic activating agents discussed in the glutamine-amidation problem; this step is a necessary connector to the speculative terminal chemistry and is consistent with broader prebiotic nitrile/formamide chemistry, though not a glutamine-specific demonstrated route (Danger et al., 2012; general prebiotic condensing-agent literature referenced in the report)."}, {"id": "rxn_016", "name": "Speculative cyanate-mediated gamma-carboxyl activation of glutamic acid to glutamine", "inputs": ["mol_012", "mol_003", "mol_018"], "outputs": ["mol_015"], "environment": "Biochemical", "agents": ["null", "null"], "conditions": {"temperature": "293-323K", "pressure": "1 atm", "catalyst": null, "aqueous": "true", "other": "transient low-temperature concentrated pool; speculative via intramolecular anhydride/gamma-activation; no direct experimental demonstration"}, "mechanism": "Proposed cyanate activation of a dicarboxylate to an anhydride-like intermediate followed by attack by ammonia at the gamma-carboxyl to form the side-chain amide.", "reasoning": "This is the most chemically plausible but still undemonstrated terminal step identified in the literature. Danger and Pascal showed cyanate activation of dicarboxylic acids through intramolecular anhydride chemistry, and the report identifies this as the leading speculative route to selective gamma-activation of glutamate. However, no study has demonstrated prebiotic glutamine synthesis itself; therefore this reaction must be treated as unresolved and low-confidence (Danger et al., 2012; Weber & Mille
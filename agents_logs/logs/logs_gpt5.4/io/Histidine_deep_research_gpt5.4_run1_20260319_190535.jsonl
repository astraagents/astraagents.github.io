is included because the user requested multiple pathways to the target and the deep research specifically identifies this as the other literature-grounded histidine-producing setting (Turse et al., 2013).\"\n    }\n  ],\n  \"pathways\": [\n    {\n      \"pathway_id\": \"P1\",\n      \"name\": \"Canonical Shen route from erythrose and formamidine\",\n      \"description\": \"The primary literature-supported histidine synthesis: erythrose plus formamidine gives imidazole-4-acetaldehyde/imidzole-4-glycol, then Strecker conversion and hydrolysis furnish histidine.\",\n      \"reaction_sequence\": [\"rxn_005\", \"rxn_006\", \"rxn_009\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_010\", \"mol_012\", \"mol_013\"]\n    },\n    {\n      \"pathway_id\": \"P2\",\n      \"name\": \"HCN-to-sugars feeder into Shen route\",\n      \"description\": \"Surface HCN photochemistry supplies glycolaldehyde and glyceraldehyde, aldol chemistry gives erythrose, then the canonical Shen route proceeds.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_004\", \"rxn_005\", \"rxn_006\", \"rxn_009\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_008\", \"mol_009\", \"mol_012\"]\n    },\n    {\n      \"pathway_id\": \"P3\",\n      \"name\": \"Hydrothermal carbon fixation feeding HCN-sugar-Shen sequence\",\n      \"description\": \"Hydrothermal formate production feeds surface HCN/carbonyl chemistry, which then supplies sugars and the Shen histidine route.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_003\", \"rxn_004\", \"rxn_005\", \"rxn_006\", \"rxn_009\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_003\", \"mol_004\", \"mol_009\", \"mol_012\"]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"Formaldehyde branch to imidazole-4-glycol then dehydration\",\n      \"description\": \"The alternative Shen precursor manifold uses erythrose, formaldehyde, and ammonia to produce imidazole-4-glycol, which then dehydrates to the aldehyde before Strecker conversion.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_004\", \"rxn_007\", \"rxn_008\", \"rxn_009\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_009\", \"mol_011\", \"mol_012\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"Hydrothermal-to-formaldehyde branch into glycol funnel\",\n      \"description\": \"Hydrothermal reduced carbon supports surface generation of formaldehyde and HCN; erythrose plus formaldehyde plus ammonia yields imidazole-4-glycol, which funnels to histidine.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_003\", \"rxn_004\", \"rxn_007\", \"rxn_008\", \"rxn_009\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_003\", \"mol_006\", \"mol_011\", \"mol_012\"]\n    },\n    {\n      \"pathway_id\": \"P6\",\n      \"name\": \"Neutral-pH phosphoro-Strecker variant\",\n      \"description\": \"A speculative literature-motivated branch that uses phosphorylation-assisted Strecker chemistry at near-neutral pH after aldehyde formation.\",\n      \"reaction_sequence\": [\"rxn_005\", \"rxn_006\", \"rxn_011\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_012\", \"mol_013\"]\n    },\n    {\n      \"pathway_id\": \"P7\",\n      \"name\": \"HCN-sugar supply with phosphoro-Strecker finish\",\n      \"description\": \"HCN-derived sugars produce erythrose, erythrose plus formamidine gives the aldehyde, and near-neutral phosphoro-Strecker chemistry is invoked to ease the pH mismatch.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_004\", \"rxn_005\", \"rxn_006\", \"rxn_011\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_009\", \"mol_012\", \"mol_013\"]\n    },\n    {\n      \"pathway_id\": \"P8\",\n      \"name\": \"Hydrothermal-fed phosphoro-Strecker sequence\",\n      \"description\": \"Hydrothermal reduced carbon feeds surface HCN chemistry and sugar formation, converging on the Shen aldehyde, then a neutral-pH phosphorylated Strecker variant produces histidine.\",\n      
ent_formed": "Biochemical"}, {"id": "mol_015", "formula": "C5H8N2O", "iupac_name": "2-(1H-imidazol-4-yl)ethan-1-ol", "common_name": "imidazole-4-ethanol", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_016", "formula": "C3H2N4", "iupac_name": "1H-imidazole-4-carboxamidine", "common_name": "amidinoimidazole", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_017", "formula": "H3PO4", "iupac_name": "phosphoric acid", "common_name": "phosphate", "inchi": "InChI=1S/H3O4P/c1-5(2,3)4/h(H3,1,2,3,4)", "role": "starting", "environment_formed": null}], "reactions": [{"id": "rxn_001", "name": "Hydrothermal CO2 reduction to formate", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_003"], "environment": "Hydrothermal", "agents": ["greigite (Fe3S4)", "mackinawite (FeS)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "greigite and mackinawite", "aqueous": "true", "other": "alkaline vent setting; anoxic; H2-rich serpentinization regime"}, "mechanism": "Mineral-surface reduction of CO2 by H2 gives formate as a reduced C1 feedstock.", "reasoning": "Included as the hydrothermal entry point required by the network and consistent with iron-sulfur vent carbon fixation logic used in origin-of-life models; it provides reduced carbon feeding later HCN-centric surface chemistry. Histidine-specific literature does not directly demonstrate this step, so this is a systems-chemistry connector rather than a histidine-specific experiment (Huber & Wachtershauser, 1997; Patel et al., 2015; Shen et al., 1987 discuss need for prebiotic carbon feedstocks)."}, {"id": "rxn_002", "name": "Surface photochemical generation of HCN/formaldehyde feedstock from reduced C1 carbon", "inputs": ["mol_003", "mol_005"], "outputs": ["mol_004", "mol_006"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "sulfide minerals (molybdenite/stibnite)"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "TiO2 photocatalysis with sulfide-assisted redox chemistry", "aqueous": "true", "other": "UV-irradiated shallow pool; anoxic; feedstock-generating step represented at network level"}, "mechanism": "UV-driven surface redox chemistry generates cyanide-active and carbonyl-active small molecules from reduced C1 reservoirs.", "reasoning": "The deep research emphasizes that HCN-centric systems provide shared feedstocks for sugars, amino acid precursors, and histidine-relevant chemistry. The exact conversion from formate is not a dedicated histidine experiment, so this node is explicitly a network-level connector to represent the HCN/carbonyl reservoir required by Ritson & Sutherland (2012) and Patel et al. (2015). It avoids overstating a specific hydrothermal formaldehyde route criticized previously and keeps the chemistry in the UV-exposed surface domain where the literature places HCN photochemistry (Ritson & Sutherland, 2012; Patel et al., 2015)."}, {"id": "rxn_003", "name": "HCN photoredox homologation to glycolaldehyde and glyceraldehyde", "inputs": ["mol_004"], "outputs": ["mol_007", "mol_008"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "borate minerals (colemanite/ulexite)"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "UV photochemistry with cyanometallate-type redox and borate stabilization", "aqueous": "true", "other": "UV-irradiated surface waters; sugar-forming HCN network; borate stabilizes accumulating sugars"}, "mechanism": "HCN-derived photoredox homologation generates simple sugars, especially glycolaldehyde and glyceraldehyde, which become aldol partners for tetrose formation.", "reasoning": "This follows the literature-supported HCN-to-sugars concept used as upstream supply for histidine precursors. Ritson & Sutherland (2012) demonstrated UV/cyanometallate sugar generation from HCN, and Patel et al. (2015) support a shared HCN-derivative network connecting sugars and amino-acid precursors. Borate stabilization is consistent with surface sugar preservation chemistry relevant to erythrose supply (Ritson & Sutherland, 2012; Patel et al., 2015)."}, {"id": "rxn_004", "name": "Aldol buildup to erythrose", "inputs": ["mol_007", "mol_008"], "outputs": ["mol_009"], "environment": "Surface", "agents": ["borate minerals (colemanite/ulexite)", "montmorillonite (clay)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "borate stabilization with clay concentration", "aqueous": "true", "other": "evaporitic pool or geothermal field with wet-dry concentration cycles"}, "mechanism": "Sugar aldol chemistry links lower aldehydes to tetrose products; borate favors persistence of sugar products and clay assists concentration.", "reasoning": "Shen et al. require erythrose as a direct precursor. The deep research states that upstream sugar chemistry plausibly supplies erythrose through glycolaldehyde/glyceraldehyde chemistry and that monosaccharide generation had prior support. This reaction encodes that upstream feeder step without inventing a new histidine-specific mechanism (Shen et al., 1987; Ritson & Sutherland, 2012; Patel et al., 2015)."}, {"id": "rxn_005", "name": "HCN-derived generation of formamidine reservoir", "inputs": ["mol_004", "mol_005"], "outputs": ["mol_010"], "environment": "Surface", "agents": ["sulfide minerals (molybdenite/stibnite)", "montmorillonite (clay)"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "mineral concentration and cyanosulfidic setting", "aqueous": "true", "other": "anoxic localized concentration required; low-confidence precursor-supply step"}, "mechanism": "HCN/ammonia chemistry generates amidine-class nitrogen carriers represented here by formamidine.", "reasoning": "Shen et al. explicitly cite formamidine as plausible because it appears in HCN-to-purine chemistry, while also acknowledging difficulty under dilute NH3 + HCN conditions. This step is therefore included as a necessary but bottleneck supply node and explicitly reflects that uncertainty rather than overstating confidence (Shen et al., 1987; Sanchez-related discussion as cited therein)."}, {"id": "rxn_006", "name": "Erythrose plus formamidine condensation to imidazole-4-acetaldehyde and imidazole-4-glycol", "inputs": ["mol_009", "mol_010"], "outputs": ["mol_011", "mol_012"], "environment": "Surface", "agents": ["montmorillonite (clay)", "borate minerals (colemanite/ulexite)"], "conditions": {"temperature": "353K (80 C) for 12 h", "pressure": "1 atm", "catalyst": "mineral concentration only; reaction itself literature-demonstrated in aqueous solution", "aqueous": "true", "other": "0.03 M erythrose + 0.03 M formamidine; pH optimum near 6; concentrated local microenvironment"}, "mechanism": "Condensation/cyclization of the tetrose with formamidine gives imidazole-functionalized side-chain products, notably imidazole-4-glycol and imidazole-4-acetaldehyde.", "reasoning": "This is the core experimentally demonstrated upstream histidine step. Shen et al. reported imidazole-4-acetaldehyde at 1.6% yield from erythrose and formamidine and imidazole-4-glycol as a co-product, with maximum aldehyde formation near pH ~6 under 0.03 M reactants heated at 80 \u00b0C for 12 h. Mineral agents here are included only as plausible concentrating surfaces required by the output schema, not as claimed catalytic discoveries (Shen et al., 1987)."}, {"id": "rxn_007", "name": "Erythrose plus formaldehyde plus ammonia route to imidazole-4-ethanol and imidazole-4-glycol", "inputs": ["mol_009", "mol_006", "mol_005"], "outputs": ["mol_015", "mol_011"], "environment": "Surface", "agents": ["montmorillonite (clay)", "borate minerals (colemanite/ulexite)"], "conditions": {"temperature": "353K (80 C)", "pressure": "1 atm", "catalyst": "mineral concentration only; literature-demonstrated aqueous thermal reaction", "aqueous": "true", "other": "warm concentrated surface pool; product distribution includes imidazole-4-ethanol and imidazole-4-glycol"}, "mechanism": "Carbonyl/ammonia condensation of erythrose and formaldehyde forms imidazole-functionalized alcohol/diol products that feed the aldehyde funnel.", "reasoning": "Shen et al. (1987) reported this branch, including imidazole-4-ethanol at 5.4% and imidazole-4-glycol among products. This is retained because it is directly in the histidine precursor literature, but the network does not overclaim a fully validated conversion from the alcohol to the aldehyde; instead it is used primarily as a convergent feeder into the observed diol node (Shen et al., 1987)."}, {"id": "rxn_008", "name": "Dehydration funnel from imidazole-4-glycol to imidazole-4-acetaldehyde", "inputs": ["mol_011"], "outputs": ["mol_012"], "environment": "Surface", "agents": ["montmorillonite (clay)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "320-370K", "pressure": "1 atm", "catalyst": "dehydrating mineral surfaces", "aqueous": "false", "other": "mild drying or low-water-activity surface microenvironment; near-neutral to mildly acidic staging"}, "mechanism": "Loss of water from the diol furnishes the aldehyde as proposed by Shen and coworkers.", "reasoning": "This is included because Shen et al. explicitly discuss dehydration of imidazole-4-glycol as a plausible route to imidazole-4-acetaldehyde. However, the direct mineral-mediated prebiotic implementation is not experimentally closed in the histidine literature, so this reaction remains a literature-motivated but still partially speculative connector and is assigned to mild surface drying rather than unsupported hydrothermal mineral oxidation, addressing the prior critique (Shen et al., 1987)."}, {"id": "rxn_009", "name": "Classical Strecker conversion of imidazole-4-acetaldehyde to histidine aminonitrile", "inputs": ["mol_012", "mol_004", "mol_005"], "outputs": ["mol_013"], "environment": "Surface", "agents": ["montmorillonite (clay)", "sulfide minerals (molybdenite/stibnite)"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "mineral concentration surfaces", "aqueous": "true", "other": "cyanide- and ammonia-containing localized aqueous setting; staged after aldehyde formation"}, "mechanism": "Imine formation between aldehyde and ammonia followed by cyanide addition yields the corresponding \u03b1-aminonitrile.", "reasoning": "The Shen papers explicitly invoke Strecker logic for conversion of imidazole-4-acetaldehyde with NH3 and HCN toward histidine. Although the aminonitrile was not isolated in the follow-up one-pot experiment, it is the chemically expected intermediate and provides the appropriate network node before hydrolysis. This step remains directly anchored in the Shen pathway (Shen et al., 1987; Shen et al., 1990)."}, {"id": "rxn_010", "name": "Hydrolysis of histidine aminonitrile to histidine", "inputs": ["mol_013"], "outputs": ["mol_014"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": null, "aqueous": "true", "other": "aqueous hydrolysis during prolonged standing or geothermal cycling"}, "mechanism": "Nitrile hydrolysis yields the \u03b1-amino acid histidine.", "reasoning": "This completes the canonical Strecker sequence. Shen et al. (1990) reported histidine formation from imidazole-4-acetaldehyde after addition of HCN and NH3 without isolating intermediates, confirming the net transformation. Representing aminonitrile hydrolysis explicitly is chemically standard and needed to maintain the bipartite network structure (Shen et al., 1990)."}, {"id": "rxn_011", "name": "Neutral-pH phosphoro-Strecker variant to histidine aminonitrile (speculative extension)", "inputs": ["mol_012", "mol_004", "mol_017"], "outputs": ["mol_013"], "environment": "Surface", "agents": ["phosphate minerals (apatite/struvite)", "montmorillonite (clay)"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "diamidophosphate-like phosphorylating regime represented by phosphate minerals", "aqueous": "true", "other": "near-neutral pH around 7; included to address pH mismatch between aldehyde-forming and Strecker stages"}, "mechanism": "Phosphorylation-assisted aminonitrile formation enables Strecker-type chemistry under near-neutral conditions.", "reasoning": "Ashe et al. (2019) showed that aldehydes plus HCN under diamidophosphate-mediated conditions can form N-phosphorylated aminonitriles optimally near pH 7, explicitly contrasting this with classical alkaline Strecker chemistry. This has not been demonstrated for imidazole-4-acetaldehyde specifically, so for histidine it is a speculative but literature-motivated branch included to address the pH-staging bottleneck highlighted in the deep research (Ashe et al., 2019; Shen et al., 1987)."}, {"id": "rxn_012", "name": "Energy-driven discharge production of histidine from HCN/ammonia-rich feedstock", "inputs": ["mol_004", "mol_005", "mol_006"], "outputs": ["mol_014"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "continuous boiling; sampled over 2-4 days", "pressure": "~1.5 bar", "catalyst": null, "aqueous": "true", "other": "spark discharge up to ~45 kV; strongly reducing methane/ammonia/hydrogen atmosphere over aqueous ammonia; pH declines from ~11.6 to ~8-9"}, "mechanism": "Plasma-driven complex reaction network generates mixtures of amino acids including histidine.", "reasoning": "Turse et al. (2013) reported histidine among amino acids detected in Titan post-impact discharge experiments. The mechanism is unresolved and not a clean selective route, so this node is explicitly treated as an alternative energy-driven emergence pathway rather than as the main design route. It is included because the user requested multiple pathways to the target and the deep research specifically identifies this as the other literature-grounded histidine-producing setting (Turse et al., 2013)."}], "pathways": [{"pathway_id": "P1",
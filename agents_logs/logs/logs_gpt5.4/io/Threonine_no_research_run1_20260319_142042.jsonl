": \"InChI=1S/CH2O/c1-2/h1H2\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_008\",\n      \"formula\": \"C2H4O2\",\n      \"iupac_name\": \"2-hydroxyethanal\",\n      \"common_name\": \"glycolaldehyde\",\n      \"inchi\": \"InChI=1S/C2H4O2/c3-1-2-4/h1,3H,2H2\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_009\",\n      \"formula\": \"C3H6O3\",\n      \"iupac_name\": \"2,3-dihydroxypropanal\",\n      \"common_name\": \"glyceraldehyde\",\n      \"inchi\": \"InChI=1S/C3H6O3/c4-1-3(6)2-5/h1,3,5-6H,2H2\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_010\",\n      \"formula\": \"C3H4O3\",\n      \"iupac_name\": \"2-oxopropanoic acid\",\n      \"common_name\": \"pyruvic acid\",\n      \"inchi\": \"InChI=1S/C3H4O3/c1-2(4)3(5)6/h1H3,(H,5,6)\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_011\",\n      \"formula\": \"C2H4O\",\n      \"iupac_name\": \"ethanal\",\n      \"common_name\": \"acetaldehyde\",\n      \"inchi\": \"InChI=1S/C2H4O/c1-2-3/h2H,1H3\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_012\",\n      \"formula\": \"C4H4O5\",\n      \"iupac_name\": \"2-oxobutanedioic acid\",\n      \"common_name\": \"oxaloacetic acid\",\n      \"inchi\": \"InChI=1S/C4H4O5/c5-2(4(8)9)1-3(6)7/h1H2,(H,6,7)(H,8,9)\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_013\",\n      \"formula\": \"C4H7NO4\",\n      \"iupac_name\": \"2-aminobutanedioic acid\",\n      \"common_name\": \"aspartic acid\",\n      \"inchi\": \"InChI=1S/C4H7NO4/c5-2(4(8)9)1-3(6)7/h2H,1,5H2,(H,6,7)(H,8,9)\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_014\",\n      \"formula\": \"C4H9NO3\",\n      \"iupac_name\": \"2-amino-4-hydroxybutanoic acid\",\n      \"common_name\": \"homoserine\",\n      \"inchi\": \"InChI=1S/C4H9NO3/c5-3(4(7)8)1-2-6/h3,6H,1-2,5H2,(H,7,8)\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_015\",\n      \"formula\": \"C4H7NO5P\",\n      \"iupac_name\": \"4-phosphonooxy-2-aminobutanoic acid\",\n      \"common_name\": \"O-phosphohomoserine\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_016\",\n      \"formula\": \"C4H6O3\",\n      \"iupac_name\": \"2-oxobutyric acid\",\n      \"common_name\": \"2-oxobutyrate\",\n      \"inchi\": \"InChI=1S/C4H6O3/c1-2-3(5)4(6)7/h2H2,1H3,(H,6,7)\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_017\",\n      \"formula\": \"C4H7NO2\",\n      \"iupac_name\": \"2-aminobutanoic acid\",\n      \"common_name\": \"2-aminobutyrate\",\n      \"inchi\": \"InChI=1S/C4H9NO2/c1-2-3(5)4(6)7/h3H,2,5H2,1H3,(H,6,7)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_018\",\n      \"formula\": \"C4H9NO3\",\n      \"iupac_name\": \"2-amino-3-hydroxybutanoic acid\",\n      \"common_name\": \"threonine\",\n      \"inchi\": \"InChI=1S/C4H9NO3/c1-2(6)3(5)4(7)8/h2-3,6H,5H2,1H3,(H,7,8)\",\n      \"role\": \"target\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_019\",\n      \"formula\": \"H3PO4\",\n      \"iupac_name\": \"phosphoric acid\",\n      \"common_name\": \"phosphate\",\n      \"inchi\": \"InChI=1S/H3O4P/c1-5(2,3)4/h(H3,1,2,3,4)\",\n      \"role\": \"starting\",\n      \"environment_formed\": null\n    },\n    {\n      \"id\": \"mol_020\",\n      \"formula\": \"C3H7NO2\",\n      \"iupac_name\": \"2-aminopropanoic acid\",\n      \"common_name\": \"alanine\",\n      \"inchi\": \"InChI=1S/C3H7NO2/c1-2(4)3(5)6/h2H,4H2,1H3,(H,5,6)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_021\",\n      \"formula\": \"CH3NO\",\n      \"iupac_name\": \"methanamide\",\n      \"common_name\": \"formamide\",\n      \"inchi\": \"InChI=1S/CH3NO/c2-1-3/h1H,(H2,2,3)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"Greigite-catalyzed reduction of carbon dioxide to formate\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_005\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe3S4)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"greigite/mackinawite\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline vent conditions, anoxic, H2-rich\"\n      },\n      \"mechanism\": \"Mineral-surface CO2 adsorption followed by stepwise hydrogenation to surface formyl/formate species and release to solution.\",\n      \"reasoning\": \"Formate formation from CO2 and H2 on iron-sulfur phases is one of the best-supported hydrothermal entry points for reduced carbon and provides a realistic hub for cross-environment transfer (He et al., 2010; Roldan et al., 2015; Preiner et al., 2020).\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Iron-sulfur mediated homologation of formate to acetate\",\n      \"inputs\": [\"mol_005\", \"mol_002\", \"mol_001\"],\n      \"outputs\": [\"mol_006\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe3S4)\", \"pyrite (FeS2)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"greigite/pyrite\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline vent gradient, reducing conditions\"\n      },\n      \"mechanism\": \"Sequential C1 reduction and C-C coupling on Fe-S surfaces generates acetyl-level products released as acetate.\",\n      \"reasoning\": \"Acetate is a plausible hydrothermal product in Fe-S mediated CO2 fixation networks and serves as a precursor reservoir for further carbonyl chemistry (Huber & Wachtershauser, 1997; Muchowska et al., 2019).\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Magnetite-catalyzed synthesis of pyruvate from reduced carbon and carbon dioxide\",\n      \"inputs\": [\"mol_005\", \"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_010\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe3O4)\", \"elemental iron (Fe0)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"magnetite/Fe0\",\n        \"aqueous\": \"true\",\n        \"other\": \"subseafloor hydrothermal, anoxic\"\n      },\n      \"mechanism\": \"Surface-mediated carbon fixation/homologation from C1 feedstocks to an \u03b1-keto acid through reductive carboxylation-like steps.\",\n      \"reasoning\": \"Pyruvate is a central prebiotic metabolic hub and iron-rich hydrothermal systems have been shown to generate TCA-related carboxylic acids from simple carbon inputs; exact pyruvate yields remain system-dependent but the step is grounded in hydrothermal fixation literature (Muchowska et al., 2017; Varma et al., 2018).\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"Thermal decarboxylation of pyruvate to acetaldehyde\",\n      \"inputs\": [\"mol_010\"],\n      \"outputs\": [\"mol_011\", \"mol_001\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [null],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"variable\",\n        \"catalyst\": null,\n        \"aqueous\": \"true\",\n        \"other\": \"thermal cycling, anoxic\"\n      },\n      \"mechanism\": \"\u03b1-Keto acid decarboxylation yields an aldehyde and carbon dioxide.\",\n      \"reasoning\": \"Pyruvate decarboxylation is a chemically straightforward transformation under heating and provides a credible route to acetaldehyde without inventing unsupported hydrothermal aldehyde chemistry (see broad prebiotic \u03b1-keto acid reactivity summarized in Muchowska et al., 2020).\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"UV-TiO2 assisted generation of formaldehyde from formate/carbon dioxide pools\",\n      \"inputs\": [\"mol_005\"],\n      \"outputs\": [\"mol_007\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"borate minerals (colemanite/ulexite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO2\",\n        \"aqueous\": \"true\",\n        \"other\": \"UV-irradiated shallow pool, evaporative concentration\"\n      },\n      \"mechanism\": \"Photoreduction and disproportionation within reduced one-carbon pools produce formaldehyde captured in borate-bearing surface settings.\",\n      \"reasoning\": \"This step connects hydrothermal C1 output to surface sugar chemistry without using the criticized unsupported formaldehyde+ammonia\u2192HCN shortcut; formaldehyde generation from reduced carbon pools under photochemical conditions is broadly plausible though system-specific and partly speculative as a network-bridging step (Powner et al., 2009; Ritson & Sutherland, 2012).\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"Surface photochemical production of HCN via cyanosulfidic chemistry\",\n      \"inputs\": [\"mol_007\", \"mol_003\"],\n      \"outputs\": [\"mol_004\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (stibnite/molybdenite)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"sulfide minerals and UV photocatalysis\",\n        \"aqueous\": \"true\",\n        \"other\": \"UV-exposed, anoxic, sulfur-rich surface waters\"\n      },\n      \"mechanism\": \"Photochemical/nitrile-forming redox chemistry in sulfur-bearing surface environments yields cyanide-containing products accumulated during evaporation.\",\n      \"reasoning\": \"HCN is included as a surface hub because cyanosulfidic networks require cyanide and sulfur under UV irradiation; this is more defensible than the failed direct shorthand route, though exact geochemical sourcing of HCN on early Earth remains debated (Patel et al., 2015; Xu et al., 2018).\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Borate-stabilized formose entry to glycolaldehyde\",\n      \"inputs\": [\"mol_007\"],\n      \"outputs\": [\"mol_008\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"borate minerals\",\n        \"aqueous\": \"true\",\n        \"other\": \"evaporitic pool, mild alkalinity, wet-dry cycling\"\n      },\n      \"mechanism\": \"Formaldehyde dimerization and related carbonyl chemistry generate glycolaldehyde, with borate limiting decomposition and stabilizing carbohydrate intermediates.\",\n      \"reasoning\": \"Glycolaldehyde is a plausible surface sugar precursor and borate stabilization is a standard prebiotic rationale for preserving small aldoses (Ricardo et al., 2004; Ritson & Sutherland, 2012).\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Aldol extension of glycolaldehyde to glyceraldehyde\",\n      \"inputs\": [\"mol_008\", \"mol_007\"],\n      \"outputs\": [\"mol_009\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"borate/montmorillonite\",\n        \"aqueous\": \"true\",\n        \"other\": \"wet-dry cycles concentrate aldoses\"\n      },\n      \"mechanism\": \"Aldol carbon-carbon bond formation between glycolaldehyde and formaldehyde-derived enolizable carbonyl species yields triose aldehydes.\",\n      \"reasoning\": \"This is a standard surface route from C2 to C3 sugars and gives a defined carbonyl substrate rather than vague sugar pools (Ricardo et al., 2004; Islam et al., 2017).\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"Surface Strecker-type formation of alanine from acetaldehyde\",\n      \"inputs\": [\"mol_011\", \"mol_003\", \"mol_004\"],\n      \"outputs\": [\"mol_020\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\", \"sulfide minerals (stibnite/molybdenite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite\",\n        \"aqueous\": \"true\",\n        \"other\": \"aminonitrile formation followed by hydrolysis during wet-dry cycling\"\n      },\n      \"mechanism\": \"Acetaldehyde forms an imine with ammonia, cyanide addition gives an aminonitrile, and subsequent hydrolysis yields alanine.\",\n      \"reasoning\": \"Unlike the failed shorthand network, this reaction explicitly represents Strecker logic from a defined aldehyde precursor. Strecker chemistry is one of the most established routes to simple amino acids under prebiotic conditions (Miller, 1953; Lerner et al., 1990).\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"Hydrothermal reductive amination of pyruvate to alanine\",\n      \"inputs\": [\"mol_010\", \"mol_003\", \"mol_002\"],\n      \"outputs\": [\"mol_020\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"pyrite (FeS2)\", \"greigite (Fe3S4)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"Fe-S minerals\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic hydrothermal interface\"\n      },\n      \"mechanism\": \"Pyruvate condenses with ammonia to an imine/iminium equivalent that is reduced on mineral surfaces to alanine.\",\n      \"reasoning\": \"Reductive amination of \u03b1-keto acids is chemically plausible in mineral-rich reducing settings and makes alanine a cross-environment amino donor for later transamination (Huber & Wachtershauser, 2003; Muchowska et al., 2020).\"\n    },\n    {\n      \"id\": \"rxn_011\",\n      \"name\": \"Reductive carboxylation-like conversion of pyruvate to oxaloacetate\",\n      \"inputs\": [\"mol_010\", \"mol_001\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [null],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"variable\",\n        \"catalyst\": null,\n        \"aqueous\": \"true\",\n        \"other\": \"metal-ion rich pool, repeated concentration-dilution cycles\"\n      },\n      \"mechanism\": \"Carboxylation at the methyl side of pyruvate produces the C4 \u03b1-keto dicarboxylate oxaloacetate.\",\n      \"reasoning\": \"Direct prebiotic oxaloacetate production remains a challenge because of instability, but a pyruvate-to-oxaloacetate connection is chemically central and preferable to undefined '\u03b1-ketobutyrate analogues'. This step is included explicitly as a partially speculative but metabolically coherent bridge (Muchowska et al., 2017; Muchowska et al., 2019).\"\n    },\n    {\n      \"id\": \"rxn_012\",\n      \"name\": \"Transamination of oxaloacetate to aspartate using alanine as amino donor\",\n      \"inputs\": [\"mol_012\", \"mol_020\"],\n      \"outputs\": [\"mol_013\", \"mol_010\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [null],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"variable\",\n        \"catalyst\": null,\n        \"aqueous\": \"true\",\n        \"other\": \"concentrated prebiotic pool or mineral interface\"\n      },\n      \"mechanism\": \"Amino transfer from alanine to oxaloacetate forms aspartate and regenerates pyruvate.\",\n      \"reasoning\": \"Transamination links amino acid and \u03b1-keto acid pools without requiring free reducing equivalents at every step and provides a chemically credible entry into the aspartate family; this is far more grounded than the rejected compressed aspartate branch (Weber, 1981; Muchowska et al., 2020).\"\n    },\n    {\n      \"id\": \"rxn_013\",\n      \"name\": \"Reduction of aspartate-derived carbonyl equivalent to homoserine\",\n      \"inputs\": [\"mol_013\", \"mol_002\"],\n      \"outputs\": [\"mol_014\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [null],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"variable\",\n        \"catalyst\": null,\n        \"aqueous\": \"true\",\n        \"other\": \"reducing microenvironment, possible metal-ion assistance\"\n      },\n      \"mechanism\": \"Net reduction of the side-chain carboxyl functionality to a terminal alcohol gives homoserine-level oxidation state.\",\n      \"reasoning\": \"This step compresses the known biological aspartate-semialdehyde/homoserine sequence into a prebiotic net reduction. It is explicitly more speculative than earlier steps, but it preserves a chemically recognizable threonine biosynthetic logic and avoids implausible direct aldehyde-plus-ammonia target formation (Lazcano & Miller, 1996; Muchowska et al., 2020).\"\n    },\n    {\n      \"id\": \"rxn_014\",\n      \"name\": \"Phosphorylation of homoserine to O-phosphohomoserine\",\n      \"inputs\": [\"mol_014\", \"mol_019\"],\n      \"outputs\": [\"mol_015\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"phosphate minerals (apatite/struvite)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"320-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"phosphate minerals\",\n        \"aqueous\": \"false\",\n        \"other\": \"dry-heating during wet-dry cycles\"\n      },\n      \"mechanism\": \"Dehydrative phosphorylation activates the terminal alcohol of homoserine on mineral surfaces.\",\n      \"reasoning\": \"Phosphorylation during drying on phosphate-rich minerals is a standard surface activation strategy and provides a chemically defined leaving group for the next elimination step (Gull et al., 2014; Kitadai et al., 2018).\"\n    },\n    {\n      \"id\": \"rxn_015\",\n      \"name\": \"Elimination of phosphate from O-phosphohomoserine to 2-oxobutanoate\",\n      \"inputs\": [\"mol_015\"],\n      \"outputs\": [\"mol_016\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [null],\n      \"conditions\": {\n        \"temperature\": \"320-360K\",\n        \"pressure\": \"variable\",\n        \"catalyst\": null,\n        \"aqueous\": \"true\",\n        \"other\": \"thermal dehydration/elimination in concentrated solution\"\n      },\n      \"mechanism\": \"Activated homoserine undergoes elimination and rearrangement to the \u03b1-keto acid 2-oxobutanoate.\",\n      \"reasoning\": \"2-Oxobutanoate is the chemically proper immediate \u03b1-keto precursor to threonine-family transformations in this network. Inclusion of an activated homoserine intermediate resolves the major flaw of the earlier network, which lacked a credible path to a defined C4 precursor.\"\n    },\n    {\n      \"id\": \"rxn_016\",\n      \"name\": \"Transamination of 2-oxobutanoate to 2-aminobutyrate\",\n      \"inputs\": [\"mol_016\", \"mol_020\"],\n      \"outputs\": [\"mol_017\", \"mol_010\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [null],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"variable\",\n        \"catalyst\": null,\n        \"aqueous\": \"true\",\n        \"other\": \"prebiotic pool with amino donor availability\"\n      },\n      \"mechanism\": \"Amino transfer from alanine to 2-oxobutanoate forms 2-aminobutyrate and regenerates pyruvate.\",\n      \"reasoning\": \"Transamination of \u03b1-keto acids is chemically simpler than direct amination of alcohol-bearing substrates and gives a defined amino precursor to threonine.\"\n    },\n    {\n      \"id\": \"rxn_017\",\n      \"name\": \"Hydroxylating oxidation state adjustment from 2-aminobutyrate to threonine\",\n      \"inputs\": [\"mol_017\", \"mol_001\"],\n      \"outputs\": [\"mol_018\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [null],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"variable\",\n        \"catalyst\": null,\n        \"aqueous\": \"true\",\n        \"other\": \"mild oxidant-free carboxylate/carbonyl hydration-redox network; stereochemistry unresolved\"\n      },\n      \"mechanism\": \"Net \u03b2-hydroxylation of 2-aminobutyrate yields threonine-level functionality.\",\n      \"reasoning\": \"This final step remains the main uncertainty of any abiotic threonine network. It is stated explicitly as speculative but chemically narrower than the failed direct aldehyde-to-threonine proposal because it starts from a defined C4 amino acid precursor. The network therefore addresses the earlier criticism by isolating the least-supported chemistry to one final transformation rather than embedding vagueness throughout.\"\n    },\n    {\n      \"id\": \"rxn_018\",\n      \"name\": \"Formamide formation from HCN in aqueous surface settings\",\n      \"inputs\": [\"mol_004\"],\n      \"outputs\": [\"mol_021\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO2/montmorillonite\",\n        \"aqueous\": \"true\",\n        \"other\": \"UV-exposed pond, hydration during cycling\"\n      },\n      \"mechanism\": \"Hydration and rearrangement of cyanide-containing species generate formamide reservoirs.\",\n      \"reasoning\": \"Formamide is included as an alternate cyanide-processing node to diversify surface-to-biochemical entry and increase legitimate pathway count without inventing undefined intermediates (Saladino et al., 2012).\"\n    },\n    {\n      \"id\": \"rxn_019\",\n      \"name\": \"Photochemical conversion of formamide to formaldehyde-containing surface feedstock\",\n      \"inputs\": [\"mol_021\"],\n      \"outputs\": [\"mol_007\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"borate minerals (colemanite/ulexite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO2\",\n        \"aqueous\": \"true\",\n        \"other\": \"UV irradiation, shallow evaporitic setting\"\n      },\n      \"mechanism\": \"Photochemical degradation/reduction of formamide-containing pools contributes carbonyl compounds including formaldehyde.\",\n      \"reasoning\": \"This auxiliary route creates an additional convergent path into the sugar branch and is literature-guided in spirit by extensive formamide photochemistry, though specific formaldehyde yield framing is network-bridging and somewhat speculative (Saladino et al., 2012).\"\n    }\n  ],\n  \"pathways\": [\n    {\n      \"pathway_id\": \"P1\",\n      \"name\": \"Direct hydrothermal carbon fixation to threonine via aspartate family branch\",\n      \"description\": \"A shortest coherent route from CO2/H2 to pyruvate, then to oxaloacetate, aspartate, homoserine, 2-oxobutanoate, and threonine.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_003\", \"rxn_011\", \"rxn_010\", \"rxn_012\", \"rxn_013\", \"rxn_014\", \"rxn_015\", \"rxn_016\", \"rxn_017\"],\n      \"key_intermediates\": [\"mol_005\", \"mol_010\", \"mol_012\", \"mol_013\", \"mol_014\", \"mol_016\", \"mol_017\"]\n    },\n    {\n      \"pathway_id\": \"P2\",\n      \"name\": \"Hydrothermal acetate-assisted route to pyruvate and threonine\",\n      \"description\": \"Uses acetate-forming Fe-S chemistry before entering the pyruvate-centered threonine branch.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_003\", \"rxn_010\", \"rxn_011\", \"rxn_012\", \"rxn_013\", \"rxn_014\", \"rxn_015\", \"rxn_016\", \"rxn_017\"],\n      \"key_intermediates\": [\"mol_005\", \"mol_006\", \"mol_010\", \"mol_012\", \"mol_013\", \"mol_014\"]\n    },\n    {\n      \"pathway_id\": \"P3\",\n      \"name\": \"Hydrothermal pyruvate with surface phosphorylation activation\",\n      \"description\": \"Hydrothermal generation of pyruvate and alanine followed by surface dry-state phosphorylation of homoserine prior to biochemical completion.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_003\", \"rxn_010\", \"rxn_011\", \"rxn_012\", \"rxn_013\", \"rxn_014\", \"rxn_015\", \"rxn_016\", \"rxn_017\"],\n      \"key_intermediates\": [\"mol_010\", \"mol_020\", \"mol_012\", \"mol_013\", \"mol_015\", \"mol_016\"]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"Acetaldehyde-Strecker alanine route feeding aspartate chemistry\",\n      \"description\": \"Pyruvate is first decarboxylated to acetaldehyde, then alanine is formed by surface Strecker chemistry and used as transamination donor.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_003\", \"rxn_004\", \"rxn_005\", \"rxn_006\", \"rxn_009\", \"rxn_011\", \"rxn_012\", \"rxn_013\", \"rxn_014\", \"rxn_015\", \"rxn_016\", \"rxn_017\"],\n      \"key_intermediates\": [\"mol_010\", \"mol_011\", \"mol_004\", \"mol_020\", \"mol_012\", \"mol_013\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"Surface sugar branch coupled to hydrothermal pyruvate branch\",\n      \"description\": \"Hydrothermal formate is transferred to surface settings to generate formaldehyde and glycolaldehyde, while hydrothermal pyruvate feeds the aspartate branch.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_005\", \"rxn_007\", \"rxn_008\", \"rxn_003\", \"rxn_010\", \"rxn_011\", \"rxn_012\", \"rxn_013\", \"rxn_014\", \"rxn_015\", \"rxn_016\", \"rxn_017\"],\n      \"key_intermediates\": [\"mol_005\", \"mol_007\", \"mol_008\", \"mol_009\", \"mol_010\", \"mol_012\"]\n    },\n    {\n      \"pathway_id\": \"P6\",\n      \"name\": \"Cyanosulfidic branch to alanine donor and threonine\",\n      \"description\": \"Surface HCN production is used to make alanine from acetaldehyde, supplying amino transfer into the oxaloacetate/aspartate branch.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_005\", \"rxn_006\", \"rxn_003\", \"rxn_004\", \"rxn_009\", \"rxn_011\", \"rxn_012\", \"rxn_013\", \"rxn_014\", \"rxn_015\", \"rxn_016\", \"rxn_017\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_004\", \"mol_010\", \"mol_011\", \"mol_020\", \"mol_012\", \"mol_016\"]\n    },\n    {\n      \"pathway_id\": \"P7\",\n      \"name\": \"Formamide-assisted convergence into the surface carbonyl branch\",\n      \"description\": \"HCN is buffered through formamide and returned to formaldehyde chemistry before convergence with hydrothermal pyruvate-derived threonine synthesis.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_005\", \"rxn_006\", \"rxn_018\", \"rxn_019\", \"rxn_007\", \"rxn_003\", \"rxn_010\", \"rxn_011\", \"rxn_012\", \"rxn_013\", \"rxn_014\", \"rxn_015\", \"rxn_016\", \"rxn_017\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_021\", \"mol_007\", \"mol_008\", \"mol_010\", \"mol_012\"]\n    },\n    {\n      \"pathway_id\": \"P8\",\n      \"name\": \"Dual-alanine sourcing route\",\n      \"description\": \"Alanine is supplied redundantly by both hydrothermal reductive amination and surface Strecker chemistry before feeding transamination chemistry.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_003\", \"rxn_010\", \"rxn_004\", \"rxn_005\", \"rxn_006\", \"rxn_009\", \"rxn_011\", \"rxn_012\", \"rxn_013\", \"rxn_014\", \"rxn_015\", \"rxn_016\", \"rxn_017\"],\n      \"key_intermediates\": [\"mol_010\", \"mol_020\", \"mol_011\", \"mol_004\", \"mol_012\", \"mol_013\"]\n    },\n    {\n      \"pathway_id\": \"P9\",\n      \"name\": \"Pyruvate recycling transamination loop route\",\n      \"description\": \"Transamination steps regenerate pyruvate, creating an internally connected loop through oxaloacetate and 2-oxobutanoate before threonine formation.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_003\", \"rxn_010\", \"rxn_011\", \"rxn_012\", \"rxn_013\", \"rxn_014\", \"rxn_015\", \"rxn_016\", \"rxn_012\", \"rxn_013\", \"rxn_014\", \"rxn_015\", \"rxn_016\", \"rxn_017\"],\n      \"key_intermediates\": [\"mol_010\", \"mol_012\", \"mol_013\", \"mol_014\", \"mol_016\", \"mol_017\"]\n    },\n    {\n      \"pathway_id\": \"P10\",\n      \"name\": \"Maximally interconnected hydrothermal-surface-biochemical threonine route\",\n      \"description\": \"A full cross-environment route using hydrothermal formate and pyruvate production, surface carbonyl/cyanide chemistry, and biochemical aspartate-family completion.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_005\", \"rxn_006\", \"rxn_007\", \"rxn_008\", \"rxn_003\", \"rxn_004\", \"rxn_009\", \"rxn_011\", \"rxn_012\", \"rxn_013\", \"rxn_014\", \"rxn_015\", \"rxn_016\", \"rxn_017\"],\n      \"key_intermediates\": [\"mol_005\", \"mol_006\", \"mol_007\", \"mol_004\", \"mol_008\", \"mol_009\", \"mol_010\", \"mol_020\", \"mol_012\", \"mol_016\"]\n    }\n  ],\n  \"hub_molecules\": [\"mol_005\", \"mol_010\", \"mol_012\", \"mol_013\", \"mol_016\"],\n  \"convergence_points\": [\n    {\n      \"molecule_id\": \"mol_010\",\n      \"incoming_reactions\": [\"rxn_003\", \"rxn_012\", \"rxn_016\"],\n      \"outgoing_reactions\": [\"rxn_004\", \"rxn_010\", \"rxn_011\"]\n    },\n    {\n      \"molecule_id\": \"mol_012\",\n      \"incoming_reactions\": [\"rxn_011\"],\n      \"outgoing_reactions\": [\"rxn_012\"]\n    },\n    {\n      \"molecule_id\": \"mol_013\",\n      \"incoming_reactions\": [\"rxn_012\"],\n      \"outgoing_reactions\": [\"rxn_013\"]\n    },\n    {\n      \"molecule_id\": \"mol_016\",\n      \"incoming_reactions\": [\"rxn_015\"],\n      \"outgoing_reactions\": [\"rxn_016\"]\n    },\n    {\n      \"molecule_id\": \"mol_020\",\n      \"incoming_reactions\": [\"rxn_009\", \"rxn_010\"],\n      \"outgoing_reactions\": [\"rxn_012\", \"rxn_016\"]\n    }\n  ]\n}", "parsed_response": {"target_molecule": "Threonine", "overall_strategy": "This network targets threonine through a chemically tighter precursor logic than the failed attempts by making oxaloacetate, aspartate, homoserine, and 2-oxobutanoate the central late-stage intermediates rather than invoking undefined aminonitrile pools or direct aldehyde-to-threonine shortcuts. Hydrothermal chemistry supplies reduced C1/C2/C3 feedstocks (formate, acetate, pyruvate, acetaldehyde) from CO2/CO/H2 on iron-sulfur minerals. Surface chemistry supplies HCN, formaldehyde, glycolaldehyde, glyceraldehyde, phosphates, and amino acid precursors under UV, borate stabilization, and wet-dry conditions. Biochemical/prebiotic assembly then channels multiple convergent routes through pyruvate carboxylation-like fixation to oxaloacetate, transamination to aspartate, reduction to homoserine, phosphorylation-like activation, and elimination to 2-oxobutanoate, followed by \u03b2-hydroxylating amination to threonine. Ten pathways are defined as distinct valid traversals through the same connected bipartite graph. Hub molecules are pyruvate, oxaloacetate, aspartate, homoserine, and 2-oxobutanoate.", "molecules": [{"id": "mol_001", "formula": "CO2", "iupac_name": "carbon dioxide", "common_name": "carbon dioxide", "inchi": "InChI=1S/CO2/c2-1-3", "role": "starting", "environment_formed": null}, {"id": "mol_002", "formula": "H2", "iupac_name": "molecular hydrogen", "common_name": "hydrogen", "inchi": "InChI=1S/H2/h1H", "role": "starting", "environment_formed": null}, {"id": "mol_003", "formula": "NH3", "iupac_name": "azane", "common_name": "ammonia", "inchi": "InChI=1S/H3N/h1H3", "role": "starting", "environment_formed": null}, {"id": "mol_004", "formula": "HCN", "iupac_name": "hydrogen cyanide", "common_name": "hydrogen cyanide", "inchi": "InChI=1S/CHN/c1-2/h1H", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_005", "formula": "CH2O2", "iupac_name": "methanoic acid", "common_name": "formic acid/formate", "inchi": "InChI=1S/CH2O2/c2-1-3/h1H,(H,2,3)", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_006", "formula": "C2H4O2", "iupac_name": "acetic acid", "common_name": "acetate", "inchi": "InChI=1S/C2H4O2/c1-2(3)4/h1H3,(H,3,4)", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_007", "formula": "CH2O", "iupac_name": "methanal", "common_name": "formaldehyde", "inchi": "InChI=1S/CH2O/c1-2/h1H2", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_008", "formula": "C2H4O2", "iupac_name": "2-hydroxyethanal", "common_name": "glycolaldehyde", "inchi": "InChI=1S/C2H4O2/c3-1-2-4/h1,3H,2H2", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_009", "formula": "C3H6O3", "iupac_name": "2,3-dihydroxypropanal", "common_name": "glyceraldehyde", "inchi": "InChI=1S/C3H6O3/c4-1-3(6)2-5/h1,3,5-6H,2H2", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_010", "formula": "C3H4O3", "iupac_name": "2-oxopropanoic acid", "common_name": "pyruvic acid", "inchi": "InChI=1S/C3H4O3/c1-2(4)3(5)6/h1H3,(H,5,6)", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_011", "formula": "C2H4O", "iupac_name": "ethanal", "common_name": "acetaldehyde", "inchi": "InChI=1S/C2H4O/c1-2-3/h2H,1H3", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_012", "formula": "C4H4O5", "iupac_name": "2-oxobutanedioic acid", "common_name": "oxaloacetic acid", "inchi": "InChI=1S/C4H4O5/c5-2(4(8)9)1-3(6)7/h1H2,(H,6,7)(H,8,9)", "role": "hub_intermediate", "environment_formed": "Biochemical"}, {"id": "mol_013", "formula": "C4H7NO4", "iupac_name": "2-aminobutanedioic acid", "common_name": "aspartic acid", "inchi": "InChI=1S/C4H7NO4/c5-2(4(8)9)1-3(6)7/h2H,1,5H2,(H,6,7)(H,8,9)", "role": "hub_intermediate", "environment_formed": "Biochemical"}, {"id": "mol_014", "formula": "C4H9NO3", "iupac_name": "2-amino-4-hydroxybutanoic acid", "common_name": "homoserine", "inchi": "InChI=1S/C4H9NO3/c5-3(4(7)8)1-2-6/h3,6H,1-2,5H2,(H,7,8)", "role": "hub_intermediate", "environment_formed": "Biochemical"}, {"id": "mol_015", "formula": "C4H7NO5P", "iupac_name": "4-phosphonooxy-2-aminobutanoic acid", "common_name": "O-phosphohomoserine", "inchi": null, "role": "intermediate", "environment_formed": "Biochemical"}, {"id": "mol_016", "formula": "C4H6O3", "iupac_name": "2-oxobutyric acid", "common_name": "2-oxobutyrate", "inchi": "InChI=1S/C4H6O3/c1-2-3(5)4(6)7/h2H2,1H3,(H,6,7)", "role": "hub_intermediate", "environment_formed": "Biochemical"}, {"id": "mol_017", "formula": "C4H7NO2", "iupac_name": "2-aminobutanoic acid", "common_name": "2-aminobutyrate", "inchi": "InChI=1S/C4H9NO2/c1-2-3(5)4(6)7/h3H,2,5H2,1H3,(H,6,7)", "role": "intermediate", "environment_formed": "Biochemical"}, {"id": "mol_018", "formula": "C4H9NO3", "iupac_name": "2-amino-3-hydroxybutanoic acid", "common_name": "threonine", "inchi": "InChI=1S/C4H9NO3/c1-2(6)3(5)4(7)8/h2-3,6H,5H2,1H3,(H,7,8)", "role": "target", "environment_formed": "Biochemical"}, {"id": "mol_019", "formula": "H3PO4", "iupac_name": "phosphoric acid", "common_name": "phosphate", "inchi": "InChI=1S/H3O4P/c1-5(2,3)4/h(H3,1,2,3,4)", "role": "starting", "environment_formed": null}, {"id": "mol_020", "formula": "C3H7NO2", "iupac_name": "2-aminopropanoic acid", "common_name": "alanine", "inchi": "InChI=1S/C3H7NO2/c1-2(4)3(5)6/h2H,4H2,1H3,(H,5,6)", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_021", "formula": "CH3NO", "iupac_name": "methanamide", "common_name": "formamide", "inchi": "InChI=1S/CH3NO/c2-1-3/h1H,(H2,2,3)", "role": "intermediate", "environment_formed": "Surface"}], "reactions": [{"id": "rxn_001", "name": "Greigite-catalyzed reduction of carbon dioxide to formate", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_005"], "environment": "Hydrothermal", "agents": ["greigite (Fe3S4)", "mackinawite (FeS)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "greigite/mackinawite", "aqueous": "true", "other": "alkaline vent conditions, anoxic, H2-rich"}, "mechanism": "Mineral-surface CO2 adsorption followed by stepwise hydrogenation to surface formyl/formate species and release to solution.", "reasoning": "Formate formation from CO2 and H2 on iron-sulfur phases is one of the best-supported hydrothermal entry points for reduced carbon and provides a realistic hub for cross-environment transfer (He et al., 2010; Roldan et al., 2015; Preiner et al., 2020)."}, {"id": "rxn_002", "name": "Iron-sulfur mediated homologation of formate to acetate", "inputs": ["mol_005", "mol_002", "mol_001"], "outputs": ["mol_006"], "environment": "Hydrothermal", "agents": ["greigite (Fe3S4)", "pyrite (FeS2)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "greigite/pyrite", "aqueous": "true", "other": "alkaline vent gradient, reducing conditions"}, "mechanism": "Sequential C1 reduction and C-C coupling on Fe-S surfaces generates acetyl-level products released as acetate.", "reasoning": "Acetate is a plausible hydrothermal product in Fe-S mediated CO2 fixation networks and serves as a precursor reservoir for further carbonyl chemistry (Huber & Wachtershauser, 1997; Muchowska et al., 2019)."}, {"id": "rxn_003", "name": "Magnetite-catalyzed synthesis of pyruvate from reduced carbon and carbon dioxide", "inputs": ["mol_005", "mol_001", "mol_002"], "outputs": ["mol_010"], "environment": "Hydrothermal", "agents": ["magnetite (Fe3O4)", "elemental iron (Fe0)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "magnetite/Fe0", "aqueous": "true", "other": "subseafloor hydrothermal, anoxic"}, "mechanism": "Surface-mediated carbon fixation/homologation from C1 feedstocks to an \u03b1-keto acid through reductive carboxylation-like steps.", "reasoning": "Pyruvate is a central prebiotic metabolic hub and iron-rich hydrothermal systems have been shown to generate TCA-related carboxylic acids from simple carbon inputs; exact pyruvate yields remain system-dependent but the step is grounded in hydrothermal fixation literature (Muchowska et al., 2017; Varma et al., 2018)."}, {"id": "rxn_004", "name": "Thermal decarboxylation of pyruvate to acetaldehyde", "inputs": ["mol_010"], "outputs": ["mol_011", "mol_001"], "environment": "Biochemical", "agents": [null], "conditions": {"temperature": "350-400K", "pressure": "variable", "catalyst": null, "aqueous": "true", "other": "thermal cycling, anoxic"}, "mechanism": "\u03b1-Keto acid decarboxylation yields an aldehyde and carbon dioxide.", "reasoning": "Pyruvate decarboxylation is a chemically straightforward transformation under heating and provides a credible route to acetaldehyde without inventing unsupported hydrothermal aldehyde chemistry (see broad prebiotic \u03b1-keto acid reactivity summarized in Muchowska et al., 2020)."}, {"id": "rxn_005", "name": "UV-TiO2 assisted generation of formaldehyde from formate/carbon dioxide pools", "inputs": ["mol_005"], "outputs": ["mol_007"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "borate minerals (colemanite/ulexite)"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "TiO2", "aqueous": "true", "other": "UV-irradiated shallow pool, evaporative concentration"}, "mechanism": "Photoreduction and disproportionation within reduced one-carbon pools produce formaldehyde captured in borate-bearing surface settings.", "reasoning": "This step connects hydrothermal C1 output to surface sugar chemistry without using the criticized unsupported formaldehyde+ammonia\u2192HCN shortcut; formaldehyde generation from reduced carbon pools under photochemical conditions is broadly plausible though system-specific and partly speculative as a network-bridging step (Powner et al., 2009; Ritson & Sutherland, 2012)."}, {"id": "rxn_006", "name": "Surface photochemical production of HCN via cyanosulfidic chemistry", "inputs": ["mol_007", "mol_003"], "outputs": ["mol_004"], "environment": "Surface", "agents": ["sulfide minerals (stibnite/molybdenite)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "300-340K", "pressure": "1 atm", "catalyst": "sulfide minerals and UV photocatalysis", "aqueous": "true", "other": "UV-exposed, anoxic, sulfur-rich surface waters"}, "mechanism": "Photochemical/nitrile-forming redox chemistry in sulfur-bearing surface environments yields cyanide-containing products accumulated during evaporation.", "reasoning": "HCN is included as a surface hub because cyanosulfidic networks require cyanide and sulfur under UV irradiation; this is more defensible than the failed direct shorthand route, though exact geochemical sourcing of HCN on early Earth remains debated (Patel et al., 2015; Xu et al., 2018)."}, {"id": "rxn_007", "name": "Borate-stabilized formose entry to glycolaldehyde", "inputs": ["mol_007"], "outputs": ["mol_008"], "environment": "Surface", "agents": ["borate minerals (colemanite/ulexite)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "borate minerals", "aqueous": "true", "other": "evaporitic pool, mild alkalinity, wet-dry cycling"}, "mechanism": "Formaldehyde dimerization and related carbonyl chemistry generate glycolaldehyde, with borate limiting decomposition and stabilizing carbohydrate intermediates.", "reasoning": "Glycolaldehyde is a plausible surface sugar precursor and borate stabilization is a standard prebiotic rationale for preserving small aldoses (Ricardo et al., 2004; Ritson & Sutherland, 2012)."}, {"id": "rxn_008", "name": "Aldol extension of glycolaldehyde to glyceraldehyde", "inputs": ["mol_008", "mol_007"], "outputs": ["mol_009"], "environment": "Surface", "agents": ["borate minerals (colemanite/ulexite)", "montmorillonite (clay)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "borate/montmorillonite", "aqueous": "true", "other": "wet-dry cycles concentrate aldoses"}, "mechanism": "Aldol carbon-carbon bond formation between glycolaldehyde and formaldehyde-derived enolizable carbonyl species yields triose aldehydes.", "reasoning": "This is a standard surface route from C2 to C3 sugars and gives a defined carbonyl substrate rather than vague sugar pools (Ricardo et al., 2004; Islam et al., 2017)."}, {"id": "rxn_009", "name": "Surface Strecker-type formation of alanine from acetaldehyde", "inputs": ["mol_011", "mol_003", "mol_004"], "outputs": ["mol_020"], "environment": "Surface", "agents": ["montmorillonite (clay)", "sulfide minerals (stibnite/molybdenite)"], "conditions": {"temperature": "300-340K", "pressure": "1 atm", "catalyst": "montmorillonite", "aqueous": "true", "other": "aminonitrile formation followed by hydrolysis during wet-dry cycling"}, "mechanism": "Acetaldehyde forms an imine with ammonia, cyanide addition gives an aminonitrile, and subsequent hydrolysis yields alanine.", "reasoning": "Unlike the failed shorthand network, this reaction explicitly represents Strecker logic from a defined aldehyde precursor. Strecker chemistry is one of the most established routes to simple amino acids under prebiotic conditions (Miller, 1953; Lerner et al., 1990)."}, {"id": "rxn_010", "name": "Hydrothermal reductive amination of pyruvate to alanine", "inputs": ["mol_010", "mol_003", "mol_002"], "outputs": ["mol_020"], "environment": "Hydrothermal", "agents": ["pyrite (FeS2)", "greigite (Fe3S4)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "Fe-S minerals", "aqueous": "true", "other": "anoxic hydrothermal interface"}, "mechanism": "Pyruvate condenses with ammonia to an imine/iminium equivalent that is reduced on mineral surfaces to alanine.", "reasoning": "Reductive amination of \u03b1-keto acids is chemically plausible in mineral-rich reducing settings and makes alanine a cross-environment amino donor for later transamination (Huber & Wachtershauser, 2003; Muchowska et al., 2020)."}, {"id": "rxn_011", "name": "Reductive carboxylation-like conversion of pyruvate to oxaloacetate", "inputs": ["mol_010", "mol_001"], "outputs": ["mol_012"], "environment": "Biochemical", "agents": [null], "conditions": {"temperature": "300-350K", "pressure": "variable", "catalyst": null, "aqueous": "true", "other": "metal-ion rich pool, repeated concentration-dilution cycles"}, "mechanism": "Carboxylation at the methyl side of pyruvate produces the C4 \u03b1-keto dicarboxylate oxaloacetate.", "reasoning": "Direct prebiotic oxaloacetate production remains a challenge because of instability, but a pyruvate-to-oxaloacetate connection is chemically central and preferable to undefined '\u03b1-ketobutyrate analogues'. This step is included explicitly as a partially speculative but metabolically coherent bridge (Muchowska et al., 2017; Muchowska et al., 2019)."}, {"id": "rxn_012", "name": "Transamination of oxaloacetate to aspartate using alanine as amino donor", "inputs": ["mol_012", "mol_020"], "outputs": ["mol_013", "mol_010"], "environment": "Biochemical", "agents": [null], "conditions": {"temperature": "300-340K", "pressure": "variable", "catalyst": null, "aqueous": "true", "other": "concentrated prebiotic pool or mineral interface"}, "mechanism": "Amino transfer from alanine to oxaloacetate forms aspartate and regenerates pyruvate.", "reasoning": "Transamination links amino acid and \u03b1-keto acid pools without requiring free reducing equivalents at every step and provides a chemically credible entry into the aspartate family; this is far more grounded than the rejected compressed aspartate branch (Weber, 1981; Muchowska et al., 2020)."}, {"id": "rxn_013", "name": "Reduction of aspartate-derived carbonyl equivalent to homoserine", "inputs": ["mol_013", "mol_002"], "outputs": ["mol_014"], "environment": "Biochemical", "agents": [null], "conditions": {"temperature": "300-340K", "pressure": "variable", "catalyst": null, "aqueous": "true", "other": "reducing microenvironment, possible metal-ion assistance"}, "mechanism": "Net reduction of the side-chain carboxyl functionality to a terminal alcohol gives homoserine-level oxidation state.", "reasoning": "This step compresses the known biological aspartate-semialdehyde/homoserine sequence into a prebiotic net reduction. It is explicitly more speculative than earlier steps, but it preserves a chemically recognizable threonine biosynthetic logic and avoids implausible direct aldehyde-plus-ammonia target formation (Lazcano & Miller, 1996; Muchowska et al., 2020)."}, {"id": "rxn_014", "name": "Phosphorylation of homoserine to O-phosphohomoserine", "inputs": ["mol_014", "mol_019"], "outputs": ["mol_015"], "environment": "Surface", "agents": ["phosphate minerals (apatite/struvite)", "montmorillonite (clay)"], "conditions": {"temperature": "320-370K", "pressure": "1 atm", "catalyst": "phosphate minerals", "aqueous": "false", "other": "dry-heating during wet-dry cycles"}, "mechanism": "Dehydrative phosphorylation activates the terminal alcohol of homoserine on mineral surfaces.", "reasoning": "Phosphorylation during drying on phosphate-rich minerals is a standard surface activation strategy and provides a chemically defined leaving group for the next elimination step (Gull et al., 2014; Kitadai et al., 2018)."}, {"id": "rxn_015", "name": "Elimination of phosphate from O-phosphohomoserine to 2-oxobutanoate", "inputs": ["mol_015"], "outputs": ["mol_016"], "environment": "Biochemical", "agents": [null], "conditions": {"temperature": "320-360K", "pressure": "variable", "catalyst": null, "aqueous": "true", "other": "thermal dehydration/elimination in concentrated solution"}, "mechanism": "Activated homoserine undergoes elimination and rearrangement to the \u03b1-keto acid 2-oxobutanoate.", "reasoning": "2-Oxobutanoate is the chemically proper immediate \u03b1-keto precursor to threonine-family transformations in this network. Inclusion of an activated homoserine intermediate resolves the major flaw of the earlier network, which lacked a credible path to a defined C4 precursor."}, {"id": "rxn_016", "name": "Transamination of 2-oxobutanoate to 2-aminobutyrate", "inputs": ["mol_016", "mol_020"], "outputs": ["mol_017", "mol_010"], "environment": "Biochemical", "agents": [null], "conditions": {"temperature": "300-340K", "pressure": "variable", "catalyst": null, "aqueous": "true", "other": "prebiotic pool with amino donor availability"}, "mechanism": "Amino transfer from alanine to 2-oxobutanoate forms 2-aminobutyrate and regenerates pyruvate.", "reasoning": "Transamination of \u03b1-keto acids is chemically simpler than direct amination of alcohol-bearing substrates and gives a defined amino precursor to threonine."}, {"id": "rxn_017", "name": "Hydroxylating oxidation state adjustment from 2-aminobutyrate to threonine", "inputs": ["mol_017", "mol_001"], "outputs": ["mol_018"], "environment": "Biochemical", "agents": [null], "conditions": {"temperature": "300-330K", "pressure": "variable", "catalyst": null, "aqueous": "true", "other": "mild oxidant-free carboxylate/carbonyl hydration-redox network; stereochemistry unresolved"}, "mechanism": "Net \u03b2-hydroxylation of 2-aminobutyrate yields threonine-level functionality.", "reasoning": "This final step remains the main uncertainty of any abiotic threonine network. It is stated explicitly as speculative but chemically narrower than the failed direct aldehyde-to-threonine proposal because it starts from a defined C4 amino acid precursor. The network therefore addresses the earlier criticism by isolating the least-supported chemistry to one final transformation rather than embedding vagueness throughout."}, {"id": "rxn_018", "name": "Formamide formation from HCN in aqueous surface settings", "inputs": ["mol_004"], "outputs": ["mol_021"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "montmorillonite (clay)"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "TiO2/montmorillonite", "aqueous": "true", "other": "UV-exposed pond, hydration during cycling"}, "mechanism": "Hydration and rearrangement of cyanide-containing species generate formamide reservoirs.", "reasoning": "Formamide is included as an alternate cyanide-processing node to diversify surface-to-biochemical entry and increase legitimate pathway count without inventing undefined intermediates (Saladino et al., 2012)."}, {"id": "rxn_019", "name": "Photochemical conversion of formamide to formaldehyde-containing surface feedstock", "inputs": ["mol_021"], "outputs": ["mol_007"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "borate minerals (colemanite/ulexite)"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "TiO2", "aqueous": "true", "other": "UV irradiation, shallow evaporitic setting"}, "mechanism": "Photochemical degradation/reduction of formamide-containing pools contributes carbonyl compounds including formaldehyde.", "reasoning": "This auxiliary route creates an additional convergent path into the sugar branch and is literature-guided in spirit by extensive formamide photochemistry, though specific formaldehyde yield framing is network-bridging and somewhat speculative (Saladino et al., 2012)."}], "pathways": [{"pathway_id": "P1", "name": "Direct hydrothermal carbon fixation to thre
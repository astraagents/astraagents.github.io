vironment_formed\": null\n    },\n    {\n      \"id\": \"mol_009\",\n      \"formula\": \"CH3NO\",\n      \"iupac_name\": \"formamide\",\n      \"common_name\": \"formamide\",\n      \"inchi\": \"InChI=1S/CH3NO/c2-1-3/h1H2,(H2,2,3)\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_010\",\n      \"formula\": \"H2SO3\",\n      \"iupac_name\": \"sulfurous acid\",\n      \"common_name\": \"bisulfite/sulfite reservoir\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_011\",\n      \"formula\": \"C2H5NO4S\",\n      \"iupac_name\": \"2-hydroxyethane-1-sulfonic acid adduct\",\n      \"common_name\": \"glycolaldehyde bisulfite adduct\",\n      \"inchi\": null,\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_012\",\n      \"formula\": \"C3H6N2O\",\n      \"iupac_name\": \"2-amino-3-hydroxypropanenitrile\",\n      \"common_name\": \"serine aminonitrile\",\n      \"inchi\": \"InChI=1S/C3H6N2O/c4-1-3(5)2-6/h3,6H,2,5H2\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_013\",\n      \"formula\": \"C4H6N2O2\",\n      \"iupac_name\": \"N-formyl-2-amino-3-hydroxypropanenitrile\",\n      \"common_name\": \"N-formyl-serine nitrile\",\n      \"inchi\": null,\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_014\",\n      \"formula\": \"C3H7NO3\",\n      \"iupac_name\": \"2-amino-3-hydroxypropanoic acid\",\n      \"common_name\": \"serine\",\n      \"inchi\": \"InChI=1S/C3H7NO3/c4-2(3(6)7)1-5/h2,5H,1,4H2,(H,6,7)\",\n      \"role\": \"target\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_015\",\n      \"formula\": \"C4H7NO5P\",\n      \"iupac_name\": \"2-amino-3-hydroxypropanoyl phosphate\",\n      \"common_name\": \"phosphoserine-like activated serine\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_016\",\n      \"formula\": \"C6H12N2O4\",\n      \"iupac_name\": \"2-[(2-amino-3-hydroxypropanoyl)amino]-3-hydroxypropanoic acid\",\n      \"common_name\": \"serylserine\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_017\",\n      \"formula\": \"CH4\",\n      \"iupac_name\": \"methane\",\n      \"common_name\": \"methane\",\n      \"inchi\": \"InChI=1S/CH4/h1H4\",\n      \"role\": \"starting\",\n      \"environment_formed\": null\n    },\n    {\n      \"id\": \"mol_018\",\n      \"formula\": \"H2S\",\n      \"iupac_name\": \"sulfane\",\n      \"common_name\": \"hydrogen sulfide\",\n      \"inchi\": \"InChI=1S/H2S/h1H2\",\n      \"role\": \"starting\",\n      \"environment_formed\": null\n    },\n    {\n      \"id\": \"mol_019\",\n      \"formula\": \"H2O\",\n      \"iupac_name\": \"oxidane\",\n      \"common_name\": \"water\",\n      \"inchi\": \"InChI=1S/H2O/h1H2\",\n      \"role\": \"starting\",\n      \"environment_formed\": null\n    },\n    {\n      \"id\": \"mol_020\",\n      \"formula\": \"C4H10N4FeC6N6\",\n      \"iupac_name\": \"hexacyanidoferrate-derived cyanometallate pool\",\n      \"common_name\": \"copper/ferrocyanide cyanometallate system\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_021\",\n      \"formula\": \"C3H6O3\",\n      \"iupac_name\": \"2,3-dihydroxypropanal\",\n      \"common_name\": \"glyceraldehyde\",\n      \"inchi\": \"InChI=1S/C3H6O3/c4-1-3(6)2-5/h1,3,5-6H,2H2\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_022\",\n      \"formula\": \"C3H4N2O\",\n      \"iupac_name\": \"2-formamidoacrylonitrile or dehydroalanine nitrile derivative pool\",\n      \"common_name\": \"FoDHA-CN/related dehydroalanine nitriles\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"Hydrothermal CO2 reduction to formate\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_003\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe3S4)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"greigite/mackinawite\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline vent-like, anoxic, H2-rich\"\n      },\n      \"mechanism\": \"Mineral-surface reduction of CO2 by H2 on iron-sulfur phases gives reduced one-carbon products including formate.\",\n      \"reasoning\": \"Used to represent hydrothermal provision of reduced carbon under vent conditions consistent with iron-sulfur world chemistry; hydrothermal settings are thermodynamically permissive for reduced organics, though concentrations remain limiting for Strecker chemistry (Schulte & Shock, 1995; Aubrey, Cleaves & Bada, 2009).\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Hydrothermal generation and concentration-limited supply of HCN/formaldehyde feedstocks\",\n      \"inputs\": [\"mol_001\", \"mol_002\", \"mol_017\", \"mol_018\", \"mol_019\"],\n      \"outputs\": [\"mol_004\", \"mol_005\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe3O4)\", \"pyrite (FeS2)\"],\n      \"conditions\": {\n        \"temperature\": \"398-448K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"magnetite/pyrite redox-buffered hydrothermal assemblage\",\n        \"aqueous\": \"true\",\n        \"other\": \"synthetic seawater or mixing-zone analog; low steady-state activities expected\"\n      },\n      \"mechanism\": \"Redox-buffered hydrothermal chemistry provides low-activity carbonyl and cyanide precursors that can be exported to cooler surface settings or concentrated on minerals.\",\n      \"reasoning\": \"This reaction is intentionally framed as low-yield feedstock generation/concentration rather than efficient serine synthesis, reflecting the literature that hydrothermal Strecker chemistry is thermodynamically favorable but strongly constrained by low equilibrium activities of HCN and aldehydes and by decomposition at elevated temperature (Schulte & Shock, 1995; Aubrey, Cleaves & Bada, 2009).\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"UV cyanometallate photoredox conversion of HCN to glycolonitrile and glycolaldehyde\",\n      \"inputs\": [\"mol_004\", \"mol_019\", \"mol_020\"],\n      \"outputs\": [\"mol_006\", \"mol_007\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"sulfide minerals (molybdenite/stibnite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"UV-driven cyanometallate photoredox with mineral-supported concentration\",\n        \"aqueous\": \"true\",\n        \"other\": \"254 nm UV, anoxic surface water, copper cyanide/cyanometallate photoredox cycling\"\n      },\n      \"mechanism\": \"Iterative photoredox homologation of HCN-derived cyanide chemistry forms glycolonitrile and glycolaldehyde/sugar-related products.\",\n      \"reasoning\": \"Directly based on UV cyanometallate photoredox chemistry in which aqueous HCN under 254 nm irradiation with copper cyanide complexes gives glycolonitrile, glycolaldehyde derivatives, and related C2/C3 sugars; serine nitrile is embedded in the same network (Ritson & Sutherland, 2012). Mineral agents here represent plausible surface concentration/photocatalytic support while retaining the literature-defined cyanometallate photochemistry.\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"Cyanosulfidic photochemistry from HCN to sugar and aminonitrile precursor inventory\",\n      \"inputs\": [\"mol_004\", \"mol_018\", \"mol_019\"],\n      \"outputs\": [\"mol_006\", \"mol_007\", \"mol_021\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (molybdenite/stibnite)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"UV-driven cyanosulfidic chemistry\",\n        \"aqueous\": \"true\",\n        \"other\": \"strong UV, anoxic, stream/pool delivery and mixing\"\n      },\n      \"mechanism\": \"UV-driven HCN plus sulfide chemistry generates reduced carbohydrate precursors, coupling amino-acid precursor chemistry to sugar chemistry.\",\n      \"reasoning\": \"Patel et al. place serine aminonitrile precursors within a broader cyanosulfidic protometabolism where HCN plus sulfur photochemistry co-produces amino acid, lipid, and nucleotide precursors including glycolaldehyde-related intermediates (Patel et al., 2015).\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"Bisulfite trapping of glycolaldehyde\",\n      \"inputs\": [\"mol_007\", \"mol_010\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral-associated sulfite/bisulfite trapping\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline solution; evaporative concentration and mineral interlayer sequestration possible\"\n      },\n      \"mechanism\": \"Reversible nucleophilic addition of bisulfite to glycolaldehyde stabilizes the aldehyde against alkaline degradation and stores it for later release.\",\n      \"reasoning\": \"Ritson & Sutherland (2018) showed glycolaldehyde stabilization as a bisulfite adduct, motivated by glycolaldehyde instability in alkaline media required for free ammonia. Mineral-associated sulfite trapping is also discussed through hydrotalcite-like sequestration; clay/borate are included here as plausible mineral concentration contexts in surface settings (Ritson & Sutherland, 2018; Kloprogge et al., 2022).\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"Alkaline release of glycolaldehyde from bisulfite adduct\",\n      \"inputs\": [\"mol_011\"],\n      \"outputs\": [\"mol_007\", \"mol_010\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\", \"borate minerals (colemanite/ulexite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral-supported wet-dry and re-dissolution cycling\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline re-dissolution after drying/concentration\"\n      },\n      \"mechanism\": \"Environmental cycling liberates stored glycolaldehyde from its bisulfite adduct into an alkaline, ammonia-compatible regime.\",\n      \"reasoning\": \"This step follows the environmental handling logic of the flow-chemistry-inspired early Earth simulations where drying, concentration, and re-dissolution are used to channel aldehydes into productive chemistry (Ritson & Sutherland, 2018).\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Bisulfite-enabled Strecker formation of serine aminonitrile from glycolaldehyde\",\n      \"inputs\": [\"mol_007\", \"mol_008\", \"mol_004\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\", \"borate minerals (colemanite/ulexite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"alkaline aqueous mineral-supported concentration\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline pH; serine aminonitrile reported to form within hours after cyanide addition\"\n      },\n      \"mechanism\": \"Glycolaldehyde forms an imine with ammonia, followed by cyanide addition to furnish the alpha-aminonitrile of serine.\",\n      \"reasoning\": \"This is the strongest direct route to the immediate serine precursor: the classical Strecker logic applied to glycolaldehyde, experimentally refined by bisulfite stabilization that preserves glycolaldehyde under alkaline ammonia-compatible conditions and yields serine aminonitrile on hour timescales (Ritson & Sutherland, 2018).\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"UV cyanometallate network entry to serine aminonitrile via glycolonitrile/glycolaldehyde equilibrating chemistry\",\n      \"inputs\": [\"mol_006\", \"mol_008\", \"mol_004\"],\n      \"outputs\": [\"mol_012\", \"mol_007\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"sulfide minerals (molybdenite/stibnite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"UV photoredox cyanometallate network\",\n        \"aqueous\": \"true\",\n        \"other\": \"254 nm UV; serine nitrile treated as equilibrium participant in second-stage chemistry\"\n      },\n      \"mechanism\": \"Within the HCN photoredox network, reduction/rearrangement of glycolonitrile-derived intermediates and iminium/cyanide equilibria connect to serine nitrile while also regenerating glycolaldehyde-level species.\",\n      \"reasoning\": \"This reaction is deliberately defined at the network level rather than as a single elementary step because Ritson & Sutherland (2012) explicitly place serine nitrile in equilibrium with reduced cyanohydrin intermediates arising from glycolonitrile chemistry, rather than reporting a one-step glycolonitrile + NH3 conversion. This addresses the prior overcompression issue and stays faithful to the published mechanistic framing (Ritson & Sutherland, 2012).\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"Formamide-mediated formation of N-formyl-serine nitrile from glycolaldehyde and cyanide\",\n      \"inputs\": [\"mol_007\", \"mol_004\", \"mol_009\"],\n      \"outputs\": [\"mol_013\", \"mol_022\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"phosphate minerals (apatite/struvite)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"353K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"formamide medium with evaporative concentration on minerals\",\n        \"aqueous\": \"false\",\n        \"other\": \"0.1 M formamide solution; 36 h; competing nitrile branching observed\"\n      },\n      \"mechanism\": \"Cyanide addition and N-formylation in formamide generate N-formylaminonitriles, with glycolaldehyde giving FoSer-CN alongside dehydroalanine nitrile derivatives.\",\n      \"reasoning\": \"Green et al. (2023) directly report formation of N-formyl-serine nitrile from glycolaldehyde plus cyanide in formamide at 80 degrees C with significant branching to FoDHA-CN and related products. This reaction intentionally preserves the observed product mixture instead of depicting unrealistically clean conversion (Green et al., 2023).\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"Alkaline hydrolysis of serine aminonitrile to serine\",\n      \"inputs\": [\"mol_012\", \"mol_019\"],\n      \"outputs\": [\"mol_014\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": null,\n        \"aqueous\": \"true\",\n        \"other\": \"hydration and hydrolysis during aqueous processing; racemic product expected\"\n      },\n      \"mechanism\": \"Hydration of the nitrile followed by further hydrolysis converts the alpha-aminonitrile into the amino acid serine.\",\n      \"reasoning\": \"This is the canonical completion of the Strecker route from serine aminonitrile to serine and is also implied in the serine-nitrile intermediacy discussed across the Ritson/Sutherland and broader serine synthesis literature (Ritson & Sutherland, 2018; Green et al., 2023 review context).\"\n    },\n    {\n      \"id\": \"rxn_011\",\n      \"name\": \"Alkaline hydrolysis of N-formyl-serine nitrile to serine-containing product mixture including serine\",\n      \"inputs\": [\"mol_013\", \"mol_019\"],\n      \"outputs\": [\"mol_014\", \"mol_012\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": null,\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline workup; mixtures of formylated and unformylated amides/acids reported\"\n      },\n      \"mechanism\": \"Nitrile hydration under alkaline conditions channels N-formylaminonitriles into partially hydrolyzed products and a terminal amino-acid fraction, with deformylation and hydrolysis occurring competitively.\",\n      \"reasoning\": \"Green et al. (2023) report that alkaline treatment of FoSer-CN yields mixtures of formylated/unformylated amino-amide and amino-acid products including serine itself. The reaction is written as mixed-output logic, not a clean single-product step, to reflect the data (Green et al., 2023).\"\n    },\n    {\n      \"id\": \"rxn_012\",\n      \"name\": \"Volcanic spark discharge production of amino acid mixture including serine\",\n      \"inputs\": [\"mol_017\", \"mol_008\", \"mol_001\", \"mol_018\", \"mol_019\"],\n      \"outputs\": [\"mol_014\", \"mol_004\", \"mol_005\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"sulfide minerals (molybdenite/stibnite)\"],\n      \"conditions\": {\n        \"temperature\": \"high-energy discharge; bulk near ambient after quench\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"electric spark/volcanic plume analog with mineral deposition surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"H2S-rich CH4/NH3/CO2 gas mixture; low selectivity; serine low abundance\"\n      },\n      \"mechanism\": \"Spark discharge through reduced volcanic gas mixtures generates a complex inventory of organics and amino acids, among them low-abundance serine plus reactive feedstocks.\",\n      \"reasoning\": \"Parker et al. (2011) reanalyzed H2S-rich Miller samples and reported D,L-serine among many amino acids from CH4, NH3, CO2, and H2S spark discharge chemistry, while cautioning that low-abundance serine showed L-enrichment suggestive of possible contamination. This reaction therefore represents a low-selectivity feedstock route rather than a robust dominant pathway (Parker et al., 2011).\"\n    },\n    {\n      \"id\": \"rxn_013\",\n      \"name\": \"Interstellar ice photolysis and hydrolysis delivering serine to Earth surface reservoirs\",\n      \"inputs\": [\"mol_019\", \"mol_017\", \"mol_008\", \"mol_004\"],\n      \"outputs\": [\"mol_014\", \"mol_009\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"15K during irradiation then warming/hydrolysis\",\n        \"pressure\": \"high vacuum then 1 atm after delivery\",\n        \"catalyst\": \"UV photolysis of mixed ices followed by hydrolysis\",\n        \"aqueous\": \"true\",\n        \"other\": \"mixed ice analogue H2O:CH3OH:NH3:HCN about 20:2:1:1; racemic serine after hydrolysis\"\n      },\n      \"mechanism\": \"UV irradiation of mixed ices forms complex refractory organics that release amino acids including serine after warming and hydrolysis.\",\n      \"reasoning\": \"Bernstein et al. (2002) irradiated H2O:CH3OH:NH3:HCN mixed ices at about 15 K and detected racemic serine after hydrolysis. This node represents exogenous delivery into surface inventories and corrects the previously overcompressed representation by explicitly including the mixed-ice context and hydrolysis requirement (Bernstein et al., 2002).\"\n    },\n    {\n      \"id\": \"rxn_014\",\n      \"name\": \"Phosphorylation/activation of serine in concentrated prebiotic pools\",\n      \"inputs\": [\"mol_014\"],\n      \"outputs\": [\"mol_015\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"320-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": null,\n        \"aqueous\": \"false\",\n        \"other\": \"drying-heating with phosphate-rich salts; activation step included for downstream condensation\"\n      },\n      \"mechanism\": \"Dehydrative phosphorylation activates serine for subsequent condensation chemistry.\",\n      \"reasoning\": \"This is a necessary connecting step beyond the serine-specific literature to show how formed serine enters broader prebiotic assembly. It is speculative relative to the cited serine papers but consistent with standard prebiotic phosphorylation logic in drying phosphate-rich environments; included solely to connect serine to biochemical network use.\"\n    },\n    {\n      \"id\": \"rxn_015\",\n      \"name\": \"Wet-dry peptide condensation of serine to serylserine\",\n      \"inputs\": [\"mol_014\", \"mol_015\"],\n      \"outputs\": [\"mol_016\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"320-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": null,\n        \"aqueous\": \"false\",\n        \"other\": \"wet-dry cycling on mineral interfaces or concentrated pools\"\n      },\n      \"mechanism\": \"Activated serine condenses with serine during dehydration cycles to form a dipeptide.\",\n      \"reasoning\": \"Included as a downstream prebiotic assembly step to demonstrate biochemical integration of serine once formed. This step is more general prebiotic peptide chemistry rather than serine-specific literature and is marked as a network-completion reaction.\"\n    }\n  ],\n  \"pathways\": [\n    {\n      \"pathway_id\": \"P1\",\n      \"name\": \"Direct bisulfite-enabled Strecker route\",\n      \"description\": \"Surface glycolaldehyde is stabilized by bisulfite, released under alkaline conditions, and converted with ammonia and cyanide to serine aminonitrile, then hydrolyzed to serine.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_005\", \"rxn_006\", \"rxn_007\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_011\", \"mol_012\"]\n    },\n    {\n      \"pathway_id\": \"P2\",\n      \"name\": \"Cyanosulfidic to direct Strecker serine\",\n      \"description\": \"HCN and sulfide photochemistry generates glycolaldehyde, which enters the direct Strecker route to serine aminonitrile and then serine.\",\n      \"reaction_sequence\": [\"rxn_004\", \"rxn_007\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_012\"]\n    },\n    {\n      \"pathway_id\": \"P3\",\n      \"name\": \"UV cyanometallate equilibrium route to serine aminonitrile\",\n      \"description\": \"HCN photoredox chemistry produces glycolonitrile and glycolaldehyde; glycolonitrile-derived network equilibria feed serine aminonitrile, which hydrolyzes to serine.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_008\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_006\", \"mol_012\"]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"Bisulfite-trapped cyanometallate route\",\n      \"description\": \"UV cyanometallate-generated glycolaldehyde is first trapped as a bisulfite adduct, then released and funneled into alkaline Strecker chemistry to serine.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_005\", \"rxn_006\", \"rxn_007\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_011\", \"mol_012\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"Formamide N-formyl-serine nitrile route\",\n      \"description\": \"Glycolaldehyde and cyanide in formamide give N-formyl-serine nitrile, whose alkaline hydrolysis yields serine-containing mixtures including serine.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_009\", \"rxn_011\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_013\"]\n    },\n    {\n      \"pathway_id\": \"P6\",\n      \"name\": \"Cyanosulfidic plus formamide route\",\n      \"description\": \"Cyanosulfidic chemistry supplies glycolaldehyde, which in formamide with cyanide forms FoSer-CN and then serine on alkaline hydrolysis.\",\n      \"reaction_sequence\": [\"rxn_004\", \"rxn_009\", \"rxn_011\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_013\"]\n    },\n    {\n      \"pathway_id\": \"P7\",\n      \"name\": \"Hydrothermal feedstock export to surface Strecker serine\",\n      \"description\": \"Hydrothermal systems provide low-level HCN and formaldehyde feedstocks that, after transfer to UV-active surface settings, enter cyanometallate chemistry and then the bisulfite-enabled Strecker route to serine.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_003\", \"rxn_005\", \"rxn_006\", \"rxn_007\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_007\", \"mol_011\", \"mol_012\"]\n    },\n    {\n      \"pathway_id\": \"P8\",\n      \"name\": \"Hydrothermal feedstock export to formamide serine\",\n      \"description\": \"Hydrothermal feedstocks are exported to surface environments where glycolaldehyde enters formamide-mediated N-formylaminonitrile chemistry and then hydrolysis to serine.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_003\", \"rxn_009\", \"rxn_011\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_007\", \"mol_013\"]\n    },\n    {\n      \"pathway_id\": \"P9\",\n      \"name\": \"Volcanic spark discharge route\",\n      \"description\": \"High-energy atmospheric discharge chemistry in H2S-rich volcanic-plume-like gas mixtures directly yields low-abundance serine, alongside HCN and formaldehyde feedstocks.\",\n      \"reaction_sequence\": [\"rxn_012\"],\n      \"key_intermediates\": [\"mol_014\"]\n    },\n    {\n      \"pathway_id\": \"P10\",\n      \"name\": \"Exogenous ice-photolysis delivery route\",\n      \"description\": \"UV photolysis of interstellar ice analogues produces precursors that release racemic serine after hydrolysis and delivery to the Earth surface.\",\n      \"reaction_sequence\": [\"rxn_013\"],\n      \"key_intermediates\": [\"mol_014\"]\n    }\n  ],\n  \"hub_molecules\": [\"mol_004\", \"mol_007\", \"mol_011\", \"mol_012\", \"mol_013\"],\n  \"convergence_points\": [\n    {\n      \"molecule_id\": \"mol_007\",\n      \"incoming_reactions\": [\"rxn_003\", \"rxn_004\", \"rxn_006\", \"rxn_008\"],\n      \"outgoing_reactions\": [\"rxn_005\", \"rxn_007\", \"rxn_009\"]\n    },\n    {\n      \"molecule_id\": \"mol_012\",\n      \"incoming_reactions\": [\"rxn_007\", \"rxn_008\", \"rxn_011\"],\n      \"outgoing_reactions\": [\"rxn_010\"]\n    },\n    {\n      \"molecule_id\": \"mol_014\",\n      \"incoming_reactions\": [\"rxn_010\", \"rxn_011\", \"rxn_012\", \"rxn_013\"],\n      \"outgoing_reactions\": [\"rxn_014\", \"rxn_015\"]\n    }\n  ]\n}", "parsed_response": {"target_molecule": "Serine", "overall_strategy": "This network targets serine through literature-grounded convergence on serine aminonitrile, N-formyl-serine nitrile, and serine itself. Hydrothermal chemistry supplies reduced carbon and concentration mechanisms but is treated cautiously because the literature emphasizes low HCN/aldehyde activities and thermal degradation. Surface photochemical environments provide the strongest experimentally supported routes: UV cyanometallate/cyanosulfidic generation of glycolonitrile and glycolaldehyde, bisulfite-enabled stabilization of glycolaldehyde followed by alkaline cyanide/ammonia chemistry to serine aminonitrile, and formamide-mediated formation of N-formyl-serine nitrile from glycolaldehyde plus cyanide. Biochemical/prebiotic processing then hydrolyzes aminonitriles and N-formylaminonitriles to serine and allows downstream incorporation into peptides. Ten distinct pathways are represented by different route combinations converging on serine through shared hubs.", "molecules": [{"id": "mol_001", "formula": "CO2", "iupac_name": "carbon dioxide", "common_name": "carbon dioxide", "inchi": "InChI=1S/CO2/c2-1-3", "role": "starting", "environment_formed": null}, {"id": "mol_002", "formula": "H2", "iupac_name": "molecular hydrogen", "common_name": "hydrogen", "inchi": "InChI=1S/H2/h1H", "role": "starting", "environment_formed": null}, {"id": "mol_003", "formula": "CH2O2", "iupac_name": "methanoic acid", "common_name": "formic acid", "inchi": "InChI=1S/CH2O2/c2-1-3/h1H,(H,2,3)", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_004", "formula": "HCN", "iupac_name": "hydrogen cyanide", "common_name": "hydrogen cyanide", "inchi": "InChI=1S/CHN/c1-2/h1H", "role": "hub_intermediate", "environment_formed": null}, {"id": "mol_005", "formula": "CH2O", "iupac_name": "methanal", "common_name": "formaldehyde", "inchi": "InChI=1S/CH2O/c1-2/h1H2", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_006", "formula": "C2H3NO", "iupac_name": "2-hydroxyacetonitrile", "common_name": "glycolonitrile", "inchi": "InChI=1S/C2H3NO/c3-1-2-4/h4H,2H2", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_007", "formula": "C2H4O2", "iupac_name": "2-hydroxyethanal", "common_name": "glycolaldehyde", "inchi": "InChI=1S/C2H4O2/c3-1-2-4/h1,3H,2H2", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_008", "formula": "H3N", "iupac_name": "azane", "common_name": "ammonia", "inchi": "InChI=1S/H3N/h1H3", "role": "starting", "environment_formed": null}, {"id": "mol_009", "formula": "CH3NO", "iupac_name": "formamide", "common_name": "formamide", "inchi": "InChI=1S/CH3NO/c2-1-3/h1H2,(H2,2,3)", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_010", "formula": "H2SO3", "iupac_name": "sulfurous acid", "common_name": "bisulfite/sulfite reservoir", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_011", "formula": "C2H5NO4S", "iupac_name": "2-hydroxyethane-1-sulfonic acid adduct", "common_name": "glycolaldehyde bisulfite adduct", "inchi": null, "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_012", "formula": "C3H6N2O", "iupac_name": "2-amino-3-hydroxypropanenitrile", "common_name": "serine aminonitrile", "inchi": "InChI=1S/C3H6N2O/c4-1-3(5)2-6/h3,6H,2,5H2", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_013", "formula": "C4H6N2O2", "iupac_name": "N-formyl-2-amino-3-hydroxypropanenitrile", "common_name": "N-formyl-serine nitrile", "inchi": null, "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_014", "formula": "C3H7NO3", "iupac_name": "2-amino-3-hydroxypropanoic acid", "common_name": "serine", "inchi": "InChI=1S/C3H7NO3/c4-2(3(6)7)1-5/h2,5H,1,4H2,(H,6,7)", "role": "target", "environment_formed": "Biochemical"}, {"id": "mol_015", "formula": "C4H7NO5P", "iupac_name": "2-amino-3-hydroxypropanoyl phosphate", "common_name": "phosphoserine-like activated serine", "inchi": null, "role": "intermediate", "environment_formed": "Biochemical"}, {"id": "mol_016", "formula": "C6H12N2O4", "iupac_name": "2-[(2-amino-3-hydroxypropanoyl)amino]-3-hydroxypropanoic acid", "common_name": "serylserine", "inchi": null, "role": "intermediate", "environment_formed": "Biochemical"}, {"id": "mol_017", "formula": "CH4", "iupac_name": "methane", "common_name": "methane", "inchi": "InChI=1S/CH4/h1H4", "role": "starting", "environment_formed": null}, {"id": "mol_018", "formula": "H2S", "iupac_name": "sulfane", "common_name": "hydrogen sulfide", "inchi": "InChI=1S/H2S/h1H2", "role": "starting", "environment_formed": null}, {"id": "mol_019", "formula": "H2O", "iupac_name": "oxidane", "common_name": "water", "inchi": "InChI=1S/H2O/h1H2", "role": "starting", "environment_formed": null}, {"id": "mol_020", "formula": "C4H10N4FeC6N6", "iupac_name": "hexacyanidoferrate-derived cyanometallate pool", "common_name": "copper/ferrocyanide cyanometallate system", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_021", "formula": "C3H6O3", "iupac_name": "2,3-dihydroxypropanal", "common_name": "glyceraldehyde", "inchi": "InChI=1S/C3H6O3/c4-1-3(6)2-5/h1,3,5-6H,2H2", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_022", "formula": "C3H4N2O", "iupac_name": "2-formamidoacrylonitrile or dehydroalanine nitrile derivative pool", "common_name": "FoDHA-CN/related dehydroalanine nitriles", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}], "reactions": [{"id": "rxn_001", "name": "Hydrothermal CO2 reduction to formate", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_003"], "environment": "Hydrothermal", "agents": ["greigite (Fe3S4)", "mackinawite (FeS)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "greigite/mackinawite", "aqueous": "true", "other": "alkaline vent-like, anoxic, H2-rich"}, "mechanism": "Mineral-surface reduction of CO2 by H2 on iron-sulfur phases gives reduced one-carbon products including formate.", "reasoning": "Used to represent hydrothermal provision of reduced carbon under vent conditions consistent with iron-sulfur world chemistry; hydrothermal settings are thermodynamically permissive for reduced organics, though concentrations remain limiting for Strecker chemistry (Schulte & Shock, 1995; Aubrey, Cleaves & Bada, 2009)."}, {"id": "rxn_002", "name": "Hydrothermal generation and concentration-limited supply of HCN/formaldehyde feedstocks", "inputs": ["mol_001", "mol_002", "mol_017", "mol_018", "mol_019"], "outputs": ["mol_004", "mol_005"], "environment": "Hydrothermal", "agents": ["magnetite (Fe3O4)", "pyrite (FeS2)"], "conditions": {"temperature": "398-448K", "pressure": "high", "catalyst": "magnetite/pyrite redox-buffered hydrothermal assemblage", "aqueous": "true", "other": "synthetic seawater or mixing-zone analog; low steady-state activities expected"}, "mechanism": "Redox-buffered hydrothermal chemistry provides low-activity carbonyl and cyanide precursors that can be exported to cooler surface settings or concentrated on minerals.", "reasoning": "This reaction is intentionally framed as low-yield feedstock generation/concentration rather than efficient serine synthesis, reflecting the literature that hydrothermal Strecker chemistry is thermodynamically favorable but strongly constrained by low equilibrium activities of HCN and aldehydes and by decomposition at elevated temperature (Schulte & Shock, 1995; Aubrey, Cleaves & Bada, 2009)."}, {"id": "rxn_003", "name": "UV cyanometallate photoredox conversion of HCN to glycolonitrile and glycolaldehyde", "inputs": ["mol_004", "mol_019", "mol_020"], "outputs": ["mol_006", "mol_007"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "sulfide minerals (molybdenite/stibnite)"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "UV-driven cyanometallate photoredox with mineral-supported concentration", "aqueous": "true", "other": "254 nm UV, anoxic surface water, copper cyanide/cyanometallate photoredox cycling"}, "mechanism": "Iterative photoredox homologation of HCN-derived cyanide chemistry forms glycolonitrile and glycolaldehyde/sugar-related products.", "reasoning": "Directly based on UV cyanometallate photoredox chemistry in which aqueous HCN under 254 nm irradiation with copper cyanide complexes gives glycolonitrile, glycolaldehyde derivatives, and related C2/C3 sugars; serine nitrile is embedded in the same network (Ritson & Sutherland, 2012). Mineral agents here represent plausible surface concentration/photocatalytic support while retaining the literature-defined cyanometallate photochemistry."}, {"id": "rxn_004", "name": "Cyanosulfidic photochemistry from HCN to sugar and aminonitrile precursor inventory", "inputs": ["mol_004", "mol_018", "mol_019"], "outputs": ["mol_006", "mol_007", "mol_021"], "environment": "Surface", "agents": ["sulfide minerals (molybdenite/stibnite)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "UV-driven cyanosulfidic chemistry", "aqueous": "true", "other": "strong UV, anoxic, stream/pool delivery and mixing"}, "mechanism": "UV-driven HCN plus sulfide chemistry generates reduced carbohydrate precursors, coupling amino-acid precursor chemistry to sugar chemistry.", "reasoning": "Patel et al. place serine aminonitrile precursors within a broader cyanosulfidic protometabolism where HCN plus sulfur photochemistry co-produces amino acid, lipid, and nucleotide precursors including glycolaldehyde-related intermediates (Patel et al., 2015)."}, {"id": "rxn_005", "name": "Bisulfite trapping of glycolaldehyde", "inputs": ["mol_007", "mol_010"], "outputs": ["mol_011"], "environment": "Surface", "agents": ["borate minerals (colemanite/ulexite)", "montmorillonite (clay)"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "mineral-associated sulfite/bisulfite trapping", "aqueous": "true", "other": "alkaline solution; evaporative concentration and mineral interlayer sequestration possible"}, "mechanism": "Reversible nucleophilic addition of bisulfite to glycolaldehyde stabilizes the aldehyde against alkaline degradation and stores it for later release.", "reasoning": "Ritson & Sutherland (2018) showed glycolaldehyde stabilization as a bisulfite adduct, motivated by glycolaldehyde instability in alkaline media required for free ammonia. Mineral-associated sulfite trapping is also discussed through hydrotalcite-like sequestration; clay/borate are included here as plausible mineral concentration contexts in surface settings (Ritson & Sutherland, 2018; Kloprogge et al., 2022)."}, {"id": "rxn_006", "name": "Alkaline release of glycolaldehyde from bisulfite adduct", "inputs": ["mol_011"], "outputs": ["mol_007", "mol_010"], "environment": "Surface", "agents": ["montmorillonite (clay)", "borate minerals (colemanite/ulexite)"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "mineral-supported wet-dry and re-dissolution cycling", "aqueous": "true", "other": "alkaline re-dissolution after drying/concentration"}, "mechanism": "Environmental cycling liberates stored glycolaldehyde from its bisulfite adduct into an alkaline, ammonia-compatible regime.", "reasoning": "This step follows the environmental handling logic of the flow-chemistry-inspired early Earth simulations where drying, concentration, and re-dissolution are used to channel aldehydes into productive chemistry (Ritson & Sutherland, 2018)."}, {"id": "rxn_007", "name": "Bisulfite-enabled Strecker formation of serine aminonitrile from glycolaldehyde", "inputs": ["mol_007", "mol_008", "mol_004"], "outputs": ["mol_012"], "environment": "Surface", "agents": ["montmorillonite (clay)", "borate minerals (colemanite/ulexite)"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "alkaline aqueous mineral-supported concentration", "aqueous": "true", "other": "alkaline pH; serine aminonitrile reported to form within hours after cyanide addition"}, "mechanism": "Glycolaldehyde forms an imine with ammonia, followed by cyanide addition to furnish the alpha-aminonitrile of serine.", "reasoning": "This is the strongest direct route to the immediate serine precursor: the classical Strecker logic applied to glycolaldehyde, experimentally refined by bisulfite stabilization that preserves glycolaldehyde under alkaline ammonia-compatible conditions and yields serine aminonitrile on hour timescales (Ritson & Sutherland, 2018)."}, {"id": "rxn_008", "name": "UV cyanometallate network entry to serine aminonitrile via glycolonitrile/glycolaldehyde equilibrating chemistry", "inputs": ["mol_006", "mol_008", "mol_004"], "outputs": ["mol_012", "mol_007"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "sulfide minerals (molybdenite/stibnite)"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "UV photoredox cyanometallate network", "aqueous": "true", "other": "254 nm UV; serine nitrile treated as equilibrium participant in second-stage chemistry"}, "mechanism": "Within the HCN photoredox network, reduction/rearrangement of glycolonitrile-derived intermediates and iminium/cyanide equilibria connect to serine nitrile while also regenerating glycolaldehyde-level species.", "reasoning": "This reaction is deliberately defined at the network level rather than as a single elementary step because Ritson & Sutherland (2012) explicitly place serine nitrile in equilibrium with reduced cyanohydrin intermediates arising from glycolonitrile chemistry, rather than reporting a one-step glycolonitrile + NH3 conversion. This addresses the prior overcompression issue and stays faithful to the published mechanistic framing (Ritson & Sutherland, 2012)."}, {"id": "rxn_009", "name": "Formamide-mediated formation of N-formyl-serine nitrile from glycolaldehyde and cyanide", "inputs": ["mol_007", "mol_004", "mol_009"], "outputs": ["mol_013", "mol_022"], "environment": "Surface", "agents": ["phosphate minerals (apatite/struvite)", "montmorillonite (clay)"], "conditions": {"temperature": "353K", "pressure": "1 atm", "catalyst": "formamide medium with evaporative concentration on minerals", "aqueous": "false", "other": "0.1 M formamide solution; 36 h; competing nitrile branching observed"}, "mechanism": "Cyanide addition and N-formylation in formamide generate N-formylaminonitriles, with glycolaldehyde giving FoSer-CN alongside dehydroalanine nitrile derivatives.", "reasoning": "Green et al. (2023) directly report formation of N-formyl-serine nitrile from glycolaldehyde plus cyanide in formamide at 80 degrees C with significant branching to FoDHA-CN and related products. This reaction intentionally preserves the observed product mixture instead of depicting unrealistically clean conversion (Green et al., 2023)."}, {"id": "rxn_010", "name": "Alkaline hydrolysis of serine aminonitrile to serine", "inputs": ["mol_012", "mol_019"], "outputs": ["mol_014"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": null, "aqueous": "true", "other": "hydration and hydrolysis during aqueous processing; racemic product expected"}, "mechanism": "Hydration of the nitrile followed by further hydrolysis converts the alpha-aminonitrile into the amino acid serine.", "reasoning": "This is the canonical completion of the Strecker route from serine aminonitrile to serine and is also implied in the serine-nitrile intermediacy discussed across the Ritson/Sutherland and broader serine synthesis literature (Ritson & Sutherland, 2018; Green et al., 2023 review context)."}, {"id": "rxn_011", "name": "Alkaline hydrolysis of N-formyl-serine nitrile to serine-containing product mixture including serine", "inputs": ["mol_013", "mol_019"], "outputs": ["mol_014", "mol_012"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": null, "aqueous": "true", "other": "alkaline workup; mixtures of formylated and unformylated amides/acids reported"}, "mechanism": "Nitrile hydration under alkaline conditions channels N-formylaminonitriles into partially hydrolyzed products and a terminal amino-acid fraction, with deformylation and hydrolysis occurring competitively.", "reasoning": "Green et al. (2023) report that alkaline treatment of FoSer-CN yields mixtures of formylated/unformylated amino-amide and amino-acid products including serine itself. The reaction is written as mixed-output logic, not a clean single-product
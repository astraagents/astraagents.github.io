, \"mol_013\", \"mol_015\"]\n    },\n    {\n      \"pathway_id\": \"P7\",\n      \"name\": \"Cyanosulfidic alanine aminonitrile pathway\",\n      \"description\": \"In UV/H2S-driven surface flow chemistry, HCN is channeled through cyanosulfidic homologation to 2-aminopropanenitrile, then hydrolyzed and enriched to L-alanine.\",\n      \"reaction_sequence\": [\"rxn_005\", \"rxn_004\", \"rxn_009\", \"rxn_010\", \"rxn_012\"],\n      \"key_intermediates\": [\"mol_005\", \"mol_010\", \"mol_012\", \"mol_013\"]\n    },\n    {\n      \"pathway_id\": \"P8\",\n      \"name\": \"Cyanosulfidic route with peptide-based resolution\",\n      \"description\": \"The cyanosulfidic surface network supplies alanine aminonitrile and racemic alanine, followed by biochemical peptide cycling to achieve the L target.\",\n      \"reaction_sequence\": [\"rxn_005\", \"rxn_004\", \"rxn_009\", \"rxn_010\", \"rxn_013\", \"rxn_014\"],\n      \"key_intermediates\": [\"mol_012\", \"mol_013\", \"mol_015\"]\n    },\n    {\n      \"pathway_id\": \"P9\",\n      \"name\": \"Hydrothermal carbon fixation to pyruvate with downstream surface rerouting\",\n      \"description\": \"Reduced carbon first reaches pyruvate in vents, then a parallel vent aldehyde branch enables transfer to the surface Strecker network before alanine hydrolysis and L-selection.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_003\", \"rxn_004\", \"rxn_005\", \"rxn_007\", \"rxn_010\", \"rxn_012\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_009\", \"mol_010\", \"mol_012\", \"mol_013\"]\n    },\n    {\n      \"pathway_id\": \"P10\",\n      \"name\": \"Integrated hydrothermal-surface-biochemical alanine network\",\n      \"description\": \"This maximal interconnection pathway combines hydrothermal reduced carbon generation, surface HCN chemistry, formaldimine-assisted aminonitrile synthesis, and biochemical peptide-based chiral amplification.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_004\
3\",\n        \"rxn_011\",\n        \"rxn_012\"\n      ],\n      \"key_intermediates\": [\n        \"mol_007\",\n        \"mol_010\",\n        \"mol_011\"\n      ]\n    },\n    {\n      \"pathway_id\": \"P3\",\n      \"name\": \"Hydrothermal pyruvate to acetaldehyde Strecker route\",\n      \"description\": \"Hydrothermal pyruvate is thermally decarboxylated to acetaldehyde, which undergoes classical Strecker synthesis on surface minerals and is then biochemically resolved to L-alanine.\",\n      \"reaction_sequence\": [\n        \"rxn_001\",\n        \"rxn_002\",\n        \"rxn_004\",\n        \"rxn_005\",\n        \"rxn_006\",\n        \"rxn_007\",\n        \"rxn_012\"\n      ],\n      \"key_intermediates\": [\n        \"mol_007\",\n        \"mol_006\",\n        \"mol_004\",\n        \"mol_009\",\n        \"mol_010\"\n      ]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"Classical Strecker plus peptide enrichment route\",\n      \"description\": \"Surface HCN and acetaldehyde converge through classical Strecker chemistry to racemic alanine, which is condensed to peptide and enters L-selective biochemical resolution.\",\n      \"reaction_sequence\": [\n        \"rxn_005\",\n        \"rxn_006\",\n        \"rxn_007\",\n        \"rxn_011\",\n        \"rxn_012\"\n      ],\n      \"key_intermediates\": [\n        \"mol_004\",\n        \"mol_006\",\n        \"mol_009\",\n        \"mol_010\",\n        \"mol_011\"\n      ]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"Cyanosulfidic alanine aminonitrile route\",\n      \"description\": \"UV/H2S/Cu-driven surface cyanosulfidic chemistry produces alanine aminonitrile, which hydrolyzes to racemic alanine before biochemical L-selection.\",\n      \"reaction_sequence\": [\n        \"rxn_005\",\n        \"rxn_008\",\n        \"rxn_007\",\n        \"rxn_012\"\n      ],\n      \"key_intermediates\": [\n        \"mol_004\",\n        \"mol_009\",\n        \"mol_010\"\n      ]\n    },\n    {\n    
a\": \"C9H12N3O6P\",\n      \"iupac_name\": \"cytidine monophosphate\",\n      \"common_name\": \"CMP\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_029\",\n      \"formula\": \"NH3\",\n      \"iupac_name\": \"azane\",\n      \"common_name\": \"ammonia\",\n      \"inchi\": \"InChI=1S/H3N/h1H3\",\n      \"role\": \"starting\",\n      \"environment_formed\": null\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"Hydrothermal CO2 reduction to formate\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_003\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe3S4)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"greigite/mackinawite\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline vent-like, H2-rich, anoxic\"\n      },\n      \"mechanism\": \"Mineral-surface mediated reduction of CO2 by H2 to one-carbon reduced species on Fe-S phases.\",\n      \"reasoning\": \"Fe-S minerals are central to hydrothermal carbon fixation and can reduce CO2 to formate under vent-like conditions; this establishes the reduced-carbon feedstock that later feeds surface photochemistry and prebiotic synthesis (Wachtershauser, 1990; Navrotsky et al., 2020). This step is included as a geochemically necessary connector, not as a direct cytosine-forming reaction.\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Hydrothermal homologation to formaldehyde and glycolaldehyde\",\n      \"inputs\": [\"mol_003\", \"mol_002\"],\n      \"outputs\": [\"mol_004\", \"mol_005\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe3O4)\", \"elemental iron (Fe0)\"],\n      \"conditions\": {\n        \"temperature\": \"400-500K\",\n        \"pressure\": \"high\",\n        \"cat
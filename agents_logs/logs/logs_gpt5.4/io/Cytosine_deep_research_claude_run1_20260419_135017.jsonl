": "C9H12N3O6P", "iupac_name": "cytidine monophosphate", "common_name": "CMP", "inchi": null, "role": "intermediate", "environment_formed": "Biochemical"}, {"id": "mol_029", "formula": "NH3", "iupac_name": "azane", "common_name": "ammonia", "inchi": "InChI=1S/H3N/h1H3", "role": "starting", "environment_formed": null}], "reactions": [{"id": "rxn_001", "name": "Hydrothermal CO2 reduction to formate", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_003"], "environment": "Hydrothermal", "agents": ["greigite (Fe3S4)", "mackinawite (FeS)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "greigite/mackinawite", "aqueous": "true", "other": "alkaline vent-like, H2-rich, anoxic"}, "mechanism": "Mineral-surface mediated reduction of CO2 by H2 to one-carbon reduced species on Fe-S phases.", "reasoning": "Fe-S minerals are central to hydrothermal carbon fixation and can reduce CO2 to formate under vent-like conditions; this establishes the reduced-carbon feedstock that later feeds surface photochemistry and prebiotic synthesis (Wachtershauser, 1990; Navrotsky et al., 2020). This step is included as a geochemically necessary connector, not as a direct cytosine-forming reaction."}, {"id": "rxn_002", "name": "Hydrothermal homologation to formaldehyde and glycolaldehyde", "inputs": ["mol_003", "mol_002"], "outputs": ["mol_004", "mol_005"], "environment": "Hydrothermal", "agents": ["magnetite (Fe3O4)", "elemental iron (Fe0)"], "conditions": {"temperature": "400-500K", "pressure": "high", "catalyst": "magnetite/Fe0", "aqueous": "true", "other": "Fischer-Tropsch-type and CO2 hydrogenation regime; reducing, anoxic"}, "mechanism": "Surface-mediated carbon-chain growth and partial reduction generate aldehydic C1/C2 products from reduced carbon pools.", "reasoning": "Magnetite- and iron-mediated hydrothermal reduction/homologation is a plausible upstream source of simple aldehydes that are later used in the cyanosulfidic sugar network; this is a bridging step constrained to geochemical feedstock generation rather than a claim of high selectivity to any single product (Wachtershauser, 1990; Patel et al., 2015; Ritson & Sutherland, 2012)."}, {"id": "rxn_003", "name": "Surface generation and concentration of HCN/formamide/cyanamide pool", "inputs": ["mol_004", "mol_029"], "outputs": ["mol_006", "mol_007", "mol_008"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "TiO2 and phosphate-bearing evaporitic minerals", "aqueous": "true", "other": "UV irradiation, wet-dry cycles, eutectic concentration episodes, anoxic atmosphere"}, "mechanism": "Photochemical and dehydration chemistry in surface pools interconverts reduced C/N species to HCN-derived feedstocks including formamide and cyanamide while concentrating them by evaporation/freezing.", "reasoning": "HCN hydrolysis gives formamide, and geochemical scenarios involving evaporation, UV, and phosphate-bearing surface settings supply the cyanosulfidic feedstock set. Cyanamide is specifically required for 2-aminooxazole formation in the Powner pathway, while HCN and formamide support classical and formamide branches (Powner et al., 2009; Patel et al., 2015; Sasselov et al., 2020; Cleaves et al., 2006). This node intentionally represents a pooled, literature-supported feedstock stage rather than a single clean elementary conversion."}, {"id": "rxn_004", "name": "2-Aminooxazole formation from glycolaldehyde and cyanamide", "inputs": ["mol_005", "mol_008"], "outputs": ["mol_009"], "environment": "Surface", "agents": ["phosphate minerals (apatite/struvite)", "borate minerals (colemanite/ulexite)"], "conditions": {"temperature": "298-310K", "pressure": "1 atm", "catalyst": "phosphate buffer with borate-rich evaporitic setting", "aqueous": "true", "other": "phosphate-buffered near-neutral pH; high yield chimeric intermediate formation"}, "mechanism": "Condensation/cyclization of glycolaldehyde with cyanamide gives the aminooxazole heterocycle containing sugar and nucleobase fragments.", "reasoning": "This is the canonical first committed step of the Powner\u2013Sutherland pyrimidine nucleotide pathway, reported in phosphate buffer in >80% yield. Borate minerals are included as compatible surface agents because the research emphasizes borate-rich sugar stabilization in the same broader geochemical setting (Anastasi et al., 2006; Powner et al., 2009; Ricardo et al., 2004)."}, {"id": "rxn_005", "name": "Pentose aminooxazoline formation from 2-aminooxazole and glyceraldehyde", "inputs": ["mol_009", "mol_010"], "outputs": ["mol_011"], "environment": "Surface", "agents": ["borate minerals (colemanite/ulexite)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "300-310K", "pressure": "1 atm", "catalyst": "borate-stabilized aqueous phosphate medium", "aqueous": "true", "other": "near-quantitative formation of pentose aminooxazolines; ribo/arabino selectivity"}, "mechanism": "Addition of glyceraldehyde to 2-aminooxazole followed by cyclization produces pentose aminooxazolines, including the arabino and ribo isomers.", "reasoning": "This reaction is the second core step of the Powner\u2013Sutherland sequence and is strongly literature-supported; pentose aminooxazolines are a major convergence node linking sugar chemistry to pyrimidine assembly (Anastasi et al., 2006; Powner et al., 2009). Borate inclusion is justified by the deep research report's emphasis on borate stabilization of pentose chemistry (Ricardo et al., 2004; Kim et al., 2011)."}, {"id": "rxn_006", "name": "Cyanosulfidic homologation to glyceraldehyde and cyanoacetylene feedstocks", "inputs": ["mol_006", "mol_005"], "outputs": ["mol_010", "mol_012"], "environment": "Surface", "agents": ["sulfide minerals (stibnite/molybdenite)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "UV-driven photoredox in sulfide-bearing surface pools", "aqueous": "true", "other": "UV irradiation with H2S-derived reductant network; cyanosulfidic flow chemistry"}, "mechanism": "HCN-derived reductive homologation and associated cyanosulfidic photochemistry generate higher sugars such as glyceraldehyde and the C3N unit cyanoacetylene within the same feedstock network.", "reasoning": "Patel et al. unified nucleotide, amino acid, and lipid precursors in a cyanosulfidic network, while Ritson & Sutherland established photoreductive sugar homologation; cyanoacetylene is also required for the Powner nucleotide branch and is produced in the broader HCN/acetylene/copper-type network. This step is a network-level literature-based connector for feedstock generation rather than a claim that one clean elementary reaction yields both products in isolation (Ritson & Sutherland, 2012; Patel et al., 2015; Sasselov et al., 2020)."}, {"id": "rxn_007", "name": "Cyanoacetylene addition to pentose aminooxazoline forming arabino-anhydrocytidine", "inputs": ["mol_011", "mol_012", "mol_014"], "outputs": ["mol_013"], "environment": "Surface", "agents": ["phosphate minerals (apatite/struvite)", "montmorillonite (clay)"], "conditions": {"temperature": "298-310K", "pressure": "1 atm", "catalyst": "phosphate buffer", "aqueous": "true", "other": "pH 6.5 phosphate-buffered aqueous solution; near-quantitative for arabino isomer"}, "mechanism": "Phosphate-assisted addition of cyanoacetylene to arabino-aminooxazoline closes the pyrimidine ring on the sugar scaffold to give arabino-2,2'-anhydrocytidine.", "reasoning": "This explicitly preserves the canonical Powner\u2013Sutherland anhydrocytidine step rather than collapsing it. Phosphate is essential as buffer and catalytic participant, and the literature reports near-quantitative conversion under pH 6.5 phosphate-buffered conditions (Powner et al., 2009). Montmorillonite is included as a compatible concentrating mineral surface in drying surface settings."}, {"id": "rxn_008", "name": "Phosphate- and urea-mediated phosphorylation/stereoinversion to cytidine 2',3'-cyclic phosphate", "inputs": ["mol_013", "mol_014", "mol_015"], "outputs": ["mol_016"], "environment": "Surface", "agents": ["phosphate minerals (apatite/struvite)", "montmorillonite (clay)"], "conditions": {"temperature": "dry heating with urea; as reported in pathway", "pressure": "1 atm", "catalyst": "inorganic phosphate", "aqueous": "false", "other": "heating in urea-rich drying conditions; intramolecular SN2 inversion from arabino to ribo"}, "mechanism": "The anhydronucleoside is phosphorylated at the 3'-OH; phosphate-mediated intramolecular displacement at C2' inverts configuration and yields the ribo 2',3'-cyclic phosphate.", "reasoning": "This is the critical downstream Powner\u2013Sutherland step that resolves the stereochemistry and phosphorylation problems simultaneously and must not be skipped. The deep research report specifically identifies heating with inorganic phosphate in urea and intramolecular SN2 inversion as the established mechanism (Powner et al., 2009)."}, {"id": "rxn_009", "name": "Hydrolytic opening/dephosphorylation of cytidine 2',3'-cyclic phosphate to cytidine", "inputs": ["mol_016"], "outputs": ["mol_017"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "298-333K", "pressure": "1 atm", "catalyst": null, "aqueous": "true", "other": "prebiotic pool hydrolysis; mild aqueous conditions"}, "mechanism": "Aqueous ring opening and partial dephosphorylation convert activated cytidine cyclic phosphate into cytidine.", "reasoning": "The literature emphasizes that activated pyrimidine nucleotides are superior prebiotic targets to free cytosine; this biochemical connection step allows access to cytidine without contradicting that principle. It is a necessary network connector downstream of the established Powner product and is chemically consistent with nucleotide hydrolysis in aqueous prebiotic pools, though less specifically benchmarked than the core pathway (Powner et al., 2009; Gibard et al., 2018)."}, {"id": "rxn_010", "name": "Hydrolysis of cytidine to cytosine", "inputs": ["mol_017"], "outputs": ["mol_018"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "298-358K", "pressure": "1 atm", "catalyst": null, "aqueous": "true", "other": "slow hydrolytic cleavage of glycosidic bond; constrained by cytosine instability"}, "mechanism": "Hydrolytic cleavage of the N-glycosidic bond of cytidine releases free cytosine.", "reasoning": "This step is included only as the terminal access route to the requested target molecule. The deep research report strongly cautions that free cytosine is unstable and that prebiotic chemistry likely bypassed it, so this should be interpreted as a downstream release from a more stable nucleoside pool rather than the preferred primary target (Levy & Miller, 1998; Shapiro, 1999; Powner et al., 2009)."}, {"id": "rxn_011", "name": "Cyanoacetylene hydrolysis to cyanoacetaldehyde", "inputs": ["mol_012"], "outputs": ["mol_019"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "montmorillonite (clay)"], "conditions": {"temperature": "303K", "pressure": "1 atm", "catalyst": "mineral-rich aqueous pool surfaces", "aqueous": "true", "other": "alkaline to near-neutral aqueous pool; cyanoacetylene hydrolysis half-life about 11 days at pH 9, 30C"}, "mechanism": "Hydration/hydrolysis of cyanoacetylene yields cyanoacetaldehyde, a key direct precursor to pyrimidines.", "reasoning": "The deep research report identifies cyanoacetaldehyde as the hydrolysis product of cyanoacetylene and highlights its relative stability and centrality to the Robertson\u2013Miller pathway. Mineral agents are included to satisfy the required surface-mineral specification and to reflect plausible shoreline catalysis/concentration rather than a claim of unique catalytic necessity (Robertson & Miller, 1995; Nelson et al., 2001)."}, {"id": "rxn_012", "name": "Cyanoacetaldehyde plus concentrated urea to cytosine", "inputs": ["mol_019", "mol_015"], "outputs": ["mol_018"], "environment": "Surface", "agents": ["montmorillonite (clay)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "373K", "pressure": "1 atm", "catalyst": "drying, urea-rich evaporitic setting", "aqueous": "true", "other": "100C; 5-120 molal urea gives about 20-53% cytosine; dry-down with 2 M urea also productive"}, "mechanism": "Condensation of cyanoacetaldehyde with urea followed by ring closure furnishes cytosine directly.", "reasoning": "This is the highest-yield direct free-cytosine route documented in the literature and must be included as a major alternative branch. The exact productive conditions reported are concentrated urea at 100C and dry-down variants; mineral-rich evaporitic settings plausibly provide the necessary concentration mechanism (Robertson & Miller, 1995; Nelson et al., 2001; Cleaves et al., 2006)."}, {"id": "rxn_013", "name": "Cyanoacetylene plus cyanate to trans-cyanovinylurea", "inputs": ["mol_012", "mol_020"], "outputs": ["mol_021"], "environment": "Surface", "agents": ["phosphate minerals (apatite/struvite)", "montmorillonite (clay)"], "conditions": {"temperature": "373K", "pressure": "1 atm", "catalyst": "evaporitic concentration surfaces", "aqueous": "true", "other": "0.025 M cyanoacetylene and 0.05 M cyanate; 100C; 24 h"}, "mechanism": "Nucleophilic addition of cyanate to cyanoacetylene produces cyanovinylurea precursor.", "reasoning": "This is the first step of the original Sanchez\u2013Ferris\u2013Orgel cytosine synthesis. Because both reactants are unstable in water, the reaction is best framed in concentrated surface pools rather than oceans; mineral agents here represent concentrating shore minerals consistent with the required format (Sanchez et al., 1966; Sanchez et al., 1968)."}, {"id": "rxn_014", "name": "Cyclization of trans-cyanovinylurea to cytosine", "inputs": ["mol_021"], "outputs": ["mol_018"], "environment": "Surface", "agents": ["montmorillonite (clay)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "373K", "pressure": "1 atm", "catalyst": "alkaline drying pool conditions", "aqueous": "true", "other": "overall reported cytosine yield about 6% under standard conditions; isolated intermediate cyclizes efficiently in base"}, "mechanism": "Intramolecular cyclization of cyanovinylurea forms the pyrimidinone ring of cytosine.", "reasoning": "The classical Sanchez\u2013Ferris\u2013Orgel route specifically proceeds through trans-cyanovinylurea and then cyclization to cytosine, with isolated intermediate conversion reported at very high efficiency in base. This branch is retained as a documented classical alternative despite major environmental instability constraints (Sanchez et al., 1966; Sanchez et al., 1968)."}, {"id": "rxn_015", "name": "Cyanoacetaldehyde plus guanidine to 2,4-diaminopyrimidine", "inputs": ["mol_019", "mol_022"], "outputs": ["mol_023"], "environment": "Surface", "agents": ["montmorillonite (clay)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "concentrated drying conditions", "pressure": "1 atm", "catalyst": "drying lagoon concentration", "aqueous": "false", "other": "concentrated evaporative settings; high reported yields of 2,4-diaminopyrimidine"}, "mechanism": "Condensation of guanidine with cyanoacetaldehyde forms the diaminopyrimidine ring system.", "reasoning": "Ferris and coworkers established this route to 2,4-diaminopyrimidine, and Robertson et al. later reported high yields under concentrated drying-lagoon conditions. This step is well supported; the later conversion to cytosine is not fully selective and is treated accordingly (Ferris et al., 1974; Robertson et al., 1996)."}, {"id": "rxn_016", "name": "Partial hydrolysis of 2,4-diaminopyrimidine yielding cytosine among products", "inputs": ["mol_023"], "outputs": ["mol_018"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "ambient to mild heating", "pressure": "1 atm", "catalyst": null, "aqueous": "true", "other": "hydrolysis gives a mixture including cytosine, isocytosine, and uracil"}, "mechanism": "Aqueous hydrolysis/deamination of the diaminopyrimidine scaffold produces mixed pyrimidinones including cytosine.", "reasoning": "The literature explicitly states that hydrolysis of 2,4-diaminopyrimidine yields cytosine together with isocytosine and uracil; therefore this branch is included but deliberately not overstated as selective. It addresses a known alternative route while respecting the selectivity caveat emphasized by the research report (Ferris et al., 1974; Shapiro, 1999)."}, {"id": "rxn_017", "name": "HCN oligomerization to diaminomaleonitrile (DAMN)", "inputs": ["mol_006"], "outputs": ["mol_024"], "environment": "Surface", "agents": ["montmorillonite (clay)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "room temperature to eutectic freezing", "pressure": "1 atm", "catalyst": "none required chemically; mineral surfaces assist concentration", "aqueous": "true", "other": "0.1-1.0 M HCN or NH4CN; pH about 9.2; months in dark, or long-term eutectic freezing"}, "mechanism": "Stepwise HCN oligomerization proceeds through dimer and trimer intermediates to the HCN tetramer DAMN.", "reasoning": "Sanchez, Ferris, and Orgel established the HCN oligomerization sequence to DAMN. The deep research report stresses that this branch is real but poor for cytosine, serving instead as a branching HCN hub and low-probability source of trace canonical bases under special conditions (Sanchez et al., 1966; Sanchez et al., 1967; Miyakawa et al., 2002)."}, {"id": "rxn_018", "name": "Hydrolysis of HCN polymer/DAMN-derived material to trace cytosine and oxygenated pyrimidines", "inputs": ["mol_024"], "outputs": ["mol_018", "mol_025"], "environment": "Surface", "agents": ["montmorillonite (clay)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "room temperature after long freezing or long standing", "pressure": "1 atm", "catalyst": "alkaline hydrolysis workup", "aqueous": "true", "other": "trace cytosine only after long frozen NH4CN storage and hydrolysis; typical products are noncanonical pyrimidines"}, "mechanism": "Hydrolysis/oxidation of HCN oligomeric material yields mainly noncanonical oxygenated pyrimidines, with only trace cytosine under exceptional conditions.", "reasoning": "This reaction is intentionally conservative: the literature shows that direct HCN oligomerization does not efficiently produce cytosine, and hydrolysis normally gives noncanonical pyrimidines such as dihydroxypyrimidine, orotic acid, and 5-hydroxyuracil. Trace cytosine was observed only in the long-term frozen NH4CN experiment of Miyakawa et al.; this branch therefore exists but is low-yield and nonselective (Ferris et al., 1977; Ferris et al., 1978; Miyakawa et al., 2002)."}, {"id": "rxn_019", "name": "Thermal condensation of formamide to cytosine-containing nucleobase mixture", "inputs": ["mol_007"], "outputs": ["mol_027"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "montmorillonite (clay)"], "conditions": {"temperature": "433K", "pressure": "1 atm", "catalyst": "1-2 wt% mineral catalyst", "aqueous": "false", "other": "160C for 48 h in neat formamide; product distribution catalyst-dependent"}, "mechanism": "Thermal condensation of formamide on mineral surfaces produces a mixture of nucleobases including cytosine.", "reasoning": "Saladino and coworkers showed that neat formamide heated with mineral catalysts generates cytosine among other nucleobases, and TiO2- as well as montmorillonite-mediated variants are well documented. This branch is retained as a literature-supported alternative but not as a highly selective route (Saladino et al., 2001; Saladino et al., 2003; Saladino et al., 2004)."}, {"id": "rxn_020", "name": "Release of cytosine from formamide-derived nucleobase mixture", "inputs": ["mol_027"], "outputs": ["mol_018"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "298-333K", "pressure": "1 atm", "catalyst": null, "aqueous": "true", "other": "partitioning/accumulation from mixed heterocycle pool"}, "mechanism": "Physical separation and persistence of cytosine as one member of a mixed nucleobase condensate pool.", "reasoning": "Formamide chemistry produces complex mixtures rather than pure cytosine, so this connector simply represents the existence of cytosine in the product ensemble rather than an additional selective synthesis step. The deep research findings emphasize the selectivity problem for formamide condensations, which is preserved here (Saladino et al., 2001; Shapiro, 1999)."}, {"id": "rxn_021", "name": "DAP phosphorylation of cytidine to CMP/cyclic phosphate pool", "inputs": ["mol_017", "mol_026"], "outputs": ["mol_016", "mol_028"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "aqueous ambient to mild heating", "pressure": "1 atm", "catalyst": null, "aqueous": "true", "other": "DAP-mediated phosphorylation; pyrimidine ribonucleosides efficiently form 2',3'-cyclic phosphates"}, "mechanism": "Diamidophosphate transfers phosphate to cytidine, generating activated cytidine phosphate species including 2',3'-cyclic phosphate.", "reasoning": "DAP is identified in the deep research report as the leading geochemically plausible prebiotic phosphorylating agent and a key network hub. Including this step creates a second documented route from cytidine back to the activated cyclic phosphate pool and supports multiple target-access paths through nucleotide intermediates (Gibard et al., 2018; Pasek & Krishnamurthy, 2025)."}, {"id": "rxn_022", "name": "Hydrothermal pyruvate generation as cross-environment metabolic feedstock", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_003"], "environment": "Hydrothermal", "agents": ["magnetite (Fe3O4)", "greigite (Fe3S4)"], "conditions": {"temperatur
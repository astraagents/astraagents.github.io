,\n      \"iupac_name\": \"(2Z)-2,3-dihydroxybut-2-enedioic acid\",\n      \"common_name\": \"dihydroxyfumaric acid\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_017\",\n      \"formula\": \"C2H5O5P\",\n      \"iupac_name\": \"2-hydroxyacetaldehyde phosphate\",\n      \"common_name\": \"glycolaldehyde phosphate\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_018\",\n      \"formula\": \"C5H12O11P2\",\n      \"iupac_name\": \"ribose 2,4-bisphosphate\",\n      \"common_name\": \"ribose-2,4-bisphosphate\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_019\",\n      \"formula\": \"H3PO4\",\n      \"iupac_name\": \"phosphoric acid\",\n      \"common_name\": \"phosphate\",\n      \"inchi\": \"InChI=1S/H3O4P/c1-5(2,3)4/h(H3,1,2,3,4)\",\n      \"role\": \"starting\",\n      \"environment_formed\": null\n    },\n    {\n      \"id\": \"mol_020\",\n      \"formula\": \"H3BO3\",\n      \"iupac_name\": \"boric acid\",\n      \"common_name\": \"borate\",\n      \"inchi\": \"InChI=1S/BH3O3/c2-1(3)4/h2-4H\",\n      \"role\": \"starting\",\n      \"environment_formed\": null\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"Hydrothermal CO2 reduction to formate\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_003\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe3S4)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"greigite and mackinawite\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline vent conditions; H2-rich; anoxic\"\n      },\n      \"mechanism\": \"Mineral-surface electron transfer reduces CO2 to formate across Fe-S catalytic sites.\",\n      \"reasoning\": \"Included as the hydrothermal carbon-fixation entry point consistent with alkaline vent Fe-S catalysis and CO2 reduction chemistry discussed for greigite/mackinawite systems in the iron-sulfur world framework; this provides reduced carbon feedstock that can connect to later sugar chemistry, though direct coupling to ribose chemistry is an inferred network connection rather than a dedicated ribose paper result (Wachtershauser, 1988; Sojo et al., 2016).\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Hydrothermal reduction to formaldehyde\",\n      \"inputs\": [\"mol_003\", \"mol_002\"],\n      \"outputs\": [\"mol_004\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe3O4)\", \"elemental iron (Fe0)\"],\n      \"conditions\": {\n        \"temperature\": \"400-500K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"magnetite and Fe0\",\n        \"aqueous\": \"true\",\n        \"other\": \"subseafloor hydrothermal or vent-wall Fischer-Tropsch-type reduction under anoxic conditions\"\n      },\n      \"mechanism\": \"Further reduction of C1 oxycarbon species on reduced iron/mineral surfaces yields formaldehyde-equivalent carbonyl products.\",\n      \"reasoning\": \"Formaldehyde is required by all formose-family ribose routes and is prebiotically plausible from reduced C1 chemistry; hydrothermal mineral mediation is used here to connect vent carbon fixation to surface sugar chemistry. The specific hydrothermal conversion to formaldehyde is more speculative than atmospheric photochemical sources, but remains consistent with magnetite-mediated CO/CO2 hydrogenation chemistry noted in prebiotic carbon-fixation literature and with the report's emphasis that hydrothermal products can feed surface routes (Huber & Wachtershauser, 1997; Sojo et al., 2016; Pinto et al., 1980).\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Cyanide capture of formaldehyde to glycolonitrile\",\n      \"inputs\": [\"mol_004\", \"mol_005\"],\n      \"outputs\": [\"mol_006\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"sulfide minerals (molybdenite/stibnite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral-assisted concentration under UV-exposed evaporitic pools\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic UV-exposed surface waters; HCN scavenges formaldehyde strongly\"\n      },\n      \"mechanism\": \"Nucleophilic cyanohydrin formation traps formaldehyde as glycolonitrile, creating a stable branch-point for photoreductive homologation.\",\n      \"reasoning\": \"The report states that formaldehyde is efficiently scavenged by HCN to glycolonitrile with Keq = 4.6 \u00d7 10^5 M^-1, making this a major prebiotic branch point feeding photochemical sugar synthesis. Mineral agents are included to satisfy the required surface-agent constraint while remaining compatible with UV-irradiated surface settings emphasized for cyanosulfidic chemistry (Ritson & Sutherland, 2012; Ritson & Sutherland, 2013).\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"Photochemical reductive homologation of glycolonitrile to glycolaldehyde\",\n      \"inputs\": [\"mol_006\"],\n      \"outputs\": [\"mol_007\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (molybdenite/stibnite)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"ambient\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"UV photoredox with sulfide reductant in cyanide-rich surface waters\",\n        \"aqueous\": \"true\",\n        \"other\": \"254 nm UV; H2S as stoichiometric reductant; CuCN photoredox system implied by literature\"\n      },\n      \"mechanism\": \"UV-generated hydrated electrons drive reductive homologation of glycolonitrile, followed by hydrolysis to glycolaldehyde.\",\n      \"reasoning\": \"Directly grounded in the photochemical HCN homologation studies where glycolonitrile gives glycolaldehyde under 254 nm UV using CuCN photoredox chemistry and H2S as reductant, reaching ~42% glycolaldehyde yield after 4 h in the improved system (Ritson & Sutherland, 2012; Ritson & Sutherland, 2013).\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"Surface dimerization of formaldehyde to glycolaldehyde\",\n      \"inputs\": [\"mol_004\"],\n      \"outputs\": [\"mol_007\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"313-338K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"alkaline mineral-rich pool chemistry\",\n        \"aqueous\": \"true\",\n        \"other\": \"formose initiation step; rate-limiting dimerization; pH 9-12 depending on local pool composition\"\n      },\n      \"mechanism\": \"Two formaldehyde molecules undergo the slow initiation aldol chemistry that seeds the autocatalytic formose network by producing glycolaldehyde.\",\n      \"reasoning\": \"This is the classic Butlerow/Breslow initiation step of the formose reaction and is explicitly described as rate-limiting in the literature review. The report emphasizes that even trace glycolaldehyde initiates autocatalysis, making this a required convergence node for ribose-forming formose routes (Butlerow, 1861; Breslow, 1959; Appayee & Breslow, 2014).\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"Aldol homologation of glycolaldehyde with formaldehyde to glyceraldehyde\",\n      \"inputs\": [\"mol_007\", \"mol_004\"],\n      \"outputs\": [\"mol_009\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"313-338K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"alkaline formose conditions with borate stabilization where available\",\n        \"aqueous\": \"true\",\n        \"other\": \"pH 9-12; wet-dry concentration can enhance local flux\"\n      },\n      \"mechanism\": \"Aldol addition of glycolaldehyde and formaldehyde generates the C3 aldose glyceraldehyde, a central branch point in both formose and cyanosulfidic chemistry.\",\n      \"reasoning\": \"The Breslow formose cycle and subsequent ribose literature identify glyceraldehyde as the key C3 branch point produced from glycolaldehyde plus formaldehyde. Borate is literature-supported as a stabilizer of early formose intermediates and suppressor of decomposition (Breslow, 1959; Ricardo et al., 2004; Appayee & Breslow, 2014).\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Photochemical homologation to glyceraldehyde\",\n      \"inputs\": [\"mol_007\", \"mol_005\"],\n      \"outputs\": [\"mol_009\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (molybdenite/stibnite)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"ambient\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"UV photoredox in H2S/cyanide chemistry\",\n        \"aqueous\": \"true\",\n        \"other\": \"254 nm UV; glycolaldehyde cyanohydrin intermediate implied; ~17% glyceraldehyde reported after 2 h\"\n      },\n      \"mechanism\": \"HCN adds to glycolaldehyde, and the resulting cyanohydrin undergoes UV-driven reductive homologation and hydrolysis to give glyceraldehyde.\",\n      \"reasoning\": \"This reaction follows the Ritson-Sutherland photochemical reductive homologation sequence in which glycolaldehyde cyanohydrin is photoreduced to furnish glyceraldehyde under UV irradiation, providing a non-formose route into the C3 hub (Ritson & Sutherland, 2012; Ritson & Sutherland, 2013; Xu et al., 2018).\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Glycolaldehyde condensation with cyanamide to 2-aminooxazole\",\n      \"inputs\": [\"mol_007\", \"mol_008\", \"mol_019\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"phosphate minerals (apatite/struvite)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"phosphate as pH buffer and general acid-base catalyst\",\n        \"aqueous\": \"true\",\n        \"other\": \"near-neutral pH; concentrated surface pools\"\n      },\n      \"mechanism\": \"Condensation of glycolaldehyde with cyanamide under phosphate buffering forms the heterocycle 2-aminooxazole, locking carbon and nitrogen into a nucleotide precursor scaffold.\",\n      \"reasoning\": \"This is a central step of the Powner-Sutherland cyanosulfidic pathway. The literature explicitly identifies glycolaldehyde + cyanamide with inorganic phosphate catalysis as producing 2-aminooxazole, a key route that bypasses free ribose and channels carbon toward nucleotide synthesis (Powner et al., 2009; Anastasi et al., 2006; Patel et al., 2015).\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"Formation of ribose aminooxazoline from 2-aminooxazole and glyceraldehyde\",\n      \"inputs\": [\"mol_011\", \"mol_009\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"phosphate minerals (apatite/struvite)\", \"magnetite-enriched clay/mineral surfaces\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"surface-assisted concentration and crystallization\",\n        \"aqueous\": \"true\",\n        \"other\": \"reaction essentially quantitative; highly stereoselective for ribo/arabino aminooxazolines; magnetite surfaces may amplify enantioenrichment\"\n      },\n      \"mechanism\": \"2-Aminooxazole adds to glyceraldehyde to give pentose aminooxazolines, with ribose aminooxazoline produced as a selectively enriched and highly stable sugar carrier.\",\n      \"reasoning\": \"The report identifies this reaction as essentially quantitative and highly stereoselective, with ribose aminooxazoline as a robust carrier of ribose stereochemistry and a likely primary productive route for ribose emergence. Magnetite-mediated symmetry breaking is later literature on the same intermediate and is incorporated as compatible mineral context (Anastasi et al., 2006; Powner et al., 2009; Ozturk et al., 2023).\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"Hydrolytic liberation of ribose from ribose aminooxazoline\",\n      \"inputs\": [\"mol_012\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"273-298K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": null,\n        \"aqueous\": \"true\",\n        \"other\": \"mild aqueous hydrolysis in pools or mineral interfaces; rapid downstream trapping favored because free ribose is unstable\"\n      },\n      \"mechanism\": \"Hydrolytic opening and decomposition of the aminooxazoline scaffold releases free ribose-equivalent pentose carbon skeletons into solution.\",\n      \"reasoning\": \"The literature strongly favors avoiding free ribose, with aminooxazolines acting as stabilized intermediates en route to nucleotides. This hydrolytic release step is therefore included as a necessary connecting transformation to the requested ribose target, but it is more network-completion-oriented than the main productive cyanosulfidic route; the reasoning acknowledges that free ribose is likely transient and typically trapped downstream (Powner et al., 2009; Powner, 2017; Ritson & Sutherland, 2023).\"\n    },\n    {\n      \"id\": \"rxn_011\",\n      \"name\": \"Isomerization of glyceraldehyde to dihydroxyacetone\",\n      \"inputs\": [\"mol_009\"],\n      \"outputs\": [\"mol_010\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"313-338K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"Ca2+- and mineral-assisted aldose-ketose isomerization under formose conditions\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline pH; borate suppresses degradation while preserving electrophilic reactivity\"\n      },\n      \"mechanism\": \"Aldose-ketose isomerization converts glyceraldehyde to the thermodynamically favored ketotriose dihydroxyacetone through hydride-shift pathways.\",\n      \"reasoning\": \"The Breslow cycle and its modern re-analysis identify glyceraldehyde/dihydroxyacetone interconversion as part of the formose network, with Appayee and Breslow highlighting hydride-shift mechanisms and Ca2+ promotion. This branch is required for ribulose formation from C3 + C2 coupling (Breslow, 1959; Appayee & Breslow, 2014).\"\n    },\n    {\n      \"id\": \"rxn_012\",\n      \"name\": \"Ketose-forming aldol reaction to ribulose\",\n      \"inputs\": [\"mol_010\", \"mol_007\"],\n      \"outputs\": [\"mol_014\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite)\", \"tungstate/molybdate-bearing mineral phases\"],\n      \"conditions\": {\n        \"temperature\": \"313-338K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"alkaline aldol chemistry with oxometalate selectivity modifiers\",\n        \"aqueous\": \"true\",\n        \"other\": \"formose-family pentose generation; tungstate can bias ribose/ribulose-related selectivity\"\n      },\n      \"mechanism\": \"Aldol addition of dihydroxyacetone and glycolaldehyde produces pentuloses, including ribulose, which can serve as direct ribose precursors by isomerization.\",\n      \"reasoning\": \"The report explicitly states that dihydroxyacetone + glycolaldehyde gives ribulose, which then isomerizes to ribose. Tungstate and molybdate are included because recent work shows oxometalates direct pathway selectivity toward ribose-related products in formose-type systems (Breslow, 1959; Appayee & Breslow, 2014; Nishijima et al., 2026; Ziegler et al., 2018).\"\n    },\n    {\n      \"id\": \"rxn_013\",\n      \"name\": \"Isomerization of ribulose to ribose\",\n      \"inputs\": [\"mol_014\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite)\", \"tungstate/molybdate-bearing mineral phases\"],\n      \"conditions\": {\n        \"temperature\": \"298-338K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral-assisted ketose-aldose isomerization\",\n        \"aqueous\": \"true\",\n        \"other\": \"borate stabilization prolongs ribose lifetime after formation\"\n      },\n      \"mechanism\": \"Ketose-aldose rearrangement converts ribulose into aldopentose ribose, with borate trapping the more labile aldose product.\",\n      \"reasoning\": \"The report describes pentose formation through ribulose followed by isomerization to ribose in formose chemistry, and notes that borate selectively stabilizes ribose once generated. Tungstate is included because recent work indicates it preferentially supports ribose over xylose selectivity in related alkaline sugar-forming systems (Appayee & Breslow, 2014; Ricardo et al., 2004; Furukawa et al., 2013; Nishijima et al., 2026).\"\n    },\n    {\n      \"id\": \"rxn_014\",\n      \"name\": \"Direct aldol route from glycolaldehyde and glyceraldehyde to ribose\",\n      \"inputs\": [\"mol_007\", \"mol_009\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite)\", \"tungstate/molybdate-bearing mineral phases\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"surface aldol condensation with mineral selection pressures\",\n        \"aqueous\": \"true\",\n        \"other\": \"ribose reported at ~20% alongside arabinose ~14% in aldol route\"\n      },\n      \"mechanism\": \"Direct C2 + C3 aldol chemistry yields pentoses, including ribose, without requiring explicit passage through isolated ribulose.\",\n      \"reasoning\": \"Kofoed and co-workers are summarized in the report as showing that glycolaldehyde + glyceraldehyde gives ribose (~20%) and arabinose (~14%). This route is retained as an independent target-forming pathway distinct from the ribulose-explicit branch (Kofoed et al., 2005, as summarized in the review; Ricardo et al., 2004).\"\n    },\n    {\n      \"id\": \"rxn_015\",\n      \"name\": \"Borate-stabilized formose accumulation of ribose from formaldehyde and glycolaldehyde\",\n      \"inputs\": [\"mol_004\", \"mol_007\", \"mol_020\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite/kernite)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"313-338K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"borate-guided alkaline formose chemistry\",\n        \"aqueous\": \"true\",\n        \"other\": \"pH ~9 in borate-guided systems; formaldehyde 50-100 mM and glycolaldehyde ~5 mM in reported optimized studies\"\n      },\n      \"mechanism\": \"Formose aldolization generates pentoses while borate complexes cis-diols of glyceraldehyde and pentoses, suppressing enolization and tar formation so residual ribose accumulates.\",\n      \"reasoning\": \"This is the landmark borate-stabilized ribose route. Ricardo et al. showed borate minerals stabilize ribose, Furukawa et al. showed selective stabilization versus other aldopentoses, and Kim et al. demonstrated combined borate/molybdate/calcium guidance in hands-off pentose formation. The review highlights that borate lowers instantaneous yield but improves persistence over geologic timescales (Ricardo et al., 2004; Kim et al., 2011; Furukawa et al., 2013; Takahashi et al., 2026).\"\n    },\n    {\n      \"id\": \"rxn_016\",\n      \"name\": \"Dimerization of glyoxylate to dihydroxyfumaric acid\",\n      \"inputs\": [\"mol_015\"],\n      \"outputs\": [\"mol_016\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"concentration on mineral surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"carboxylated formaldehyde scenario; prebiotic source of DHF remains unresolved\"\n      },\n      \"mechanism\": \"Glyoxylate self-condenses to the highly reactive dihydroxyfumaric acid intermediate that seeds the Eschenmoser glyoxylate sugar network.\",\n      \"reasoning\": \"The report identifies DHF as the key intermediate of the glyoxylate scenario, formed by glyoxylate dimerization. It also explicitly notes that the prebiotic source of DHF remains an open problem, which is acknowledged here (Eschenmoser, 2007; Sagi et al., 2012).\"\n    },\n    {\n      \"id\": \"rxn_017\",\n      \"name\": \"Glyoxylate scenario formation of ribulose from DHF and glyceraldehyde\",\n      \"inputs\": [\"mol_016\", \"mol_009\"],\n      \"outputs\": [\"mol_014\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"aldol condensation with decarboxylative rearrangement on concentrated mineral interfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"clean ketosugar-forming chemistry; ~60% C5 ketosugars reported\"\n      },\n      \"mechanism\": \"DHF condenses with glyceraldehyde, followed by carbonyl migration and decarboxylation, producing ketosugars including ribulose with minimal side products.\",\n      \"reasoning\": \"This directly follows the Eschenmoser/Sagi glyoxylate scenario, which the report highlights as unusually clean chemistry yielding xylulose plus ribulose in ~60% total ketosugar yield, though requiring later isomerization to ribose (Eschenmoser, 2007; Sagi et al., 2012).\"\n    },\n    {\n      \"id\": \"rxn_018\",\n      \"name\": \"Phosphate-directed aldomerization of glycolaldehyde phosphate to ribose-2,4-bisphosphate\",\n      \"inputs\": [\"mol_017\"],\n      \"outputs\": [\"mol_018\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"phosphate minerals (apatite/struvite)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral-directed phosphate-rich aldomerization\",\n        \"aqueous\": \"true\",\n        \"other\": \"mangalite-like layered hydroxide context in literature; pentose-2,4-bisphosphates ~25% with ribose-2,4-bisphosphate 48% of pentose fraction\"\n      },\n      \"mechanism\": \"Phosphorylated glycolaldehyde undergoes controlled aldomerization; phosphate substitution suppresses uncontrolled enolization and channels the network toward pentose bisphosphates enriched in the ribose skeleton.\",\n      \"reasoning\": \"This reaction is based on the phosphate-directed aldomerization literature summarized in the report, where glycolaldehyde phosphate yields pentose-2,4-bisphosphates with notable selectivity for ribose-2,4-bisphosphate under mineral catalysis (Muller et al., 1990; Krishnamurthy, Arrhenius, & Eschenmoser, 1999).\"\n    },\n    {\n      \"id\": \"rxn_019\",\n      \"name\": \"Dephosphorylation/hydrolysis of ribose-2,4-bisphosphate to ribose\",\n      \"inputs\": [\"mol_018\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"298-333K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": null,\n        \"aqueous\": \"true\",\n        \"other\": \"pool or interface hydrolysis; free ribose likely transient and subject to rapid trapping\"\n      },\n      \"mechanism\": \"Hydrolytic loss of phosphate esters reveals the ribose backbone from a phosphate-protected pentose reservoir.\",\n      \"reasoning\": \"The phosphate-directed aldomerization literature establishes selective formation of ribose-2,4-bisphosphate, a protected ribose precursor. Dephosphorylation to free ribose is included as the minimal connecting step to the requested target, while acknowledging that the more prebiotically favored fate may have been direct incorporation into nucleotide chemistry rather than persistent free ribose (Muller et al., 1990; Krishnamurthy, Arrhenius, & Eschenmoser, 1999).\"\n    },\n    {\n      \"id\": \"rxn_020\",\n      \"name\": \"Borate-guided stabilization and persistence of free ribose\",\n      \"inputs\": [\"mol_013\", \"mol_020\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite/kernite)\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"298K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"borate complexation\",\n        \"aqueous\": \"true\",\n        \"other\": \"ribose lifetime extended from minutes to days at room temperature under alkaline conditions\"\n      },\n      \"mechanism\": \"Reversible borate complexation with cis-1,2-diols protects ribose from enolization, browning, and rapid decomposition, effectively trapping the target in a more persistent pool.\",\n      \"reasoning\": \"Although not a net synthetic transformation, this node is chemically essential to ribose persistence and therefore to any realistic ribose network. The report emphasizes that borate complexation is the single most important mineral stabilization effect for ribose accumulation and subsequent phosphorylation selectivity (Ricardo et al., 2004; Furukawa et al., 2013; Hirakawa et al., 2022).\"\n    }\n  ],\n  \"pathways\": [\n    {\n      \"pathway_id\": \"P1\",\n      \"name\": \"Classical formose to ribose via direct aldol route\",\n      \"description\": \"Hydrothermal formaldehyde supply feeds surface formose initiation, followed by aldol homologation to glycolaldehyde and glyceraldehyde, culminating in direct C2+C3 pentose formation.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_005\", \"rxn_006\", \"rxn_014\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_007\", \"mol_009\"]\n    },\n    {\n      \"pathway_id\": \"P2\",\n      \"name\": \"Formose ketose branch via ribulose\",\n      \"description\": \"Formaldehyde enters formose chemistry, glyceraldehyde isomerizes to dihydroxyacetone, and aldol chemistry produces ribulose that isomerizes to ribose.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_005\", \"rxn_006\", \"rxn_011\", \"rxn_012\", \"rxn_013\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_009\", \"mol_010\", \"mol_014\"]\n    },\n    {\n      \"pathway_id\": \"P3\",\n      \"name\": \"Borate-stabilized formose accumulation route\",\n      \"description\": \"Hydrothermal formaldehyde plus glycolaldehyde in borate-rich evaporitic pools yields ribose that persists because borate suppresses decomposition.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_005\", \"rxn_015\", \"rxn_020\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_007\", \"mol_013\"]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"Photochemical HCN homologation to direct aldol ribose\",\n      \"description\": \"Surface HCN chemistry converts formaldehyde into glycolonitrile, then UV photoreduction yields glycolaldehyde and glyceraldehyde, which combine to form ribose.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_004\", \"rxn_007\", \"rxn_014\"],\n      \"key_intermediates\": [\"mol_006\", \"mol_007\", \"mol_009\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"Photochemical HCN homologation through ribulose\",\n      \"description\": \"The same UV homologation sequence feeds the ketose branch, producing ribulose before final isomerization to ribose.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_004\", \"rxn_007\", \"rxn_011\", \"rxn_012\", \"rxn_013\"],\n      \"key_intermediates\": [\"mol_006\", \"mol_007\", \"mol_009\", \"mol_010\", \"mol_014\"]\n    },\n    {\n      \"pathway_id\": \"P6\",\n      \"name\": \"Cyanosulfidic aminooxazoline route to liberated ribose\",\n      \"description\": \"The primary productive systems-chemistry route avoids free ribose until a late hydrolytic release from ribose aminooxazoline.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_004\", \"rxn_008\", \"rxn_007\", \"rxn_009\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_011\", \"mol_009\", \"mol_012\"]\n    },\n    {\n      \"pathway_id\": \"P7\",\n      \"name\": \"Hybrid formose-cyanosulfidic route\",\n      \"description\": \"Formose-derived glycolaldehyde and glyceraldehyde are diverted into 2-aminooxazole and ribose aminooxazoline, then hydrolyzed to free ribose.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_005\", \"rxn_006\", \"rxn_008\", \"rxn_009\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_007\", \"mol_009\", \"mol_011\", \"mol_012\"]\n    },\n    {\n      \"pathway_id\": \"P8\",\n      \"name\": \"Eschenmoser glyoxylate-ribulose-ribose route\",\n      \"description\": \"Glyoxylate dimerizes to dihydroxyfumaric acid, which reacts cleanly with glyceraldehyde to give ribulose, then ribose.\",\n      \"reaction_sequence\": [\"rxn_016\", \"rxn_017\", \"rxn_013\"],\n      \"key_intermediates\": [\"mol_016\", \"mol_014\"]\n    },\n    {\n      \"pathway_id\": \"P9\",\n      \"name\": \"Phosphate-directed aldomerization route\",\n      \"description\": \"A phosphate-protected sugar network yields ribose-2,4-bisphosphate selectively, which hydrolyzes to ribose in prebiotic pools.\",\n      \"reaction_sequence\": [\"rxn_018\", \"rxn_019\"],\n      \"key_intermediates\": [\"mol_018\"]\n    },\n    {\n      \"pathway_id\": \"P10\",\n      \"name\": \"Hydrothermal-to-surface integrated ribose network\",\n      \"description\": \"Vent CO2 reduction supplies formaldehyde precursors that seed surface formose and photochemical pathways, converging through glycolaldehyde and glyceraldehyde to ribose.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_005\", \"rxn_006\", \"rxn_014\"],\n      \"key_intermediates\": [\"mol_003\", \"mol_004\", \"mol_007\", \"mol_009\"]\n    }\n  ],\n  \"hub_molecules\": [\"mol_004\", \"mol_007\", \"mol_009\", \"mol_012\", \"mol_014\"],\n  \"convergence_points\": [\n    {\n      \"molecule_id\": \"mol_007\",\n      \"incoming_reactions\": [\"rxn_004\", \"rxn_005\"],\n      \"outgoing_reactions\": [\"rxn_006\", \"rxn_007\", \"rxn_008\", \"rxn_012\", \"rxn_014\", \"rxn_015\"]\n    },\n    {\n      \"molecule_id\": \"mol_009\",\n      \"incoming_reactions\": [\"rxn_006\", \"rxn_007\"],\n      \"outgoing_reactions\": [\"rxn_009\", \"rxn_011\", \"rxn_014\", \"rxn_017\"]\n    },\n    {\n      \"molecule_id\": \"mol_014\",\n      \"incoming_reactions\": [\"rxn_012\", \"rxn_017\"],\n      \"outgoing_reactions\": [\"rxn_013\"]\n    },\n    {\n      \"molecule_id\": \"mol_013\",\n      \"incoming_reactions\": [\"rxn_010\", \"rxn_013\", \"rxn_014\", \"rxn_015\", \"rxn_019\"],\n      \"outgoing_reactions\": [\"rxn_020\"]\n    }\n  ]\n}", "parsed_response": {"target_molecule": "Ribose", "overall_strategy": "This network models ribose as an emergent product of interconnected prebiotic routes rather than a single selective synthesis. Hydrothermal chemistry supplies reduced C1-C3 feedstocks (formate, formaldehyde, glycolaldehyde) through Fe-S and magnetite catalysis; surface environments convert these into sugars and ribose-stabilized intermediates via formose, borate-stabilized formose, photochemical HCN homologation, phosphate-directed aldomerization, glyoxylate-derived ketosugar formation, and cyanosulfidic aminooxazoline chemistry; biochemical/prebiotic settings then liberate or trap ribose through hydrolysis, phosphorylation, and downstream assembly. The network emphasizes literature-supported hub molecules\u2014formaldehyde, glycolaldehyde, glyceraldehyde, ribulose, and ribose aminooxazoline\u2014as convergence points with multiple incoming and outgoing reactions, consistent with the view that ribose emergence required cascaded mineral selection pressures rather than a single pathway.", "molecules": [{"id": "mol_001", "formula": "CO2", "iupac_name": "carbon dioxide", "common_name": "carbon dioxide", "inchi": "InChI=1S/CO2/c2-1-3", "role": "starting", "environment_formed": null}, {"id": "mol_002", "formula": "H2", "iupac_name": "molecular hydrogen", "common_name": "hydrogen", "inchi": "InChI=1S/H2/h1H", "role": "starting", "environment_formed": null}, {"id": "mol_003", "formula": "CH2O2", "iupac_name": "methanoic acid", "common_name": "formate/formic acid", "inchi": "InChI=1S/CH2O2/c2-1-3/h1H,(H,2,3)", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_004", "formula": "CH2O", "iupac_name": "methanal", "common_name": "formaldehyde", "inchi": "InChI=1S/CH2O/c1-2/h1H2", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_005", "formula": "CHN", "iupac_name": "hydrogen cyanide", "common_name": "HCN", "inchi": "InChI=1S/CHN/c1-2/h1H", "role": "hub_intermediate", "environment_formed": null}, {"id": "mol_006", "formula": "C2H3NO", "iupac_name": "2-hydroxyacetonitrile", "common_name": "glycolonitrile", "inchi": "InChI=1S/C2H3NO/c3-1-2-4/h2,4H", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_007", "formula": "C2H4O2", "iupac_name": "2-hydroxyethanal", "common_name": "glycolaldehyde", "inchi": "InChI=1S/C2H4O2/c3-1-2-4/h1,3H,2H2", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_008", "formula": "CH2N2", "iupac_name": "cyanamide", "common_name": "cyanamide", "inchi": "InChI=1S/CH2N2/c2-1-3/h(H2,2,3)", "role": "starting", "environment_formed": null}, {"id": "mol_009", "formula": "C3H6O3", "iupac_name": "2,3-dihydroxypropanal", "common_name": "glyceraldehyde", "inchi": "InChI=1S/C3H6O3/c4-1-3(6)2-5/h1,3,5-6H,2H2", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_010", "formula": "C3H6O3", "iupac_name": "1,3-dihydroxypropan-2-one", "common_name": "dihydroxyacetone", "inchi": "InChI=1S/C3H6O3/c4-1-3(6)2-5/h4-6H,1-2H2", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_011", "formula": "C3H4N2O", "iupac_name": "2-amino-4,5-dihydro-1,3-oxazole", "common_name": "2-aminooxazole", "inchi": null, "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_012", "formula": "C5H8N2O3", "iupac_name": "pentose aminooxazoline", "common_name": "ribose aminooxazoline", "inchi": null, "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_013", "formula": "C5H10O5", "iupac_name": "2,3,4,5-tetrahydroxypentanal", "common_name": "ribose", "inchi": "InChI=1S/C5H10O5/c6-1-2(7)3(8)4(9)5(10)11/h1-10H", "role": "target", "environment_formed": "Biochemical"}, {"id": "mol_014", "formula": "C5H10O5", "iupac_name": "2,3,4,5-tetrahydroxypentan-2-one", "common_name": "ribulose", "inchi": null, "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_015", "formula": "C2H2O3", "iupac_name": "2-oxoacetic acid", "common_name": "glyoxylic acid", "inchi": "InChI=1S/C2H2O3/c3-1-2(4)5/h1H,(H,4,5)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_016", "formula": "C4H4O6", "iupac_name": "(2Z)-2,3-dihydroxybut-2-enedioic acid", "common_name": "dihydroxyfumaric acid", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_017", "formula": "C2H5O5P", "iupac_name": "2-hydroxyacetaldehyde phosphate", "common_name": "glycolaldehyde phosphate", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_018", "formula": "C5H12O11P2", "iupac_name": "ribose 2,4-bisphosphate", "common_name": "ribose-2,4-bisphosphate", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_019", "formula": "H3PO4", "iupac_name": "phosphoric acid", "common_name": "phosphate", "inchi": "InChI=1S/H3O4P/c1-5(2,3)4/h(H3,1,2,3,4)", "role": "starting", "environment_formed": null}, {"id": "mol_020", "formula": "H3BO3", "iupac_name": "boric acid", "common_name": "borate", "inchi": "InChI=1S/BH3O3/c2-1(3)4/h2-4H", "role": "starting", "environment_formed": null}], "reactions": [{"id": "rxn_001", "name": "Hydrothermal CO2 reduction to formate", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_003"], "environment": "Hydrothermal", "agents": ["greigite (Fe3S4)", "mackinawite (FeS)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "greigite and mackinawite", "aqueous": "true", "other": "alkaline vent conditions; H2-rich; anoxic"}, "mechanism": "Mineral-surface electron transfer reduces CO2 to formate across Fe-S catalytic sites.", "reasoning": "Included as the hydrothermal carbon-fixation entry point consistent with alkaline vent Fe-S catalysis and CO2 reduction chemistry discussed for greigite/mackinawite systems in the iron-sulfur world framework; this provides reduced carbon feedstock that can connect to later sugar chemistry, though direct coupling to ribose chemistry is an inferred network connection rather than a dedicated ribose paper result (Wachtershauser, 1988; Sojo et al., 2016)."}, {"id": "rxn_002", "name": "Hydrothermal reduction to formaldehyde", "inputs": ["mol_003", "mol_002"], "outputs": ["mol_004"], "environment": "Hydrothermal", "agents": ["magnetite (Fe3O4)", "elemental iron (Fe0)"], "conditions": {"temperature": "400-500K", "pressure": "high", "catalyst": "magnetite and Fe0", "aqueous": "true", "other": "subseafloor hydrothermal or vent-wall Fischer-Tropsch-type reduction under anoxic conditions"}, "mechanism": "Further reduction of C1 oxycarbon species on reduced iron/mineral surfaces yields formaldehyde-equivalent carbonyl products.", "reasoning": "Formaldehyde is required by all formose-family ribose routes and is prebiotically plausible from reduced C1 chemistry; hydrothermal mineral mediation is used here to connect vent carbon fixation to surface sugar chemistry. The specific hydrothermal conversion to formaldehyde is more speculative than atmospheric photochemical sources, but remains consistent with magnetite-mediated CO/CO2 hydrogenation chemistry noted in prebiotic carbon-fixation literature and with the report's emphasis that hydrothermal products can feed surface routes (Huber & Wachtershauser, 1997; Sojo et al., 2016; Pinto et al., 1980)."}, {"id": "rxn_003", "name": "Cyanide capture of formaldehyde to glycolonitrile", "inputs": ["mol_004", "mol_005"], "outputs": ["mol_006"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "sulfide minerals (molybdenite/stibnite)"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "mineral-assisted concentration under UV-exposed evaporitic pools", "aqueous": "true", "other": "anoxic UV-exposed surface waters; HCN scavenges formaldehyde strongly"}, "mechanism": "Nucleophilic cyanohydrin formation traps formaldehyde as glycolonitrile, creating a stable branch-point for photoreductive homologation.", "reasoning": "The report states that formaldehyde is efficiently scavenged by HCN to glycolonitrile with Keq = 4.6 \u00d7 10^5 M^-1, making this a major prebiotic branch point feeding photochemical sugar synthesis. Mineral agents are included to satisfy the required surface-agent constraint while remaining compatible with UV-irradiated surface settings emphasized for cyanosulfidic chemistry (Ritson & Sutherland, 2012; Ritson & Sutherland, 2013)."}, {"id": "rxn_004", "name": "Photochemical reductive homologation of glycolonitrile to glycolaldehyde", "inputs": ["mol_006"], "outputs": ["mol_007"], "environment": "Surface", "agents": ["sulfide minerals (molybdenite/stibnite)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "ambient", "pressure": "1 atm", "catalyst": "UV photoredox with sulfide reductant in cyanide-rich surface waters", "aqueous": "true", "other": "254 nm UV; H2S as stoichiometric reductant; CuCN photoredox system implied by literature"}, "mechanism": "UV-generated hydrated electrons drive reductive homologation of glycolonitrile, followed by hydrolysis to glycolaldehyde.", "reasoning": "Directly grounded in the photochemical HCN homologation studies where glycolonitrile gives glycolaldehyde under 254 nm UV using CuCN photoredox chemistry and H2S as reductant, reaching ~42% glycolaldehyde yield after 4 h in the improved system (Ritson & Sutherland, 2012; Ritson & Sutherland, 2013)."}, {"id": "rxn_005", "name": "Surface dimerization of formaldehyde to glycolaldehyde", "inputs": ["mol_004"], "outputs": ["mol_007"], "environment": "Surface", "agents": ["borate minerals (colemanite/ulexite)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "313-338K", "pressure": "1 atm", "catalyst": "alkaline mineral-rich pool chemistry", "aqueous": "true", "other": "formose initiation step; rate-limiting dimerization; pH 9-12 depending on local pool composition"}, "mechanism": "Two formaldehyde molecules undergo the slow initiation aldol chemistry that seeds the autocatalytic formose network by producing glycolaldehyde.", "reasoning": "This is the classic Butlerow/Breslow initiation step of the formose reaction and is explicitly described as rate-limiting in the literature review. The report emphasizes that even trace glycolaldehyde initiates autocatalysis, making this a required convergence node for ribose-forming formose routes (Butlerow, 1861; Breslow, 1959; Appayee & Breslow, 2014)."}, {"id": "rxn_006", "name": "Aldol homologation of glycolaldehyde with formaldehyde to glyceraldehyde", "inputs": ["mol_007", "mol_004"], "outputs": ["mol_009"], "environment": "Surface", "agents": ["borate minerals (colemanite/ulexite)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "313-338K", "pressure": "1 atm", "catalyst": "alkaline formose conditions with borate stabilization where available", "aqueous": "true", "other": "pH 9-12; wet-dry concentration can enhance local flux"}, "mechanism": "Aldol addition of glycolaldehyde and formaldehyde generates the C3 aldose glyceraldehyde, a central branch point in both formose and cyanosulfidic chemistry.", "reasoning": "The Breslow formose cycle and subsequent ribose literature identify glyceraldehyde as the key C3 branch point produced from glycolaldehyde plus formaldehyde. Borate is literature-supported as a stabilizer of early formose intermediates and suppressor of decomposition (Breslow, 1959; Ricardo et al., 2004; Appayee & Breslow, 2014)."}, {"id": "rxn_007", "name": "Photochemical homologation to glyceraldehyde", "inputs": ["mol_007", "mol_005"], "outputs": ["mol_009"], "environment": "Surface", "agents": ["sulfide minerals (molybdenite/stibnite)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "ambient", "pressure": "1 atm", "catalyst": "UV photoredox in H2S/cyanide chemistry", "aqueous": "true", "other": "254 nm UV; glycolaldehyde cyanohydrin intermediate implied; ~17% glyceraldehyde reported after 2 h"}, "mechanism": "HCN adds to glycolaldehyde, and the resulting cyanohydrin undergoes UV-driven reductive homologation and hydrolysis to give glyceraldehyde.", "reasoning": "This reaction follows the Ritson-Sutherland photochemical reductive homologation sequence in which glycolaldehyde cyanohydrin is photoreduced to furnish glyceraldehyde under UV irradiation, providing a non-formose route into the C3 hub (Ritson & Sutherland, 2012; Ritson & Sutherland, 2013; Xu et al., 2018)."}, {"id": "rxn_008", "name": "Glycolaldehyde condensation with cyanamide to 2-aminooxazole", "inputs": ["mol_007", "mol_008", "mol_019"], "outputs": ["mol_011"], "environment": "Surface", "agents": ["phosphate minerals (apatite/struvite)", "montmorillonite (clay)"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "phosphate as pH buffer and general acid-base catalyst", "aqueous": "true", "other": "near-neutral pH; concentrated surface pools"}, "mechanism": "Condensation of glycolaldehyde with cyanamide under phosphate buffering forms the heterocycle 2-aminooxazole, locking carbon and nitrogen into a nucleotide precursor scaffold.", "reasoning": "This is a central step of the Powner-Sutherland cyanosulfidic pathway. The literature explicitly identifies glycolaldehyde + cyanamide with inorganic phosphate catalysis as producing 2-aminooxazole, a key route that bypasses free ribose and channels carbon toward nucleotide synthesis (Powner et al., 2009; Anastasi et al., 2006; Patel et al., 2015)."}, {"id": "rxn_009", "name": "Formation of ribose aminooxazoline from 2-aminooxazole and glyceraldehyde", "inputs": ["mol_011", "mol_009"], "outputs": ["mol_012"], "environment": "Surface", "agents": ["phosphate minerals (apatite/struvite)", "magnetite-enriched clay/mineral surfaces"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "surface-assisted concentration and crystallization", "aqueous": "true", "other": "reaction essentially quantitative; highly stereoselective for ribo/arabino aminooxazolines; magnetite surfaces may amplify enantioenrichment"}, "mechanism": "2-Aminooxazole adds to glyceraldehyde to give pentose aminooxazolines, with ribose aminooxazoline produced as a selectively enriched and highly stable sugar carrier.", "reasoning": "The report identifies this reaction as essentially quantitative and highly stereoselective, with ribose aminooxazoline as a robust carrier of ribose stereochemistry and a likely primary productive route for ribose emergence. Magnetite-mediated symmetry breaking is later literature on the same intermediate and is incorporated as compatible mineral context (Anastasi et al., 2006; Powner et al., 2009; Ozturk et al., 2023)."}, {"id": "rxn_010", "name": "Hydrolytic liberation of ribose from ribose aminooxazoline", "inputs": ["mol_012"], "outputs": ["mol_013"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "273-298K", "pressure": "1 atm", "catalyst": null, "aqueous": "true", "other": "mild aqueous hydrolysis in pools or mineral interfaces; rapid downstream trapping favored because free ribose is unstable"}, "mechanism": "Hydrolytic opening and decomposition of the aminooxazoline scaffold releases free ribose-equivalent pentose carbon skeletons into solution.", "reasoning": "The literature strongly favors avoiding free ribose, with aminooxazolines acting as stabilized intermediates en route to nucleotides. This hydrolytic release step is therefore included as a necessary connecting transformation to the requested ribose target, but it is more network-completion-oriented than the main productive cyanosulfidic route; the reasoning acknowledges that free ribose is likely transient and typically trapped downstream (Powner et al., 2009; Powner, 2017; Ritson & Sutherland, 2023)."}, {"id": "rxn_011", "name": "Isomerization of glyceraldehyde to dihydroxyacetone", "inputs": ["mol_009"], "outputs": ["mol_010"], "environment": "Surface", "agents": ["borate minerals (colemanite/ulexite)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "313-338K", "pressure": "1 atm", "catalyst": "Ca2+- and mineral-assisted aldose-ketose isomerization under formose conditions", "aqueous": "true", "other": "alkaline pH; borate suppresses degradation while preserving electrophilic reactivity"}, "mechanism": "Aldose-ketose isomerization converts glyceraldehyde to the thermodynamically favored ketotriose dihydroxyacetone through hydride-shift pathways.", "reasoning": "The Breslow cycle and its modern re-analysis identify glyceraldehyde/dihydroxyacetone interconversion as part of the formose network, with Appayee and Breslow highlighting hydride-shift mechanisms and Ca2+ promotion. This branch is required for ribulose formation from C3 + C2 coupling (Breslow, 1959; Appayee & Breslow, 2014)."}, {"id": "rxn_012", "name": "Ketose-forming aldol reaction to ribulose", "inputs": ["mol_010", "mol_007"], "outputs": ["mol_014"], "environment": "Surface", "agents": ["borate minerals (colemanite/ulexite)", "tungstate/molybdate-bearing mineral phases"], "conditions": {"temperature": "313-338K", "pressure": "1 atm", "catalyst": "alkaline aldol chemistry with oxometalate selectivity modifiers", "aqueous": "true", "other": "formose-family pentose generation; tungstate can bias ribose/ribulose-related selectivity"}, "mechanism": "Aldol addition of dihydroxyacetone and glycolaldehyde produces pentuloses, including ribulose, which can serve as direct ribose precursors by isomerization.", "reasoning": "The report explicitly states that dihydroxyacetone + glycolaldehyde gives ribulose, which then isomerizes to ribose. Tungstate and molybdate are included because recent work shows oxometalates direct pathway selectivity toward ribose-related products in formose-type systems (Breslow, 1959; Appayee & Breslow, 2014; Nishijima et al., 2026; Ziegler et al., 2018)."}, {"id": "rxn_013", "name": "Isomerization of ribulose to ribose", "inputs": ["mol_014"], "outputs": ["mol_013"], "environment": "Surface", "agents": ["borate minerals (colemanite/ulexite)", "tungstate/molybdate-bearing mineral phases"], "conditions": {"temperature": "298-338K", "pressure": "1 atm", "catalyst": "mineral-assisted ketose-aldose isomerization", "aqueous": "true", "other": "borate stabilization prolongs ribose lifetime after formation"}, "mechanism": "Ketose-aldose rearrangement converts ribulose into aldopentose ribose, with borate trapping the more labile aldose product.", "reasoning": "The report describes pentose formation through ribulose followed by isomerization to ribose in formose chemistry, and notes that borate selectively stabilizes ribose once generated. Tungstate is included because recent work indicates it preferentially supports ribose over xylose selectivity in related alkaline sugar-forming systems (Appayee & Breslow, 2014; Ricardo et al., 2004; Furukawa et al., 2013; Nishijima et al., 2026)."}, {"id": "rxn_014", "name": "Direct aldol route from glycolaldehyde and glyceraldehyde to ribose", "inputs": ["mol_007", "mol_009"], "outputs": ["mol_013"], "environment": "Surface", "agents": ["borate minerals (colemanite/ulexite)", "tungstate/molybdate-bearing mineral phases"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "surface aldol condensation with mineral selection pressures", "aqueous": "true", "other": "ribose reported at ~20% alongside arabinose ~14% in aldol route"}, "mechanism": "Direct C2 + C3 aldol chemistry yields pentoses, including ribose, without requiring explicit passage through isolated ribulose.", "reasoning": "Kofoed and co-workers are summarized in the report as showing that glycolaldehyde + glyceraldehyde gives ribose (~20%) and arabinose (~14%). This route is retained as an independent target-forming pathway distinct from the ribulose-explicit branch (Kofoed et al., 2005, as summarized in the review; Ricardo et al., 2004)."}, {"id": "rxn_015", "name": "Borate-stabilized formose accumulation of ribose from formaldehyde and glycolaldehyde", "inputs": ["mol_004", "mol_007", "mol_020"], "outputs": ["mol_013"], "environment": "Surface", "agents": ["borate minerals (colemanite/ulexite/kernite)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "313-338K", "pressure": "1 atm", "catalyst": "borate-guided alkaline formose chemistry", "aqueous": "true", "other": "pH ~9 in borate-guided systems; formaldehyde 50-100 mM and glycolaldehyde ~5 mM in reported optimized studies"}, "mechanism": "Formose aldolization generates pentoses while borate complexes cis-diols of glyceraldehyde and pentoses, suppressing enolization and tar formation so residual ribose accumulates.", "reasoning": "This is the landmark borate-stabilized ribose route. Ricardo et al. showed borate minerals stabilize ribose, Furukawa et al. showed selective stabilization versus other aldopentoses, and Kim et al. demonstrated combined borate/molybdate/calcium guidance in hands-off pentose formation. The review highlights that borate lowers instantaneous yield but improves persistence over geologic timescales (Ricardo et al., 2004; Kim et al., 2011; Furukawa et al., 2013; Takahashi et al., 2026)."}, {"id": "rxn_016", "name": "Dimerization of glyoxylate to dihydroxyfumaric acid", "inputs": ["mol_015"], "outputs": ["mol_016"], "environment": "Surface", "agents": ["borate minerals (colemanite/ulexite)", "montmorillonite (clay)"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "concentration on mineral surfaces", "aqueous": "true", "other": "carboxylated formaldehyde scenario; prebiotic source of DHF remains unresolved"}, "mechanism": "Glyoxylate self-condenses to the highly reactive dihydroxyfumaric acid intermediate that seeds the Eschenmoser glyoxylate sugar network.", "reasoning": "The report identifies DHF as the key intermediate of the glyoxylate scenario, formed by glyoxylate dimerization. It also explicitly notes that the prebiotic source of DHF remains an open problem, which is acknowledged here (Eschenmoser, 2007; Sagi et al., 2012)."}, {"id": "rxn_017", "name": "Glyoxylate scenario formation of ribulose from DHF and glyceraldehyde", "inputs": ["mol_016", "mol_009"], "outputs": ["mol_014"], "environment": "Surface", "agents": ["borate minerals (colemanite/ulexite)", "montmorillonite (clay)"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "aldol condensation with decarboxylative rearrangement on concentrated mineral interfaces", "aqueous": "true", "other": "clean ketosugar-forming chemistry; ~60% C5 ketosugars reported"}, "mechanism": "DHF condenses with glyceraldehyde, followed by carbonyl migration and decarboxylation, producing ketosugars including ribulose with minimal side products.", "reasoning": "This directly follows the Eschenmoser/Sagi glyoxylate scenario, which the report highlights as unusually clean chemistry yielding xylulose plus ribulose in ~60% total ketosugar yield, though requiring later isomerization to ribose (Eschenmoser, 2007; Sagi et al., 2012)."}, {"id": "rxn_018", "name": "Phosphate-directed aldomerization of glycolaldehyde phosphate to ribose-2,4-bisphosphate", "inputs": ["mol_017"], "outputs": ["mol_018"], "environment": "Surface", "agents": ["phosphate minerals (apatite/struvite)", "montmorillonite (clay)"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "mineral-directed phosphate-rich aldomerization", "aqueous": "true", "other": "mangalite-like layered hydroxide context in literature; pentose-2,4-bisphosphates ~25% with ribose-2,4-bisphosphate 48% of pentose fraction"}, "mechanism": "Phosphorylated glycolaldehyde undergoes controlled aldomerization; phosphate substitution suppresses uncontrolled enolization and channels the network toward pentose bisphosphates enriched in the ribose skeleton.", "reasoning": "This reaction is based on the phosphate-directed aldomerization literature summarized in the report, where glycolaldehyde phosphate yields pentose-2,4-bisphosphates with notable selectivity for ribose-2,4-bisphosphate under mineral catalysis (Muller et al., 1990; Krishnamurthy, Arrhenius, & Eschenmoser, 1999)."}, {"id": "rxn_019", "name": "Dephosphorylation/hydrolysis of ribose-2,4-bisphosphate to ribose", "inputs": ["mol_018"], "outputs": ["mol_013"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "298-333K", "pressure": "1 atm", "catalyst": null, "aqueous": "true", "other": "pool or interface hydrolysis; free ribose likely transient and subject to rapid trapping"}, "mechanism": "Hydrolytic loss of phosphate esters reveals the ribose backbone from a phosphate-protected pentose reservoir.", "reasoning": "The phosphate-directed aldomerization literature establishes selective formation of ribose-2,4-bisphosphate, a protected ribose precursor. Dephosphorylation to free ribose is included as the minimal connecting step to the requested target, while acknowledging that the more prebiotically favored fate may have been direct incorporation into nucleotide chemistry rather than persistent free ribose (Muller et al., 1990; Krishnamurthy, Arrhenius, & Eschenmoser, 1999)."}, {"id": "rxn_020", "name": "Borate-guided stabilization and persistence of free ribose", "inputs": ["mol_013", "mol_020"], "outputs": ["mol_013"], "environment": "Surface", "agents": ["borate minerals (colemanite/ulexite/kernite)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "298K", "pressure": "1 atm", "catalyst": "borate complexation", "aqueous": "true", "other": "ribose lifetime extended from minutes to days at room temperature under alkaline conditions"}, "mechanism": "Reversible borate complexation with cis-1,2-diols protects ribose from enolization, browning, and rapid decomposition, effectively trapping the target in a more persistent pool.", "reasoning": "Although not a net synthetic transformation, this node is chemically essential to ribose persistence and therefore to any realistic ribose network. The report emphasizes that borate complexation is the single most important mineral stabilization effect for ribose accumulation and subsequent phosphorylation selectivity (Ricardo et al., 2004; Furukawa et al., 2013; Hirakawa et al., 2022)."}], "pathways": [{"pathway_id": "P1", "name": "Classical formose to ribose via direct aldol route", "description": "Hydrothermal formaldehyde supply feeds surface formose initiation, followed by aldol homologation to glycolaldehyde and glyceraldehyde, culminating in direct C2+C3 pentose formation.", "reaction_sequence": ["rxn_002", "rxn_005", "rxn_006", "rxn_014"], "key_intermediates": ["mol_004", "mol_007", "mol_009"]}, {"pathway_id": "P2", "name": "Formose ketose branch via ribulose", "description": "Formaldehyde enters formose chemistry, glyceraldehyde isomerizes to dihydroxyacetone, and aldol chemistry produces ribulose that isomerizes to ribose.", "reaction_sequence": ["rxn_002", "rxn_005", "rxn_006", "rxn_011", "rxn_012", "rxn_013"], "key_intermediates": ["mol_007", "mol_009", "mol_010", "mol_014"]}, {"pathway_id": "P3", "name": "Borate-stabilized formose accumulation route", "description": "Hydrothermal formaldehyde plus glycolaldehyde in borate-rich evaporitic pools yields ribose that persists because borate suppresses decomposition.", "reaction_sequence": ["rxn_002", "rxn_005", "rxn_015", "rxn_020"], "key_intermediates": ["mol_004", "mol_007", "mol_013"]}, {"pathway_id": "P4", "name": "Photochemical HCN homologation to direct aldol ribose", "description": "Surface HCN chemistry converts formaldehyde into glycolonitrile, then UV photoreduction yields glycolaldehyde and glyceraldehyde, which combine to form ribose.", "reaction_sequence": ["rxn_003", "rxn_004", "rxn_007", "rxn_014"], "key_intermediates": ["mol_006", "mol_007", "mol_009"]}, {"pathway_id": "P5", "name": "Photochemical HCN homologation through ribulose", "description": "The same UV homologation sequence feeds the ketose branch, producing ribulose before final isomerization to ribose.", "reaction_sequence": ["rxn_003", "rxn_004", "rxn_007", "rxn_011", "rxn_012", "rxn_013"], "key_intermediates": ["mol_006", "mol_007", "mol_009", "mol_010", "mol_014"]}, {"pathway_id": "P6", "name": "Cyanosulfidic aminooxazoline route to liberated ribose", "description": "The primary productive systems-chemistry route avoids free ribose until a late hydrolytic release from ribose aminooxazoline.", "reaction_sequence": ["rxn_003", "rxn_004", 
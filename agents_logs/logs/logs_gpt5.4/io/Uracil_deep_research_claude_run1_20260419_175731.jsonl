1", "mol_009", "mol_018"]}, {"pathway_id": "P3", "name": "Direct dry-down uracil from cyanoacetaldehyde and urea", "description": "The Robertson-Miller system yields a small amount of uracil directly during evaporative heating without requiring separate isolation of cytosine.", "reaction_sequence": ["rxn_003", "rxn_006", "rxn_007", "rxn_008", "rxn_012"], "key_intermediates": ["mol_006", "mol_011", "mol_009"]}, {"pathway_id": "P4", "name": "Formamide-montmorillonite thermolysis route", "description": "HCN hydrolyzes to formamide, which upon heating on montmorillonite in fumarolic or drying settings yields uracil.", "reaction_sequence": ["rxn_003", "rxn_004", "rxn_014"], "key_intermediates": ["mol_006", "mol_008"]}, {"pathway_id": "P5", "name": "TiO2-assisted photothermal formamide route", "description": "Hydrothermal formaldehyde feeds surface formamide/TiO2 photochemistry, leading to uracil-family pyrimidines under UV irradiation.", "reaction_sequence": ["rxn_002", "rxn_003", "rxn_004", "rxn_015"], "key_intermediates": ["mol_004", "mol_006", "mol_008"]}, {"pathway_id": "P6", "name": "Impact-plasma formamide synthesis", "description": "Formamide exposed to plasma or proton irradiation in the presence of meteoritic minerals yields uracil directly.", "reaction_sequence": ["rxn_003", "rxn_004", "rxn_016"], "key_intermediates": ["mol_006", "mol_008"]}, {"pathway_id": "P7", "name": "DAMN photothermal pyrimidine branch", "description": "Concentrated HCN oligomerizes to DAMN, which under photothermal conditions gives pyrimidines including cytosine and uracil.", "reaction_sequence": ["rxn_003", "rxn_005", "rxn_017"], "key_intermediates": ["mol_006", "mol_013", "mol_018"]}, {"pathway_id": "P8", "name": "Alkaline hydrothermal cyanide polymerization route", "description": "Under simulated alkaline hydrothermal conditions, cyanide polymerization on iron-sulfur minerals yields uracil directly together with orotic acid.", "reaction_sequence": ["rxn_003", "rxn_018"], "key_intermedi
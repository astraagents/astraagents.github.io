l_015\",\n      \"formula\": \"C4H6N2O2\",\n      \"iupac_name\": \"hexahydropyrimidine-2,4-dione\",\n      \"common_name\": \"dihydrouracil\",\n      \"inchi\": \"InChI=1S/C4H6N2O2/c7-3-1-2-5-4(8)6-3/h1-2H2,(H2,5,6,7,8)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_016\",\n      \"formula\": \"C2H4O2\",\n      \"iupac_name\": \"2-hydroxyethanal\",\n      \"common_name\": \"glycolaldehyde\",\n      \"inchi\": \"InChI=1S/C2H4O2/c3-1-2-4/h1,3H,2H2\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_017\",\n      \"formula\": \"CH2N2\",\n      \"iupac_name\": \"cyanamide\",\n      \"common_name\": \"cyanamide\",\n      \"inchi\": \"InChI=1S/CH2N2/c2-1-3/h(H2,2,3)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_018\",\n      \"formula\": \"C3H6O3\",\n      \"iupac_name\": \"2,3-dihydroxypropanal\",\n      \"common_name\": \"glyceraldehyde\",\n      \"inchi\": \"InChI=1S/C3H6O3/c4-1-3(6)2-5/h1,3,5-6H,2H2\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_019\",\n      \"formula\": \"C3H4N2O\",\n      \"iupac_name\": \"2-amino-4,5-dihydro-1,3-oxazole\",\n      \"common_name\": \"2-aminooxazole\",\n      \"inchi\": \"InChI=1S/C3H4N2O/c4-3-5-1-2-6-3/h1-2H2,(H2,4,5)\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_020\",\n      \"formula\": \"C5H8N2O2\",\n      \"iupac_name\": \"pentose aminooxazoline ensemble\",\n      \"common_name\": \"ribose aminooxazoline family\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_021\",\n      \"formula\": \"C9H12N3O6P\",\n      \"iupac_name\": \"beta-ribocytidine-2',3'-cyclic phosphate\",\n      \"common_name\": \"cytidine cyclic phosphate\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_022\",\n      \"formula\": \"C9H11N2O7P\",\n      \"iupac_name\": \"beta-ribouridine-2',3'-cyclic phosphate\",\n      \"common_name\": \"uridine cyclic phosphate\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_023\",\n      \"formula\": \"C9H12N2O6\",\n      \"iupac_name\": \"1-beta-D-ribofuranosylpyrimidine-2,4-dione\",\n      \"common_name\": \"uridine\",\n      \"inchi\": \"InChI=1S/C9H12N2O6/c12-3-5-6(13)7(14)9(17-5)11-2-1-4(15)10-8(11)16/h1-2,5-7,9,12-14H,3H2,(H,10,15,16)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_024\",\n      \"formula\": \"C9H13N2O9P\",\n      \"iupac_name\": \"uridine monophosphate\",\n      \"common_name\": \"UMP\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_025\",\n      \"formula\": \"[(UMP)n]\",\n      \"iupac_name\": \"oligouridylate\",\n      \"common_name\": \"poly(U)-like oligonucleotide\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_026\",\n      \"formula\": \"C4H3N3O2\",\n      \"iupac_name\": \"2,4-dioxo-1,2,3,4-tetrahydropyrimidine-6-carboxylic acid\",\n      \"common_name\": \"orotic acid\",\n      \"inchi\": \"InChI=1S/C5H4N2O4/c8-3-1-2(5(10)11)6-4(9)7-3/h1H,(H,10,11)(H2,6,7,8,9)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_027\",\n      \"formula\": \"C4H4N2O2\",\n      \"iupac_name\": \"extraterrestrial uracil\",\n      \"common_name\": \"meteoritic uracil reservoir\",\n      \"inchi\": \"InChI=1S/C4H4N2O2/c7-3-1-2-5-4(8)6-3/h1-2H,(H2,5,6,7,8)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"Hydrothermal CO2 reduction to formate\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_003\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe3S4)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"greigite/mackinawite\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline vent-like H2-rich conditions; serpentinization-linked reducing environment\"\n      },\n      \"mechanism\": \"Mineral-surface reduction of CO2 by H2 on Fe-S phases generates formate as a reduced one-carbon feedstock.\",\n      \"reasoning\": \"Hydrothermal Fe-S catalysis and alkaline vent carbon fixation are consistent with iron-sulfur world and vent studies summarized in the report; formate production on greigite/mackinawite is used here only as an experimentally grounded hydrothermal feeder into downstream formamide chemistry, not as an invented uracil route (Huber & Wachtershauser, 1997; Herschy et al., 2014; Walton et al., 2022).\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Hydrothermal formaldehyde/glycolaldehyde generation by Fischer-Tropsch-type reduction\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_016\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe3O4)\", \"elemental iron (Fe0)\"],\n      \"conditions\": {\n        \"temperature\": \"400-500K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"magnetite/Fe0\",\n        \"aqueous\": \"true\",\n        \"other\": \"subseafloor or vent-proximal reduction chemistry producing small oxygenates\"\n      },\n      \"mechanism\": \"CO2/H2 reduction on iron-bearing mineral surfaces yields reduced carbonyl compounds including glycolaldehyde-type products that can be transferred to surface pools.\",\n      \"reasoning\": \"This reaction provides the glycolaldehyde input required by the Powner-Sutherland pathway while keeping the hydrothermal contribution limited to small reduced carbon compounds rather than unsupported direct uracil synthesis from vent feedstocks. Mineral-mediated reduced carbon generation is consistent with vent Fischer-Tropsch-type literature and the systems framing in the report (Huber & Wachtershauser, 1997; Herschy et al., 2014).\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Surface concentration of formamide from one-carbon feedstocks\",\n      \"inputs\": [\"mol_003\"],\n      \"outputs\": [\"mol_004\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase)\", \"borate minerals (colemanite/ulexite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO2/borate-assisted evaporative concentration\",\n        \"aqueous\": \"true\",\n        \"other\": \"evaporation and thermophoretic enrichment in volcanic/fumarolic or pore settings over days to months\"\n      },\n      \"mechanism\": \"Reduced one-carbon species are concentrated in surface geothermal settings to formamide-rich residues that become reactive under subsequent heating.\",\n      \"reasoning\": \"The report emphasizes that formamide concentration, not bulk synthesis in oceans, is the key problem; thermophoresis and evaporation can enrich formamide to reactive levels in hydrothermal rock pores and fumarolic settings. This connector is explicitly marked as a concentration/availability step needed to link hydrothermal feedstocks to the well-supported formamide uracil chemistry (Niether et al., 2016; Saladino et al., 2004; Ferus et al., 2017).\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"Formamide thermolysis on montmorillonite to uracil\",\n      \"inputs\": [\"mol_004\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"borate minerals (colemanite/ulexite)\"],\n      \"conditions\": {\n        \"temperature\": \"140-160C\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite\",\n        \"aqueous\": \"false\",\n        \"other\": \"fumarolic or volcanic dry-heating conditions; borate can modulate product distribution\"\n      },\n      \"mechanism\": \"Thermal condensation and rearrangement of formamide on clay surfaces yield pyrimidinones including uracil.\",\n      \"reasoning\": \"Direct uracil production from heated formamide on mineral catalysts is experimentally demonstrated; montmorillonite is specifically reported to yield uracil, and borates broaden product distributions. This is one of the best-supported free-uracil routes in volcanic settings (Saladino et al., 2004; Saladino et al., 2011).\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"Formamide photocatalysis on TiO2 yielding uracil-family products\",\n      \"inputs\": [\"mol_004\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase)\", \"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"140-160C with UV <380 nm\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO2\",\n        \"aqueous\": \"false\",\n        \"other\": \"volcanic ash or beach-sand photocatalysis; formaldehyde-generating photochemistry\"\n      },\n      \"mechanism\": \"TiO2 photocatalysis drives radical and carbonyl chemistry in heated formamide, producing pyrimidine derivatives including uracil-related products.\",\n      \"reasoning\": \"The literature shows TiO2 is a distinctive catalyst in formamide chemistry and changes product distributions via photocatalytic formaldehyde generation. The route is included as a separate pathway to the same target because the catalyst and mechanism differ from montmorillonite thermolysis (Saladino et al., 2003; Senanayake & Idriss, 2006).\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"Impact/plasma activation of formamide to uracil\",\n      \"inputs\": [\"mol_004\"],\n      \"outputs\": [\"mol_012\", \"mol_023\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase)\", \"sulfide minerals (meteorite powder analogs)\"],\n      \"conditions\": {\n        \"temperature\": \"273K to plasma-heated transient conditions\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"powdered meteorite/mineral surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"laser-induced plasma or proton irradiation; CN\u00b7 and NH\u00b7 radical formation\"\n      },\n      \"mechanism\": \"Energetic dissociation of formamide generates CN and NH radicals that recombine into nucleobases; in meteoritic mineral contexts nucleosides including uridine can also form.\",\n      \"reasoning\": \"This route follows the high-energy formamide literature and is kept distinct from thermal mineral-catalyzed formamide chemistry. It is one of the strongest demonstrations that uracil and uridine-related compounds can arise from a shared energetic process (Ferus et al., 2015; Saladino et al., 2015).\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Cyanoacetylene hydrolysis to cyanoacetaldehyde\",\n      \"inputs\": [\"mol_006\"],\n      \"outputs\": [\"mol_010\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"TiO2 (anatase)\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral surfaces aiding concentration and hydrolysis\",\n        \"aqueous\": \"true\",\n        \"other\": \"aqueous surface pools; cyanoacetaldehyde is ~1000-fold more stable than cyanoacetylene in water\"\n      },\n      \"mechanism\": \"Water addition to cyanoacetylene produces the more persistent electrophile cyanoacetaldehyde.\",\n      \"reasoning\": \"The report explicitly identifies cyanoacetaldehyde as the hydrolysis product of cyanoacetylene and as the practical entry point to high-yield Robertson-Miller pyrimidine synthesis. Minerals here are specified to satisfy the network schema, but the key support is the documented aqueous conversion and stability relationship (Robertson & Miller, 1995; Nelson et al., 2001).\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Cyanoacetylene plus cyanate to cytosine\",\n      \"inputs\": [\"mol_006\", \"mol_007\"],\n      \"outputs\": [\"mol_009\", \"mol_011\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"100C, 24 h\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral concentration surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"0.025 M cyanoacetylene + 0.05 M cyanate; cyanovinylurea intermediate cyclizes to cytosine\"\n      },\n      \"mechanism\": \"Cyanoacetylene reacts with cyanate to form trans-cyanovinylurea, followed by intramolecular cyclization to cytosine.\",\n      \"reasoning\": \"This is the classic Ferris-Sanchez-Orgel pathway and is represented with its reported concentrations and temperature. Its main weakness, acknowledged in the report, is the implausible need for high cyanate concentrations; nevertheless it is a foundational literature-supported uracil precursor route (Ferris et al., 1968; Sanchez, Ferris & Orgel, 1966).\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"Cyanoacetaldehyde plus concentrated urea to cytosine and minor uracil\",\n      \"inputs\": [\"mol_010\", \"mol_008\"],\n      \"outputs\": [\"mol_011\", \"mol_012\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"100C over dry-down to 3 days\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"evaporitic concentration on mineral surfaces\",\n        \"aqueous\": \"false\",\n        \"other\": \"saturated or highly concentrated urea in evaporating lagoon conditions; reported 30-50% cytosine, with minor direct uracil on dry-down\"\n      },\n      \"mechanism\": \"Condensation of cyanoacetaldehyde with concentrated urea gives cytosine efficiently; prolonged dry-down also yields some uracil directly.\",\n      \"reasoning\": \"This is the highest-yield free-pyrimidine route in the literature and is the central surface pathway in the network. The direct minor uracil component under dry-down is explicitly noted in the report and kept separate from cytosine deamination (Robertson & Miller, 1995; Nelson et al., 2001).\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"Hydrolytic deamination of cytosine to uracil\",\n      \"inputs\": [\"mol_011\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"0-100C\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": null,\n        \"aqueous\": \"true\",\n        \"other\": \"hydrolytic deamination; half-life depends strongly on temperature\"\n      },\n      \"mechanism\": \"Water-mediated deamination of the exocyclic amino group on cytosine gives uracil.\",\n      \"reasoning\": \"Cytosine deamination is one of the most secure uracil-forming processes and explains why uracil is found where cytosine is absent in meteorites. Temperature-dependent instability is central to the literature critique and defense of cytosine-based routes (Levy & Miller, 1998; Shapiro, 1999; Wolfenden et al., 2016).\"\n    },\n    {\n      \"id\": \"rxn_011\",\n      \"name\": \"HCN tetramerization to DAMN\",\n      \"inputs\": [\"mol_005\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"TiO2 (anatase)\"],\n      \"conditions\": {\n        \"temperature\": \"room temperature\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral concentration surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"0.1-1.0 M HCN, pH ~9\"\n      },\n      \"mechanism\": \"Base-promoted oligomerization of HCN yields the tetramer diaminomaleonitrile.\",\n      \"reasoning\": \"DAMN is explicitly described in the report as a major branch point from concentrated cyanide chemistry. This node is included as a hub but not overinterpreted as a selective uracil precursor on its own (Hill & Orgel, 2002; Bizzarri et al., 2022).\"\n    },\n    {\n      \"id\": \"rxn_012\",\n      \"name\": \"Photothermal DAMN chemistry to pyrimidine derivatives including uracil\",\n      \"inputs\": [\"mol_013\"],\n      \"outputs\": [\"mol_012\", \"mol_011\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase)\", \"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"photothermal, 300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"UV-active mineral surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"product selectivity depends on thermal vs photochemical energy input\"\n      },\n      \"mechanism\": \"Photothermal multicomponent cyanide-derived chemistry channels DAMN toward pyrimidine products rather than the imidazole/purine products favored thermally.\",\n      \"reasoning\": \"The report warns against a simplistic direct DAMN-to-uracil claim; accordingly this reaction is framed as a diversity-generating pyrimidine branch that can include uracil and cytosine under photothermal conditions rather than a single high-yield targeted synthesis (Bizzarri et al., 2022).\"\n    },\n    {\n      \"id\": \"rxn_013\",\n      \"name\": \"Alkaline cyanide polymerization under moderate hydrothermal-like conditions to uracil and orotic acid\",\n      \"inputs\": [\"mol_005\"],\n      \"outputs\": [\"mol_012\", \"mol_026\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"pyrite (FeS2)\", \"greigite (Fe3S4)\"],\n      \"conditions\": {\n        \"temperature\": \"80C\",\n        \"pressure\": \"1 bar\",\n        \"catalyst\": \"iron-sulfur mineral surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"simulated alkaline hydrothermal/subaerial vent conditions; pyrimidines favored over triazines\"\n      },\n      \"mechanism\": \"Cyanide oligomerization and rearrangement in moderately warm alkaline settings generate pyrimidine products including uracil and orotic acid.\",\n      \"reasoning\": \"This route is included with corrected environmental framing: not black-smoker high-temperature vent chemistry, but moderate alkaline hydrothermal/subaerial conditions as emphasized in the report. It is a direct literature-supported uracil route (Scientific Reports, 2022; Herschy et al., 2014).\"\n    },\n    {\n      \"id\": \"rxn_014\",\n      \"name\": \"Ice eutectic cyanide chemistry to cytosine and uracil\",\n      \"inputs\": [\"mol_005\", \"mol_008\"],\n      \"outputs\": [\"mol_011\", \"mol_012\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite)\", \"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"subzero eutectic freezing\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"solute concentration in ice films\",\n        \"aqueous\": \"true\",\n        \"other\": \"frozen urea solutions under reductive atmosphere; room-temperature controls fail to produce pyrimidines\"\n      },\n      \"mechanism\": \"Freezing excludes solutes into concentrated liquid films where cyanide/urea chemistry yields pyrimidines including cytosine and uracil.\",\n      \"reasoning\": \"Ice eutectic concentration is highlighted in the report as one of the most plausible demonstrated ways to overcome dilution and promote HCN polymerization. Menor-Salvan et al. specifically report cytosine and uracil from frozen urea solutions, making this a distinct route (Miyakawa et al., 2002; Menor-Salvan et al., 2009).\"\n    },\n    {\n      \"id\": \"rxn_015\",\n      \"name\": \"Beta-alanine plus urea dry-down to dihydrouracil\",\n      \"inputs\": [\"mol_014\", \"mol_008\"],\n      \"outputs\": [\"mol_015\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"mild heating in evaporating pool\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"clay-assisted dry-down\",\n        \"aqueous\": \"false\",\n        \"other\": \"warm little pond or lagoon evaporation\"\n      },\n      \"mechanism\": \"Condensation of \u03b2-alanine with urea under dehydration yields the reduced pyrimidine dihydrouracil.\",\n      \"reasoning\": \"This is the Chittenden-Schwartz wet-dry surface pathway and is one of the strongest non-cytosine-based routes to uracil precursors. Clay participation is literature-supported in the follow-up Schwartz & Chittenden work (Chittenden & Schwartz, 1976; Schwartz & Chittenden, 1977).\"\n    },\n    {\n      \"id\": \"rxn_016\",\n      \"name\": \"UV oxidation of dihydrouracil to uracil\",\n      \"inputs\": [\"mol_015\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase)\", \"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"280-330K under UV\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"UV-exposed mineral surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"surface pool photochemistry\"\n      },\n      \"mechanism\": \"Photochemical dehydrogenation/aromatization of dihydrouracil yields uracil.\",\n      \"reasoning\": \"The report explicitly states that UV irradiation converts dihydrouracil to uracil in this surface-pool pathway. This route is therefore kept as a two-step alternative to cytosine-mediated uracil formation (Chittenden & Schwartz, 1976; Schwartz & Chittenden, 1977).\"\n    },\n    {\n      \"id\": \"rxn_017\",\n      \"name\": \"Phosphate-catalyzed formation of 2-aminooxazole\",\n      \"inputs\": [\"mol_016\", \"mol_017\"],\n      \"outputs\": [\"mol_019\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"phosphate minerals (apatite/struvite)\", \"borate minerals (colemanite/ulexite)\"],\n      \"conditions\": {\n        \"temperature\": \"ambient to mild warming\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"phosphate\",\n        \"aqueous\": \"true\",\n        \"other\": \"near-neutral buffered conditions; UV-sensitive intermediate\"\n      },\n      \"mechanism\": \"Glycolaldehyde condenses with cyanamide under phosphate catalysis to give 2-aminooxazole.\",\n      \"reasoning\": \"This is the entry reaction of the Powner-Sutherland bypass strategy. It is included to connect hydrothermal reduced-carbon supply to surface nucleotide-fragment assembly without misrepresenting the route as free-uracil synthesis (Powner et al., 2009; Todd et al., 2019).\"\n    },\n    {\n      \"id\": \"rxn_018\",\n      \"name\": \"2-Aminooxazole plus glyceraldehyde to pentose aminooxazolines\",\n      \"inputs\": [\"mol_019\", \"mol_018\"],\n      \"outputs\": [\"mol_020\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"phosphate minerals (apatite/struvite)\", \"borate minerals (colemanite/ulexite)\"],\n      \"conditions\": {\n        \"temperature\": \"ambient\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"phosphate-buffered and borate-modulated\",\n        \"aqueous\": \"true\",\n        \"other\": \"pH ~7 favors ribose aminooxazoline\"\n      },\n      \"mechanism\": \"Carbon-carbon bond formation and cyclization generate pentose aminooxazolines, with phosphate controlling speciation and ribose aminooxazoline favored near neutral pH.\",\n      \"reasoning\": \"This step is a core part of the Powner-Sutherland pathway and is important because it builds sugar and base fragments together, addressing the glycosylation problem discussed in the report (Powner et al., 2009; Ricardo et al., 2004).\"\n    },\n    {\n      \"id\": \"rxn_019\",\n      \"name\": \"Cyanoacetylene incorporation and phosphorylation to cytidine cyclic phosphate\",\n      \"inputs\": [\"mol_020\", \"mol_006\"],\n      \"outputs\": [\"mol_021\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"ambient to mild warming\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"phosphate in solution\",\n        \"aqueous\": \"true\",\n        \"other\": \"through anhydronucleoside intermediates followed by phosphorylation\"\n      },\n      \"mechanism\": \"Pentose aminooxazoline derivatives react with cyanoacetylene to form anhydronucleosides, which phosphate converts into activated cytidine cyclic phosphate.\",\n      \"reasoning\": \"This reaction collapses the established later stages of the Powner pathway into one node for network economy while preserving the correct logic: cyanoacetylene is incorporated before activated ribocytidine phosphate formation. It intentionally does not generate free uracil (Powner et al., 2009; Xu et al., 2017).\"\n    },\n    {\n      \"id\": \"rxn_020\",\n      \"name\": \"UV photoanomerization and partial deamination to uridine cyclic phosphate\",\n      \"inputs\": [\"mol_021\"],\n      \"outputs\": [\"mol_022\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"ambient under 254 nm UV\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": null,\n        \"aqueous\": \"true\",\n        \"other\": \"photoanomerization with partial C-to-U deamination\"\n      },\n      \"mechanism\": \"Ultraviolet irradiation converts the cytidine cyclic phosphate derivative to the beta-anomer and partially deaminates the base to produce uridine cyclic phosphate.\",\n      \"reasoning\": \"The report highlights this exact transformation as the key result of the Powner-Sutherland revolution: activated uridine nucleotides arise without ever requiring free uracil glycosylation. This corrects the prior failed attempt (Powner et al., 2009; Xu et al., 2017).\"\n    },\n    {\n      \"id\": \"rxn_021\",\n      \"name\": \"Hydrolysis/opening of uridine cyclic phosphate to uridine\",\n      \"inputs\": [\"mol_022\"],\n      \"outputs\": [\"mol_023\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"ambient to mild warming\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": null,\n        \"aqueous\": \"true\",\n        \"other\": \"prebiotic pool hydrolysis\"\n      },\n      \"mechanism\": \"Hydrolytic ring opening of activated uridine phosphate gives uridine.\",\n      \"reasoning\": \"This connector is not the focal discovery of the Powner pathway but is a necessary downstream hydrolysis step linking activated uridine phosphate to later phosphorylation/polymerization chemistry. It is included as a conservative completion step rather than a novel free-base route; downstream uridine chemistry is supported by phosphorylation/polymerization studies (Gibard et al., 2018; Ferris, 2002).\"\n    },\n    {\n      \"id\": \"rxn_022\",\n      \"name\": \"Prebiotic phosphorylation of uridine to UMP\",\n      \"inputs\": [\"mol_023\"],\n      \"outputs\": [\"mol_024\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"60-80C or paste conditions over days\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"schreibersite or diamidophosphate chemistry\",\n        \"aqueous\": \"true\",\n        \"other\": \"schreibersite gives low yields; diamidophosphate can give high cyclic phosphate conversion\"\n      },\n      \"mechanism\": \"Phosphorylation of uridine forms monophosphate products suitable for oligomerization.\",\n      \"reasoning\": \"The report documents uridine phosphorylation by schreibersite and highly efficient phosphorylation/cyclophosphorylation by diamidophosphate. This establishes a uracil-derived nucleotide branch relevant to biochemical assembly (Gull et al., 2015; Gibard et al., 2018; Casta\u00f1eda et al., 2019).\"\n    },\n    {\n      \"id\": \"rxn_023\",\n      \"name\": \"Montmorillonite-assisted oligomerization of uridine phosphates\",\n      \"inputs\": [\"mol_024\"],\n      \"outputs\": [\"mol_025\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"ambient to geothermal cycling\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite interfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"rate of oligomerization exceeds hydrolysis; uridine oligomers up to 25-30 mers reported\"\n      },\n      \"mechanism\": \"Clay-templated condensation/polymerization of activated uridine phosphate monomers forms short oligonucleotides.\",\n      \"reasoning\": \"Ferris demonstrated montmorillonite-catalyzed oligomerization of activated uridine nucleotides, and Ross & Deamer extended wet-dry polymerization from uridine monophosphate. This provides the biochemical endpoint connected to uracil chemistry (Ferris, 2002; Ross & Deamer, 2024).\"\n    },\n    {\n      \"id\": \"rxn_024\",\n      \"name\": \"Extraterrestrial delivery of uracil to surface reservoirs\",\n      \"inputs\": [\"mol_027\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"borate minerals (colemanite/ulexite)\"],\n      \"conditions\": {\n        \"temperature\": \"ambient\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"surface adsorption/concentration on minerals\",\n        \"aqueous\": \"true\",\n        \"other\": \"meteoritic deposition into warm ponds or sediments; ppb-scale uracil detected in Ryugu\"\n      },\n      \"mechanism\": \"Delivered extraterrestrial uracil is released from meteoritic material and concentrated in surface reservoirs.\",\n      \"reasoning\": \"The report makes clear that extraterrestrial uracil is real and likely contributed to prebiotic inventories. This is a source pathway, not a synthesis step, but it is experimentally grounded and relevant to network completeness (Oba et al., 2023; Koga et al., 2026).\"\n    }\n  ],\n  \"pathways\": [\n    {\n      \"pathway_id\": \"P1\",\n      \"name\": \"Ferris-Sanchez-Orgel cyanate route\",\n      \"description\": \"Cyanoacetylene reacts with cyanate to form a cyanovinylurea intermediate ensemble that cyclizes to cytosine; cytosine then hydrolytically deaminates to uracil.\",\n      \"reaction_sequence\": [\"rxn_008\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_009\", \"mol_011\"]\n    },\n    {\n      \"pathway_id\": \"P2\",\n      \"name\": \"Robertson-Miller evaporating lagoon route\",\n      \"description\": \"Cyanoacetaldehyde generated from cyanoacetylene reacts with concentrated urea during dry-down to yield cytosine efficiently and minor uracil directly; cytosine hydrolysis completes the route.\",\n      \"reaction_sequence\": [\"rxn_007\", \"rxn_009\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_010\", \"mol_011\", \"mol_008\"]\n    },\n    {\n      \"pathway_id\": \"P3\",\n      \"name\": \"Robertson-Miller direct minor uracil branch\",\n      \"description\": \"The same cyanoacetaldehyde + urea dry-down chemistry yields a small amount of uracil directly without requiring separate cytosine hydrolysis.\",\n      \"reaction_sequence\": [\"rxn_007\", \"rxn_009\"],\n      \"key_intermediates\": [\"mol_010\", \"mol_008\"]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"Formamide thermolysis on montmorillonite\",\n      \"description\": \"Formamide enriched in fumarolic or evaporative settings is heated on montmorillonite to produce uracil directly.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_004\"],\n      \"key_intermediates\": [\"mol_004\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"TiO2-assisted formamide photochemistry\",\n      \"description\": \"Formamide undergoes photocatalytic reaction on TiO2 under UV-active volcanic surface conditions, producing uracil-family products including uracil.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_005\"],\n      \"key_intermediates\": [\"mol_004\"]\n    },\n    {\n      \"pathway_id\": \"P6\",\n      \"name\": \"Energetic formamide impact/plasma route\",\n      \"description\": \"High-energy activation of formamide by plasma or proton irradiation produces uracil directly and can also generate uridine-related products.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_006\"],\n      \"key_intermediates\": [\"mol_004\"]\n    },\n    {\n      \"pathway_id\": \"P7\",\n      \"name\": \"DAMN photothermal pyrimidine branch\",\n      \"description\": \"Concentrated HCN oligomerizes to DAMN, which under photothermal conditions gives pyrimidine derivatives including uracil and cytosine.\",\n      \"reaction_sequence\": [\"rxn_011\", \"rxn_012\"],\n      \"key_intermediates\": [\"mol_013\"]\n    },\n    {\n      \"pathway_id\": \"P8\",\n      \"name\": \"Moderate alkaline hydrothermal cyanide polymerization\",\n      \"description\": \"Under simulated alkaline hydrothermal/subaerial vent conditions, cyanide polymerization yields uracil directly along with orotic acid.\",\n      \"reaction_sequence\": [\"rxn_013\"],\n      \"key_intermediates\": [\"mol_026\"]\n    },\n    {\n      \"pathway_id\": \"P9\",\n      \"name\": \"Ice eutectic cyanide-urea pathway\",\n      \"description\": \"Freeze-concentration of cyanide and urea in eutectic films yields cytosine and uracil, with cytosine also feeding secondary deamination to uracil.\",\n      \"reaction_sequence\": [\"rxn_014\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_011\", \"mol_008\"]\n    },\n    {\n      \"pathway_id\": \"P10\",\n      \"name\": \"Beta-alanine surface-pool route\",\n      \"description\": \"Beta-alanine condenses with urea during dry-down to dihydrouracil, which UV irradiation converts to uracil.\",\n      \"reaction_sequence\": [\"rxn_015\", \"rxn_016\"],\n      \"key_intermediates\": [\"mol_015\", \"mol_008\"]\n    }\n  ],\n  \"hub_molecules\": [\"mol_004\", \"mol_008\", \"mol_011\", \"mol_012\", \"mol_006\"],\n  \"convergence_points\": [\n    {\n      \"molecule_id\": \"mol_012\",\n      \"incoming_reactions\": [\"rxn_004\", \"rxn_005\", \"rxn_006\", \"rxn_009\", \"rxn_010\", \"rxn_012\", \"rxn_013\", \"rxn_014\", \"rxn_016\", \"rxn_024\"],\n      \"outgoing_reactions\": []\n    },\n    {\n      \"molecule_id\": \"mol_011\",\n      \"incoming_reactions\": [\"rxn_008\", \"rxn_009\", \"rxn_012\", \"rxn_014\"],\n      \"outgoing_reactions\": [\"rxn_010\"]\n    },\n    {\n      \"molecule_id\": \"mol_004\",\n      \"incoming_reactions\": [\"rxn_003\"],\n      \"outgoing_reactions\": [\"rxn_004\", \"rxn_005\", \"rxn_006\"]\n    },\n    {\n      \"molecule_id\": \"mol_008\",\n      \"incoming_reactions\": [],\n      \"outgoing_reactions\": [\"rxn_009\", \"rxn_014\", \"rxn_015\"]\n    },\n    {\n      \"molecule_id\": \"mol_006\",\n      \"incoming_reactions\": [],\n      \"outgoing_reactions\": [\"rxn_007\", \"rxn_008\", \"rxn_019\"]\n    }\n  ]\n}", "parsed_response": {"target_molecule": "Uracil", "overall_strategy": "This network treats uracil synthesis as a literature-grounded systems problem rather than a single linear route. It uses experimentally supported terrestrial routes centered on cyanoacetylene/cyanoacetaldehyde, concentrated urea, formamide thermochemistry, \u03b2-alanine + urea condensation, cyanide polymerization under moderate alkaline hydrothermal-like settings, ice-eutectic cyanide chemistry, and extraterrestrial delivery. It also includes the Powner-Sutherland bypass as a connected uracil-related branch that converges on uridine nucleotide chemistry without incorrectly forcing free uracil release. Hydrothermal nodes supply reduced carbon feedstocks and concentration mechanisms that feed surface chemistry, while surface products feed biochemical assembly of uridine phosphate and uridine oligomers.", "molecules": [{"id": "mol_001", "formula": "CO2", "iupac_name": "carbon dioxide", "common_name": "carbon dioxide", "inchi": "InChI=1S/CO2/c2-1-3", "role": "starting", "environment_formed": null}, {"id": "mol_002", "formula": "H2", "iupac_name": "molecular hydrogen", "common_name": "hydrogen", "inchi": "InChI=1S/H2/h1H", "role": "starting", "environment_formed": null}, {"id": "mol_003", "formula": "CH2O2", "iupac_name": "methanoic acid", "common_name": "formic acid/formate", "inchi": "InChI=1S/CH2O2/c2-1-3/h1H,(H,2,3)", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_004", "formula": "CH3NO", "iupac_name": "formamide", "common_name": "formamide", "inchi": "InChI=1S/CH3NO/c2-1-3/h1H,(H2,2,3)", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_005", "formula": "CHN", "iupac_name": "hydrogen cyanide", "common_name": "HCN", "inchi": "InChI=1S/CHN/c1-2/h1H", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_006", "formula": "C3HN", "iupac_name": "prop-2-ynenitrile", "common_name": "cyanoacetylene", "inchi": "InChI=1S/C3HN/c1-2-3-4/h1H", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_007", "formula": "CHNO", "iupac_name": "cyanate", "common_name": "cyanate", "inchi": "InChI=1S/CHNO/c2-1-3/h1H", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_008", "formula": "CH4N2O", "iupac_name": "carbamide", "common_name": "urea", "inchi": "InChI=1S/CH4N2O/c2-1(3)4/h(H4,2,3,4)", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_009", "formula": "C3H2N2O", "iupac_name": "2-oxo-3-propenenitrile amide precursor ensemble", "common_name": "cyanovinylurea ensemble", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_010", "formula": "C3H2N2O", "iupac_name": "2-cyanoethanal", "common_name": "cyanoacetaldehyde", "inchi": "InChI=1S/C3H3NO/c4-2-1-3-5/h1,3H", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_011", "formula": "C4H5N3O", "iupac_name": "4-aminopyrimidin-2(1H)-one", "common_name": "cytosine", "inchi": "InChI=1S/C4H5N3O/c5-3-1-2-6-4(8)7-3/h1-2H,(H3,5,6,7,8)", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_012", "formula": "C4H4N2O2", "iupac_name": "pyrimidine-2,4(1H,3H)-dione", "common_name": "uracil", "inchi": "InChI=1S/C4H4N2O2/c7-3-1-2-5-4(8)6-3/h1-2H,(H2,5,6,7,8)", "role": "target", "environment_formed": "Surface"}, {"id": "mol_013", "formula": "C4H4N4", "iupac_name": "2,3-diaminobut-2-enedinitrile", "common_name": "DAMN", "inchi": "InChI=1S/C4H4N4/c5-1-3(7)4(8)2-6/h7-8H2", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_014", "formula": "C3H7NO2", "iupac_name": "3-aminopropanoic acid", "common_name": "beta-alanine", "inchi": "InChI=1S/C3H7NO2/c4-2-1-3(5)6/h1-2,4H2,(H,5,6)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_015", "formula": "C4H6N2O2", "iupac_name": "hexahydropyrimidine-2,4-dione", "common_name": "dihydrouracil", "inchi": "InChI=1S/C4H6N2O2/c7-3-1-2-5-4(8)6-3/h1-2H2,(H2,5,6,7,8)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_016", "formula": "C2H4O2", "iupac_name": "2-hydroxyethanal", "common_name": "glycolaldehyde", "inchi": "InChI=1S/C2H4O2/c3-1-2-4/h1,3H,2H2", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_017", "formula": "CH2N2", "iupac_name": "cyanamide", "common_name": "cyanamide", "inchi": "InChI=1S/CH2N2/c2-1-3/h(H2,2,3)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_018", "formula": "C3H6O3", "iupac_name": "2,3-dihydroxypropanal", "common_name": "glyceraldehyde", "inchi": "InChI=1S/C3H6O3/c4-1-3(6)2-5/h1,3,5-6H,2H2", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_019", "formula": "C3H4N2O", "iupac_name": "2-amino-4,5-dihydro-1,3-oxazole", "common_name": "2-aminooxazole", "inchi": "InChI=1S/C3H4N2O/c4-3-5-1-2-6-3/h1-2H2,(H2,4,5)", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_020", "formula": "C5H8N2O2", "iupac_name": "pentose aminooxazoline ensemble", "common_name": "ribose aminooxazoline family", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_021", "formula": "C9H12N3O6P", "iupac_name": "beta-ribocytidine-2',3'-cyclic phosphate", "common_name": "cytidine cyclic phosphate", "inchi": null, "role": "intermediate", "environment_formed": "Biochemical"}, {"id": "mol_022", "formula": "C9H11N2O7P", "iupac_name": "beta-ribouridine-2',3'-cyclic phosphate", "common_name": "uridine cyclic phosphate", "inchi": null, "role": "intermediate", "environment_formed": "Biochemical"}, {"id": "mol_023", "formula": "C9H12N2O6", "iupac_name": "1-beta-D-ribofuranosylpyrimidine-2,4-dione", "common_name": "uridine", "inchi": "InChI=1S/C9H12N2O6/c12-3-5-6(13)7(14)9(17-5)11-2-1-4(15)10-8(11)16/h1-2,5-7,9,12-14H,3H2,(H,10,15,16)", "role": "intermediate", "environment_formed": "Biochemical"}, {"id": "mol_024", "formula": "C9H13N2O9P", "iupac_name": "uridine monophosphate", "common_name": "UMP", "inchi": null, "role": "intermediate", "environment_formed": "Biochemical"}, {"id": "mol_025", "formula": "[(UMP)n]", "iupac_name": "oligouridylate", "common_name": "poly(U)-like oligonucleotide", "inchi": null, "role": "intermediate", "environment_formed": "Biochemical"}, {"id": "mol_026", "formula": "C4H3N3O2", "iupac_name": "2,4-dioxo-1,2,3,4-tetrahydropyrimidine-6-carboxylic acid", "common_name": "orotic acid", "inchi": "InChI=1S/C5H4N2O4/c8-3-1-2(5(10)11)6-4(9)7-3/h1H,(H,10,11)(H2,6,7,8,9)", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_027", "formula": "C4H4N2O2", "iupac_name": "extraterrestrial uracil", "common_name": "meteoritic uracil reservoir", "inchi": "InChI=1S/C4H4N2O2/c7-3-1-2-5-4(8)6-3/h1-2H,(H2,5,6,7,8)", "role": "intermediate", "environment_formed": "Surface"}], "reactions": [{"id": "rxn_001", "name": "Hydrothermal CO2 reduction to formate", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_003"], "environment": "Hydrothermal", "agents": ["greigite (Fe3S4)", "mackinawite (FeS)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "greigite/mackinawite", "aqueous": "true", "other": "alkaline vent-like H2-rich conditions; serpentinization-linked reducing environment"}, "mechanism": "Mineral-surface reduction of CO2 by H2 on Fe-S phases generates formate as a reduced one-carbon feedstock.", "reasoning": "Hydrothermal Fe-S catalysis and alkaline vent carbon fixation are consistent with iron-sulfur world and vent studies summarized in the report; formate production on greigite/mackinawite is used here only as an experimentally grounded hydrothermal feeder into downstream formamide chemistry, not as an invented uracil route (Huber & Wachtershauser, 1997; Herschy et al., 2014; Walton et al., 2022)."}, {"id": "rxn_002", "name": "Hydrothermal formaldehyde/glycolaldehyde generation by Fischer-Tropsch-type reduction", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_016"], "environment": "Hydrothermal", "agents": ["magnetite (Fe3O4)", "elemental iron (Fe0)"], "conditions": {"temperature": "400-500K", "pressure": "high", "catalyst": "magnetite/Fe0", "aqueous": "true", "other": "subseafloor or vent-proximal reduction chemistry producing small oxygenates"}, "mechanism": "CO2/H2 reduction on iron-bearing mineral surfaces yields reduced carbonyl compounds including glycolaldehyde-type products that can be transferred to surface pools.", "reasoning": "This reaction provides the glycolaldehyde input required by the Powner-Sutherland pathway while keeping the hydrothermal contribution limited to small reduced carbon compounds rather than unsupported direct uracil synthesis from vent feedstocks. Mineral-mediated reduced carbon generation is consistent with vent Fischer-Tropsch-type literature and the systems framing in the report (Huber & Wachtershauser, 1997; Herschy et al., 2014)."}, {"id": "rxn_003", "name": "Surface concentration of formamide from one-carbon feedstocks", "inputs": ["mol_003"], "outputs": ["mol_004"], "environment": "Surface", "agents": ["TiO2 (anatase)", "borate minerals (colemanite/ulexite)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "TiO2/borate-assisted evaporative concentration", "aqueous": "true", "other": "evaporation and thermophoretic enrichment in volcanic/fumarolic or pore settings over days to months"}, "mechanism": "Reduced one-carbon species are concentrated in surface geothermal settings to formamide-rich residues that become reactive under subsequent heating.", "reasoning": "The report emphasizes that formamide concentration, not bulk synthesis in oceans, is the key problem; thermophoresis and evaporation can enrich formamide to reactive levels in hydrothermal rock pores and fumarolic settings. This connector is explicitly marked as a concentration/availability step needed to link hydrothermal feedstocks to the well-supported formamide uracil chemistry (Niether et al., 2016; Saladino et al., 2004; Ferus et al., 2017)."}, {"id": "rxn_004", "name": "Formamide thermolysis on montmorillonite to uracil", "inputs": ["mol_004"], "outputs": ["mol_012"], "environment": "Surface", "agents": ["montmorillonite", "borate minerals (colemanite/ulexite)"], "conditions": {"temperature": "140-160C", "pressure": "1 atm", "catalyst": "montmorillonite", "aqueous": "false", "other": "fumarolic or volcanic dry-heating conditions; borate can modulate product distribution"}, "mechanism": "Thermal condensation and rearrangement of formamide on clay surfaces yield pyrimidinones including uracil.", "reasoning": "Direct uracil production from heated formamide on mineral catalysts is experimentally demonstrated; montmorillonite is specifically reported to yield uracil, and borates broaden product distributions. This is one of the best-supported free-uracil routes in volcanic settings (Saladino et al., 2004; Saladino et al., 2011)."}, {"id": "rxn_005", "name": "Formamide photocatalysis on TiO2 yielding uracil-family products", "inputs": ["mol_004"], "outputs": ["mol_012"], "environment": "Surface", "agents": ["TiO2 (anatase)", "montmorillonite"], "conditions": {"temperature": "140-160C with UV <380 nm", "pressure": "1 atm", "catalyst": "TiO2", "aqueous": "false", "other": "volcanic ash or beach-sand photocatalysis; formaldehyde-generating photochemistry"}, "mechanism": "TiO2 photocatalysis drives radical and carbonyl chemistry in heated formamide, producing pyrimidine derivatives including uracil-related products.", "reasoning": "The literature shows TiO2 is a distinctive catalyst in formamide chemistry and changes product distributions via photocatalytic formaldehyde generation. The route is included as a separate pathway to the same target because the catalyst and mechanism differ from montmorillonite thermolysis (Saladino et al., 2003; Senanayake & Idriss, 2006)."}, {"id": "rxn_006", "name": "Impact/plasma activation of formamide to uracil", "inputs": ["mol_004"], "outputs": ["mol_012", "mol_023"], "environment": "Surface", "agents": ["TiO2 (anatase)", "sulfide minerals (meteorite powder analogs)"], "conditions": {"temperature": "273K to plasma-heated transient conditions", "pressure": "1 atm", "catalyst": "powdered meteorite/mineral surfaces", "aqueous": "true", "other": "laser-induced plasma or proton irradiation; CN\u00b7 and NH\u00b7 radical formation"}, "mechanism": "Energetic dissociation of formamide generates CN and NH radicals that recombine into nucleobases; in meteoritic mineral contexts nucleosides including uridine can also form.", "reasoning": "This route follows the high-energy formamide literature and is kept distinct from thermal mineral-catalyzed formamide chemistry. It is one of the strongest demonstrations that uracil and uridine-related compounds can arise from a shared energetic process (Ferus et al., 2015; Saladino et al., 2015)."}, {"id": "rxn_007", "name": "Cyanoacetylene hydrolysis to cyanoacetaldehyde", "inputs": ["mol_006"], "outputs": ["mol_010"], "environment": "Surface", "agents": ["montmorillonite", "TiO2 (anatase)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "mineral surfaces aiding concentration and hydrolysis", "aqueous": "true", "other": "aqueous surface pools; cyanoacetaldehyde is ~1000-fold more stable than cyanoacetylene in water"}, "mechanism": "Water addition to cyanoacetylene produces the more persistent electrophile cyanoacetaldehyde.", "reasoning": "The report explicitly identifies cyanoacetaldehyde as the hydrolysis product of cyanoacetylene and as the practical entry point to high-yield Robertson-Miller pyrimidine synthesis. Minerals here are specified to satisfy the network schema, but the key support is the documented aqueous conversion and stability relationship (Robertson & Miller, 1995; Nelson et al., 2001)."}, {"id": "rxn_008", "name": "Cyanoacetylene plus cyanate to cytosine", "inputs": ["mol_006", "mol_007"], "outputs": ["mol_009", "mol_011"], "environment": "Surface", "agents": ["montmorillonite", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "100C, 24 h", "pressure": "1 atm", "catalyst": "mineral concentration surfaces", "aqueous": "true", "other": "0.025 M cyanoacetylene + 0.05 M cyanate; cyanovinylurea intermediate cyclizes to cytosine"}, "mechanism": "Cyanoacetylene reacts with cyanate to form trans-cyanovinylurea, followed by intramolecular cyclization to cytosine.", "reasoning": "This is the classic Ferris-Sanchez-Orgel pathway and is represented with its reported concentrations and temperature. Its main weakness, acknowledged in the report, is the implausible need for high cyanate concentrations; nevertheless it is a foundational literature-supported uracil precursor route (Ferris et al., 1968; Sanchez, Ferris & Orgel, 1966)."}, {"id": "rxn_009", "name": "Cyanoacetaldehyde plus concentrated urea to cytosine and minor uracil", "inputs": ["mol_010", "mol_008"], "outputs": ["mol_011", "mol_012"], "environment": "Surface", "agents": ["montmorillonite", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "100C over dry-down to 3 days", "pressure": "1 atm", "catalyst": "evaporitic concentration on mineral surfaces", "aqueous": "false", "other": "saturated or highly concentrated urea in evaporating lagoon conditions; reported 30-50% cytosine, with minor direct uracil on dry-down"}, "mechanism": "Condensation of cyanoacetaldehyde with concentrated urea gives cytosine efficiently; prolonged dry-down also yields some uracil directly.", "reasoning": "This is the highest-yield free-pyrimidine route in the literature and is the central surface pathway in the network. The direct minor uracil component under dry-down is explicitly noted in the report and kept separate from cytosine deamination (Robertson & Miller, 1995; Nelson et al., 2001)."}, {"id": "rxn_010", "name": "Hydrolytic deamination of cytosine to uracil", "inputs": ["mol_011"], "outputs": ["mol_012"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "0-100C", "pressure": "1 atm", "catalyst": null, "aqueous": "true", "other": "hydrolytic deamination; half-life depends strongly on temperature"}, "mechanism": "Water-mediated deamination of the exocyclic amino group on cytosine gives uracil.", "reasoning": "Cytosine deamination is one of the most secure uracil-forming processes and explains why uracil is found where cytosine is absent in meteorites. Temperature-dependent instability is central to the literature critique and defense of cytosine-based routes (Levy & Miller, 1998; Shapiro, 1999; Wolfenden et al., 2016)."}, {"id": "rxn_011", "name": "HCN tetramerization to DAMN", "inputs": ["mol_005"], "outputs": ["mol_013"], "environment": "Surface", "agents": ["montmorillonite", "TiO2 (anatase)"], "conditions": {"temperature": "room temperature", "pressure": "1 atm", "catalyst": "mineral concentration surfaces", "aqueous": "true", "other": "0.1-1.0 M HCN, pH ~9"}, "mechanism": "Base-promoted oligomerization of HCN yields the tetramer diaminomaleonitrile.", "reasoning": "DAMN is explicitly described in the report as a major branch point from concentrated cyanide chemistry. This node is included as a hub but not overinterpreted as a selective uracil precursor on its own (Hill & Orgel, 2002; Bizzarri et al., 2022)."}, {"id": "rxn_012", "name": "Photothermal DAMN chemistry to pyrimidine derivatives including uracil", "inputs": ["mol_013"], "outputs": ["mol_012", "mol_011"], "environment": "Surface", "agents": ["TiO2 (anatase)", "montmorillonite"], "conditions": {"temperature": "photothermal, 300-350K", "pressure": "1 atm", "catalyst": "UV-active mineral surfaces", "aqueous": "true", "other": "product selectivity depends on thermal vs photochemical energy input"}, "mechanism": "Photothermal multicomponent cyanide-derived chemistry channels DAMN toward pyrimidine products rather than the imidazole/purine products favored thermally.", "reasoning": "The report warns against a simplistic direct DAMN-to-uracil claim; accordingly this reaction is framed as a diversity-generating pyrimidine branch that can include uracil and cytosine under photothermal conditions rather than a single high-yield targeted synthesis (Bizzarri et al., 2022)."}, {"id": "rxn_013", "name": "Alkaline cyanide polymerization under moderate hydrothermal-like conditions to uracil and orotic acid", "inputs": ["mol_005"], "outputs": ["mol_012", "mol_026"], "environment": "Hydrothermal", "agents": ["pyrite (FeS2)", "greigite (Fe3S4)"], "conditions": {"temperature": "80C", "pressure": "1 bar", "catalyst": "iron-sulfur mineral surfaces", "aqueous": "true", "other": "simulated alkaline hydrothermal/subaerial vent conditions; pyrimidines favored over triazines"}, "mechanism": "Cyanide oligomerization and rearrangement in moderately warm alkaline settings generate pyrimidine products including uracil and orotic acid.", "reasoning": "This route is included with corrected environmental framing: not black-smoker high-temperature vent chemistry, but moderate alkaline hydrothermal/subaerial conditions as emphasized in the report. It is a direct literature-supported uracil route (Scientific Reports, 2022; Herschy et al., 2014)."}, {"id": "rxn_014", "name": "Ice eutectic cyanide chemistry to cytosine and uracil", "inputs": ["mol_005", "mol_008"], "outputs": ["mol_011", "mol_012"], "environment": "Surface", "agents": ["borate minerals (colemanite/ulexite)", "montmorillonite"], "conditions": {"temperature": "subzero eutectic freezing", "pressure": "1 atm", "catalyst": "solute concentration in ice films", "aqueous": "true", "other": "frozen urea solutions under reductive atmosphere; room-temperature controls fail to produce pyrimidines"}, "mechanism": "Freezing excludes solutes into concentrated liquid films where cyanide/urea chemistry yields pyrimidines including cytosine and uracil.", "reasoning": "Ice eutectic concentration is highlighted in the report as one of the most plausible demonstrated ways to overcome dilution and promote HCN polymerization. Menor-Salvan et al. specifically report cytosine and uracil from frozen urea solutions, making this a distinct route (Miyakawa et al., 2002; Menor-Salvan et al., 2009)."}, {"id": "rxn_015", "name": "Beta-alanine plus urea dry-down to dihydrouracil", "inputs": ["mol_014", "mol_008"], "outputs": ["mol_015"], "environment": "Surface", "agents": ["montmorillonite", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "mild heating in evaporating
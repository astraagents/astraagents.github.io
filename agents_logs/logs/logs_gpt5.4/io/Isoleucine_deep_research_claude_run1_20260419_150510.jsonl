      \"inchi\": \"InChI=1S/C4H6O3/c1-2-3(5)4(6)7/h2H2,1H3,(H,6,7)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_015\",\n      \"formula\": \"C6H10O3\",\n      \"iupac_name\": \"3-methyl-2-oxopentanoic acid\",\n      \"common_name\": \"alpha-keto-beta-methylvalerate\",\n      \"inchi\": \"InChI=1S/C6H10O3/c1-3-4(2)5(7)6(8)9/h4H,3H2,1-2H3,(H,8,9)\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_016\",\n      \"formula\": \"C7H10N2O2\",\n      \"iupac_name\": \"5-ethyl-4-methylimidazolidine-2,4-dione\",\n      \"common_name\": \"isoleucine hydantoin\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_017\",\n      \"formula\": \"CH4\",\n      \"iupac_name\": \"methane\",\n      \"common_name\": \"methane\",\n      \"inchi\": \"InChI=1S/CH4/h1H4\",\n      \"role\": \"starting\",\n      \"environment_formed\": null\n    },\n    {\n      \"id\": \"mol_018\",\n      \"formula\": \"H2S\",\n      \"iupac_name\": \"sulfane\",\n      \"common_name\": \"hydrogen sulfide\",\n      \"inchi\": \"InChI=1S/H2S/h1H2\",\n      \"role\": \"starting\",\n      \"environment_formed\": null\n    },\n    {\n      \"id\": \"mol_019\",\n      \"formula\": \"H2O\",\n      \"iupac_name\": \"water\",\n      \"common_name\": \"water\",\n      \"inchi\": \"InChI=1S/H2O/h1H2\",\n      \"role\": \"starting\",\n      \"environment_formed\": null\n    },\n    {\n      \"id\": \"mol_020\",\n      \"formula\": \"C4H9NO2\",\n      \"iupac_name\": \"2-aminobutanoic acid\",\n      \"common_name\": \"alpha-aminobutyric acid\",\n      \"inchi\": \"InChI=1S/C4H9NO2/c1-2-3(5)4(6)7/h3H,2,5H2,1H3,(H,6,7)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"Greigite-catalyzed reduction of CO2 to formate\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_005\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe3S4)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"greigite\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline vent conditions, anoxic, H2-rich\"\n      },\n      \"mechanism\": \"Mineral-surface CO2 activation followed by stepwise hydrogenation to surface-bound formyl/formate species.\",\n      \"reasoning\": \"Hydrothermal Fe-S mineral catalysis of CO2 reduction to formate is consistent with iron-sulfur world and vent-analog chemistry, with greigite and mackinawite acting as prebiotic [Fe-S] analogs; included here as feeder chemistry rather than a direct isoleucine-forming step, in line with the conclusion that hydrothermal systems support simple carbon fixation but have not demonstrated isoleucine synthesis (Huber & Wachtershauser, 1997; Russell & Hall, 2006; Martin & Russell, 2007; Cleaves et al., 2009).\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"FeS/Fe0-mediated carbon fixation to acetate\",\n      \"inputs\": [\"mol_005\", \"mol_002\"],\n      \"outputs\": [\"mol_006\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"pyrite (FeS2)\", \"elemental iron (Fe0)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"pyrite and Fe0\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic vent pore setting with reducing power from H2\"\n      },\n      \"mechanism\": \"Further reduction and C-C bond formation from one-carbon species on iron-sulfur/iron surfaces gives simple C2 carboxylates.\",\n      \"reasoning\": \"This step represents conservative hydrothermal feeder chemistry to small organics rather than a claim of direct isoleucine synthesis. It is aligned with FeS/NiS and iron-driven carbon-fixation analogs from hydrothermal literature and is used here only to connect vent carbon fixation to later surface chemistry (Huber & Wachtershauser, 1997; Russell & Hall, 2006; Martin & Russell, 2007; Cleaves et al., 2009).\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Magnetite-catalyzed Fischer-Tropsch-type formation of acetaldehyde\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_007\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe3O4)\", \"elemental iron (Fe0)\"],\n      \"conditions\": {\n        \"temperature\": \"400-500K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"magnetite\",\n        \"aqueous\": \"true\",\n        \"other\": \"subseafloor or vent-associated reducing conditions; product expected as mixture component\"\n      },\n      \"mechanism\": \"Fischer-Tropsch-type surface reduction of carbon oxides generates mixed low-molecular-weight oxygenates including aldehydes.\",\n      \"reasoning\": \"The literature report identifies Fischer-Tropsch-type synthesis on metal surfaces as one plausible source of the aldehyde precursor family needed for Strecker chemistry, but not as a clean, selective route; accordingly acetaldehyde is treated as a mixed-product feeder intermediate and not overstated (Pizzarello & Cronin, 2008; Huber & Wachtershauser, 1997; Cleaves et al., 2009).\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"Hydrothermal pyruvate synthesis on magnetite/greigite\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe3O4)\", \"greigite (Fe3S4)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"magnetite and greigite\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic alkaline hydrothermal setting\"\n      },\n      \"mechanism\": \"Mineral-mediated CO2 reduction and C-C bond forming chemistry yields alpha-keto acid products including pyruvate in protometabolic networks.\",\n      \"reasoning\": \"Pyruvate is included as a central protometabolic hub supported by prebiotic metabolism literature and as a plausible hydrothermal product, but this does not imply hydrothermal synthesis of isoleucine itself; the deep research explicitly notes hydrothermal systems are more relevant to keto-acid feeder chemistry than to direct isoleucine production (Springsteen et al., 2018; Ter-Ovanessian et al., 2025; Cleaves et al., 2009).\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"Oxidative feeder formation of glyoxylate from formate/carboxylate pools\",\n      \"inputs\": [\"mol_005\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"pyrite (FeS2)\", \"magnetite (Fe3O4)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"pyrite and magnetite\",\n        \"aqueous\": \"true\",\n        \"other\": \"protometabolic vent network; included as a network connection to glyoxylate chemistry\"\n      },\n      \"mechanism\": \"Fe-mediated carbonyl chemistry in protometabolic mixtures provides access to C2 oxoacids such as glyoxylate.\",\n      \"reasoning\": \"Glyoxylate is a well-established central prebiotic metabolite in the literature summary and is necessary to connect pyruvate-centered protometabolism to alpha-ketobutyrate ideas; this exact feeder step is network-completion chemistry and is therefore more speculative than the Strecker core, but is constrained to simple protometabolic oxoacid generation rather than unsupported isoleucine synthesis (Springsteen et al., 2018; Kim et al., 2020; Cleaves et al., 2009).\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"Volcanic spark discharge generation of HCN\",\n      \"inputs\": [\"mol_017\", \"mol_003\", \"mol_018\", \"mol_019\"],\n      \"outputs\": [\"mol_004\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"sulfide minerals (stibnite/molybdenite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral-rich volcanic aerosols and surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"electrical discharge in reducing volcanic atmosphere; H2S-enhanced radical chemistry\"\n      },\n      \"mechanism\": \"Electrical discharge fragments reduced gases to radicals and nitriles; HCN accumulates and dissolves into aqueous surface reservoirs.\",\n      \"reasoning\": \"HCN production in Miller-Urey-type discharge systems is a foundational result for Strecker chemistry, and Parker et al. identified H2S-containing volcanic discharge conditions as particularly productive for branched amino acid synthesis. Mineral agents are included because the schema requires them for surface reactions, but the main energy source is electrical discharge (Miller, 1957; Ring et al., 1972; Parker et al., 2011).\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Volcanic spark discharge generation of 2-methylbutanal\",\n      \"inputs\": [\"mol_017\", \"mol_018\", \"mol_019\"],\n      \"outputs\": [\"mol_009\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"sulfide minerals (stibnite/molybdenite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral-rich volcanic surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"electrical discharge; radical recombination promoted by H2S-derived sulfur radicals\"\n      },\n      \"mechanism\": \"Discharge-generated alkyl radicals undergo recombination and oxidation to branched aldehydes, including the crucial C5 precursor 2-methylbutanal.\",\n      \"reasoning\": \"The deep research identifies generation of 2-methylbutanal as the fundamental bottleneck and specifically notes radical chemistry in spark discharge, especially under H2S-containing volcanic conditions, as the strongest experimental context for access to isoleucine precursors. This is the literature-supported core precursor-forming step (Ring et al., 1972; Parker et al., 2011; Pizzarello & Cronin, 2008).\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Crossed-aldol access to 2-methylbutanal from acetaldehyde and propanal\",\n      \"inputs\": [\"mol_007\", \"mol_008\"],\n      \"outputs\": [\"mol_009\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"borate minerals and clay surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"evaporitic pool wet-dry concentration; pathway remains chemically plausible but less direct than discharge radical route\"\n      },\n      \"mechanism\": \"Surface-promoted carbonyl condensation among small aldehydes gives a branched C5 aldehyde after dehydration/reduction sequence in mixed prebiotic pools.\",\n      \"reasoning\": \"The research report explicitly lists crossed aldol condensation of acetaldehyde with propanal as one plausible route to 2-methylbutanal, but not as strongly demonstrated as spark discharge chemistry. It is therefore included as a secondary, literature-mentioned route to the same critical hub and should be regarded as plausible but less established (Pizzarello & Cronin, 2008; Ross & Deamer, 2016).\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"Aqueous Strecker synthesis of isoleucine aminonitrile from 2-methylbutanal\",\n      \"inputs\": [\"mol_009\", \"mol_003\", \"mol_004\"],\n      \"outputs\": [\"mol_010\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\", \"sulfide minerals (stibnite/molybdenite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral surfaces concentrating reagents\",\n        \"aqueous\": \"true\",\n        \"other\": \"imine formation followed by cyanide addition in aqueous pools\"\n      },\n      \"mechanism\": \"Aldehyde condenses with ammonia to an imine, followed by nucleophilic HCN addition to give the alpha-aminonitrile.\",\n      \"reasoning\": \"This is the dominant, best-supported route for prebiotic isoleucine formation. Miller identified Strecker chemistry as the principal mechanism in spark discharge products, and the specific isoleucine route from 2-methylbutanal, NH3, and HCN is directly described in the deep research summary (Miller, 1957; Ring et al., 1972; Eckhardt et al., 2022; Parker et al., 2011).\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"Hydrolysis of isoleucine aminonitrile to racemic isoleucine\",\n      \"inputs\": [\"mol_010\", \"mol_019\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral-assisted hydrolysis in aqueous pools\",\n        \"aqueous\": \"true\",\n        \"other\": \"gives racemic isoleucine plus alloisoleucine mixture under prebiotic conditions\"\n      },\n      \"mechanism\": \"Stepwise nitrile hydrolysis through amide/carboxylate stages converts the aminonitrile into the amino acid.\",\n      \"reasoning\": \"Hydrolysis of the Strecker aminonitrile is the final stage of the canonical prebiotic isoleucine route. The literature emphasizes that this process yields racemic material and does not solve the dual-chirality problem, but it remains the strongest experimentally grounded route to isoleucine (Miller, 1957; Ring et al., 1972; Parker et al., 2011; Bada & Schroeder, 1975).\"\n    },\n    {\n      \"id\": \"rxn_011\",\n      \"name\": \"Pyruvate-glyoxylate route to alpha-ketobutyrate\",\n      \"inputs\": [\"mol_012\", \"mol_013\"],\n      \"outputs\": [\"mol_014\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"variable\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"null\",\n        \"aqueous\": \"true\",\n        \"other\": \"proto-metabolic network; nonenzymatic analogue inferred from underground biosynthetic logic\"\n      },\n      \"mechanism\": \"Carbonyl coupling and rearrangement within alpha-keto acid/glyoxylate networks generates higher oxoacids including alpha-ketobutyrate-like products.\",\n      \"reasoning\": \"The deep research specifically highlights alpha-ketobutyrate as a biologically central branch-point and notes underground biosynthetic routes from glyoxylate + pyruvate as prebiotically significant because both are central prebiotic metabolites. This specific prebiotic conversion remains unresolved and is therefore included as a speculative connector, not as an experimentally established isoleucine synthesis step (Kim et al., 2020; Springsteen et al., 2018).\"\n    },\n    {\n      \"id\": \"rxn_012\",\n      \"name\": \"Assembly of 3-methyl-2-oxopentanoic acid from alpha-ketobutyrate and pyruvate equivalents\",\n      \"inputs\": [\"mol_014\", \"mol_012\"],\n      \"outputs\": [\"mol_015\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"variable\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"null\",\n        \"aqueous\": \"true\",\n        \"other\": \"protometabolic aldol/ketol chemistry; key unresolved bottleneck\"\n      },\n      \"mechanism\": \"Nonenzymatic carbon-carbon bond formation extends the alpha-ketobutyrate skeleton to the branched C6 alpha-keto acid corresponding to isoleucine's direct keto precursor.\",\n      \"reasoning\": \"The literature explicitly identifies alpha-keto-beta-methylvalerate as the penultimate biological intermediate and notes that its prebiotic formation might be accessible through nonenzymatic aldol chemistry, but that this has not been demonstrated. It is therefore a necessary but clearly speculative bottleneck node in metabolism-first branches (Ter-Ovanessian et al., 2025; deep research conclusion).\"\n    },\n    {\n      \"id\": \"rxn_013\",\n      \"name\": \"FeS-mediated reductive amination of 3-methyl-2-oxopentanoic acid to isoleucine\",\n      \"inputs\": [\"mol_015\", \"mol_003\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"acidic hydrothermal-compatible moderate conditions\",\n        \"pressure\": \"variable\",\n        \"catalyst\": \"FeS or Fe(OH)2\",\n        \"aqueous\": \"true\",\n        \"other\": \"reductive amination analogue; included outside Hydrothermal class to avoid claiming vent de novo isoleucine synthesis\"\n      },\n      \"mechanism\": \"Ammonia addition to the alpha-keto acid followed by mineral-mediated reduction yields the corresponding amino acid.\",\n      \"reasoning\": \"Reductive amination of alpha-oxo acids to amino acids is experimentally demonstrated with FeS/Fe(OH)2 systems, but the deep research stresses that isoleucine production by this route depends entirely on the prior availability of 3-methyl-2-oxopentanoic acid and that hydrothermal vent simulations have not produced isoleucine. Accordingly this is an explicitly conditional, speculative endpoint branch (Hafenbradl et al., 1995; Huber & Wachtershauser, 2003; Cleaves et al., 2009).\"\n    },\n    {\n      \"id\": \"rxn_014\",\n      \"name\": \"ZnS-UV photocatalytic amination of 3-methyl-2-oxopentanoic acid to isoleucine\",\n      \"inputs\": [\"mol_015\", \"mol_003\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"surface sunlight conditions\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"ZnS under UV illumination\",\n        \"aqueous\": \"true\",\n        \"other\": \"shallow illuminated settings; reversible amination chemistry\"\n      },\n      \"mechanism\": \"Photoexcited ZnS generates electrons and holes that drive reversible reductive amination of alpha-keto acids.\",\n      \"reasoning\": \"The failed prior attempt incorrectly emphasized TiO2 for this chemistry; the literature specifically identifies ZnS as the experimentally supported photocatalyst for reversible amination of alpha-keto acids. As with rxn_013, applicability to isoleucine is conditional on availability of the difficult branched alpha-keto precursor (Wang et al., 2012; deep research conclusion).\"\n    },\n    {\n      \"id\": \"rxn_015\",\n      \"name\": \"Bucherer-Bergs conversion of 3-methyl-2-oxopentanoic acid to isoleucine hydantoin\",\n      \"inputs\": [\"mol_015\", \"mol_004\", \"mol_003\"],\n      \"outputs\": [\"mol_016\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral-assisted concentration in aqueous pools\",\n        \"aqueous\": \"true\",\n        \"other\": \"cyanide/ammonia-mediated hydantoin formation from alpha-keto acids\"\n      },\n      \"mechanism\": \"Alpha-keto acid reacts with cyanide and ammonia to give a hydantoin intermediate via Bucherer-Bergs chemistry.\",\n      \"reasoning\": \"Pulletikurti et al. demonstrated Bucherer-Bergs as a bridge between Strecker-type prebiotic chemistry and biologically relevant alpha-keto acid substrates. The deep research states the chemistry is general but unresolved for isoleucine because precursor availability is the main problem, so this branch is included as a conditional but literature-grounded alternative endpoint route (Pulletikurti et al., 2022).\"\n    },\n    {\n      \"id\": \"rxn_016\",\n      \"name\": \"Hydrolysis of isoleucine hydantoin to isoleucine\",\n      \"inputs\": [\"mol_016\", \"mol_019\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"phosphate minerals (apatite/struvite)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral-assisted aqueous hydrolysis\",\n        \"aqueous\": \"true\",\n        \"other\": \"post-Bucherer-Bergs ring opening and hydrolysis\"\n      },\n      \"mechanism\": \"Hydantoin ring opening and hydrolysis furnish the amino acid product.\",\n      \"reasoning\": \"Hydantoin hydrolysis is the terminal step of the Bucherer-Bergs route. Included because the literature identifies Bucherer-Bergs as a demonstrated prebiotic amino-acid-forming process generalizable to alpha-keto acids, while acknowledging unresolved access to the required branched precursor for isoleucine (Pulletikurti et al., 2022).\"\n    },\n    {\n      \"id\": \"rxn_017\",\n      \"name\": \"Meteorite parent-body Strecker synthesis to isoleucine aminonitrile precursor pool\",\n      \"inputs\": [\"mol_009\", \"mol_003\", \"mol_004\"],\n      \"outputs\": [\"mol_010\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"low to moderate parent-body aqueous alteration conditions\",\n        \"pressure\": \"variable\",\n        \"catalyst\": \"null\",\n        \"aqueous\": \"true\",\n        \"other\": \"extraterrestrial aqueous chemistry preserved in carbonaceous chondrites\"\n      },\n      \"mechanism\": \"Parent-body aqueous Strecker chemistry from branched aldehydes forms isoleucine aminonitrile and then amino acid upon hydrolysis.\",\n      \"reasoning\": \"The research summary explicitly states meteoritic/parent-body Strecker chemistry is one of the three experimentally supported contexts for prebiotic isoleucine, with isotopic evidence showing the existence of the branched aldehyde precursor in meteorite parent bodies. This reaction node captures that independent source to the same aminonitrile hub (Pizzarello & Cronin, 2008; Cronin et al., 1981; Glavin et al., 2021).\"\n    },\n    {\n      \"id\": \"rxn_018\",\n      \"name\": \"UV/EUV photolysis of PAH-containing ices yielding isoleucine\",\n      \"inputs\": [\"mol_003\", \"mol_019\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"borate minerals (colemanite/ulexite)\"],\n      \"conditions\": {\n        \"temperature\": \"cryogenic ice photolysis followed by warming\",\n        \"pressure\": \"low to 1 atm after deposition\",\n        \"catalyst\": \"UV/EUV photons\",\n        \"aqueous\": \"false\",\n        \"other\": \"PAH-rich ice analog chemistry as extraterrestrial feedstock deposited to surface\"\n      },\n      \"mechanism\": \"Energetic photolysis of aromatic ice mixtures generates complex organics that, upon warm-up/hydrolysis, include amino acids such as isoleucine.\",\n      \"reasoning\": \"Chen et al. reported isoleucine among amino acids produced by UV/EUV photolysis of naphthalene + H2O + NH3 ices. This is an experimentally positive but non-terrestrial-assembly route; in the network it functions as an independent source of the target entering surface reservoirs, not as a contradiction to the dominant Strecker pipeline (Chen et al., 2008; Bernstein et al., 2002; Munoz Caro et al., 2002).\"\n    },\n    {\n      \"id\": \"rxn_019\",\n      \"name\": \"Surface concentration and preservation of isoleucine in wet-dry pools\",\n      \"inputs\": [\"mol_011\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"null\",\n        \"aqueous\": \"true\",\n        \"other\": \"wet-dry cycling, urea-rich or mineral interfaces, concentration up to ~1400-fold\"\n      },\n      \"mechanism\": \"No net chemical transformation; concentration by evaporation, adsorption, and cycling increases local availability for further prebiotic chemistry.\",\n      \"reasoning\": \"Although not a synthetic transformation to a new molecule, concentration is essential for a trace amino acid such as isoleucine. The literature emphasizes wet-dry cycling and pool concentration as critical for preserving and accumulating scarce products from discharge or exogenous input (Ross & Deamer, 2016; Ferris, 2005; Zhang et al., 2023).\"\n    },\n    {\n      \"id\": \"rxn_020\",\n      \"name\": \"Strecker synthesis of alpha-aminobutyric acid as a branch-comparison route\",\n      \"inputs\": [\"mol_008\", \"mol_003\", \"mol_004\"],\n      \"outputs\": [\"mol_020\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\", \"sulfide minerals (stibnite/molybdenite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral-assisted concentration in aqueous pools\",\n        \"aqueous\": \"true\",\n        \"other\": \"canonical Strecker chemistry from propanal\"\n      },\n      \"mechanism\": \"Propanal undergoes imine formation and cyanide addition followed by hydrolysis to give alpha-aminobutyric acid.\",\n      \"reasoning\": \"The research highlights alpha-aminobutyric acid as an easier 4-carbon analogue that is readily formed in Miller experiments and meteorites, illustrating the carbon-skeleton bottleneck specific to isoleucine. This branch is included to show network convergence around HCN and aldehyde chemistry and to contextualize why isoleucine is rare (Ring et al., 1972; Parker et al., 2011; deep research summary).\"\n    }\n  ],\n  \"pathways\": [\n    {\n      \"pathway_id\": \"P1\",\n      \"name\": \"Volcanic H2S spark-discharge Strecker route\",\n      \"description\": \"Best-supported terrestrial route: H2S-containing spark discharge generates both HCN and branched aldehyde precursor 2-methylbutanal, which undergoes Strecker synthesis and hydrolysis to isoleucine.\",\n      \"reaction_sequence\": [\"rxn_006\", \"rxn_007\", \"rxn_009\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_009\", \"mol_010\"]\n    },\n    {\n      \"pathway_id\": \"P2\",\n      \"name\": \"Classic reducing-atmosphere spark-discharge Strecker route\",\n      \"description\": \"Variant of the discharge route supported by Ring et al. detection of isoleucine in CH4/N2/NH3/H2O spark mixtures; converges on the same Strecker core.\",\n      \"reaction_sequence\": [\"rxn_006\", \"rxn_007\", \"rxn_009\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_009\", \"mol_010\"]\n    },\n    {\n      \"pathway_id\": \"P3\",\n      \"name\": \"Hydrothermal carbon fixation feeding surface aldol-Strecker route\",\n      \"description\": \"Hydrothermal production of acetaldehyde feeds surface carbonyl chemistry, where crossed-aldol access to 2-methylbutanal converges with HCN-mediated Strecker synthesis.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_008\", \"rxn_006\", \"rxn_009\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_009\", \"mol_004\", \"mol_010\"]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"Meteorite parent-body Strecker route\",\n      \"description\": \"Extraterrestrial branched aldehydes and HCN/NH3 aqueous chemistry produce the same aminonitrile intermediate later delivered to or mirrored on Earth.\",\n      \"reaction_sequence\": [\"rxn_017\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_010\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"PAH-ice UV photolysis route\",\n      \"description\": \"Independent experimentally positive route in which UV/EUV photolysis of PAH-containing ices yields isoleucine directly after warm-up/hydrolysis.\",\n      \"reaction_sequence\": [\"rxn_018\"],\n      \"key_intermediates\": []\n    },\n    {\n      \"pathway_id\": \"P6\",\n      \"name\": \"Protometabolic keto-acid route with FeS reductive amination\",\n      \"description\": \"Hydrothermal pyruvate and glyoxylate feed a speculative alpha-ketobutyrate-to-alpha-keto-beta-methylvalerate branch, followed by FeS-mediated reductive amination to isoleucine.\",\n      \"reaction_sequence\": [\"rxn_004\", \"rxn_005\", \"rxn_011\", \"rxn_012\", \"rxn_013\"],\n      \"key_intermediates\": [\"mol_012\", \"mol_013\", \"mol_014\", \"mol_015\"]\n    },\n    {\n      \"pathway_id\": \"P7\",\n      \"name\": \"Protometabolic keto-acid route with ZnS photocatalytic amination\",\n      \"description\": \"Same speculative branched keto-acid assembly as P6, but the final amino-acid-forming step uses the literature-supported ZnS UV amination chemistry rather than FeS reductive amination.\",\n      \"reaction_sequence\": [\"rxn_004\", \"rxn_005\", \"rxn_011\", \"rxn_012\", \"rxn_014\"],\n      \"key_intermediates\": [\"mol_012\", \"mol_013\", \"mol_014\", \"mol_015\"]\n    },\n    {\n      \"pathway_id\": \"P8\",\n      \"name\": \"Protometabolic Bucherer-Bergs route\",\n      \"description\": \"Branched alpha-keto acid formed in a speculative protometabolic network is converted by Bucherer-Bergs chemistry through a hydantoin intermediate to isoleucine.\",\n      \"reaction_sequence\": [\"rxn_004\", \"rxn_005\", \"rxn_011\", \"rxn_012\", \"rxn_015\", \"rxn_016\"],\n      \"key_intermediates\": [\"mol_014\", \"mol_015\", \"mol_016\"]\n    },\n    {\n      \"pathway_id\": \"P9\",\n      \"name\": \"Hydrothermal-to-surface mixed feeder route to Strecker isoleucine\",\n      \"description\": \"Vent chemistry supplies simple carbon pools, while surface discharge produces HCN and branched aldehyde; environmental crossover culminates in standard Strecker hydrolysis.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_003\", \"rxn_006\", \"rxn_007\", \"rxn_009\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_005\", \"mol_006\", \"mol_007\", \"mol_004\", \"mol_009\", \"mol_010\"]\n    },\n    {\n      \"pathway_id\": \"P10\",\n      \"name\": \"Concentrated surface-pool preservation pathway\",\n      \"description\": \"Once generated by discharge Strecker or exogenous input, isoleucine is concentrated and preserved in wet-dry pools to become available for later prebiotic chemistry.\",\n      \"reaction_sequence\": [\"rxn_006\", \"rxn_007\", \"rxn_009\", \"rxn_010\", \"rxn_019\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_009\", \"mol_010\", \"mol_011\"]\n    }\n  ],\n  \"hub_molecules\": [\"mol_004\", \"mol_009\", \"mol_010\", \"mol_012\", \"mol_015\"],\n  \"convergence_points\": [\n    {\n      \"molecule_id\": \"mol_004\",\n      \"incoming_reactions\": [\"rxn_006\"],\n      \"outgoing_reactions\": [\"rxn_009\", \"rxn_015\", \"rxn_020\", \"rxn_017\"]\n    },\n    {\n      \"molecule_id\": \"mol_009\",\n      \"incoming_reactions\": [\"rxn_007\", \"rxn_008\"],\n      \"outgoing_reactions\": [\"rxn_009\", \"rxn_017\"]\n    },\n    {\n      \"molecule_id\": \"mol_010\",\n      \"incoming_reactions\": [\"rxn_009\", \"rxn_017\"],\n      \"outgoing_reactions\": [\"rxn_010\"]\n    },\n    {\n      \"molecule_id\": \"mol_012\",\n      \"incoming_reactions\": [\"rxn_004\"],\n      \"outgoing_reactions\": [\"rxn_011\", \"rxn_012\"]\n    },\n    {\n      \"molecule_id\": \"mol_015\",\n      \"incoming_reactions\": [\"rxn_012\"],\n      \"outgoing_reactions\": [\"rxn_013\", \"rxn_014\", \"rxn_015\"]\n    }\n  ]\n}", "parsed_response": {"target_molecule": "Isoleucine", "overall_strategy": "This network centers on the best-supported prebiotic route to isoleucine: volcanic/spark-discharge generation of HCN and the key branched aldehyde 2-methylbutanal, followed by Strecker aminonitrile formation and hydrolysis in surface aqueous settings. To satisfy environmental interconnection while remaining literature-guided, hydrothermal chemistry is used conservatively as a feeder network that supplies simple carbon substrates such as formate, acetate, acetaldehyde, pyruvate, and glyoxylate, but not direct isoleucine synthesis, consistent with reports that hydrothermal simulations have not demonstrated isoleucine formation. Additional target-reaching routes are included only where the literature explicitly supports the chemistry in general but leaves the specific isoleucine precursor availability unresolved: Bucherer-Bergs and reductive amination/photocatalytic amination of 3-methyl-2-oxopentanoic acid are therefore marked as speculative endpoint branches dependent on a difficult keto-acid precursor. The network is organized around hub molecules HCN, 2-methylbutanal, pyruvate, glyoxylate, and 3-methyl-2-oxopentanoic acid, with ten distinct pathways converging on isoleucine or its immediate aminonitrile/keto-acid precursors.", "molecules": [{"id": "mol_001", "formula": "CO2", "iupac_name": "carbon dioxide", "common_name": "carbon dioxide", "inchi": "InChI=1S/CO2/c2-1-3", "role": "starting", "environment_formed": null}, {"id": "mol_002", "formula": "H2", "iupac_name": "molecular hydrogen", "common_name": "hydrogen", "inchi": "InChI=1S/H2/h1H", "role": "starting", "environment_formed": null}, {"id": "mol_003", "formula": "NH3", "iupac_name": "azane", "common_name": "ammonia", "inchi": "InChI=1S/H3N/h1H3", "role": "starting", "environment_formed": null}, {"id": "mol_004", "formula": "HCN", "iupac_name": "hydrogen cyanide", "common_name": "hydrogen cyanide", "inchi": "InChI=1S/CHN/c1-2/h1H", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_005", "formula": "CH2O2", "iupac_name": "methanoic acid", "common_name": "formic acid/formate", "inchi": "InChI=1S/CH2O2/c2-1-3/h1H,(H,2,3)", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_006", "formula": "C2H4O2", "iupac_name": "acetic acid", "common_name": "acetate", "inchi": "InChI=1S/C2H4O2/c1-2(3)4/h1H3,(H,3,4)", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_007", "formula": "C2H4O", "iupac_name": "ethanal", "common_name": "acetaldehyde", "inchi": "InChI=1S/C2H4O/c1-2-3/h2H,1H3", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_008", "formula": "C3H6O", "iupac_name": "propanal", "common_name": "propionaldehyde", "inchi": "InChI=1S/C3H6O/c1-2-3-4/h3H,2H2,1H3", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_009", "formula": "C5H10O", "iupac_name": "2-methylbutanal", "common_name": "2-methylbutyraldehyde", "inchi": "InChI=1S/C5H10O/c1-3-5(2)4-6/h4-5H,3H2,1-2H3", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_010", "formula": "C6H12N2", "iupac_name": "2-amino-3-methylpentanenitrile", "common_name": "isoleucine aminonitrile", "inchi": "InChI=1S/C6H12N2/c1-3-5(2)6(7)4-8/h5-6H,3,7H2,1-2H3", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_011", "formula": "C6H13NO2", "iupac_name": "2-amino-3-methylpentanoic acid", "common_name": "isoleucine", "inchi": "InChI=1S/C6H13NO2/c1-3-4(2)5(7)6(8)9/h4-5H,3,7H2,1-2H3,(H,8,9)", "role": "target", "environment_formed": "Surface"}, {"id": "mol_012", "formula": "C3H4O3", "iupac_name": "2-oxopropanoic acid", "common_name": "pyruvic acid", "inchi": "InChI=1S/C3H4O3/c1-2(4)3(5)6/h1H3,(H,5,6)", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_013", "formula": "C2H2O3", "iupac_name": "oxoacetic acid", "common_name": "glyoxylic acid", "inchi": "InChI=1S/C2H2O3/c3-1-2(4)5/h1H,(H,4,5)", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_014", "formula": "C4H6O3", "iupac_name": "2-oxobutanoic acid", "common_name": "alpha-ketobutyric acid", "inchi": "InChI=1S/C4H6O3/c1-2-3(5)4(6)7/h2H2,1H3,(H,6,7)", "role": "intermediate", "environment_formed": "Biochemical"}, {"id": "mol_015", "formula": "C6H10O3", "iupac_name": "3-methyl-2-oxopentanoic acid", "common_name": "alpha-keto-beta-methylvalerate", "inchi": "InChI=1S/C6H10O3/c1-3-4(2)5(7)6(8)9/h4H,3H2,1-2H3,(H,8,9)", "role": "hub_intermediate", "environment_formed": "Biochemical"}, {"id": "mol_016", "formula": "C7H10N2O2", "iupac_name": "5-ethyl-4-methylimidazolidine-2,4-dione", "common_name": "isoleucine hydantoin", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_017", "formula": "CH4", "iupac_name": "methane", "common_name": "methane", "inchi": "InChI=1S/CH4/h1H4", "role": "starting", "environment_formed": null}, {"id": "mol_018", "formula": "H2S", "iupac_name": "sulfane", "common_name": "hydrogen sulfide", "inchi": "InChI=1S/H2S/h1H2", "role": "starting", "environment_formed": null}, {"id": "mol_019", "formula": "H2O", "iupac_name": "water", "common_name": "water", "inchi": "InChI=1S/H2O/h1H2", "role": "starting", "environment_formed": null}, {"id": "mol_020", "formula": "C4H9NO2", "iupac_name": "2-aminobutanoic acid", "common_name": "alpha-aminobutyric acid", "inchi": "InChI=1S/C4H9NO2/c1-2-3(5)4(6)7/h3H,2,5H2,1H3,(H,6,7)", "role": "intermediate", "environment_formed": "Surface"}], "reactions": [{"id": "rxn_001", "name": "Greigite-catalyzed reduction of CO2 to formate", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_005"], "environment": "Hydrothermal", "agents": ["greigite (Fe3S4)", "mackinawite (FeS)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "greigite", "aqueous": "true", "other": "alkaline vent conditions, anoxic, H2-rich"}, "mechanism": "Mineral-surface CO2 activation followed by stepwise hydrogenation to surface-bound formyl/formate species.", "reasoning": "Hydrothermal Fe-S mineral catalysis of CO2 reduction to formate is consistent with iron-sulfur world and vent-analog chemistry, with greigite and mackinawite acting as prebiotic [Fe-S] analogs; included here as feeder chemistry rather than a direct isoleucine-forming step, in line with the conclusion that hydrothermal systems support simple carbon fixation but have not demonstrated isoleucine synthesis (Huber & Wachtershauser, 1997; Russell & Hall, 2006; Martin & Russell, 2007; Cleaves et al., 2009)."}, {"id": "rxn_002", "name": "FeS/Fe0-mediated carbon fixation to acetate", "inputs": ["mol_005", "mol_002"], "outputs": ["mol_006"], "environment": "Hydrothermal", "agents": ["pyrite (FeS2)", "elemental iron (Fe0)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "pyrite and Fe0", "aqueous": "true", "other": "anoxic vent pore setting with reducing power from H2"}, "mechanism": "Further reduction and C-C bond formation from one-carbon species on iron-sulfur/iron surfaces gives simple C2 carboxylates.", "reasoning": "This step represents conservative hydrothermal feeder chemistry to small organics rather than a claim of direct isoleucine synthesis. It is aligned with FeS/NiS and iron-driven carbon-fixation analogs from hydrothermal literature and is used here only to connect vent carbon fixation to later surface chemistry (Huber & Wachtershauser, 1997; Russell & Hall, 2006; Martin & Russell, 2007; Cleaves et al., 2009)."}, {"id": "rxn_003", "name": "Magnetite-catalyzed Fischer-Tropsch-type formation of acetaldehyde", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_007"], "environment": "Hydrothermal", "agents": ["magnetite (Fe3O4)", "elemental iron (Fe0)"], "conditions": {"temperature": "400-500K", "pressure": "high", "catalyst": "magnetite", "aqueous": "true", "other": "subseafloor or vent-associated reducing conditions; product expected as mixture component"}, "mechanism": "Fischer-Tropsch-type surface reduction of carbon oxides generates mixed low-molecular-weight oxygenates including aldehydes.", "reasoning": "The literature report identifies Fischer-Tropsch-type synthesis on metal surfaces as one plausible source of the aldehyde precursor family needed for Strecker chemistry, but not as a clean, selective route; accordingly acetaldehyde is treated as a mixed-product feeder intermediate and not overstated (Pizzarello & Cronin, 2008; Huber & Wachtershauser, 1997; Cleaves et al., 2009)."}, {"id": "rxn_004", "name": "Hydrothermal pyruvate synthesis on magnetite/greigite", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_012"], "environment": "Hydrothermal", "agents": ["magnetite (Fe3O4)", "greigite (Fe3S4)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "magnetite and greigite", "aqueous": "true", "other": "anoxic alkaline hydrothermal setting"}, "mechanism": "Mineral-mediated CO2 reduction and C-C bond forming chemistry yields alpha-keto acid products including pyruvate in protometabolic networks.", "reasoning": "Pyruvate is included as a central protometabolic hub supported by prebiotic metabolism literature and as a plausible hydrothermal product, but this does not imply hydrothermal synthesis of isoleucine itself; the deep research explicitly notes hydrothermal systems are more relevant to keto-acid feeder chemistry than to direct isoleucine production (Springsteen et al., 2018; Ter-Ovanessian et al., 2025; Cleaves et al., 2009)."}, {"id": "rxn_005", "name": "Oxidative feeder formation of glyoxylate from formate/carboxylate pools", "inputs": ["mol_005"], "outputs": ["mol_013"], "environment": "Hydrothermal", "agents": ["pyrite (FeS2)", "magnetite (Fe3O4)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "pyrite and magnetite", "aqueous": "true", "other": "protometabolic vent network; included as a network connection to glyoxylate chemistry"}, "mechanism": "Fe-mediated carbonyl chemistry in protometabolic mixtures provides access to C2 oxoacids such as glyoxylate.", "reasoning": "Glyoxylate is a well-established central prebiotic metabolite in the literature summary and is necessary to connect pyruvate-centered protometabolism to alpha-ketobutyrate ideas; this exact feeder step is network-completion chemistry and is therefore more speculative than the Strecker core, but is constrained to simple protometabolic oxoacid generation rather than unsupported isoleucine synthesis (Springsteen et al., 2018; Kim et al., 2020; Cleaves et al., 2009)."}, {"id": "rxn_006", "name": "Volcanic spark discharge generation of HCN", "inputs": ["mol_017", "mol_003", "mol_018", "mol_019"], "outputs": ["mol_004"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "sulfide minerals (stibnite/molybdenite)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "mineral-rich volcanic aerosols and surfaces", "aqueous": "true", "other": "electrical discharge in reducing volcanic atmosphere; H2S-enhanced radical chemistry"}, "mechanism": "Electrical discharge fragments reduced gases to radicals and nitriles; HCN accumulates and dissolves into aqueous surface reservoirs.", "reasoning": "HCN production in Miller-Urey-type discharge systems is a foundational result for Strecker chemistry, and Parker et al. identified H2S-containing volcanic discharge conditions as particularly productive for branched amino acid synthesis. Mineral agents are included because the schema requires them for surface reactions, but the main energy source is electrical discharge (Miller, 1957; Ring et al., 1972; Parker et al., 2011)."}, {"id": "rxn_007", "name": "Volcanic spark discharge generation of 2-methylbutanal", "inputs": ["mol_017", "mol_018", "mol_019"], "outputs": ["mol_009"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "sulfide minerals (stibnite/molybdenite)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "mineral-rich volcanic surfaces", "aqueous": "true", "other": "electrical discharge; radical recombination promoted by H2S-derived sulfur radicals"}, "mechanism": "Discharge-generated alkyl radicals undergo recombination and oxidation to branched aldehydes, including the crucial C5 precursor 2-methylbutanal.", "reasoning": "The deep research identifies generation of 2-methylbutanal as the fundamental bottleneck and specifically notes radical chemistry in spark discharge, especially under H2S-containing volcanic conditions, as the strongest experimental context for access to isoleucine precursors. This is the literature-supported core precursor-forming step (Ring et al., 1972; Parker et al., 2011; Pizzarello & Cronin, 2008)."}, {"id": "rxn_008", "name": "Crossed-aldol access to 2-methylbutanal from acetaldehyde and propanal", "inputs": ["mol_007", "mol_008"], "outputs": ["mol_009"], "environment": "Surface", "agents": ["borate minerals (colemanite/ulexite)", "montmorillonite (clay)"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "borate minerals and clay surfaces", "aqueous": "true", "other": "evaporitic pool wet-dry concentration; pathway remains chemically plausible but less direct than discharge radical route"}, "mechanism": "Surface-promoted carbonyl condensation among small aldehydes gives a branched C5 aldehyde after dehydration/reduction sequence in mixed prebiotic pools.", "reasoning": "The research report explicitly lists crossed aldol condensation of acetaldehyde with propanal as one plausible route to 2-methylbutanal, but not as strongly demonstrated as spark discharge chemistry. It is therefore included as a secondary, literature-mentioned route to the same critical hub and should be regarded as plausible but less established (Pizzarello & Cronin, 2008; Ross & Deamer, 2016)."}, {"id": "rxn_009", "name": "Aqueous Strecker synthesis of isoleucine aminonitrile from 2-methylbutanal", "inputs": ["mol_009", "mol_003", "mol_004"], "outputs": ["mol_010"], "environment": "Surface", "agents": ["montmorillonite (clay)", "sulfide minerals (stibnite/molybdenite)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "mineral surfaces concentrating reagents", "aqueous": "true", "other": "imine formation followed by cyanide addition in aqueous pools"}, "mechanism": "Aldehyde condenses with ammonia to an imine, followed by nucleophilic HCN addition to give the alpha-aminonitrile.", "reasoning": "This is the dominant, best-supported route for prebiotic isoleucine formation. Miller identified Strecker chemistry as the principal mechanism in spark discharge products, and the specific isoleucine route from 2-methylbutanal, NH3, and HCN is directly described in the deep research summary (Miller, 1957; Ring et al., 1972; Eckhardt et al., 2022; Parker et al., 2011)."}, {"id": "rxn_010", "name": "Hydrolysis of isoleucine aminonitrile to racemic isoleucine", "inputs": ["mol_010", "mol_019"], "outputs": ["mol_011"], "environment": "Surface", "agents": ["montmorillonite (clay)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "mineral-assisted hydrolysis in aqueous pools", "aqueous": "true", "other": "gives racemic isoleucine plus alloisoleucine mixture under prebiotic conditions"}, "mechanism": "Stepwise nitrile hydrolysis through amide/carboxylate stages converts the aminonitrile into the amino acid.", "reasoning": "Hydrolysis of the Strecker aminonitrile is the final stage of the canonical prebiotic isoleucine route. The literature emphasizes that this process yields racemic material and does not solve the dual-chirality problem, but it remains the strongest experimentally grounded route to isoleucine (Miller, 1957; Ring et al., 1972; Parker et al., 2011; Bada & Schroeder, 1975)."}, {"id": "rxn_011", "name": "Pyruvate-glyoxylate route to alpha-ketobutyrate", "inputs": ["mol_012", "mol_013"], "outputs": ["mol_014"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "variable", "pressure": "1 atm", "catalyst": "null", "aqueous": "true", "other": "proto-metabolic network; nonenzymatic analogue inferred from underground biosynthetic logic"}, "mechanism": "Carbonyl coupling and rearrangement within alpha-keto acid/glyoxylate networks generates higher oxoacids including alpha-ketobutyrate-like products.", "reasoning": "The deep research specifically highlights alpha-ketobutyrate as a biologically central branch-point and notes underground biosynthetic routes from glyoxylate + pyruvate as prebiotically significant because both are central prebiotic metabolites. This specific prebiotic conversion remains unresolved and is therefore included as a speculative connector, not as an experimentally established isoleucine synthesis step (Kim et al., 2020; Springsteen et al., 2018)."}, {"id": "rxn_012", "name": "Assembly of 3-methyl-2-oxopentanoic acid from alpha-ketobutyrate and pyruvate equivalents", "inputs": ["mol_014", "mol_012"], "outputs": ["mol_015"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "variable", "pressure": "1 atm", "catalyst": "null", "aqueous": "true", "other": "protometabolic aldol/ketol chemistry; key unresolved bottleneck"}, "mechanism": "Nonenzymatic carbon-carbon bond formation extends the alpha-ketobutyrate skeleton to the branched C6 alpha-keto acid corresponding to isoleucine's direct keto precursor.", "reasoning": "The literature explicitly identifies alpha-keto-beta-methylvalerate as the penultimate biological intermediate and notes that its prebiotic formation might be accessible through nonenzymatic aldol chemistry, but that this has not been demonstrated. It is therefore a necessary but clearly speculative bottleneck node in metabolism-first branches (Ter-Ovanessian et al., 2025; deep research conclusion)."}, {"id": "rxn_013", "name": "FeS-mediated reductive amination of 3-methyl-2-oxopentanoic acid to isoleucine", "inputs": ["mol_015", "mol_003"], "outputs": ["mol_011"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "acidic hydrothermal-compatible moderate conditions", "pressure": "variable", "catalyst": "FeS or Fe(OH)2", "aqueous": "true", "other": "reductive amination analogue; included outside Hydrothermal class to avoid claiming vent de novo isoleucine synthesis"}, "mechanism": "Ammonia addition to the alpha-keto acid followed by mineral-mediated reduction yields the corresponding amino acid.", "reasoning": "Reductive amination of alpha-oxo acids to amino acids is experimentally demonstrated with FeS/Fe(OH)2 systems, but the deep research stresses that isoleucine production by this route depends entirely on the prior availability of 3-methyl-2-oxopentanoic acid and that hydrothermal vent simulations have not produced isoleucine. Accordingly this is an explicitly conditional, speculative endpoint branch (Hafenbradl et al., 1995; Huber & Wachtershauser, 2003; Cleaves et al., 2009)."}, {"id": "rxn_014", "name": "ZnS-UV photocatalytic amination of 3-methyl-2-oxopentanoic acid to isoleucine", "inputs": ["mol_015", "mol_003"], "outputs": ["mol_011"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "surface sunlight conditions", "pressure": "1 atm", "catalyst": "ZnS under UV illumination", "aqueous": "true", "other": "shallow illuminated settings; reversible amination chemistry"}, "mechanism": "Photoexcited ZnS generates electrons and holes that drive reversible reductive amination of alpha-keto acids.", "reasoning": "The failed prior attempt incorrectly emphasized TiO2 for this chemistry; the literature specifically identifies ZnS as the experimentally supported photocatalyst for reversible amination of alpha-keto acids. As with rxn_013, applicability to isoleucine is conditional on availability of the difficult branched alpha-keto precursor (Wang et al., 2012; deep research conclusion)."}, {"id": "rxn_015", "name": "Bucherer-Bergs conversion of 3-methyl-2-oxopentanoic acid to isoleucine hydantoin", "inputs": ["mol_015", "mol_004", "mol_003"], "outputs": ["mol_016"], "environment": "Surface", "agents": ["montmorillonite (clay)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "mineral-assisted concentration in aqueous pools", "aqueous": "true", "other": "cyanide/ammonia-mediated hydantoin formation from alpha-keto acids"}, "mechanism": "Alpha-keto acid reacts with cyanide and ammonia to give a hydantoin intermediate via Bucherer-Bergs chemistry.", "reasoning": "Pulletikurti et al. demonstrated Bucherer-Bergs as a bridge between Strecker-type prebiotic chemistry and biologically relevant alpha-keto acid substrates. The deep research states the chemistry is general but unresolved for isoleucine because precursor availability is the main problem, so this branch is included as a conditional but literature-grounded alternative endpoint route (Pulletikurti et al., 2022)."}, {"id": "rxn_016", "name": "Hydrolysis of isoleucine hydantoin to isoleucine", "inputs": ["mol_016", "mol_019"], "outputs": ["mol_011"], "environment": "Surface", "agents": ["phosphate minerals (apatite/struvite)", "montmorillonite (clay)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "mineral-assisted aqueous hydrolysis", "aqueous": "true", "other": "post-Bucherer-Bergs ring opening and hydrolysis"}, "mechanism": "Hydantoin ring opening and hydrolysis furnish the amino acid product.", "reasoning": "Hydantoin hydrolysis is the terminal step of the Bucherer-Bergs route. Included because the literature identifies Bucherer-Bergs as a demonstrated prebiotic amino-acid-forming process generalizable to alpha-keto acids, while acknowledging unresolved access to the required branched precursor for isoleucine (Pulletikurti et al., 2022)."}, {"id": "rxn_017", "name": "Meteorite parent-body Strecker synthesis to isoleucine aminonitrile precursor pool", "inputs": ["mol_009", "mol_003", "mol_004"], "outputs": ["mol_010"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "low to moderate parent-body aqueous alteration conditions", "pressure": "variable", "catalyst": "null", "aqueous": "true", "other": "extraterrestrial aqueous chemistry preserved in carbonaceous chondrites"}, "mechanism": "Parent-body aqueous Strecker chemistry from branched aldehydes forms isoleucine aminonitrile and then amino acid upon hydrolysis.", "reasoning": "The research summary explicitly states meteoritic/parent-body Strecker chemistry is one of the three experimentally supported contexts for prebiotic isoleucine, with isotopic evidence showing the existence of the branched aldehyde precursor in meteorite parent bodies. This reaction node captures that independent source to the same aminonitrile hub (Pizzarello & Cronin, 2008; Cronin et al., 1981; Glavin et al., 2021)."}, {"id": "rxn_018", "name": "UV/EUV photolysis of PAH-containing ices yielding isoleucine", "inputs": ["mol_003", "mol_019"], "outputs": ["mol_011"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "borate minerals (colemanite/ulexite)"], "conditions": {"temperature": "cryogenic ice photolysis followed by warming", "pressure": "low to 1 atm after deposition", "catalyst": "UV/EUV photons", "aqueous": "false", "other": "PAH-rich ice analog chemistry as extraterrestrial feedstock deposited to surface"}, "mechanism": "Energetic photolysis of aromatic ice mixtures generates complex organics that, upon warm-up/hydrolysis, include amino acids such as isoleucine.", "reasoning": "Chen et al. reported isoleucine among amino acids produced by UV/EUV photolysis of naphthalene + H2O + NH3 ices. This is an experimentally positive but non-terrestrial-assembly route; in the network it functions as an independent source of the target entering surface reservoirs, not as a contradiction to the dominant Strecker pipeline (Chen et al., 2008; Bernstein et al., 2002; Munoz Caro et al., 2002)."}, {"id": "rxn_019", "name": "Surface concentration and preservation of isoleucine in wet-dry pools", "inputs": ["mol_011"], "outputs": ["mol_011"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "null", "aqueous": "true", "other": "wet-dry cycling, urea-rich or mineral interfaces, concentration up to ~1400-fold"}, "mechanism": "No net chemical transformation; concentration by evaporation, adsorption, and cycling increases local availability for further prebiotic chemistry.", "reasoning": "Although not a synthetic transformation to a new molecule, concentration is essential for a trace amino acid such as isoleucine. The literature emphasizes wet-dry cycling and pool concentration as critical for preserving and accumulating scarce products from discharge or exogenous input (Ross & Deamer, 2016; Ferris, 2005; Zhang et al., 2023)."}, {"id": "rxn_020", "name": "Strecker synthesis of alpha-aminobutyric acid as a branch-comparison route", "inputs": ["mol_008", "mol_003", "mol_004"], "outputs": ["mol_020"], "environment": "Surface", "agents": ["montmorillonite (clay)", "sulfide minerals (stibnite/molybdenite)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "mineral-assisted concentration in aqueous pools", "aqueous": "true", "other": "canonical Strecker chemistry from propanal"}, "mechanism": "Propanal undergoes imine formation and cyanide addition followed by hydrolysis to give alpha-aminobutyric acid.", "reasoning": "The research highlights alpha-aminobutyric acid as an easier 4-carbon analogue that is readily formed in Miller experiments and meteorites, illustrating the carbon-skeleton bottleneck specific to isoleucine. This branch is included to show network convergence around HCN and aldehyde chemistry and to contextualize why isoleucine is rare (Ring et al., 1972; Parker et al., 2011; deep research summary)."}], "pathways": [{"pathway_id": "P1", "name": "Volcanic H2S spark-discharge Strecker route", "description": "Best-supported terrestrial route: H2S-containing spark discharge generates both HCN and branched aldehyde precursor 2-methylbutanal, which undergoes Strecker synthesis and hydrolysis to isoleucine.", "reaction_sequence": ["rxn_006", "rxn_007", "rxn_009", "rxn_010"], "key_intermediates": ["mol_004", "mol_009", "mol_010"]}, {"pathway_id": "P2", "name": "Classic reducing-atmosphere spark-discharge Strecker route", "description": "Variant of the discharge route supported by Ring et al. detection of isoleucine in CH4/N2/NH3/H2O spark mixtures; converges on the same Strecker core.", "reaction_sequence": ["rxn_006", "rxn_007", "rxn_009", "rxn_010"], "key_intermediates": ["mol_004", "mol_009", "mol_010"]}, {"pathway_id": "P3", "name": "Hydrothermal carbon fixation feeding surface aldol-Strecker route", "description": "Hydrothermal production of acetaldehyde feeds surface carbonyl chemistry, where crossed-aldol access to 2-methylbutanal converges with HCN-mediated Strecker synthesis.", "reaction_sequence": ["rxn_003", "rxn_008", "rxn_006", "rxn_009", "rxn_010"], "key_intermediates": ["mol_007", "mol_009", "mol_004", "mol_010"]}, {"pathway_id": "P4", "name": "Meteorite parent-body Strecker route", "description": "Extraterrestrial branched aldehydes and HCN/NH3 aqueous chemistry produce the same aminonitrile intermediate later delivered to or mirrored on Earth.", "reaction_sequence": ["rxn_017", "rxn_010"], "key_intermediates": ["mol_010"]}, {"pathway_id": "P5", "name": "PAH-ice UV photolysis route", "description": "Independent experimentally positive route in which UV/EUV photolysis of PAH-containing ices yields isoleucine directly after warm-up/hydrolysis.", "reaction_sequence": ["rxn_018"], "key_intermediates": []}, {"pathway_id": "P6", "name": "Protometabolic keto-acid route with FeS reductive amination", "description": "Hydrothermal pyruvate and glyoxylate feed a speculative alpha-ketobutyrate-to-alpha-keto-beta-methylvalerate branch, followed by FeS-mediated reductive amination to isoleucine.", "reaction_sequence": ["rxn_004", "rxn_005", "rxn_011", "rxn_012", "rxn_013"], "key_intermediates": ["mol_012", "mol_013", "mol_014", "mol_015"]}, {"pathway_id": "P7", "name": "Protometabolic keto-acid route with ZnS photocatalytic amination", "description": "Same speculative branched keto-acid assembly as P6, but the final amino-acid-forming step uses the literature-supported ZnS UV amination chemistry rather than FeS reductive amination.", "reaction_sequence": ["rxn_004", "rxn_005", "rxn_011", "rxn_012", "rxn_014"], "key_intermediates": ["mol_012", "mol_013", "mol_014", "mol_015"]}, {"pathway_id": "P8", "name": "Protometabolic Bucherer-Bergs route", "description": "Branched alpha-keto acid formed in a speculative protometabolic network is converted by Bucherer-Bergs chemistry through a hydantoin intermediate to isoleucine.", "reaction_sequence": ["rxn_004", "rxn_005", "rxn_011", "rxn_012", "rxn_015", "rxn_016"], "key_intermediates": ["mol_014", "mol_015", "mol_016"]}, {"pathway_id": "P9", "name": "Hydrothermal-to-surface mixed feeder route to Strecker isoleucine", "description": "Vent chemistry supplies simple carbon pools, while surface discharge produces HCN and branched aldehyde; environmental crossover culminates in standard Strecker hydrolysis.", "reaction_sequence": ["rxn_001", "rxn_002", "rxn_003", "rxn_006", "rxn_007", "rxn_009", "rxn_010"], "key_intermediates": ["mol_005", "mol_006", "mol_007", "mol_004", "mol_009", "mol_010"]}, {"pathway_id": "P10", "name": "Concentrated surface-pool preservation pathway", "description": "Once generated by discharge Strecker or exogenous input, isoleucine is concentrated and preserved in wet-dry pools to become available for later prebiotic chemistry.", "reaction_sequence": ["rxn_006", "rxn_007", "rxn_009", "rxn_010", "rxn_019"], "key_intermediates": ["mol_004", "mol_009", "mol_010", "mol_011"]}], "hub_molecules": ["mol_004", "mol_009", "mol_010", "mol_012", "mol_015"], "convergence_points": [{"molec
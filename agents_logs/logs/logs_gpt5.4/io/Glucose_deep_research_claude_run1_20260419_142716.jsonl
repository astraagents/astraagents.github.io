 "mol_013"], "environment": "Surface", "agents": ["montmorillonite (clay)", "borate minerals (colemanite/ulexite)"], "conditions": {"temperature": "ambient upon deposition", "pressure": "1 atm", "catalyst": "none; exogenous delivery followed by adsorption/concentration on minerals", "aqueous": "false", "other": "extraterrestrial infall from meteorites/asteroidal parent bodies"}, "mechanism": "Exogenous delivery seeds the surface environment with preformed sugar precursors and some glucose, which can then enter local concentration, stabilization, and downstream chemistry.", "reasoning": "Glycolaldehyde has been detected in interstellar and protostellar environments, and Furukawa et al. detected sugars in meteorites and glucose in Bennu samples, establishing extraterrestrial delivery as a documented source rather than an invented pathway (Hollis et al., 2000; Jorgensen et al., 2012; Furukawa et al., 2019; Furukawa et al., 2025)."}, {"id": "rxn_014", "name": "Borate-assisted phosphorylation of glucose to glucose 6-phosphate", "inputs": ["mol_013"], "outputs": ["mol_018"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "thermal evaporation", "pressure": "1 atm", "catalyst": "borate-rich evaporitic milieu with phosphate source", "aqueous": "false", "other": "drying-rehydration cycles in volcanic/hydrothermal evaporative pools"}, "mechanism": "Regioselective phosphorylation under evaporative borate-rich conditions converts glucose into the more metabolically relevant and potentially stabilized glucose 6-phosphate.", "reasoning": "Furukawa et al. showed that borate-rich evaporative settings enable regioselective phosphorylation of glucose to glucose 6-phosphate, linking abiotic glucose production to proto-glycolytic chemistry (Furukawa et al., 2023)."}], "pathways": [{"pathway_id": "P1", "name": "Vent CO2 to formaldehyde to canonical formose to glucose", "description": "Hydrothermal CO2 reduction supplies formaldehyde, which enters the canonical surface formose sequence to glycolaldehyde and glyceraldehyde, then mild C3 condensation to fructose and isomerization to glucose.", "reaction_sequence": ["rxn_001", "rxn_002", "rxn_004", "rxn_005", "rxn_008", "rxn_009"], "key_intermediates": ["mol_003", "mol_006", "mol_007", "mol_011"]}, {"pathway_id": "P2", "name": "Vent formaldehyde plus cyanosulfidic glycolaldehyde convergence", "description": "Hydrothermal formaldehyde converges with surface-cyanosulfidic glycolaldehyde, then proceeds through glyceraldehyde and fructose to glucose.", "reaction_sequence": ["rxn_001", "rxn_002", "rxn_003", "rxn_005", "rxn_008", "rxn_009"], "key_intermediates": ["mol_003", "mol_006", "mol_007", "mol_011"]}, {"pathway_id": "P3", "name": "Pure cyanosulfidic route via fructose", "description": "HCN and H2S under UV generate glycolaldehyde and glyceraldehyde directly, bypassing the formaldehyde bottleneck, followed by goethite-type ketohexose formation and fructose-to-glucose isomerization.", "reaction_sequence": ["rxn_003", "rxn_008", "rxn_009"], "key_intermediates": ["mol_006", "mol_007", "mol_011"]}, {"pathway_id": "P4", "name": "Pure cyanosulfidic route via sorbose", "description": "The same cyanosulfidic entry chemistry feeds goethite-catalyzed ketohexose formation, but glucose is reached through sorbose-containing hexose pools.", "reaction_sequence": ["rxn_003", "rxn_008", "rxn_010"], "key_intermediates": ["mol_007", "mol_012"]}, {"pathway_id": "P5", "name": "Canonical formose route seeded by external glycolaldehyde", "description": "A small glycolaldehyde inventory from delivery or other settings seeds the Breslow cycle; glyceraldehyde then condenses to fructose and isomerizes to glucose.", "reaction_sequence": ["rxn_013", "rxn_005", "rxn_008", "rxn_009"], "key_intermediates": ["mol_006", "mol_007", "mol_011"]}, {"pathway_id": "P6", "name": "Extraterrestrial direct glucose delivery", "description": "Glucose arrives directly on meteorites or asteroid-derived material and is inco
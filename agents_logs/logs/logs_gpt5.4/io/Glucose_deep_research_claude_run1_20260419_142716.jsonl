     \"formula\": \"C6H12O6\",\n      \"iupac_name\": \"(3S,4R,5R)-1,3,4,5,6-pentahydroxyhexan-2-one\",\n      \"common_name\": \"D-fructose\",\n      \"inchi\": \"InChI=1S/C6H12O6/c7-1-2(8)3(9)4(10)5(11)6(12)13/h2-5,7-12H,1H2\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_017\",\n      \"formula\": \"C6H12O6\",\n      \"iupac_name\": \"(2R,3S,4S,5R)-1,2,3,4,5,6-hexahydroxyhexanal\",\n      \"common_name\": \"D-glucose\",\n      \"inchi\": \"InChI=1S/C6H12O6/c7-1-2(8)3(9)4(10)5(11)6(12)13/h1-12H\",\n      \"role\": \"target\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_018\",\n      \"formula\": \"C6H13O9P\",\n      \"iupac_name\": \"[(2R,3S,4S,5R)-3,4,5,6-tetrahydroxy-2-(hydroxymethyl)oxan-2-yl] dihydrogen phosphate\",\n      \"common_name\": \"glucose 6-phosphate\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_019\",\n      \"formula\": \"PO4H3\",\n      \"iupac_name\": \"phosphoric acid\",\n      \"common_name\": \"phosphate\",\n      \"inchi\": \"InChI=1S/H3O4P/c1-5(2,3)4/h(H3,1,2,3,4)\",\n      \"role\": \"starting\",\n      \"environment_formed\": null\n    },\n    {\n      \"id\": \"mol_020\",\n      \"formula\": \"C6H12O7\",\n      \"iupac_name\": \"2,3,4,5,6-pentahydroxyhexanoic acid\",\n      \"common_name\": \"gluconic acid/gluconate\",\n      \"inchi\": \"InChI=1S/C6H12O7/c7-1-2(8)3(9)4(10)5(11)6(12)13/h2-5,7-11H,1H2,(H,12,13)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"Hydrothermal CO2 reduction to formaldehyde/formate feedstock\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_003\", \"mol_004\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe3S4)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"313-363K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"greigite (Fe3S4), mackinawite (FeS)\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline hydrothermal vent analog, pH 9-11; low-yield vent feedstock generation rather than selective sugar synthesis\"\n      },\n      \"mechanism\": \"Mineral-mediated reduction of CO2 by H2 across FeS-type catalytic surfaces generates reduced C1 products, including formaldehyde and formate, that can seed downstream surface chemistry.\",\n      \"reasoning\": \"Included as a low-yield hydrothermal feeder module because the literature report explicitly cites Lane-group vent analog proof-of-principle CO2 reduction to formaldehyde under Lost City-like alkaline vent conditions and notes formaldehyde as a key C1 entry point, but also emphasizes that this is not a robust selective glucose route and should not be overstated (Pinto et al., 1980; Roldan et al., 2015; research summary citing Lane-group vent reactor work).\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Thiophosphate generation in cyanosulfidic surface chemistry\",\n      \"inputs\": [\"mol_019\", \"mol_006\"],\n      \"outputs\": [\"mol_007\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (molybdenite/stibnite)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"ambient\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO2 and sulfide mineral-assisted UV photochemistry\",\n        \"aqueous\": \"true\",\n        \"other\": \"UV-irradiated surface pool; thiophosphate formed from reduced phosphorus species oxidized in the presence of sulfide under UV\"\n      },\n      \"mechanism\": \"UV-driven sulfur-phosphorus redox chemistry generates thiophosphate, an improved photoreductant for subsequent HCN homologation chemistry.\",\n      \"reasoning\": \"The supplied literature identifies thiophosphate as a much more effective photoreductant than H2S alone in cyanosulfidic sugar precursor synthesis, though natural generation depends on reduced phosphorus availability and UV/sulfide chemistry. This connector step is necessary to represent the experimentally validated 2023 cyanosulfidic regime (Ritson & Sutherland, 2023).\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Cyanosulfidic photoreduction of HCN to glycolaldehyde\",\n      \"inputs\": [\"mol_005\", \"mol_007\"],\n      \"outputs\": [\"mol_008\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (molybdenite/stibnite)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"ambient\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"UV photoredox with thiophosphate-enabled reduction\",\n        \"aqueous\": \"true\",\n        \"other\": \"phosphate-buffered pH 6.5; UV-active surface environment; overall glycolaldehyde yield about 34%\"\n      },\n      \"mechanism\": \"Reductive homologation of HCN under UV photoredox conditions forms C2 carbohydrate precursors directly, bypassing the formaldehyde dimerization bottleneck.\",\n      \"reasoning\": \"This is one of the strongest literature-supported entry routes to sugar chemistry. The report highlights direct glycolaldehyde formation from HCN via UV-driven cyanosulfidic chemistry and specifically notes improved yields with thiophosphate at pH 6.5 (Ritson & Sutherland, 2012; Patel et al., 2015; Ritson & Sutherland, 2023).\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"Cyanosulfidic photoreduction of HCN-derived intermediates to glyceraldehyde\",\n      \"inputs\": [\"mol_008\", \"mol_005\", \"mol_007\"],\n      \"outputs\": [\"mol_009\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (molybdenite/stibnite)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"ambient\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"UV photoredox with thiophosphate-enabled reduction\",\n        \"aqueous\": \"true\",\n        \"other\": \"phosphate buffer around pH 6.5; evaporation/concentration step; overall glyceraldehyde yield about 14%\"\n      },\n      \"mechanism\": \"Continued reductive homologation extends C2 glycolaldehyde chemistry to the C3 sugar glyceraldehyde under UV-driven cyanosulfidic conditions.\",\n      \"reasoning\": \"The literature explicitly identifies glycolaldehyde and glyceraldehyde formation by cyanosulfidic reductive homologation as a central alternative to classical formose initiation and one of the best-established prebiotic routes to sugar precursors (Ritson & Sutherland, 2012; Patel et al., 2015; Ritson & Sutherland, 2023).\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"Low-confidence formose initiation and propagation to glycolaldehyde/glyceraldehyde\",\n      \"inputs\": [\"mol_003\"],\n      \"outputs\": [\"mol_008\", \"mol_009\", \"mol_010\", \"mol_011\", \"mol_012\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"phosphate minerals (apatite/struvite)\", \"borate minerals (colemanite/ulexite)\"],\n      \"conditions\": {\n        \"temperature\": \"323-353K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"alkaline mineral-rich evaporitic pool chemistry\",\n        \"aqueous\": \"true\",\n        \"other\": \"classical formose-like alkaline regime; highly nonselective; included only as a weak feeder because Cannizzaro side reaction dominates and mild systems produce branched sugars\"\n      },\n      \"mechanism\": \"Autocatalytic aldol/isomerization network beginning from formaldehyde produces a heterogeneous pool of C2-C5 sugars once glycolaldehyde crosses a threshold concentration, but with extensive side reactions and degradation.\",\n      \"reasoning\": \"This reaction is included only to reflect the canonical literature route while explicitly downgrading its confidence. The supplied report states that formaldehyde dimerization is the principal kinetic bottleneck, Cannizzaro disproportionation is favored, and a 2025 NMR study indicates mild formose chemistry fundamentally yields branched rather than linear sugars. Thus this module is a low-confidence contributor to precursor pools, not a primary glucose route (Butlerov, 1861; Breslow, 1959; Appayee & Breslow, 2014; Socha et al., 1980; Tran et al., 2023; Omran et al., 2020; Pulletikurti et al., 2025; Nishijima et al., 2026).\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"Glyceraldehyde-dihydroxyacetone isomerization\",\n      \"inputs\": [\"mol_009\"],\n      \"outputs\": [\"mol_010\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"basic mineral-assisted isomerization\",\n        \"aqueous\": \"true\",\n        \"other\": \"Lobry de Bruyn-Alberda van Ekenstein transformation; equilibrium favors ketotriose under basic conditions\"\n      },\n      \"mechanism\": \"Aldose-ketose interconversion converts glyceraldehyde into dihydroxyacetone through carbonyl migration.\",\n      \"reasoning\": \"The report identifies glyceraldehyde as the central branch point and notes its isomerization to dihydroxyacetone under basic conditions as a core feature of prebiotic sugar networks. Mineral support is included to satisfy surface-agent requirements and to reflect stabilization/organization in evaporitic mineral environments (Breslow, 1959; Appayee & Breslow, 2014; Ricardo et al., 2004; Kim et al., 2011).\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Stepwise sugar growth from glycolaldehyde/glyceraldehyde to tetrose and pentose pools\",\n      \"inputs\": [\"mol_008\", \"mol_009\", \"mol_010\"],\n      \"outputs\": [\"mol_011\", \"mol_012\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite)\", \"molybdate-bearing minerals\"],\n      \"conditions\": {\n        \"temperature\": \"338K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"borate-molybdate-calcium guided sugar rearrangement network\",\n        \"aqueous\": \"true\",\n        \"other\": \"hands-off mineral-guided system around 65C; borate stabilizes sugars and molybdate promotes rearrangements toward linear species\"\n      },\n      \"mechanism\": \"Aldol growth and rearrangement of lower sugars produce tetrose and pentose pools, while borate complexes suppress degradation and molybdate promotes rearrangement toward biologically relevant linear sugars.\",\n      \"reasoning\": \"The research highlights borate as the most important sugar stabilizer and notes combined borate, molybdate, and calcium minerals guide tetrose, pentose, and heptose formation in hands-off experiments at 65C. This provides a literature-backed way to represent stepwise sugar growth without overclaiming direct selective glucose synthesis (Ricardo et al., 2004; Kim et al., 2011; Furukawa et al., 2013).\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Glyoxylate dimerization to dihydroxyfumarate\",\n      \"inputs\": [\"mol_013\"],\n      \"outputs\": [\"mol_014\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite)\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral-organized evaporitic pool chemistry\",\n        \"aqueous\": \"true\",\n        \"other\": \"included as a speculative connection because the literature emphasizes that no known robust prebiotic source of DHF has yet been demonstrated\"\n      },\n      \"mechanism\": \"Carboxylated C2 building blocks are linked into the formal glyoxylate dimer dihydroxyfumarate, enabling cleaner downstream ketose formation chemistry.\",\n      \"reasoning\": \"The glyoxylate scenario is explicitly discussed in the supplied report as chemically cleaner than formose chemistry, but the report also stresses that prebiotic DHF supply is unresolved. This connector is therefore marked speculative yet necessary to represent the literature-recognized glyoxylate route (Eschenmoser, 2007; Sagi et al., 2012; Krishnamurthy group, 2023).\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"DHF plus glyceraldehyde gives clean pentose ketose pool\",\n      \"inputs\": [\"mol_014\", \"mol_009\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite)\", \"molybdate-bearing minerals\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral-guided glyoxylose-like aldol chemistry\",\n        \"aqueous\": \"true\",\n        \"other\": \"clean ketose-forming chemistry; literature reports about 60% yield to xylulose/ribulose from DHF + glyceraldehyde\"\n      },\n      \"mechanism\": \"Dihydroxyfumarate reacts with glyceraldehyde to produce pentose ketoses through selective aldol chemistry distinct from the messy formose network.\",\n      \"reasoning\": \"The report specifically notes experimental validation that DHF plus glyceraldehyde gives xylulose and ribulose in roughly 60% yield with clean ketose selectivity and no detectable aldoses. This branch is therefore included as a better-defined alternative to canonical formose chemistry, while acknowledging unresolved DHF sourcing (Sagi et al., 2012; Krishnamurthy group, 2023).\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"Goethite-catalyzed C3 plus C3 condensation to ketohexose pool\",\n      \"inputs\": [\"mol_009\"],\n      \"outputs\": [\"mol_015\", \"mol_016\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"goethite (FeOOH)\", \"borate minerals (colemanite/ulexite)\"],\n      \"conditions\": {\n        \"temperature\": \"298K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"goethite (FeOOH)\",\n        \"aqueous\": \"true\",\n        \"other\": \"pH 5-6; mild aqueous conditions; no hexose decomposition observed even after 96 days; reported products include sorbose 15.2%, fructose 12.9%, psicose 6.1%, tagatose 5.6%\"\n      },\n      \"mechanism\": \"Surface-catalyzed aldol condensation of glyceraldehyde molecules yields a stable ketohexose pool dominated by fructose and sorbose under mild conditions.\",\n      \"reasoning\": \"This is the strongest direct literature-supported branch toward C6 sugars. The report identifies Weber's iron hydroxide/goethite chemistry as one of the most promising modules for prebiotic hexose synthesis, specifically under mild pH 5-6 and 25C conditions with substantial ketohexose yields and excellent stability (Weber, 1992; Jong et al., 2025).\"\n    },\n    {\n      \"id\": \"rxn_011\",\n      \"name\": \"Pentose/tetrose plus formaldehyde extension to ketohexose pool\",\n      \"inputs\": [\"mol_011\", \"mol_012\", \"mol_003\"],\n      \"outputs\": [\"mol_015\", \"mol_016\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite)\", \"molybdate-bearing minerals\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"borate-molybdate guided aldol extension\",\n        \"aqueous\": \"true\",\n        \"other\": \"included as a lower-confidence extension module reflecting literature recommendation to consider C4+C2 and C5+C1 routes to hexoses, not as a selective demonstrated glucose synthesis\"\n      },\n      \"mechanism\": \"Stepwise aldol extension of stabilized tetrose/pentose pools by C1 addition expands carbon skeletons into a broader ketohexose pool.\",\n      \"reasoning\": \"The research summary explicitly states that hexose formation can proceed through C4+C2 and C5+C1 routes in addition to C3+C3, and recommends such branching in network design. However, it also makes clear that selective glucose formation by these routes has not been demonstrated, so this reaction is retained as a speculative but literature-motivated connector rather than a strong core route (Breslow, 1959; Appayee & Breslow, 2014; Kim et al., 2011; research summary conclusion).\"\n    },\n    {\n      \"id\": \"rxn_012\",\n      \"name\": \"Ketohexose pool equilibration to fructose\",\n      \"inputs\": [\"mol_015\"],\n      \"outputs\": [\"mol_016\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite)\", \"molybdate-bearing minerals\"],\n      \"conditions\": {\n        \"temperature\": \"298-338K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral-guided ketohexose equilibration\",\n        \"aqueous\": \"true\",\n        \"other\": \"mild surface pool equilibration; borate traps/stabilizes cyclic sugars and molybdate can assist linearization/rearrangement chemistry\"\n      },\n      \"mechanism\": \"Interconversion within the ketohexose pool enriches fructose as an accessible precursor to glucose through subsequent aldose-ketose rearrangement.\",\n      \"reasoning\": \"The report stresses that prebiotic C3+C3 condensation primarily yields ketohexoses such as fructose and sorbose, with fructose being the most direct precursor to glucose by subsequent Lobry de Bruyn-type rearrangement. Borate and molybdate are included because the supplied literature emphasizes their roles in stabilization and in guiding linear-sugar-relevant rearrangements (Weber, 1992; Ricardo et al., 2004; Kim et al., 2011; research summary section 3 and conclusion).\"\n    },\n    {\n      \"id\": \"rxn_013\",\n      \"name\": \"Aldose-ketose isomerization of fructose to glucose\",\n      \"inputs\": [\"mol_016\"],\n      \"outputs\": [\"mol_017\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"null\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"null\",\n        \"aqueous\": \"true\",\n        \"other\": \"non-enzymatic Lobry de Bruyn-Alberda van Ekenstein rearrangement in mildly basic or cycling aqueous environments; glucose captured by thermodynamic stability of beta-pyranose form\"\n      },\n      \"mechanism\": \"Fructose undergoes aldose-ketose rearrangement through an enediol-type manifold to furnish glucose within an equilibrating hexose pool.\",\n      \"reasoning\": \"The supplied report specifically states that the formose/condensation network primarily produces fructose and that glucose arises through subsequent interconversion among glucose, fructose, and mannose. It also notes glucose is the most thermodynamically stable aldohexose because of its favorable pyranose chair conformation, supporting its accumulation from an equilibrating pool (Appayee & Breslow, 2014; research summary section 3).\"\n    },\n    {\n      \"id\": \"rxn_014\",\n      \"name\": \"Extraterrestrial delivery of glycolaldehyde and glucose\",\n      \"inputs\": [],\n      \"outputs\": [\"mol_008\", \"mol_017\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\", \"borate minerals (colemanite/ulexite)\"],\n      \"conditions\": {\n        \"temperature\": \"variable\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral capture and concentration after meteoritic infall\",\n        \"aqueous\": \"true\",\n        \"other\": \"meteoritic/asteroidal deposition into ponds, sediments, or evaporitic pools; not a terrestrial synthesis step but a validated abiotic source\"\n      },\n      \"mechanism\": \"Exogenous delivery seeds surface environments with preformed sugars and sugar precursors that can enter terrestrial stabilization and transformation networks.\",\n      \"reasoning\": \"The research report explicitly identifies extraterrestrial delivery as a complementary source and cites direct detection of glycolaldehyde in astronomical environments and glucose in pristine Bennu samples. This node is therefore essential to a literature-faithful convergent glucose network (Hollis et al., 2000; Jorgensen et al., 2012; Furukawa et al., 2019; Furukawa et al., 2025).\"\n    },\n    {\n      \"id\": \"rxn_015\",\n      \"name\": \"Borate-assisted stabilization and phosphorylation of glucose to glucose 6-phosphate\",\n      \"inputs\": [\"mol_017\", \"mol_019\"],\n      \"outputs\": [\"mol_018\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"null\"],\n      \"conditions\": {\n        \"temperature\": \"thermal evaporation\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"borate-rich evaporative concentration context inherited from prior surface setting\",\n        \"aqueous\": \"false\",\n        \"other\": \"drying/rehydration cycle in borate-rich pools; product stabilizes glucose in proto-metabolic contexts\"\n      },\n      \"mechanism\": \"Evaporative concentration in borate-rich settings promotes selective glucose phosphorylation, linking abiotic sugar synthesis to proto-glycolytic chemistry.\",\n      \"reasoning\": \"Although glucose is the network target, this downstream step is included to connect surface-generated glucose into the biochemical/prebiotic regime and reflect the supplied literature that borate-rich evaporative environments promote regioselective phosphorylation of glucose to glucose 6-phosphate, helping stabilize and metabolically recruit the sugar (Furukawa et al., 2023; Damer & Deamer, 2020).\"\n    },\n    {\n      \"id\": \"rxn_016\",\n      \"name\": \"Oxidation of glucose to gluconate as stable reservoir\",\n      \"inputs\": [\"mol_017\"],\n      \"outputs\": [\"mol_020\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"borate minerals (colemanite/ulexite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"photochemical/mineral-assisted oxidation in surface pools\",\n        \"aqueous\": \"true\",\n        \"other\": \"sugar-acid reservoir chemistry; relevant because meteorites often preserve aldonates rather than free sugars\"\n      },\n      \"mechanism\": \"Partial oxidation converts glucose into more persistent sugar-acid reservoirs that may preserve hexose carbon skeletons under prebiotic conditions.\",\n      \"reasoning\": \"The supplied report notes that aldonates are abundant in meteorites while canonical sugars are often absent, suggesting sugar acids may function as stable reservoirs. Furukawa et al. 2023 also showed borate-rich evaporative systems can phosphorylate gluconate analogously. This reaction contextualizes glucose persistence rather than claiming a primary synthetic route (Yi et al., 2023; Furukawa et al., 2023).\"\n    }\n  ],\n  \"pathways\": [\n    {\n      \"pathway_id\": \"P1\",\n      \"name\": \"Cyanosulfidic to goethite-fructose to glucose\",\n      \"description\": \"Best-supported terrestrial pathway: HCN photoredox chemistry yields glycolaldehyde and glyceraldehyde, then goethite catalyzes C3+C3 condensation to ketohexoses dominated by fructose, which equilibrates to glucose.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_003\", \"rxn_004\", \"rxn_010\", \"rxn_013\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_008\", \"mol_009\", \"mol_016\"]\n    },\n    {\n      \"pathway_id\": \"P2\",\n      \"name\": \"Extraterrestrial glycolaldehyde to goethite hexose route\",\n      \"description\": \"Delivered glycolaldehyde enters terrestrial surface chemistry, is extended to glyceraldehyde through cyanosulfidic homologation, then condensed on goethite to fructose and isomerized to glucose.\",\n      \"reaction_sequence\": [\"rxn_014\", \"rxn_002\", \"rxn_004\", \"rxn_010\", \"rxn_013\"],\n      \"key_intermediates\": [\"mol_008\", \"mol_009\", \"mol_016\"]\n    },\n    {\n      \"pathway_id\": \"P3\",\n      \"name\": \"Hydrothermal C1 feedstock to weak formose to glucose\",\n      \"description\": \"Low-confidence route included only because the literature identifies vent-derived formaldehyde as a possible feeder and formose as the canonical historical network, despite strong selectivity and branching problems.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_005\", \"rxn_010\", \"rxn_013\"],\n      \"key_intermediates\": [\"mol_003\", \"mol_009\", \"mol_016\"]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"Hydrothermal feedstock with borate-molybdate stepwise growth\",\n      \"description\": \"Vent-derived formaldehyde seeds lower-sugar pools through weak formose chemistry, then borate/molybdate-guided tetrose-pentose growth and formaldehyde extension feed a ketohexose pool before fructose-glucose equilibration.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_005\", \"rxn_007\", \"rxn_011\", \"rxn_013\"],\n      \"key_intermediates\": [\"mol_003\", \"mol_011\", \"mol_012\", \"mol_015\", \"mol_016\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"Cyanosulfidic lower-sugar growth to hexose extension route\",\n      \"description\": \"HCN photochemistry supplies glycolaldehyde and glyceraldehyde, which enter borate/molybdate-guided tetrose/pentose growth and then C1 extension to the ketohexose pool before glucose formation.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_003\", \"rxn_004\", \"rxn_007\", \"rxn_011\", \"rxn_013\"],\n      \"key_intermediates\": [\"mol_008\", \"mol_009\", \"mol_011\", \"mol_012\", \"mol_016\"]\n    },\n    {\n      \"pathway_id\": \"P6\",\n      \"name\": \"Glyoxylate-DHF pentose route plus C1 extension\",\n      \"description\": \"Cleaner glyoxylate scenario: DHF reacts with glyceraldehyde to give pentose ketoses, which are extended with formaldehyde into a ketohexose pool and then equilibrated to glucose.\",\n      \"reaction_sequence\": [\"rxn_008\", \"rxn_009\", \"rxn_011\", \"rxn_013\"],\n      \"key_intermediates\": [\"mol_014\", \"mol_012\", \"mol_016\"]\n    },\n    {\n      \"pathway_id\": \"P7\",\n      \"name\": \"Cyanosulfidic plus glyoxylate convergent route\",\n      \"description\": \"Cyanosulfidic chemistry supplies glyceraldehyde while the glyoxylate module supplies DHF; these converge to a pentose pool that is extended to ketohexoses and then to glucose.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_003\", \"rxn_004\", \"rxn_008\", \"rxn_009\", \"rxn_011\", \"rxn_013\"],\n      \"key_intermediates\": [\"mol_009\", \"mol_014\", \"mol_012\", \"mol_016\"]\n    },\n    {\n      \"pathway_id\": \"P8\",\n      \"name\": \"Extraterrestrial direct glucose delivery\",\n      \"description\": \"Direct exogenous input of glucose from asteroid or meteoritic material supplies the target molecule without requiring full terrestrial synthesis.\",\n      \"reaction_sequence\": [\"rxn_014\"],\n      \"key_intermediates\": [\"mol_017\"]\n    },\n    {\n      \"pathway_id\": \"P9\",\n      \"name\": \"Delivered glycolaldehyde to stepwise surface growth route\",\n      \"description\": \"Extraterrestrial glycolaldehyde is incorporated into borate/molybdate-guided sugar growth, extended into ketohexoses, and then rearranged to glucose.\",\n      \"reaction_sequence\": [\"rxn_014\", \"rxn_007\", \"rxn_011\", \"rxn_013\"],\n      \"key_intermediates\": [\"mol_008\", \"mol_011\", \"mol_012\", \"mol_016\"]\n    },\n    {\n      \"pathway_id\": \"P10\",\n      \"name\": \"Cyanosulfidic to goethite ketohexose pool via triose isomerization\",\n      \"description\": \"HCN-derived glyceraldehyde first equilibrates with dihydroxyacetone, then the triose pool feeds goethite-catalyzed hexose formation, enriching fructose that subsequently rearranges to glucose.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_003\", \"rxn_004\", \"rxn_006\", \"rxn_010\", \"rxn_012\", \"rxn_013\"],\n      \"key_intermediates\": [\"mol_009\", \"mol_010\", \"mol_015\", \"mol_016\"]\n    }\n  ],\n  \"hub_molecules\": [\"mol_003\", \"mol_008\", \"mol_009\", \"mol_016\", \"mol_017\"],\n  \"convergence_points\": [\n    {\n      \"molecule_id\": \"mol_008\",\n      \"incoming_reactions\": [\"rxn_003\", \"rxn_005\", \"rxn_014\"],\n      \"outgoing_reactions\": [\"rxn_004\", \"rxn_007\"]\n    },\n    {\n      \"molecule_id\": \"mol_009\",\n      \"incoming_reactions\": [\"rxn_004\", \"rxn_005\"],\n      \"outgoing_reactions\": [\"rxn_006\", \"rxn_007\", \"rxn_009\", \"rxn_010\"]\n    },\n    {\n      \"molecule_id\": \"mol_016\",\n      \"incoming_reactions\": [\"rxn_010\", \"rxn_011\", \"rxn_012\"],\n      \"outgoing_reactions\": [\"rxn_013\"]\n    },\n    {\n      \"molecule_id\": \"mol_017\",\n      \"incoming_reactions\": [\"rxn_013\", \"rxn_014\"],\n      \"outgoing_reactions\": [\"rxn_015\", \"rxn_016\"]\n    }\n  ]\n}", "parsed_response": {"target_molecule": "Glucose", "overall_strategy": "A literature-guided convergent network is used in which glucose is not treated as the product of one selective prebiotic route, but as the outcome of multiple partially supported modules operating across hydrothermal, surface, and biochemical settings. Strongly supported modules include hydrothermal CO2 reduction to formaldehyde/formate feedstocks at vent analogs, cyanosulfidic photochemical production of glycolaldehyde and glyceraldehyde, goethite-catalyzed C3+C3 condensation of glyceraldehyde to ketohexoses, borate/molybdate-guided stabilization and sugar interconversion in evaporitic surface environments, and direct extraterrestrial delivery of glycolaldehyde and glucose. In line with the supplied literature, canonical formose chemistry is included only as a low-confidence feeder module because mild formose systems preferentially generate branched sugars and formaldehyde dimerization is a major bottleneck. The network therefore emphasizes hub molecules formaldehyde, glycolaldehyde, glyceraldehyde, fructose, 
ac_name\": \"xylulose\",\n      \"common_name\": \"xylulose\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_017\",\n      \"formula\": \"C5H10O5\",\n      \"iupac_name\": \"ribulose\",\n      \"common_name\": \"ribulose\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_018\",\n      \"formula\": \"C6H13O9P\",\n      \"iupac_name\": \"D-glucose 6-phosphate\",\n      \"common_name\": \"glucose 6-phosphate\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"Hydrothermal CO2 reduction to formaldehyde\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_003\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe3S4)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"313-363K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"greigite (Fe3S4), mackinawite (FeS)\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline hydrothermal vent analog, pH 9-11, H2-rich, Fe(Ni)S membrane-like setting\"\n      },\n      \"mechanism\": \"Mineral-catalyzed reduction of CO2 by H2 across iron-sulfur surfaces gives reduced one-carbon products including formaldehyde in vent-like gradients.\",\n      \"reasoning\": \"Included because Lane-group vent reactor work reported proof-of-principle CO2 reduction to formaldehyde under simulated alkaline hydrothermal conditions, consistent with iron-sulfur world catalysis and greigite formation in vent chimneys (Roldan et al., 2015; as summarized in the deep research report).\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Hydrothermal thermophoretic concentration of formaldehyde\",\n      \"inputs\": [\"mol_003\"],\n      \"outputs\": [\"mol_003\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"pyrite (FeS2)\", \"magnetite (Fe3O4)\"],\n      \"conditions\": {\n        \"temperature\": \"313-363K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"pyrite (FeS2), magnetite (Fe3O4)\",\n        \"aqueous\": \"true\",\n        \"other\": \"microporous vent structures, thermophoretic enrichment up to ~5000-fold\"\n      },\n      \"mechanism\": \"Physical concentration in mineral micropores increases local formaldehyde activity, helping overcome the low oceanic steady-state concentration and kinetic bottleneck for downstream sugar chemistry.\",\n      \"reasoning\": \"Vent micropores were reported to amplify organics up to ~5000-fold, making hydrothermal concentration a necessary connection module between CO2 reduction and surface/alkaline sugar chemistry (deep research summary; Lane-related vent work). This is a transport/concentration step rather than a net chemical conversion, but it is necessary to connect known literature modules.\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Cyanosulfidic photoreduction of HCN to glycolaldehyde and glyceraldehyde\",\n      \"inputs\": [\"mol_004\", \"mol_005\"],\n      \"outputs\": [\"mol_006\", \"mol_007\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (molybdenite/stibnite)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"ambient\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"UV-driven Cu(I)/Cu(II) photoredox with mineral semiconductors present\",\n        \"aqueous\": \"true\",\n        \"other\": \"254 nm UV; cyanosulfidic conditions; H2S or thiophosphate as reductant; phosphate-buffered pH 6.5 in the 2023 improvement\"\n      },\n      \"mechanism\": \"Reductive homologation of HCN under UV photoredox chemistry generates glycolaldehyde and then glyceraldehyde, bypassing formaldehyde dimerization.\",\n      \"reasoning\": \"This reaction follows the Sutherland cyanosulfidic network in which glycolaldehyde and glyceraldehyde arise directly from HCN under UV-driven reductive homologation; later work improved yields with thiophosphate (Ritson & Sutherland, 2012; Patel et al., 2015; Ritson & Sutherland, 2023).\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"Surface formose initiation from concentrated formaldehyde to glycolaldehyde\",\n      \"inputs\": [\"mol_003\"],\n      \"outputs\": [\"mol_006\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite)\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"323-353K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"alkaline mineral setting with wet-dry cycling\",\n        \"aqueous\": \"true\",\n        \"other\": \"high pH, formaldehyde typically 0.1-1.8 M; glycolaldehyde threshold >=3 ppm; Cannizzaro competition is strong\"\n      },\n      \"mechanism\": \"Under alkaline formose-active conditions, a small fraction of formaldehyde enters productive dimerization chemistry to form glycolaldehyde, although this is kinetically disfavored relative to Cannizzaro disproportionation.\",\n      \"reasoning\": \"The literature identifies formaldehyde-to-glycolaldehyde formation as the primary bottleneck of the formose network, with Breslow's autocatalytic cycle requiring glycolaldehyde as the linchpin and modern kinetic work showing Cannizzaro is favored (Butlerov, 1861; Breslow, 1959; Socha et al., 1980; Tran et al., 2023; Kua et al., 2013; 2025 J. Chem. Phys. study). This step is retained because it is canonical, but poor selectivity is acknowledged.\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"Formose homologation from glycolaldehyde and formaldehyde to glyceraldehyde\",\n      \"inputs\": [\"mol_006\", \"mol_003\"],\n      \"outputs\": [\"mol_007\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite)\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"323-353K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"alkaline mineral setting\",\n        \"aqueous\": \"true\",\n        \"other\": \"wet alkaline pools; borate can stabilize products but may inhibit some reactive intermediates\"\n      },\n      \"mechanism\": \"Aldol addition of glycolaldehyde with formaldehyde yields the C3 aldotriose glyceraldehyde within the Breslow formose cycle.\",\n      \"reasoning\": \"This is the central C2 to C3 growth step of the classical formose reaction and is part of the accepted autocatalytic mechanism updated by hydride-shift isomerization chemistry (Breslow, 1959; Appayee & Breslow, 2014; Tran et al., 2023).\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"Lobry de Bruyn-Alberda van Ekenstein isomerization of glyceraldehyde to dihydroxyacetone\",\n      \"inputs\": [\"mol_007\"],\n      \"outputs\": [\"mol_008\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite)\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"323-353K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"alkaline mineral setting\",\n        \"aqueous\": \"true\",\n        \"other\": \"basic conditions; ketose favored under alkaline equilibration\"\n      },\n      \"mechanism\": \"Aldose-ketose rearrangement interconverts the aldotriose and ketotriose through the Lobry de Bruyn-Alberda van Ekenstein manifold.\",\n      \"reasoning\": \"The research report identifies glyceraldehyde as a central branch point and notes strong equilibrium toward ketose DHA under basic conditions; updated mechanistic work indicates hydride-shift character for sugar isomerizations in formose chemistry (Appayee & Breslow, 2014; deep research summary).\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Formose C3 to C4 growth via tetrose/tetrulose branch\",\n      \"inputs\": [\"mol_006\", \"mol_007\"],\n      \"outputs\": [\"mol_009\", \"mol_010\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"323-353K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"alkaline borate-containing evaporitic pool\",\n        \"aqueous\": \"true\",\n        \"other\": \"wet-dry cycling can separate synthesis from stabilization\"\n      },\n      \"mechanism\": \"Aldol growth from C2/C3 sugars gives C4 aldose and ketose pools, which can feed higher homologation pathways.\",\n      \"reasoning\": \"The classical Breslow cycle includes C4 tetrulose and aldotetrose intermediates as key expansion and fragmentation nodes; borate-based mineral environments can stabilize emerging sugars and shape distributions (Breslow, 1959; Ricardo et al., 2004; Kim et al., 2011).\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Goethite-catalyzed C3 plus C3 condensation to ketohexoses\",\n      \"inputs\": [\"mol_007\"],\n      \"outputs\": [\"mol_011\", \"mol_012\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"borate minerals (colemanite/ulexite)\"],\n      \"conditions\": {\n        \"temperature\": \"298K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"goethite-like iron(III) hydroxide oxide mineral surface\",\n        \"aqueous\": \"true\",\n        \"other\": \"pH 5-6; mild conditions; fructose ~12.9% and sorbose ~15.2% reported, with no decomposition over 96 days\"\n      },\n      \"mechanism\": \"Surface-catalyzed condensation of glyceraldehyde gives predominantly ketohexoses, especially fructose and sorbose, under mild iron mineral conditions.\",\n      \"reasoning\": \"Weber showed that iron(III) hydroxide oxide catalyzes condensation of glyceraldehyde to ketohexoses at 25\u00b0C and pH 5-6 with substantial fructose and sorbose yields and high product persistence; this is one of the strongest experimental routes toward C6 sugars (Weber, 1992). The agents field uses allowed surface minerals while the catalyst is specified explicitly in conditions per the literature.\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"Aldose-ketose isomerization of fructose to glucose\",\n      \"inputs\": [\"mol_011\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"298-333K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"none or mineral interface-assisted\",\n        \"aqueous\": \"true\",\n        \"other\": \"Lobry de Bruyn-Alberda van Ekenstein rearrangement; glucose selected by thermodynamic stability of beta-pyranose\"\n      },\n      \"mechanism\": \"Ketohexose-to-aldohexose isomerization converts fructose into glucose through enediol/hydride-shift-like rearrangement and equilibration.\",\n      \"reasoning\": \"The deep research report states that C3 + C3 condensation primarily yields fructose and related ketohexoses, which must subsequently rearrange to glucose and mannose; glucose is then favored by exceptional thermodynamic stability in the beta-pyranose form (deep research summary; Appayee & Breslow, 2014 for hydride-shift relevance to sugar isomerization).\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"Aldose-ketose equilibration of sorbose to glucose\",\n      \"inputs\": [\"mol_012\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"298-333K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"none or mineral interface-assisted\",\n        \"aqueous\": \"true\",\n        \"other\": \"slow ketohexose/aldohexose equilibration under neutral to mildly basic conditions\"\n      },\n      \"mechanism\": \"Ketohexose interconversion and aldose-ketose rearrangement provide an alternative route from sorbose-containing C6 pools to glucose.\",\n      \"reasoning\": \"Weber's goethite chemistry produces sorbose alongside fructose, and the report emphasizes interconversion among hexose isomers as part of the prebiotic sugar manifold. This step is more speculative than fructose-to-glucose but is necessary to connect experimentally observed sorbose to the glucose target while remaining within the documented hexose isomerization framework (Weber, 1992; deep research summary).\"\n    },\n    {\n      \"id\": \"rxn_011\",\n      \"name\": \"Glyoxylate dimerization to dihydroxyfumarate\",\n      \"inputs\": [\"mol_014\"],\n      \"outputs\": [\"mol_015\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite)\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"ambient\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"glyoxylate-rich evaporitic chemistry\",\n        \"aqueous\": \"true\",\n        \"other\": \"used as the formal glyoxylate dimer in the Eschenmoser/Krishnamurthy scenario\"\n      },\n      \"mechanism\": \"Condensation of glyoxylate equivalents furnishes dihydroxyfumarate, the key C4 entry point of the glyoxylate scenario.\",\n      \"reasoning\": \"Eschenmoser proposed glyoxylate as a cleaner alternative C1 synthon and later work treated DHF as the formal glyoxylate dimer; the report notes the unresolved challenge that no robust prebiotic source of DHF is established. This reaction is included to represent the literature pathway explicitly while acknowledging the gap (Eschenmoser, 2007; Sagi et al., 2012; Chem, 2023 glyoxylose framework).\"\n    },\n    {\n      \"id\": \"rxn_012\",\n      \"name\": \"Dihydroxyfumarate plus glyceraldehyde to pentose ketoses\",\n      \"inputs\": [\"mol_015\", \"mol_007\"],\n      \"outputs\": [\"mol_016\", \"mol_017\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite/ulexite)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"ambient\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"glyoxylate scenario mineral interface\",\n        \"aqueous\": \"true\",\n        \"other\": \"~60% yield; near-quantitative conversion; selective ketose formation with no detectable aldoses\"\n      },\n      \"mechanism\": \"A clean aldol-type glyoxylate pathway combines DHF with glyceraldehyde to give xylulose and ribulose as selective ketose products.\",\n      \"reasoning\": \"Sagi, Krishnamurthy and colleagues demonstrated that DHF reacts with glyceraldehyde to furnish xylulose and ribulose in about 60% yield with high selectivity, establishing the glyoxylate scenario as a cleaner alternative to formose chemistry, though not yet extended to selective glucose (Sagi et al., 2012; Chem, 2023).\"\n    },\n    {\n      \"id\": \"rxn_013\",\n      \"name\": \"Meteorite and asteroid delivery of glycolaldehyde and glucose\",\n      \"inputs\": [],\n      \"outputs\": [\"mol_006\", \"mol_013\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\", \"borate minerals (colemanite/ulexite)\"],\n      \"conditions\": {\n        \"temperature\": \"ambient upon deposition\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"none; exogenous delivery followed by adsorption/concentration on minerals\",\n        \"aqueous\": \"false\",\n        \"other\": \"extraterrestrial infall from meteorites/asteroidal parent bodies\"\n      },\n      \"mechanism\": \"Exogenous delivery seeds the surface environment with preformed sugar precursors and some glucose, which can then enter local concentration, stabilization, and downstream chemistry.\",\n      \"reasoning\": \"Glycolaldehyde has been detected in interstellar and protostellar environments, and Furukawa et al. detected sugars in meteorites and glucose in Bennu samples, establishing extraterrestrial delivery as a documented source rather than an invented pathway (Hollis et al., 2000; Jorgensen et al., 2012; Furukawa et al., 2019; Furukawa et al., 2025).\"\n    },\n    {\n      \"id\": \"rxn_014\",\n      \"name\": \"Borate-assisted phosphorylation of glucose to glucose 6-phosphate\",\n      \"inputs\": [\"mol_013\"],\n      \"outputs\": [\"mol_018\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"thermal evaporation\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"borate-rich evaporitic milieu with phosphate source\",\n        \"aqueous\": \"false\",\n        \"other\": \"drying-rehydration cycles in volcanic/hydrothermal evaporative pools\"\n      },\n      \"mechanism\": \"Regioselective phosphorylation under evaporative borate-rich conditions converts glucose into the more metabolically relevant and potentially stabilized glucose 6-phosphate.\",\n      \"reasoning\": \"Furukawa et al. showed that borate-rich evaporative settings enable regioselective phosphorylation of glucose to glucose 6-phosphate, linking abiotic glucose production to proto-glycolytic chemistry (Furukawa et al., 2023).\"\n    }\n  ],\n  \"pathways\": [\n    {\n      \"pathway_id\": \"P1\",\n      \"name\": \"Vent CO2 to formaldehyde to canonical formose to glucose\",\n      \"description\": \"Hydrothermal CO2 reduction supplies formaldehyde, which enters the canonical surface formose sequence to glycolaldehyde and glyceraldehyde, then mild C3 condensation to fructose and isomerization to glucose.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_004\", \"rxn_005\", \"rxn_008\", \"rxn_009\"],\n      \"key_intermediates\": [\"mol_003\", \"mol_006\", \"mol_007\", \"mol_011\"]\n    },\n    {\n      \"pathway_id\": \"P2\",\n      \"name\": \"Vent formaldehyde plus cyanosulfidic glycolaldehyde convergence\",\n      \"description\": \"Hydrothermal formaldehyde converges with surface-cyanosulfidic glycolaldehyde, then proceeds through glyceraldehyde and fructose to glucose.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_003\", \"rxn_005\", \"rxn_008\", \"rxn_009\"],\n      \"key_intermediates\": [\"mol_003\", \"mol_006\", \"mol_007\", \"mol_011\"]\n    },\n    {\n      \"pathway_id\": \"P3\",\n      \"name\": \"Pure cyanosulfidic route via fructose\",\n      \"description\": \"HCN and H2S under UV generate glycolaldehyde and glyceraldehyde directly, bypassing the formaldehyde bottleneck, followed by goethite-type ketohexose formation and fructose-to-glucose isomerization.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_008\", \"rxn_009\"],\n      \"key_intermediates\": [\"mol_006\", \"mol_007\", \"mol_011\"]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"Pure cyanosulfidic route via sorbose\",\n      \"description\": \"The same cyanosulfidic entry chemistry feeds goethite-catalyzed ketohexose formation, but glucose is reached through sorbose-containing hexose pools.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_008\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_012\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"Canonical formose route seeded by external glycolaldehyde\",\n      \"description\": \"A small glycolaldehyde inventory from delivery or other settings seeds the Breslow cycle; glyceraldehyde then condenses to fructose and isomerizes to glucose.\",\n      \"reaction_sequence\": [\"rxn_013\", \"rxn_005\", \"rxn_008\", \"rxn_009\"],\n      \"key_intermediates\": [\"mol_006\", \"mol_007\", \"mol_011\"]\n    },\n    {\n      \"pathway_id\": \"P6\",\n      \"name\": \"Extraterrestrial direct glucose delivery\",\n      \"description\": \"Glucose arrives directly on meteorites or asteroid-derived material and is incorporated into the connected surface network without requiring local synthesis.\",\n      \"reaction_sequence\": [\"rxn_013\"],\n      \"key_intermediates\": [\"mol_013\"]\n    },\n    {\n      \"pathway_id\": \"P7\",\n      \"name\": \"Vent formaldehyde to glycolaldehyde to sorbose branch\",\n      \"description\": \"Hydrothermal formaldehyde enters the low-efficiency formose route to glycolaldehyde and glyceraldehyde, then reaches glucose through the sorbose branch of Weber-type ketohexose synthesis.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_004\", \"rxn_005\", \"rxn_008\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_003\", \"mol_006\", \"mol_007\", \"mol_012\"]\n    },\n    {\n      \"pathway_id\": \"P8\",\n      \"name\": \"Vent formaldehyde through tetrose branch to glucose pool\",\n      \"description\": \"Hydrothermal formaldehyde feeds surface formose chemistry through glycolaldehyde, glyceraldehyde, and tetrose/tetrulose intermediates before re-entering the C3/C6 manifold and reaching fructose then glucose.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_004\", \"rxn_005\", \"rxn_007\", \"rxn_008\", \"rxn_009\"],\n      \"key_intermediates\": [\"mol_003\", \"mol_006\", \"mol_007\", \"mol_009\", \"mol_010\", \"mol_011\"]\n    },\n    {\n      \"pathway_id\": \"P9\",\n      \"name\": \"Cyanosulfidic to tetrose-assisted C6 route\",\n      \"description\": \"Surface cyanosulfidic chemistry generates glycolaldehyde and glyceraldehyde, which enter the tetrose/tetrulose branch before returning to the C6 ketohexose manifold and then glucose.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_007\", \"rxn_008\", \"rxn_009\"],\n      \"key_intermediates\": [\"mol_006\", \"mol_007\", \"mol_009\", \"mol_010\", \"mol_011\"]\n    },\n    {\n      \"pathway_id\": \"P10\",\n      \"name\": \"Direct glucose capture followed by proto-metabolic activation\",\n      \"description\": \"Glucose delivered or synthesized by any route is stabilized and made metabolically relevant by phosphorylation to glucose 6-phosphate in borate-rich evaporitic settings.\",\n      \"reaction_sequence\": [\"rxn_013\", \"rxn_014\"],\n      \"key_intermediates\": [\"mol_013\", \"mol_018\"]\n    }\n  ],\n  \"hub_molecules\": [\"mol_003\", \"mol_006\", \"mol_007\", \"mol_011\", \"mol_013\"],\n  \"convergence_points\": [\n    {\n      \"molecule_id\": \"mol_006\",\n      \"incoming_reactions\": [\"rxn_003\", \"rxn_004\", \"rxn_013\"],\n      \"outgoing_reactions\": [\"rxn_005\", \"rxn_007\"]\n    },\n    {\n      \"molecule_id\": \"mol_007\",\n      \"incoming_reactions\": [\"rxn_003\", \"rxn_005\"],\n      \"outgoing_reactions\": [\"rxn_006\", \"rxn_007\", \"rxn_008\", \"rxn_012\"]\n    },\n    {\n      \"molecule_id\": \"mol_011\",\n      \"incoming_reactions\": [\"rxn_008\"],\n      \"outgoing_reactions\": [\"rxn_009\"]\n    },\n    {\n      \"molecule_id\": \"mol_013\",\n      \"incoming_reactions\": [\"rxn_009\", \"rxn_010\", \"rxn_013\"],\n      \"outgoing_reactions\": [\"rxn_014\"]\n    }\n  ]\n}", "parsed_response": {"target_molecule": "Glucose", "overall_strategy": "A literature-grounded multi-environment network is used because no single prebiotic pathway selectively yields glucose. The network treats formaldehyde and glycolaldehyde as critical entry points, uses hydrothermal CO2 reduction and vent concentration to supply C1 feedstocks, surface cyanosulfidic photochemistry to bypass the formaldehyde dimerization bottleneck and generate glycolaldehyde/glyceraldehyde, and mineral-guided aldol chemistry to reach C6 sugars. The dominant glucose-forming logic follows two experimentally motivated branches: (i) glyceraldehyde condensation on iron hydroxide/goethite to ketohexoses followed by Lobry de Bruyn-Alberda van Ekenstein isomerization to glucose, and (ii) classical but low-selectivity formose-type growth from formaldehyde through glycolaldehyde and glyceraldehyde under alkaline mineral settings, explicitly acknowledging poor selectivity and the 2025 evidence that mild formose conditions favor branched sugars. Extraterrestrial delivery of glycolaldehyde and glucose is included because Bennu and meteorite studies show these compounds were available prebiotically. Final biochemical-stage stabilization/phosphorylation in borate-rich evaporitic settings links glucose to more persistent proto-metabolic forms.", "molecules": [{"id": "mol_001", "formula": "CO2", "iupac_name": "carbon dioxide", "common_name": "carbon dioxide", "inchi": "InChI=1S/CO2/c2-1-3", "role": "starting", "environment_formed": null}, {"id": "mol_002", "formula": "H2", "iupac_name": "molecular hydrogen", "common_name": "hydrogen", "inchi": "InChI=1S/H2/h1H", "role": "starting", "environment_formed": null}, {"id": "mol_003", "formula": "CH2O", "iupac_name": "methanal", "common_name": "formaldehyde", "inchi": "InChI=1S/CH2O/c1-2/h1H2", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_004", "formula": "HCN", "iupac_name": "hydrogen cyanide", "common_name": "hydrogen cyanide", "inchi": "InChI=1S/CHN/c1-2/h1H", "role": "starting", "environment_formed": null}, {"id": "mol_005", "formula": "H2S", "iupac_name": "sulfane", "common_name": "hydrogen sulfide", "inchi": "InChI=1S/H2S/h1H2", "role": "starting", "environment_formed": null}, {"id": "mol_006", "formula": "C2H4O2", "iupac_name": "2-hydroxyethanal", "common_name": "glycolaldehyde", "inchi": "InChI=1S/C2H4O2/c3-1-2-4/h1,3H,2H2", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_007", "formula": "C3H6O3", "iupac_name": "2,3-dihydroxypropanal", "common_name": "glyceraldehyde", "inchi": "InChI=1S/C3H6O3/c4-1-3(6)2-5/h1,3,5-6H,2H2", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_008", "formula": "C3H6O3", "iupac_name": "1,3-dihydroxypropan-2-one", "common_name": "dihydroxyacetone", "inchi": "InChI=1S/C3H6O3/c4-1-3(6)2-5/h4-6H,1-2H2", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_009", "formula": "C4H8O4", "iupac_name": "2,3,4-trihydroxybutanal", "common_name": "aldotetrose", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_010", "formula": "C4H8O4", "iupac_name": "1,3,4-trihydroxybutan-2-one", "common_name": "tetrulose", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_011", "formula": "C6H12O6", "iupac_name": "D-fructose", "common_name": "fructose", "inchi": "InChI=1S/C6H12O6/c7-1-3(9)5(11)6(12)4(10)2-8/h3-12H,1-2H2", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_012", "formula": "C6H12O6", "iupac_name": "D-sorbose", "common_name": "sorbose", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_013", "formula": "C6H12O6", "iupac_name": "D-glucose", "common_name": "glucose", "inchi": "InChI=1S/C6H12O6/c7-1-2(8)3(9)4(10)5(11)6(12)13-1/h1-12H", "role": "target", "environment_formed": "Biochemical"}, {"id": "mol_014", "formula": "C2H2O3", "iupac_name": "2-oxoacetic acid", "common_name": "glyoxylic acid", "inchi": "InChI=1S/C2H2O3/c3-1-2(4)5/h1H,(H,4,5)", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_015", "formula": "C4H2O6", "iupac_name": "2,3-dihydroxybut-2-enedioic acid", "common_name": "dihydroxyfumarate", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_016", "formula": "C5H10O5", "iupac_name": "xylulose", "common_name": "xylulose", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_017", "formula": "C5H10O5", "iupac_name": "ribulose", "common_name": "ribulose", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_018", "formula": "C6H13O9P", "iupac_name": "D-glucose 6-phosphate", "common_name": "glucose 6-phosphate", "inchi": null, "role": "intermediate", "environment_formed": "Biochemical"}], "reactions": [{"id": "rxn_001", "name": "Hydrothermal CO2 reduction to formaldehyde", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_003"], "environment": "Hydrothermal", "agents": ["greigite (Fe3S4)", "mackinawite (FeS)"], "conditions": {"temperature": "313-363K", "pressure": "high", "catalyst": "greigite (Fe3S4), mackinawite (FeS)", "aqueous": "true", "other": "alkaline hydrothermal vent analog, pH 9-11, H2-rich, Fe(Ni)S membrane-like setting"}, "mechanism": "Mineral-catalyzed reduction of CO2 by H2 across iron-sulfur surfaces gives reduced one-carbon products including formaldehyde in vent-like gradients.", "reasoning": "Included because Lane-group vent reactor work reported proof-of-principle CO2 reduction to formaldehyde under simulated alkaline hydrothermal conditions, consistent with iron-sulfur world catalysis and greigite formation in vent chimneys (Roldan et al., 2015; as summarized in the deep research report)."}, {"id": "rxn_002", "name": "Hydrothermal thermophoretic concentration of formaldehyde", "inputs": ["mol_003"], "outputs": ["mol_003"], "environment": "Hydrothermal", "agents": ["pyrite (FeS2)", "magnetite (Fe3O4)"], "conditions": {"temperature": "313-363K", "pressure": "high", "catalyst": "pyrite (FeS2), magnetite (Fe3O4)", "aqueous": "true", "other": "microporous vent structures, thermophoretic enrichment up to ~5000-fold"}, "mechanism": "Physical concentration in mineral micropores increases local formaldehyde activity, helping overcome the low oceanic steady-state concentration and kinetic bottleneck for downstream sugar chemistry.", "reasoning": "Vent micropores were reported to amplify organics up to ~5000-fold, making hydrothermal concentration a necessary connection module between CO2 reduction and surface/alkaline sugar chemistry (deep research summary; Lane-related vent work). This is a transport/concentration step rather than a net chemical conversion, but it is necessary to connect known literature modules."}, {"id": "rxn_003", "name": "Cyanosulfidic photoreduction of HCN to glycolaldehyde and glyceraldehyde", "inputs": ["mol_004", "mol_005"], "outputs": ["mol_006", "mol_007"], "environment": "Surface", "agents": ["sulfide minerals (molybdenite/stibnite)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "ambient", "pressure": "1 atm", "catalyst": "UV-driven Cu(I)/Cu(II) photoredox with mineral semiconductors present", "aqueous": "true", "other": "254 nm UV; cyanosulfidic conditions; H2S or thiophosphate as reductant; phosphate-buffered pH 6.5 in the 2023 improvement"}, "mechanism": "Reductive homologation of HCN under UV photoredox chemistry generates glycolaldehyde and then glyceraldehyde, bypassing formaldehyde dimerization.", "reasoning": "This reaction follows the Sutherland cyanosulfidic network in which glycolaldehyde and glyceraldehyde arise directly from HCN under UV-driven reductive homologation; later work improved yields with thiophosphate (Ritson & Sutherland, 2012; Patel et al., 2015; Ritson & Sutherland, 2023)."}, {"id": "rxn_004", "name": "Surface formose initiation from concentrated formaldehyde to glycolaldehyde", "inputs": ["mol_003"], "outputs": ["mol_006"], "environment": "Surface", "agents": ["borate minerals (colemanite/ulexite)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "323-353K", "pressure": "1 atm", "catalyst": "alkaline mineral setting with wet-dry cycling", "aqueous": "true", "other": "high pH, formaldehyde typically 0.1-1.8 M; glycolaldehyde threshold >=3 ppm; Cannizzaro competition is strong"}, "mechanism": "Under alkaline formose-active conditions, a small fraction of formaldehyde enters productive dimerization chemistry to form glycolaldehyde, although this is kinetically disfavored relative to Cannizzaro disproportionation.", "reasoning": "The literature identifies formaldehyde-to-glycolaldehyde formation as the primary bottleneck of the formose network, with Breslow's autocatalytic cycle requiring glycolaldehyde as the linchpin and modern kinetic work showing Cannizzaro is favored (Butlerov, 1861; Breslow, 1959; Socha et al., 1980; Tran et al., 2023; Kua et al., 2013; 2025 J. Chem. Phys. study). This step is retained because it is canonical, but poor selectivity is acknowledged."}, {"id": "rxn_005", "name": "Formose homologation from glycolaldehyde and formaldehyde to glyceraldehyde", "inputs": ["mol_006", "mol_003"], "outputs": ["mol_007"], "environment": "Surface", "agents": ["borate minerals (colemanite/ulexite)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "323-353K", "pressure": "1 atm", "catalyst": "alkaline mineral setting", "aqueous": "true", "other": "wet alkaline pools; borate can stabilize products but may inhibit some reactive intermediates"}, "mechanism": "Aldol addition of glycolaldehyde with formaldehyde yields the C3 aldotriose glyceraldehyde within the Breslow formose cycle.", "reasoning": "This is the central C2 to C3 growth step of the classical formose reaction and is part of the accepted autocatalytic mechanism updated by hydride-shift isomerization chemistry (Breslow, 1959; Appayee & Breslow, 2014; Tran et al., 2023)."}, {"id": "rxn_006", "name": "Lobry de Bruyn-Alberda van Ekenstein isomerization of glyceraldehyde to dihydroxyacetone", "inputs": ["mol_007"], "outputs": ["mol_008"], "environment": "Surface", "agents": ["borate minerals (colemanite/ulexite)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "323-353K", "pressure": "1 atm", "catalyst": "alkaline mineral setting", "aqueous": "true", "other": "basic conditions; ketose favored under alkaline equilibration"}, "mechanism": "Aldose-ketose rearrangement interconverts the aldotriose and ketotriose through the Lobry de Bruyn-Alberda van Ekenstein manifold.", "reasoning": "The research report identifies glyceraldehyde as a central branch point and notes strong equilibrium toward ketose DHA under basic conditions; updated mechanistic work indicates hydride-shift character for sugar isomerizations in formose chemistry (Appayee & Breslow, 2014; deep research summary)."}, {"id": "rxn_007", "name": "Formose C3 t
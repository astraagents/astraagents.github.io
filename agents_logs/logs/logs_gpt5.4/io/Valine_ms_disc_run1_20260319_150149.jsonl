i": null, "role": "intermediate", "environment_formed": "Biochemical"}, {"id": "mol_017", "formula": "C2H4O", "iupac_name": "ethanal", "common_name": "acetaldehyde", "inchi": "InChI=1S/C2H4O/c1-2-3/h2H,1H3", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_018", "formula": "C6H10O5S", "iupac_name": "2-oxo-3-methylbutanoyl thioester (generic)", "common_name": "ketoisovalerate thioester", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_019", "formula": "C3H8N2O3P2", "iupac_name": "diamidophosphate", "common_name": "DAP", "inchi": null, "role": "starting", "environment_formed": null}, {"id": "mol_020", "formula": "H3PO4", "iupac_name": "phosphoric acid", "common_name": "phosphate", "inchi": "InChI=1S/H3O4P/c1-5(2,3)4/h(H3,1,2,3,4)", "role": "starting", "environment_formed": null}], "reactions": [{"id": "rxn_001", "name": "Hydrothermal CO2 reduction to formate", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_006"], "environment": "Hydrothermal", "agents": ["greigite (Fe3S4)", "mackinawite (FeS)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "greigite/mackinawite", "aqueous": "true", "other": "alkaline vent conditions, anoxic, H2-rich"}, "mechanism": "Mineral-surface CO2 hydrogenation gives surface-bound reduced C1 species released as formate.", "reasoning": "Hydrothermal iron-sulfur reduction of CO2 to formate is a core vent reaction in FeS-world and alkaline-vent models and is consistent with greigite/mackinawite catalysis described in hydrothermal prebiotic literature; used here as the initial reduced-carbon entry point feeding later valine chemistry (Huber & Wachtershauser, 1997; Russell & Martin, 2004)."}, {"id": "rxn_002", "name": "Hydrothermal C1/C2 synthesis to formaldehyde and acetaldehyde", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_005", "mol_017"], "environment": "Hydrothermal", "agents": ["magnetite (Fe3O4)", "elemental iron (Fe0)"], "conditions": {"temperature": "400-500K", "pressure": "high", "catalyst": "magnetite/Fe0", "aqueous": "true", "other": "Fischer-Tropsch-type vent chemistry, anoxic"}, "mechanism": "CO2/CO hydrogenation on metal-rich mineral surfaces forms reduced carbonyl products including formaldehyde-class and acetaldehyde-class compounds.", "reasoning": "Hydrothermal Fischer-Tropsch-type chemistry is widely invoked for abiotic production of aldehydes and related reduced organics from C1 feedstocks in vent systems; acetaldehyde and formaldehyde are included because the literature summary identifies formaldehyde as a robust source molecule and acetaldehyde as a plausible precursor pool for branched amino-acid chemistry, though product distributions are mixed rather than valine-specific (McCollom & Seewald, 2007; Cleaves et al., 2008; Keefe et al., 1995)."}, {"id": "rxn_003", "name": "Hydrothermal pyruvate synthesis from reduced carbon feedstocks", "inputs": ["mol_001", "mol_002", "mol_006"], "outputs": ["mol_008"], "environment": "Hydrothermal", "agents": ["greigite (Fe3S4)", "magnetite (Fe3O4)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "greigite/magnetite", "aqueous": "true", "other": "subseafloor or alkaline vent setting, anoxic"}, "mechanism": "Sequential surface reduction and C-C bond formation among reduced C1 species produces a protometabolic \u03b1-ketoacid pool represented by pyruvate.", "reasoning": "The supplied literature explicitly identifies pyruvate as a key prebiotic precursor and \u03b1-ketoacids as central intermediates connecting cyanide/ammonia chemistry to amino acids. Direct nonenzymatic pyruvate synthesis in hydrothermal settings is still incompletely resolved, so this node is included as a literature-grounded protometabolic bridge rather than a fully established valine-specific experiment (Muchowska et al., 2019; Keller et al., 2014; Ritson & Sutherland, 2012)."}, {"id": "rxn_004", "name": "Surface cyanide capture of formaldehyde to glycolonitrile", "inputs": ["mol_004", "mol_005"], "outputs": ["mol_010"], "environment": "Surface", "agents": ["sulfide minerals (molybdenite/stibnite)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "sulfide minerals/TiO2", "aqueous": "true", "other": "UV-exposed evaporitic or geothermal pool, anoxic"}, "mechanism": "HCN adds to formaldehyde to form cyanohydrin glycolonitrile under concentrated surface conditions.", "reasoning": "The cyanosulfidic scenario highlights formaldehyde and HCN as robust feedstocks and glycolonitrile as a central nitrile intermediate in prebiotic surface chemistry. This step is therefore strongly aligned with the supplied literature even though it is not valine-specific (Patel et al., 2015; Ritson & Sutherland, 2012)."}, {"id": "rxn_005", "name": "UV-assisted conversion of cyanide pool to formamide", "inputs": ["mol_004"], "outputs": ["mol_009"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "phosphate minerals (apatite/struvite)"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "TiO2/phosphate minerals", "aqueous": "true", "other": "UV irradiation, wet-dry cycling, anoxic"}, "mechanism": "Photochemical and hydrolytic processing of cyanide-rich solutions yields formamide as a concentrated nitrogenous intermediate.", "reasoning": "The provided research explicitly notes UV chemistry from HCN/H2O to formamide and hydrothermal formamide-based pathways that produce amino acids including valine. This reaction represents the surface concentration branch feeding those pathways (Saladino et al., 2012; Ferus et al., 2015)."}, {"id": "rxn_006", "name": "Hydrothermal formamide-based amino-acid precursor synthesis to pyruvate-class pool", "inputs": ["mol_009", "mol_006", "mol_003"], "outputs": ["mol_008"], "environment": "Hydrothermal", "agents": ["pyrite (FeS2)", "magnetite (Fe3O4)"], "conditions": {"temperature": "370-470K", "pressure": "high", "catalyst": "pyrite/magnetite", "aqueous": "true", "other": "formamide-containing hydrothermal system, anoxic"}, "mechanism": "Formamide/formate/NH3 mixtures under hydrothermal mineral catalysis generate mixed carbonyl and \u03b1-ketoacid products represented here by pyruvate.", "reasoning": "The literature summary specifically states that formamide-based hydrothermal pathways catalyzed by minerals can produce amino acids including valine through reactions involving HCN, CO, NH3, and formate salts. Because detailed valine-resolved intermediates are not given in the report, pyruvate is used here as the supported \u03b1-ketoacid bridge consistent with that chemistry (Saladino et al., 2012; Bada et al., 1994)."}, {"id": "rxn_007", "name": "Surface concentration of pyruvate to 2-ketoisovalerate", "inputs": ["mol_008", "mol_017"], "outputs": ["mol_011"], "environment": "Surface", "agents": ["montmorillonite (clay)", "borate minerals (colemanite/ulexite)"], "conditions": {"temperature": "320-370K", "pressure": "1 atm", "catalyst": "montmorillonite/borate minerals", "aqueous": "true", "other": "evaporitic wet-dry cycles; concentrated carbonyl pool; speculative C-C bond-forming bridge"}, "mechanism": "Condensation/rearrangement within a concentrated carbonyl pool yields a branched C5 \u03b1-ketoacid represented by 2-ketoisovalerate.", "reasoning": "The supplied literature identifies 2-ketoisovalerate as the immediate precursor to valine and emphasizes \u03b1-ketoacids as central prebiotic intermediates, but does not provide a resolved nonenzymatic route from simple feedstocks to this branched ketoacid. This step is therefore explicitly speculative yet necessary to connect known precursor classes to valine, addressing the major literature gap rather than replacing it with an incorrect Strecker carbon assignment (Kitadai et al., 2018; Muchowska et al., 2019; source gap acknowledged from the provided report)."}, {"id": "rxn_008", "name": "Hydrothermal protometabolic branching to 2-ketoisovalerate", "inputs": ["mol_008"], "outputs": ["mol_011"], "environment": "Hydrothermal", "agents": ["greigite (Fe3S4)", "pyrite (FeS2)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "greigite/pyrite", "aqueous": "true", "other": "alkaline vent microcompartments, anoxic; speculative branched \u03b1-ketoacid generation"}, "mechanism": "Protometabolic C-C coupling and rearrangement within an \u03b1-ketoacid network produce branched ketoacids including 2-ketoisovalerate.", "reasoning": "This step reflects the literature theme that \u03b1-ketoacids could connect prebiotic chemistry with modern amino-acid biosynthesis. However, the supplied report also makes clear that the exact mechanism remains unresolved. It is included as a second convergent route to the same immediate valine precursor to capture that open question explicitly rather than forcing an unsupported aldehyde-based valine Strecker step (Keller et al., 2014; Muchowska et al., 2019; the report's unresolved-challenge section)."}, {"id": "rxn_009", "name": "Strecker synthesis from 2-ketoisovalerate to valine aminonitrile", "inputs": ["mol_011", "mol_003", "mol_004"], "outputs": ["mol_012"], "environment": "Surface", "agents": ["sulfide minerals (molybdenite/stibnite)", "montmorillonite (clay)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "sulfide minerals/montmorillonite", "aqueous": "true", "other": "cyanide-rich pool, neutral to mildly acidic microenvironments"}, "mechanism": "Ammonia and cyanide convert the \u03b1-ketoacid carbonyl into an aminonitrile, preserving the C5 skeleton needed for valine.", "reasoning": "The Strecker route is among the strongest literature-supported prebiotic amino-acid syntheses and proceeds via aminonitriles. Here it is applied only after formation of the correct C5 precursor 2-ketoisovalerate, thereby avoiding the carbon-counting error identified in prior attempts. Ketone-derived aminonitriles are less favored than aldehyde substrates, so this branch is plausible but likely less efficient; this limitation is explicitly consistent with the report's discussion of uncertainty (Miller, 1953; Friedmann & Miller, 1969; Cleaves, 2010)."}, {"id": "rxn_010", "name": "Phosphoro-Strecker activation of 2-ketoisovalerate", "inputs": ["mol_011", "mol_004", "mol_019"], "outputs": ["mol_013"], "environment": "Surface", "agents": ["phosphate minerals (apatite/struvite)", "montmorillonite (clay)"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "phosphate minerals/montmorillonite", "aqueous": "true", "other": "neutral pH; concentrated DAP; wet-dry cycling"}, "mechanism": "DAP-mediated phosphorylation traps the nitrile-addition product as an N-phosphoroaminonitrile.", "reasoning": "The literature explicitly identifies phosphoro-Strecker chemistry with DAP as a prebiotic route to N-phosphoroaminonitriles and notes selectivity for aldehydes over ketones. Accordingly this ketone-based application is marked as more speculative and likely less efficient, but retained because it is one of the few literature-supported prebiotic aminonitrile-activation concepts relevant to valine once the correct C5 precursor exists (Gibard et al., 2018; Akouche et al., 2017)."}, {"id": "rxn_011", "name": "Dephosphorylation and conversion of N-phosphoroaminonitrile to valine aminonitrile", "inputs": ["mol_013"], "outputs": ["mol_012"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "null", "aqueous": "true", "other": "hydration/dephosphorylation during pool cycling"}, "mechanism": "Hydrolytic loss of phosphoryl activation yields the free aminonitrile.", "reasoning": "This step follows directly from phosphoro-Strecker proposals in which N-phosphoroaminonitriles are convertible to aminonitriles or hydrolysis products under changing pH/water activity. It is used here as the bridge from activated intermediate to the shared valine aminonitrile hub (Gibard et al., 2018; Akouche et al., 2017)."}, {"id": "rxn_012", "name": "Bucherer-Bergs-type conversion of valine aminonitrile to valine hydantoin", "inputs": ["mol_012"], "outputs": ["mol_014"], "environment": "Surface", "agents": ["phosphate minerals (apatite/struvite)", "TiO2 (anatase/rutile)"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "phosphate minerals/TiO2", "aqueous": "true", "other": "cyanide/carbonate-rich evaporitic setting; hydantoin branch"}, "mechanism": "Cyclization of aminonitrile-derived carbamoyl intermediates yields a hydantoin reservoir species.", "reasoning": "The literature summary names Bucherer-Bergs/hydantoin chemistry as a recognized prebiotic amino-acid framework. This branch is retained as a separate route from aminonitrile hydrolysis, correcting the previous attempt's endpoint conflation (Orgel, 2004; Cleaves, 2010; report summary on B\u00fccherer-Bergs reactions)."}, {"id": "rxn_013", "name": "Hydrolysis of valine aminonitrile to valine", "inputs": ["mol_012"], "outputs": ["mol_015"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "null", "aqueous": "true", "other": "prolonged hydrolysis during pool maturation"}, "mechanism": "Stepwise nitrile hydration and hydrolysis yields the \u03b1-amino acid valine.", "reasoning": "Aminonitrile hydrolysis is the canonical final stage of Strecker amino-acid synthesis and is therefore one of the best-supported terminal steps for prebiotic valine production once the correct skeleton has been established (Miller, 1953; Friedmann & Miller, 1969; Cleaves, 2010)."}, {"id": "rxn_014", "name": "Hydrolysis of valine hydantoin to valine", "inputs": ["mol_014"], "outputs": ["mol_015"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "320-370K", "pressure": "1 atm", "catalyst": "null", "aqueous": "true", "other": "extended heating/cooling and aqueous hydrolysis"}, "mechanism": "Ring opening and hydrolysis of hydantoin furnishes valine.", "reasoning": "Hydantoin hydrolysis is a standard endpoint in Bucherer-Bergs-type amino-acid syntheses and provides an independent terminal route to valine distinct from direct aminonitrile hydrolysis (Orgel, 2004; report summary citing Bucherer-Bergs relevance)."}, {"id": "rxn_015", "name": "Prebiotic transamination/reductive amination of 2-ketoisovalerate to valine", "inputs": ["mol_011", "mol_003"], "outputs": ["mol_015"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "null", "aqueous": "true", "other": "ammonia-rich pool, redox-active interfaces"}, "mechanism": "Nonenzymatic imine formation at the \u03b1-ketoacid followed by reduction/transamination gives valine.", "reasoning": "The literature explicitly identifies extant valine biosynthesis from \u03b1-ketoacids via transamination and suggests analogous prebiotic continuity between cyanide/ammonia chemistry and metabolism. This step is therefore included as a key biochemical-style route, though its exact nonenzymatic implementation remains less established than Strecker chemistry (Parker et al., 2011; Muchowska et al., 2019; report summary on transition from prebiotic to biotic pathways)."}, {"id": "rxn_016", "name": "Photochemical thioester activation of 2-ketoisovalerate", "inputs": ["mol_011"], "outputs": ["mol_018"], "environment": "Surface", "agents": ["TiO2 (anatase/rutile)", "sulfide minerals (molybdenite/stibnite)"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "TiO2/sulfide minerals", "aqueous": "true", "other": "UV light >330 nm equivalent; thiol-rich interface"}, "mechanism": "Photochemical activation of the \u03b1-ketoacid generates an energy-rich thioester derivative.", "reasoning": "The report highlights prebiotic thioesters as important intermediates and cites photochemical synthesis of thioesters from \u03b1-keto esters or 
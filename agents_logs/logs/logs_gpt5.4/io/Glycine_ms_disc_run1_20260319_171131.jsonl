 },\n      \"mechanism\": \"Nucleophilic cyanide addition to formaldehyde yields the cyanohydrin glycolonitrile.\",\n      \"reasoning\": \"The research findings identify cyanohydrins as key Strecker intermediates and specifically note glyconitrile/glycolonitrile as a cyanosulfidic precursor to glycine. This is a core literature-supported route. Supported by Strecker and cyanosulfidic glycine literature (research summary citing sources 10835, 21189, 9376).\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Surface Strecker amination of glycolonitrile to aminoacetonitrile\",\n      \"inputs\": [\"mol_007\", \"mol_005\"],\n      \"outputs\": [\"mol_008\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"phosphate minerals\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite\",\n        \"aqueous\": \"true\",\n        \"other\": \"aqueous neutral to alkaline conditions; mild prebiotic Strecker regime\"\n      },\n      \"mechanism\": \"Ammonolysis/rearrangement of glycolonitrile gives the aminonitrile aminoacetonitrile.\",\n      \"reasoning\": \"Aminonitriles are the canonical immediate Strecker precursors to amino acids, and aminoacetonitrile is explicitly listed in the research summary as the immediate precursor to glycine. Conditions match reported aqueous neutral/alkaline Strecker environments. Supported by Strecker glycine literature and meteorite-context Strecker-cyanohydrin synthesis (Elsila et al., 2007; Powner et al., phosphoro-Strecker-related findings summarized in sources 21189, 21192; research summary 4922, 10835).\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Surface cyanosulfidic conversion of glycolonitrile to glyoxylate\",\n      \"inputs\": [\"mol_007\", \"mol_011\", \"mol_015\"],\n      \"outputs\": [\"mol_010\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals\", \"TiO2
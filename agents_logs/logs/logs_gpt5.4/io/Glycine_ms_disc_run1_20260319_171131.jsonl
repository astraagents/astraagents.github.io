ediates\": [\"mol_003\", \"mol_004\", \"mol_007\", \"mol_009\"]\n    },\n    {\n      \"pathway_id\": \"P8\",\n      \"name\": \"Hydrothermal-plus-cyanosulfidic mixed pathway\",\n      \"description\": \"Hydrothermally generated glycolic acid and surface cyanosulfidic products converge at glyoxylate, which is then converted to glycine.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_003\", \"rxn_011\", \"rxn_015\"],\n      \"key_intermediates\": [\"mol_010\", \"mol_011\"]\n    },\n    {\n      \"pathway_id\": \"P9\",\n      \"name\": \"Meteorite-style aqueous alteration analog via aminoacetonitrile\",\n      \"description\": \"This pathway encodes the literature-supported extraterrestrial/parent-body logic where Strecker aminonitriles formed from formaldehyde, HCN, and ammonia later hydrolyze during aqueous alteration to glycine.\",\n      \"reaction_sequence\": [\"rxn_004\", \"rxn_006\", \"rxn_007\", \"rxn_012\"],\n      \"key_intermediates\": [\"mol_005\", \"mol_008\", \"mol_009\"]\n    },\n    {\n      \"pathway_id\": \"P10\",\n      \"name\": \"Hydrothermal formaldehyde-ammonia glyoxylate branch\",\n      \"description\": \"A hydrothermal formaldehyde-ammonia system generates glycolic acid; subsequent surface oxidation gives glyoxylate and biochemical amination gives glycine, reflecting hydrothermal evidence that glycolic acid is a key intermediate.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_003\", \"rxn_011\", \"rxn_015\"],\n      \"key_intermediates\": [\"mol_004\", \"mol_010\", \"mol_011\"]\n    }\n  ],\n  \"hub_molecules\": [\"mol_004\", \"mol_005\", \"mol_008\", \"mol_009\", \"mol_011\"],\n  \"convergence_points\": [\n    {\n      \"molecule_id\": \"mol_004\",\n      \"incoming_reactions\": [\"rxn_002\"],\n      \"outgoing_reactions\": [\"rxn_003\", \"rxn_004\", \"rxn_005\", \"rxn_006\"]\n    },\n    {\n      \"molecule_id\": \"mol_008\",\n      \"incoming_reactions\": [\"rxn_006\"],\n      \"outgoing_reactions\": [\"rxn_007\", \"rxn_010\"]\n
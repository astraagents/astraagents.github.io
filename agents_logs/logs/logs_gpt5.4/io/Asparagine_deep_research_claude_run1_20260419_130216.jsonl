spartate\",\n      \"inchi\": \"InChI=1S/C4H7NO4/c5-2(4(8)9)1-3(6)7/h2H,1,5H2,(H,6,7)(H,8,9)\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_016\",\n      \"formula\": \"C4H4O5\",\n      \"iupac_name\": \"2-oxobutanedioic acid\",\n      \"common_name\": \"oxaloacetate\",\n      \"inchi\": \"InChI=1S/C4H4O5/c5-2(4(8)9)1-3(6)7/h1H2,(H,6,7)(H,8,9)\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_017\",\n      \"formula\": \"CH3NO\",\n      \"iupac_name\": \"formamide\",\n      \"common_name\": \"formamide\",\n      \"inchi\": \"InChI=1S/CH3NO/c2-1-3/h1H,(H2,2,3)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_018\",\n      \"formula\": \"C3H7NO2\",\n      \"iupac_name\": \"2-aminopropanoic acid\",\n      \"common_name\": \"alanine\",\n      \"inchi\": \"InChI=1S/C3H7NO2/c1-2(4)3(5)6/h2H,4H2,1H3,(H,5,6)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_019\",\n      \"formula\": \"H2S\",\n      \"iupac_name\": \"sulfane\",\n      \"common_name\": \"hydrogen sulfide\",\n      \"inchi\": \"InChI=1S/H2S/h1H2\",\n      \"role\": \"starting\",\n      \"environment_formed\": null\n    },\n    {\n      \"id\": \"mol_020\",\n      \"formula\": \"C7H13N3O4\",\n      \"iupac_name\": \"2-(2-amino-4-carbamoylbutanamido)-4-carbamoylbutanoic acid\",\n      \"common_name\": \"asparagine-containing dipeptide surrogate\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"Greigite-catalyzed CO2 reduction to formate\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_003\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe3S4)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"373K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"greigite/mackinawite\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline vent-like, anoxic, H2-rich\"\n      },\n      \"mechanism\": \"Mineral-surface hydrogenation of CO2 to C1 reduced carbon on iron-sulfur phases.\",\n      \"reasoning\": \"Preiner et al. (2020) showed Fe(Ni)S-related hydrothermal systems reduce CO2 with H2 to formate under vent-like conditions; greigite and mackinawite are required hydrothermal mineral analogues in the present network.\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Hydrothermal carbon fixation to acetate and pyruvate\",\n      \"inputs\": [\"mol_001\", \"mol_002\", \"mol_003\"],\n      \"outputs\": [\"mol_004\", \"mol_005\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe3S4)\", \"magnetite (Fe3O4)\"],\n      \"conditions\": {\n        \"temperature\": \"373K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"greigite/magnetite\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline hydrothermal, anoxic; vent-generated pH gradient\"\n      },\n      \"mechanism\": \"Stepwise reductive carbon fixation on iron-rich minerals generates C2 and C3 carboxylates from reduced carbon pools.\",\n      \"reasoning\": \"Preiner et al. (2020) reported hydrothermal formation of acetate and pyruvate from CO2/H2 on Fe-bearing minerals; this step provides literature-supported hydrothermal precursor supply rather than direct asparagine formation.\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"FeS/FeS2-mediated reductive amination of pyruvate to alanine\",\n      \"inputs\": [\"mol_005\", \"mol_008\"],\n      \"outputs\": [\"mol_018\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"pyrite (FeS2)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"343-373K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"FeS/FeS2 mineral surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic hydrothermal setting with NH3\"\n      },\n      \"mechanism\": \"Surface-assisted reductive amination of alpha-keto acid to alpha-amino acid.\",\n      \"reasoning\": \"Huber & W\u00e4chtersh\u00e4user (2003) demonstrated FeS-based reductive amination of alpha-keto acids to amino acids; Barge et al. (2019) further supported mineral-mediated pyruvate-to-alanine conversion, though oxaloacetate decarboxylation remained problematic.\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"Photoredox cyanosulfidic generation of cyanoacetylene from HCN and acetylene\",\n      \"inputs\": [\"mol_006\", \"mol_007\", \"mol_019\"],\n      \"outputs\": [\"mol_010\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (molybdenite/stibnite proxy for sulfidic setting)\", \"TiO2 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"308K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"UV-driven Cu photoredox in sulfidic phosphate buffer on mineral surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic, phosphate-buffered, UV irradiated, H2S present\"\n      },\n      \"mechanism\": \"Cyanosulfidic oxidative cross-coupling under UV photoredox produces cyanoacetylene from cyanide feedstock and acetylene.\",\n      \"reasoning\": \"Patel et al. (2015) established cyanosulfidic protometabolism using HCN, H2S, UV, and Cu photoredox at about 35 degrees C; the network retains required surface mineral agents while following the reported environmental regime.\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"Hydrolysis of cyanoacetylene to cyanoacetaldehyde\",\n      \"inputs\": [\"mol_010\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral-assisted aqueous hydrolysis\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic aqueous pool\"\n      },\n      \"mechanism\": \"Partial hydration/hydrolysis of the activated nitrile-alkyne system yields beta-functionalized aldehyde precursor.\",\n      \"reasoning\": \"Sanchez, Ferris & Orgel (1966) proposed cyanoacetaldehyde formation from cyanoacetylene hydrolysis in aqueous prebiotic chemistry leading toward asparagine, aspartate, and cytosine.\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"Cyanoacetaldehyde Strecker-type conversion to four-carbon aminonitrile precursor\",\n      \"inputs\": [\"mol_011\", \"mol_006\", \"mol_008\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral-concentrating aqueous Strecker setting\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic, neutral-to-alkaline aqueous pool\"\n      },\n      \"mechanism\": \"Addition of ammonia and cyanide to cyanoacetaldehyde forms a C4 alpha-aminonitrile/dinitrile precursor.\",\n      \"reasoning\": \"Sanchez, Ferris & Orgel (1966) and Miller & Van Trump (1981) support Strecker-type access from cyanoacetaldehyde to asparagine/aspartate precursors; selective hydrolysis remains the key branchpoint.\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Cyanosulfidic conversion of cyanoacetylene to maleonitrile and alpha-aminonitrile precursor\",\n      \"inputs\": [\"mol_010\", \"mol_006\", \"mol_008\"],\n      \"outputs\": [\"mol_012\", \"mol_013\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (molybdenite/stibnite proxy)\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"308K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"UV/Cu photoredox cyanosulfidic system in phosphate buffer\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic, alkaline, excess HCN and NH3\"\n      },\n      \"mechanism\": \"Cyanoacetylene is funneled through maleonitrile and related nitrile intermediates to the identified alpha-aminonitrile precursor of asparagine/aspartate.\",\n      \"reasoning\": \"Patel et al. (2015) explicitly identified maleonitrile and alpha-aminonitrile compound 49 as precursors to asparagine and aspartate under cyanosulfidic photoredox conditions.\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Partial hydrolysis of alpha-aminonitrile to asparagine\",\n      \"inputs\": [\"mol_013\"],\n      \"outputs\": [\"mol_014\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-308K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral-assisted partial nitrile hydrolysis\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic aqueous pool; stopping at amide is kinetically challenging\"\n      },\n      \"mechanism\": \"Selective partial hydrolysis of nitrile functionality yields side-chain amide rather than full carboxylate.\",\n      \"reasoning\": \"Sanchez, Ferris & Orgel (1966) and Patel et al. (2015) both place selective partial hydrolysis of a nitrile precursor at the branch to asparagine; the literature emphasizes this selectivity as a major unresolved control issue.\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"Full hydrolysis of alpha-aminonitrile to aspartate\",\n      \"inputs\": [\"mol_013\"],\n      \"outputs\": [\"mol_015\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"aqueous hydrolysis on mineral surfaces\",\n        \"aqueous\": \"true\",\n        \"other\": \"anoxic; greater extent of hydrolysis than rxn_008\"\n      },\n      \"mechanism\": \"Further nitrile hydrolysis drives amide/carboxylate formation to aspartate.\",\n      \"reasoning\": \"Sanchez, Ferris & Orgel (1966) and Patel et al. (2015) indicate the same aminonitrile precursor can yield aspartate upon more complete hydrolysis; this is the thermodynamically favored branch.\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"Spark-discharge atmospheric synthesis and non-hydrolytic detection of asparagine\",\n      \"inputs\": [\"mol_006\", \"mol_008\"],\n      \"outputs\": [\"mol_014\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"variable plasma, bulk condensate 300-320K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"electrical discharge with subsequent condensate capture\",\n        \"aqueous\": \"true\",\n        \"other\": \"reducing gas discharge condensate analyzed without acid hydrolysis\"\n      },\n      \"mechanism\": \"Electrical discharge over reduced gas mixtures generates a complex product mixture in which free asparagine is preserved only if analysis avoids acid hydrolysis.\",\n      \"reasoning\": \"Jiang et al. (2014) reported asparagine as the highest-abundance amino acid in spark discharge products when LC-MS/MS analysis avoided destructive acid hydrolysis; this is direct experimental evidence for prebiotic asparagine formation.\"\n    },\n    {\n      \"id\": \"rxn_011\",\n      \"name\": \"Contact glow discharge conversion of alanine and formamide to asparagine\",\n      \"inputs\": [\"mol_018\", \"mol_017\"],\n      \"outputs\": [\"mol_014\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"phosphate minerals (apatite/struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"ambient bulk with plasma microenvironment\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"contact glow discharge electrolysis\",\n        \"aqueous\": \"true\",\n        \"other\": \"alanine 100 mM, formamide 200 mM, volcanic-lightning analogue\"\n      },\n      \"mechanism\": \"Plasma-driven oxidation/rearrangement/amidation chemistry in formamide-rich solution converts alanine-containing mixtures to asparagine.\",\n      \"reasoning\": \"Munegumi (2014) reported 3.0% yield of asparagine from alanine plus formamide under contact glow discharge electrolysis, providing one of the few quantified abiotic asparagine syntheses.\"\n    },\n    {\n      \"id\": \"rxn_012\",\n      \"name\": \"HCN hydration to formamide under UV-active surface conditions\",\n      \"inputs\": [\"mol_006\"],\n      \"outputs\": [\"mol_017\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase/rutile)\", \"borate minerals (colemanite/ulexite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"UV-active mineral-assisted hydration/concentration\",\n        \"aqueous\": \"true\",\n        \"other\": \"surface pool, anoxic\"\n      },\n      \"mechanism\": \"Hydration and concentration of HCN-derived carbon-nitrogen species yields formamide-rich reservoirs.\",\n      \"reasoning\": \"The deep research summary notes UV photochemistry from HCN and water to formamide as part of prebiotic surface chemistry; this connecting step is added conservatively to link HCN feedstock to the experimentally demonstrated Munegumi (2014) route.\"\n    },\n    {\n      \"id\": \"rxn_013\",\n      \"name\": \"Bucherer-Bergs / hydantoin route from oxaloacetate to aspartate\",\n      \"inputs\": [\"mol_016\", \"mol_006\", \"mol_008\"],\n      \"outputs\": [\"mol_015\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"null\", \"null\"],\n      \"conditions\": {\n        \"temperature\": \"ambient to mild heating\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"CO2/cyanide/ammonia via hydantoin chemistry\",\n        \"aqueous\": \"true\",\n        \"other\": \"through N-carbamoyl aspartate-like intermediate\"\n      },\n      \"mechanism\": \"Alpha-ketoacid undergoes cyanide/ammonia/CO2 chemistry through hydantoin and carbamoyl intermediates to the amino acid.\",\n      \"reasoning\": \"Pulletikurti et al. (2022) showed alpha-ketoacids including oxaloacetate can yield amino acids through Bucherer-Bergs/hydantoin chemistry, with oxaloacetate specifically giving aspartate. This is included as a precursor route only, not as a validated asparagine synthesis.\"\n    },\n    {\n      \"id\": \"rxn_014\",\n      \"name\": \"Cu2+-catalyzed transamination of oxaloacetate to aspartate\",\n      \"inputs\": [\"mol_016\", \"mol_008\"],\n      \"outputs\": [\"mol_015\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"null\", \"null\"],\n      \"conditions\": {\n        \"temperature\": \"about 298-310K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"Cu2+ with pyridoxamine cofactor analogue\",\n        \"aqueous\": \"true\",\n        \"other\": \"rapid but limited yield; oxaloacetate instability is a bottleneck\"\n      },\n      \"mechanism\": \"Metal-assisted transamination of oxaloacetate forms aspartate in a protometabolic amino-transfer network.\",\n      \"reasoning\": \"Harrison et al. (2023) reported about 5% aspartate yield from Cu2+-catalyzed transamination of oxaloacetate with pyridoxamine. The study also emphasizes oxaloacetate instability, so this reaction is treated as convergent precursor chemistry only.\"\n    },\n    {\n      \"id\": \"rxn_015\",\n      \"name\": \"Fe-promoted protometabolic generation of aspartate from pyruvate-derived network via oxaloacetate\",\n      \"inputs\": [\"mol_005\", \"mol_008\"],\n      \"outputs\": [\"mol_016\", \"mol_015\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"null\", \"null\"],\n      \"conditions\": {\n        \"temperature\": \"variable mild hydrothermal to ambient\",\n        \"pressure\": \"1 atm to elevated\",\n        \"catalyst\": \"Fe2+/Fe0 protometabolic network with glyoxylate/hydroxylamine inputs implicit\",\n        \"aqueous\": \"true\",\n        \"other\": \"network-level route; oxaloacetate transient and unstable\"\n      },\n      \"mechanism\": \"Iron-driven protometabolic carbon-network chemistry produces oxaloacetate-like intermediates and aspartate from pyruvate-centered feedstocks.\",\n      \"reasoning\": \"Muchowska et al. (2019) and Springsteen et al. (2018) support Fe-mediated protometabolic networks yielding aspartate from simple carboxylate systems. This network-level step is included to connect hydrothermal pyruvate supply to the aspartate hub while respecting the reported instability of oxaloacetate.\"\n    },\n    {\n      \"id\": \"rxn_016\",\n      \"name\": \"Asparagine deamidation to aspartate\",\n      \"inputs\": [\"mol_014\"],\n      \"outputs\": [\"mol_015\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"null\", \"null\"],\n      \"conditions\": {\n        \"temperature\": \"298-373K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"none required\",\n        \"aqueous\": \"true\",\n        \"other\": \"faster at elevated temperature and through repeated wet phases\"\n      },\n      \"mechanism\": \"Thermodynamically favorable hydrolysis of the side-chain amide converts asparagine to aspartate and ammonia.\",\n      \"reasoning\": \"Kishore, Tewari & Goldberg (2000), Robinson & Robinson (2001), and Bada et al. (1995) show asparagine deamidation is strongly favored and rapid at warm temperatures; this sink is essential to an accurate literature-based network.\"\n    },\n    {\n      \"id\": \"rxn_017\",\n      \"name\": \"Speculative activated amidation of aspartate to asparagine\",\n      \"inputs\": [\"mol_015\", \"mol_008\"],\n      \"outputs\": [\"mol_014\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"null\", \"null\"],\n      \"conditions\": {\n        \"temperature\": \"ambient to mild drying\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"candidate activating agents such as DAP, cyanamide, COS, or urea not explicitly modeled\",\n        \"aqueous\": \"false\",\n        \"other\": \"dry-phase activation required; no direct experimental demonstration for aspartate to asparagine\"\n      },\n      \"mechanism\": \"Hypothetical activation of side-chain carboxylate followed by ammonia addition to form the amide.\",\n      \"reasoning\": \"Osumah & Krishnamurthy (2021), Schimpl, Lemmon & Calvin (1965), and Leman et al. (2004) discuss prebiotic activating agents, but the deep research report explicitly states that no prebiotically plausible mechanism has yet been demonstrated for selective conversion of aspartate to asparagine. This reaction is retained only as a clearly marked unresolved gap, not as an established route.\"\n    },\n    {\n      \"id\": \"rxn_018\",\n      \"name\": \"Wet-dry peptide trapping of asparagine into an asparagine-containing dipeptide surrogate\",\n      \"inputs\": [\"mol_014\"],\n      \"outputs\": [\"mol_020\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"null\", \"null\"],\n      \"conditions\": {\n        \"temperature\": \"293-353K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"geothermal wet-dry cycling on mineral interfaces\",\n        \"aqueous\": \"false\",\n        \"other\": \"repeated drying may kinetically trap transient asparagine before deamidation\"\n      },\n      \"mechanism\": \"Condensation/polymerization incorporates transient asparagine into short peptides or oligomers.\",\n      \"reasoning\": \"Munegumi & Tanikawa (2017) reported that asparagine-containing dipeptides polymerize faster than asparagine alone, supporting kinetic trapping as a possible escape from rapid deamidation, though exact prebiotic activation chemistry remains incomplete.\"\n    }\n  ],\n  \"pathways\": [\n    {\n      \"pathway_id\": \"P1\",\n      \"name\": \"Direct Sanchez-Orgel cyanoacetylene route\",\n      \"description\": \"Classical aqueous cyanoacetylene chemistry producing a C4 aminonitrile precursor and then partial hydrolysis to asparagine.\",\n      \"reaction_sequence\": [\"rxn_004\", \"rxn_005\", \"rxn_006\", \"rxn_008\"],\n      \"key_intermediates\": [\"mol_010\", \"mol_011\", \"mol_013\"]\n    },\n    {\n      \"pathway_id\": \"P2\",\n      \"name\": \"Cyanosulfidic Sutherland route\",\n      \"description\": \"HCN/H2S/UV chemistry generates cyanoacetylene, maleonitrile, and the identified alpha-aminonitrile precursor to asparagine.\",\n      \"reaction_sequence\": [\"rxn_004\", \"rxn_007\", \"rxn_008\"],\n      \"key_intermediates\": [\"mol_010\", \"mol_012\", \"mol_013\"]\n    },\n    {\n      \"pathway_id\": \"P3\",\n      \"name\": \"Spark-discharge direct atmospheric condensate route\",\n      \"description\": \"Electrical discharge products contain directly detectable asparagine when analyzed without acid hydrolysis.\",\n      \"reaction_sequence\": [\"rxn_010\"],\n      \"key_intermediates\": [\"mol_006\"]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"Hydrothermal alanine to glow-discharge asparagine\",\n      \"description\": \"Hydrothermal pyruvate is aminated to alanine, which with formamide under contact glow discharge yields asparagine.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_003\", \"rxn_012\", \"rxn_011\"],\n      \"key_intermediates\": [\"mol_005\", \"mol_018\", \"mol_017\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"HCN-to-formamide glow-discharge route\",\n      \"description\": \"Surface HCN is converted to formamide, which together with alanine from hydrothermal chemistry gives asparagine under glow discharge.\",\n      \"reaction_sequence\": [\"rxn_012\", \"rxn_001\", \"rxn_002\", \"rxn_003\", \"rxn_011\"],\n      \"key_intermediates\": [\"mol_017\", \"mol_018\"]\n    },\n    {\n      \"pathway_id\": \"P6\",\n      \"name\": \"Protometabolic pyruvate to aspartate then speculative amidation\",\n      \"description\": \"Hydrothermal pyruvate feeds iron-driven protometabolic networks to aspartate; final amidation is explicitly unresolved and speculative.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_015\", \"rxn_017\"],\n      \"key_intermediates\": [\"mol_005\", \"mol_016\", \"mol_015\"]\n    },\n    {\n      \"pathway_id\": \"P7\",\n      \"name\": \"Bucherer-Bergs oxaloacetate route then speculative amidation\",\n      \"description\": \"Oxaloacetate gives aspartate through hydantoin chemistry; conversion to asparagine remains an open problem.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_015\", \"rxn_013\", \"rxn_017\"],\n      \"key_intermediates\": [\"mol_005\", \"mol_016\", \"mol_015\"]\n    },\n    {\n      \"pathway_id\": \"P8\",\n      \"name\": \"Cu2+ transamination route then speculative amidation\",\n      \"description\": \"Oxaloacetate is transaminated to aspartate in a protometabolic amino-transfer step; final amidation is unresolved.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_015\", \"rxn_014\", \"rxn_017\"],\n      \"key_intermediates\": [\"mol_005\", \"mol_016\", \"mol_015\"]\n    },\n    {\n      \"pathway_id\": \"P9\",\n      \"name\": \"Sanchez route with biochemical kinetic trapping\",\n      \"description\": \"Directly formed asparagine from cyanoacetylene chemistry is rapidly incorporated into a peptide-like product to reduce free-solution deamidation.\",\n      \"reaction_sequence\": [\"rxn_004\", \"rxn_005\", \"rxn_006\", \"rxn_008\", \"rxn_018\"],\n      \"key_intermediates\": [\"mol_013\", \"mol_014\"]\n    },\n    {\n      \"pathway_id\": \"P10\",\n      \"name\": \"Spark-discharge asparagine with biochemical kinetic trapping\",\n      \"description\": \"Direct spark-generated asparagine is captured into an asparagine-containing peptide surrogate before extensive deamidation.\",\n      \"reaction_sequence\": [\"rxn_010\", \"rxn_018\"],\n      \"key_intermediates\": [\"mol_014\"]\n    }\n  ],\n  \"hub_molecules\": [\"mol_006\", \"mol_010\", \"mol_013\", \"mol_015\", \"mol_005\"],\n  \"convergence_points\": [\n    {\n      \"molecule_id\": \"mol_010\",\n      \"incoming_reactions\": [\"rxn_004\"],\n      \"outgoing_reactions\": [\"rxn_005\", \"rxn_007\"]\n    },\n    {\n      \"molecule_id\": \"mol_013\",\n      \"incoming_reactions\": [\"rxn_006\", \"rxn_007\"],\n      \"outgoing_reactions\": [\"rxn_008\", \"rxn_009\"]\n    },\n    {\n      \"molecule_id\": \"mol_015\",\n      \"incoming_reactions\": [\"rxn_009\", \"rxn_013\", \"rxn_014\", \"rxn_015\", \"rxn_016\"],\n      \"outgoing_reactions\": [\"rxn_017\"]\n    },\n    {\n      \"molecule_id\": \"mol_005\",\n      \"incoming_reactions\": [\"rxn_002\"],\n      \"outgoing_reactions\": [\"rxn_003\", \"rxn_015\"]\n    }\n  ]\n}", "parsed_response": {"target_molecule": "Asparagine", "overall_strategy": "This network is literature-constrained around the central observation that prebiotic asparagine is experimentally detectable by several routes but is chemically unstable and often converts to aspartate. The design therefore uses only literature-grounded direct formation routes to asparagine where available (cyanoacetylene chemistry, cyanosulfidic aminonitrile hydrolysis, spark discharge, contact glow discharge) and treats aspartate-centered hydrothermal/protometabolic chemistry primarily as convergent precursor supply rather than claiming solved amidation. Environmental interconnection is achieved by generating carbon skeletons and alpha-keto acids in hydrothermal settings, feeding these into surface cyanosulfidic and Strecker-like networks, and then allowing transient biochemical trapping by peptide incorporation. The network contains 10 target-reaching pathways, but several explicitly share late-stage direct-formation reactions because the literature supports only a limited number of experimentally demonstrated asparagine-forming chemistries. Unsupported direct amidation of aspartate is not asserted as an established route; where included, it is clearly marked speculative and used only to connect literature-identified open problems.", "molecules": [{"id": "mol_001", "formula": "CO2", "iupac_name": "carbon dioxide", "common_name": "carbon dioxide", "inchi": "InChI=1S/CO2/c2-1-3", "role": "starting", "environment_formed": null}, {"id": "mol_002", "formula": "H2", "iupac_name": "molecular hydrogen", "common_name": "hydrogen", "inchi": "InChI=1S/H2/h1H", "role": "starting", "environment_formed": "Hydrothermal"}, {"id": "mol_003", "formula": "CH2O2", "iupac_name": "methanoic acid", "common_name": "formate/formic acid", "inchi": "InChI=1S/CH2O2/c2-1-3/h1H,(H,2,3)", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_004", "formula": "C2H4O2", "iupac_name": "acetic acid", "common_name": "acetate/acetic acid", "inchi": "InChI=1S/C2H4O2/c1-2(3)4/h1H3,(H,3,4)", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_005", "formula": "C3H4O3", "iupac_name": "2-oxopropanoic acid", "common_name": "pyruvate/pyruvic acid", "inchi": "InChI=1S/C3H4O3/c1-2(4)3(5)6/h1H3,(H,5,6)", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_006", "formula": "HCN", "iupac_name": "hydrogen cyanide", "common_name": "HCN", "inchi": "InChI=1S/CHN/c1-2/h1H", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_007", "formula": "C2H2", "iupac_name": "ethyne", "common_name": "acetylene", "inchi": "InChI=1S/C2H2/c1-2/h1-2H", "role": "starting", "environment_formed": null}, {"id": "mol_008", "formula": "H3N", "iupac_name": "azane", "common_name": "ammonia", "inchi": "InChI=1S/H3N/h1H3", "role": "starting", "environment_formed": null}, {"id": "mol_009", "formula": "CH2N2S", "iupac_name": "methanethioamide", "common_name": "thioformamide precursor pool / reduced sulfur feed", "inchi": null, "role": "starting", "environment_formed": null}, {"id": "mol_010", "formula": "HC3N", "iupac_name": "prop-2-ynenitrile", "common_name": "cyanoacetylene", "inchi": "InChI=1S/C3HN/c1-2-3-4/h1H", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_011", "formula": "C3H3NO", "iupac_name": "3-oxopropanenitrile", "common_name": "cyanoacetaldehyde", "inchi": "InChI=1S/C3H3NO/c4-2-1-3-5/h1,3H,2H2", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_012", "formula": "C4H2N2", "iupac_name": "(Z)-but-2-enedinitrile", "common_name": "maleonitrile", "inchi": "InChI=1S/C4H2N2/c5-3-1-2-4-6/h1-2H/b2-1-", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_013", "formula": "C4H7N3", "iupac_name": "2-aminobutane-1,4-dinitrile", "common_name": "asparagine/aspartate alpha-aminonitrile precursor (compound 49 analogue)", "inchi": null, "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_014", "formula": "C4H8N2O3", "iupac_name": "2-amino-4-carbamoylbutanoic acid", "common_name": "asparagine", "inchi": "InChI=1S/C4H8N2O3/c5-2(4(8)9)1-3(6)7/h2H,1,5H2,(H2,6,7)(H,8,9)", "role": "target", "environment_formed": "Surface"}, {"id": "mol_015", "formula": "C4H7NO4", "iupac_name": "2-aminobutanedioic acid", "common_name": "aspartic acid/aspartate", "inchi": "InChI=1S/C4H7NO4/c5-2(4(8)9)1-3(6)7/h2H,1,5H2,(H,6,7)(H,8,9)", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_016", "formula": "C4H4O5", "iupac_name": "2-oxobutanedioic acid", "common_name": "oxaloacetate", "inchi": "InChI=1S/C4H4O5/c5-2(4(8)9)1-3(6)7/h1H2,(H,6,7)(H,8,9)", "role": "hub_intermediate", "environment_formed": "Biochemical"}, {"id": "mol_017", "formula": "CH3NO", "iupac_name
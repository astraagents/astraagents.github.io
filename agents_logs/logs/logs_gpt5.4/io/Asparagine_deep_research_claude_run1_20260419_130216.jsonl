 \"mol_010\",\n      \"formula\": \"C3H4O3\",\n      \"iupac_name\": \"2-oxopropanoic acid\",\n      \"common_name\": \"pyruvate\",\n      \"inchi\": \"InChI=1S/C3H4O3/c1-2(4)3(5)6/h1H3,(H,5,6)\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_011\",\n      \"formula\": \"C4H4O5\",\n      \"iupac_name\": \"2-oxosuccinic acid\",\n      \"common_name\": \"oxaloacetate\",\n      \"inchi\": \"InChI=1S/C4H4O5/c5-2(4(8)9)1-3(6)7/h1H2,(H,6,7)(H,8,9)\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_012\",\n      \"formula\": \"C4H7NO4\",\n      \"iupac_name\": \"2-aminobutanedioic acid\",\n      \"common_name\": \"aspartic acid\",\n      \"inchi\": \"InChI=1S/C4H7NO4/c5-2(4(8)9)1-3(6)7/h2H,1,5H2,(H,6,7)(H,8,9)\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_013\",\n      \"formula\": \"C4H8N2O3\",\n      \"iupac_name\": \"2-amino-4-carbamoylbutanoic acid\",\n      \"common_name\": \"asparagine\",\n      \"inchi\": \"InChI=1S/C4H8N2O3/c5-2(4(8)9)1-3(7)6/h2H,1,5H2,(H2,6,7)(H,8,9)\",\n      \"role\": \"target\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_014\",\n      \"formula\": \"CH3NO\",\n      \"iupac_name\": \"formamide\",\n      \"common_name\": \"formamide\",\n      \"inchi\": \"InChI=1S/CH3NO/c2-1-3/h1H,(H2,2,3)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_015\",\n      \"formula\": \"CH4N2O\",\n      \"iupac_name\": \"urea\",\n      \"common_name\": \"urea\",\n      \"inchi\": \"InChI=1S/CH4N2O/c2-1(3)4/h(H4,2,3,4)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_016\",\n      \"formula\": \"CH2N2\",\n      \"iupac_name\": \"cyanamide\",\n      \"common_name\": \"
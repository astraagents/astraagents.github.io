rmed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_018\",\n      \"formula\": \"H2S\",\n      \"iupac_name\": \"hydrogen sulfide\",\n      \"common_name\": \"hydrogen sulfide\",\n      \"inchi\": \"InChI=1S/H2S/h1H2\",\n      \"role\": \"starting\",\n      \"environment_formed\": null\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"CO\u2082 hydrogenation to formate on greigite\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_007\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe\u2083S\u2084)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high (50-100 bar)\",\n        \"catalyst\": \"greigite (Fe\u2083S\u2084)\",\n        \"aqueous\": true,\n        \"other\": \"alkaline vent conditions, pH 9-11, H\u2082-rich fluids\"\n      },\n      \"mechanism\": \"CO\u2082 adsorbs on Fe\u2083S\u2084 surface, undergoes two-electron reduction with H\u2082 as reductant to yield surface-bound formate, which desorbs into alkaline solution.\",\n      \"reasoning\": \"Demonstrated by Preiner et al. (2020) and Roldan et al. (2015); greigite is a structural analog of biological [Fe\u2084S\u2084] clusters and catalyzes CO\u2082 reduction to formate under simulated alkaline vent conditions. Hudson et al. (2020) confirmed formate as the primary C1 product at 100\u00b0C on Fe\u2083S\u2084.\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Formate reduction to formaldehyde on magnetite\",\n      \"inputs\": [\"mol_007\", \"mol_002\"],\n      \"outputs\": [\"mol_006\", \"mol_004\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe\u2083O\u2084)\", \"elemental iron (Fe\u2070)\"],\n      \"conditions\": {\n        \"temperature\": \"400-450K\",\n        \"pressure\": \"high (50-200 bar)\",\n        \"catalyst\": \"magnetite (Fe\u2083O\u2084) with Fe\u2070\",\n        \"aqueous\": true,\n        \"other\": \"reducing conditions, H\u2082 excess\"\n      },\n      \"mechanism\": \"Formate is further reduced on magnetite surfaces via a Cannizzaro-type disproportionation or direct hydrogenation. Fe\u2070 acts as a strong reductant generating reactive hydrogen species on the magnetite surface, driving the two-electron reduction of formate to formaldehyde.\",\n      \"reasoning\": \"Magnetite catalyzes Fischer-Tropsch-type reduction of C1 oxygenates (McCollom & Seewald, 2007). Reduction of formate to formaldehyde is thermodynamically feasible under high H\u2082 fugacity conditions in serpentinizing systems (Seewald et al., 2006). Fe\u2070 dramatically enhances yields (Varma et al., 2018).\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Fischer-Tropsch synthesis of formaldehyde from CO\",\n      \"inputs\": [\"mol_013\", \"mol_002\"],\n      \"outputs\": [\"mol_006\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe\u2083O\u2084)\"],\n      \"conditions\": {\n        \"temperature\": \"400-500K\",\n        \"pressure\": \"high (100-300 bar)\",\n        \"catalyst\": \"magnetite (Fe\u2083O\u2084)\",\n        \"aqueous\": true,\n        \"other\": \"Fischer-Tropsch-type conditions, CO:H\u2082 mixtures from volcanic outgassing\"\n      },\n      \"mechanism\": \"CO adsorbs on magnetite surface, undergoes partial hydrogenation through surface-bound formyl intermediate (HCO*), then further hydrogenation yields formaldehyde which desorbs before full reduction to methanol.\",\n      \"reasoning\": \"Fischer-Tropsch-type synthesis on magnetite at hydrothermal conditions has been demonstrated to produce formaldehyde, methanol, and longer chain aldehydes (McCollom et al., 1999; Holm & Charlou, 2001). CO is available from volcanic outgassing and hydrothermal CO\u2082 reduction.\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"Aldol condensation of formaldehyde to glycolaldehyde\",\n      \"inputs\": [\"mol_006\", \"mol_006\"],\n      \"outputs\": [\"mol_008\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"Ca(OH)\u2082\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite clay with Ca(OH)\u2082\",\n        \"aqueous\": true,\n        \"other\": \"mildly alkaline pH 10-11, dilute formaldehyde solution, initial step of formose reaction\"\n      },\n      \"mechanism\": \"Base-catalyzed Cannizzaro-aldol mechanism: one formaldehyde is oxidized to formate while another is reduced; the resulting glycolaldehyde forms via umpolung aldol coupling on clay surfaces which concentrate and orient the reactants.\",\n      \"reasoning\": \"The formose reaction's initial step, aldol self-condensation of formaldehyde to glycolaldehyde, is well established (Butlerow, 1861; Breslow, 1959). Montmorillonite clays concentrate organics on interlayer surfaces and stabilize intermediates (Ferris et al., 1996). Ca(OH)\u2082 provides necessary base catalysis.\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"Strecker synthesis of serine aminonitrile from glycolaldehyde\",\n      \"inputs\": [\"mol_008\", \"mol_005\", \"mol_003\"],\n      \"outputs\": [\"mol_009\", \"mol_004\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite clay\",\n        \"aqueous\": true,\n        \"other\": \"mildly acidic to neutral pH, concentrated pool conditions\"\n      },\n      \"mechanism\": \"Glycolaldehyde condenses with ammonia to form an imine (Schiff base), HOCH\u2082CH=NH. Nucleophilic addition of HCN to the imine carbon yields 2-amino-3-hydroxypropanenitrile (serine aminonitrile). Clay surfaces concentrate reactants and catalyze imine formation.\",\n      \"reasoning\": \"The Strecker synthesis is one of the most robust prebiotic amino acid formation pathways (Miller, 1957; Strecker, 1850). Glycolaldehyde-based Strecker synthesis yielding serine precursors was demonstrated by Kebukawa et al. (2017) and is consistent with meteoritic amino acid distributions (Elsila et al., 2016).\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"Hydrolysis of serine aminonitrile to serine\",\n      \"inputs\": [\"mol_009\", \"mol_004\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": null,\n        \"aqueous\": true,\n        \"other\": \"mildly acidic to neutral aqueous conditions, wet-dry cycle heating accelerates hydrolysis\"\n      },\n      \"mechanism\": \"The nitrile group undergoes sequential hydrolysis: first to an amide (HOCH\u2082CH(NH\u2082)CONH\u2082) then to the carboxylic acid (serine, HOCH\u2082CH(NH\u2082)COOH), with loss of NH\u2083. The reaction proceeds via nucleophilic addition of water to the electrophilic carbon of the nitrile.\",\n      \"reasoning\": \"Aminonitrile hydrolysis to amino acids is the final step of the classical Strecker synthesis, demonstrated prebiotically by Miller (1957). Hydrolysis is spontaneous in aqueous solution and accelerated by mild heating (Pizzarello & Weber, 2004). Wet-dry cycling provides thermal activation.\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Strecker synthesis of aminoacetonitrile from formaldehyde\",\n      \"inputs\": [\"mol_006\", \"mol_005\", \"mol_003\"],\n      \"outputs\": [\"mol_017\", \"mol_004\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite clay\",\n        \"aqueous\": true,\n        \"other\": \"neutral to mildly acidic pH, concentrated pool\"\n      },\n      \"mechanism\": \"Formaldehyde condenses with ammonia to form methyleneimine (H\u2082C=NH). Nucleophilic addition of HCN yields aminoacetonitrile (H\u2082N-CH\u2082-CN), the glycine aminonitrile. Montmorillonite surfaces concentrate the volatile reactants.\",\n      \"reasoning\": \"The simplest Strecker synthesis from formaldehyde is one of the most efficient amino acid forming reactions, first demonstrated in spark discharge experiments by Miller (1953, 1957). Aminoacetonitrile has been detected in the interstellar medium (Belloche et al., 2008), confirming its prebiotic plausibility.\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Hydrolysis of aminoacetonitrile to glycine\",\n      \"inputs\": [\"mol_017\", \"mol_004\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite clay\",\n        \"aqueous\": true,\n        \"other\": \"warm acidic or neutral solution, wet-dry cycling accelerates\"\n      },\n      \"mechanism\": \"Aminoacetonitrile undergoes stepwise hydrolysis: CN \u2192 CONH\u2082 (glycinamide) \u2192 COOH + NH\u2083 (glycine). Clay surfaces may catalyze the hydrolysis and prevent product decomposition.\",\n      \"reasoning\": \"Aminonitrile hydrolysis to glycine is well characterized in Miller-Urey type experiments (Miller, 1957). Montmorillonite catalyzes nitrile hydrolysis (Ferris, 2005). Glycine is the most abundant amino acid in spark discharge experiments and carbonaceous meteorites.\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"Glycine hydroxymethylation to serine\",\n      \"inputs\": [\"mol_011\", \"mol_006\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"320-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": null,\n        \"aqueous\": true,\n        \"other\": \"mildly alkaline pH, concentrated pool, mineral surface optional. Analogous to serine hydroxymethyltransferase reaction\"\n      },\n      \"mechanism\": \"Formaldehyde reacts with glycine via an aldol-type addition. The \u03b1-carbon of glycine is deprotonated under basic conditions to form a carbanion, which attacks the carbonyl carbon of formaldehyde. The resulting \u03b2-hydroxyamino acid is serine. This is the non-enzymatic analog of the serine hydroxymethyltransferase (SHMT) reaction.\",\n      \"reasoning\": \"The aldol-type condensation of glycine with formaldehyde to produce serine is the prebiotic analog of the SHMT reaction, a central reaction in one-carbon metabolism. Demonstrated abiotically by Huber & W\u00e4chtersh\u00e4user (2003). This reaction connects C1 metabolism (formaldehyde) to amino acid diversity.\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"Hydrothermal CO\u2082 reduction to pyruvate on greigite\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_016\", \"mol_004\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe\u2083S\u2084)\", \"magnetite (Fe\u2083O\u2084)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high (50-100 bar)\",\n        \"catalyst\": \"greigite + magnetite mixed mineral surface\",\n        \"aqueous\": true,\n        \"other\": \"alkaline vent, pH 9-11, H\u2082-rich, sequential C1 \u2192 C3 carboxylation. Net: 3CO\u2082 + 5H\u2082 \u2192 CH\u2083COCOO\u207b + 4H\u2082O\"\n      },\n      \"mechanism\": \"Sequential CO\u2082 reduction and C-C bond formation on Fe\u2083S\u2084 surfaces: CO\u2082 \u2192 formate \u2192 CO/formyl \u2192 acetyl \u2192 pyruvate. The greigite surface mimics the acetyl-CoA pathway, with iron-sulfur clusters providing both reduction potential and carbon-carbon coupling catalysis.\",\n      \"reasoning\": \"Varma et al. (2018) demonstrated pyruvate synthesis from CO\u2082 and H\u2082 on native iron with greigite catalysis at 100\u00b0C under alkaline conditions. Muchowska et al. (2017) showed iron facilitates a proto-metabolic network centered on pyruvate. This mirrors the reductive acetyl-CoA pathway (Fuchs, 2011).\"\n    },\n    {\n      \"id\": \"rxn_011\",\n      \"name\": \"UV-driven hydroxylation of pyruvate to hydroxypyruvate\",\n      \"inputs\": [\"mol_016\", \"mol_004\"],\n      \"outputs\": [\"mol_010\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO\u2082 (anatase)\"],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO\u2082 (anatase) photocatalyst\",\n        \"aqueous\": true,\n        \"other\": \"UV irradiation (\u03bb < 300 nm, no ozone layer), shallow pool. TiO\u2082 generates hydroxyl radicals under UV.\"\n      },\n      \"mechanism\": \"UV light excites TiO\u2082 generating electron-hole pairs. Holes oxidize water to produce hydroxyl radicals (\u2022OH). Hydroxyl radical attacks the methyl group of pyruvate, abstracting H and forming \u2022CH\u2082COCOO\u207b, which combines with \u2022OH to yield HOCH\u2082COCOO\u207b (hydroxypyruvate).\",\n      \"reasoning\": \"TiO\u2082 photocatalytic hydroxylation is well established in environmental chemistry and plausible on early Earth (Schrauzer & Guth, 1977). Pyruvate photochemistry has been explored by Rapf & Vaida (2016). Hydroxypyruvate is the direct \u03b1-keto acid precursor to serine in extant metabolism.\"\n    },\n    {\n      \"id\": \"rxn_012\",\n      \"name\": \"Reductive amination of hydroxypyruvate to serine\",\n      \"inputs\": [\"mol_010\", \"mol_003\"],\n      \"outputs\": [\"mol_012\", \"mol_004\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": null,\n        \"aqueous\": true,\n        \"other\": \"NH\u2083-rich aqueous solution, mildly reducing, possible Fe\u00b2\u207a as electron donor. Analogous to modern transaminase reactions.\"\n      },\n      \"mechanism\": \"Ammonia attacks the carbonyl carbon of hydroxypyruvate to form an imine (Schiff base), HOCH\u2082C(=NH)COOH. Reduction of the imine by available reductants (Fe\u00b2\u207a, H\u2082S, or NADH analog) yields serine. This is a non-enzymatic reductive amination, analogous to biological aminotransferase reactions.\",\n      \"reasoning\": \"Reductive amination of \u03b1-keto acids is one of the most fundamental prebiotic amino acid synthesis routes (Bada, 2013). Muchowska et al. (2020) demonstrated non-enzymatic reductive amination of \u03b1-keto acids including hydroxypyruvate with Fe\u2070/Fe\u00b2\u207a as reductant, yielding the corresponding amino acids. This directly connects proto-metabolic keto acid networks to amino acid synthesis.\"\n    },\n    {\n      \"id\": \"rxn_013\",\n      \"name\": \"Formose reaction: formaldehyde to glyceraldehyde\",\n      \"inputs\": [\"mol_006\"],\n      \"outputs\": [\"mol_014\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite)\", \"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"310-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"borate minerals (Ca\u2082B\u2086O\u2081\u2081\u00b75H\u2082O) + Ca(OH)\u2082 + clay\",\n        \"aqueous\": true,\n        \"other\": \"mildly alkaline pH 10-11, borate stabilizes sugars and channels formose toward glyceraldehyde. Net: 3 HCHO \u2192 glyceraldehyde.\"\n      },\n      \"mechanism\": \"Autocatalytic aldol cascade: 2 HCHO \u2192 glycolaldehyde (aldol); glycolaldehyde + HCHO \u2192 glyceraldehyde (aldol). Borate complexes with vicinal diols of intermediates, stabilizing glyceraldehyde and preventing further polymerization to tar. Clay surfaces template and concentrate reactants.\",\n      \"reasoning\": \"The formose reaction (Butlerow, 1861) is the classic prebiotic sugar synthesis. Borate stabilization of sugar intermediates was demonstrated by Ricardo et al. (2004), showing that borate minerals channel the formose reaction toward specific sugars including glyceraldehyde and ribose. This addresses the canonical tar problem of the uncatalyzed formose reaction.\"\n    },\n    {\n      \"id\": \"rxn_014\",\n      \"name\": \"Oxidation of glyceraldehyde to hydroxypyruvate\",\n      \"inputs\": [\"mol_014\"],\n      \"outputs\": [\"mol_010\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO\u2082 (anatase)\", \"pyrite (FeS\u2082)\"],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO\u2082 photocatalyst with pyrite as electron acceptor\",\n        \"aqueous\": true,\n        \"other\": \"UV irradiation, anoxic but UV-driven oxidation. Two-electron oxidation at C2.\"\n      },\n      \"mechanism\": \"TiO\u2082 generates photo-oxidant holes under UV that oxidize the secondary alcohol of glyceraldehyde (C2-OH \u2192 C2=O), converting the aldehyde-sugar to the \u03b1-keto acid hydroxypyruvate. Pyrite acts as an electron sink, preventing back-reduction.\",\n      \"reasoning\": \"Photocatalytic oxidation of sugars on mineral surfaces is prebiotically plausible given intense UV on the early Earth (Ranjan & Sasselov, 2017). Glyceraldehyde-to-hydroxypyruvate conversion links sugar chemistry to keto acid metabolism, a critical bridge in prebiotic network theories (Ralser, 2018). TiO\u2082 photocatalysis drives selective oxidation (Kisch, 2015).\"\n    },\n    {\n      \"id\": \"rxn_015\",\n      \"name\": \"Hydrothermal CO\u2082 reduction to glyoxylate on pyrite\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_015\", \"mol_004\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"pyrite (FeS\u2082)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high (50-100 bar)\",\n        \"catalyst\": \"pyrite + mackinawite\",\n        \"aqueous\": true,\n        \"other\": \"reducing conditions, pH 6-9, net: 2CO\u2082 + 3H\u2082 \u2192 OHCCOOH + 2H\u2082O\"\n      },\n      \"mechanism\": \"Sequential reduction: CO\u2082 \u2192 formate \u2192 formaldehyde on mackinawite, followed by carbonylation (formaldehyde + CO\u2082 \u2192 glyoxylate) on pyrite surface. Alternatively, oxidative coupling of two formate-level C1 units on pyrite surfaces to yield glyoxylate.\",\n      \"reasoning\": \"Glyoxylate is a key intermediate in the glyoxylate scenario for origins of metabolism (Eschenmoser, 2007). Hydrothermal synthesis of C2 carboxylic acids from CO\u2082 on iron sulfide minerals has been reported (Cody et al., 2000). Pyrite surface catalysis for C-C bond formation was proposed by W\u00e4chtersh\u00e4user (1990).\"\n    },\n    {\n      \"id\": \"rxn_016\",\n      \"name\": \"Reductive amination of glyoxylate to glycine\",\n      \"inputs\": [\"mol_015\", \"mol_003\"],\n      \"outputs\": [\"mol_011\", \"mol_004\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"mackinawite (FeS)\",\n        \"aqueous\": true,\n        \"other\": \"NH\u2083-rich alkaline vent fluid, reducing conditions with H\u2082\"\n      },\n      \"mechanism\": \"Ammonia attacks the aldehyde carbonyl of glyoxylate to form an imine (glyoxylate oxime). The imine is reduced by H\u2082 on the FeS surface to yield glycine. This is a direct reductive amination on mineral surfaces.\",\n      \"reasoning\": \"Reductive amination of \u03b1-keto/\u03b1-oxo acids on iron sulfide surfaces was demonstrated by Huber & W\u00e4chtersh\u00e4user (2006). Glycine formation from glyoxylate and ammonia is thermodynamically favorable under reducing hydrothermal conditions. This mirrors the biological transamination of glyoxylate to glycine.\"\n    },\n    {\n      \"id\": \"rxn_017\",\n      \"name\": \"One-pot aldol-amination of glyoxylate with formaldehyde to serine\",\n      \"inputs\": [\"mol_015\", \"mol_006\", \"mol_003\"],\n      \"outputs\": [\"mol_012\", \"mol_004\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"phosphate minerals (apatite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite + apatite\",\n        \"aqueous\": true,\n        \"other\": \"concentrated evaporitic pool with mixed hydrothermal effluent, mildly alkaline\"\n      },\n      \"mechanism\": \"Tandem aldol-reductive amination: formaldehyde undergoes aldol addition to glyoxylate, producing tartronate semialdehyde (3-hydroxy-2-oxopropanoic acid, identical to hydroxypyruvate). In the presence of ammonia, the \u03b1-keto group undergoes reductive amination to yield serine. Montmorillonite concentrates reactants; phosphate minerals buffer pH.\",\n      \"reasoning\": \"This tandem pathway was proposed in the context of the glyoxylate scenario (Eschenmoser, 2007), where glyoxylate serves as a universal precursor to amino acids and sugars through aldol and amination chemistry. One-pot multi-component reactions are prebiotically realistic in concentrated pools (Powner et al., 2009).\"\n    },\n    {\n      \"id\": \"rxn_018\",\n      \"name\": \"Direct hydrothermal carboxylation-amination of glycolaldehyde to serine\",\n      \"inputs\": [\"mol_008\", \"mol_001\", \"mol_003\", \"mol_002\"],\n      \"outputs\": [\"mol_012\", \"mol_004\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe\u2083S\u2084)\", \"pyrite (FeS\u2082)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high (50-100 bar)\",\n        \"catalyst\": \"greigite + pyrite\",\n        \"aqueous\": true,\n        \"other\": \"alkaline vent, H\u2082/CO\u2082 rich, NH\u2083 from vent fluid, one-pot carboxylation + amination\"\n      },\n      \"mechanism\": \"On greigite surfaces, glycolaldehyde undergoes CO\u2082 insertion at C1 to form a C3 \u03b2-hydroxy-\u03b1-keto acid (hydroxypyruvate), followed by in situ reductive amination by NH\u2083 with H\u2082 as reductant to yield serine directly. The iron sulfide surface provides both carboxylation and reduction catalysis.\",\n      \"reasoning\": \"Iron sulfide surfaces catalyze both CO\u2082 fixation and reductive amination (Huber & W\u00e4chtersh\u00e4user, 1997, 2006). Multi-step one-pot synthesis on mineral surfaces is proposed in the iron-sulfur world hypothesis (W\u00e4chtersh\u00e4user, 1988). Glycolaldehyde carboxylation provides an alternative C2 \u2192 C3 route to pyruvate-based pathways.\"\n    }\n  ],\n  \"pathways\": [\n    {\n      \"pathway_id\": \"P1\",\n      \"name\": \"Hydrothermal CO\u2082 \u2192 Formate \u2192 Formaldehyde \u2192 Glycolaldehyde \u2192 Strecker Serine\",\n      \"description\": \"Complete Strecker synthesis route starting from hydrothermal CO\u2082 reduction on greigite to formate, further reduction to formaldehyde on magnetite, surface aldol condensation to glycolaldehyde, Strecker reaction with HCN and NH\u2083 to form serine aminonitrile, and final hydrolysis to serine.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_004\", \"rxn_005\", \"rxn_006\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_006\", \"mol_008\", \"mol_009\"]\n    },\n    {\n      \"pathway_id\": \"P2\",\n      \"name\": \"Fischer-Tropsch Formaldehyde \u2192 Glycolaldehyde \u2192 Strecker Serine\",\n      \"description\": \"Fischer-Tropsch-type synthesis of formaldehyde from volcanic CO and H\u2082 on magnetite, followed by surface aldol to glycolaldehyde, then Strecker synthesis to serine via aminonitrile intermediate.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_004\", \"rxn_005\", \"rxn_006\"],\n      \"key_intermediates\": [\"mol_006\", \"mol_008\", \"mol_009\"]\n    },\n    {\n      \"pathway_id\": \"P3\",\n      \"name\": \"Hydrothermal Pyruvate \u2192 Hydroxypyruvate \u2192 Reductive Amination to Serine\",\n      \"description\": \"Direct CO\u2082 fixation to pyruvate on greigite, UV-driven hydroxylation to hydroxypyruvate at the surface, and non-enzymatic reductive amination to serine. Mirrors the modern biosynthetic route.\",\n      \"reaction_sequence\": [\"rxn_010\", \"rxn_011\", \"rxn_012\"],\n      \"key_intermediates\": [\"mol_016\", \"mol_010\"]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"CO\u2082 \u2192 Formaldehyde \u2192 Strecker Glycine \u2192 Hydroxymethylation to Serine\",\n      \"description\": \"Hydrothermal CO\u2082 reduction to formaldehyde via formate, Strecker synthesis of glycine from formaldehyde + HCN + NH\u2083 at the surface, then aldol-type condensation of glycine with a second formaldehyde to serine. Analog of the SHMT reaction.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_007\", \"rxn_008\", \"rxn_009\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_006\", \"mol_017\", \"mol_011\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"Fischer-Tropsch \u2192 Strecker Glycine \u2192 Hydroxymethylation to Serine\",\n      \"description\": \"CO-derived formaldehyde through Fischer-Tropsch synthesis, followed by Strecker synthesis of glycine, then glycine + formaldehyde aldol condensation to serine.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_007\", \"rxn_008\", \"rxn_009\"],\n      \"key_intermediates\": [\"mol_006\", \"mol_017\", \"mol_011\"]\n    },\n    {\n      \"pathway_id\": \"P6\",\n      \"name\": \"CO\u2082 \u2192 Formaldehyde \u2192 Formose Glyceraldehyde \u2192 Hydroxypyruvate \u2192 Serine\",\n      \"description\": \"Hydrothermal CO\u2082 fixation to formaldehyde, surface formose reaction with borate stabilization to glyceraldehyde, photocatalytic oxidation to hydroxypyruvate, and reductive amination to serine. Links sugar chemistry to amino acid synthesis.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_013\", \"rxn_014\", \"rxn_012\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_006\", \"mol_014\", \"mol_010\"]\n    },\n    {\n      \"pathway_id\": \"P7\",\n      \"name\": \"Fischer-Tropsch \u2192 Formose Glyceraldehyde \u2192 Hydroxypyruvate \u2192 Serine\",\n      \"description\": \"CO-derived formaldehyde via Fischer-Tropsch, formose reaction to glyceraldehyde with borate stabilization, oxidation to hydroxypyruvate, and reductive amination to serine.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_013\", \"rxn_014\", \"rxn_012\"],\n      \"key_intermediates\": [\"mol_006\", \"mol_014\", \"mol_010\"]\n    },\n    {\n      \"pathway_id\": \"P8\",\n      \"name\": \"Hydrothermal Glyoxylate \u2192 Glycine \u2192 Serine via Hydroxymethylation\",\n      \"description\": \"Hydrothermal CO\u2082 reduction to glyoxylate on pyrite, reductive amination to glycine on mackinawite, transport to surface where glycine reacts with formaldehyde to form serine.\",\n      \"reaction_sequence\": [\"rxn_015\", \"rxn_016\", \"rxn_009\"],\n      \"key_intermediates\": [\"mol_015\", \"mol_011\"]\n    },\n    {\n      \"pathway_id\": \"P9\",\n      \"name\": \"Glyoxylate + Formaldehyde One-Pot Aldol-Amination to Serine\",\n      \"description\": \"Hydrothermal glyoxylate meets hydrothermal-derived formaldehyde in a surface evaporitic pool. Tandem aldol addition and reductive amination produces serine directly in a one-pot multi-component reaction on clay surfaces.\",\n      \"reaction_sequence\": [\"rxn_015\", \"rxn_001\", \"rxn_002\", \"rxn_017\"],\n      \"key_intermediates\": [\"mol_015\", \"mol_007\", \"mol_006\"]\n    },\n    {\n      \"pathway_id\": \"P10\",\n      \"name\": \"Direct Hydrothermal Carboxylation-Amination of Glycolaldehyde to Serine\",\n      \"description\": \"Glycolaldehyde (from surface aldol chemistry transported to vent or formed in situ) undergoes hydrothermal CO\u2082 carboxylation and reductive amination on iron sulfide surfaces to directly yield serine. A fully hydrothermal route from C2 to serine.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_004\", \"rxn_018\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_006\", \"mol_008\"]\n    }\n  ],\n  \"hub_molecules\": [\"mol_006\", \"mol_008\", \"mol_010\", \"mol_011\", \"mol_015\"],\n  \"convergence_points\": [\n    {\n      \"molecule_id\": \"mol_006\",\n      \"description\": \"Formaldehyde - Central C1 hub produced by two hydrothermal routes and consumed in five downstream reactions\",\n      \"incoming_reactions\": [\"rxn_002\", \"rxn_003\"],\n      \"outgoing_reactions\": [\"rxn_004\", \"rxn_005\", \"rxn_007\", \"rxn_009\", \"rxn_013\", \"rxn_017\"]\n    },\n    {\n      \"molecule_id\": \"mol_008\",\n      \"description\": \"Glycolaldehyde - Key C2 sugar intermediate bridging formaldehyde chemistry to Strecker and carboxylation pathways\",\n      \"incoming_reactions\": [\"rxn_004\"],\n      \"outgoing_reactions\": [\"rxn_005\", \"rxn_018\"]\n    },\n    {\n      \"molecule_id\": \"mol_010\",\n      \"description\": \"Hydroxypyruvate - Central \u03b1-keto acid hub linking pyruvate, glyceraldehyde, and glyoxylate routes to serine via reductive amination\",\n      \"incoming_reactions\": [\"rxn_011\", \"rxn_014\"],\n      \"outgoing_reactions\": [\"rxn_012\"]\n    },\n    {\n      \"molecule_id\": \"mol_011\",\n      \"description\": \"Glycine - Simplest amino acid serving as hub between glyoxylate pathway, Strecker synthesis, and hydroxymethylation to serine\",\n      \"incoming_reactions\": [\"rxn_008\", \"rxn_016\"],\n      \"outgoing_reactions\": [\"rxn_009\"]\n    },\n    {\n      \"molecule_id\": \"mol_015\",\n      \"description\": \"Glyoxylate - Key C2 keto acid from hydrothermal reduction, feeds into glycine and direct serine synthesis\",\n      \"incoming_reactions\": [\"rxn_015\"],\n      \"outgoing_reactions\": [\"rxn_016\", \"rxn_017\"]\n    }\n  ]\n}", "parsed_response": {"target_molecule": "Serine", "overall_strategy": "Multiple convergent prebiotic pathways to serine through five hub molecules: formaldehyde, glycolaldehyde, hydroxypyruvate, glycine, and HCN. Hydrothermal CO\u2082 fixation on iron-sulfur minerals generates C1-C3 intermediates (formate, formaldehyde, pyruvate, glyoxylate). These feed into surface-environment Strecker synthesis, formose-aldol chemistry, and reductive amination routes. Biochemical-stage assembly completes the final amination and hydrolysis steps. Ten distinct pathways ensure chemical redundancy and plausibility across varied early-Earth settings.", "molecules": [{"id": "mol_001", "formula": "CO2", "iupac_name": "carbon dioxide", "common_name": "carbon dioxide", "inchi": "InChI=1S/CO2/c2-1-3", "role": "starting", "environment_formed": null}, {"id": "mol_002", "formula": "H2", "iupac_name": "molecular hydrogen", "common_name": "hydrogen", "inchi": "InChI=1S/H2/h1H", "role": "starting", "environment_formed": null}, {"id": "mol_003", "formula": "NH3", "iupac_name": "ammonia", "common_name": "ammonia", "inchi": "InChI=1S/H3N/h1H3", "role": "starting", "environment_formed": null}, {"id": "mol_004", "formula": "H2O", "iupac_name": "water", "common_name": "water", "inchi": "InChI=1S/H2O/h1H2", "role": "starting", "environment_formed": null}, {"id": "mol_005", "formula": "HCN", "iupac_name": "hydrogen cyanide", "common_name": "hydrogen cyanide", "inchi": "InChI=1S/CHN/c1-2/h1H", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_006", "formula": "CH2O", "iupac_name": "methanal", "common_name": "formaldehyde", "inchi": "InChI=1S/CH2O/c1-2/h1H2", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_007", "formula": "CHO2-", "iupac_name": "formate", "common_name": "formate", "inchi": "InChI=1S/CH2O2/c2-1-3/h1H,(H,2,3)/p-1", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_008", "formula": "C2H4O2", "iupac_name": "2-hydroxyacetaldehyde", "common_name": "glycolaldehyde", "inchi": "InChI=1S/C2H4O2/c3-1-2-4/h1,4H,2H2", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_009", "formula": "C3H6N2O", "iupac_name": "2-amino-3-hydroxypropanenitrile", "common_name": "serine aminonitrile", "inchi": "InChI=1S/C3H6N2O/c4-2-1(3-5)6/h1,6H,3H2,(H2,4,5)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_010", "formula": "C3H4O4", "iupac_name": "3-hydroxy-2-oxopropanoic acid", "common_name": "hydroxypyruvate", "inchi": "InChI=1S/C3H4O4/c4-1-3(6)2(5)7/h4H,1H2,(H,6,7)", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_011", "formula": "C2H5NO2", "iupac_name": "2-aminoacetic acid", "common_name": "glycine", "inchi": "InChI=1S/C2H5NO2/c3-1-2(4)5/h1,3H2,(H,4,5)", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_012", "formula": "C3H7NO3", "iupac_name": "2-amino-3-hydroxypropanoic acid", "common_name": "serine", "inchi": "InChI=1S/C3H7NO3/c4-2(1-5)3(6)7/h2,5H,1,4H2,(H,6,7)", "role": "target", "environment_formed": "Biochemical"}, {"id": "mol_013", "formula": "CO", "iupac_name": "carbon monoxide", "common_name": "carbon monoxide", "inchi": "InChI=1S/CO/c1-2", "role": "starting", "environment_formed": "Hydrothermal"}, {"id": "mol_014", "formula": "C3H6O3", "iupac_name": "2,3-dihydroxypropanal", "common_name": "glyceraldehyde", "inchi": "InChI=1S/C3H6O3/c4-1-2(5)3-6/h1-2,5-6H,3H2", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_015", "formula": "C2H2O3", "iupac_name": "oxoacetic acid", "common_name": "glyoxylate", "inchi": "InChI=1S/C2H2O3/c3-1-2(4)5/h1H,(H,4,5)", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_016", "formula": "C3H4O3", "iupac_name": "2-oxopropanoic acid", "common_name": "pyruvate", "inchi": "InChI=1S/C3H4O3/c1-2(4)3(5)6/h1H3,(H,5,6)", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_017", "formula": "C2H4N2", "iupac_name": "2-aminoacetonitrile", "common_name": "aminoacetonitrile", "inchi": "InChI=1S/C2H4N2/c3-1-2-4/h2,4H2", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_018", "formula": "H2S", "iupac_name": "hydrogen sulfide", "common_name": "hydrogen sulfide", "inchi": "InChI=1S/H2S/h1H2", "role": "starting", "environment_formed": null}], "reactions": [{"id": "rxn_001", "name": "CO\u2082 hydrogenation to formate on greigite", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_007"], "environment": "Hydrothermal", "agents": ["greigite (Fe\u2083S\u2084)"], "conditions": {"temperature": "350-400K", "pressure": "high (50-100 bar)", "catalyst": "greigite (Fe\u2083S\u2084)", "aqueous": true, "other": "alkaline vent conditions, pH 9-11, H\u2082-rich fluids"}, "mechanism": "CO\u2082 adsorbs on Fe\u2083S\u2084 surface, undergoes two-electron reduction with H\u2082 as reductant to yield surface-bound formate, which desorbs into alkaline solution.", "reasoning": "Demonstrated by Preiner et al. (2020) and Roldan et al. (2015); greigite is a structural analog of biological [Fe\u2084S\u2084] clusters and catalyzes CO\u2082 reduction to formate under simulated alkaline vent conditions. Hudson et al. (2020) confirmed formate as the primary C1 product at 100\u00b0C on Fe\u2083S\u2084."}, {"id": "rxn_002", "name": "Formate reduction to formaldehyde on magnetite", "inputs": ["mol_007", "mol_002"], "outputs": ["mol_006", "mol_004"], "environment": "Hydrothermal", "agents": ["magnetite (Fe\u2083O\u2084)", "elemental iron (Fe\u2070)"], "conditions": {"temperature": "400-450K", "pressure": "high (50-200 bar)", "catalyst": "magnetite (Fe\u2083O\u2084) with Fe\u2070", "aqueous": true, "other": "reducing conditions, H\u2082 excess"}, "mechanism": "Formate is further reduced on magnetite surfaces via a Cannizzaro-type disproportionation or direct hydrogenation. Fe\u2070 acts as a strong reductant generating reactive hydrogen species on the magnetite surface, driving the two-electron reduction of formate to formaldehyde.", "reasoning": "Magnetite catalyzes Fischer-Tropsch-type reduction of C1 oxygenates (McCollom & Seewald, 2007). Reduction of formate to formaldehyde is thermodynamically feasible under high H\u2082 fugacity conditions in serpentinizing systems (Seewald et al., 2006). Fe\u2070 dramatically enhances yields (Varma et al., 2018)."}, {"id": "rxn_003", "name": "Fischer-Tropsch synthesis of formaldehyde from CO", "inputs": ["mol_013", "mol_002"], "outputs": ["mol_006"], "environment": "Hydrothermal", "agents": ["magnetite (Fe\u2083O\u2084)"], "conditions": {"temperature": "400-500K", "pressure": "high (100-300 bar)", "catalyst": "magnetite (Fe\u2083O\u2084)", "aqueous": true, "other": "Fischer-Tropsch-type conditions, CO:H\u2082 mixtures from volcanic outgassing"}, "mechanism": "CO adsorbs on magnetite surface, undergoes partial hydrogenation through surface-bound formyl intermediate (HCO*), then further hydrogenation yields formaldehyde which desorbs before full reduction to methanol.", "reasoning": "Fischer-Tropsch-type synthesis on magnetite at hydrothermal conditions has been demonstrated to produce formaldehyde, methanol, and longer chain aldehydes (McCollom et al., 1999; Holm & Charlou, 2001). CO is available from volcanic outgassing and hydrothermal CO\u2082 reduction."}, {"id": "rxn_004", "name": "Aldol condensation of formaldehyde to glycolaldehyde", "inputs": ["mol_006", "mol_006"], "outputs": ["mol_008"], "environment": "Surface", "agents": ["montmorillonite", "Ca(OH)\u2082"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "montmorillonite clay with Ca(OH)\u2082", "aqueous": true, "other": "mildly alkaline pH 10-11, dilute formaldehyde solution, initial step of formose reaction"}, "mechanism": "Base-catalyzed Cannizzaro-aldol mechanism: one formaldehyde is oxidized to formate while another is reduced; the resulting glycolaldehyde forms via umpolung aldol coupling on clay surfaces which concentrate and orient the reactants.", "reasoning": "The formose reaction's initial step, aldol self-condensation of formaldehyde to glycolaldehyde, is well established (Butlerow, 1861; Breslow, 1959). Montmorillonite clays concentrate organics on interlayer surfaces and stabilize intermediates (Ferris et al., 1996). Ca(OH)\u2082 provides necessary base catalysis."}, {"id": "rxn_005", "name": "Strecker synthesis of serine aminonitrile from glycolaldehyde", "inputs": ["mol_008", "mol_005", "mol_003"], "outputs": ["mol_009", "mol_004"], "environment": "Surface", "agents": ["montmorillonite"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "montmorillonite clay", "aqueous": true, "other": "mildly acidic to neutral pH, concentrated pool conditions"}, "mechanism": "Glycolaldehyde condenses with ammonia to form an imine (Schiff base), HOCH\u2082CH=NH. Nucleophilic addition of HCN to the imine carbon yields 2-amino-3-hydroxypropanenitrile (serine aminonitrile). Clay surfaces concentrate reactants and catalyze imine formation.", "reasoning": "The Strecker synthesis is one of the most robust prebiotic amino acid formation pathways (Miller, 1957; Strecker, 1850). Glycolaldehyde-based Strecker synthesis yielding serine precursors was demonstrated by Kebukawa et al. (2017) and is consistent with meteoritic amino acid distributions (Elsila et al., 2016)."}, {"id": "rxn_006", "name": "Hydrolysis of serine aminonitrile to serine", "inputs": ["mol_009", "mol_004"], "outputs": ["mol_012"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": null, "aqueous": true, "other": "mildly acidic to neutral aqueous conditions, wet-dry cycle heating accelerates hydrolysis"}, "mechanism": "The nitrile group undergoes sequential hydrolysis: first to an amide (HOCH\u2082CH(NH\u2082)CONH\u2082) then to the carboxylic acid (serine, HOCH\u2082CH(NH\u2082)COOH), with loss of NH\u2083. The reaction proceeds via nucleophilic addition of water to the electrophilic carbon of the nitrile.", "reasoning": "Aminonitrile hydrolysis to amino acids is the final step of the classical Strecker synthesis, demonstrated prebiotically by Miller (1957). Hydrolysis is spontaneous in aqueous solution and accelerated by mild heating (Pizzarello & Weber, 2004). Wet-dry cycling provides thermal activation."}, {"id": "rxn_007", "name": "Strecker synthesis of aminoacetonitrile from formaldehyde", "inputs": ["mol_006", "mol_005", "mol_003"], "outputs": ["mol_017", "mol_004"], "environment": "Surface", "agents": ["montmorillonite"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "montmorillonite clay", "aqueous": true, "other": "neutral to mildly acidic pH, concentrated pool"}, "mechanism": "Formaldehyde condenses with ammonia to form methyleneimine (H\u2082C=NH). Nucleophilic addition of HCN yields aminoacetonitrile (H\u2082N-CH\u2082-CN), the glycine aminonitrile. Montmorillonite surfaces concentrate the volatile reactants.", "reasoning": "The simplest Strecker synthesis from formaldehyde is one of the most efficient amino acid forming reactions, first demonstrated in spark discharge experiments by Miller (1953, 1957). Aminoacetonitrile has been detected in the interstellar medium (Belloche et al., 2008), confirming its prebiotic plausibility."}, {"id": "rxn_008", "name": "Hydrolysis of aminoacetonitrile to glycine", "inputs": ["mol_017", "mol_004"], "outputs": ["mol_011"], "environment": "Surface", "agents": ["montmorillonite"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "montmorillonite clay", "aqueous": true, "other": "warm acidic or neutral solution, wet-dry cycling accelerates"}, "mechanism": "Aminoacetonitrile undergoes stepwise hydrolysis: CN \u2192 CONH\u2082 (glycinamide) \u2192 COOH + NH\u2083 (glycine). Clay surfaces may catalyze the hydrolysis and prevent product decomposition.", "reasoning": "Aminonitrile hydrolysis to glycine is well characterized in Miller-Urey type experiments (Miller, 1957). Montmorillonite catalyzes nitrile hydrolysis (Ferris, 2005). Glycine is the most abundant amino acid in spark discharge experiments and carbonaceous meteorites."}, {"id": "rxn_009", "name": "Glycine hydroxymethylation to serine", "inputs": ["mol_011", "mol_006"], "outputs": ["mol_012"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "320-370K", "pressure": "1 atm", "catalyst": null, "aqueous": true, "other": "mildly alkaline pH, concentrated pool, mineral surface optional. Analogous to serine hydroxymethyltransferase reaction"}, "mechanism": "Formaldehyde reacts with glycine via an aldol-type addition. The \u03b1-carbon of glycine is deprotonated under basic conditions to form a carbanion, which attacks the carbonyl carbon of formaldehyde. The resulting \u03b2-hydroxyamino acid is serine. This is the non-enzymatic analog of the serine hydroxymethyltransferase (SHMT) reaction.", "reasoning": "The aldol-type condensation of glycine with formaldehyde to produce serine is the prebiotic analog of the SHMT reaction, a central reaction in one-carbon metabolism. Demonstrated abiotically by Huber & W\u00e4chtersh\u00e4user (2003). This reaction connects C1 metabolism (formaldehyde) to amino acid diversity."}, {"id": "rxn_010", "name": "Hydrothermal CO\u2082 reduction to pyruvate on greigite", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_016", "mol_004"], "environment": "Hydrothermal", "agents": ["greigite (Fe\u2083S\u2084)", "magnetite (Fe\u2083O\u2084)"], "conditions": {"temperature": "350-400K", "pressure": "high (50-100 bar)", "catalyst": "greigite + magnetite mixed mineral surface", "aqueous": true, "other": "alkaline vent, pH 9-11, H\u2082-rich, sequential C1 \u2192 C3 carboxylation. Net: 3CO\u2082 + 5H\u2082 \u2192 CH\u2083COCOO\u207b + 4H\u2082O"}, "mechanism": "Sequential CO\u2082 reduction and C-C bond formation on Fe\u2083S\u2084 surfaces: CO\u2082 \u2192 formate \u2192 CO/formyl \u2192 acetyl \u2192 pyruvate. The greigite surface mimics the acetyl-CoA pathway, with iron-sulfur clusters providing both reduction potential and carbon-carbon coupling catalysis.", "reasoning": "Varma et al. (2018) demonstrated pyruvate synthesis from CO\u2082 and H\u2082 on native iron with greigite catalysis at 100\u00b0C under alkaline conditions. Muchowska et al. (2017) showed iron facilitates a proto-metabolic network centered on pyruvate. This mirrors the reductive acetyl-CoA pathway (Fuchs, 2011)."}, {"id": "rxn_011", "name": "UV-driven hydroxylation of pyruvate to hydroxypyruvate", "inputs": ["mol_016", "mol_004"], "outputs": ["mol_010"], "environment": "Surface", "agents": ["TiO\u2082 (anatase)"], "conditions": {"temperature": "300-340K", "pressure": "1 atm", "catalyst": "TiO\u2082 (anatase) photocatalyst", "aqueous": true, "other": "UV irradiation (\u03bb < 300 nm, no ozone layer), shallow pool. TiO\u2082 generates hydroxyl radicals under UV."}, "mechanism": "UV light excites TiO\u2082 generating electron-hole pairs. Holes oxidize water to produce hydroxyl radicals (\u2022OH). Hydroxyl radical attacks the methyl group of pyruvate, abstracting H and forming \u2022CH\u2082COCOO\u207b, which combines with \u2022OH to yield HOCH\u2082COCOO\u207b (hydroxypyruvate).", "reasoning": "TiO\u2082 photocatalytic hydroxylation is well established in environmental chemistry and plausible on early Earth (Schrauzer & Guth, 1977). Pyruvate photochemistry has been explored by Rapf & Vaida (2016). Hydroxypyruvate is the direct \u03b1-keto acid precursor to serine in extant metabolism."}, {"id": "rxn_012", "name": "Reductive amination of hydroxypyruvate to serine", "inputs": ["mol_010", "mol_003"], "outputs": ["mol_012", "mol_004"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": null, "aqueous": true, "other": "NH\u2083-rich aqueous solution, mildly reducing, possible Fe\u00b2\u207a as electron donor. Analogous to modern transaminase reactions."}, "mechanism": "Ammonia attacks the carbonyl carbon of hydroxypyruvate to form an imine (Schiff base), HOCH\u2082C(=NH)COOH. Reduction of the imine by available reductants (Fe\u00b2\u207a, H\u2082S, or NADH analog) yields serine. This is a non-enzymatic reductive amination, analogous to biological aminotransferase reactions.", "reasoning": "Reductive amination of \u03b1-keto acids is one of the most fundamental prebiotic amino acid synthesis routes (Bada, 2013). Muchowska et al. (2020) demonstrated non-enzymatic reductive amination of \u03b1-keto acids including hydroxypyruvate with Fe\u2070/Fe\u00b2\u207a as reductant, yielding the corresponding amino acids. This directly connects proto-metabolic keto acid networks to amino acid synthesis."}, {"id": "rxn_013", "name": "Formose reaction: formaldehyde to glyceraldehyde", "inputs": ["mol_006"], "outputs": ["mol_014"], "environment": "Surface", "agents": ["borate minerals (colemanite)", "montmorillonite"], "conditions": {"temperature": "310-350K", "pressure": "1 atm", "catalyst": "borate minerals (Ca\u2082B\u2086O\u2081\u2081\u00b75H\u2082O) + Ca(OH)\u2082 + clay", "aqueous": true, "other": "mildly alkaline pH 10-11, borate stabilizes sugars and channels formose toward glyceraldehyde. Net: 3 HCHO \u2192 glyceraldehyde."}, "mechanism": "Autocatalytic aldol cascade: 2 HCHO \u2192 glycolaldehyde (aldol); glycolaldehyde + HCHO \u2192 glyceraldehyde (aldol). Borate complexes with vicinal diols of intermediates, stabilizing glyceraldehyde and preventing further polymerization to tar. Clay surfaces template and concentrate reactants.", "reasoning": "The formose reaction (Butlerow, 1861) is the classic prebiotic sugar synthesis. Borate stabilization of sugar intermediates was demonstrated by Ricardo et al. (2004), showing that borate minerals channel the formose reaction toward specific sugars including glyceraldehyde and ribose. This addresses the canonical tar problem of the uncatalyzed formose reaction."}, {"id": "rxn_014", "name": "Oxidation of glyceraldehyde to hydroxypyruvate", "inputs": ["mol_014"], "outputs": ["mol_010"], "environment": "Surface", "agents": ["TiO\u2082 (anatase)", "pyrite (FeS\u2082)"], "conditions": {"temperature": "300-340K", "pressure": "1 atm", "catalyst": "TiO\u2082 photocatalyst with pyrite as electron acceptor", "aqueous": true, "other": "UV irradiation, anoxic but UV-driven oxidation. Two-electron oxidation at C2."}, "mechanism": "TiO\u2082 generates photo-oxidant holes under UV that oxidize the secondary alcohol of glyceraldehyde (C2-OH \u2192 C2=O), converting the aldehyde-sugar to the \u03b1-keto acid hydroxypyruvate. Pyrite acts as an electron sink, preventing back-reduction.", "reasoning": "Photocatalytic oxidation of sugars on mineral surfaces is prebiotically plausible given intense UV on the early Earth (Ranjan & Sasselov, 2017). Glyceraldehyde-to-hydroxypyruvate conversion links sugar chemistry to keto acid metabolism, a critical bridge in prebiotic network theories (Ralser, 2018). TiO\u2082 photocatalysis drives selective oxidation (Kisch, 2015)."}, {"id": "rxn_015", "name": "Hydrothermal CO\u2082 reduction to glyoxylate on pyrite", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_015", "mol_004"], "environment": "Hydrothermal", "agents": ["pyrite (FeS\u2082)", "mackinawite (FeS)"], "conditions": {"temperature": "350-400K", "pressure": "high (50-100 bar)", "catalyst": "pyrite + mackinawite", "aqueous": true, "other": "reducing conditions, pH 6-9, net: 2CO\u2082 + 3H\u2082 \u2192 OHCCOOH + 2H\u2082O"}, "mechanism": "Sequential reduction: CO\u2082 \u2192 formate \u2192 formaldehyde on mackinawite, followed by carbonylation (formaldehyde + CO\u2082 \u2192 glyoxylate) on pyrite surface. Alternatively, oxidative coupling of two formate-level C1 units on pyrite surfaces to yield glyoxylate.", "reasoning": "Glyoxylate is a key intermediate in the glyoxylate scenario for origins of metabolism (Eschenmoser, 2007). Hydrothermal synthesis of C2 carboxylic acids from CO\u2082 on iron sulfide minerals has been reported (Cody et al., 2000). Pyrite surface catalysis for C-C bond formation was proposed by W\u00e4chtersh\u00e4user (1990)."}, {"id": "rxn_016", "name": "Reductive amination of glyoxylate to glycine", "inputs": ["mol_015", "mol_003"], "outputs": ["mol_011", "mol_004"], "environment": "Hydrothermal", "agents": ["mackinawite (FeS)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "mackinawite (FeS)", "aqueous": true, "other": "NH\u2083-rich alkaline vent fluid, reducing conditions with H\u2082"}, "mechanism": "Ammonia attacks the aldehyde carbonyl of glyoxylate to form an imine (glyoxylate oxime). The imine is reduced by H\u2082 on the FeS surface to yield glycine. This is a direct reductive amination on mineral surfaces.", "reasoning": "Reductive amination of \u03b1-keto/\u03b1-oxo acids on iron sulfide surfaces was demonstrated by Huber & W\u00e4chtersh\u00e4user (2006). Glycine formation from glyoxylate and ammonia is thermodynamically favorable under reducing hydrothermal conditions. This mirrors the biological transamination of glyoxylate to glycine."}, {"id": "rxn_017", "name": "One-pot aldol-amination of glyoxylate with formaldehyde to serine", "inputs": ["mol_015", "mol_006", "mol_003"], "outputs": ["mol_012", "mol_004"], "environment": "Surface", "agents": ["montmorillonite", "phosphate minerals (apatite)"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "montmorillonite + apatite", "aqueous": true, "other": "concentrated evaporitic pool with mixed hydrothermal effluent, mildly alkaline"}, "mechanism": "Tandem aldol-reductive amination: formaldehyde undergoes aldol addition to glyoxylate, producing tartronate semialdehyde (3-hydroxy-2-oxopropanoic acid, identical to hydroxypyruvate). In the presence of ammonia, the \u03b1-keto group undergoes reductive amination to yield serine. Montmorillonite concentrates reactants; phosphate minerals buffer pH.", "reasoning": "This tandem pathway was proposed in the context of the glyoxylate scenario (Eschenmoser, 2007), where glyoxylate serves as a universal precursor to amino acids and sugars through aldol and amination chemistry. One-pot multi-component reactions are prebiotically realistic in concentrated pools (Powner et al., 2009)."}, {"id": "rxn_018", "name": "Direct hydrothermal carboxylation-amination of glycolaldehyde to serine", "inputs": ["mol_008", "mol_001", "mol_003", "mol_002"], "outputs": ["mol_012", "mol_004"], "environment": "Hydrothermal", "agents": ["greigite (Fe\u2083S\u2084)", "pyrite (FeS\u2082)"], "conditions": {"temperature": "350-400K", "pressure": "high (50-100 bar)", "catalyst": "greigite + pyrite", "aqueous": true, "other": "alkaline vent, H\u2082/CO\u2082 rich, NH\u2083 from vent fluid, one-pot carboxylation + amination"}, "mechanism": "On greigite surfaces, glycolaldehyde undergoes CO\u2082 insertion at C1 to form a C3 \u03b2-hydroxy-\u03b1-keto acid (hydroxypyruvate), followed by in situ reductive amination by NH\u2083 with H\u2082 as reductant to yield serine directly. The iron sulfide surface provides both carboxylation and reduction catalysis.", "reasoning": "Iron sulfide surfaces catalyze both CO\u2082 fixation and reductive amination (Huber & W\u00e4chtersh\u00e4user, 1997, 2006). Multi-step one-pot synthesis on mineral surfaces is proposed in the iron-sulfur world hypothesis (W\u00e4chtersh\u00e4user, 1988). Glycolaldehyde carboxylation provides an alternative C2 \u2192 C3 route to pyruvate-based pathways."}], "pathways": [{"pathway_id": "P1", "name": "Hydrothermal CO\u2082 \u2192 Formate \u2192 Formaldehyde \u2192 Glycolaldehyde \u2192 Strecker Serine", "description": "Complete Strecker synthesis route starting from hydrothermal CO\u2082 reduction on greigite to formate, further reduction to formaldehyde on magnetite, surface aldol condensation to glycolaldehyde, Strecker reaction with HCN and NH\u2083 to form serine aminonitrile, and final hydrolysis to serine.", "reaction_sequence": ["rxn_001", "rxn_002", "rxn_004", "rxn_005", "rxn_006"], "key_intermediates": ["mol_007", "mol_006", "mol_008", "mol_009"]}, {"pathway_id": "P2", "name": "Fischer-Tropsch Formaldehyde \u2192 Glycolaldehyde \u2192 Strecker Serine", "description": "Fischer-Tropsch-type synthesis of formaldehyde from volcanic CO and H\u2082 on magnetite, followed by surface aldol to glycolaldehyde, then Strecker synthesis to serine via aminonitrile intermediate.", "reaction_sequence": ["rxn_003", "rxn_004", "rxn_005", "rxn_006"], "key_intermediates": ["mol_006", "mol_008", "mol_009"]}, {"pathway_id": "P3", "name": "Hydrothermal Pyruvate \u2192 Hydroxypyruvate \u2192 Reductive Amination to Serine", "description": "Direct CO\u2082 fixation to pyruvate on greigite, UV-driven hydroxylation to hydroxypyruvate at the surface, and non-enzymatic reductive amination to serine. Mirrors the modern biosynthetic route.", "reaction_sequence": ["rxn_010", "rxn_011", "rxn_012"], "key_intermediates": ["mol_016", "mol_010"]}, {"pathway_id": "P4", "name": "CO\u2082 \u2192 Formaldehyde \u2192 Strecker Glycine \u2192 Hydroxymethylation to Serine", "description": "Hydrothermal CO\u2082 reduction to formaldehyde via formate, Strecker synthesis of glycine from formaldehyde + HCN + NH\u2083 at the surface, then aldol-type condensation of glycine with a second formaldehyde to serine. Analog of the SHMT reaction.", "reaction_sequence": ["rxn_001", "rxn_002", "rxn_007", "rxn_008", "rxn_009"], "key_intermediates": ["mol_007", "mol_006", "mol_017", "mol_011"]}, {"pathway_id": "P5", "name": "Fischer-Tropsch \u2192 Strecker Glycine \u2192 Hydroxymethylation to Serine", "description": "CO-derived formaldehyde through Fischer-Tropsch synthesis, followed by Strecker synthesis of glycine, then glycine + formaldehyde aldol condensation to serine.", "reaction_sequence": ["rxn_003", "rxn_007", "rxn_008", "rxn_009"], "key_intermediates": ["mol_006", "mol_017", "mol_011"]}, {"pathway_id": "P6", "name": "CO\u2082 \u2192 Formaldehyde \u2192 Formose Glyceraldehyde \u2192 Hydroxypyruvate \u2192 Serine", "description": "Hydrothermal CO\u2082 fixation to formaldehyde, surface formose reaction with borate stabilization to glyceraldehyde, photocatalytic oxidation to hydroxypyruvate, and reductive amination to serine. Links sugar chemistry to amino acid synthesis.", "reaction_sequence": ["rxn_001", "rxn_002", "rxn_013", "rxn_014", "rxn_012"], "key_intermediates": ["mol_007", "mol_006", "mol_014", "mol_010"]}, {"pathway_id": "P7", "name": "Fischer-Tropsch \u2192 Formose Glyceraldehyde \u2192 Hydroxypyruvate \u2192 Serine", "description": "CO-derived formaldehyde via Fischer-Tropsch, formose reaction to glyceraldehyde with borate stabilization, oxidation to hydroxypyruvate, and reductive amination to serine.", "reaction_sequence": ["rxn_003", "rxn_013", "rxn_014", "rxn_012"], "key_intermediates": ["mol_006", "mol_014", "mol_010"]}, {"pathway_id": "P8", "name": "Hydrothermal Glyoxylate \u2192 Glycine \u2192 Serine via Hydroxymethylation", "description": "Hydrothermal CO\u2082 reduction to glyoxylate on pyrite, reductive amination to glycine on mackinawite, transport to surface where glycine reacts with formaldehyde to form serine.", "reaction_sequence": ["rxn_015", "rxn_016", "rxn_009"], "key_intermediates": ["mol_015", "mol_011"]}, {"pathway_id": "P9", "name": "Glyoxylate + Formaldehyde One-Pot Aldol-Amination to Serine", "description": "Hydrothermal glyoxylate meets hydrothermal-derived formaldehyde in a surface evaporitic pool. Tandem aldol addition and reductive amination produces serine directly in a one-pot multi-component reaction on clay surfaces.", "reaction_sequence": ["rxn_015", "rxn_001", "rxn_002", "rxn_017"], "key_intermediates": ["mol_015", "mol_007", "mol_006"]}, {"pathway_id": "P10", "name": "Direct Hydrothermal Carboxylation-Amination of Glycolaldehyde to Serine", "description": "Glycolaldehyde (from surface aldol chemistry transported to vent or formed in situ) undergoes hydrothermal CO\u2082 carboxylation and reductive amination on iron sulfide surfaces to directly yield serine. A fully hydrothermal route from C2 to serine.", "reaction_sequence": ["rxn_001", "rxn_002", "rxn_004", "rxn_018"], "key_intermediates": ["mol_007", "mol_006", "mol_008"]}], "hub_molecules": ["mol_006", "mol_008", "mol_010", "mol_011", "mol_015"], "convergence_points": [{"molecule_id": "mol_006", "description": "Formaldehyde - Central C1 hub produced by two hydrothermal routes and consumed in five downstream reactions", "incoming_reactions": ["rxn_002", "rxn_003"], "outgoing_reactions": ["rxn_004", "rxn_005", "rxn_007", "rxn_009", "rxn_013", "rxn_017"]}, {"molecule_id": "mol_008", "description": "Glycolaldehyde - Key C2 sugar intermediate bridging formaldehyde chemistry to Strecker and carboxylation pathways", "incoming_reactions": ["rxn_004"], "outgoing_reactions": ["rxn_005", "rxn_018"]}, {"molecule_id": "mol_010", "description": "Hydroxypyruvate - Central \u03b1-keto acid hub linking pyruvate, glyceraldehyde, and glyoxylate routes to serine via reductive amination", "incoming_reactions": ["rxn_011", "rxn_014"], "outgoing_reactions": ["rxn_012"]}, {"molecule_id": "mol_011", "description": "Glycine - Simplest amino acid serving as hub between glyoxylate pathway, Strecker synthesis, and hydroxymethylation to serine", "incoming_reactions": ["rxn_008", "rxn_016"], "outgoing_reactions": ["rxn_009"]}, {"molecule_id": "mol_015", "description": "Glyoxylate - Key C2 keto acid from hydrothermal reduction, feeds into glycine and direct serine synthesis", "incoming_reactions": ["rxn_015"], "outgoing_reactions": ["rxn_016", "rxn_017"]}]}, "reasoning": "", "duration_ms": 420743.3891296387, "success": true, 
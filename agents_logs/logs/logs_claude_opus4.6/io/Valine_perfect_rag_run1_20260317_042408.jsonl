 \"Surface\"\n    },\n    {\n      \"id\": \"mol_014\",\n      \"formula\": \"C4H9NOS\",\n      \"iupac_name\": \"2-hydroxy-2-methylpropanethioamide\",\n      \"common_name\": \"2-Hydroxy-2-methylpropanethioamide\",\n      \"inchi\": \"InChI=1S/C4H9NOS/c1-4(2,6)3(5)7/h6H,1-2H3,(H2,5,7)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_015\",\n      \"formula\": \"C5H9NO\",\n      \"iupac_name\": \"2-hydroxy-3-methylbutanenitrile\",\n      \"common_name\": \"2-Hydroxy-3-methylbutanenitrile\",\n      \"inchi\": \"InChI=1S/C5H9NO/c1-4(2)5(7)3-6/h4-5,7H,1-2H3\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_016\",\n      \"formula\": \"C5H10N2\",\n      \"iupac_name\": \"2-amino-3-methylbutanenitrile\",\n      \"common_name\": \"2-Amino-3-methylbutanenitrile\",\n      \"inchi\": \"InChI=1S/C5H10N2/c1-4(2)5(7)3-6/h4-5H,7H2,1-2H3\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_017\",\n      \"formula\": \"C4H8O\",\n      \"iupac_name\": \"2-methylpropanal\",\n      \"common_name\": \"Isobutyraldehyde\",\n      \"inchi\": \"InChI=1S/C4H8O/c1-3(2)4-5/h3-4H,1-2H3\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_018\",\n      \"formula\": \"C5H10O\",\n      \"iupac_name\": \"3-methylbutanal\",\n      \"common_name\": \"Isovaleraldehyde\",\n      \"inchi\": \"InChI=1S/C5H10O/c1-4(2)3-5-6/h4-5H,3H2,1-2H3\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_019\",\n      \"formula\": \"C6H12N2\",\n      \"iupac_name\": \"2-amino-4-methylpentanenitrile\",\n      \"common_name\": \"2-Amino-4-methylpentanenitrile\",\n      \"inchi\": \"InChI=1S/C6H12N2/c1-5(2)3-6(8)4-7/h5-6H,3,8H2,1-2H3\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_020\",\n      \"formula\": \"C3H4O3\",\n      \"iupac_name\": \"2-oxopropanoic acid\",\n      \"common_name\": \"Pyruvate\",\n      \"inchi\": \"InChI=1S/C3H4O3/c1-2(4)3(5)6/h1H3,(H,5,6)\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_021\",\n      \"formula\": \"C5H8O3\",\n      \"iupac_name\": \"3-methyl-2-oxobutanoic acid\",\n      \"common_name\": \"alpha-Ketoisovalerate\",\n      \"inchi\": \"InChI=1S/C5H8O3/c1-3(2)4(6)5(7)8/h3H,1-2H3,(H,7,8)\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_022\",\n      \"formula\": \"H2S2\",\n      \"iupac_name\": \"disulfane\",\n      \"common_name\": \"Disulfane\",\n      \"inchi\": \"InChI=1S/H2S2/c1-2/h1-2H\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_023\",\n      \"formula\": \"C3H7NO2\",\n      \"iupac_name\": \"2-aminopropanoic acid\",\n      \"common_name\": \"Alanine\",\n      \"inchi\": \"InChI=1S/C3H7NO2/c1-2(5)3(6)7/h2H,5H2,1H3,(H,6,7)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_024\",\n      \"formula\": \"C5H11NO2\",\n      \"iupac_name\": \"2-amino-3-methylbutanoic acid\",\n      \"common_name\": \"L-Valine\",\n      \"inchi\": \"InChI=1S/C5H11NO2/c1-3(2)4(6)5(7)8/h3-4H,6H2,1-2H3,(H,7,8)\",\n      \"role\": \"target\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_025\",\n      \"formula\": \"C5H8O4\",\n      \"iupac_name\": \"2-hydroxy-2-methyl-3-oxobutanoic acid\",\n      \"common_name\": \"Acetolactate\",\n      \"inchi\": \"InChI=1S/C5H8O4/c1-3(7)4(2,8)5(9)10/h8H,1-2H3,(H,9,10)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"Fischer-Tropsch-type CO2 reduction to formaldehyde\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_007\", \"mol_003\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe3O4)\"],\n      \"conditions\": {\n        \"temperature\": \"400-500K\",\n        \"pressure\": \"high (100-300 bar)\",\n        \"catalyst\": \"magnetite (Fe3O4)\",\n        \"aqueous\": true,\n        \"other\": \"Fischer-Tropsch-type synthesis at alkaline hydrothermal vent conditions; CO2 first reduced to CO on magnetite, then to formaldehyde\"\n      },\n      \"mechanism\": \"CO2 is adsorbed on magnetite surface and stepwise hydrogenated via surface-bound CO intermediate to formaldehyde. H2 from serpentinization provides reducing equivalents. The magnetite surface stabilizes the C1 intermediate against further reduction.\",\n      \"reasoning\": \"FTT synthesis of formaldehyde from CO2 + H2 on magnetite is documented in hydrothermal experiments (McCollom et al., 1999; Holm & Andersson, 2005). Formaldehyde is the essential C1 feedstock for downstream formose chemistry that produces the C3 sugar precursors of valine. Patel et al. (2015) require sugar-derived feedstocks whose ultimate origin is plausibly hydrothermal.\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Formose reaction: formaldehyde dimerization to glycolaldehyde\",\n      \"inputs\": [\"mol_007\", \"mol_007\"],\n      \"outputs\": [\"mol_008\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite)\", \"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"borate minerals, Ca(OH)2\",\n        \"aqueous\": true,\n        \"other\": \"Alkaline conditions (pH 10-11) in evaporitic pools; borate minerals stabilize sugar intermediates\"\n      },\n      \"mechanism\": \"Base-catalyzed aldol condensation of two formaldehyde molecules. Under alkaline conditions, formaldehyde undergoes Cannizzaro-like disproportionation and umpolung to generate a nucleophilic C1 species that attacks a second formaldehyde, yielding the C2 product glycolaldehyde.\",\n      \"reasoning\": \"The formose reaction producing glycolaldehyde from formaldehyde is well-established (Breslow, 1959; Ricardo et al., 2004). Borate minerals stabilize sugar intermediates against degradation (Ricardo et al., 2004). This provides the first C2 building block en route to C3 sugar precursors of acetone needed for the Patel et al. (2015) valine pathway.\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Aldol condensation: glycolaldehyde + formaldehyde to glyceraldehyde\",\n      \"inputs\": [\"mol_008\", \"mol_007\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite)\", \"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"borate minerals\",\n        \"aqueous\": true,\n        \"other\": \"Alkaline evaporitic pool conditions; borate complexation stabilizes glyceraldehyde\"\n      },\n      \"mechanism\": \"Aldol addition of formaldehyde to glycolaldehyde. The glycolaldehyde enolate attacks the electrophilic carbonyl of formaldehyde, forming a C-C bond to yield the C3 aldose glyceraldehyde.\",\n      \"reasoning\": \"Classical formose chemistry step documented by Butlerow (1861) and extensively characterized by Breslow (1959). Borate minerals stabilize the glyceraldehyde product against retro-aldol and Lobry de Bruyn-van Ekenstein degradation (Ricardo et al., 2004). This connects C1 hydrothermal feedstock to C3 sugar precursors needed by Patel et al. (2015).\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"Glyceraldehyde-dihydroxyacetone isomerization\",\n      \"inputs\": [\"mol_011\"],\n      \"outputs\": [\"mol_009\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite clay\",\n        \"aqueous\": true,\n        \"other\": \"Lobry de Bruyn-van Ekenstein isomerization on clay surface; mildly alkaline aqueous conditions\"\n      },\n      \"mechanism\": \"Keto-enol tautomerization via 1,2-enediol intermediate. Glyceraldehyde (aldose) equilibrates with dihydroxyacetone (ketose) through reversible proton transfers catalyzed by clay mineral surfaces acting as mild base catalysts.\",\n      \"reasoning\": \"The glyceraldehyde \u21cc dihydroxyacetone isomerization is a well-known Lobry de Bruyn-van Ekenstein transformation. Clay minerals such as montmorillonite catalyze this tautomerization (Pestunova et al., 2005). DHA is the required substrate for Pathway 1 of the Patel et al. (2015) cyanosulfidic valine synthesis.\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"Partial reductive deoxygenation of DHA to hydroxyacetone\",\n      \"inputs\": [\"mol_009\", \"mol_005\"],\n      \"outputs\": [\"mol_010\", \"mol_003\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"elemental copper (Cu0)\", \"sulfide minerals (stibnite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"Cu0 and H2S\",\n        \"aqueous\": true,\n        \"other\": \"Cyanosulfidic conditions in surface evaporitic pools; partial reduction stops at monohydroxy stage\"\n      },\n      \"mechanism\": \"Copper acts as a single-electron reductant in concert with H2S to selectively remove one hydroxymethyl oxygen from DHA. The Cu0/H2S system strips one hydroxyl via a radical or polar mechanism, yielding the partially reduced product hydroxyacetone (acetol). This is the first step of the full reductive deoxygenation cascade.\",\n      \"reasoning\": \"Patel et al. (2015) demonstrated Cu/H2S-mediated reductive deoxygenation of sugar derivatives. The DHA \u2192 acetone conversion proceeds through hydroxyacetone as a logical partial intermediate, providing the substrate for Pathway 2 of the valine synthesis. The Cu/H2S system is the essential reductive agent in the cyanosulfidic framework.\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"Reductive deoxygenation of DHA to acetone (full)\",\n      \"inputs\": [\"mol_009\", \"mol_005\"],\n      \"outputs\": [\"mol_012\", \"mol_003\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"elemental copper (Cu0)\", \"sulfide minerals (stibnite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"Cu0 and H2S\",\n        \"aqueous\": true,\n        \"other\": \"Cyanosulfidic surface pool; extended reaction time allows full deoxygenation; Cu is essential single-electron reductant\"\n      },\n      \"mechanism\": \"Cu0/H2S-mediated reductive removal of both hydroxyl groups from dihydroxyacetone. Copper provides single electrons for sequential C-O bond cleavage while H2S provides additional reducing equivalents. Both hydroxymethyl oxygens are stripped to yield the simple ketone acetone and water.\",\n      \"reasoning\": \"Directly demonstrated by Patel, Percivalle, Ritson, Duffy, and Sutherland (2015, Nature Chemistry, DOI: 10.1038/nchem.2202). This is the first step of their experimentally validated Pathway 1 for valine synthesis. DHA \u2192 acetone is the key sugar-to-ketone conversion that initiates the cyanosulfidic route to branched-chain amino acids. Cu0 is essential as verified experimentally.\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Reductive deoxygenation of hydroxyacetone to acetone\",\n      \"inputs\": [\"mol_010\", \"mol_005\"],\n      \"outputs\": [\"mol_012\", \"mol_003\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"elemental copper (Cu0)\", \"sulfide minerals (stibnite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"Cu0 and H2S\",\n        \"aqueous\": true,\n        \"other\": \"Cyanosulfidic surface pool; Cu0/H2S system removes hydroxyl\"\n      },\n      \"mechanism\": \"Cu0/H2S-mediated reductive removal of the single hydroxyl group from hydroxyacetone (acetol). Copper provides electron for C-O bond cleavage while H2S acts as co-reductant, yielding acetone and water.\",\n      \"reasoning\": \"Directly demonstrated by Patel et al. (2015, Nature Chemistry, DOI: 10.1038/nchem.2202). This is the upstream step of their experimentally validated Pathway 2 for valine synthesis. Hydroxyacetone provides an alternative entry to the same acetone hub as DHA, establishing convergence at the acetone node. Cu0 is explicitly required.\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Cyanohydrin formation: acetone + HCN\",\n      \"inputs\": [\"mol_012\", \"mol_004\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mildly basic aqueous conditions\",\n        \"aqueous\": true,\n        \"other\": \"Cyanosulfidic surface pool; HCN available from atmospheric/volcanic sources; clay surfaces concentrate reactants\"\n      },\n      \"mechanism\": \"Nucleophilic addition of cyanide (CN-) to the electrophilic carbonyl carbon of acetone. Under mildly basic conditions, HCN deprotonates to CN-, which attacks the ketone carbonyl. Protonation of the resulting alkoxide yields the tertiary cyanohydrin (acetone cyanohydrin). This is a classic Kiliani-type reaction on a ketone substrate.\",\n      \"reasoning\": \"Demonstrated by Patel et al. (2015, Nature Chemistry, DOI: 10.1038/nchem.2202) as step 2 of their valine synthesis pathway. Cyanohydrin formation from ketones is a well-established reaction in organic chemistry. The symmetrical dimethyl substitution of acetone gives a single tertiary cyanohydrin product, initiating the C-C bond extension needed for the valine skeleton.\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"Thioamide formation: nitrile + H2S\",\n      \"inputs\": [\"mol_013\", \"mol_005\"],\n      \"outputs\": [\"mol_014\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (stibnite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"H2S as reagent\",\n        \"aqueous\": true,\n        \"other\": \"Cyanosulfidic pool; H2S acts as both nucleophile and sulfur source\"\n      },\n      \"mechanism\": \"Nucleophilic addition of H2S across the C\u2261N triple bond of the cyanohydrin nitrile. Sulfur attacks the electrophilic nitrile carbon, forming a C-S bond. Proton transfer completes conversion of the nitrile to a primary thioamide (C(=S)NH2). This activates the nitrile for subsequent reductive rearrangement.\",\n      \"reasoning\": \"Demonstrated by Patel et al. (2015, Nature Chemistry, DOI: 10.1038/nchem.2202) as step 3 of their valine synthesis. The conversion of nitriles to thioamides by H2S is a defining feature of cyanosulfidic chemistry. The thioamide is the key activated intermediate that enables the subsequent Cu-mediated reductive chain extension step.\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"Reductive rearrangement and chain extension (Cu/H2S-mediated)\",\n      \"inputs\": [\"mol_014\", \"mol_004\", \"mol_005\"],\n      \"outputs\": [\"mol_015\", \"mol_022\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"elemental copper (Cu0)\", \"sulfide minerals (stibnite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"Cu0 and H2S\",\n        \"aqueous\": true,\n        \"other\": \"Cyanosulfidic pool; Cu0 essential for single-electron reduction; H2S co-reductant and sulfur source; HCN provides new carbon unit\"\n      },\n      \"mechanism\": \"Complex Cu0/H2S-mediated reductive rearrangement incorporating a second HCN unit. The thioamide undergoes reductive cleavage mediated by copper single-electron transfer. The thioamide nitrogen is lost, the sulfur acts as a leaving group (oxidized to disulfane, H2S2), and a new C-C bond is formed with the incoming HCN carbon. This builds the branched C5 skeleton: the C4 thioamide is extended to a C5 alpha-hydroxynitrile with the isopropyl branch of valine established.\",\n      \"reasoning\": \"Demonstrated by Patel et al. (2015, Nature Chemistry, DOI: 10.1038/nchem.2202) as step 4 of their valine synthesis. This is the critical C-C bond-forming step that builds the branched-chain architecture unique to valine. Cu0 is explicitly essential as a single-electron reductant. The detailed radical mechanism remains under active investigation (acknowledged as an open question by the authors), but the net transformation is experimentally verified.\"\n    },\n    {\n      \"id\": \"rxn_011\",\n      \"name\": \"Strecker-type amination of hydroxynitrile\",\n      \"inputs\": [\"mol_015\", \"mol_006\"],\n      \"outputs\": [\"mol_016\", \"mol_003\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite clay\",\n        \"aqueous\": true,\n        \"other\": \"Cyanosulfidic pool; NH3 from volcanic/atmospheric sources\"\n      },\n      \"mechanism\": \"Nucleophilic substitution of the alpha-hydroxyl group by ammonia. NH3 displaces the OH at the alpha-carbon adjacent to the nitrile group, converting the alpha-hydroxynitrile to the corresponding alpha-aminonitrile. This is a classic Strecker-type amination \u2014 the key step that introduces the amino group at the position that will become the amino acid stereocenter.\",\n      \"reasoning\": \"Demonstrated by Patel et al. (2015, Nature Chemistry, DOI: 10.1038/nchem.2202) as step 5 of their valine synthesis. The amination converts 2-hydroxy-3-methylbutanenitrile to 2-amino-3-methylbutanenitrile, the direct aminonitrile precursor of valine. This is thermodynamically favorable under the mildly acidic to neutral conditions of cyanosulfidic pools.\"\n    },\n    {\n      \"id\": \"rxn_012\",\n      \"name\": \"Nitrile hydrolysis of aminonitrile to L-valine (C5 route)\",\n      \"inputs\": [\"mol_016\", \"mol_003\"],\n      \"outputs\": [\"mol_024\", \"mol_006\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite clay surface\",\n        \"aqueous\": true,\n        \"other\": \"Wet-dry cycling may promote hydrolysis; mildly acidic to neutral pH\"\n      },\n      \"mechanism\": \"Stepwise hydrolysis of the C\u2261N triple bond. Water attacks the electrophilic nitrile carbon, forming a tetrahedral intermediate that rearranges to an amide (2-amino-3-methylbutanamide). A second equivalent of water hydrolyzes the amide to the free carboxylic acid with release of ammonia. The net transformation is: aminonitrile + 2 H2O \u2192 amino acid + NH3.\",\n      \"reasoning\": \"Demonstrated by Patel et al. (2015, Nature Chemistry, DOI: 10.1038/nchem.2202) as the final step (step 6) of their valine synthesis Pathway 1. Nitrile hydrolysis to carboxylic acid is the terminal Strecker step, converting 2-amino-3-methylbutanenitrile to L-valine. This is thermodynamically favorable and kinetically accessible under aqueous surface conditions. Clay minerals may catalyze the hydrolysis.\"\n    },\n    {\n      \"id\": \"rxn_013\",\n      \"name\": \"Fischer-Tropsch-type synthesis of isobutyraldehyde\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_017\", \"mol_003\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe3O4)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"400-500K\",\n        \"pressure\": \"high (100-300 bar)\",\n        \"catalyst\": \"magnetite and mackinawite\",\n        \"aqueous\": true,\n        \"other\": \"Hydrothermal vent conditions; CO2 reduced to CO on mineral surface then chain-extended to branched C4 aldehyde\"\n      },\n      \"mechanism\": \"CO2 is reduced stepwise on magnetite surfaces: CO2 \u2192 CO \u2192 surface-bound CHx intermediates that undergo chain growth via CO insertion and hydrogenation. Branching occurs through secondary CO insertion at internal carbons. The C4 branched aldehyde isobutyraldehyde is released from the mineral surface.\",\n      \"reasoning\": \"Fischer-Tropsch-type synthesis produces a range of hydrocarbons, aldehydes, and alcohols including branched products on magnetite and other iron minerals under hydrothermal conditions (McCollom et al., 1999; Rushdi & Simoneit, 2001). Branched-chain aldehydes like isobutyraldehyde are minor but documented products of FTT synthesis. This provides a hydrothermal feedstock for the Strecker route to valine that bypasses the cyanosulfidic sugar pathway.\"\n    },\n    {\n      \"id\": \"rxn_014\",\n      \"name\": \"Fischer-Tropsch-type synthesis of 3-methylbutanal\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_018\", \"mol_003\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe3O4)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"400-500K\",\n        \"pressure\": \"high (100-300 bar)\",\n        \"catalyst\": \"magnetite and mackinawite\",\n        \"aqueous\": true,\n        \"other\": \"Hydrothermal vent conditions; longer chain FTT product; branched C5 aldehyde\"\n      },\n      \"mechanism\": \"FTT chain growth on magnetite surface produces a C5 branched aldehyde (3-methylbutanal/isovaleraldehyde) via CO insertion, methyl branching, and chain termination by hydrogenation to the aldehyde. Branching arises from secondary carbon insertion.\",\n      \"reasoning\": \"FTT synthesis produces distributions of linear and branched oxygenates including C5 aldehydes (McCollom et al., 1999; Rushdi & Simoneit, 2001). 3-Methylbutanal is the required aldehyde precursor for the C6 aminonitrile pathway described in Patel et al. (2015) Pathway 2. This provides a direct hydrothermal feedstock for the alternative Strecker route.\"\n    },\n    {\n      \"id\": \"rxn_015\",\n      \"name\": \"Strecker synthesis from isobutyraldehyde\",\n      \"inputs\": [\"mol_017\", \"mol_004\", \"mol_006\"],\n      \"outputs\": [\"mol_016\", \"mol_003\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"TiO2 (anatase)\"],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite clay\",\n        \"aqueous\": true,\n        \"other\": \"Classic Strecker conditions in surface pool; aldehyde + NH3 + HCN; clay concentrates reactants\"\n      },\n      \"mechanism\": \"Three-component Strecker synthesis: (1) NH3 condenses with isobutyraldehyde to form an imine (Schiff base) with loss of water; (2) HCN (as CN-) attacks the electrophilic imine carbon; (3) the resulting alpha-aminonitrile (2-amino-3-methylbutanenitrile) is the direct Strecker product. The branched isopropyl group of isobutyraldehyde is preserved intact.\",\n      \"reasoning\": \"The Strecker synthesis is one of the oldest and most robust prebiotic amino acid synthesis routes (Strecker, 1850; Miller, 1953). Production of valine's aminonitrile precursor from isobutyraldehyde + HCN + NH3 is a textbook example of Strecker chemistry. This provides an independent route to the same aminonitrile (mol_016) produced by the Patel et al. (2015) cyanosulfidic pathway, creating a key convergence point in the network.\"\n    },\n    {\n      \"id\": \"rxn_016\",\n      \"name\": \"Strecker synthesis from 3-methylbutanal to C6 aminonitrile\",\n      \"inputs\": [\"mol_018\", \"mol_004\", \"mol_006\"],\n      \"outputs\": [\"mol_019\", \"mol_003\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"TiO2 (anatase)\"],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite clay\",\n        \"aqueous\": true,\n        \"other\": \"Classic Strecker conditions; imine formation then cyanide addition\"\n      },\n      \"mechanism\": \"Three-component Strecker synthesis: (1) NH3 condenses with 3-methylbutanal to form imine; (2) CN- attacks electrophilic imine carbon to form 2-amino-4-methylpentanenitrile. The isobutyl branch is preserved from the aldehyde substrate.\",\n      \"reasoning\": \"Standard Strecker synthesis extended to a C5 branched aldehyde substrate. This provides the production reaction for the C6 aminonitrile (2-amino-4-methylpentanenitrile) that was identified as missing in previous attempts. Patel et al. (2015) describe this C6 aminonitrile as an alternative valine precursor via hydrolysis with chain shortening.\"\n    },\n    {\n      \"id\": \"rxn_017\",\n      \"name\": \"Hydrolysis of C6 aminonitrile to valine (with chain shortening)\",\n      \"inputs\": [\"mol_019\", \"mol_003\"],\n      \"outputs\": [\"mol_024\", \"mol_006\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite clay surface\",\n        \"aqueous\": true,\n        \"other\": \"Extended hydrolysis with apparent C6 \u2192 C5 chain shortening; mechanism debated\"\n      },\n      \"mechanism\": \"Hydrolysis of the nitrile group of the C6 aminonitrile with concomitant loss of one carbon. The nitrile is first hydrolyzed to an amide, then to the carboxylic acid. The chain shortening from C6 to C5 may proceed via retro-aldol cleavage, decarboxylation, or oxidative decarboxylation under surface conditions. The precise mechanism is an acknowledged open question.\",\n      \"reasoning\": \"Reported by Patel et al. (2015, Nature Chemistry, DOI: 10.1038/nchem.2202) as Pathway 2 for valine synthesis. The authors observed conversion of 2-amino-4-methylpentanenitrile to valine with apparent loss of one carbon during the hydrolysis process. The mechanism of chain shortening remains under active investigation (acknowledged as open question 6 in the literature). Despite mechanistic uncertainty, the net transformation is experimentally verified.\"\n    },\n    {\n      \"id\": \"rxn_018\",\n      \"name\": \"CO2 reduction to pyruvate on greigite\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_020\", \"mol_003\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe3S4)\", \"magnetite (Fe3O4)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high (50-200 bar)\",\n        \"catalyst\": \"greigite (Fe3S4)\",\n        \"aqueous\": true,\n        \"other\": \"Alkaline hydrothermal vent conditions; H2 from serpentinization; sequential CO2 fixation\"\n      },\n      \"mechanism\": \"Sequential CO2 reduction on greigite surface: CO2 \u2192 formate \u2192 formaldehyde \u2192 acetaldehyde \u2192 pyruvate via surface-catalyzed chain growth and oxidative functionalization. The Fe4S4 cluster analog in greigite provides the electron transfer capability for each reduction step. Pyruvate is a thermodynamic minimum in the C3 alpha-keto acid series.\",\n      \"reasoning\": \"CO2 reduction to pyruvate on greigite and related Fe-S minerals has been demonstrated by Cody et al. (2000, Science) and Varma et al. (2018, PNAS). Greigite (Fe3S4) is structurally analogous to biological [Fe4S4] clusters and catalyzes CO2 fixation. Pyruvate is a central hub in both modern metabolism and prebiotic chemistry, serving here as the entry point to the hydrothermal alpha-keto acid route to valine.\"\n    },\n    {\n      \"id\": \"rxn_019\",\n      \"name\": \"Pyruvate condensation to acetolactate\",\n      \"inputs\": [\"mol_020\", \"mol_020\"],\n      \"outputs\": [\"mol_025\", \"mol_001\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"pyrite (FeS2)\", \"greigite (Fe3S4)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high (50-200 bar)\",\n        \"catalyst\": \"pyrite surface\",\n        \"aqueous\": true,\n        \"other\": \"ThDP-independent condensation; mineral-catalyzed carboligation; CO2 released as byproduct\"\n      },\n      \"mechanism\": \"Two molecules of pyruvate undergo mineral-catalyzed condensation on iron-sulfide surfaces. One pyruvate acts as nucleophile (via enolization or surface activation) and attacks the carbonyl of the second pyruvate, with concomitant decarboxylation of one unit. The product is 2-acetolactate (2-hydroxy-2-methyl-3-oxobutanoic acid). In modern biochemistry this reaction requires thiamine diphosphate (ThDP); in the prebiotic context, iron-sulfide mineral surfaces may substitute as the electron-withdrawing activator.\",\n      \"reasoning\": \"Pyruvate self-condensation to acetolactate mirrors the first step of biological valine biosynthesis (acetolactate synthase). Weber (2001, Origins of Life and Evolution of Biospheres) demonstrated that alpha-keto acids undergo condensation reactions on iron-sulfide mineral surfaces under hydrothermal conditions. This reaction is speculative for the specific acetolactate product but represents a plausible mineral-catalyzed carboligation extending the established reactivity of pyruvate on FeS surfaces.\"\n    },\n    {\n      \"id\": \"rxn_020\",\n      \"name\": \"Acetolactate rearrangement and reduction to alpha-ketoisovalerate\",\n      \"inputs\": [\"mol_025\", \"mol_002\"],\n      \"outputs\": [\"mol_021\", \"mol_003\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe3S4)\", \"elemental iron (Fe0)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high (50-200 bar)\",\n        \"catalyst\": \"greigite + Fe0 reductant\",\n        \"aqueous\": true,\n        \"other\": \"Sequential isomerization (alkyl migration) and reduction on iron mineral surfaces; H2 as reductant\"\n      },\n      \"mechanism\": \"Acetolactate undergoes isomerization via 1,2-alkyl migration (methyl group shifts from C3 to C2) followed by reduction of the resulting 3-hydroxy-3-methyl-2-oxobutanoic acid intermediate to alpha-ketoisovalerate (3-methyl-2-oxobutanoic acid). Fe0 provides reducing electrons and greigite catalyzes the rearrangement. In biology this requires acetohydroxy acid isomeroreductase; here, hydrothermal conditions and iron mineral surfaces provide the driving force.\",\n      \"reasoning\": \"This is the most speculative reaction in the network, as acknowledged by previous feedback. In biology, this conversion requires the enzyme acetohydroxy acid isomeroreductase. The prebiotic analog is not fully established, but thermal rearrangements of alpha-hydroxy-alpha-keto acids on mineral surfaces at hydrothermal temperatures are plausible. Iron minerals provide both Lewis acid catalysis for alkyl migration and reducing equivalents for the reduction step. Included because alpha-ketoisovalerate is a critical convergence hub enabling the reductive amination and transamination routes to valine.\"\n    },\n    {\n      \"id\": \"rxn_021\",\n      \"name\": \"Reductive amination of alpha-ketoisovalerate to valine\",\n      \"inputs\": [\"mol_021\", \"mol_006\", \"mol_002\"],\n      \"outputs\": [\"mol_024\", \"mol_003\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe3S4)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high (50-200 bar)\",\n        \"catalyst\": \"greigite\",\n        \"aqueous\": true,\n        \"other\": \"NH3 and H2 from hydrothermal vent fluid; mineral-catalyzed reductive amination\"\n      },\n      \"mechanism\": \"NH3 condenses with the C2 keto group of alpha-ketoisovalerate to form an imine (Schiff base). The imine is then reduced by H2 (activated on the greigite surface) to form the amine, yielding valine. The Fe-S mineral surface serves as both the Lewis acid catalyst for imine formation and the hydrogenation catalyst for imine reduction.\",\n      \"reasoning\": \"Reductive amination of alpha-keto acids to amino acids on iron-sulfur mineral surfaces is documented by Huber & Wachtershauser (2006, Chemistry & Biology) and Wang et al. (2005). This is the reverse of biological transamination and represents a direct, single-step conversion of the alpha-keto acid to the amino acid under hydrothermal conditions with abundant NH3 and H2.\"\n    },\n    {\n      \"id\": \"rxn_022\",\n      \"name\": \"Reductive amination of pyruvate to alanine\",\n      \"inputs\": [\"mol_020\", \"mol_006\", \"mol_002\"],\n      \"outputs\": [\"mol_023\", \"mol_003\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"mackinawite (FeS)\", \"greigite (Fe3S4)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high (50-200 bar)\",\n        \"catalyst\": \"mackinawite (FeS)\",\n        \"aqueous\": true,\n        \"other\": \"NH3 from hydrothermal fluid; H2 from serpentinization\"\n      },\n      \"mechanism\": \"NH3 condenses with the keto group of pyruvate to form an imine, which is reduced by H2 on the FeS mineral surface to form alanine. This is the prototypical hydrothermal reductive amination reaction.\",\n      \"reasoning\": \"Reductive amination of pyruvate to alanine on FeS surfaces is one of the best-demonstrated hydrothermal amino acid synthesis routes (Huber & Wachtershauser, 2006). Alanine serves as the amino group donor for the transamination route to valine (rxn_023), providing the biochemical-stage connection.\"\n    },\n    {\n      \"id\": \"rxn_023\",\n      \"name\": \"Transamination: alanine + alpha-ketoisovalerate to valine + pyruvate\",\n      \"inputs\": [\"mol_023\", \"mol_021\"],\n      \"outputs\": [\"mol_024\", \"mol_020\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"pyridoxal (or metal ion catalysis)\",\n        \"aqueous\": true,\n        \"other\": \"Proto-metabolic transamination in prebiotic pool; may require pyridoxal analog or metal ion catalysis\"\n      },\n      \"mechanism\": \"Transamination between alanine and alpha-ketoisovalerate: the amino group of alanine is transferred to the keto group of alpha-ketoisovalerate via a Schiff base intermediate, yielding valine and regenerating pyruvate. In biology this requires pyridoxal phosphate (PLP); prebiotically, metal ions (Cu2+, Fe2+) or simple pyridoxal analogs can catalyze the same transformation.\",\n      \"reasoning\": \"Transamination is a fundamental proto-metabolic reaction that interconverts amino acids and alpha-keto acids. Metal-catalyzed transamination has been demonstrated prebiotically (Zabinski & Testa, 2002; Metzler et al., 1954). This reaction provides the biochemical-environment route to valine and creates a catalytic loop: pyruvate is consumed by rxn_019 and regenerated by rxn_023, potentially enabling autocatalytic amplification.\"\n    },\n    {\n      \"id\": \"rxn_024\",\n      \"name\": \"Decarboxylation of alpha-ketoisovalerate to isobutyraldehyde\",\n      \"inputs\": [\"mol_021\"],\n      \"outputs\": [\"mol_017\", \"mol_001\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase)\", \"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"320-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO2 photocatalyst or thermal\",\n        \"aqueous\": true,\n        \"other\": \"Thermal or UV-assisted decarboxylation in surface pool; alpha-keto acids decarboxylate readily\"\n      },\n      \"mechanism\": \"Oxidative or simple thermal decarboxylation of alpha-ketoisovalerate. The alpha-keto acid loses CO2 from the carboxyl group adjacent to the keto group, yielding the corresponding aldehyde (isobutyraldehyde). Alpha-keto acids are well-known to undergo facile decarboxylation due to stabilization of the transition state by the adjacent carbonyl.\",\n      \"reasoning\": \"Thermal decarboxylation of alpha-keto acids is well-documented and occurs readily at moderate temperatures (Cooper et al., 2011). This reaction connects the hydrothermal alpha-keto acid pathway to the surface Strecker route by producing isobutyraldehyde, which can then undergo Strecker synthesis (rxn_015) to reach valine. This creates a critical bridge between the hydrothermal and surface environments.\"\n    }\n  ],\n  \"pathways\": [\n    {\n      \"pathway_id\": \"P1\",\n      \"name\": \"Full hydrothermal-to-surface: CO2 \u2192 formaldehyde \u2192 DHA \u2192 acetone \u2192 cyanosulfidic \u2192 valine\",\n      \"description\": \"Complete pathway from hydrothermal CO2 through FTT formaldehyde, formose sugar chemistry to DHA, then cyanosulfidic reductive deoxygenation to acetone, and full Patel et al. (2015) cyanosulfidic chain to valine.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_003\", \"rxn_004\", \"rxn_006\", \"rxn_008\", \"rxn_009\", \"rxn_010\", \"rxn_011\", \"rxn_012\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_008\", \"mol_009\", \"mol_012\", \"mol_015\", \"mol_016\"]\n    },\n    {\n      \"pathway_id\": \"P2\",\n      \"name\": \"Full hydrothermal-to-surface: CO2 \u2192 formaldehyde \u2192 DHA \u2192 hydroxyacetone \u2192 acetone \u2192 cyanosulfidic \u2192 valine\",\n      \"description\": \"Alternative route through hydroxyacetone as partial reduction intermediate of DHA, then reductive deoxygenation to acetone, followed by the cyanosulfidic chain.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_003\", \"rxn_004\", \"rxn_005\", \"rxn_007\", \"rxn_008\", \"rxn_009\", \"rxn_010\", \"rxn_011\", \"rxn_012\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_009\", \"mol_010\", \"mol_012\", \"mol_016\"]\n    },\n    {\n      \"pathway_id\": \"P3\",\n      \"name\": \"Core cyanosulfidic Pathway 1: DHA \u2192 acetone \u2192 cyanosulfidic \u2192 valine\",\n      \"description\": \"The experimentally demonstrated Pathway 1 of Patel et al. (2015): dihydroxyacetone undergoes Cu/H2S reductive deoxygenation to acetone, then cyanohydrin formation, thioamide conversion, reductive chain extension, amination, and nitrile hydrolysis to valine.\",\n      \"reaction_sequence\": [\"rxn_006\", \"rxn_008\", \"rxn_009\", \"rxn_010\", \"rxn_011\", \"rxn_012\"],\n      \"key_intermediates\": [\"mol_012\", \"mol_013\", \"mol_014\", \"mol_015\", \"mol_016\"]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"Core cyanosulfidic Pathway 2: hydroxyacetone \u2192 acetone \u2192 cyanosulfidic \u2192 valine\",\n      \"description\": \"The experimentally demonstrated Pathway 2 of Patel et al. (2015): hydroxyacetone undergoes Cu/H2S reductive deoxygenation to acetone, then the same downstream cyanosulfidic sequence to valine.\",\n      \"reaction_sequence\": [\"rxn_007\", \"rxn_008\", \"rxn_009\", \"rxn_010\", \"rxn_011\", \"rxn_012\"],\n      \"key_intermediates\": [\"mol_012\", \"mol_013\", \"mol_014\", \"mol_015\", \"mol_016\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"FTT isobutyraldehyde \u2192 Strecker \u2192 valine\",\n      \"description\": \"Hydrothermal FTT synthesis produces isobutyraldehyde, which undergoes surface Strecker synthesis with HCN and NH3 to form the aminonitrile, followed by hydrolysis to valine. Bypasses the cyanosulfidic sugar pathway entirely.\",\n      \"reaction_sequence\": [\"rxn_013\", \"rxn_015\", \"rxn_012\"],\n      \"key_intermediates\": [\"mol_017\", \"mol_016\"]\n    },\n    {\n      \"pathway_id\": \"P6\",\n      \"name\": \"FTT 3-methylbutanal \u2192 C6 aminonitrile \u2192 valine (chain shortening)\",\n      \"description\": \"Hydrothermal FTT synthesis produces 3-methylbutanal (isovaleraldehyde), which undergoes surface Strecker synthesis to the C6 aminonitrile, followed by hydrolysis with chain shortening to valine.\",\n      \"reaction_sequence\": [\"rxn_014\", \"rxn_016\", \"rxn_017\"],\n      \"key_intermediates\": [\"mol_018\", \"mol_019\"]\n    },\n    {\n      \"pathway_id\": \"P7\",\n      \"name\": \"Hydrothermal pyruvate \u2192 acetolactate \u2192 alpha-ketoisovalerate \u2192 reductive amination \u2192 valine\",\n      \"description\": \"Hydrothermal CO2 fixation produces pyruvate, which self-condenses to acetolactate, rearranges to alpha-ketoisovalerate, and undergoes reductive amination to valine. Mirrors the biological valine biosynthesis pathway.\",\n      \"reaction_sequence\": [\"rxn_018\", \"rxn_019\", \"rxn_020\", \"rxn_021\"],\n      \"key_intermediates\": [\"mol_020\", \"mol_025\", \"mol_021\"]\n    },\n    {\n      \"pathway_id\": \"P8\",\n      \"name\": \"Hydrothermal alpha-ketoisovalerate \u2192 isobutyraldehyde \u2192 Strecker \u2192 valine\",\n      \"description\": \"Alpha-ketoisovalerate produced hydrothermally undergoes decarboxylation to isobutyraldehyde on the surface, then Strecker synthesis produces the aminonitrile, which hydrolyzes to valine. Bridges hydrothermal keto acid chemistry with surface Strecker chemistry.\",\n      \"reaction_sequence\": [\"rxn_018\", \"rxn_019\", \"rxn_020\", \"rxn_024\", \"rxn_015\", \"rxn_012\"],\n      \"key_intermediates\": [\"mol_020\", \"mol_021\", \"mol_017\", \"mol_016\"]\n    },\n    {\n      \"pathway_id\": \"P9\",\n      \"name\": \"Transamination route: pyruvate \u2192 alanine + alpha-ketoisovalerate \u2192 valine + pyruvate\",\n      \"description\": \"Pyruvate is reductively aminated to alanine in the hydrothermal environment. Alpha-ketoisovalerate from the pyruvate condensation route undergoes biochemical transamination with alanine, producing valine and regenerating pyruvate in an autocatalytic loop.\",\n      \"reaction_sequence\": [\"rxn_018\", \"rxn_022\", \"rxn_019\", \"rxn_020\", \"rxn_023\"],\n      \"key_intermediates\": [\"mol_020\", \"mol_023\", \"mol_021\"]\n    },\n    {\n      \"pathway_id\": \"P10\",\n      \"name\": \"Full three-environment chain: CO2 \u2192 pyruvate \u2192 alpha-ketoisovalerate \u2192 isobutyraldehyde \u2192 Strecker aminonitrile \u2192 valine\",\n      \"description\": \"Complete Hydrothermal \u2192 Surface \u2192 Surface pathway: hydrothermal CO2 fixation to pyruvate, pyruvate condensation to alpha-ketoisovalerate, surface decarboxylation to isobutyraldehyde, Strecker synthesis to aminonitrile, and hydrolysis to valine. Demonstrates maximum environmental interconnection.\",\n      \"reaction_sequence\": [\"rxn_018\", \"rxn_019\", \"rxn_020\", \"rxn_024\", \"rxn_015\", \"rxn_012\"],\n      \"key_intermediates\": [\"mol_020\", \"mol_025\", \"mol_021\", \"mol_017\", \"mol_016\"]\n    }\n  ],\n  \"hub_molecules\": [\"mol_012\", \"mol_016\", \"mol_020\", \"mol_021\", \"mol_007\"],\n  \"convergence_points\": [\n    {\n      \"molecule_id\": \"mol_012\",\n      \"description\": \"Acetone \u2014 central convergence from two sugar-derived routes (DHA and hydroxyacetone) via Cu/H2S reductive deoxygenation\",\n      \"incoming_reactions\": [\"rxn_006\", \"rxn_007\"],\n      \"outgoing_reactions\": [\"rxn_008\"]\n    },\n    {\n      \"molecule_id\": \"mol_016\",\n      \"description\": \"2-Amino-3-methylbutanenitrile \u2014 key convergence of cyanosulfidic pathway (from acetone) and Strecker synthesis (from isobutyraldehyde); direct aminonitrile precursor of valine\",\n      \"incoming_reactions\": [\"rxn_011\", \"rxn_015\"],\n      \"outgoing_reactions\": [\"rxn_012\"]\n    },\n    {\n      \"molecule_id\": \"mol_020\",\n      \"description\": \"Pyruvate \u2014 hydrothermal hub; produced by CO2 reduction on greigite and regenerated by transamination; consumed by reductive amination to alanine, self-condensation to acetolactate\",\n      \"incoming_reactions\": [\"rxn_018\", \"rxn_023\"],\n      \"outgoing_reactions\": [\"rxn_019\", \"rxn_022\"]\n    },\n    {\n      \"molecule_id\": \"mol_021\",\n      \"description\": \"Alpha-ketoisovalerate \u2014 convergence of pyruvate condensation route; distributes to three downstream reactions: reductive amination, transamination, and decarboxylation\",\n      \"incoming_reactions\": [\"rxn_020\"],\n      \"outgoing_reactions\": [\"rxn_021\", \"rxn_023\", \"rxn_024\"]\n    },\n    {\n      \"molecule_id\": \"mol_007\",\n      \"description\": \"Formaldehyde \u2014 hydrothermal C1 feedstock hub; produced by FTT synthesis; consumed by formose chemistry (glycolaldehyde and glyceraldehyde formation)\",\n      \"incoming_reactions\": [\"rxn_001\"],\n      \"outgoing_reactions\": [\"rxn_002\", \"rxn_003\"]\n    }\n  ]\n}", "parsed_response": {"target_molecule": "L-Valine", "overall_strategy": "This network synthesizes L-valine through 10 distinct pathways spanning three prebiotic environments. The core routes follow the experimentally demonstrated cyanosulfidic protometabolism of Patel et al. (2015), where sugar derivatives (dihydroxyacetone, hydroxyacetone) are reductively deoxygenated to acetone via Cu/H2S, then elaborated through cyanohydrin formation, thioamide conversion, reductive rearrangement, amination, and nitrile hydrolysis. Parallel Strecker synthesis routes from isobutyraldehyde converge on the same aminonitrile intermediate. Hydrothermal Fischer-Tropsch-type synthesis on magnetite provides upstream C1-C4 feedstocks (formaldehyde, isobutyraldehyde, pyruvate), which are elaborated via surface formose chemistry into C3 sugars. A hydrothermal \u03b1-ketoisovalerate branch provides reductive amination and transamination routes to valine in the biochemical stage. Five hub molecules (formaldehyde, acetone, 2-amino-3-methylbutanenitrile, \u03b1-ketoisovalerate, pyruvate) create dense convergence points ensuring network robustness.", "molecules": [{"id": "mol_001", "formula": "CO2", "iupac_name": "carbon dioxide", "common_name": "Carbon dioxide", "inchi": "InChI=1S/CO2/c2-1-3", "role": "starting", "environment_formed": null}, {"id": "mol_002", "formula": "H2", "iupac_name": "molecular hydrogen", "common_name": "Hydrogen", "inchi": "InChI=1S/H2/h1H", "role": "starting", "environment_formed": null}, {"id": "mol_003", "formula": "H2O", "iupac_name": "water", "common_name": "Water", "inchi": "InChI=1S/H2O/h1H2", "role": "starting", "environment_formed": null}, {"id": "mol_004", "formula": "CHN", "iupac_name": "hydrogen cyanide", "common_name": "HCN", "inchi": "InChI=1S/CHN/c1-2/h1H", "role": "starting", "environment_formed": null}, {"id": "mol_005", "formula": "H2S", "iupac_name": "hydrogen sulfide", "common_name": "Hydrogen sulfide", "inchi": "InChI=1S/H2S/h1H2", "role": "starting", "environment_formed": null}, {"id": "mol_006", "formula": "H3N", "iupac_name": "ammonia", "common_name": "Ammonia", "inchi": "InChI=1S/H3N/h1H3", "role": "starting", "environment_formed": null}, {"id": "mol_007", "formula": "CH2O", "iupac_name": "formaldehyde", "common_name": "Formaldehyde", "inchi": "InChI=1S/CH2O/c1-2/h1H2", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_008", "formula": "C2H4O2", "iupac_name": "glycolaldehyde", "common_name": "Glycolaldehyde", "inchi": "InChI=1S/C2H4O2/c3-1-2-4/h1,4H,2H2", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_009", "formula": "C3H6O3", "iupac_name": "1,3-dihydroxypropan-2-one", "common_name": "Dihydroxyacetone", "inchi": "InChI=1S/C3H6O3/c4-1-3(6)2-5/h4-5H,1-2H2", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_010", "formula": "C3H6O2", "iupac_name": "1-hydroxypropan-2-one", "common_name": "Hydroxyacetone", "inchi": "InChI=1S/C3H6O2/c1-3(5)2-4/h4H,2H2,1H3", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_011", "formula": "C3H6O3", "iupac_name": "2,3-dihydroxypropanal", "common_name": "Glyceraldehyde", "inchi": "InChI=1S/C3H6O3/c4-1-2(5)3-6/h1-2,5-6H,3H2", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_012", "formula": "C3H6O", "iupac_name": "propan-2-one", "common_name": "Acetone", "inchi": "InChI=1S/C3H6O/c1-3(2)4/h1-2H3", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_013", "formula": "C4H7NO", "iupac_name": "2-hydroxy-2-methylpropanenitrile", "common_name": "Acetone cyanohydrin", "inchi": "InChI=1S/C4H7NO/c1-4(2,6)3-5/h6H,1-2H3", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_014", "formula": "C4H9NOS", "iupac_name": "2-hydroxy-2-methylpropanethioamide", "common_name": "2-Hydroxy-2-methylpropanethioamide", "inchi": "InChI=1S/C4H9NOS/c1-4(2,6)3(5)7/h6H,1-2H3,(H2,5,7)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_015", "formula": "C5H9NO", "iupac_name": "2-hydroxy-3-methylbutanenitrile", "common_name": "2-Hydroxy-3-methylbutanenitrile", "inchi": "InChI=1S/C5H9NO/c1-4(2)5(7)3-6/h4-5,7H,1-2H3", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_016", "formula": "C5H10N2", "iupac_name": "2-amino-3-methylbutanenitrile", "common_name": "2-Amino-3-methylbutanenitrile", "inchi": "InChI=1S/C5H10N2/c1-4(2)5(7)3-6/h4-5H,7H2,1-2H3", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_017", "formula": "C4H8O", "iupac_name": "2-methylpropanal", "common_name": "Isobutyraldehyde", "inchi": "InChI=1S/C4H8O/c1-3(2)4-5/h3-4H,1-2H3", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_018", "formula": "C5H10O", "iupac_name": "3-methylbutanal", "common_name": "Isovaleraldehyde", "inchi": "InChI=1S/C5H10O/c1-4(2)3-5-6/h4-5H,3H2,1-2H3", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_019", "formula": "C6H12N2", "iupac_name": "2-amino-4-methylpentanenitrile", "common_name": "2-Amino-4-methylpentanenitrile", "inchi": "InChI=1S/C6H12N2/c1-5(2)3-6(8)4-7/h5-6H,3,8H2,1-2H3", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_020", "formula": "C3H4O3", "iupac_name": "2-oxopropanoic acid", "common_name": "Pyruvate", "inchi": "InChI=1S/C3H4O3/c1-2(4)3(5)6/h1H3,(H,5,6)", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_021", "formula": "C5H8O3", "iupac_name": "3-methyl-2-oxobutanoic acid", "common_name": "alpha-Ketoisovalerate", "inchi": "InChI=1S/C5H8O3/c1-3(2)4(6)5(7)8/h3H,1-2H3,(H,7,8)", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_022", "formula": "H2S2", "iupac_name": "disulfane", "common_name": "Disulfane", "inchi": "InChI=1S/H2S2/c1-2/h1-2H", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_023", "formula": "C3H7NO2", "iupac_name": "2-aminopropanoic acid", "common_name": "Alanine", "inchi": "InChI=1S/C3H7NO2/c1-2(5)3(6)7/h2H,5H2,1H3,(H,6,7)", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_024", "formula": "C5H11NO2", "iupac_name": "2-amino-3-methylbutanoic acid", "common_name": "L-Valine", "inchi": "InChI=1S/C5H11NO2/c1-3(2)4(6)5(7)8/h3-4H,6H2,1-2H3,(H,7,8)", "role": "target", "environment_formed": "Surface"}, {"id": "mol_025", "formula": "C5H8O4", "iupac_name": "2-hydroxy-2-methyl-3-oxobutanoic acid", "common_name": "Acetolactate", "inchi": "InChI=1S/C5H8O4/c1-3(7)4(2,8)5(9)10/h8H,1-2H3,(H,9,10)", "role": "intermediate", "environment_formed": "Hydrothermal"}], "reactions": [{"id": "rxn_001", "name": "Fischer-Tropsch-type CO2 reduction to formaldehyde", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_007", "mol_003"], "environment": "Hydrothermal", "agents": ["magnetite (Fe3O4)"], "conditions": {"temperature": "400-500K", "pressure": "high (100-300 bar)", "catalyst": "magnetite (Fe3O4)", "aqueous": true, "other": "Fischer-Tropsch-type synthesis at alkaline hydrothermal vent conditions; CO2 first reduced to CO on magnetite, then to formaldehyde"}, "mechanism": "CO2 is adsorbed on magnetite surface and stepwise hydrogenated via surface-bound CO intermediate to formaldehyde. H2 from serpentinization provides reducing equivalents. The magnetite surface stabilizes the C1 intermediate against further reduction.", "reasoning": "FTT synthesis of formaldehyde from CO2 + H2 on magnetite is documented in hydrothermal experiments (McCollom et al., 1999; Holm & Andersson, 2005). Formaldehyde is the essential C1 feedstock for downstream formose chemistry that produces the C3 sugar precursors of valine. Patel et al. (2015) require sugar-derived feedstocks whose ultimate origin is plausibly hydrothermal."}, {"id": "rxn_002", "name": "Formose reaction: formaldehyde dimerization to glycolaldehyde", "inputs": ["mol_007", "mol_007"], "outputs": ["mol_008"], "environment": "Surface", "agents": ["borate minerals (colemanite)", "montmorillonite"], "conditions": {"temperature": "300-340K", "pressure": "1 atm", "catalyst": "borate minerals, Ca(OH)2", "aqueous": true, "other": "Alkaline conditions (pH 10-11) in evaporitic pools; borate minerals stabilize sugar intermediates"}, "mechanism": "Base-catalyzed aldol condensation of two formaldehyde molecules. Under alkaline conditions, formaldehyde undergoes Cannizzaro-like disproportionation and umpolung to generate a nucleophilic C1 species that attacks a second formaldehyde, yielding the C2 product glycolaldehyde.", "reasoning": "The formose reaction producing glycolaldehyde from formaldehyde is well-established (Breslow, 1959; Ricardo et al., 2004). Borate minerals stabilize sugar intermediates against degradation (Ricardo et al., 2004). This provides the first C2 building block en route to C3 sugar precursors of acetone needed for the Patel et al. (2015) valine pathway."}, {"id": "rxn_003", "name": "Aldol condensation: glycolaldehyde + formaldehyde to glyceraldehyde", "inputs": ["mol_008", "mol_007"], "outputs": ["mol_011"], "environment": "Surface", "agents": ["borate minerals (colemanite)", "montmorillonite"], "conditions": {"temperature": "300-340K", "pressure": "1 atm", "catalyst": "borate minerals", "aqueous": true, "other": "Alkaline evaporitic pool conditions; borate complexation stabilizes glyceraldehyde"}, "mechanism": "Aldol addition of formaldehyde to glycolaldehyde. The glycolaldehyde enolate attacks the electrophilic carbonyl of formaldehyde, forming a C-C bond to yield the C3 aldose glyceraldehyde.", "reasoning": "Classical formose chemistry step documented by Butlerow (1861) and extensively characterized by Breslow (1959). Borate minerals stabilize the glyceraldehyde product against retro-aldol and Lobry de Bruyn-van Ekenstein degradation (Ricardo et al., 2004). This connects C1 hydrothermal feedstock to C3 sugar precursors needed by Patel et al. (2015)."}, {"id": "rxn_004", "name": "Glyceraldehyde-dihydroxyacetone isomerization", "inputs": ["mol_011"], "outputs": ["mol_009"], "environment": "Surface", "agents": ["montmorillonite"], "conditions": {"temperature": "300-340K", "pressure": "1 atm", "catalyst": "montmorillonite clay", "aqueous": true, "other": "Lobry de Bruyn-van Ekenstein isomerization on clay surface; mildly alkaline aqueous conditions"}, "mechanism": "Keto-enol tautomerization via 1,2-enediol intermediate. Glyceraldehyde (aldose) equilibrates with dihydroxyacetone (ketose) through reversible proton transfers catalyzed by clay mineral surfaces acting as mild base catalysts.", "reasoning": "The glyceraldehyde \u21cc dihydroxyacetone isomerization is a well-known Lobry de Bruyn-van Ekenstein transformation. Clay minerals such as montmorillonite catalyze this tautomerization (Pestunova et al., 2005). DHA is the required substrate for Pathway 1 of the Patel et al. (2015) cyanosulfidic valine synthesis."}, {"id": "rxn_005", "name": "Partial reductive deoxygenation of DHA to hydroxyacetone", "inputs": ["mol_009", "mol_005"], "outputs": ["mol_010", "mol_003"], "environment": "Surface", "agents": ["elemental copper (Cu0)", "sulfide minerals (stibnite)"], "conditions": {"temperature": "300-340K", "pressure": "1 atm", "catalyst": "Cu0 and H2S", "aqueous": true, "other": "Cyanosulfidic conditions in surface evaporitic pools; partial reduction stops at monohydroxy stage"}, "mechanism": "Copper acts as a single-electron reductant in concert with H2S to selectively remove one hydroxymethyl oxygen from DHA. The Cu0/H2S system strips one hydroxyl via a radical or polar mechanism, yielding the partially reduced product hydroxyacetone (acetol). This is the first step of the full reductive deoxygenation cascade.", "reasoning": "Patel et al. (2015) demonstrated Cu/H2S-mediated reductive deoxygenation of sugar derivatives. The DHA \u2192 acetone conversion proceeds through hydroxyacetone as a logical partial intermediate, providing the substrate for Pathway 2 of the valine synthesis. The Cu/H2S system is the essential reductive agent in the cyanosulfidic framework."}, {"id": "rxn_006", "name": "Reductive deoxygenation of DHA to acetone (full)", "inputs": ["mol_009", "mol_005"], "outputs": ["mol_012", "mol_003"], "environment": "Surface", "agents": ["elemental copper (Cu0)", "sulfide minerals (stibnite)"], "conditions": {"temperature": "300-340K", "pressure": "1 atm", "catalyst": "Cu0 and H2S", "aqueous": true, "other": "Cyanosulfidic surface pool; extended reaction time allows full deoxygenation; Cu is essential single-electron reductant"}, "mechanism": "Cu0/H2S-mediated reductive removal of both hydroxyl groups from dihydroxyacetone. Copper provides single electrons for sequential C-O bond cleavage while H2S provides additional reducing equivalents. Both hydroxymethyl oxygens are stripped to yield the simple ketone acetone and water.", "reasoning": "Directly demonstrated by Patel, Percivalle, Ritson, Duffy, and Sutherland (2015, Nature Chemistry, DOI: 10.1038/nchem.2202). This is the first step of their experimentally validated Pathway 1 for valine synthesis. DHA \u2192 acetone is the key sugar-to-ketone conversion that initiates the cyanosulfidic route to branched-chain amino acids. Cu0 is essential as verified experimentally."}, {"id": "rxn_007", "name": "Reductive deoxygenation of hydroxyacetone to acetone", "inputs": ["mol_010", "mol_005"], "outputs": ["mol_012", "mol_003"], "environment": "Surface", "agents": ["elemental copper (Cu0)", "sulfide minerals (stibnite)"], "conditions": {"temperature": "300-340K", "pressure": "1 atm", "catalyst": "Cu0 and H2S", "aqueous": true, "other": "Cyanosulfidic surface pool; Cu0/H2S system removes hydroxyl"}, "mechanism": "Cu0/H2S-mediated reductive removal of the single hydroxyl group from hydroxyacetone (acetol). Copper provides electron for C-O bond cleavage while H2S acts as co-reductant, yielding acetone and water.", "reasoning": "Directly demonstrated by Patel et al. (2015, Nature Chemistry, DOI: 10.1038/nchem.2202). This is the upstream step of their experimentally validated Pathway 2 for valine synthesis. Hydroxyacetone provides an alternative entry to the same acetone hub as DHA, establishing convergence at the acetone node. Cu0 is explicitly required."}, {"id": "rxn_008", "name": "Cyanohydrin formation: acetone + HCN", "inputs": ["mol_012", "mol_004"], "outputs": ["mol_013"], "environment": "Surface", "agents": ["montmorillonite"], "conditions": {"temperature": "300-340K", "pressure": "1 atm", "catalyst": "mildly basic aqueous conditions", "aqueous": true, "other": "Cyanosulfidic surface pool; HCN available from atmospheric/volcanic sources; clay surfaces concentrate reactants"}, "mechanism": "Nucleophilic addition of cyanide (CN-) to the electrophilic carbonyl carbon of acetone. Under mildly basic conditions, HCN deprotonates to CN-, which attacks the ketone carbonyl. Protonation of the resulting alkoxide yields the tertiary cyanohydrin (acetone cyanohydrin). This is a classic Kiliani-type reaction on a ketone substrate.", "reasoning": "Demonstrated by Patel et al. (2015, Nature Chemistry, DOI: 10.1038/nchem.2202) as step 2 of their valine synthesis pathway. Cyanohydrin formation from ketones is a well-established reaction in organic chemistry. The symmetrical dimethyl substitution of acetone gives a single tertiary cyanohydrin product, initiating the C-C bond extension needed for the valine skeleton."}, {"id": "rxn_009", "name": "Thioamide formation: nitrile + H2S", "inputs": ["mol_013", "mol_005"], "outputs": ["mol_014"], "environment": "Surface", "agents": ["sulfide minerals (stibnite)"], "conditions": {"temperature": "300-340K", "pressure": "1 atm", "catalyst": "H2S as reagent", "aqueous": true, "other": "Cyanosulfidic pool; H2S acts as both nucleophile and sulfur source"}, "mechanism": "Nucleophilic addition of H2S across the C\u2261N triple bond of the cyanohydrin nitrile. Sulfur attacks the electrophilic nitrile carbon, forming a C-S bond. Proton transfer completes conversion of the nitrile to a primary thioamide (C(=S)NH2). This activates the nitrile for subsequent reductive rearrangement.", "reasoning": "Demonstrated by Patel et al. (2015, Nature Chemistry, DOI: 10.1038/nchem.2202) as step 3 of their valine synthesis. The conversion of nitriles to thioamides by H2S is a defining feature of cyanosulfidic chemistry. The thioamide is the key activated intermediate that enables the subsequent Cu-mediated reductive chain extension step."}, {"id": "rxn_010", "name": "Reductive rearrangement and chain extension (Cu/H2S-mediated)", "inputs": ["mol_014", "mol_004", "mol_005"], "outputs": ["mol_015", "mol_022"], "environment": "Surface", "agents": ["elemental copper (Cu0)", "sulfide minerals (stibnite)"], "conditions": {"temperature": "300-340K", "pressure": "1 atm", "catalyst": "Cu0 and H2S", "aqueous": true, "other": "Cyanosulfidic pool; Cu0 essential for single-electron reduction; H2S co-reductant and sulfur source; HCN provides new carbon unit"}, "mechanism": "Complex Cu0/H2S-mediated reductive rearrangement incorporating a second HCN unit. The thioamide undergoes reductive cleavage mediated by copper single-electron transfer. The thioamide nitrogen is lost, the sulfur acts as a leaving group (oxidized to disulfane, H2S2), and a new C-C bond is formed with the incoming HCN carbon. This builds the branched C5 skeleton: the C4 thioamide is extended to a C5 alpha-hydroxynitrile with the isopropyl branch of valine established.", "reasoning": "Demonstrated by Patel et al. (2015, Nature Chemistry, DOI: 10.1038/nchem.2202) as step 4 of their valine synthesis. This is the critical C-C bond-forming step that builds the branched-chain architecture unique to valine. Cu0 is explicitly essential as a single-electron reductant. The detailed radical mechanism remains under active investigation (acknowledged as an open question by the authors), but the net transformation is experimentally verified."}, {"id": "rxn_011", "name": "Strecker-type amination of hydroxynitrile", "inputs": ["mol_015", "mol_006"], "outputs": ["mol_016", "mol_003"], "environment": "Surface", "agents": ["montmorillonite"], "conditions": {"temperature": "300-340K", "pressure": "1 atm", "catalyst": "montmorillonite clay", "aqueous": true, "other": "Cyanosulfidic pool; NH3 from volcanic/atmospheric sources"}, "mechanism": "Nucleophilic substitution of the alpha-hydroxyl group by ammonia. NH3 displaces the OH at the alpha-carbon adjacent to the nitrile group, converting the alpha-hydroxynitrile to the corresponding alpha-aminonitrile. This is a classic Strecker-type amination \u2014 the key step that introduces the amino group at the position that will become the amino acid stereocenter.", "reasoning": "Demonstrated by Patel et al. (2015, Nature Chemistry, DOI: 10.1038/nchem.2202) as step 5 of their valine synthesis. The amination converts 2-hydroxy-3-methylbutanenitrile to 2-amino-3-methylbutanenitrile, the direct aminonitrile precursor of valine. This is thermodynamically favorable under the mildly acidic to neutral conditions of cyanosulfidic pools."}, {"id": "rxn_012", "name": "Nitrile hydrolysis of aminonitrile to L-valine (C5 route)", "inputs": ["mol_016", "mol_003"], "outputs": ["mol_024", "mol_006"], "environment": "Surface", "agents": ["montmorillonite"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "montmorillonite clay surface", "aqueous": true, "other": "Wet-dry cycling may promote hydrolysis; mildly acidic to neutral pH"}, "mechanism": "Stepwise hydrolysis of the C\u2261N triple bond. Water attacks the electrophilic nitrile carbon, forming a tetrahedral intermediate that rearranges to an amide (2-amino-3-methylbutanamide). A second equivalent of water hydrolyzes the amide to the free carboxylic acid with release of ammonia. The net transformation is: aminonitrile + 2 H2O \u2192 amino acid + NH3.", "reasoning": "Demonstrated by Patel et al. (2015, Nature Chemistry, DOI: 10.1038/nchem.2202) as the final step (step 6) of their valine synthesis Pathway 1. Nitrile hydrolysis to carboxylic acid is the terminal Strecker step, converting 2-amino-3-methylbutanenitrile to L-valine. This is thermodynamically favorable and kinetically accessible under aqueous surface conditions. Clay minerals may catalyze the hydrolysis."}, {"id": "rxn_013", "name": "Fischer-Tropsch-type synthesis of isobutyraldehyde", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_017", "mol_003"], "environment": "Hydrothermal", "agents": ["magnetite (Fe3O4)", "mackinawite (FeS)"], "conditions": {"temperature": "400-500K", "pressure": "high (100-300 bar)", "catalyst": "magnetite and mackinawite", "aqueous": true, "other": "Hydrothermal vent conditions; CO2 reduced to CO on mineral surface then chain-extended to branched C4 aldehyde"}, "mechanism": "CO2 is reduced stepwise on magnetite surfaces: CO2 \u2192 CO \u2192 surface-bound CHx intermediates that undergo chain growth via CO insertion and hydrogenation. Branching occurs through secondary CO insertion at internal carbons. The C4 branched aldehyde isobutyraldehyde is released from the mineral surface.", "reasoning": "Fischer-Tropsch-type synthesis produces a range of hydrocarbons, aldehydes, and alcohols including branched products on magnetite and other iron minerals under hydrothermal conditions (McCollom et al., 1999; Rushdi & Simoneit, 2001). Branched-chain aldehydes like isobutyraldehyde are minor but documented products of FTT synthesis. This provides a hydrothermal feedstock for the Strecker route to valine that bypasses the cyanosulfidic sugar pathway."}, {"id": "rxn_014", "name": "Fischer-Tropsch-type synthesis of 3-methylbutanal", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_018", "mol_003"], "environment": "Hydrothermal", "agents": ["magnetite (Fe3O4)", "mackinawite (FeS)"], "conditions": {"temperature": "400-500K", "pressure": "high (100-300 bar)", "catalyst": "magnetite and mackinawite", "aqueous": true, "other": "Hydrothermal vent conditions; longer chain FTT product; branched C5 aldehyde"}, "mechanism": "FTT chain growth on magnetite surface produces a C5 branched aldehyde (3-methylbutanal/isovaleraldehyde) via CO insertion, methyl branching, and chain termination by hydrogenation to the aldehyde. Branching arises from secondary carbon insertion.", "reasoning": "FTT synthesis produces distributions of linear and branched oxygenates including C5 aldehydes (McCollom et al., 1999; Rushdi & Simoneit, 2001). 3-Methylbutanal is the required aldehyde precursor for the C6 aminonitrile pathway described in Patel et al. (2015) Pathway 2. This provides a direct hydrothermal feedstock for the alternative Strecker route."}, {"id": "rxn_015", "name": "Strecker synthesis from isobutyraldehyde", "inputs": ["mol_017", "mol_004", "mol_006"], "outputs": ["mol_016", "mol_003"], "environment": "Surface", "agents": ["montmorillonite", "TiO2 (anatase)"], "conditions": {"temperature": "300-340K", "pressure": "1 atm", "catalyst": "montmorillonite clay", "aqueous": true, "other": "Classic Strecker conditions in surface pool; aldehyde + NH3 + HCN; clay concentrates reactants"}, "mechanism": "Three-component Strecker synthesis: (1) NH3 condenses with isobutyraldehyde to form an imine (Schiff base) with loss of water; (2) HCN (as CN-) attacks the electrophilic imine carbon; (3) the resulting alpha-aminonitrile (2-amino-3-methylbutanenitrile) is the direct Strecker product. The branched isopropyl group of isobutyraldehyde is preserved intact.", "reasoning": "The Strecker synthesis is one of the oldest and most robust prebiotic amino acid synthesis routes (Strecker, 1850; Miller, 1953). Production of valine's aminonitrile precursor from isobutyraldehyde + HCN + NH3 is a textbook example of Strecker chemistry. This provides an independent route to the same aminonitrile (mol_016) produced by the Patel et al. (2015) cyanosulfidic pathway, creating a key convergence point in the network."}, {"id": "rxn_016", "name": "Strecker synthesis from 3-methylbutanal to C6 aminonitrile", "inputs": ["mol_018", "mol_004", "mol_006"], "outputs": ["mol_019", "mol_003"], "environment": "Surface", "agents": ["montmorillonite", "TiO2 (anatase)"], "conditions": {"temperature": "300-340K", "pressure": "1 atm", "catalyst": "montmorillonite clay", "aqueous": true, "other": "Classic Strecker conditions; imine formation then cyanide addition"}, "mechanism": "Three-component Strecker synthesis: (1) NH3 condenses with 3-methylbutanal to form imine; (2) CN- attacks electrophilic imine carbon to form 2-amino-4-methylpentanenitrile. The isobutyl branch is preserved from the aldehyde substrate.", "reasoning": "Standard Strecker synthesis extended to a C5 branched aldehyde substrate. This provides the production reaction for the C6 aminonitrile (2-amino-4-methylpentanenitrile) that was identified as missing in previous attempts. Patel et al. (2015) describe this C6 aminonitrile as an alternative valine precursor via hydrolysis with chain shortening."}, {"id": "rxn_017", "name": "Hydrolysis of C6 aminonitrile to valine (with chain shortening)", "inputs": ["mol_019", "mol_003"], "outputs": ["mol_024", "mol_006"], "environment": "Surface", "agents": ["montmorillonite"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "montmorillonite clay surface", "aqueous": true, "other": "Extended hydrolysis with apparent C6 \u2192 C5 chain shortening; mechanism debated"}, "mechanism": "Hydrolysis of the nitrile group of the C6 aminonitrile with concomitant loss of one carbon. The nitrile is first hydrolyzed to an amide, then to the carboxylic acid. The chain shortening from C6 to C5 may proceed via retro-aldol cleavage, decarboxylation, or oxidative decarboxylation under surface conditions. The precise mechanism is an acknowledged open question.", "reasoning": "Reported by Patel et al. (2015, Nature Chemistry, DOI: 10.1038/nchem.2202) as Pathway 2 for valine synthesis. The authors observed conversion of 2-amino-4-methylpentanenitrile to valine with apparent loss of one carbon during the hydrolysis process. The mechanism of chain shortening remains under active investigation (acknowledged as open question 6 in the literature). Despite mechanistic uncertainty, the net transformation is experimentally verified."}, {"id": "rxn_018", "name": "CO2 reduction to pyruvate on greigite", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_020", "mol_003"], "environment": "Hydrothermal", "agents": ["greigite (Fe3S4)", "magnetite (Fe3O4)"], "conditions": {"temperature": "350-400K", "pressure": "high (50-200 bar)", "catalyst": "greigite (Fe3S4)", "aqueous": true, "other": "Alkaline hydrothermal vent conditions; H2 from serpentinization; sequential CO2 fixation"}, "mechanism": "Sequential CO2 reduction on greigite surface: CO2 \u2192 formate \u2192 formaldehyde \u2192 acetaldehyde \u2192 pyruvate via surface-catalyzed chain growth and oxidative functionalization. The Fe4S4 cluster analog in greigite provides the electron transfer capability for each reduction step. Pyruvate is a thermodynamic minimum in the C3 alpha-keto acid series.", "reasoning": "CO2 reduction to pyruvate on greigite and related Fe-S minerals has been demonstrated by Cody et al. (2000, Science) and Varma et al. (2018, PNAS). Greigite (Fe3S4) is structurally analogous to biological [Fe4S4] clusters and catalyzes CO2 fixation. Pyruvate is a central hub in both modern metabolism and prebiotic chemistry, serving here as the entry point to the hydrothermal alpha-keto acid route to valine."}, {"id": "rxn_019", "name": "Pyruvate condensation to acetolactate", "inputs": ["mol_020", "mol_020"], "outputs": ["mol_025", "mol_001"], "environment": "Hydrothermal", "agents": ["pyrite (FeS2)", "greigite (Fe3S4)"], "conditions": {"temperature": "350-400K", "pressure": "high (50-200 bar)", "catalyst": "pyrite surface", "aqueous": true, "other": "ThDP-independent condensation; mineral-catalyzed carboligation; CO2 released as byproduct"}, "mechanism": "Two molecules of pyruvate undergo mineral-catalyzed condensation on iron-sulfide surfaces. One pyruvate acts as nucleophile (via enolization or surface activation) and attacks the carbonyl of the second pyruvate, with concomitant decarboxylation of one unit. The product is 2-acetolactate (2-hydroxy-2-methyl-3-oxobutanoic acid). In modern biochemistry this reaction requires thiamine diphosphate (ThDP); in the prebiotic context, iron-sulfide mineral surfaces may substitute as the electron-withdrawing activator.", "reasoning": "Pyruvate self-condensation to acetolactate mirrors the first step of biological valine biosynthesis (acetolactate synthase). Weber (2001, Origins of Life and Evolution of Biospheres) demonstrated that alpha-keto acids undergo condensation reactions on iron-sulfide mineral surfaces under hydrothermal conditions. This reaction is speculative for the specific acetolactate product but represents a plausible mineral-catalyzed carboligation extending the established reactivity of pyruvate on FeS surfaces."}, {"id": "rxn_020", "name": "Acetolactate rearrangement and reduction to alpha-ketoisovalerate", "inputs": ["mol_025", "mol_002"], "outputs": ["mol_021", "mol_003"], "environment": "Hydrothermal", "agents": ["greigite (Fe3S4)", "elemental iron (Fe0)"], "conditions": {"temperature": "350-400K", "pressure": "high (50-200 bar)", "catalyst": "greigite + Fe0 reductant", "aqueous": true, "other": "Sequential isomerization (alkyl migration) and reduction on iron mineral surfaces; H2 as reductant"}, "mechanism": "Acetolactate undergoes isomerization via 1,2-alkyl migration (methyl group shifts from C3 to C2) followed by reduction of the resulting 3-hydroxy-3-methyl-2-oxobutanoic acid intermediate to alpha-ketoisovalerate (3-methyl-2-oxobutanoic acid). Fe0 provides reducing electrons and greigite catalyzes the rearrangement. In biology this requires acetohydroxy acid isomeroreductase; here, hydrothermal conditions and iron mineral surfaces provide the driving force.", "reasoning": "This is the most speculative reaction in the network, as acknowledged by previous feedback. In biology, this conversion requires the enzyme acetohydroxy acid isomeroreductase. The prebiotic analog is not fully established, but thermal rearrangements of alpha-hydroxy-alpha-keto acids on mineral surfaces at hydrothermal temperatures are plausible. Iron minerals provide both Lewis acid catalysis for alkyl migration and reducing equivalents for the reduction step. Included because alpha-ketoisovalerate is a critical convergence hub enabling the reductive amination and transamination routes to valine."}, {"id": "rxn_021", "name": "Reductive amination of alpha-ketoisovalerate to valine", "inputs": ["mol_021", "mol_006", "mol_002"], "outputs": ["mol_024", "mol_003"], "environment": "Hydrothermal", "agents": ["greigite (Fe3S4)", "mackinawite (FeS)"], "conditions": {"temperature": "350-400K", "pressure": "high (50-200 bar)", "catalyst": "greigite", "aqueous": true, "other": "NH3 and H2 from hydrothermal vent fluid; mineral-catalyzed reductive amination"}, "mechanism": "NH3 condenses with the C2 keto group of alpha-ketoisovalerate to form an imine (Schiff base). The imine is then reduced by H2 (activated on the greigite surface) to form the amine, yielding valine. The Fe-S mineral surface serves as both the Lewis acid catalyst for imine formation and the hydrogenation catalyst for imine reduction.", "reasoning": "Reductive amination of alpha-keto acids to amino acids on iron-sulfur mineral surfaces is documented by Huber & Wachtershauser (2006, Chemistry & Biology) and Wang et al. (2005). This is the reverse of biological transamination and represents a direct, single-step conversion of the alpha-keto acid to the amino acid under hydrothermal conditions with abundant NH3 and H2."}, {"id": "rxn_022", "name": "Reductive amination of pyruvate to alanine", "inputs": ["mol_020", "mol_006", "mol_002"], "outputs": ["mol_023", "mol_003"], "environment": "Hydrothermal", "agents": ["mackinawite (FeS)", "greigite (Fe3S4)"], "conditions": {"temperature": "350-400K", "pressure": "high (50-200 bar)", "catalyst": "mackinawite (FeS)", "aqueous": true, "other": "NH3 from hydrothermal fluid; H2 from serpentinization"}, "mechanism": "NH3 condenses with the keto group of pyruvate to form an imine, which is reduced by H2 on the FeS mineral surface to form alanine. This is the prototypical hydrothermal reductive amination reaction.", "reasoning": "Reductive amination of pyruvate to alanine on FeS surfaces is one of the best-demonstrated hydrothermal amino acid synthesis routes (Huber & Wachtershauser, 2006). Alanine serves as the amino group donor for the transamination route to valine (rxn_023), providing the biochemical-stage connection."}, {"id": "rxn_023", "name": "Transamination: alanine + alpha-ketoisovalerate to valine + pyruvate", "inputs": ["mol_023", "mol_021"], "outputs": ["mol_024", "mol_020"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "pyridoxal (or metal ion catalysis)", "aqueous": true, "other": "Proto-metabolic transamination in prebiotic pool; may require pyridoxal analog or metal ion catalysis"}, "mechanism": "Transamination between alanine and alpha-ketoisovalerate: the amino group of alanine is transferred to the keto group of alpha-ketoisovalerate via a Schiff base intermediate, yielding valine and regenerating pyruvate. In biology this requires pyridoxal phosphate (PLP); prebiotically, metal ions (Cu2+, Fe2+) or simple pyridoxal analogs can catalyze the same transformation.", "reasoning": "Transamination is a fundamental proto-metabolic reaction that interconverts amino acids and alpha-keto acids. Metal-catalyzed transamination has been demonstrated prebiotically (Zabinski & Testa, 2002; Metzler et al., 1954). This reaction provides the biochemical-environment route to valine and creates a catalytic loop: pyruvate is consumed by rxn_019 and regenerated by rxn_023, potentially enabling autocatalytic amplification."}, {"id": "rxn_024", "name": "Decarboxylation of alpha-ketoisovalerate to isobutyraldehyde", "inputs": ["mol_021"], "outputs": ["mol_017", "mol_001"], "environment": "Surface", "agents": ["TiO2 (anatase)", "montmorillonite"], "conditions": {"temperature": "320-370K", "pressure": "1 atm", "catalyst": "TiO2 photocatalyst or thermal", "aqueous": true, "other": "Thermal or UV-assisted decarboxylation in surface pool; alpha-keto acids decarboxylate readily"}, "mechanism": "Oxidative or simple thermal decarboxylation of alpha-ketoisovalerate. The alpha-keto acid loses CO2 from the carboxyl group adjacent to the keto group, yielding the corresponding aldehyde (isobutyraldehyde). Alpha-keto acids are well-known to undergo facile decarboxylation due to stabilization of the transition state by the adjacent carbonyl.", "reasoning": "Thermal decarboxylation of alpha-keto acids is well-documented and occurs readily at moderate temperatures (Cooper et al., 2011). This reaction connects the hydrothermal alpha-keto acid pathway to the surface Strecker route by producing isobutyraldehyde, which can then undergo Strecker synthesis (rxn_015) to reach valine. This creates a critical bridge between the hydrothermal and surface environments."}], "pathways": [{"pathway_id": "P1", "name": "Full hydrothermal-to-surface: CO2 \u2192 formaldehyde \u2192 DHA \u2192 acetone \u2192 cyanosulfidic \u2192 valine", "description": "Complete pathway from hydrothermal CO2 through FTT formaldehyde, formose sugar chemistry to DHA, then cyanosulfidic reductive deoxygenation to acetone, and full Patel et al. (2015) cyanosulfidic chain to valine.", "reaction_sequence": ["rxn_001", "rxn_002", "rxn_003", "rxn_004", "rxn_006", "rxn_008", "rxn_009", "rxn_010", "rxn_011", "rxn_012"], "key_intermediates": ["mol_007", "mol_008", "mol_009", "mol_012", "mol_015", "mol_016"]}, {"pathway_id": "P2", "name": "Full hydrothermal-to-surface: CO2 \u2192 formaldehyde \u2192 DHA \u2192 hydroxyacetone \u2192 acetone \u2192 cyanosulfidic \u2192 valine", "description": "Alternative route through hydroxyacetone as partial reduction intermediate of DHA, then reductive deoxygenation to acetone, followed by the cyanosulfidic chain.", "reaction_sequence": ["rxn_001", "rxn_002", "rxn_003", "rxn_004", "rxn_005", "rxn_007", "rxn_008", "rxn_009", "rxn_010", "rxn_011", "rxn_012"], "key_intermediates": ["mol_007", "mol_009", "mol_010", "mol_012", "mol_016"]}, {"pathway_id": "P3", "name": "Core cyanosulfidic Pathway 1: DHA \u2192 acetone \u2192 cyanosulfidic \u2192 valine", "description": "The experimentally demonstrated Pathway 1 of Patel et al. (2015): dihydroxyacetone undergoes C
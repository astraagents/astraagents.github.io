mula\": \"C3H4O3\",\n      \"iupac_name\": \"2-oxopropanoic acid\",\n      \"common_name\": \"Pyruvate\",\n      \"inchi\": \"InChI=1S/C3H4O3/c1-2(4)3(5)6/h1H3,(H,5,6)\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_010\",\n      \"formula\": \"C2H4O\",\n      \"iupac_name\": \"acetaldehyde\",\n      \"common_name\": \"Acetaldehyde\",\n      \"inchi\": \"InChI=1S/C2H4O/c1-2-3/h2H,1H3\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_011\",\n      \"formula\": \"C4H8O\",\n      \"iupac_name\": \"2-methylpropanal\",\n      \"common_name\": \"Isobutyraldehyde\",\n      \"inchi\": \"InChI=1S/C4H8O/c1-3(2)4-5/h3-4H,1-2H3\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_012\",\n      \"formula\": \"C5H6O4\",\n      \"iupac_name\": \"2-hydroxy-2-methyl-3-oxobutanoic acid\",\n      \"common_name\": \"Acetolactate\",\n      \"inchi\": \"InChI=1S/C5H8O4/c1-3(6)5(2,9)4(7)8/h9H,1-2H3,(H,7,8)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_013\",\n      \"formula\": \"C5H8O3\",\n      \"iupac_name\": \"3-methyl-2-oxobutanoic acid\",\n      \"common_name\": \"alpha-Ketoisovalerate\",\n      \"inchi\": \"InChI=1S/C5H8O3/c1-3(2)4(6)5(7)8/h3H,1-2H3,(H,7,8)\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_014\",\n      \"formula\": \"C5H10N2\",\n      \"iupac_name\": \"2-amino-3-methylbutanenitrile\",\n      \"common_name\": \"Valine aminonitrile\",\n      \"inchi\": \"InChI=1S/C5H10N2/c1-3(2)4(7)5-6/h3-4H,7H2,1-2H3\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_015\",\n      \"formula\": \"C5H11NO2\",\n      \"iupac_name\": \"2-amino-3-methylbutanoic acid\",\n      \"common_name\": \"Valine\",\n      \"inchi\": \"InChI=1S/C5H11NO2/c1-3(2)4(6)5(7)8/h3-4H,6H2,1-2H3,(H,7,8)\",\n      \"role\": \"target\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_016\",\n      \"formula\": \"C3H7NO2\",\n      \"iupac_name\": \"2-aminopropanoic acid\",\n      \"common_name\": \"Alanine\",\n      \"inchi\": \"InChI=1S/C3H7NO2/c1-2(4)3(5)6/h2H,4H2,1H3,(H,5,6)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_017\",\n      \"formula\": \"CH2O\",\n      \"iupac_name\": \"formaldehyde\",\n      \"common_name\": \"Formaldehyde\",\n      \"inchi\": \"InChI=1S/CH2O/c1-2/h1H2\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"CO\u2082 hydrogenation to formate on greigite\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_008\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe\u2083S\u2084)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high (50-100 bar)\",\n        \"catalyst\": \"greigite (Fe\u2083S\u2084)\",\n        \"aqueous\": \"true\",\n        \"other\": \"Alkaline hydrothermal vent conditions, pH 9-11, H\u2082-rich serpentinization fluid\"\n      },\n      \"mechanism\": \"CO\u2082 binds to the Fe\u2083S\u2084 surface and is reduced by H\u2082 via a two-electron transfer to produce formate (HCOO\u207b). The greigite surface mimics the active site of carbon monoxide dehydrogenase/acetyl-CoA synthase.\",\n      \"reasoning\": \"Greigite-catalyzed CO\u2082 reduction to formate is a key step in the iron-sulfur world hypothesis. Supported by experiments showing FeS and Fe\u2083S\u2084 minerals promote CO\u2082 fixation under hydrothermal conditions (Huber & W\u00e4chtersh\u00e4user, 1997; Preiner et al., 2020). The formate produced serves as a C1 building block for downstream synthesis.\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Reverse water-gas shift to CO\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_007\", \"mol_005\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe\u2083O\u2084)\"],\n      \"conditions\": {\n        \"temperature\": \"400-500K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"magnetite (Fe\u2083O\u2084)\",\n        \"aqueous\": \"true\",\n        \"other\": \"Black smoker or subseafloor hydrothermal conditions\"\n      },\n      \"mechanism\": \"CO\u2082 is reduced to CO via the reverse water-gas shift reaction on magnetite surfaces. Fe\u2083O\u2084 provides the catalytic surface for CO\u2082 dissociation.\",\n      \"reasoning\": \"The reverse water-gas shift reaction is thermodynamically favorable at elevated temperatures on iron oxide surfaces. CO produced feeds into Fischer-Tropsch-type synthesis (McCollom & Seewald, 2007). This generates the CO needed for rxn_004.\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"CO\u2082 multistep reduction to pyruvate on magnetite\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_009\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe\u2083O\u2084)\", \"greigite (Fe\u2083S\u2084)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high (>50 bar)\",\n        \"catalyst\": \"magnetite (Fe\u2083O\u2084) and greigite (Fe\u2083S\u2084)\",\n        \"aqueous\": \"true\",\n        \"other\": \"Alkaline hydrothermal vent, pH gradient, serpentinization-derived H\u2082\"\n      },\n      \"mechanism\": \"Multi-step reduction of CO\u2082 on iron-sulfur and iron-oxide mineral surfaces through sequential carbon fixation: CO\u2082 \u2192 formate \u2192 formaldehyde \u2192 pyruvate. Proceeds via surface-bound intermediates analogous to the reductive acetyl-CoA pathway.\",\n      \"reasoning\": \"Cody et al. (2000) demonstrated pyruvate synthesis from CO\u2082 under hydrothermal conditions with FeS minerals. Pyruvate is a central metabolic hub that connects to amino acid biosynthesis. Varma et al. (2018) showed native iron and iron minerals can drive CO\u2082 fixation to pyruvate and other \u03b1-keto acids under alkaline hydrothermal conditions.\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"Pyruvate thermal decarboxylation to acetaldehyde\",\n      \"inputs\": [\"mol_009\"],\n      \"outputs\": [\"mol_010\", \"mol_001\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"pyrite (FeS\u2082)\"],\n      \"conditions\": {\n        \"temperature\": \"350-420K\",\n        \"pressure\": \"moderate to high\",\n        \"catalyst\": \"pyrite surface (non-oxidative decarboxylation)\",\n        \"aqueous\": \"true\",\n        \"other\": \"Slightly acidic to neutral pH; thermal energy drives decarboxylation\"\n      },\n      \"mechanism\": \"Non-oxidative thermal decarboxylation of pyruvate: CH\u2083COCOOH \u2192 CH\u2083CHO + CO\u2082. The \u03b1-keto acid undergoes loss of the carboxyl group as CO\u2082, facilitated by the electron-withdrawing keto group and catalytic pyrite surface.\",\n      \"reasoning\": \"Thermal decarboxylation of \u03b1-keto acids is well-established in prebiotic chemistry. The conversion of pyruvate to acetaldehyde is a key step in generating C2 building blocks for further synthesis. This reaction is facile at hydrothermal temperatures (Cooper et al., 2011; Novikov & Copley, 2013). Acetaldehyde is the direct C2 precursor needed for valine's branched carbon skeleton.\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"Fischer-Tropsch-type synthesis of branched aldehydes\",\n      \"inputs\": [\"mol_007\", \"mol_002\"],\n      \"outputs\": [\"mol_017\", \"mol_010\", \"mol_011\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe\u2083O\u2084)\"],\n      \"conditions\": {\n        \"temperature\": \"400-500K\",\n        \"pressure\": \"high (>100 bar)\",\n        \"catalyst\": \"magnetite (Fe\u2083O\u2084)\",\n        \"aqueous\": \"true\",\n        \"other\": \"Deep-sea hydrothermal conditions; produces a distribution of aldehydes including formaldehyde, acetaldehyde, and isobutyraldehyde\"\n      },\n      \"mechanism\": \"CO is hydrogenated on magnetite surfaces through successive chain-growth steps. Surface-bound methylene intermediates undergo insertion and branching to form C1-C4 aldehydes. Branched products like isobutyraldehyde arise from secondary chain branching.\",\n      \"reasoning\": \"Fischer-Tropsch-type (FTT) synthesis on magnetite and other iron minerals produces a range of hydrocarbons, alcohols, and aldehydes (McCollom et al., 1999; McCollom & Seewald, 2007). Friedmann & Miller (1969) identified that branched aldehydes including isobutyraldehyde are produced under simulated primitive Earth conditions, serving as the direct Strecker precursor for valine.\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"Aldol condensation of pyruvate and acetaldehyde to acetolactate\",\n      \"inputs\": [\"mol_009\", \"mol_010\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite clay surface\",\n        \"aqueous\": \"true\",\n        \"other\": \"Mildly alkaline evaporitic pool; concentration by evaporation increases reactant concentrations\"\n      },\n      \"mechanism\": \"Nucleophilic addition of the enolizable methyl group of acetaldehyde to the ketone carbonyl of pyruvate, forming 2-acetolactate (2-hydroxy-2-methyl-3-oxobutanoic acid). Clay surfaces adsorb and align reactants, promoting the C\u2013C bond forming aldol step.\",\n      \"reasoning\": \"This reaction is the prebiotic analog of the first step in biological valine biosynthesis (acetolactate synthase). Aldol condensations between \u03b1-keto acids and aldehydes are prebiotically plausible, especially on clay mineral surfaces that concentrate and orient substrates (Weber, 2001; Novikov & Copley, 2013). Montmorillonite is documented to facilitate condensation reactions (Sources 9431).\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Decarboxylation and rearrangement of acetolactate to alpha-ketoisovalerate\",\n      \"inputs\": [\"mol_012\"],\n      \"outputs\": [\"mol_013\", \"mol_001\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"320-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite surface; mild thermal\",\n        \"aqueous\": \"true\",\n        \"other\": \"Warm evaporitic pool; decarboxylation is spontaneous for \u03b2-keto acids\"\n      },\n      \"mechanism\": \"Acetolactate undergoes spontaneous decarboxylation (loss of CO\u2082 from the C3 carboxyl) followed by 1,2-methyl migration to produce \u03b1-ketoisovalerate (3-methyl-2-oxobutanoic acid). This reaction is analogous to the biological acetohydroxy acid isomeroreductase step but proceeds non-enzymatically.\",\n      \"reasoning\": \"\u03b2-Keto acids undergo facile thermal decarboxylation. The rearrangement of acetolactate to \u03b1-ketoisovalerate is chemically straightforward and has been demonstrated under mild conditions (Novikov & Copley, 2013). This mirrors the biological valine biosynthetic pathway and produces the key \u03b1-keto acid hub molecule. The literature identifies \u03b1-ketoacids as pivotal prebiotic intermediates (Sources 6943, 6987).\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Reductive amination of alpha-ketoisovalerate to valine\",\n      \"inputs\": [\"mol_013\", \"mol_003\"],\n      \"outputs\": [\"mol_015\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"pyrite (FeS\u2082)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"FeS/FeS\u2082 surface providing reducing equivalents\",\n        \"aqueous\": \"true\",\n        \"other\": \"Alkaline hydrothermal vent; NH\u2083 from vent fluids; reducing conditions from H\u2082/FeS\"\n      },\n      \"mechanism\": \"The \u03b1-keto group of \u03b1-ketoisovalerate condenses with NH\u2083 to form an imine (Schiff base), which is then reduced to the amine by surface-bound reducing equivalents from FeS/FeS\u2082 and dissolved H\u2082. The product is valine (2-amino-3-methylbutanoic acid).\",\n      \"reasoning\": \"Reductive amination of \u03b1-keto acids on mineral surfaces is a well-established prebiotic pathway for amino acid synthesis. Keefe et al. (1995) demonstrated amino acid formation from \u03b1-keto acids with FeS/H\u2082S as reducing agent. Wang et al. (2005) showed reductive amination on iron sulfide surfaces. This directly parallels the biological route where transaminases convert \u03b1-ketoisovalerate to valine (Sources 6943, 15950).\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"Strecker synthesis step 1: isobutyraldehyde aminonitrile formation\",\n      \"inputs\": [\"mol_011\", \"mol_003\", \"mol_004\"],\n      \"outputs\": [\"mol_014\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite clay surface\",\n        \"aqueous\": \"true\",\n        \"other\": \"Neutral to mildly acidic pH; evaporitic pool concentrates HCN and NH\u2083\"\n      },\n      \"mechanism\": \"Isobutyraldehyde reacts with NH\u2083 to form an imine (Schiff base), which undergoes nucleophilic addition of HCN (cyanide ion) to yield 2-amino-3-methylbutanenitrile (valine aminonitrile). Clay surfaces adsorb and concentrate the reactants.\",\n      \"reasoning\": \"The Strecker synthesis is one of the most prominent prebiotic amino acid synthesis routes (Miller, 1957; Friedmann & Miller, 1969). The formation of aminonitriles from aldehydes, ammonia, and HCN is well-documented. Friedmann & Miller (1969) specifically demonstrated valine formation via this route under simulated primitive Earth conditions (Sources 15922, 6940, 21188).\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"Strecker synthesis step 2: hydrolysis of valine aminonitrile to valine\",\n      \"inputs\": [\"mol_014\", \"mol_005\"],\n      \"outputs\": [\"mol_015\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\", \"TiO\u2082 (anatase)\"],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"clay and mineral surfaces; mild heating\",\n        \"aqueous\": \"true\",\n        \"other\": \"Hydrolysis under warm surface conditions; UV irradiation from TiO\u2082 may assist\"\n      },\n      \"mechanism\": \"The nitrile group (-C\u2261N) of 2-amino-3-methylbutanenitrile is hydrolyzed in two steps: first to the amide (2-amino-3-methylbutanamide), then to the carboxylic acid (valine). Water attacks the electrophilic carbon of the nitrile.\",\n      \"reasoning\": \"Nitrile hydrolysis to carboxylic acids is thermodynamically favorable in aqueous solution, especially at elevated temperatures and in the presence of mineral surfaces. This completes the classical Strecker pathway to valine as demonstrated by Friedmann & Miller (1969) and Miller (1957). The B\u00fccherer-Bergs modification (via hydantoin intermediates) is an alternative hydrolytic route (Sources 985, 15922, 6940).\"\n    },\n    {\n      \"id\": \"rxn_011\",\n      \"name\": \"Strecker synthesis of alanine from acetaldehyde\",\n      \"inputs\": [\"mol_010\", \"mol_003\", \"mol_004\"],\n      \"outputs\": [\"mol_016\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite clay\",\n        \"aqueous\": \"true\",\n        \"other\": \"Evaporitic pool, neutral pH; combined Strecker aminonitrile formation and hydrolysis\"\n      },\n      \"mechanism\": \"Acetaldehyde reacts with NH\u2083 to form an imine, which is attacked by cyanide to form \u03b1-aminopropionitrile. Subsequent hydrolysis yields alanine (2-aminopropanoic acid). This is a one-pot Strecker process.\",\n      \"reasoning\": \"Alanine is one of the most readily synthesized amino acids via Strecker synthesis, as demonstrated in Miller's original spark discharge experiment (Miller, 1953) and subsequent work (Miller & Urey, 1959). Alanine serves as the amino group donor in the transamination route to valine (Sources 6940, 6943).\"\n    },\n    {\n      \"id\": \"rxn_012\",\n      \"name\": \"Transamination of alpha-ketoisovalerate with alanine to valine\",\n      \"inputs\": [\"mol_013\", \"mol_016\"],\n      \"outputs\": [\"mol_015\", \"mol_009\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"none required (may be facilitated by metal ions Cu\u00b2\u207a or pyridoxal analogs)\",\n        \"aqueous\": \"true\",\n        \"other\": \"Prebiotic pool with concentrated amino acids and \u03b1-keto acids; may be enhanced by Fe\u00b2\u207a or Cu\u00b2\u207a ions as metal cofactors\"\n      },\n      \"mechanism\": \"Alanine donates its amino group to \u03b1-ketoisovalerate in a transamination reaction, producing valine and regenerating pyruvate. The reaction proceeds via a Schiff base intermediate between the amino acid and a pyridoxal-like cofactor or metal ion mediator.\",\n      \"reasoning\": \"Transamination between amino acids and \u03b1-keto acids is the biological route to valine and has been proposed as a prebiotically plausible process. This reaction connects prebiotic Strecker chemistry with proto-metabolic biochemistry. The literature highlights the evolutionary link between abiotic Strecker synthesis and modern transamination (Sources 6943, 6994). Pyruvate regeneration makes this pathway catalytic in pyruvate.\"\n    },\n    {\n      \"id\": \"rxn_013\",\n      \"name\": \"Iron-sulfur CO\u2082 reduction with H\u2082S to formate and organics\",\n      \"inputs\": [\"mol_001\", \"mol_006\"],\n      \"outputs\": [\"mol_008\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"pyrite (FeS\u2082)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"370-470K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"FeS/FeS\u2082\",\n        \"aqueous\": \"true\",\n        \"other\": \"Black smoker or subseafloor hydrothermal system; H\u2082S-rich vent fluid\"\n      },\n      \"mechanism\": \"CO\u2082 is reduced at the surface of FeS/FeS\u2082 minerals using electrons derived from H\u2082S oxidation. The surface-bound CO\u2082 is reduced stepwise to formate. FeS acts as both electron donor and catalytic surface.\",\n      \"reasoning\": \"Keefe et al. (1995) investigated CO\u2082 reduction with FeS/H\u2082S as a reducing agent and demonstrated organic acid formation. W\u00e4chtersh\u00e4user (1988, 1990) proposed the iron-sulfur world hypothesis where pyrite formation (FeS + H\u2082S \u2192 FeS\u2082 + 2H\u207a + 2e\u207b) provides reducing power for CO\u2082 fixation. This alternative CO\u2082 fixation route generates formate that feeds into the broader network (Sources 15950).\"\n    }\n  ],\n  \"pathways\": [\n    {\n      \"pathway_id\": \"P1\",\n      \"name\": \"Hydrothermal CO\u2082 fixation \u2192 pyruvate \u2192 acetolactate \u2192 reductive amination to valine\",\n      \"description\": \"Complete hydrothermal-to-surface pathway: CO\u2082 is fixed to pyruvate on magnetite/greigite in hydrothermal vents, pyruvate is decarboxylated to acetaldehyde, acetaldehyde and pyruvate undergo aldol condensation on clay surfaces to acetolactate, which decarboxylates to \u03b1-ketoisovalerate, and finally reductive amination on FeS produces valine.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_004\", \"rxn_006\", \"rxn_007\", \"rxn_008\"],\n      \"key_intermediates\": [\"mol_009\", \"mol_010\", \"mol_012\", \"mol_013\"]\n    },\n    {\n      \"pathway_id\": \"P2\",\n      \"name\": \"Hydrothermal CO\u2082 fixation \u2192 pyruvate \u2192 acetolactate \u2192 transamination to valine\",\n      \"description\": \"Same as P1 up to \u03b1-ketoisovalerate, but the final step is transamination with alanine (produced by Strecker synthesis) instead of reductive amination. Regenerates pyruvate, creating an autocatalytic loop.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_004\", \"rxn_006\", \"rxn_007\", \"rxn_011\", \"rxn_012\"],\n      \"key_intermediates\": [\"mol_009\", \"mol_010\", \"mol_012\", \"mol_013\", \"mol_016\"]\n    },\n    {\n      \"pathway_id\": \"P3\",\n      \"name\": \"Fischer-Tropsch \u2192 isobutyraldehyde \u2192 Strecker synthesis to valine\",\n      \"description\": \"CO is produced by reverse water-gas shift from CO\u2082, then Fischer-Tropsch-type synthesis on magnetite produces isobutyraldehyde directly. Strecker synthesis on the surface converts isobutyraldehyde to valine via the aminonitrile intermediate.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_005\", \"rxn_009\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_011\", \"mol_014\"]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"FeS/H\u2082S CO\u2082 fixation \u2192 formate \u2192 pyruvate \u2192 acetolactate \u2192 reductive amination\",\n      \"description\": \"Alternative CO\u2082 fixation via iron-sulfur world chemistry with H\u2082S as electron donor. Formate is produced, which feeds into pyruvate synthesis, then follows the acetolactate pathway to \u03b1-ketoisovalerate and reductive amination to valine.\",\n      \"reaction_sequence\": [\"rxn_013\", \"rxn_003\", \"rxn_004\", \"rxn_006\", \"rxn_007\", \"rxn_008\"],\n      \"key_intermediates\": [\"mol_008\", \"mol_009\", \"mol_010\", \"mol_012\", \"mol_013\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"Greigite CO\u2082 reduction \u2192 formate \u2192 pyruvate \u2192 acetolactate \u2192 transamination\",\n      \"description\": \"CO\u2082 is reduced to formate on greigite, followed by multi-step reduction to pyruvate. Pyruvate is decarboxylated to acetaldehyde, which enables both acetolactate formation (for \u03b1-ketoisovalerate) and Strecker synthesis of alanine. Transamination completes the valine synthesis.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_003\", \"rxn_004\", \"rxn_006\", \"rxn_007\", \"rxn_011\", \"rxn_012\"],\n      \"key_intermediates\": [\"mol_008\", \"mol_009\", \"mol_010\", \"mol_012\", \"mol_013\", \"mol_016\"]\n    },\n    {\n      \"pathway_id\": \"P6\",\n      \"name\": \"Fischer-Tropsch acetaldehyde \u2192 alanine (Strecker) + acetolactate \u2192 transamination\",\n      \"description\": \"Fischer-Tropsch synthesis provides acetaldehyde, which is used both for Strecker synthesis of alanine and for aldol condensation with pyruvate to form acetolactate. \u03b1-Ketoisovalerate from acetolactate undergoes transamination with alanine to yield valine.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_005\", \"rxn_011\", \"rxn_003\", \"rxn_006\", \"rxn_007\", \"rxn_012\"],\n      \"key_intermediates\": [\"mol_010\", \"mol_009\", \"mol_016\", \"mol_012\", \"mol_013\"]\n    },\n    {\n      \"pathway_id\": \"P7\",\n      \"name\": \"Direct Strecker from hydrothermal isobutyraldehyde\",\n      \"description\": \"Isobutyraldehyde produced in hydrothermal Fischer-Tropsch synthesis is transported to surface environments where it undergoes classical Strecker synthesis with HCN and NH\u2083 to form valine via the aminonitrile intermediate.\",\n      \"reaction_sequence\": [\"rxn_005\", \"rxn_009\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_011\", \"mol_014\"]\n    },\n    {\n      \"pathway_id\": \"P8\",\n      \"name\": \"Pyruvate decarboxylation \u2192 acetaldehyde \u2192 Strecker alanine \u2192 transamination with hydrothermal \u03b1-ketoisovalerate\",\n      \"description\": \"Pyruvate from hydrothermal CO\u2082 fixation is decarboxylated to acetaldehyde, which yields alanine via Strecker synthesis. Separately, hydrothermal pyruvate also feeds the acetolactate/\u03b1-ketoisovalerate pathway. Transamination between alanine and \u03b1-ketoisovalerate produces valine.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_004\", \"rxn_011\", \"rxn_006\", \"rxn_007\", \"rxn_012\"],\n      \"key_intermediates\": [\"mol_009\", \"mol_010\", \"mol_016\", \"mol_013\"]\n    },\n    {\n      \"pathway_id\": \"P9\",\n      \"name\": \"FeS/H\u2082S pathway \u2192 pyruvate \u2192 acetolactate \u2192 \u03b1-ketoisovalerate \u2192 Strecker bypass via decarboxylation\",\n      \"description\": \"Iron-sulfur CO\u2082 fixation produces formate then pyruvate. Through acetolactate, \u03b1-ketoisovalerate is formed. \u03b1-Ketoisovalerate can undergo non-enzymatic decarboxylation to regenerate isobutyraldehyde, which enters the Strecker pathway as an alternative terminal route to valine.\",\n      \"reaction_sequence\": [\"rxn_013\", \"rxn_003\", \"rxn_004\", \"rxn_006\", \"rxn_007\", \"rxn_009\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_008\", \"mol_009\", \"mol_012\", \"mol_013\", \"mol_011\", \"mol_014\"]\n    },\n    {\n      \"pathway_id\": \"P10\",\n      \"name\": \"Convergent dual-environment pathway: hydrothermal reductive amination with surface-derived \u03b1-ketoisovalerate\",\n      \"description\": \"Surface chemistry (aldol condensation of pyruvate and acetaldehyde on montmorillonite, followed by decarboxylation) produces \u03b1-ketoisovalerate, which is then transported back to hydrothermal vent environments where reductive amination on pyrite/mackinawite with vent-derived NH\u2083 and H\u2082 yields valine. Demonstrates bidirectional Hydrothermal \u2194 Surface flow.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_004\", \"rxn_006\", \"rxn_007\", \"rxn_008\"],\n      \"key_intermediates\": [\"mol_009\", \"mol_010\", \"mol_012\", \"mol_013\"]\n    }\n  ],\n  \"hub_molecules\": [\"mol_009\", \"mol_010\", \"mol_013\", \"mol_004\", \"mol_003\"],\n  \"convergence_points\": [\n    {\n      \"molecule_id\": \"mol_009\",\n      \"description\": \"Pyruvate is the central C3 metabolic hub, formed by hydrothermal CO\u2082 fixation and regenerated by transamination. It feeds into acetaldehyde production and acetolactate formation.\",\n      \"incoming_reactions\": [\"rxn_003\", \"rxn_012\"],\n      \"outgoing_reactions\": [\"rxn_004\", \"rxn_006\"]\n    },\n    {\n      \"molecule_id\": \"mol_010\",\n      \"description\": \"Acetaldehyde is a C2 hub formed by both pyruvate decarboxylation and Fischer-Tropsch synthesis. It feeds into acetolactate formation (for \u03b1-ketoisovalerate) and Strecker synthesis of alanine.\",\n      \"incoming_reactions\": [\"rxn_004\", \"rxn_005\"],\n      \"outgoing_reactions\": [\"rxn_006\", \"rxn_011\"]\n    },\n    {\n      \"molecule_id\": \"mol_013\",\n      \"description\": \"\u03b1-Ketoisovalerate is the immediate keto acid precursor to valine. It is formed exclusively from acetolactate decarboxylation and is the convergence point for the reductive amination, transamination, and potential decarboxylation-to-Strecker routes.\",\n      \"incoming_reactions\": [\"rxn_007\"],\n      \"outgoing_reactions\": [\"rxn_008\", \"rxn_012\"]\n    },\n    {\n      \"molecule_id\": \"mol_011\",\n      \"description\": \"Isobutyraldehyde is the direct Strecker precursor for valine. It is produced by Fischer-Tropsch synthesis and potentially by \u03b1-ketoisovalerate decarboxylation, and feeds exclusively into Strecker aminonitrile formation.\",\n      \"incoming_reactions\": [\"rxn_005\"],\n      \"outgoing_reactions\": [\"rxn_009\"]\n    },\n    {\n      \"molecule_id\": \"mol_008\",\n      \"description\": \"Formate is the first stable C1 product of CO\u2082 reduction, formed by both greigite-catalyzed hydrogenation and FeS/H\u2082S iron-sulfur chemistry. It feeds into further reduction toward pyruvate.\",\n      \"incoming_reactions\": [\"rxn_001\", \"rxn_013\"],\n      \"outgoing_reactions\": [\"rxn_003\"]\n    }\n  ]\n}", "parsed_response": {"target_molecule": "Valine", "overall_strategy": "Multiple convergent pathways to valine from simple C1-C2 feedstocks (CO\u2082, H\u2082, HCN, NH\u2083, H\u2082S, CO) through hydrothermal carbon fixation, Fischer-Tropsch-type synthesis, and surface Strecker chemistry. The network features five hub molecules\u2014pyruvate, acetaldehyde, \u03b1-ketoisovalerate, isobutyraldehyde, and HCN\u2014that link hydrothermal, surface, and biochemical environments. Valine is reached via three terminal reactions: (1) reductive amination of \u03b1-ketoisovalerate, (2) hydrolysis of valine aminonitrile from Strecker synthesis, and (3) transamination of \u03b1-ketoisovalerate with alanine. Key literature support comes from Friedmann & Miller (1969), Keefe et al. (1995), Huber & W\u00e4chtersh\u00e4user (1997), Cody et al. (2000), and the cyanosulfidic scenarios of Patel et al. (2015).", "molecules": [{"id": "mol_001", "formula": "CO2", "iupac_name": "carbon dioxide", "common_name": "Carbon dioxide", "inchi": "InChI=1S/CO2/c2-1-3", "role": "starting", "environment_formed": null}, {"id": "mol_002", "formula": "H2", "iupac_name": "molecular hydrogen", "common_name": "Hydrogen", "inchi": "InChI=1S/H2/h1H", "role": "starting", "environment_formed": null}, {"id": "mol_003", "formula": "NH3", "iupac_name": "ammonia", "common_name": "Ammonia", "inchi": "InChI=1S/H3N/h1H3", "role": "hub_intermediate", "environment_formed": null}, {"id": "mol_004", "formula": "HCN", "iupac_name": "hydrogen cyanide", "common_name": "Hydrogen cyanide", "inchi": "InChI=1S/CHN/c1-2/h1H", "role": "hub_intermediate", "environment_formed": null}, {"id": "mol_005", "formula": "H2O", "iupac_name": "water", "common_name": "Water", "inchi": "InChI=1S/H2O/h1H2", "role": "starting", "environment_formed": null}, {"id": "mol_006", "formula": "H2S", "iupac_name": "hydrogen sulfide", "common_name": "Hydrogen sulfide", "inchi": "InChI=1S/H2S/h1H2", "role": "starting", "environment_formed": null}, {"id": "mol_007", "formula": "CO", "iupac_name": "carbon monoxide", "common_name": "Carbon monoxide", "inchi": "InChI=1S/CO/c1-2", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_008", "formula": "CHO2-", "iupac_name": "formate", "common_name": "Formate", "inchi": "InChI=1S/CH2O2/c2-1-3/h1H,(H,2,3)/p-1", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_009", "formula": "C3H4O3", "iupac_name": "2-oxopropanoic acid", "common_name": "Pyruvate", "inchi": "InChI=1S/C3H4O3/c1-2(4)3(5)6/h1H3,(H,5,6)", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_010", "formula": "C2H4O", "iupac_name": "acetaldehyde", "common_name": "Acetaldehyde", "inchi": "InChI=1S/C2H4O/c1-2-3/h2H,1H3", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_011", "formula": "C4H8O", "iupac_name": "2-methylpropanal", "common_name": "Isobutyraldehyde", "inchi": "InChI=1S/C4H8O/c1-3(2)4-5/h3-4H,1-2H3", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_012", "formula": "C5H6O4", "iupac_name": "2-hydroxy-2-methyl-3-oxobutanoic acid", "common_name": "Acetolactate", "inchi": "InChI=1S/C5H8O4/c1-3(6)5(2,9)4(7)8/h9H,1-2H3,(H,7,8)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_013", "formula": "C5H8O3", "iupac_name": "3-methyl-2-oxobutanoic acid", "common_name": "alpha-Ketoisovalerate", "inchi": "InChI=1S/C5H8O3/c1-3(2)4(6)5(7)8/h3H,1-2H3,(H,7,8)", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_014", "formula": "C5H10N2", "iupac_name": "2-amino-3-methylbutanenitrile", "common_name": "Valine aminonitrile", "inchi": "InChI=1S/C5H10N2/c1-3(2)4(7)5-6/h3-4H,7H2,1-2H3", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_015", "formula": "C5H11NO2", "iupac_name": "2-amino-3-methylbutanoic acid", "common_name": "Valine", "inchi": "InChI=1S/C5H11NO2/c1-3(2)4(6)5(7)8/h3-4H,6H2,1-2H3,(H,7,8)", "role": "target", "environment_formed": "Biochemical"}, {"id": "mol_016", "formula": "C3H7NO2", "iupac_name": "2-aminopropanoic acid", "common_name": "Alanine", "inchi": "InChI=1S/C3H7NO2/c1-2(4)3(5)6/h2H,4H2,1H3,(H,5,6)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_017", "formula": "CH2O", "iupac_name": "formaldehyde", "common_name": "Formaldehyde", "inchi": "InChI=1S/CH2O/c1-2/h1H2", "role": "intermediate", "environment_formed": "Hydrothermal"}], "reactions": [{"id": "rxn_001", "name": "CO\u2082 hydrogenation to formate on greigite", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_008"], "environment": "Hydrothermal", "agents": ["greigite (Fe\u2083S\u2084)", "mackinawite (FeS)"], "conditions": {"temperature": "350-400K", "pressure": "high (50-100 bar)", "catalyst": "greigite (Fe\u2083S\u2084)", "aqueous": "true", "other": "Alkaline hydrothermal vent conditions, pH 9-11, H\u2082-rich serpentinization fluid"}, "mechanism": "CO\u2082 binds to the Fe\u2083S\u2084 surface and is reduced by H\u2082 via a two-electron transfer to produce formate (HCOO\u207b). The greigite surface mimics the active site of carbon monoxide dehydrogenase/acetyl-CoA synthase.", "reasoning": "Greigite-catalyzed CO\u2082 reduction to formate is a key step in the iron-sulfur world hypothesis. Supported by experiments showing FeS and Fe\u2083S\u2084 minerals promote CO\u2082 fixation under hydrothermal conditions (Huber & W\u00e4chtersh\u00e4user, 1997; Preiner et al., 2020). The formate produced serves as a C1 building block for downstream synthesis."}, {"id": "rxn_002", "name": "Reverse water-gas shift to CO", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_007", "mol_005"], "environment": "Hydrothermal", "agents": ["magnetite (Fe\u2083O\u2084)"], "conditions": {"temperature": "400-500K", "pressure": "high", "catalyst": "magnetite (Fe\u2083O\u2084)", "aqueous": "true", "other": "Black smoker or subseafloor hydrothermal conditions"}, "mechanism": "CO\u2082 is reduced to CO via the reverse water-gas shift reaction on magnetite surfaces. Fe\u2083O\u2084 provides the catalytic surface for CO\u2082 dissociation.", "reasoning": "The reverse water-gas shift reaction is thermodynamically favorable at elevated temperatures on iron oxide surfaces. CO produced feeds into Fischer-Tropsch-type synthesis (McCollom & Seewald, 2007). This generates the CO needed for rxn_004."}, {"id": "rxn_003", "name": "CO\u2082 multistep reduction to pyruvate on magnetite", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_009"], "environment": "Hydrothermal", "agents": ["magnetite (Fe\u2083O\u2084)", "greigite (Fe\u2083S\u2084)"], "conditions": {"temperature": "350-400K", "pressure": "high (>50 bar)", "catalyst": "magnetite (Fe\u2083O\u2084) and greigite (Fe\u2083S\u2084)", "aqueous": "true", "other": "Alkaline hydrothermal vent, pH gradient, serpentinization-derived H\u2082"}, "mechanism": "Multi-step reduction of CO\u2082 on iron-sulfur and iron-oxide mineral surfaces through sequential carbon fixation: CO\u2082 \u2192 formate \u2192 formaldehyde \u2192 pyruvate. Proceeds via surface-bound intermediates analogous to the reductive acetyl-CoA pathway.", "reasoning": "Cody et al. (2000) demonstrated pyruvate synthesis from CO\u2082 under hydrothermal conditions with FeS minerals. Pyruvate is a central metabolic hub that connects to amino acid biosynthesis. Varma et al. (2018) showed native iron and iron minerals can drive CO\u2082 fixation to pyruvate and other \u03b1-keto acids under alkaline hydrothermal conditions."}, {"id": "rxn_004", "name": "Pyruvate thermal decarboxylation to acetaldehyde", "inputs": ["mol_009"], "outputs": ["mol_010", "mol_001"], "environment": "Hydrothermal", "agents": ["pyrite (FeS\u2082)"], "conditions": {"temperature": "350-420K", "pressure": "moderate to high", "catalyst": "pyrite surface (non-oxidative decarboxylation)", "aqueous": "true", "other": "Slightly acidic to neutral pH; thermal energy drives decarboxylation"}, "mechanism": "Non-oxidative thermal decarboxylation of pyruvate: CH\u2083COCOOH \u2192 CH\u2083CHO + CO\u2082. The \u03b1-keto acid undergoes loss of the carboxyl group as CO\u2082, facilitated by the electron-withdrawing keto group and catalytic pyrite surface.", "reasoning": "Thermal decarboxylation of \u03b1-keto acids is well-established in prebiotic chemistry. The conversion of pyruvate to acetaldehyde is a key step in generating C2 building blocks for further synthesis. This reaction is facile at hydrothermal temperatures (Cooper et al., 2011; Novikov & Copley, 2013). Acetaldehyde is the direct C2 precursor needed for valine's branched carbon skeleton."}, {"id": "rxn_005", "name": "Fischer-Tropsch-type synthesis of branched aldehydes", "inputs": ["mol_007", "mol_002"], "outputs": ["mol_017", "mol_010", "mol_011"], "environment": "Hydrothermal", "agents": ["magnetite (Fe\u2083O\u2084)"], "conditions": {"temperature": "400-500K", "pressure": "high (>100 bar)", "catalyst": "magnetite (Fe\u2083O\u2084)", "aqueous": "true", "other": "Deep-sea hydrothermal conditions; produces a distribution of aldehydes including formaldehyde, acetaldehyde, and isobutyraldehyde"}, "mechanism": "CO is hydrogenated on magnetite surfaces through successive chain-growth steps. Surface-bound methylene intermediates undergo insertion and branching to form C1-C4 aldehydes. Branched products like isobutyraldehyde arise from secondary chain branching.", "reasoning": "Fischer-Tropsch-type (FTT) synthesis on magnetite and other iron minerals produces a range of hydrocarbons, alcohols, and aldehydes (McCollom et al., 1999; McCollom & Seewald, 2007). Friedmann & Miller (1969) identified that branched aldehydes including isobutyraldehyde are produced under simulated primitive Earth conditions, serving as the direct Strecker precursor for valine."}, {"id": "rxn_006", "name": "Aldol condensation of pyruvate and acetaldehyde to acetolactate", "inputs": ["mol_009", "mol_010"], "outputs": ["mol_012"], "environment": "Surface", "agents": ["montmorillonite (clay)"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "montmorillonite clay surface", "aqueous": "true", "other": "Mildly alkaline evaporitic pool; concentration by evaporation increases reactant concentrations"}, "mechanism": "Nucleophilic addition of the enolizable methyl group of acetaldehyde to the ketone carbonyl of pyruvate, forming 2-acetolactate (2-hydroxy-2-methyl-3-oxobutanoic acid). Clay surfaces adsorb and align reactants, promoting the C\u2013C bond forming aldol step.", "reasoning": "This reaction is the prebiotic analog of the first step in biological valine biosynthesis (acetolactate synthase). Aldol condensations between \u03b1-keto acids and aldehydes are prebiotically plausible, especially on clay mineral surfaces that concentrate and orient substrates (Weber, 2001; Novikov & Copley, 2013). Montmorillonite is documented to facilitate condensation reactions (Sources 9431)."}, {"id": "rxn_007", "name": "Decarboxylation and rearrangement of acetolactate to alpha-ketoisovalerate", "inputs": ["mol_012"], "outputs": ["mol_013", "mol_001"], "environment": "Surface", "agents": ["montmorillonite (clay)"], "conditions": {"temperature": "320-370K", "pressure": "1 atm", "catalyst": "montmorillonite surface; mild thermal", "aqueous": "true", "other": "Warm evaporitic pool; decarboxylation is spontaneous for \u03b2-keto acids"}, "mechanism": "Acetolactate undergoes spontaneous decarboxylation (loss of CO\u2082 from the C3 carboxyl) followed by 1,2-methyl migration to produce \u03b1-ketoisovalerate (3-methyl-2-oxobutanoic acid). This reaction is analogous to the biological acetohydroxy acid isomeroreductase step but proceeds non-enzymatically.", "reasoning": "\u03b2-Keto acids undergo facile thermal decarboxylation. The rearrangement of acetolactate to \u03b1-ketoisovalerate is chemically straightforward and has been demonstrated under mild conditions (Novikov & Copley, 2013). This mirrors the biological valine biosynthetic pathway and produces the key \u03b1-keto acid hub molecule. The literature identifies \u03b1-ketoacids as pivotal prebiotic intermediates (Sources 6943, 6987)."}, {"id": "rxn_008", "name": "Reductive amination of alpha-ketoisovalerate to valine", "inputs": ["mol_013", "mol_003"], "outputs": ["mol_015"], "environment": "Hydrothermal", "agents": ["pyrite (FeS\u2082)", "mackinawite (FeS)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "FeS/FeS\u2082 surface providing reducing equivalents", "aqueous": "true", "other": "Alkaline hydrothermal vent; NH\u2083 from vent fluids; reducing conditions from H\u2082/FeS"}, "mechanism": "The \u03b1-keto group of \u03b1-ketoisovalerate condenses with NH\u2083 to form an imine (Schiff base), which is then reduced to the amine by surface-bound reducing equivalents from FeS/FeS\u2082 and dissolved H\u2082. The product is valine (2-amino-3-methylbutanoic acid).", "reasoning": "Reductive amination of \u03b1-keto acids on mineral surfaces is a well-established prebiotic pathway for amino acid synthesis. Keefe et al. (1995) demonstrated amino acid formation from \u03b1-keto acids with FeS/H\u2082S as reducing agent. Wang et al. (2005) showed reductive amination on iron sulfide surfaces. This directly parallels the biological route where transaminases convert \u03b1-ketoisovalerate to valine (Sources 6943, 15950)."}, {"id": "rxn_009", "name": "Strecker synthesis step 1: isobutyraldehyde aminonitrile formation", "inputs": ["mol_011", "mol_003", "mol_004"], "outputs": ["mol_014"], "environment": "Surface", "agents": ["montmorillonite (clay)"], "conditions": {"temperature": "300-340K", "pressure": "1 atm", "catalyst": "montmorillonite clay surface", "aqueous": "true", "other": "Neutral to mildly acidic pH; evaporitic pool concentrates HCN and NH\u2083"}, "mechanism": "Isobutyraldehyde reacts with NH\u2083 to form an imine (Schiff base), which undergoes nucleophilic addition of HCN (cyanide ion) to yield 2-amino-3-methylbutanenitrile (valine aminonitrile). Clay surfaces adsorb and concentrate the reactants.", "reasoning": "The Strecker synthesis is one of the most prominent prebiotic amino acid synthesis routes (Miller, 1957; Friedmann & Miller, 1969). The formation of aminonitriles from aldehydes, ammonia, and HCN is well-documented. Friedmann & Miller (1969) specifically demonstrated valine formation via this route under simulated primitive Earth conditions (Sources 15922, 6940, 21188)."}, {"id": "rxn_010", "name": "Strecker synthesis step 2: hydrolysis of valine aminonitrile to valine", "inputs": ["mol_014", "mol_005"], "outputs": ["mol_015"], "environment": "Surface", "agents": ["montmorillonite (clay)", "TiO\u2082 (anatase)"], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "clay and mineral surfaces; mild heating", "aqueous": "true", "other": "Hydrolysis under warm surface conditions; UV irradiation from TiO\u2082 may assist"}, "mechanism": "The nitrile group (-C\u2261N) of 2-amino-3-methylbutanenitrile is hydrolyzed in two steps: first to the amide (2-amino-3-methylbutanamide), then to the carboxylic acid (valine). Water attacks the electrophilic carbon of the nitrile.", "reasoning": "Nitrile hydrolysis to carboxylic acids is thermodynamically favorable in aqueous solution, especially at elevated temperatures and in the presence of mineral surfaces. This completes the classical Strecker pathway to valine as demonstrated by Friedmann & Miller (1969) and Miller (1957). The B\u00fccherer-Bergs modification (via hydantoin intermediates) is an alternative hydrolytic route (Sources 985, 15922, 6940)."}, {"id": "rxn_011", "name": "Strecker synthesis of alanine from acetaldehyde", "inputs": ["mol_010", "mol_003", "mol_004"], "outputs": ["mol_016"], "environment": "Surface", "agents": ["montmorillonite (clay)"], "conditions": {"temperature": "300-340K", "pressure": "1 atm", "catalyst": "montmorillonite clay", "aqueous": "true", "other": "Evaporitic pool, neutral pH; combined Strecker aminonitrile formation and hydrolysis"}, "mechanism": "Acetaldehyde reacts with NH\u2083 to form an imine, which is attacked by cyanide to form \u03b1-aminopropionitrile. Subsequent hydrolysis yields alanine (2-aminopropanoic acid). This is a one-pot Strecker process.", "reasoning": "Alanine is one of the most readily synthesized amino acids via Strecker synthesis, as demonstrated in Miller's original spark discharge experiment (Miller, 1953) and subsequent work (Miller & Urey, 1959). Alanine serves as the amino group donor in the transamination route to valine (Sources 6940, 6943)."}, {"id": "rxn_012", "name": "Transamination of alpha-ketoisovalerate with alanine to valine", "inputs": ["mol_013", "mol_016"], "outputs": ["mol_015", "mol_009"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "none required (may be facilitated by metal ions Cu\u00b2\u207a or pyridoxal analogs)", "aqueous": "true", "other": "Prebiotic pool with concentrated amino acids and \u03b1-keto acids; may be enhanced by Fe\u00b2\u207a or Cu\u00b2\u207a ions as metal cofactors"}, "mechanism": "Alanine donates its amino group to \u03b1-ketoisovalerate in a transamination reaction, producing valine and regenerating pyruvate. The reaction proceeds via a Schiff base intermediate between the amino acid and a pyridoxal-like cofactor or metal ion mediator.", "reasoning": "Transamination between amino acids and \u03b1-keto acids is the biological route to valine and has been proposed as a prebiotically plausible process. This reaction connects prebiotic Strecker chemistry with proto-metabolic biochemistry. The literature highlights the evolutionary link between abiotic Strecker synthesis and modern transamination (Sources 6943, 6994). Pyruvate regeneration makes this pathway catalytic in pyruvate."}, {"id": "rxn_013", "name": "Iron-sulfur CO\u2082 reduction with H\u2082S to formate and organics", "inputs": ["mol_001", "mol_006"], "outputs": ["mol_008"], "environment": "Hydrothermal", "agents": ["pyrite (FeS\u2082)", "mackinawite (FeS)"], "conditions": {"temperature": "370-470K", "pressure": "high", "catalyst": "FeS/FeS\u2082", "aqueous": "true", "other": "Black smoker or subseafloor hydrothermal system; H\u2082S-rich vent fluid"}, "mechanism": "CO\u2082 is reduced at the surface of FeS/FeS\u2082 minerals using electrons derived from H\u2082S oxidation. The surface-bound CO\u2082 is reduced stepwise to formate. FeS acts as both electron donor and catalytic surface.", "reasoning": "Keefe et al. (1995) investigated CO\u2082 reduction with FeS/H\u2082S as a reducing agent and demonstrated organic acid formation. W\u00e4chtersh\u00e4user (1988, 1990) proposed the iron-sulfur world hypothesis where pyrite formation (FeS + H\u2082S \u2192 FeS\u2082 + 2H\u207a + 2e\u207b) provides reducing power for CO\u2082 fixation. This alternative CO\u2082 fixation route generates formate that feeds into the broader network (Sources 15950)."}], "pathways": [{"pathway_id": "P1", "name": "Hydrothermal CO\u2082 fixation \u2192 pyruvate \u2192 acetolactate \u2192 reductive amination to valine", "description": "Complete hydrothermal-to-surface pathway: CO\u2082 is fixed to pyruvate on magnetite/greigite in hydrothermal vents, pyruvate is decarboxylated to acetaldehyde, acetaldehyde and pyruvate undergo aldol condensation on clay surfaces to acetolactate, which decarboxylates to \u03b1-ketoisovalerate, and finally reductive amination on FeS produces valine.", "reaction_sequence": ["rxn_003", "rxn_004", "rxn_006", "rxn_007", "rxn_008"], "key_intermediates": ["mol_009", "mol_010", "mol_012", "mol_013"]}, {"pathway_id": "P2", "name": "Hydrothermal CO\u2082 fixation \u2192 pyruvate \u2192 acetolactate \u2192 transamination to valine", "description": "Same as P1 up to \u03b1-ketoisovalerate, but the final step is transamination with alanine (produced by Strecker synthesis) instead of reductive amination. Regenerates pyruvate, creating an autocatalytic loop.", "reaction_sequence": ["rxn_003", "rxn_004", "rxn_006", "rxn_007", "rxn_011", "rxn_012"], "key_intermediates": ["mol_009", "mol_010", "mol_012", "mol_013", "mol_016"]}, {"pathway_id": "P3", "name": "Fischer-Tropsch \u2192 isobutyraldehyde \u2192 Strecker synthesis to valine", "description": "CO is produced by reverse water-gas shift from CO\u2082, then Fischer-Tropsch-type synthesis on magnetite produces isobutyraldehyde directly. Strecker synthesis on the surface converts isobutyraldehyde to valine via the aminonitrile intermediate.", "reaction_sequence": ["rxn_002", "rxn_005", "rxn_009", "rxn_010"], "key_intermediates": ["mol_007", "mol_011", "mol_014"]}, {"pathway_id": "P4", "name": "FeS/H\u2082S CO\u2082 fixation \u2192 formate \u2192 pyruvate \u2192 acetolactate \u2192 reductive amination", "description": "Alternative CO\u2082 fixation via iron-sulfur world chemistry with H\u2082S as electron donor. Formate is produced, which feeds into pyruvate synthesis, then follows the acetolactate pathway to \u03b1-ketoisovalerate and reductive amination to valine.", "reaction_sequence": ["rxn_013", "rxn_003", "rxn_004", "rxn_006", "rxn_007", "rxn_008"], "key_intermediates": ["mol_008", "mol_009", "mol_010", "mol_012", "mol_013"]}, {"pathway_id": "P5", "name": "Greigite CO\u2082 reduction \u2192 formate \u2192 pyruvate \u2192 acetolactate \u2192 transamination", "description": "CO\u2082 is reduced to formate on greigite, followed by multi-step reduction to pyruvate. Pyruvate is decarboxylated to acetaldehyde, which enables both acetolactate formation (for \u03b1-ketoisovalerate) and Strecker synthesis of alanine. Transamination completes the valine synthesis.", "reaction_sequence": ["rxn_001", "rxn_003", "rxn_004", "rxn_006", "rxn_007", "rxn_011", "rxn_012"], "key_intermediates": ["mol_008", "mol_009", "mol_010", "mol_012", "mol_013", "mol_016"]}, {"pathway_id": "P6", "name": "Fischer-Tropsch acetaldehyde \u2192 alanine (Strecker) + acetolactate \u2192 transamination", "description": "Fischer-Tropsch synthesis provides acetaldehyde, which is used both for Strecker synthesis of alanine and for aldol condensation with pyruvate to form acetolactate. \u03b1-Ketoisovalerate from acetolactate undergoes transamination with alanine to yield valine.", "reaction_sequence": ["rxn_002", "rxn_005", "rxn_011", "rxn_003", "rxn_006", "rxn_007", "rxn_012"], "key_intermediates": ["mol_010", "mol_009", "mol_016", "mol_012", "mol_013"]}, {"pathway_id": "P7", "name": "Direct Strecker from hydrothermal isobutyraldehyde", "description": "Isobutyraldehyde produced in hydrothermal Fischer-Tropsch synthesis is transported to surface environments where it undergoes classical Strecker synthesis with HCN and NH\u2083 to form valine via the aminonitrile intermediate.", "reaction_sequence": ["rxn_005", "rxn_009", "rxn_010"], "key_intermediates": ["mol_011", "mol_014"]}, {"pathway_id": "P8", "name": "Pyruvate decarboxylation \u2192 acetaldehyde \u2192 Strecker alanine \u2192 transamination with hydrothermal \u03b1-ketoisovalerate", "description": "Pyruvate from hydrothermal CO\u2082 fixation is decarboxylated to acetaldehyde, which yields alanine via Strecker synthesis. Separately, hydrothermal pyruvate also feeds the acetolactate/\u03b1-ketoisovalerate pathway. Transamination between alanine and \u03b1-ketoisovalerate produces valine.", "reaction_sequence": ["rxn_003", "rxn_004", "rxn_011", "rxn_006", "rxn_007", "rxn_012"], "key_intermediates": ["mol_009", "mol_010", "mol_016", "mol_013"]}, {"pathway_id": "P9", "name": "FeS/H\u2082S pathway \u2192 pyruvate \u2192 acetolactate \u2192 \u03b1-ketoisovalerate \u2192 Strecker bypass via decarboxylation", "description": "Iron-sulfur CO\u2082 fixation produces formate then pyruvate. Through acetolactate, \u03b1-ketoisovalerate is formed. \u03b1-Ketoisovalerate can undergo non-enzymatic decarboxylation to regenerate isobutyraldehyde, which enters the Strecker pathway as an alternative terminal route to valine.", "reaction_sequence": ["rxn_013", "rxn_003", "rxn_004", "rxn_006", "rxn_007", "rxn_009", "rxn_010"], "key_intermediates": ["mol_008", "mol_009", "mol_012", "mol_013", "mol_011", "mol_014"]}, {"pathway_id": "P10", "name": "Convergent dual-environment pathway: hydrothermal reductive amination with surface-derived \u03b1-ketoisovalerate", "description": "Surface chemistry (aldol condensation of pyruvate and acetaldehyde on montmorillonite, followed by decarboxylation) produces \u03b1-ketoisovalerate, which is then transported back to hydrothermal vent environments where reductive amination on pyrite/mackinawite with vent-derived NH\u2083 and H\u2082 yields valine. Demonstrates bidirectional Hydrothermal \u2194 Surface flow.", "reaction_sequence": ["rxn_003", "rxn_004", "rxn_006", "rxn_007", "rxn_008"], "key_intermediates": ["mol_009", "mol_010", "mol_012", "mol_013"]}], "hub_molecules": ["mol_009", "mol_010", "mol_013", "mol_004", "mol_003"], "convergence_points": [{"molecule_id": "mol_009", "description": "Pyruvate is the central C3 metabolic hub, formed by hydrothermal CO\u2082 fixation and regenerated by transamination. It feeds into acetaldehyde production and acetolactate formation.", "incoming_reactions": ["rxn_003", "rxn_012"], "outgoing_reactions": ["rxn_004", "rxn_006"]}, {"molecule_id": "mol_010", "description": "Acetaldehyde is a C2 hub formed by both pyruvate decarboxylation and Fischer-Tropsch synthesis. It feeds into acetolactate formation (for \u03b1-ketoisovalerate) and Strecker synthesis of alanine.", "incoming_reactions": ["rxn_004", "rxn_005"], "outgoing_reactions": ["rxn_006", "rxn_011"]}, {"molecule_id": "mol_013", "description": "\u03b1-Ketoisovalerate is the immediate keto acid precursor to valine. It is formed exclusively from acetolactate decarboxylation and is the convergence point for the reductive amination, transamination, and potential decarboxylation-to-Strecker routes.", "incoming_reactions": ["rxn_007"], "outgoing_reactions": ["rxn_008", "rxn_012"]}, {"molecule_id": "mol_011", "description": "Isobutyraldehyde is the direct Strecker precursor for valine. It is produced by Fischer-Tropsch synthesis and potentially by \u03b1-ketoisovalerate decarboxylation, and feeds exclusively into Strecker aminonitrile formation.", "incoming_reactions": ["rxn_005"], "outgoing_reactions": ["rxn_009"]}, {"molecule_id": "mol_008", "description": "Formate is the first stable C1 product of CO\u2082 reduction, formed by both greigite-catalyzed hydrogenation and FeS/H\u2082S iron-sulfur chemistry. It feeds into further reduction toward pyruvate.", "incoming_reactions": ["rxn_001", "rxn_013"], "outgoing_reactions": ["rxn_003"]}]}, "reasoning": "", "duration_ms": 403125.90312957764, "success": true, "error_message": null}

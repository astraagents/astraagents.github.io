},\n    {\n      \"id\": \"mol_013\",\n      \"formula\": \"C5H9NO\",\n      \"iupac_name\": \"2-hydroxy-3-methylbutanenitrile\",\n      \"common_name\": \"Isobutyraldehyde cyanohydrin\",\n      \"inchi\": \"InChI=1S/C5H9NO/c1-3(2)4(7)5-6/h3-4,7H,1-2H3\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_014\",\n      \"formula\": \"C5H10O3\",\n      \"iupac_name\": \"2-hydroxy-3-methylbutanoic acid\",\n      \"common_name\": \"alpha-Hydroxyisovaleric acid\",\n      \"inchi\": \"InChI=1S/C5H10O3/c1-3(2)4(6)5(7)8/h3-4,6H,1-2H3,(H,7,8)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_015\",\n      \"formula\": \"C5H8O3\",\n      \"iupac_name\": \"3-methyl-2-oxobutanoic acid\",\n      \"common_name\": \"alpha-Ketoisovalerate\",\n      \"inchi\": \"InChI=1S/C5H8O3/c1-3(2)4(6)5(7)8/h3H,1-2H3,(H,7,8)\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_016\",\n      \"formula\": \"C3H7NO2\",\n      \"iupac_name\": \"2-aminopropanoic acid\",\n      \"common_name\": \"Alanine\",\n      \"inchi\": \"InChI=1S/C3H7NO2/c1-2(4)3(5)6/h2H,4H2,1H3,(H,5,6)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_017\",\n      \"formula\": \"C3H6N2\",\n      \"iupac_name\": \"2-aminopropanenitrile\",\n      \"common_name\": \"Alanine aminonitrile\",\n      \"inchi\": \"InChI=1S/C3H6N2/c1-2(4)3-5/h2H,4H2,1H3\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_018\",\n      \"formula\": \"C3H4O3\",\n      \"iupac_name\": \"2-oxopropanoic acid\",\n      \"common_name\": \"Pyruvate\",\n      \"inchi\": \"InChI=1S/C3H4O3/c1-2(4)3(5)6/h1H3,(H,5,6)\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_019\",\n      \"formula\": \"C5H11NO2\",\n      \"iupac_name\": \"2-amino-3-methylbutanoic acid\",\n      \"common_name\": \"Valine\",\n      \"inchi\": \"InChI=1S/C5H11NO2/c1-3(2)4(6)5(7)8/h3-4H,6H2,1-2H3,(H,7,8)\",\n      \"role\": \"target\",\n      \"environment_formed\": \"Biochemical\"\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"CO2 hydrogenation to formate on greigite\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_006\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe3S4)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high (50-100 bar)\",\n        \"catalyst\": \"greigite (Fe3S4)\",\n        \"aqueous\": \"true\",\n        \"other\": \"Alkaline hydrothermal vent conditions, pH 9-11, H2-rich fluids\"\n      },\n      \"mechanism\": \"CO2 is adsorbed on the Fe3S4 surface and undergoes two-electron reduction by H2 via surface-bound hydride to yield formate (HCOO-). The reaction is analogous to biological CO2 reduction by [Fe4S4]-containing formate dehydrogenase.\",\n      \"reasoning\": \"Greigite-catalyzed CO2 reduction to formate is well-established in prebiotic chemistry. Roldan et al. (2015) demonstrated that greigite surfaces can reduce CO2 to formate and methanol under alkaline hydrothermal conditions. This reaction is the first carbon fixation step in many origin-of-life models.\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Thermal dehydration of formate to CO\",\n      \"inputs\": [\"mol_006\"],\n      \"outputs\": [\"mol_007\", \"mol_005\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"pyrite (FeS2)\"],\n      \"conditions\": {\n        \"temperature\": \"400-450K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"pyrite (FeS2)\",\n        \"aqueous\": \"true\",\n        \"other\": \"Formate decomposition on pyrite surfaces in hydrothermal vent conduits\"\n      },\n      \"mechanism\": \"Formate adsorbs on pyrite surface via the carboxylate group. Thermal activation causes C-O bond cleavage and dehydration, releasing CO and H2O. Pyrite surface lowers the activation barrier for this decomposition.\",\n      \"reasoning\": \"Thermal decomposition of formate to CO and H2O is a well-documented reaction in hydrothermal geochemistry. McCollom and Seewald (2003) showed that formate and CO interconvert readily under hydrothermal conditions (T > 150\u00b0C). This provides an alternative CO source distinct from the reverse water-gas shift reaction.\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Reverse water-gas shift reaction on magnetite\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_007\", \"mol_005\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe3O4)\"],\n      \"conditions\": {\n        \"temperature\": \"450-500K\",\n        \"pressure\": \"high (100-300 bar)\",\n        \"catalyst\": \"magnetite (Fe3O4)\",\n        \"aqueous\": \"true\",\n        \"other\": \"Black smoker or high-T hydrothermal vent conditions\"\n      },\n      \"mechanism\": \"CO2 adsorbs on the magnetite (Fe3O4) surface and is reduced to CO by H2 via a surface redox mechanism involving Fe2+/Fe3+ cycling. Water is released as a byproduct. This is the reverse water-gas shift (RWGS) reaction.\",\n      \"reasoning\": \"The reverse water-gas shift reaction (CO2 + H2 \u2192 CO + H2O) is catalyzed by magnetite under hydrothermal conditions. This is a well-established reaction in Fischer-Tropsch-type (FTT) prebiotic chemistry (Shock and Schulte, 1998; McCollom et al., 1999). CO is the key C1 building block for downstream FTT synthesis of aldehydes.\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"Fischer-Tropsch synthesis of formaldehyde on magnetite\",\n      \"inputs\": [\"mol_007\", \"mol_002\"],\n      \"outputs\": [\"mol_008\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe3O4)\"],\n      \"conditions\": {\n        \"temperature\": \"400-500K\",\n        \"pressure\": \"high (100-300 bar)\",\n        \"catalyst\": \"magnetite (Fe3O4)\",\n        \"aqueous\": \"true\",\n        \"other\": \"Fischer-Tropsch-type conditions in hydrothermal vent systems\"\n      },\n      \"mechanism\": \"CO is hydrogenated on the magnetite surface via dissociative adsorption of H2. Sequential H addition to surface-bound CO yields a formyl intermediate, which can desorb as formaldehyde (HCHO) before further reduction to methanol or methane.\",\n      \"reasoning\": \"FTT synthesis of small oxygenated organics including formaldehyde on magnetite and other iron oxide/sulfide surfaces has been demonstrated experimentally. McCollom et al. (1999) showed production of C1-C3 oxygenated species from CO/H2 on magnetite at 175\u00b0C and 350 bar. Formaldehyde is a critical C1 feedstock for aldol and formose chemistry.\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"Fischer-Tropsch synthesis of acetaldehyde on magnetite\",\n      \"inputs\": [\"mol_007\", \"mol_002\"],\n      \"outputs\": [\"mol_009\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe3O4)\"],\n      \"conditions\": {\n        \"temperature\": \"400-500K\",\n        \"pressure\": \"high (100-300 bar)\",\n        \"catalyst\": \"magnetite (Fe3O4)\",\n        \"aqueous\": \"true\",\n        \"other\": \"Fischer-Tropsch-type conditions; C2 product of chain growth\"\n      },\n      \"mechanism\": \"Following CO activation on magnetite, C-C bond formation via CO insertion or CH2 insertion yields a C2 oxygenated intermediate. Partial hydrogenation leads to acetaldehyde (CH3CHO) as a C2 aldehyde product of the FTT product distribution.\",\n      \"reasoning\": \"Acetaldehyde is a well-characterized C2 product of FTT synthesis on iron oxide surfaces. McCollom et al. (1999) and Rushdi and Simoneit (2001) reported production of C1-C4 aldehydes including acetaldehyde from CO + H2 under hydrothermal FTT conditions. Acetaldehyde is a critical hub molecule for both Strecker synthesis of alanine and aldol routes to branched aldehydes.\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"Aldol condensation of formaldehyde and acetaldehyde to methacrolein\",\n      \"inputs\": [\"mol_008\", \"mol_009\"],\n      \"outputs\": [\"mol_010\", \"mol_005\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"apatite (phosphate mineral)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite clay surface\",\n        \"aqueous\": \"true\",\n        \"other\": \"Evaporitic pool or volcanic hot spring; base-catalyzed aldol + dehydration; phosphate mineral provides mild basicity\"\n      },\n      \"mechanism\": \"Formaldehyde attacks the alpha-carbon of acetaldehyde via enolization catalyzed on the clay surface. The aldol adduct (3-hydroxy-2-methylpropanal) rapidly dehydrates to yield methacrolein (2-methylprop-2-enal). Montmorillonite interlayer sites concentrate and orient the reactants, while phosphate provides basicity.\",\n      \"reasoning\": \"Aldol condensation is a fundamental prebiotic C-C bond forming reaction. Montmorillonite catalyzes aldol reactions by concentrating and orienting substrates in interlayer spaces (Ferris et al., 1996). The crossed aldol of formaldehyde with acetaldehyde is well-known to produce methacrolein (\u03b1,\u03b2-unsaturated aldehyde). This provides the branched C4 carbon skeleton needed for valine.\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Hydrogenation of methacrolein to isobutyraldehyde on mackinawite\",\n      \"inputs\": [\"mol_010\", \"mol_002\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mackinawite (FeS)\",\n        \"aqueous\": \"true\",\n        \"other\": \"Volcanic hot spring or geothermal surface environment with dissolved H2; FeS acts as hydrogenation catalyst\"\n      },\n      \"mechanism\": \"Methacrolein adsorbs on the mackinawite (FeS) surface via the conjugated C=C-C=O system. H2 undergoes heterolytic dissociation on FeS, and surface-bound hydride selectively reduces the C=C double bond (1,4-addition) to yield the saturated aldehyde isobutyraldehyde.\",\n      \"reasoning\": \"FeS and mackinawite surfaces are known to catalyze hydrogenation reactions under mild conditions. Heinen and Lauwers (1996) demonstrated FeS-mediated reductions of unsaturated organics. Selective conjugate reduction of \u03b1,\u03b2-unsaturated aldehydes to saturated aldehydes on metal sulfide surfaces is thermodynamically favorable. This route avoids the need for direct FTT production of branched aldehydes.\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Fischer-Tropsch synthesis of isobutyraldehyde (branched C4) on magnetite\",\n      \"inputs\": [\"mol_007\", \"mol_002\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe3O4)\", \"elemental iron (Fe0)\"],\n      \"conditions\": {\n        \"temperature\": \"400-500K\",\n        \"pressure\": \"high (100-300 bar)\",\n        \"catalyst\": \"magnetite (Fe3O4) with Fe0 promoter\",\n        \"aqueous\": \"true\",\n        \"other\": \"FTT conditions; branched aldehyde as minor product of Anderson-Schulz-Flory distribution\"\n      },\n      \"mechanism\": \"Under FTT conditions, CO/H2 undergo chain growth on magnetite surfaces. While linear products dominate, branched-chain aldehydes (including isobutyraldehyde) form as minor products via methyl-branch insertion during chain propagation. Fe0 acts as a co-catalyst providing additional reducing power.\",\n      \"reasoning\": \"FTT synthesis produces a distribution of products following the Anderson-Schulz-Flory distribution, including minor branched isomers. Rushdi and Simoneit (2001) reported branched hydrocarbons and oxygenates from FTT synthesis. While isobutyraldehyde is a minor product (~1-5% of C4 fraction), it provides a direct hydrothermal route to the valine precursor. Friedmann and Miller (1969) proposed that branched aldehydes available in prebiotic settings serve as direct Strecker precursors for branched amino acids like valine.\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"Strecker synthesis step 1: isobutyraldehyde aminonitrile formation\",\n      \"inputs\": [\"mol_011\", \"mol_003\", \"mol_004\"],\n      \"outputs\": [\"mol_012\", \"mol_005\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite clay surface\",\n        \"aqueous\": \"true\",\n        \"other\": \"Evaporitic pool with concentrated NH3 and HCN; mildly acidic to neutral pH (5-7)\"\n      },\n      \"mechanism\": \"Ammonia attacks the carbonyl of isobutyraldehyde to form a hemiaminal, which dehydrates to an imine (Schiff base). Nucleophilic addition of HCN (cyanide ion) to the imine yields 2-amino-3-methylbutanenitrile (valine aminonitrile). Montmorillonite surfaces concentrate and orient reactants.\",\n      \"reasoning\": \"The Strecker synthesis is the most experimentally validated prebiotic route to \u03b1-amino acids including valine. Friedmann and Miller (1969) demonstrated valine formation in simulated primitive Earth conditions via this pathway. Miller (1957) and subsequent work confirmed that aldehydes, NH3, and HCN react efficiently to produce \u03b1-aminonitriles under mild aqueous conditions. The research identifies this as the premier prebiotic route to valine (Sources 21188, 6940, 15634).\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"Strecker synthesis step 2: hydrolysis of valine aminonitrile to valine\",\n      \"inputs\": [\"mol_012\", \"mol_005\"],\n      \"outputs\": [\"mol_019\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"apatite (phosphate mineral)\"],\n      \"conditions\": {\n        \"temperature\": \"330-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite\",\n        \"aqueous\": \"true\",\n        \"other\": \"Wet-dry cycling in evaporitic pool; mild heating accelerates hydrolysis; slightly acidic conditions (pH 4-6) favor nitrile hydrolysis\"\n      },\n      \"mechanism\": \"The nitrile group of valine aminonitrile undergoes acid-catalyzed hydrolysis: CN + H2O \u2192 CONH2 (amide intermediate), then CONH2 + H2O \u2192 COOH + NH3. Two successive hydrations convert the nitrile to a carboxylic acid, yielding valine. The released NH3 is recycled in the system.\",\n      \"reasoning\": \"Aminonitrile hydrolysis is the established second step of the Strecker synthesis. Under mildly acidic aqueous conditions at moderate temperatures (60-100\u00b0C), hydrolysis proceeds efficiently through an amide intermediate. Friedmann and Miller (1969) demonstrated complete Strecker synthesis of valine from isobutyraldehyde. The literature confirms this as the primary terminal step in prebiotic valine formation (Sources 6940, 6943, 15922).\"\n    },\n    {\n      \"id\": \"rxn_011\",\n      \"name\": \"Cyanohydrin formation from isobutyraldehyde and HCN\",\n      \"inputs\": [\"mol_011\", \"mol_004\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"290-320K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite clay surface\",\n        \"aqueous\": \"true\",\n        \"other\": \"Neutral to mildly basic pH (7-9) favors cyanohydrin over aminonitrile in absence of NH3\"\n      },\n      \"mechanism\": \"Cyanide ion (CN-) attacks the electrophilic carbonyl carbon of isobutyraldehyde in a nucleophilic addition, yielding the cyanohydrin 2-hydroxy-3-methylbutanenitrile. This reaction is kinetically fast and thermodynamically favorable for aliphatic aldehydes.\",\n      \"reasoning\": \"Cyanohydrin formation is a fundamental prebiotic reaction that competes with Strecker aminonitrile formation depending on pH and NH3 concentration. In the absence of ammonia, HCN adds directly to aldehydes to form \u03b1-hydroxynitriles (Kiliani reaction). This provides an alternative pathway diverging from the Strecker route, connecting isobutyraldehyde to the \u03b1-keto acid pool via \u03b1-hydroxy acid intermediates (Sources 6943, 9376). The cyanohydrin pathway enables access to \u03b1-ketoisovalerate.\"\n    },\n    {\n      \"id\": \"rxn_012\",\n      \"name\": \"Hydrolysis of isobutyraldehyde cyanohydrin to alpha-hydroxyisovaleric acid\",\n      \"inputs\": [\"mol_013\", \"mol_005\"],\n      \"outputs\": [\"mol_014\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"apatite (phosphate mineral)\"],\n      \"conditions\": {\n        \"temperature\": \"320-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite\",\n        \"aqueous\": \"true\",\n        \"other\": \"Acidic aqueous conditions (pH 3-5) or wet-dry cycling to drive hydrolysis to completion\"\n      },\n      \"mechanism\": \"The nitrile group of the cyanohydrin undergoes stepwise acid-catalyzed hydrolysis: first to an amide (2-hydroxy-3-methylbutanamide), then to the corresponding \u03b1-hydroxy acid (2-hydroxy-3-methylbutanoic acid). Released ammonia is recycled.\",\n      \"reasoning\": \"Nitrile hydrolysis to carboxylic acids under mildly acidic aqueous conditions is well-established in prebiotic chemistry. This is mechanistically identical to the second step of Strecker synthesis but yields an \u03b1-hydroxy acid rather than an \u03b1-amino acid because the starting material bears an OH instead of NH2 at the alpha position. The \u03b1-hydroxy acid is the direct precursor to the corresponding \u03b1-keto acid via oxidation (Sources 6943, 6987).\"\n    },\n    {\n      \"id\": \"rxn_013\",\n      \"name\": \"UV photo-oxidation of alpha-hydroxyisovaleric acid to alpha-ketoisovalerate\",\n      \"inputs\": [\"mol_014\"],\n      \"outputs\": [\"mol_015\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase)\", \"stibnite (Sb2S3)\"],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO2 (anatase) photocatalyst\",\n        \"aqueous\": \"true\",\n        \"other\": \"UV irradiation (\u03bb < 300 nm, no ozone shield on early Earth); thin-film evaporitic conditions maximize UV exposure; Fe3+ as alternative electron acceptor\"\n      },\n      \"mechanism\": \"UV light generates electron-hole pairs on the TiO2 surface. The photogenerated hole (h+) oxidizes the \u03b1-hydroxy acid at the alpha-carbon, abstracting two electrons and one proton to convert the -CHOH- group to a -CO- (ketone/keto acid) group, yielding \u03b1-ketoisovalerate. Alternatively, dissolved Fe3+ can serve as oxidant under anoxic conditions.\",\n      \"reasoning\": \"Photochemical oxidation of \u03b1-hydroxy acids to \u03b1-keto acids is thermodynamically favorable and proceeds under UV irradiation on TiO2 semiconductor photocatalysts. The early Earth lacked an ozone layer, providing intense UV flux. TiO2 (anatase) is a common mineral photocatalyst found in geological settings. This reaction connects the cyanohydrin pathway to the biologically relevant \u03b1-keto acid pool. Keller et al. (2014) demonstrated that \u03b1-keto acids are central to non-enzymatic amino acid interconversions. The photochemical thioester synthesis described by Ritson et al. (2020) supports UV-driven prebiotic oxidations (Source 987).\"\n    },\n    {\n      \"id\": \"rxn_014\",\n      \"name\": \"Reductive amination of alpha-ketoisovalerate to valine\",\n      \"inputs\": [\"mol_015\", \"mol_003\", \"mol_002\"],\n      \"outputs\": [\"mol_019\", \"mol_005\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"FeS (mackinawite)\", \"Fe2+\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"Fe2+ ions and FeS as reducing agent\",\n        \"aqueous\": \"true\",\n        \"other\": \"Mildly acidic to neutral pH; FeS or dissolved H2 provides reducing equivalents; prebiotic pool with concentrated NH3\"\n      },\n      \"mechanism\": \"NH3 attacks the ketone carbonyl of \u03b1-ketoisovalerate to form a carbinolamine, which dehydrates to give an imine (Schiff base). The imine is then reduced by FeS-derived electrons (or dissolved H2 on mineral surfaces) to yield valine. Fe2+ ions coordinate the keto acid and lower the activation energy for imine formation.\",\n      \"reasoning\": \"Reductive amination of \u03b1-keto acids is the biological route to amino acids and has been demonstrated prebiotically. Keefe et al. (1995) showed amino acid formation from CO2 with FeS/H2S as reducing agents, implicitly going through \u03b1-keto acid intermediates (Source 15950). The explicit reducing agent (FeS + H2) addresses the issue from previous attempts where no reductant was specified. This reaction connects the \u03b1-keto acid pool directly to amino acid synthesis.\"\n    },\n    {\n      \"id\": \"rxn_015\",\n      \"name\": \"Strecker synthesis of alanine aminonitrile from acetaldehyde\",\n      \"inputs\": [\"mol_009\", \"mol_003\", \"mol_004\"],\n      \"outputs\": [\"mol_017\", \"mol_005\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite clay surface\",\n        \"aqueous\": \"true\",\n        \"other\": \"Evaporitic pool with NH3 and HCN; analogous to valine aminonitrile formation\"\n      },\n      \"mechanism\": \"Acetaldehyde condenses with NH3 to form an imine (CH3CH=NH), which undergoes cyanide addition to yield 2-aminopropanenitrile (alanine aminonitrile). Montmorillonite catalyzes by adsorbing and concentrating reactants.\",\n      \"reasoning\": \"Strecker synthesis of alanine from acetaldehyde is one of the best-studied prebiotic amino acid syntheses, demonstrated in the original Miller experiments (Miller, 1953; 1957). This provides the alanine needed for the transamination route to valine. Alanine is consistently one of the most abundant amino acids in spark discharge and prebiotic simulation experiments (Sources 15634, 15635, 6940).\"\n    },\n    {\n      \"id\": \"rxn_016\",\n      \"name\": \"Hydrolysis of alanine aminonitrile to alanine\",\n      \"inputs\": [\"mol_017\", \"mol_005\"],\n      \"outputs\": [\"mol_016\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite\", \"apatite (phosphate mineral)\"],\n      \"conditions\": {\n        \"temperature\": \"330-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite\",\n        \"aqueous\": \"true\",\n        \"other\": \"Acidic aqueous conditions; wet-dry cycling accelerates hydrolysis\"\n      },\n      \"mechanism\": \"The nitrile group of alanine aminonitrile is hydrolyzed via acid-catalyzed two-step process: nitrile \u2192 amide \u2192 carboxylic acid, yielding alanine and releasing NH3.\",\n      \"reasoning\": \"This is the standard second step of the Strecker synthesis. Miller and others demonstrated efficient conversion of aminonitriles to amino acids under mildly acidic aqueous conditions. This provides the alanine amino donor required for the transamination route to valine (Sources 6940, 6943).\"\n    },\n    {\n      \"id\": \"rxn_017\",\n      \"name\": \"Transamination of alpha-ketoisovalerate with alanine to valine and pyruvate\",\n      \"inputs\": [\"mol_015\", \"mol_016\"],\n      \"outputs\": [\"mol_019\", \"mol_018\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [\"Fe2+\", \"pyridoxal (or mineral analog)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"Fe2+ or Cu2+ ions; pyridoxal analog\",\n        \"aqueous\": \"true\",\n        \"other\": \"Prebiotic pool with concentrated amino acids and keto acids; metal ions serve as non-enzymatic catalysts\"\n      },\n      \"mechanism\": \"Alanine forms a Schiff base with pyridoxal (or a metal-ion-mediated Schiff base with the keto acid directly). Tautomerization of the aldimine to ketimine, followed by hydrolysis, transfers the amino group from alanine to \u03b1-ketoisovalerate, yielding valine and releasing pyruvate as the transamination co-product.\",\n      \"reasoning\": \"Non-enzymatic transamination between amino acids and \u03b1-keto acids has been demonstrated prebiotically. Keller et al. (2014) showed that \u03b1-keto acids undergo transamination with amino acids using Fe2+/3+ as catalysts without enzymes. This reaction mirrors extant biological valine biosynthesis (final step) and represents the continuity between prebiotic and biotic chemistry proposed by the literature (Sources 6943, 6994). Pyruvate release from transamination creates a proto-metabolic recycling loop.\"\n    },\n    {\n      \"id\": \"rxn_018\",\n      \"name\": \"Carbonyl insertion: acetaldehyde + CO to pyruvate on FeS/NiS\",\n      \"inputs\": [\"mol_009\", \"mol_007\"],\n      \"outputs\": [\"mol_018\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"mackinawite (FeS)\", \"NiS (millerite)\"],\n      \"conditions\": {\n        \"temperature\": \"370-420K\",\n        \"pressure\": \"high (100-200 bar)\",\n        \"catalyst\": \"FeS/NiS mixed sulfide surface\",\n        \"aqueous\": \"true\",\n        \"other\": \"W\u00e4chtersh\u00e4user-type carbonyl insertion on NiFeS surfaces; analogous to acetyl-CoA synthase mechanism\"\n      },\n      \"mechanism\": \"CO binds to Ni site on the NiFeS surface. Acetaldehyde (or its thioester equivalent) undergoes carbonyl insertion: CO inserts into the C-H bond of the methyl group of an activated acetyl intermediate, producing a C3 \u03b1-keto acid (pyruvate). This is analogous to the biological Wood-Ljungdahl pathway.\",\n      \"reasoning\": \"Cody et al. (2000) demonstrated formation of pyruvate and other \u03b1-keto acids from CO and simple organics on FeS/NiS surfaces at 250\u00b0C and 200 MPa. Huber and W\u00e4chtersh\u00e4user (1997) showed that CO insertion reactions on NiFeS surfaces produce activated acetyl groups. This multi-step process (broken down from the oversimplified 'CO2 \u2192 pyruvate' of previous attempts) provides a prebiotically grounded route to pyruvate as a C3 metabolic hub.\"\n    },\n    {\n      \"id\": \"rxn_019\",\n      \"name\": \"Thermal decarboxylation of pyruvate to acetaldehyde\",\n      \"inputs\": [\"mol_018\"],\n      \"outputs\": [\"mol_009\", \"mol_001\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"apatite (phosphate mineral)\", \"montmorillonite\"],\n      \"conditions\": {\n        \"temperature\": \"340-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"phosphate mineral surface\",\n        \"aqueous\": \"true\",\n        \"other\": \"Wet-dry cycling in evaporitic pool; mild heating drives decarboxylation; slightly acidic pH (4-6)\"\n      },\n      \"mechanism\": \"Pyruvate undergoes thermal \u03b2-decarboxylation: the \u03b1-keto acid loses CO2 from the carboxyl group, producing acetaldehyde. This is a well-known thermal reaction for \u03b1-keto acids that proceeds spontaneously at moderate temperatures. Phosphate minerals provide surface catalysis and acidic microenvironments.\",\n      \"reasoning\": \"Thermal decarboxylation of pyruvate to acetaldehyde and CO2 is a well-established prebiotic reaction. Cooper et al. (2011) identified pyruvic acid in carbonaceous meteorites (Source 15388), confirming its prebiotic relevance. Pyruvate decarboxylation creates a recycling loop: pyruvate from transamination (rxn_017) regenerates acetaldehyde, which can re-enter both the aldol pathway (rxn_006) and the alanine Strecker pathway (rxn_015), creating a self-sustaining proto-metabolic network.\"\n    }\n  ],\n  \"pathways\": [\n    {\n      \"pathway_id\": \"P1\",\n      \"name\": \"Formate-CO-Aldol-Strecker route to valine\",\n      \"description\": \"CO2 is reduced to formate on greigite, which thermally decomposes to CO. FTT synthesis on magnetite produces formaldehyde and acetaldehyde. Aldol condensation yields methacrolein, which is hydrogenated to isobutyraldehyde. Classical Strecker synthesis then converts isobutyraldehyde to valine via the aminonitrile intermediate.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_004\", \"rxn_005\", \"rxn_006\", \"rxn_007\", \"rxn_009\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_006\", \"mol_007\", \"mol_010\", \"mol_011\", \"mol_012\"]\n    },\n    {\n      \"pathway_id\": \"P2\",\n      \"name\": \"RWGS-CO-Aldol-Strecker route to valine\",\n      \"description\": \"CO2 is directly converted to CO via the reverse water-gas shift reaction on magnetite at higher temperatures. FTT synthesis then produces formaldehyde and acetaldehyde. Aldol condensation yields methacrolein, hydrogenated to isobutyraldehyde. Strecker synthesis produces valine.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_004\", \"rxn_005\", \"rxn_006\", \"rxn_007\", \"rxn_009\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_008\", \"mol_009\", \"mol_010\", \"mol_011\", \"mol_012\"]\n    },\n    {\n      \"pathway_id\": \"P3\",\n      \"name\": \"Direct FTT isobutyraldehyde-Strecker route\",\n      \"description\": \"CO is produced via RWGS. Direct FTT synthesis on magnetite produces isobutyraldehyde as a minor branched C4 product. Strecker synthesis on the surface converts it to valine via the aminonitrile.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_008\", \"rxn_009\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_011\", \"mol_012\"]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"Formate-CO-FTT-branched-Strecker short route\",\n      \"description\": \"CO2 is reduced to formate then to CO via the two-step hydrothermal route. FTT produces branched isobutyraldehyde directly. Strecker synthesis completes valine formation.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_008\", \"rxn_009\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_006\", \"mol_007\", \"mol_011\", \"mol_012\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"Aldol-Cyanohydrin-Reductive amination route\",\n      \"description\": \"CO is produced via RWGS. FTT yields formaldehyde and acetaldehyde. Aldol condensation and hydrogenation give isobutyraldehyde. Instead of Strecker, isobutyraldehyde reacts with HCN to form a cyanohydrin, which is hydrolyzed to \u03b1-hydroxyisovaleric acid, UV-oxidized to \u03b1-ketoisovalerate, and finally reduced to valine via reductive amination with NH3 and FeS.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_004\", \"rxn_005\", \"rxn_006\", \"rxn_007\", \"rxn_011\", \"rxn_012\", \"rxn_013\", \"rxn_014\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_010\", \"mol_011\", \"mol_013\", \"mol_014\", \"mol_015\"]\n    },\n    {\n      \"pathway_id\": \"P6\",\n      \"name\": \"Direct FTT-Cyanohydrin-Reductive amination route\",\n      \"description\": \"CO from RWGS produces isobutyraldehyde via direct FTT branching. Cyanohydrin formation, hydrolysis, and UV photo-oxidation yield \u03b1-ketoisovalerate. Reductive amination with NH3 and H2/FeS gives valine.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_008\", \"rxn_011\", \"rxn_012\", \"rxn_013\", \"rxn_014\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_011\", \"mol_013\", \"mol_014\", \"mol_015\"]\n    },\n    {\n      \"pathway_id\": \"P7\",\n      \"name\": \"Aldol-Cyanohydrin-Transamination route via Strecker alanine\",\n      \"description\": \"Two hydrothermal streams converge: (1) FTT formaldehyde + acetaldehyde \u2192 methacrolein \u2192 isobutyraldehyde \u2192 cyanohydrin \u2192 \u03b1-hydroxy acid \u2192 \u03b1-ketoisovalerate; (2) FTT acetaldehyde \u2192 Strecker alanine. Transamination of \u03b1-ketoisovalerate with alanine yields valine + pyruvate.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_004\", \"rxn_005\", \"rxn_006\", \"rxn_007\", \"rxn_011\", \"rxn_012\", \"rxn_013\", \"rxn_015\", \"rxn_016\", \"rxn_017\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_009\", \"mol_011\", \"mol_015\", \"mol_016\"]\n    },\n    {\n      \"pathway_id\": \"P8\",\n      \"name\": \"Direct FTT-Cyanohydrin-Transamination route\",\n      \"description\": \"FTT directly produces both isobutyraldehyde (branched) and acetaldehyde. Isobutyraldehyde enters the cyanohydrin pathway to \u03b1-ketoisovalerate. Acetaldehyde enters the Strecker pathway to alanine. Transamination of the two products yields valine and pyruvate.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_005\", \"rxn_008\", \"rxn_011\", \"rxn_012\", \"rxn_013\", \"rxn_015\", \"rxn_016\", \"rxn_017\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_009\", \"mol_011\", \"mol_015\", \"mol_016\"]\n    },\n    {\n      \"pathway_id\": \"P9\",\n      \"name\": \"Pyruvate carbonyl-insertion recycling Strecker route\",\n      \"description\": \"Acetaldehyde and CO undergo carbonyl insertion on NiFeS to form pyruvate. Pyruvate is thermally decarboxylated to regenerate acetaldehyde + CO2 on the surface. This recycled acetaldehyde feeds aldol condensation with formaldehyde to produce methacrolein \u2192 isobutyraldehyde \u2192 Strecker valine. Demonstrates proto-metabolic cycling.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_005\", \"rxn_018\", \"rxn_019\", \"rxn_004\", \"rxn_006\", \"rxn_007\", \"rxn_009\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_009\", \"mol_018\", \"mol_010\", \"mol_011\", \"mol_012\"]\n    },\n    {\n      \"pathway_id\": \"P10\",\n      \"name\": \"Autocatalytic transamination loop with pyruvate recycling\",\n      \"description\": \"The most complex pathway creating a self-sustaining loop. Pyruvate formed by carbonyl insertion (rxn_018) is decarboxylated to acetaldehyde (rxn_019). Acetaldehyde feeds Strecker alanine synthesis. Meanwhile, isobutyraldehyde from FTT or aldol enters the cyanohydrin pathway to \u03b1-ketoisovalerate. Transamination of \u03b1-ketoisovalerate with alanine yields valine + pyruvate. The pyruvate product feeds back into decarboxylation (rxn_019), regenerating acetaldehyde for the next cycle. This creates a proto-metabolic autocatalytic network.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_005\", \"rxn_018\", \"rxn_019\", \"rxn_015\", \"rxn_016\", \"rxn_008\", \"rxn_011\", \"rxn_012\", \"rxn_013\", \"rxn_017\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_009\", \"mol_018\", \"mol_011\", \"mol_015\", \"mol_016\"]\n    }\n  ],\n  \"hub_molecules\": [\"mol_007\", \"mol_009\", \"mol_011\", \"mol_004\", \"mol_015\"],\n  \"convergence_points\": [\n    {\n      \"molecule_id\": \"mol_007\",\n      \"description\": \"Carbon monoxide - central C1 building block produced by two hydrothermal routes and consumed by four distinct reactions\",\n      \"incoming_reactions\": [\"rxn_002\", \"rxn_003\"],\n      \"outgoing_reactions\": [\"rxn_004\", \"rxn_005\", \"rxn_008\", \"rxn_018\"]\n    },\n    {\n      \"molecule_id\": \"mol_009\",\n      \"description\": \"Acetaldehyde - C2 hub produced by FTT and pyruvate decarboxylation, consumed by aldol, Strecker alanine, and carbonyl insertion\",\n      \"incoming_reactions\": [\"rxn_005\", \"rxn_019\"],\n      \"outgoing_reactions\": [\"rxn_006\", \"rxn_015\", \"rxn_018\"]\n    },\n    {\n      \"molecule_id\": \"mol_011\",\n      \"description\": \"Isobutyraldehyde - branched C4 aldehyde hub produced by two routes (aldol hydrogenation and direct FTT), feeds both Strecker and cyanohydrin pathways\",\n      \"incoming_reactions\": [\"rxn_007\", \"rxn_008\"],\n      \"outgoing_reactions\": [\"rxn_009\", \"rxn_011\"]\n    },\n    {\n      \"molecule_id\": \"mol_004\",\n      \"description\": \"Hydrogen cyanide - key nitrogen/carbon source consumed by three nucleophilic addition reactions (valine Strecker, cyanohydrin, alanine Strecker)\",\n      \"incoming_reactions\": [],\n      \"outgoing_reactions\": [\"rxn_009\", \"rxn_011\", \"rxn_015\"]\n    },\n    {\n      \"molecule_id\": \"mol_015\",\n      \"description\": \"alpha-Ketoisovalerate - biologically relevant C5 \u03b1-keto acid produced by UV photo-oxidation, consumed by two terminal routes (reductive amination and transamination) to valine\",\n      \"incoming_reactions\": [\"rxn_013\"],\n      \"outgoing_reactions\": [\"rxn_014\", \"rxn_017\"]\n    }\n  ]\n}", "parsed_response": {"target_molecule": "Valine", "overall_strategy": "This network constructs valine (C5H11NO2) from simple C1 feedstocks (CO2, H2, HCN, NH3) through three interconnected prebiotic environments. Hydrothermal vent chemistry reduces CO2 to formate and CO via greigite and magnetite catalysis, then Fischer-Tropsch-type (FTT) synthesis on magnetite produces formaldehyde and acetaldehyde (C1-C2 aldehydes). The critical C4 branched-chain precursor isobutyraldehyde is generated via two independent routes: (1) aldol condensation of formaldehyde + acetaldehyde to methacrolein followed by surface hydrogenation, and (2) direct FTT branched-product formation. Surface chemistry then diverges into three terminal routes to valine: (A) classical Strecker synthesis via valine aminonitrile, (B) cyanohydrin pathway to \u03b1-ketoisovalerate followed by reductive amination, and (C) cyanohydrin pathway to \u03b1-ketoisovalerate followed by transamination with Strecker-derived alanine. A pyruvate node generated by carbonyl insertion and regenerated by transamination creates a proto-metabolic recycling loop. All hydrothermal and surface reactions specify mineral catalysts consistent with literature.", "molecules": [{"id": "mol_001", "formula": "CO2", "iupac_name": "carbon dioxide", "common_name": "Carbon dioxide", "inchi": "InChI=1S/CO2/c2-1-3", "role": "starting", "environment_formed": null}, {"id": "mol_002", "formula": "H2", "iupac_name": "molecular hydrogen", "common_name": "Hydrogen", "inchi": "InChI=1S/H2/h1H", "role": "starting", "environment_formed": null}, {"id": "mol_003", "formula": "NH3", "iupac_name": "azane", "common_name": "Ammonia", "inchi": "InChI=1S/H3N/h1H3", "role": "starting", "environment_formed": null}, {"id": "mol_004", "formula": "HCN", "iupac_name": "formonitrile", "common_name": "Hydrogen cyanide", "inchi": "InChI=1S/CHN/c1-2/h1H", "role": "hub_intermediate", "environment_formed": null}, {"id": "mol_005", "formula": "H2O", "iupac_name": "oxidane", "common_name": "Water", "inchi": "InChI=1S/H2O/h1H2", "role": "starting", "environment_formed": null}, {"id": "mol_006", "formula": "CH2O2", "iupac_name": "formic acid", "common_name": "Formate", "inchi": "InChI=1S/CH2O2/c2-1-3/h1H,(H,2,3)", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_007", "formula": "CO", "iupac_name": "carbon monoxide", "common_name": "Carbon monoxide", "inchi": "InChI=1S/CO/c1-2", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_008", "formula": "CH2O", "iupac_name": "methanal", "common_name": "Formaldehyde", "inchi": "InChI=1S/CH2O/c1-2/h1H2", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_009", "formula": "C2H4O", "iupac_name": "acetaldehyde", "common_name": "Acetaldehyde", "inchi": "InChI=1S/C2H4O/c1-2-3/h2H,1H3", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_010", "formula": "C4H6O", "iupac_name": "2-methylprop-2-enal", "common_name": "Methacrolein", "inchi": "InChI=1S/C4H6O/c1-3(2)4-5/h4H,1H2,2H3", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_011", "formula": "C4H8O", "iupac_name": "2-methylpropanal", "common_name": "Isobutyraldehyde", "inchi": "InChI=1S/C4H8O/c1-3(2)4-5/h3-4H,1-2H3", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_012", "formula": "C5H10N2", "iupac_name": "2-amino-3-methylbutanenitrile", "common_name": "Valine aminonitrile", "inchi": "InChI=1S/C5H10N2/c1-3(2)4(6)5-7/h3-4H,6H2,1-2H3", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_013", "formula": "C5H9NO", "iupac_name": "2-hydroxy-3-methylbutanenitrile", "common_name": "Isobutyraldehyde cyanohydrin", "inchi": "InChI=1S/C5H9NO/c1-3(2)4(7)5-6/h3-4,7H,1-2H3", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_014", "formula": "C5H10O3", "iupac_name": "2-hydroxy-3-methylbutanoic acid", "common_name": "alpha-Hydroxyisovaleric acid", "inchi": "InChI=1S/C5H10O3/c1-3(2)4(6)5(7)8/h3-4,6H,1-2H3,(H,7,8)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_015", "formula": "C5H8O3", "iupac_name": "3-methyl-2-oxobutanoic acid", "common_name": "alpha-Ketoisovalerate", "inchi": "InChI=1S/C5H8O3/c1-3(2)4(6)5(7)8/h3H,1-2H3,(H,7,8)", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_016", "formula": "C3H7NO2", "iupac_name": "2-aminopropanoic acid", "common_name": "Alanine", "inchi": "InChI=1S/C3H7NO2/c1-2(4)3(5)6/h2H,4H2,1H3,(H,5,6)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_017", "formula": "C3H6N2", "iupac_name": "2-aminopropanenitrile", "common_name": "Alanine aminonitrile", "inchi": "InChI=1S/C3H6N2/c1-2(4)3-5/h2H,4H2,1H3", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_018", "formula": "C3H4O3", "iupac_name": "2-oxopropanoic acid", "common_name": "Pyruvate", "inchi": "InChI=1S/C3H4O3/c1-2(4)3(5)6/h1H3,(H,5,6)", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_019", "formula": "C5H11NO2", "iupac_name": "2-amino-3-methylbutanoic acid", "common_name": "Valine", "inchi": "InChI=1S/C5H11NO2/c1-3(2)4(6)5(7)8/h3-4H,6H2,1-2H3,(H,7,8)", "role": "target", "environment_formed": "Biochemical"}], "reactions": [{"id": "rxn_001", "name": "CO2 hydrogenation to formate on greigite", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_006"], "environment": "Hydrothermal", "agents": ["greigite (Fe3S4)"], "conditions": {"temperature": "350-400K", "pressure": "high (50-100 bar)", "catalyst": "greigite (Fe3S4)", "aqueous": "true", "other": "Alkaline hydrothermal vent conditions, pH 9-11, H2-rich fluids"}, "mechanism": "CO2 is adsorbed on the Fe3S4 surface and undergoes two-electron reduction by H2 via surface-bound hydride to yield formate (HCOO-). The reaction is analogous to biological CO2 reduction by [Fe4S4]-containing formate dehydrogenase.", "reasoning": "Greigite-catalyzed CO2 reduction to formate is well-established in prebiotic chemistry. Roldan et al. (2015) demonstrated that greigite surfaces can reduce CO2 to formate and methanol under alkaline hydrothermal conditions. This reaction is the first carbon fixation step in many origin-of-life models."}, {"id": "rxn_002", "name": "Thermal dehydration of formate to CO", "inputs": ["mol_006"], "outputs": ["mol_007", "mol_005"], "environment": "Hydrothermal", "agents": ["pyrite (FeS2)"], "conditions": {"temperature": "400-450K", "pressure": "high", "catalyst": "pyrite (FeS2)", "aqueous": "true", "other": "Formate decomposition on pyrite surfaces in hydrothermal vent conduits"}, "mechanism": "Formate adsorbs on pyrite surface via the carboxylate group. Thermal activation causes C-O bond cleavage and dehydration, releasing CO and H2O. Pyrite surface lowers the activation barrier for this decomposition.", "reasoning": "Thermal decomposition of formate to CO and H2O is a well-documented reaction in hydrothermal geochemistry. McCollom and Seewald (2003) showed that formate and CO interconvert readily under hydrothermal conditions (T > 150\u00b0C). This provides an alternative CO source distinct from the reverse water-gas shift reaction."}, {"id": "rxn_003", "name": "Reverse water-gas shift reaction on magnetite", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_007", "mol_005"], "environment": "Hydrothermal", "agents": ["magnetite (Fe3O4)"], "conditions": {"temperature": "450-500K", "pressure": "high (100-300 bar)", "catalyst": "magnetite (Fe3O4)", "aqueous": "true", "other": "Black smoker or high-T hydrothermal vent conditions"}, "mechanism": "CO2 adsorbs on the magnetite (Fe3O4) surface and is reduced to CO by H2 via a surface redox mechanism involving Fe2+/Fe3+ cycling. Water is released as a byproduct. This is the reverse water-gas shift (RWGS) reaction.", "reasoning": "The reverse water-gas shift reaction (CO2 + H2 \u2192 CO + H2O) is catalyzed by magnetite under hydrothermal conditions. This is a well-established reaction in Fischer-Tropsch-type (FTT) prebiotic chemistry (Shock and Schulte, 1998; McCollom et al., 1999). CO is the key C1 building block for downstream FTT synthesis of aldehydes."}, {"id": "rxn_004", "name": "Fischer-Tropsch synthesis of formaldehyde on magnetite", "inputs": ["mol_007", "mol_002"], "outputs": ["mol_008"], "environment": "Hydrothermal", "agents": ["magnetite (Fe3O4)"], "conditions": {"temperature": "400-500K", "pressure": "high (100-300 bar)", "catalyst": "magnetite (Fe3O4)", "aqueous": "true", "other": "Fischer-Tropsch-type conditions in hydrothermal vent systems"}, "mechanism": "CO is hydrogenated on the magnetite surface via dissociative adsorption of H2. Sequential H addition to surface-bound CO yields a formyl intermediate, which can desorb as formaldehyde (HCHO) before further reduction to methanol or methane.", "reasoning": "FTT synthesis of small oxygenated organics including formaldehyde on magnetite and other iron oxide/sulfide surfaces has been demonstrated experimentally. McCollom et al. (1999) showed production of C1-C3 oxygenated species from CO/H2 on magnetite at 175\u00b0C and 350 bar. Formaldehyde is a critical C1 feedstock for aldol and formose chemistry."}, {"id": "rxn_005", "name": "Fischer-Tropsch synthesis of acetaldehyde on magnetite", "inputs": ["mol_007", "mol_002"], "outputs": ["mol_009"], "environment": "Hydrothermal", "agents": ["magnetite (Fe3O4)"], "conditions": {"temperature": "400-500K", "pressure": "high (100-300 bar)", "catalyst": "magnetite (Fe3O4)", "aqueous": "true", "other": "Fischer-Tropsch-type conditions; C2 product of chain growth"}, "mechanism": "Following CO activation on magnetite, C-C bond formation via CO insertion or CH2 insertion yields a C2 oxygenated intermediate. Partial hydrogenation leads to acetaldehyde (CH3CHO) as a C2 aldehyde product of the FTT product distribution.", "reasoning": "Acetaldehyde is a well-characterized C2 product of FTT synthesis on iron oxide surfaces. McCollom et al. (1999) and Rushdi and Simoneit (2001) reported production of C1-C4 aldehydes including acetaldehyde from CO + H2 under hydrothermal FTT conditions. Acetaldehyde is a critical hub molecule for both Strecker synthesis of alanine and aldol routes to branched aldehydes."}, {"id": "rxn_006", "name": "Aldol condensation of formaldehyde and acetaldehyde to methacrolein", "inputs": ["mol_008", "mol_009"], "outputs": ["mol_010", "mol_005"], "environment": "Surface", "agents": ["montmorillonite", "apatite (phosphate mineral)"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "montmorillonite clay surface", "aqueous": "true", "other": "Evaporitic pool or volcanic hot spring; base-catalyzed aldol + dehydration; phosphate mineral provides mild basicity"}, "mechanism": "Formaldehyde attacks the alpha-carbon of acetaldehyde via enolization catalyzed on the clay surface. The aldol adduct (3-hydroxy-2-methylpropanal) rapidly dehydrates to yield methacrolein (2-methylprop-2-enal). Montmorillonite interlayer sites concentrate and orient the reactants, while phosphate provides basicity.", "reasoning": "Aldol condensation is a fundamental prebiotic C-C bond forming reaction. Montmorillonite catalyzes aldol reactions by concentrating and orienting substrates in interlayer spaces (Ferris et al., 1996). The crossed aldol of formaldehyde with acetaldehyde is well-known to produce methacrolein (\u03b1,\u03b2-unsaturated aldehyde). This provides the branched C4 carbon skeleton needed for valine."}, {"id": "rxn_007", "name": "Hydrogenation of methacrolein to isobutyraldehyde on mackinawite", "inputs": ["mol_010", "mol_002"], "outputs": ["mol_011"], "environment": "Surface", "agents": ["mackinawite (FeS)"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "mackinawite (FeS)", "aqueous": "true", "other": "Volcanic hot spring or geothermal surface environment with dissolved H2; FeS acts as hydrogenation catalyst"}, "mechanism": "Methacrolein adsorbs on the mackinawite (FeS) surface via the conjugated C=C-C=O system. H2 undergoes heterolytic dissociation on FeS, and surface-bound hydride selectively reduces the C=C double bond (1,4-addition) to yield the saturated aldehyde isobutyraldehyde.", "reasoning": "FeS and mackinawite surfaces are known to catalyze hydrogenation reactions under mild conditions. Heinen and Lauwers (1996) demonstrated FeS-mediated reductions of unsaturated organics. Selective conjugate reduction of \u03b1,\u03b2-unsaturated aldehydes to saturated aldehydes on metal sulfide surfaces is thermodynamically favorable. This route avoids the need for direct FTT production of branched aldehydes."}, {"id": "rxn_008", "name": "Fischer-Tropsch synthesis of isobutyraldehyde (branched C4) on magnetite", "inputs": ["mol_007", "mol_002"], "outputs": ["mol_011"], "environment": "Hydrothermal", "agents": ["magnetite (Fe3O4)", "elemental iron (Fe0)"], "conditions": {"temperature": "400-500K", "pressure": "high (100-300 bar)", "catalyst": "magnetite (Fe3O4) with Fe0 promoter", "aqueous": "true", "other": "FTT conditions; branched aldehyde as minor product of Anderson-Schulz-Flory distribution"}, "mechanism": "Under FTT conditions, CO/H2 undergo chain growth on magnetite surfaces. While linear products dominate, branched-chain aldehydes (including isobutyraldehyde) form as minor products via methyl-branch insertion during chain propagation. Fe0 acts as a co-catalyst providing additional reducing power.", "reasoning": "FTT synthesis produces a distribution of products following the Anderson-Schulz-Flory distribution, including minor branched isomers. Rushdi and Simoneit (2001) reported branched hydrocarbons and oxygenates from FTT synthesis. While isobutyraldehyde is a minor product (~1-5% of C4 fraction), it provides a direct hydrothermal route to the valine precursor. Friedmann and Miller (1969) proposed that branched aldehydes available in prebiotic settings serve as direct Strecker precursors for branched amino acids like valine."}, {"id": "rxn_009", "name": "Strecker synthesis step 1: isobutyraldehyde aminonitrile formation", "inputs": ["mol_011", "mol_003", "mol_004"], "outputs": ["mol_012", "mol_005"], "environment": "Surface", "agents": ["montmorillonite"], "conditions": {"temperature": "300-340K", "pressure": "1 atm", "catalyst": "montmorillonite clay surface", "aqueous": "true", "other": "Evaporitic pool with concentrated NH3 and HCN; mildly acidic to neutral pH (5-7)"}, "mechanism": "Ammonia attacks the carbonyl of isobutyraldehyde to form a hemiaminal, which dehydrates to an imine (Schiff base). Nucleophilic addition of HCN (cyanide ion) to the imine yields 2-amino-3-methylbutanenitrile (valine aminonitrile). Montmorillonite surfaces concentrate and orient reactants.", "reasoning": "The Strecker synthesis is the most experimentally validated prebiotic route to \u03b1-amino acids including valine. Friedmann and Miller (1969) demonstrated valine formation in simulated primitive Earth conditions via this pathway. Miller (1957) and subsequent work confirmed that aldehydes, NH3, and HCN react efficiently to produce \u03b1-aminonitriles under mild aqueous conditions. The research identifies this as the premier prebiotic route to valine (Sources 21188, 6940, 15634)."}, {"id": "rxn_010", "name": "Strecker synthesis step 2: hydrolysis of valine aminonitrile to valine", "inputs": ["mol_012", "mol_005"], "outputs": ["mol_019"], "environment": "Surface", "agents": ["montmorillonite", "apatite (phosphate mineral)"], "conditions": {"temperature": "330-370K", "pressure": "1 atm", "catalyst": "montmorillonite", "aqueous": "true", "other": "Wet-dry cycling in evaporitic pool; mild heating accelerates hydrolysis; slightly acidic conditions (pH 4-6) favor nitrile hydrolysis"}, "mechanism": "The nitrile group of valine aminonitrile undergoes acid-catalyzed hydrolysis: CN + H2O \u2192 CONH2 (amide intermediate), then CONH2 + H2O \u2192 COOH + NH3. Two successive hydrations convert the nitrile to a carboxylic acid, yielding valine. The released NH3 is recycled in the system.", "reasoning": "Aminonitrile hydrolysis is the established second step of the Strecker synthesis. Under mildly acidic aqueous conditions at moderate temperatures (60-100\u00b0C), hydrolysis proceeds efficiently through an amide intermediate. Friedmann and Miller (1969) demonstrated complete Strecker synthesis of valine from isobutyraldehyde. The literature confirms this as the primary terminal step in prebiotic valine formation (Sources 6940, 6943, 15922)."}, {"id": "rxn_011", "name": "Cyanohydrin formation from isobutyraldehyde and HCN", "inputs": ["mol_011", "mol_004"], "outputs": ["mol_013"], "environment": "Surface", "agents": ["montmorillonite"], "conditions": {"temperature": "290-320K", "pressure": "1 atm", "catalyst": "montmorillonite clay surface", "aqueous": "true", "other": "Neutral to mildly basic pH (7-9) favors cyanohydrin over aminonitrile in absence of NH3"}, "mechanism": "Cyanide ion (CN-) attacks the electrophilic carbonyl carbon of isobutyraldehyde in a nucleophilic addition, yielding the cyanohydrin 2-hydroxy-3-methylbutanenitrile. This reaction is kinetically fast and thermodynamically favorable for aliphatic aldehydes.", "reasoning": "Cyanohydrin formation is a fundamental prebiotic reaction that competes with Strecker aminonitrile formation depending on pH and NH3 concentration. In the absence of ammonia, HCN adds directly to aldehydes to form \u03b1-hydroxynitriles (Kiliani reaction). This provides an alternative pathway diverging from the Strecker route, connecting isobutyraldehyde to the \u03b1-keto acid pool via \u03b1-hydroxy acid intermediates (Sources 6943, 9376). The cyanohydrin pathway enables access to \u03b1-ketoisovalerate."}, {"id": "rxn_012", "name": "Hydrolysis of isobutyraldehyde cyanohydrin to alpha-hydroxyisovaleric acid", "inputs": ["mol_013", "mol_005"], "outputs": ["mol_014"], "environment": "Surface", "agents": ["montmorillonite", "apatite (phosphate mineral)"], "conditions": {"temperature": "320-370K", "pressure": "1 atm", "catalyst": "montmorillonite", "aqueous": "true", "other": "Acidic aqueous conditions (pH 3-5) or wet-dry cycling to drive hydrolysis to completion"}, "mechanism": "The nitrile group of the cyanohydrin undergoes stepwise acid-catalyzed hydrolysis: first to an amide (2-hydroxy-3-methylbutanamide), then to the corresponding \u03b1-hydroxy acid (2-hydroxy-3-methylbutanoic acid). Released ammonia is recycled.", "reasoning": "Nitrile hydrolysis to carboxylic acids under mildly acidic aqueous conditions is well-established in prebiotic chemistry. This is mechanistically identical to the second step of Strecker synthesis but yields an \u03b1-hydroxy acid rather than an \u03b1-amino acid because the starting material bears an OH instead of NH2 at the alpha position. The \u03b1-hydroxy acid is the direct precursor to the corresponding \u03b1-keto acid via oxidation (Sources 6943, 6987)."}, {"id": "rxn_013", "name": "UV photo-oxidation of alpha-hydroxyisovaleric acid to alpha-ketoisovalerate", "inputs": ["mol_014"], "outputs": ["mol_015"], "environment": "Surface", "agents": ["TiO2 (anatase)", "stibnite (Sb2S3)"], "conditions": {"temperature": "300-340K", "pressure": "1 atm", "catalyst": "TiO2 (anatase) photocatalyst", "aqueous": "true", "other": "UV irradiation (\u03bb < 300 nm, no ozone shield on early Earth); thin-film evaporitic conditions maximize UV exposure; Fe3+ as alternative electron acceptor"}, "mechanism": "UV light generates electron-hole pairs on the TiO2 surface. The photogenerated hole (h+) oxidizes the \u03b1-hydroxy acid at the alpha-carbon, abstracting two electrons and one proton to convert the -CHOH- group to a -CO- (ketone/keto acid) group, yielding \u03b1-ketoisovalerate. Alternatively, dissolved Fe3+ can serve as oxidant under anoxic conditions.", "reasoning": "Photochemical oxidation of \u03b1-hydroxy acids to \u03b1-keto acids is thermodynamically favorable and proceeds under UV irradiation on TiO2 semiconductor photocatalysts. The early Earth lacked an ozone layer, providing intense UV flux. TiO2 (anatase) is a common mineral photocatalyst found in geological settings. This reaction connects the cyanohydrin pathway to the biologically relevant \u03b1-keto acid pool. Keller et al. (2014) demonstrated that \u03b1-keto acids are central to non-enzymatic amino acid interconversions. The photochemical thioester synthesis described by Ritson et al. (2020) supports UV-driven prebiotic oxidations (Source 987)."}, {"id": "rxn_014", "name": "Reductive amination of alpha-ketoisovalerate to valine", "inputs": ["mol_015", "mol_003", "mol_002"], "outputs": ["mol_019", "mol_005"], "environment": "Biochemical", "agents": ["FeS (mackinawite)", "Fe2+"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "Fe2+ ions and FeS as reducing agent", "aqueous": "true", "other": "Mildly acidic to neutral pH; FeS or dissolved H2 provides reducing equivalents; prebiotic pool with concentrated NH3"}, "mechanism": "NH3 attacks the ketone carbonyl of \u03b1-ketoisovalerate to form a carbinolamine, which dehydrates to give an imine (Schiff base). The imine is then reduced by FeS-derived electrons (or dissolved H2 on mineral surfaces) to yield valine. Fe2+ ions coordinate the keto acid and lower the activation energy for imine formation.", "reasoning": "Reductive amination of \u03b1-keto acids is the biological route to amino acids and has been demonstrated prebiotically. Keefe et al. (1995) showed amino acid formation from CO2 with FeS/H2S as reducing agents, implicitly going through \u03b1-keto acid intermediates (Source 15950). The explicit reducing agent (FeS + H2) addresses the issue from previous attempts where no reductant was specified. This reaction connects the \u03b1-keto acid pool directly to amino acid synthesis."}, {"id": "rxn_015", "name": "Strecker synthesis of alanine aminonitrile from acetaldehyde", "inputs": ["mol_009", "mol_003", "mol_004"], "outputs": ["mol_017", "mol_005"], "environment": "Surface", "agents": ["montmorillonite"], "conditions": {"temperature": "300-340K", "pressure": "1 atm", "catalyst": "montmorillonite clay surface", "aqueous": "true", "other": "Evaporitic pool with NH3 and HCN; analogous to valine aminonitrile formation"}, "mechanism": "Acetaldehyde condenses with NH3 to form an imine (CH3CH=NH), which undergoes cyanide addition to yield 2-aminopropanenitrile (alanine aminonitrile). Montmorillonite catalyzes by adsorbing and concentrating reactants.", "reasoning": "Strecker synthesis of alanine from acetaldehyde is one of the best-studied prebiotic amino acid syntheses, demonstrated in the original Miller experiments (Miller, 1953; 1957). This provides the alanine needed for the transamination route to valine. Alanine is consistently one of the most abundant amino acids in spark discharge and prebiotic simulation experiments (Sources 15634, 15635, 6940)."}, {"id": "rxn_016", "name": "Hydrolysis of alanine aminonitrile to alanine", "inputs": ["mol_017", "mol_005"], "outputs": ["mol_016"], "environment": "Surface", "agents": ["montmorillonite", "apatite (phosphate mineral)"], "conditions": {"temperature": "330-370K", "pressure": "1 atm", "catalyst": "montmorillonite", "aqueous": "true", "other": "Acidic aqueous conditions; wet-dry cycling accelerates hydrolysis"}, "mechanism": "The nitrile group of alanine aminonitrile is hydrolyzed via acid-catalyzed two-step process: nitrile \u2192 amide \u2192 carboxylic acid, yielding alanine and releasing NH3.", "reasoning": "This is the standard second step of the Strecker synthesis. Miller and others demonstrated efficient conversion of aminonitriles to amino acids under mildly acidic aqueous conditions. This provides the alanine amino donor required for the transamination route to valine (Sources 6940, 6943)."}, {"id": "rxn_017", "name": "Transamination of alpha-ketoisovalerate with alanine to valine and pyruvate", "inputs": ["mol_015", "mol_016"], "outputs": ["mol_019", "mol_018"], "environment": "Biochemical", "agents": ["Fe2+", "pyridoxal (or mineral analog)"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "Fe2+ or Cu2+ ions; pyridoxal analog", "aqueous": "true", "other": "Prebiotic pool with concentrated amino acids and keto acids; metal ions serve as non-enzymatic catalysts"}, "mechanism": "Alanine forms a Schiff base with pyridoxal (or a metal-ion-mediated Schiff base with the keto acid directly). Tautomerization of the aldimine to ketimine, followed by hydrolysis, transfers the amino group from alanine to \u03b1-ketoisovalerate, yielding valine and releasing pyruvate as the transamination co-product.", "reasoning": "Non-enzymatic transamination between amino acids and \u03b1-keto acids has been demonstrated prebiotically. Keller et al. (2014) showed that \u03b1-keto acids undergo transamination with amino acids using Fe2+/3+ as catalysts without enzymes. This reaction mirrors extant biological valine biosynthesis (final step) and represents the continuity between prebiotic and biotic chemistry proposed by the literature (Sources 6943, 6994). Pyruvate release from transamination creates a proto-metabolic recycling loop."}, {"id": "rxn_018", "name": "Carbonyl insertion: acetaldehyde + CO to pyruvate on FeS/NiS", "inputs": ["mol_009", "mol_007"], "outputs": ["mol_018"], "environment": "Hydrothermal", "agents": ["mackinawite (FeS)", "NiS (millerite)"], "conditions": {"temperature": "370-420K", "pressure": "high (100-200 bar)", "catalyst": "FeS/NiS mixed sulfide surface", "aqueous": "true", "other": "W\u00e4chtersh\u00e4user-type carbonyl insertion on NiFeS surfaces; analogous to acetyl-CoA synthase mechanism"}, "mechanism": "CO binds to Ni site on the NiFeS surface. Acetaldehyde (or its thioester equivalent) undergoes carbonyl insertion: CO inserts into the C-H bond of the methyl group of an activated acetyl intermediate, producing a C3 \u03b1-keto acid (pyruvate). This is analogous to the biological Wood-Ljungdahl pathway.", "reasoning": "Cody et al. (2000) demonstrated formation of pyruvate and other \u03b1-keto acids from CO and simple organics on FeS/NiS surfaces at 250\u00b0C and 200 MPa. Huber and W\u00e4chtersh\u00e4user (1997) showed that CO insertion reactions on NiFeS surfaces produce activated acetyl groups. This multi-step process (broken down from the oversimplified 'CO2 \u2192 pyruvate' of previous attempts) provides a prebiotically grounded route to pyruvate as a C3 metabolic hub."}, {"id": "rxn_019", "name": "Thermal decarboxylation of pyruvate to acetaldehyde", "inputs": ["mol_018"], "outputs": ["mol_009", "mol_001"], "environment": "Surface", "agents": ["apatite (phosphate mineral)", "montmorillonite"], "conditions": {"temperature": "340-370K", "pressure": "1 atm", "catalyst": "phosphate mineral surface", "aqueous": "true", "other": "Wet-dry cycling in evaporitic pool; mild heating drives decarboxylation; slightly acidic pH (4-6)"}, "mechanism": "Pyruvate undergoes thermal \u03b2-decarboxylation: the \u03b1-keto acid loses CO2 from the carboxyl group, producing acetaldehyde. This is a well-known thermal reaction for \u03b1-keto acids that proceeds spontaneously at moderate temperatures. Phosphate minerals provide surface catalysis and acidic microenvironments.", "reasoning": "Thermal decarboxylation of pyruvate to acetaldehyde and CO2 is a well-established prebiotic reaction. Cooper et al. (2011) identified pyruvic acid in carbonaceous meteorites (Source 15388), confirming its prebiotic relevance. Pyruvate decarboxylation creates a recycling loop: pyruvate from transamination (rxn_017) regenerates acetaldehyde, which can re-enter both the aldol pathway (rxn_006) and the alanine Strecker pathway (rxn_015), creating a self-sustaining proto-metabolic network."}], "pathways": [{"pathway_id": "P1", "name": "Formate-CO-Aldol-Strecker route to valine", "description": "CO2 is reduced to formate on greigite, which thermally decomposes to CO. FTT synthesis on magnetite produces formaldehyde and acetaldehyde. Aldol condensation yields methacrolein, which is hydrogenated to isobutyraldehyde. Classical Strecker synthesis then converts isobutyraldehyde to valine via the aminonitrile intermediate.", "reaction_sequence": ["rxn_001", "rxn_002", "rxn_004", "rxn_005", "rxn_006", "rxn_007", "rxn_009", "rxn_010"], "key_intermediates": ["mol_006", "mol_007", "mol_010", "mol_011", "mol_012"]}, {"pathway_id": "P2", "name": "RWGS-CO-Aldol-Strecker route to valine", "description": "CO2 is directly converted to CO via the reverse water-gas shift reaction on magnetite at higher temperatures. FTT synthesis then produces formaldehyde and acetaldehyde. Aldol condensation yields methacrolein, hydrogenated to isobutyraldehyde. Strecker synthesis produces valine.", "reaction_sequence": ["rxn_003", "rxn_004", "rxn_005", "rxn_006", "rxn_007", "rxn_009", "rxn_010"], "key_intermediates": ["mol_007", "mol_008", "mol_009", "mol_010", "mol_011", "mol_012"]}, {"pathway_id": "P3", "name": "Direct FTT isobutyraldehyde-Strecker route", "description": "CO is produced via RWGS. Direct FTT synthesis on magnetite produces isobutyraldehyde as a minor branched C4 product. Strecker synthesis on the surface converts it to valine via the aminonitrile.", "reaction_sequence": ["rxn_003", "rxn_008", "rxn_009", "rxn_010"], "key_intermediates": ["mol_007", "mol_011", "mol_012"]}, {"pathway_id": "P4", "name": "Formate-CO-FTT-branched-Strecker short route", "description": "CO2 is reduced to formate then to CO via the two-step hydrothermal route. FTT produces branched isobutyraldehyde directly. Strecker synthesis completes valine formation.", "reaction_sequence": ["rxn_001", "rxn_002", "rxn_008", "rxn_009", "rxn_010"], "key_intermediates": ["mol_006", "mol_007", "mol_011", "mol_012"]}, {"pathway_id": "P5", "name": "Aldol-Cyanohydrin-Reductive amination route", "description": "CO is produced via RWGS. FTT yields formaldehyde and acetaldehyde. Aldol condensation and hydrogenation give isobutyraldehyde. Instead of Strecker, isobutyraldehyde reacts with HCN to form a cyanohydrin, which is hydrolyzed to \u03b1-hydroxyisovaleric acid, UV-oxidized to \u03b1-ketoisovalerate, and finally reduced to valine via reductive amination with NH3 and FeS.", "reaction_sequence": ["rxn_003", "rxn_004", "rxn_005", "rxn_006", "rxn_007", "rxn_011", "rxn_012", "rxn_013", "rxn_014"], "key_intermediates": ["mol_007", "mol_010", "mol_011", "mol_013", "mol_014", "mol_015"]}, {"pathway_id": "P6", "name": "Direct FTT-Cyanohydrin-Reductive amination route", "description": "CO from RWGS produces isobutyraldehyde via direct FTT branching. Cyanohydrin formation, hydrolysis, and UV photo-oxidation yield \u03b1-ketoisovalerate. Reductive amination with NH3 and H2/FeS gives valine.", "reaction_sequence": ["rxn_003", "rxn_008", "rxn_011", "rxn_012", "rxn_013", "rxn_014"], "key_intermediates": ["mol_007", "mol_011", "mol_013", "mol_014", "mol_015"]}, {"pathway_id": "P7", "name": "Aldol-Cyanohydrin-Transamination route via Strecker alanine", "description": "Two hydrothermal streams converge: (1) FTT formaldehyde + acetaldehyde \u2192 methacrolein \u2192 isobutyraldehyde \u2192 cyanohydrin \u2192 \u03b1-hydroxy acid \u2192 \u03b1-ketoisovalerate; (2) FTT acetaldehyde \u2192 Strecker alanine. Transamination of \u03b1-ketoisovalerate with alanine yields valine + pyruvate.", "reaction_sequence": ["rxn_003", "rxn_004", "rxn_005", "rxn_006", "rxn_007", "rxn_011", "rxn_012", "rxn_013", "rxn_015", "rxn_016", "rxn_017"], "key_intermediates": ["mol_007", "mol_009", "mol_011", "mol_015", "mol_016"]}, {"pathway_id": "P8", "name": "Direct FTT-Cyanohydrin-Transamination route", "description": "FTT directly produces both isobutyraldehyde (branched) and acetaldehyde. Isobutyraldehyde enters the cyanohydrin pathway to \u03b1-ketoisovalerate. Acetaldehyde enters the Strecker pathway to alanine. Transamination of the two products yields valine and pyruvate.", "reaction_sequence": ["rxn_003", "rxn_005", "rxn_008", "rxn_011", "rxn_012", "rxn_013", "rxn_015", "rxn_016", "rxn_017"], "key_intermediates": ["mol_007", "mol_009", "mol_011", "mol_015", "mol_016"]}, {"pathway_id": "P9", "name": "Pyruvate carbonyl-insertion recycling Strecker route", "description": "Acetaldehyde and CO undergo carbonyl insertion on NiFeS to form pyruvate. Pyruvate is thermally decarboxylated to regenerate acetaldehyde + CO2 on the surface. This recycled acetaldehyde feeds aldol condensation with formaldehyde to produce methacrolein \u2192 isobutyraldehyde \u2192 Strecker valine. Demonstrates proto-metabolic cycling.", "reaction_sequence": ["rxn_003", "rxn_005", "rxn_018", "rxn_019", "rxn_004", "rxn_006", "rxn_007", "rxn_009", "rxn_010"], "key_intermediates": ["mol_007", "mol_009", "mol_018", "mol_010", "mol_011", "mol_012"]}, {"pathway_id": "P10", "name": "Autocatalytic transamination loop with pyruvate recycling", "description": "The most complex pathway creating a self-sustaining loop. Pyruvate formed by carbonyl insertion (rxn_018) is decarboxylated to acetaldehyde (rxn_019). Acetaldehyde feeds Strecker alanine synthesis. Meanwhile, isobutyraldehyde from FTT or aldol enters the cyanohydrin pathway to \u03b1-ketoisovalerate. Transamination of \u03b1-ketoisovalerate with alanine yields valine + pyruvate. The pyruvate product feeds back into decarboxylation (rxn_019), regenerating acetaldehyde for the next cycle. This creates a proto-metabolic autocatalytic network.", "reaction_sequence": ["rxn_003", "rxn_005", "rxn_018", "rxn_019", "rxn_015", "rxn_016", "rxn_008", "rxn_011", "rxn_012", "rxn_013", "rxn_017"], "key_intermediates": ["mol_007", "mol_009", "mol_018", "mol_011", "mol_015", "mol_016"]}], "hub_molecules": ["mol_007", "mol_009", "mol_011", "mol_004", "mol_015"], "convergence_points": [{"molecule_id": "mol_007", "description": "Carbon monoxide - central C1 building block produced by two hydrothermal routes and consumed by four distinct reactions", "incoming_reactions": ["rxn_002", "rxn_003"], "outgoing_reactions": ["rxn_004", "rxn_005", "rxn_008", "rxn_018"]}, {"molecule_id": "mol_009", "description": "Acetaldehyde - C2 hub produced by FTT and pyruvate decarboxylation, consumed by aldol, Strecker alanine, and carbonyl insertion", "incoming_reactions": ["rxn_005", "rxn_019"], "outgoing_reactions": ["rxn_006", "rxn_015", "rxn_018"]}, {"molecule_id": "mol_011", "description": "Isobutyraldehyde - branched C4 aldehyde hub produced by two routes (aldol hydrogenation and direct FTT), feeds both Strecker and cyanohydrin pathways", "incoming_reactions": ["rxn_007", "rxn_008"], "outgoing_reactions": ["rxn_009", "rxn_011"]}, {"molecule_id": "mol_004", "description": "Hydrogen cyanide - key nitrogen/carbon source consumed by three nucleophilic addition reactions (valine Strecker, c
      \"iupac_name\": \"water\",\n      \"common_name\": \"Water\",\n      \"inchi\": \"InChI=1S/H2O/h1H2\",\n      \"role\": \"starting\",\n      \"environment_formed\": null\n    },\n    {\n      \"id\": \"mol_005\",\n      \"formula\": \"CH4\",\n      \"iupac_name\": \"methane\",\n      \"common_name\": \"Methane\",\n      \"inchi\": \"InChI=1S/CH4/h1H4\",\n      \"role\": \"starting\",\n      \"environment_formed\": null\n    },\n    {\n      \"id\": \"mol_006\",\n      \"formula\": \"H2S\",\n      \"iupac_name\": \"hydrogen sulfide\",\n      \"common_name\": \"Hydrogen sulfide\",\n      \"inchi\": \"InChI=1S/H2S/h1H2\",\n      \"role\": \"starting\",\n      \"environment_formed\": null\n    },\n    {\n      \"id\": \"mol_007\",\n      \"formula\": \"CO\",\n      \"iupac_name\": \"carbon monoxide\",\n      \"common_name\": \"Carbon monoxide\",\n      \"inchi\": \"InChI=1S/CO/c1-2\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_008\",\n      \"formula\": \"CHO2-\",\n      \"iupac_name\": \"formate\",\n      \"common_name\": \"Formate\",\n      \"inchi\": \"InChI=1S/CH2O2/c2-1-3/h1H,(H,2,3)/p-1\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_009\",\n      \"formula\": \"CH2O\",\n      \"iupac_name\": \"formaldehyde\",\n      \"common_name\": \"Formaldehyde\",\n      \"inchi\": \"InChI=1S/CH2O/c1-2/h1H2\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_010\",\n      \"formula\": \"C2H4O\",\n      \"iupac_name\": \"acetaldehyde\",\n      \"common_name\": \"Acetaldehyde\",\n      \"inchi\": \"InChI=1S/C2H4O/c1-2-3/h2H,1H3\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_011\",\n      \"formula\": \"HCN\",\n      \"iupac_name\": \"hydrogen cyanide\",\n      \"common_name\": \"
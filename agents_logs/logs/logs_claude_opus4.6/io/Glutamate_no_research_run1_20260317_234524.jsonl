n_name\": \"acetate\",\n      \"inchi\": \"InChI=1S/C2H4O2/c1-2(3)4/h1H3,(H,3,4)/p-1\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_009\",\n      \"formula\": \"C3H3O3-\",\n      \"iupac_name\": \"2-oxopropanoate\",\n      \"common_name\": \"pyruvate\",\n      \"inchi\": \"InChI=1S/C3H4O3/c1-2(4)3(5)6/h1H3,(H,5,6)/p-1\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_010\",\n      \"formula\": \"C4H3O5-\",\n      \"iupac_name\": \"3-carboxy-2-oxopropanoate\",\n      \"common_name\": \"oxaloacetate\",\n      \"inchi\": \"InChI=1S/C4H4O5/c5-2(4-6)1-3(7)8/h1H2,(H,6)(H,7,8)/p-1\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_011\",\n      \"formula\": \"C6H5O7-3\",\n      \"iupac_name\": \"2-hydroxypropane-1,2,3-tricarboxylate\",\n      \"common_name\": \"citrate\",\n      \"inchi\": \"InChI=1S/C6H8O7/c7-1(8)4-6(13,3(11)12)5-2(9)10/h13H,4-5H2,(H,7,8)(H,9,10)(H,11,12)/p-3\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_012\",\n      \"formula\": \"C6H5O7-3\",\n      \"iupac_name\": \"1-hydroxypropane-1,2,3-tricarboxylate\",\n      \"common_name\": \"isocitrate\",\n      \"inchi\": \"InChI=1S/C6H8O7/c7-1(8)2(6(12)13)3-4(9)10/h2,6H,3H2,(H,7,8)(H,9,10)(H,12,13)/p-3\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_013\",\n      \"formula\": \"C5H4O5-2\",\n      \"iupac_name\": \"2-oxopentanedioate\",\n      \"common_name\": \"alpha-ketoglutarate\",\n      \"inchi\": \"InChI=1S/C5H6O5/c6-3(5(9)10)1-2-4(7)8/h1-2H2,(H,7,8)(H,9,10)/p-2\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_014\",\n      \"formula\": \"C5H8NO4-\",\n      \"iupac_name\": \"2-aminopentanedioate\",\n      \"common_name\": \"glutamate\",\n      \"inchi\": \"InChI=1S/C5H9NO4/c6-3(5(9)10)1-2-4(7)8/h3H,1-2,6H2,(H,7,8)(H,9,10)/p-1\",\n      \"role\": \"target\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_015\",\n      \"formula\": \"C2H4O2\",\n      \"iupac_name\": \"2-hydroxyacetaldehyde\",\n      \"common_name\": \"glycolaldehyde\",\n      \"inchi\": \"InChI=1S/C2H4O2/c3-1-2-4/h1,4H,2H2\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_016\",\n      \"formula\": \"C2HO3-\",\n      \"iupac_name\": \"oxoacetate\",\n      \"common_name\": \"glyoxylate\",\n      \"inchi\": \"InChI=1S/C2H2O3/c3-1-2(4)5/h1H,(H,4,5)/p-1\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_017\",\n      \"formula\": \"C5H5O6-\",\n      \"iupac_name\": \"4-hydroxy-2-oxoglutarate\",\n      \"common_name\": \"4-hydroxy-2-oxoglutarate\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_018\",\n      \"formula\": \"C4H4O4-2\",\n      \"iupac_name\": \"butanedioate\",\n      \"common_name\": \"succinate\",\n      \"inchi\": \"InChI=1S/C4H6O4/c5-3(6)1-2-4(7)8/h1-2H2,(H,5,6)(H,7,8)/p-2\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_019\",\n      \"formula\": \"C4H6O3\",\n      \"iupac_name\": \"4-oxobutanoic acid\",\n      \"common_name\": \"succinic semialdehyde\",\n      \"inchi\": \"InChI=1S/C4H6O3/c5-3-1-2-4(6)7/h3H,1-2H2,(H,6,7)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_020\",\n      \"formula\": \"C5H6NO3-\",\n      \"iupac_name\": \"2-amino-4-carboxybutanenitrile\",\n      \"common_name\": \"glutamate aminonitrile\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_021\",\n      \"formula\": \"C3H6NO2-\",\n      \"iupac_name\": \"2-aminopropanoate\",\n      \"common_name\": \"alanine\",\n      \"inchi\": \"InChI=1S/C3H7NO2/c1-2(4)3(5)6/h2H,4H2,1H3,(H,5,6)/p-1\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_022\",\n      \"formula\": \"C3H4O2\",\n      \"iupac_name\": \"2-propenal\",\n      \"common_name\": \"acrolein\",\n      \"inchi\": \"InChI=1S/C3H4O/c1-2-3-4/h2-3H,1H2\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"CO\u2082 hydrogenation to formate on greigite\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_006\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe\u2083S\u2084)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high (>50 bar)\",\n        \"catalyst\": \"greigite (Fe\u2083S\u2084)\",\n        \"aqueous\": true,\n        \"other\": \"alkaline vent conditions, pH 9-11, H\u2082-rich fluids\"\n      },\n      \"mechanism\": \"CO\u2082 adsorbs on Fe\u2083S\u2084 surface Fe sites and is reduced by H\u2082 via surface-bound hydride. The [Fe\u2084S\u2084]-like cluster in greigite transfers two electrons to CO\u2082, forming surface-bound formate which desorbs into alkaline solution.\",\n      \"reasoning\": \"Experimentally demonstrated by Preiner et al. (2020, Nature Ecology & Evolution) who showed greigite and awaruite catalyze CO\u2082 fixation to formate under simulated hydrothermal conditions. Roldan et al. (2015) also showed greigite reduces CO\u2082 to formate electrochemically. This is the most robustly supported first step in hydrothermal carbon fixation.\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Fischer-Tropsch-type CO\u2082 reduction to formaldehyde\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_007\", \"mol_004\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe\u2083O\u2084)\"],\n      \"conditions\": {\n        \"temperature\": \"400-500K\",\n        \"pressure\": \"high (>100 bar)\",\n        \"catalyst\": \"magnetite (Fe\u2083O\u2084)\",\n        \"aqueous\": true,\n        \"other\": \"Fischer-Tropsch-type conditions, CO\u2082:H\u2082 ratio ~1:3\"\n      },\n      \"mechanism\": \"CO\u2082 is first reduced to CO on magnetite surface, then CO undergoes partial hydrogenation to surface-bound -CH\u2082O- which desorbs as formaldehyde. Higher temperatures favor C\u2081 product release over chain growth.\",\n      \"reasoning\": \"Fischer-Tropsch-type (FTT) synthesis on magnetite demonstrated by McCollom et al. (1999) and Holm & Charlou (2001). Formaldehyde is a minor but consistently detected product of FTT reactions under hydrothermal conditions. Higher temperatures (400-500K) and high H\u2082:CO\u2082 ratios favor formaldehyde over longer chain products.\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Formate reduction to acetate on FeNiS surfaces\",\n      \"inputs\": [\"mol_006\", \"mol_002\", \"mol_001\"],\n      \"outputs\": [\"mol_008\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe\u2083S\u2084)\", \"awaruite (Ni\u2083Fe)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high (>50 bar)\",\n        \"catalyst\": \"greigite + awaruite (FeNi alloy)\",\n        \"aqueous\": true,\n        \"other\": \"alkaline conditions pH 9-11, analog to acetyl-CoA pathway\"\n      },\n      \"mechanism\": \"Formate is further reduced to a surface-bound methyl group on FeNi surface, then carbonylated by CO (from CO\u2082 reduction) to form an acetyl intermediate. Hydrolysis releases acetate. This parallels the Wood-Ljungdahl acetyl-CoA pathway.\",\n      \"reasoning\": \"Preiner et al. (2020) demonstrated that native Fe and Ni minerals catalyze CO\u2082 fixation to acetate via formate. Huber & W\u00e4chtersh\u00e4user (1997) showed carbon fixation to activated acetic acid on FeS/NiS surfaces at 100\u00b0C. This is a well-supported analog to the biological Wood-Ljungdahl pathway.\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"Reductive carboxylation of acetate to pyruvate\",\n      \"inputs\": [\"mol_008\", \"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_009\", \"mol_004\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"elemental iron (Fe\u2070)\", \"awaruite (Ni\u2083Fe)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high (20-100 bar)\",\n        \"catalyst\": \"Fe\u2070 and Ni\u2070 native metals\",\n        \"aqueous\": true,\n        \"other\": \"mildly acidic to neutral pH, simulating mixing zone\"\n      },\n      \"mechanism\": \"Acetate is activated on native metal surface, then undergoes reductive carboxylation where CO\u2082 is inserted at the methyl carbon. Fe\u2070 provides electrons for the reduction, and Ni\u2070 facilitates C-C bond formation.\",\n      \"reasoning\": \"Varma et al. (2018, Nature Ecology & Evolution) demonstrated that native iron and nickel metals fix CO\u2082 to pyruvate and other \u03b1-keto acids under mild aqueous conditions (30-100\u00b0C). Yields of ~0.5% pyruvate were detected. This is among the strongest experimental evidence for prebiotic pyruvate synthesis.\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"Reductive carboxylation of pyruvate to oxaloacetate\",\n      \"inputs\": [\"mol_009\", \"mol_001\"],\n      \"outputs\": [\"mol_010\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"elemental iron (Fe\u2070)\", \"magnetite (Fe\u2083O\u2084)\"],\n      \"conditions\": {\n        \"temperature\": \"340-370K\",\n        \"pressure\": \"moderate to high\",\n        \"catalyst\": \"Fe\u2070 / Fe\u00b2\u207a\",\n        \"aqueous\": true,\n        \"other\": \"pH 6-8, simulating vent mixing zone, CO\u2082 saturated\"\n      },\n      \"mechanism\": \"CO\u2082 inserts into the pyruvate enolate at the C-3 position, forming the C4 dicarboxylic acid oxaloacetate. Fe\u2070 or Fe\u00b2\u207a stabilizes the carbanion intermediate and provides reducing equivalents.\",\n      \"reasoning\": \"Muchowska et al. (2019, Nature) demonstrated that Fe\u00b2\u207a promotes interconversion of TCA cycle intermediates including pyruvate carboxylation to oxaloacetate. Varma et al. (2018) also detected oxaloacetate as a product of CO\u2082 fixation on native metals. The pyruvate \u2192 OAA step is one of the better-supported rTCA fragment reactions.\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"Citrate synthesis from oxaloacetate and acetate\",\n      \"inputs\": [\"mol_010\", \"mol_008\"],\n      \"outputs\": [\"mol_011\", \"mol_004\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"elemental iron (Fe\u2070)\", \"pyrite (FeS\u2082)\"],\n      \"conditions\": {\n        \"temperature\": \"340-370K\",\n        \"pressure\": \"moderate\",\n        \"catalyst\": \"Fe\u00b2\u207a (from Fe\u2070 dissolution)\",\n        \"aqueous\": true,\n        \"other\": \"pH 6-8, requires acetyl activation on FeS surface\"\n      },\n      \"mechanism\": \"Acetate is first activated to an acetyl-thioester on the FeS\u2082 surface (analogous to acetyl-CoA). The activated acetyl group then undergoes aldol condensation with oxaloacetate at the carbonyl carbon, followed by hydrolysis to release citrate. Fe\u00b2\u207a acts as Lewis acid catalyst.\",\n      \"reasoning\": \"Muchowska et al. (2019, Nature) showed citrate forms from OAA in their Fe\u00b2\u207a-promoted network containing multiple TCA intermediates. The thioester activation step parallels citrate synthase biochemistry. Goldford et al. (2019) provided computational support for this condensation under prebiotic conditions. This is the key C4\u2192C6 carbon-carbon bond forming step.\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Citrate to \u03b1-ketoglutarate via isocitrate (oxidative decarboxylation)\",\n      \"inputs\": [\"mol_011\"],\n      \"outputs\": [\"mol_012\", \"mol_013\", \"mol_001\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"pyrite (FeS\u2082)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"340-380K\",\n        \"pressure\": \"moderate\",\n        \"catalyst\": \"Fe\u00b2\u207a/Zn\u00b2\u207a metal ions\",\n        \"aqueous\": true,\n        \"other\": \"Two-step: (1) dehydration/rehydration for isomerization, (2) oxidative decarboxylation using FeS\u2082 as electron acceptor\"\n      },\n      \"mechanism\": \"Citrate first undergoes dehydration to aconitate then rehydration to isocitrate (catalyzed by Fe\u00b2\u207a Lewis acid). Isocitrate then undergoes oxidative decarboxylation: FeS\u2082 serves as the terminal electron acceptor, oxidizing the hydroxyl group to a ketone while CO\u2082 is lost, yielding \u03b1-ketoglutarate. This is a two-step transformation kept as one node since isocitrate is transient.\",\n      \"reasoning\": \"Muchowska et al. (2019, Nature) explicitly demonstrated the citrate \u2192 isocitrate \u2192 \u03b1-ketoglutarate conversion promoted by Fe\u00b2\u207a in their reconstituted prebiotic TCA network. Zn\u00b2\u207a and Cr\u00b3\u207a were also effective. The dehydration-rehydration-oxidative decarboxylation sequence mirrors the biological aconitase + isocitrate dehydrogenase steps. FeS\u2082 provides a prebiotically available oxidant (W\u00e4chtersh\u00e4user, 1988).\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Reductive amination of \u03b1-ketoglutarate to glutamate (hydrothermal)\",\n      \"inputs\": [\"mol_013\", \"mol_003\", \"mol_002\"],\n      \"outputs\": [\"mol_014\", \"mol_004\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"elemental iron (Fe\u2070)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"Fe\u2070 as reductant, FeS surface\",\n        \"aqueous\": true,\n        \"other\": \"NH\u2083 from vent fluids, pH 8-10, H\u2082 as co-reductant\"\n      },\n      \"mechanism\": \"NH\u2083 attacks the C-2 ketone of \u03b1-KG to form a carbinolamine, which dehydrates to an imine (Schiff base). Fe\u2070 or dissolved H\u2082 reduces the C=N bond to give the amine product glutamate. The FeS surface stabilizes the imine intermediate.\",\n      \"reasoning\": \"Wang et al. (2011, Astrobiology) demonstrated reductive amination of \u03b1-keto acids including \u03b1-KG using Fe\u2070 as reductant and NH\u2083 at elevated temperatures. Barge et al. (2019) showed amino acid synthesis via reductive amination on iron oxyhydroxide minerals. This is the most direct route from \u03b1-KG to glutamate and is thermodynamically favorable under reducing hydrothermal conditions.\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"Oxaloacetate reduction to succinate via malate and fumarate\",\n      \"inputs\": [\"mol_010\", \"mol_002\"],\n      \"outputs\": [\"mol_018\", \"mol_004\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"elemental iron (Fe\u2070)\", \"magnetite (Fe\u2083O\u2084)\"],\n      \"conditions\": {\n        \"temperature\": \"340-370K\",\n        \"pressure\": \"moderate\",\n        \"catalyst\": \"Fe\u00b2\u207a (from Fe\u2070 dissolution)\",\n        \"aqueous\": true,\n        \"other\": \"Proceeds via malate (reduction of ketone) \u2192 fumarate (dehydration) \u2192 succinate (reduction of double bond); Fe\u00b2\u207a catalyzes all three steps\"\n      },\n      \"mechanism\": \"Three sequential reactions: (1) Fe\u2070 reduces the OAA ketone to malate (C=O \u2192 CHOH); (2) Fe\u00b2\u207a-catalyzed dehydration of malate to fumarate; (3) Fe\u2070 reduces the fumarate double bond to succinate. All three steps are thermodynamically downhill under reducing conditions.\",\n      \"reasoning\": \"Muchowska et al. (2019, Nature) demonstrated the complete OAA \u2192 malate \u2192 fumarate \u2192 succinate sequence using Fe\u00b2\u207a at 70\u00b0C. These are among the most robust reactions in their prebiotic TCA analog, proceeding with high yields. The reductive sequence is strongly thermodynamically favored under anoxic conditions with Fe\u2070 as electron donor.\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"Formaldehyde self-condensation to glycolaldehyde (formose reaction initiation)\",\n      \"inputs\": [\"mol_007\"],\n      \"outputs\": [\"mol_015\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\", \"borate minerals (colemanite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"Ca(OH)\u2082 / borate minerals\",\n        \"aqueous\": true,\n        \"other\": \"Alkaline aqueous pool pH 10-12, borate stabilizes glycolaldehyde\"\n      },\n      \"mechanism\": \"Two formaldehyde molecules undergo base-catalyzed aldol condensation via umpolung: one HCHO is deprotonated by Ca(OH)\u2082 to form a carbanion, which attacks the carbonyl of the second HCHO. Borate complexation of the product glycolaldehyde prevents further condensation.\",\n      \"reasoning\": \"The formose reaction initiated by Butlerow (1861) produces glycolaldehyde as the first C\u2082 product. Ricardo et al. (2004, Science) demonstrated that borate minerals stabilize the sugar products and channel the reaction toward specific intermediates including glycolaldehyde. Montmorillonite clay concentrates formaldehyde via surface adsorption.\"\n    },\n    {\n      \"id\": \"rxn_011\",\n      \"name\": \"UV photooxidation of glycolaldehyde to glyoxylate\",\n      \"inputs\": [\"mol_015\"],\n      \"outputs\": [\"mol_016\", \"mol_002\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO\u2082 (anatase)\", \"phosphate minerals (apatite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO\u2082 photocatalyst\",\n        \"aqueous\": true,\n        \"other\": \"UV irradiation (\u03bb < 300 nm), shallow aqueous pool, no O\u2082 \u2014 uses TiO\u2082 holes as oxidant\"\n      },\n      \"mechanism\": \"UV excitation of TiO\u2082 generates electron-hole pairs. The holes oxidize glycolaldehyde at the terminal -CH\u2082OH to -CHO and then to -COO\u207b, yielding glyoxylate. The electrons reduce H\u207a to H\u2082 (or reduce Fe\u00b3\u207a). Phosphate minerals buffer pH.\",\n      \"reasoning\": \"Ritson & Sutherland (2012, Nature Chemistry) demonstrated UV-driven photoredox chemistry producing key prebiotic intermediates. TiO\u2082 is a well-established UV photocatalyst capable of oxidizing alcohols to aldehydes and carboxylic acids under anoxic conditions (Kisch, 2013). Glyoxylate is a key intermediate in prebiotic C\u2082 chemistry (Eschenmoser, 2007).\"\n    },\n    {\n      \"id\": \"rxn_012\",\n      \"name\": \"Aldol condensation of pyruvate with glyoxylate to 4-hydroxy-2-oxoglutarate\",\n      \"inputs\": [\"mol_009\", \"mol_016\"],\n      \"outputs\": [\"mol_017\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\", \"phosphate minerals (apatite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite surface, divalent metal ions (Mg\u00b2\u207a, Ca\u00b2\u207a)\",\n        \"aqueous\": true,\n        \"other\": \"mildly alkaline pH 8-10, evaporitic pool\"\n      },\n      \"mechanism\": \"Base-catalyzed enolization of pyruvate at C-3 generates a nucleophilic enolate. This attacks the aldehyde carbon of glyoxylate in a crossed aldol condensation, forming 4-hydroxy-2-oxoglutarate (a C\u2085 \u03b2-hydroxy-\u03b1-keto diacid). Clay surfaces orient reactants and stabilize the transition state.\",\n      \"reasoning\": \"This aldol condensation is well-known in enzymology \u2014 4-hydroxy-2-oxoglutarate aldolase catalyzes the reverse in biology (Dekker & Maitra, 1962). The forward direction is thermodynamically favorable. Weber (2001, Origins of Life) discussed prebiotic aldol condensations between \u03b1-keto acids and aldehydes. Montmorillonite clay catalysis of aldol reactions is established (Nagendrappa, 2011).\"\n    },\n    {\n      \"id\": \"rxn_013\",\n      \"name\": \"Dehydration and reduction of 4-hydroxy-2-oxoglutarate to \u03b1-ketoglutarate\",\n      \"inputs\": [\"mol_017\", \"mol_002\"],\n      \"outputs\": [\"mol_013\", \"mol_004\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\", \"TiO\u2082 (anatase)\"],\n      \"conditions\": {\n        \"temperature\": \"330-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"clay surface for dehydration, UV/Fe\u00b2\u207a for reduction\",\n        \"aqueous\": true,\n        \"other\": \"Wet-dry cycling drives dehydration, followed by photoreduction in next wet phase. Two-step: dehydration to 2-oxoglutaconate then reduction.\"\n      },\n      \"mechanism\": \"Step 1: Wet-dry cycling dehydrates 4-hydroxy-2-oxoglutarate to 2-oxoglutaconate (elimination of H\u2082O from \u03b2-hydroxy position \u2014 a facile \u03b2-elimination). Step 2: UV-driven photoreduction on TiO\u2082 or Fe\u00b2\u207a-mediated reduction of the C=C double bond yields \u03b1-ketoglutarate.\",\n      \"reasoning\": \"\u03b2-hydroxy acid dehydration is thermodynamically favorable and occurs readily upon mild heating or clay catalysis. The subsequent double bond reduction is achieved by Fe\u00b2\u207a under UV or by dissolved H\u2082 on mineral surfaces. This two-step expansion addresses the previous criticism of treating glyoxylate + pyruvate \u2192 \u03b1-KG as a single implausible step. Each sub-step has literature support: \u03b2-elimination is facile; alkene reduction by Fe\u00b2\u207a/H\u2082 is demonstrated (Rowan et al., 1953).\"\n    },\n    {\n      \"id\": \"rxn_014\",\n      \"name\": \"TiO\u2082-photocatalytic partial reduction of succinate to succinic semialdehyde\",\n      \"inputs\": [\"mol_018\"],\n      \"outputs\": [\"mol_019\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO\u2082 (anatase)\", \"sulfide minerals (stibnite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO\u2082 with sulfide co-catalyst as hole scavenger\",\n        \"aqueous\": true,\n        \"other\": \"UV irradiation, anaerobic, sulfide minerals provide sacrificial electron donors to prevent over-reduction\"\n      },\n      \"mechanism\": \"UV photoexcitation of TiO\u2082 generates conduction band electrons that selectively reduce one carboxylate of succinate to an aldehyde via a 2-electron pathway: -COO\u207b + 2H\u207a + 2e\u207b \u2192 -CHO + H\u2082O. Stibnite (Sb\u2082S\u2083) acts as hole scavenger, preventing back-oxidation and achieving selectivity for the monoaldehyde product.\",\n      \"reasoning\": \"TiO\u2082 photocatalytic reduction of carboxylic acids is established in synthetic chemistry (Manley et al., 2008; Xie et al., 2015). Selective mono-reduction is achieved by controlling photon flux and using sacrificial electron donors. While yields are modest (5-15%), this is prebiotically plausible given continuous UV exposure on early Earth. This addresses the previous criticism by using photochemistry rather than thermally implausible carboxylate-to-aldehyde reduction.\"\n    },\n    {\n      \"id\": \"rxn_015\",\n      \"name\": \"Strecker synthesis: succinic semialdehyde + HCN + NH\u2083 \u2192 glutamate aminonitrile\",\n      \"inputs\": [\"mol_019\", \"mol_005\", \"mol_003\"],\n      \"outputs\": [\"mol_020\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite clay surface concentrates reactants\",\n        \"aqueous\": true,\n        \"other\": \"mildly acidic to neutral pH 5-7, evaporitic concentration\"\n      },\n      \"mechanism\": \"Classic Strecker synthesis: (1) NH\u2083 attacks the aldehyde carbon of succinic semialdehyde to form a carbinolamine; (2) dehydration gives an imine (Schiff base); (3) HCN adds to the imine C=N bond to give 2-amino-4-carboxybutanenitrile (the glutamate aminonitrile). Clay concentrates all three reactants on its surface.\",\n      \"reasoning\": \"The Strecker synthesis is one of the most robust prebiotic amino acid syntheses, demonstrated under many conditions (Miller, 1957; Peltzer & Bada, 1978). The specific application to succinic semialdehyde + HCN + NH\u2083 \u2192 glutamate precursor follows standard Strecker selectivity for \u03b1-aminonitrile formation. Montmorillonite enhances yields by surface concentration (Ferris et al., 1996).\"\n    },\n    {\n      \"id\": \"rxn_016\",\n      \"name\": \"Hydrolysis of glutamate aminonitrile to glutamate\",\n      \"inputs\": [\"mol_020\", \"mol_004\"],\n      \"outputs\": [\"mol_014\", \"mol_003\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"none required \u2014 thermal hydrolysis\",\n        \"aqueous\": true,\n        \"other\": \"mildly acidic pH 3-5, or prolonged neutral pH, geothermal heating\"\n      },\n      \"mechanism\": \"The nitrile group (-C\u2261N) undergoes sequential hydrolysis: first to an amide (-CONH\u2082) then to a carboxylic acid (-COOH) with release of NH\u2083. At mildly acidic pH, the half-life for nitrile hydrolysis is days to weeks at 50-80\u00b0C.\",\n      \"reasoning\": \"Nitrile hydrolysis is thermodynamically favorable and proceeds spontaneously in aqueous solution at elevated temperatures. Bada et al. (1995) and Cleaves et al. (2008) confirmed facile aminonitrile hydrolysis under prebiotic conditions. The released NH\u2083 is recycled into the network.\"\n    },\n    {\n      \"id\": \"rxn_017\",\n      \"name\": \"Cu\u00b2\u207a/Fe\u00b2\u207a-catalyzed transamination: \u03b1-KG + alanine \u2192 glutamate + pyruvate\",\n      \"inputs\": [\"mol_013\", \"mol_021\"],\n      \"outputs\": [\"mol_014\", \"mol_009\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"Cu\u00b2\u207a or Fe\u00b2\u207a as Lewis acid catalyst\",\n        \"aqueous\": true,\n        \"other\": \"Cu\u00b2\u207a at ~1 mM concentration, mildly acidic to neutral pH 5-7, metal ion chelated between amine and carboxylate\"\n      },\n      \"mechanism\": \"Cu\u00b2\u207a chelates with alanine (bidentate via amino and carboxylate), activating the \u03b1-hydrogen for removal. Tautomerization of the resulting metal-stabilized Schiff base-like intermediate enables nitrogen transfer from the \u03b1-carbon of alanine to the \u03b1-carbon of \u03b1-KG, yielding glutamate and regenerating pyruvate.\",\n      \"reasoning\": \"Zabinski & Toth (2006) demonstrated Cu\u00b2\u207a-catalyzed transamination between amino acids and \u03b1-keto acids without pyridoxal phosphate. Snell & Jenkins (1959) showed metal ions alone can catalyze transamination. Cu\u00b2\u207a is particularly effective due to its strong Lewis acidity and Jahn-Teller distortion that stabilizes planar intermediates. This addresses the previous criticism of cofactor-free transamination by explicitly including the metal ion catalyst.\"\n    },\n    {\n      \"id\": \"rxn_018\",\n      \"name\": \"Reductive amination of pyruvate to alanine (hydrothermal)\",\n      \"inputs\": [\"mol_009\", \"mol_003\", \"mol_002\"],\n      \"outputs\": [\"mol_021\", \"mol_004\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"elemental iron (Fe\u2070)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"Fe\u2070 as reductant\",\n        \"aqueous\": true,\n        \"other\": \"NH\u2083-rich alkaline vent fluids, pH 9-11\"\n      },\n      \"mechanism\": \"NH\u2083 attacks the pyruvate ketone to form an imine (Schiff base). Fe\u2070 reduces the C=N double bond to yield alanine. Mechanism parallels rxn_008 but with the simpler C\u2083 substrate.\",\n      \"reasoning\": \"Wang et al. (2011, Astrobiology) demonstrated reductive amination of pyruvate to alanine using Fe\u2070 at elevated temperatures. Barge et al. (2019) confirmed amino acid synthesis from keto acids on iron minerals. Alanine is among the most common amino acids produced in prebiotic experiments.\"\n    },\n    {\n      \"id\": \"rxn_019\",\n      \"name\": \"UV-driven photoreductive amination of \u03b1-KG to glutamate on TiO\u2082\",\n      \"inputs\": [\"mol_013\", \"mol_003\"],\n      \"outputs\": [\"mol_014\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO\u2082 (anatase)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO\u2082 photocatalyst\",\n        \"aqueous\": true,\n        \"other\": \"UV irradiation \u03bb < 300 nm, NH\u2083-containing shallow pool, anaerobic\"\n      },\n      \"mechanism\": \"UV-excited TiO\u2082 generates electron-hole pairs. The photogenerated electron reduces the imine intermediate (formed from \u03b1-KG + NH\u2083 condensation) to the amine, yielding glutamate. The hole is scavenged by H\u2082O or organic sacrificial donors.\",\n      \"reasoning\": \"Botta et al. (2018, Chemistry: A European Journal) demonstrated UV-driven photocatalytic reductive amination on TiO\u2082 surfaces. Ranjan & Sasselov (2016) showed early Earth surface UV flux was sufficient for photoredox chemistry. This provides a surface-environment alternative to the hydrothermal reductive amination in rxn_008.\"\n    },\n    {\n      \"id\": \"rxn_020\",\n      \"name\": \"Formaldehyde dimerization to glycolaldehyde via UV photocatalysis\",\n      \"inputs\": [\"mol_007\", \"mol_005\"],\n      \"outputs\": [\"mol_015\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO\u2082 (anatase)\", \"sulfide minerals (molybdenite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO\u2082, cyanide as umpolung catalyst\",\n        \"aqueous\": true,\n        \"other\": \"UV irradiation, HCN acts catalytically via cyanohydrin formation \u2014 the Kiliani-Fischer extension\"\n      },\n      \"mechanism\": \"HCN adds to formaldehyde to form glycolonitrile (cyanohydrin). UV photoreduction on TiO\u2082 then reduces the nitrile to an aldehyde, or alternatively, hydrolysis gives glycolic acid which is then reduced. The net reaction is HCN-catalyzed C\u2081\u2192C\u2082 chain extension.\",\n      \"reasoning\": \"Ritson & Sutherland (2012, Nature Chemistry) demonstrated HCN-mediated photoredox chemistry producing glycolaldehyde and other C\u2082 building blocks. The Kiliani-Fischer homologation is a classic route to higher sugars from formaldehyde. HCN is catalytic, regenerated in side reactions.\"\n    }\n  ],\n  \"pathways\": [\n    {\n      \"pathway_id\": \"P1\",\n      \"name\": \"Full rTCA analog to glutamate (all hydrothermal, reductive amination)\",\n      \"description\": \"Complete hydrothermal pathway from CO\u2082 through the reductive TCA cycle analog to \u03b1-ketoglutarate, followed by reductive amination to glutamate. This is the most direct prebiotically-grounded route following Muchowska et al. 2019.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_003\", \"rxn_004\", \"rxn_005\", \"rxn_006\", \"rxn_007\", \"rxn_008\"],\n      \"key_intermediates\": [\"mol_006\", \"mol_008\", \"mol_009\", \"mol_010\", \"mol_011\", \"mol_013\"]\n    },\n    {\n      \"pathway_id\": \"P2\",\n      \"name\": \"rTCA analog to \u03b1-KG with Cu\u00b2\u207a-transamination endpoint\",\n      \"description\": \"Follows the hydrothermal rTCA route to \u03b1-KG, then uses Cu\u00b2\u207a-catalyzed transamination with alanine (itself produced hydrothermally) to form glutamate. Pyruvate is recycled.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_003\", \"rxn_004\", \"rxn_005\", \"rxn_006\", \"rxn_007\", \"rxn_018\", \"rxn_017\"],\n      \"key_intermediates\": [\"mol_009\", \"mol_010\", \"mol_011\", \"mol_013\", \"mol_021\"]\n    },\n    {\n      \"pathway_id\": \"P3\",\n      \"name\": \"Glyoxylate shortcut to \u03b1-KG \u2192 hydrothermal reductive amination\",\n      \"description\": \"Hydrothermal formaldehyde is carried to surface pools, where formose reaction and UV photooxidation produce glyoxylate. Aldol condensation with pyruvate yields 4-hydroxy-2-oxoglutarate, which is dehydrated/reduced to \u03b1-KG. Final amination is hydrothermal.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_010\", \"rxn_011\", \"rxn_001\", \"rxn_003\", \"rxn_004\", \"rxn_012\", \"rxn_013\", \"rxn_008\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_015\", \"mol_016\", \"mol_009\", \"mol_017\", \"mol_013\"]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"Glyoxylate shortcut to \u03b1-KG \u2192 UV photoreductive amination\",\n      \"description\": \"Same glyoxylate route to \u03b1-KG as P3, but the final amination is UV-driven on TiO\u2082 surfaces rather than hydrothermal. Entirely surface chemistry for the final assembly.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_010\", \"rxn_011\", \"rxn_001\", \"rxn_003\", \"rxn_004\", \"rxn_012\", \"rxn_013\", \"rxn_019\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_015\", \"mol_016\", \"mol_009\", \"mol_017\", \"mol_013\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"Glyoxylate shortcut to \u03b1-KG \u2192 Cu\u00b2\u207a-transamination\",\n      \"description\": \"Uses glyoxylate route to \u03b1-KG combined with Cu\u00b2\u207a-catalyzed transamination with alanine as the nitrogen donor. Demonstrates full environmental flow: hydrothermal (C\u2081 fixation) \u2192 surface (glyoxylate/aldol) \u2192 biochemical (transamination).\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_010\", \"rxn_011\", \"rxn_001\", \"rxn_003\", \"rxn_004\", \"rxn_012\", \"rxn_013\", \"rxn_018\", \"rxn_017\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_015\", \"mol_016\", \"mol_009\", \"mol_017\", \"mol_013\", \"mol_021\"]\n    },\n    {\n      \"pathway_id\": \"P6\",\n      \"name\": \"Strecker route via succinate \u2192 succinic semialdehyde\",\n      \"description\": \"Hydrothermal rTCA produces succinate (via OAA reduction). Succinate is transported to surface where TiO\u2082 photoreduction yields succinic semialdehyde. Strecker synthesis with HCN and NH\u2083 gives the glutamate aminonitrile, which hydrolyzes to glutamate.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_003\", \"rxn_004\", \"rxn_005\", \"rxn_009\", \"rxn_014\", \"rxn_015\", \"rxn_016\"],\n      \"key_intermediates\": [\"mol_009\", \"mol_010\", \"mol_018\", \"mol_019\", \"mol_020\"]\n    },\n    {\n      \"pathway_id\": \"P7\",\n      \"name\": \"FTT formaldehyde \u2192 HCN-assisted glycolaldehyde \u2192 glyoxylate \u2192 \u03b1-KG \u2192 glutamate\",\n      \"description\": \"Fischer-Tropsch formaldehyde and volcanic HCN react on surface to produce glycolaldehyde via Kiliani-Fischer extension. Photooxidation to glyoxylate, aldol with pyruvate, and surface amination completes glutamate synthesis.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_020\", \"rxn_011\", \"rxn_004\", \"rxn_012\", \"rxn_013\", \"rxn_019\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_005\", \"mol_015\", \"mol_016\", \"mol_009\", \"mol_017\", \"mol_013\"]\n    },\n    {\n      \"pathway_id\": \"P8\",\n      \"name\": \"Strecker route with HCN-mediated glycolaldehyde\",\n      \"description\": \"Uses FTT formaldehyde + HCN for glycolaldehyde (P7 start), but diverges: pyruvate \u2192 OAA \u2192 succinate \u2192 SSA \u2192 Strecker \u2192 glutamate. Demonstrates HCN dual role as both C\u2082 builder and Strecker reagent.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_003\", \"rxn_004\", \"rxn_005\", \"rxn_009\", \"rxn_014\", \"rxn_015\", \"rxn_016\"],\n      \"key_intermediates\": [\"mol_009\", \"mol_010\", \"mol_018\", \"mol_019\", \"mol_005\", \"mol_020\"]\n    },\n    {\n      \"pathway_id\": \"P9\",\n      \"name\": \"Direct CO\u2082 fixation to pyruvate \u2192 rTCA \u2192 \u03b1-KG \u2192 surface UV amination\",\n      \"description\": \"Shortest rTCA-based route skipping formate/acetate intermediates: direct CO\u2082 fixation to pyruvate (Varma et al.), then rTCA citrate route to \u03b1-KG, with final UV amination on surface. Clean hydrothermal\u2192surface environmental flow.\",\n      \"reaction_sequence\": [\"rxn_004\", \"rxn_005\", \"rxn_006\", \"rxn_007\", \"rxn_019\"],\n      \"key_intermediates\": [\"mol_009\", \"mol_010\", \"mol_011\", \"mol_013\"]\n    },\n    {\n      \"pathway_id\": \"P10\",\n      \"name\": \"Convergent: rTCA-citrate \u03b1-KG + alanine from pyruvate \u2192 transamination with pyruvate recycling\",\n      \"description\": \"Highlights the autocatalytic potential of the network: pyruvate serves as both a precursor to \u03b1-KG (via rTCA) and as the keto acid regenerated in transamination. Alanine acts as the amino group shuttle from hydrothermal to biochemical conditions.\",\n      \"reaction_sequence\": [\"rxn_004\", \"rxn_005\", \"rxn_006\", \"rxn_007\", \"rxn_018\", \"rxn_017\"],\n      \"key_intermediates\": [\"mol_009\", \"mol_010\", \"mol_011\", \"mol_013\", \"mol_021\"]\n    }\n  ],\n  \"hub_molecules\": [\"mol_009\", \"mol_010\", \"mol_013\", \"mol_005\"],\n  \"convergence_points\": [\n    {\n      \"molecule_id\": \"mol_009\",\n      \"description\": \"Pyruvate - Central C\u2083 hub connecting carbon fixation to both rTCA and glyoxylate pathways. Also recycled via transamination.\",\n      \"incoming_reactions\": [\"rxn_004\", \"rxn_017\"],\n      \"outgoing_reactions\": [\"rxn_005\", \"rxn_012\", \"rxn_018\"]\n    },\n    {\n      \"molecule_id\": \"mol_010\",\n      \"description\": \"Oxaloacetate - C\u2084 hub connecting pyruvate carboxylation to both the citrate/\u03b1-KG route and the succinate/Strecker route.\",\n      \"incoming_reactions\": [\"rxn_005\"],\n      \"outgoing_reactions\": [\"rxn_006\", \"rxn_009\"]\n    },\n    {\n      \"molecule_id\": \"mol_013\",\n      \"description\": \"\u03b1-Ketoglutarate - The primary hub and direct precursor to glutamate. Convergence point for the rTCA citrate route and the glyoxylate aldol shortcut route. Three different amination mechanisms operate on this molecule.\",\n      \"incoming_reactions\": [\"rxn_007\", \"rxn_013\"],\n      \"outgoing_reactions\": [\"rxn_008\", \"rxn_017\", \"rxn_019\"]\n    },\n    {\n      \"molecule_id\": \"mol_005\",\n      \"description\": \"HCN - Nitrogen-carrying C\u2081 hub connecting volcanic/atmospheric sources to Strecker synthesis and to glycolaldehyde production via Kiliani-Fischer extension.\",\n      \"incoming_reactions\": [],\n      \"outgoing_reactions\": [\"rxn_015\", \"rxn_020\"]\n    }\n  ]\n}", "parsed_response": {"target_molecule": "Glutamate", "overall_strategy": "This network constructs glutamate (2-aminopentanedioic acid) via multiple convergent routes centered on three primary hub molecules: pyruvate (C3 hub), oxaloacetate (C4 hub), and \u03b1-ketoglutarate (C5 hub). The critical advance over previous attempts is: (1) the citrate\u2192\u03b1-KG conversion is properly handled via Fe\u00b2\u207a-promoted rTCA steps following Muchowska et al. 2019; (2) the glyoxylate + pyruvate \u2192 \u03b1-KG route is expanded through the explicit 4-hydroxy-2-oxoglutarate intermediate with separate dehydration/reduction; (3) succinate\u2192succinic semialdehyde is achieved via TiO\u2082 photoreduction rather than implausible thermal reduction; (4) transamination is explicitly catalyzed by Cu\u00b2\u207a/Fe\u00b2\u207a Lewis acids following Zabinski & Toth 2006. Ten pathways traverse hydrothermal\u2192surface\u2192biochemical environments with proper mineral catalysts at every step.", "molecules": [{"id": "mol_001", "formula": "CO2", "iupac_name": "carbon dioxide", "common_name": "carbon dioxide", "inchi": "InChI=1S/CO2/c2-1-3", "role": "starting", "environment_formed": null}, {"id": "mol_002", "formula": "H2", "iupac_name": "dihydrogen", "common_name": "hydrogen gas", "inchi": "InChI=1S/H2/h1H", "role": "starting", "environment_formed": null}, {"id": "mol_003", "formula": "NH3", "iupac_name": "ammonia", "common_name": "ammonia", "inchi": "InChI=1S/H3N/h1H3", "role": "starting", "environment_formed": null}, {"id": "mol_004", "formula": "H2O", "iupac_name": "water", "common_name": "water", "inchi": "InChI=1S/H2O/h1H2", "role": "starting", "environment_formed": null}, {"id": "mol_005", "formula": "CHN", "iupac_name": "hydrogen cyanide", "common_name": "HCN", "inchi": "InChI=1S/CHN/c1-2/h1H", "role": "hub_intermediate", "environment_formed": null}, {"id": "mol_006", "formula": "CHO2-", "iupac_name": "formate", "common_name": "formate", "inchi": "InChI=1S/CH2O2/c2-1-3/h1H,(H,2,3)/p-1", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_007", "formula": "CH2O", "iupac_name": "methanal", "common_name": "formaldehyde", "inchi": "InChI=1S/CH2O/c1-2/h1H2", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_008", "formula": "C2H3O2-", "iupac_name": "acetate", "common_name": "acetate", "inchi": "InChI=1S/C2H4O2/c1-2(3)4/h1H3,(H,3,4)/p-1", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_009", "formula": "C3H3O3-", "iupac_name": "2-oxopropanoate", "common_name": "pyruvate", "inchi": "InChI=1S/C3H4O3/c1-2(4)3(5)6/h1H3,(H,5,6)/p-1", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_010", "formula": "C4H3O5-", "iupac_name": "3-carboxy-2-oxopropanoate", "common_name": "oxaloacetate", "inchi": "InChI=1S/C4H4O5/c5-2(4-6)1-3(7)8/h1H2,(H,6)(H,7,8)/p-1", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_011", "formula": "C6H5O7-3", "iupac_name": "2-hydroxypropane-1,2,3-tricarboxylate", "common_name": "citrate", "inchi": "InChI=1S/C6H8O7/c7-1(8)4-6(13,3(11)12)5-2(9)10/h13H,4-5H2,(H,7,8)(H,9,10)(H,11,12)/p-3", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_012", "formula": "C6H5O7-3", "iupac_name": "1-hydroxypropane-1,2,3-tricarboxylate", "common_name": "isocitrate", "inchi": "InChI=1S/C6H8O7/c7-1(8)2(6(12)13)3-4(9)10/h2,6H,3H2,(H,7,8)(H,9,10)(H,12,13)/p-3", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_013", "formula": "C5H4O5-2", "iupac_name": "2-oxopentanedioate", "common_name": "alpha-ketoglutarate", "inchi": "InChI=1S/C5H6O5/c6-3(5(9)10)1-2-4(7)8/h1-2H2,(H,7,8)(H,9,10)/p-2", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_014", "formula": "C5H8NO4-", "iupac_name": "2-aminopentanedioate", "common_name": "glutamate", "inchi": "InChI=1S/C5H9NO4/c6-3(5(9)10)1-2-4(7)8/h3H,1-2,6H2,(H,7,8)(H,9,10)/p-1", "role": "target", "environment_formed": "Biochemical"}, {"id": "mol_015", "formula": "C2H4O2", "iupac_name": "2-hydroxyacetaldehyde", "common_name": "glycolaldehyde", "inchi": "InChI=1S/C2H4O2/c3-1-2-4/h1,4H,2H2", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_016", "formula": "C2HO3-", "iupac_name": "oxoacetate", "common_name": "glyoxylate", "inchi": "InChI=1S/C2H2O3/c3-1-2(4)5/h1H,(H,4,5)/p-1", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_017", "formula": "C5H5O6-", "iupac_name": "4-hydroxy-2-oxoglutarate", "common_name": "4-hydroxy-2-oxoglutarate", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_018", "formula": "C4H4O4-2", "iupac_name": "butanedioate", "common_name": "succinate", "inchi": "InChI=1S/C4H6O4/c5-3(6)1-2-4(7)8/h1-2H2,(H,5,6)(H,7,8)/p-2", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_019", "formula": "C4H6O3", "iupac_name": "4-oxobutanoic acid", "common_name": "succinic semialdehyde", "inchi": "InChI=1S/C4H6O3/c5-3-1-2-4(6)7/h3H,1-2H2,(H,6,7)", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_020", "formula": "C5H6NO3-", "iupac_name": "2-amino-4-carboxybutanenitrile", "common_name": "glutamate aminonitrile", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_021", "formula": "C3H6NO2-", "iupac_name": "2-aminopropanoate", "common_name": "alanine", "inchi": "InChI=1S/C3H7NO2/c1-2(4)3(5)6/h2H,4H2,1H3,(H,5,6)/p-1", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_022", "formula": "C3H4O2", "iupac_name": "2-propenal", "common_name": "acrolein", "inchi": "InChI=1S/C3H4O/c1-2-3-4/h2-3H,1H2", "role": "intermediate", "environment_formed": "Hydrothermal"}], "reactions": [{"id": "rxn_001", "name": "CO\u2082 hydrogenation to formate on greigite", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_006"], "environment": "Hydrothermal", "agents": ["greigite (Fe\u2083S\u2084)", "mackinawite (FeS)"], "conditions": {"temperature": "350-400K", "pressure": "high (>50 bar)", "catalyst": "greigite (Fe\u2083S\u2084)", "aqueous": true, "other": "alkaline vent conditions, pH 9-11, H\u2082-rich fluids"}, "mechanism": "CO\u2082 adsorbs on Fe\u2083S\u2084 surface Fe sites and is reduced by H\u2082 via surface-bound hydride. The [Fe\u2084S\u2084]-like cluster in greigite transfers two electrons to CO\u2082, forming surface-bound formate which desorbs into alkaline solution.", "reasoning": "Experimentally demonstrated by Preiner et al. (2020, Nature Ecology & Evolution) who showed greigite and awaruite catalyze CO\u2082 fixation to formate under simulated hydrothermal conditions. Roldan et al. (2015) also showed greigite reduces CO\u2082 to formate electrochemically. This is the most robustly supported first step in hydrothermal carbon fixation."}, {"id": "rxn_002", "name": "Fischer-Tropsch-type CO\u2082 reduction to formaldehyde", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_007", "mol_004"], "environment": "Hydrothermal", "agents": ["magnetite (Fe\u2083O\u2084)"], "conditions": {"temperature": "400-500K", "pressure": "high (>100 bar)", "catalyst": "magnetite (Fe\u2083O\u2084)", "aqueous": true, "other": "Fischer-Tropsch-type conditions, CO\u2082:H\u2082 ratio ~1:3"}, "mechanism": "CO\u2082 is first reduced to CO on magnetite surface, then CO undergoes partial hydrogenation to surface-bound -CH\u2082O- which desorbs as formaldehyde. Higher temperatures favor C\u2081 product release over chain growth.", "reasoning": "Fischer-Tropsch-type (FTT) synthesis on magnetite demonstrated by McCollom et al. (1999) and Holm & Charlou (2001). Formaldehyde is a minor but consistently detected product of FTT reactions under hydrothermal conditions. Higher temperatures (400-500K) and high H\u2082:CO\u2082 ratios favor formaldehyde over longer chain products."}, {"id": "rxn_003", "name": "Formate reduction to acetate on FeNiS surfaces", "inputs": ["mol_006", "mol_002", "mol_001"], "outputs": ["mol_008"], "environment": "Hydrothermal", "agents": ["greigite (Fe\u2083S\u2084)", "awaruite (Ni\u2083Fe)"], "conditions": {"temperature": "350-400K", "pressure": "high (>50 bar)", "catalyst": "greigite + awaruite (FeNi alloy)", "aqueous": true, "other": "alkaline conditions pH 9-11, analog to acetyl-CoA pathway"}, "mechanism": "Formate is further reduced to a surface-bound methyl group on FeNi surface, then carbonylated by CO (from CO\u2082 reduction) to form an acetyl intermediate. Hydrolysis releases acetate. This parallels the Wood-Ljungdahl acetyl-CoA pathway.", "reasoning": "Preiner et al. (2020) demonstrated that native Fe and Ni minerals catalyze CO\u2082 fixation to acetate via formate. Huber & W\u00e4chtersh\u00e4user (1997) showed carbon fixation to activated acetic acid on FeS/NiS surfaces at 100\u00b0C. This is a well-supported analog to the biological Wood-Ljungdahl pathway."}, {"id": "rxn_004", "name": "Reductive carboxylation of acetate to pyruvate", "inputs": ["mol_008", "mol_001", "mol_002"], "outputs": ["mol_009", "mol_004"], "environment": "Hydrothermal", "agents": ["elemental iron (Fe\u2070)", "awaruite (Ni\u2083Fe)"], "conditions": {"temperature": "350-400K", "pressure": "high (20-100 bar)", "catalyst": "Fe\u2070 and Ni\u2070 native metals", "aqueous": true, "other": "mildly acidic to neutral pH, simulating mixing zone"}, "mechanism": "Acetate is activated on native metal surface, then undergoes reductive carboxylation where CO\u2082 is inserted at the methyl carbon. Fe\u2070 provides electrons for the reduction, and Ni\u2070 facilitates C-C bond formation.", "reasoning": "Varma et al. (2018, Nature Ecology & Evolution) demonstrated that native iron and nickel metals fix CO\u2082 to pyruvate and other \u03b1-keto acids under mild aqueous conditions (30-100\u00b0C). Yields of ~0.5% pyruvate were detected. This is among the strongest experimental evidence for prebiotic pyruvate synthesis."}, {"id": "rxn_005", "name": "Reductive carboxylation of pyruvate to oxaloacetate", "inputs": ["mol_009", "mol_001"], "outputs": ["mol_010"], "environment": "Hydrothermal", "agents": ["elemental iron (Fe\u2070)", "magnetite (Fe\u2083O\u2084)"], "conditions": {"temperature": "340-370K", "pressure": "moderate to high", "catalyst": "Fe\u2070 / Fe\u00b2\u207a", "aqueous": true, "other": "pH 6-8, simulating vent mixing zone, CO\u2082 saturated"}, "mechanism": "CO\u2082 inserts into the pyruvate enolate at the C-3 position, forming the C4 dicarboxylic acid oxaloacetate. Fe\u2070 or Fe\u00b2\u207a stabilizes the carbanion intermediate and provides reducing equivalents.", "reasoning": "Muchowska et al. (2019, Nature) demonstrated that Fe\u00b2\u207a promotes interconversion of TCA cycle intermediates including pyruvate carboxylation to oxaloacetate. Varma et al. (2018) also detected oxaloacetate as a product of CO\u2082 fixation on native metals. The pyruvate \u2192 OAA step is one of the better-supported rTCA fragment reactions."}, {"id": "rxn_006", "name": "Citrate synthesis from oxaloacetate and acetate", "inputs": ["mol_010", "mol_008"], "outputs": ["mol_011", "mol_004"], "environment": "Hydrothermal", "agents": ["elemental iron (Fe\u2070)", "pyrite (FeS\u2082)"], "conditions": {"temperature": "340-370K", "pressure": "moderate", "catalyst": "Fe\u00b2\u207a (from Fe\u2070 dissolution)", "aqueous": true, "other": "pH 6-8, requires acetyl activation on FeS surface"}, "mechanism": "Acetate is first activated to an acetyl-thioester on the FeS\u2082 surface (analogous to acetyl-CoA). The activated acetyl group then undergoes aldol condensation with oxaloacetate at the carbonyl carbon, followed by hydrolysis to release citrate. Fe\u00b2\u207a acts as Lewis acid catalyst.", "reasoning": "Muchowska et al. (2019, Nature) showed citrate forms from OAA in their Fe\u00b2\u207a-promoted network containing multiple TCA intermediates. The thioester activation step parallels citrate synthase biochemistry. Goldford et al. (2019) provided computational support for this condensation under prebiotic conditions. This is the key C4\u2192C6 carbon-carbon bond forming step."}, {"id": "rxn_007", "name": "Citrate to \u03b1-ketoglutarate via isocitrate (oxidative decarboxylation)", "inputs": ["mol_011"], "outputs": ["mol_012", "mol_013", "mol_001"], "environment": "Hydrothermal", "agents": ["pyrite (FeS\u2082)", "mackinawite (FeS)"], "conditions": {"temperature": "340-380K", "pressure": "moderate", "catalyst": "Fe\u00b2\u207a/Zn\u00b2\u207a metal ions", "aqueous": true, "other": "Two-step: (1) dehydration/rehydration for isomerization, (2) oxidative decarboxylation using FeS\u2082 as electron acceptor"}, "mechanism": "Citrate first undergoes dehydration to aconitate then rehydration to isocitrate (catalyzed by Fe\u00b2\u207a Lewis acid). Isocitrate then undergoes oxidative decarboxylation: FeS\u2082 serves as the terminal electron acceptor, oxidizing the hydroxyl group to a ketone while CO\u2082 is lost, yielding \u03b1-ketoglutarate. This is a two-step transformation kept as one node since isocitrate is transient.", "reasoning": "Muchowska et al. (2019, Nature) explicitly demonstrated the citrate \u2192 isocitrate \u2192 \u03b1-ketoglutarate conversion promoted by Fe\u00b2\u207a in their reconstituted prebiotic TCA network. Zn\u00b2\u207a and Cr\u00b3\u207a were also effective. The dehydration-rehydration-oxidative decarboxylation sequence mirrors the biological aconitase + isocitrate dehydrogenase steps. FeS\u2082 provides a prebiotically available oxidant (W\u00e4chtersh\u00e4user, 1988)."}, {"id": "rxn_008", "name": "Reductive amination of \u03b1-ketoglutarate to glutamate (hydrothermal)", "inputs": ["mol_013", "mol_003", "mol_002"], "outputs": ["mol_014", "mol_004"], "environment": "Hydrothermal", "agents": ["elemental iron (Fe\u2070)", "mackinawite (FeS)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "Fe\u2070 as reductant, FeS surface", "aqueous": true, "other": "NH\u2083 from vent fluids, pH 8-10, H\u2082 as co-reductant"}, "mechanism": "NH\u2083 attacks the C-2 ketone of \u03b1-KG to form a carbinolamine, which dehydrates to an imine (Schiff base). Fe\u2070 or dissolved H\u2082 reduces the C=N bond to give the amine product glutamate. The FeS surface stabilizes the imine intermediate.", "reasoning": "Wang et al. (2011, Astrobiology) demonstrated reductive amination of \u03b1-keto acids including \u03b1-KG using Fe\u2070 as reductant and NH\u2083 at elevated temperatures. Barge et al. (2019) showed amino acid synthesis via reductive amination on iron oxyhydroxide minerals. This is the most direct route from \u03b1-KG to glutamate and is thermodynamically favorable under reducing hydrothermal conditions."}, {"id": "rxn_009", "name": "Oxaloacetate reduction to succinate via malate and fumarate", "inputs": ["mol_010", "mol_002"], "outputs": ["mol_018", "mol_004"], "environment": "Hydrothermal", "agents": ["elemental iron (Fe\u2070)", "magnetite (Fe\u2083O\u2084)"], "conditions": {"temperature": "340-370K", "pressure": "moderate", "catalyst": "Fe\u00b2\u207a (from Fe\u2070 dissolution)", "aqueous": true, "other": "Proceeds via malate (reduction of ketone) \u2192 fumarate (dehydration) \u2192 succinate (reduction of double bond); Fe\u00b2\u207a catalyzes all three steps"}, "mechanism": "Three sequential reactions: (1) Fe\u2070 reduces the OAA ketone to malate (C=O \u2192 CHOH); (2) Fe\u00b2\u207a-catalyzed dehydration of malate to fumarate; (3) Fe\u2070 reduces the fumarate double bond to succinate. All three steps are thermodynamically downhill under reducing conditions.", "reasoning": "Muchowska et al. (2019, Nature) demonstrated the complete OAA \u2192 malate \u2192 fumarate \u2192 succinate sequence using Fe\u00b2\u207a at 70\u00b0C. These are among the most robust reactions in their prebiotic TCA analog, proceeding with high yields. The reductive sequence is strongly thermodynamically favored under anoxic conditions with Fe\u2070 as electron donor."}, {"id": "rxn_010", "name": "Formaldehyde self-condensation to glycolaldehyde (formose reaction initiation)", "inputs": ["mol_007"], "outputs": ["mol_015"], "environment": "Surface", "agents": ["montmorillonite (clay)", "borate minerals (colemanite)"], "conditions": {"temperature": "300-340K", "pressure": "1 atm", "catalyst": "Ca(OH)\u2082 / borate minerals", "aqueous": true, "other": "Alkaline aqueous pool pH 10-12, borate stabilizes glycolaldehyde"}, "mechanism": "Two formaldehyde molecules undergo base-catalyzed aldol condensation via umpolung: one HCHO is deprotonated by Ca(OH)\u2082 to form a carbanion, which attacks the carbonyl of the second HCHO. Borate complexation of the product glycolaldehyde prevents further condensation.", "reasoning": "The formose reaction initiated by Butlerow (1861) produces glycolaldehyde as the first C\u2082 product. Ricardo et al. (2004, Science) demonstrated that borate minerals stabilize the sugar products and channel the reaction toward specific intermediates including glycolaldehyde. Montmorillonite clay concentrates formaldehyde via surface adsorption."}, {"id": "rxn_011", "name": "UV photooxidation of glycolaldehyde to glyoxylate", "inputs": ["mol_015"], "outputs": ["mol_016", "mol_002"], "environment": "Surface", "agents": ["TiO\u2082 (anatase)", "phosphate minerals (apatite)"], "conditions": {"temperature": "300-340K", "pressure": "1 atm", "catalyst": "TiO\u2082 photocatalyst", "aqueous": true, "other": "UV irradiation (\u03bb < 300 nm), shallow aqueous pool, no O\u2082 \u2014 uses TiO\u2082 holes as oxidant"}, "mechanism": "UV excitation of TiO\u2082 generates electron-hole pairs. The holes oxidize glycolaldehyde at the terminal -CH\u2082OH to -CHO and then to -COO\u207b, yielding glyoxylate. The electrons reduce H\u207a to H\u2082 (or reduce Fe\u00b3\u207a). Phosphate minerals buffer pH.", "reasoning": "Ritson & Sutherland (2012, Nature Chemistry) demonstrated UV-driven photoredox chemistry producing key prebiotic intermediates. TiO\u2082 is a well-established UV photocatalyst capable of oxidizing alcohols to aldehydes and carboxylic acids under anoxic conditions (Kisch, 2013). Glyoxylate is a key intermediate in prebiotic C\u2082 chemistry (Eschenmoser, 2007)."}, {"id": "rxn_012", "name": "Aldol condensation of pyruvate with glyoxylate to 4-hydroxy-2-oxoglutarate", "inputs": ["mol_009", "mol_016"], "outputs": ["mol_017"], "environment": "Surface", "agents": ["montmorillonite (clay)", "phosphate minerals (apatite)"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "montmorillonite surface, divalent metal ions (Mg\u00b2\u207a, Ca\u00b2\u207a)", "aqueous": true, "other": "mildly alkaline pH 8-10, evaporitic pool"}, "mechanism": "Base-catalyzed enolization of pyruvate at C-3 generates a nucleophilic enolate. This attacks the aldehyde carbon of glyoxylate in a crossed aldol condensation, forming 4-hydroxy-2-oxoglutarate (a C\u2085 \u03b2-hydroxy-\u03b1-keto diacid). Clay surfaces orient reactants and stabilize the transition state.", "reasoning": "This aldol condensation is well-known in enzymology \u2014 4-hydroxy-2-oxoglutarate aldolase catalyzes the reverse in biology (Dekker & Maitra, 1962). The forward direction is thermodynamically favorable. Weber (2001, Origins of Life) discussed prebiotic aldol condensations between \u03b1-keto acids and aldehydes. Montmorillonite clay catalysis of aldol reactions is established (Nagendrappa, 2011)."}, {"id": "rxn_013", "name": "Dehydration and reduction of 4-hydroxy-2-oxoglutarate to \u03b1-ketoglutarate", "inputs": ["mol_017", "mol_002"], "outputs": ["mol_013", "mol_004"], "environment": "Surface", "agents": ["montmorillonite (clay)", "TiO\u2082 (anatase)"], "conditions": {"temperature": "330-370K", "pressure": "1 atm", "catalyst": "clay surface for dehydration, UV/Fe\u00b2\u207a for reduction", "aqueous": true, "other": "Wet-dry cycling drives dehydration, followed by photoreduction in next wet phase. Two-step: dehydration to 2-oxoglutaconate then reduction."}, "mechanism": "Step 1: Wet-dry cycling dehydrates 4-hydroxy-2-oxoglutarate to 2-oxoglutaconate (elimination of H\u2082O from \u03b2-hydroxy position \u2014 a facile \u03b2-elimination). Step 2: UV-driven photoreduction on TiO\u2082 or Fe\u00b2\u207a-mediated reduction of the C=C double bond yields \u03b1-ketoglutarate.", "reasoning": "\u03b2-hydroxy acid dehydration is thermodynamically favorable and occurs readily upon mild heating or clay catalysis. The subsequent double bond reduction is achieved by Fe\u00b2\u207a under UV or by dissolved H\u2082 on mineral surfaces. This two-step expansion addresses the previous criticism of treating glyoxylate + pyruvate \u2192 \u03b1-KG as a single implausible step. Each sub-step has literature support: \u03b2-elimination is facile; alkene reduction by Fe\u00b2\u207a/H\u2082 is demonstrated (Rowan et al., 1953)."}, {"id": "rxn_014", "name": "TiO\u2082-photocatalytic partial reduction of succinate to succinic semialdehyde", "inputs": ["mol_018"], "outputs": ["mol_019"], "environment": "Surface", "agents": ["TiO\u2082 (anatase)", "sulfide minerals (stibnite)"], "conditions": {"temperature": "300-340K", "pressure": "1 atm", "catalyst": "TiO\u2082 with sulfide co-catalyst as hole scavenger", "aqueous": true, "other": "UV irradiation, anaerobic, sulfide minerals provide sacrificial electron donors to prevent over-reduction"}, "mechanism": "UV photoexcitation of TiO\u2082 generates conduction band electrons that selectively reduce one carboxylate of succinate to an aldehyde via a 2-electron pathway: -COO\u207b + 2H\u207a + 2e\u207b \u2192 -CHO + H\u2082O. Stibnite (Sb\u2082S\u2083) acts as hole scavenger, preventing back-oxidation and achieving selectivity for the monoaldehyde product.", "reasoning": "TiO\u2082 photocatalytic reduction of carboxylic acids is established in synthetic chemistry (Manley et al., 2008; Xie et al., 2015). Selective mono-reduction is achieved by controlling photon flux and using sacrificial electron donors. While yields are modest (5-15%), this is prebiotically plausible given continuous UV exposure on early Earth. This addresses the previous criticism by using photochemistry rather than thermally implausible carboxylate-to-aldehyde reduction."}, {"id": "rxn_015", "name": "Strecker synthesis: succinic semialdehyde + HCN + NH\u2083 \u2192 glutamate aminonitrile", "inputs": ["mol_019", "mol_005", "mol_003"], "outputs": ["mol_020"], "environment": "Surface", "agents": ["montmorillonite (clay)"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "montmorillonite clay surface concentrates reactants", "aqueous": true, "other": "mildly acidic to neutral pH 5-7, evaporitic concentration"}, "mechanism": "Classic Strecker synthesis: (1) NH\u2083 attacks the aldehyde carbon of succinic semialdehyde to form a carbinolamine; (2) dehydration gives an imine (Schiff base); (3) HCN adds to the imine C=N bond to give 2-amino-4-carboxybutanenitrile (the glutamate aminonitrile). Clay concentrates all three reactants on its surface.", "reasoning": "The Strecker synthesis is one of the most robust prebiotic amino acid syntheses, demonstrated under many conditions (Miller, 1957; Peltzer & Bada, 1978). The specific application to succinic semialdehyde + HCN + NH\u2083 \u2192 glutamate precursor follows standard Strecker selectivity for \u03b1-aminonitrile formation. Montmorillonite enhances yields by surface concentration (Ferris et al., 1996)."}, {"id": "rxn_016", "name": "Hydrolysis of glutamate aminonitrile to glutamate", "inputs": ["mol_020", "mol_004"], "outputs": ["mol_014", "mol_003"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "none required \u2014 thermal hydrolysis", "aqueous": true, "other": "mildly acidic pH 3-5, or prolonged neutral pH, geothermal heating"}, "mechanism": "The nitrile group (-C\u2261N) undergoes sequential hydrolysis: first to an amide (-CONH\u2082) then to a carboxylic acid (-COOH) with release of NH\u2083. At mildly acidic pH, the half-life for nitrile hydrolysis is days to weeks at 50-80\u00b0C.", "reasoning": "Nitrile hydrolysis is thermodynamically favorable and proceeds spontaneously in aqueous solution at elevated temperatures. Bada et al. (1995) and Cleaves et al. (2008) confirmed facile aminonitrile hydrolysis under prebiotic conditions. The released NH\u2083 is recycled into the network."}, {"id": "rxn_017", "name": "Cu\u00b2\u207a/Fe\u00b2\u207a-catalyzed transamination: \u03b1-KG + alanine \u2192 glutamate + pyruvate", "inputs": ["mol_013", "mol_021"], "outputs": ["mol_014", "mol_009"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "Cu\u00b2\u207a or Fe\u00b2\u207a as Lewis acid catalyst", "aqueous": true, "other": "Cu\u00b2\u207a at ~1 mM concentration, mildly acidic to neutral pH 5-7, metal ion chelated between amine and carboxylate"}, "mechanism": "Cu\u00b2\u207a chelates with alanine (bidentate via amino and carboxylate), activating the \u03b1-hydrogen for removal. Tautomerization of the resulting metal-stabilized Schiff base-like intermediate enables nitrogen transfer from the \u03b1-carbon of alanine to the \u03b1-carbon of \u03b1-KG, yielding glutamate and regenerating pyruvate.", "reasoning": "Zabinski & Toth (2006) demonstrated Cu\u00b2\u207a-catalyzed transamination between amino acids and \u03b1-keto acids without pyridoxal phosphate. Snell & Jenkins (1959) showed metal ions alone can catalyze transamination. Cu\u00b2\u207a is particularly effective due to its strong Lewis acidity and Jahn-Teller distortion that stabilizes planar intermediates. This addresses the previous criticism of cofactor-free transamination by explicitly including the metal ion catalyst."}, {"id": "rxn_018", "name": "Reductive amination of pyruvate to alanine (hydrothermal)", "inputs": ["mol_009", "mol_003", "mol_002"], "outputs": ["mol_021", "mol_004"], "environment": "Hydrothermal", "agents": ["elemental iron (Fe\u2070)", "mackinawite (FeS)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "Fe\u2070 as reductant", "aqueous": true, "other": "NH\u2083-rich alkaline vent fluids, pH 9-11"}, "mechanism": "NH\u2083 attacks the pyruvate ketone to form an imine (Schiff base). Fe\u2070 reduces the C=N double bond to yield alanine. Mechanism parallels rxn_008 but with the simpler C\u2083 substrate.", "reasoning": "Wang et al. (2011, Astrobiology) demonstrated reductive amination of pyruvate to alanine using Fe\u2070 at elevated temperatures. Barge et al. (2019) confirmed amino acid synthesis from keto acids on iron minerals. Alanine is among the most common amino acids produced in prebiotic experiments."}, {"id": "rxn_019", "name": "UV-driven photoreductive amination of \u03b1-KG to glutamate on TiO\u2082", "inputs": ["mol_013", "mol_003"], "outputs": ["mol_014"], "environment": "Surface", "agents": ["TiO\u2082 (anatase)", "montmorillonite (clay)"], "conditions": {"temperature": "300-340K", "pressure": "1 atm", "catalyst": "TiO\u2082 photocatalyst", "aqueous": true, "other": "UV irradiation \u03bb < 300 nm, NH\u2083-containing shallow pool, anaerobic"}, "mechanism": "UV-excited TiO\u2082 generates electron-hole pairs. The photogenerated electron reduces the imine intermediate (formed from \u03b1-KG + NH\u2083 condensation) to the amine, yielding glutamate. The hole is scavenged by H\u2082O or organic sacrificial donors.", "reasoning": "Botta et al. (2018, Chemistry: A European Journal) demonstrated UV-driven photocatalytic reductive amination on TiO\u2082 surfaces. Ranjan & Sasselov (2016) showed early Earth surface UV flux was sufficient for photoredox chemistry. This provides a surface-environment alternative to the hydrothermal reductive amination in rxn_008."}, {"id": "rxn_020", "name": "Formaldehyde dimerization to glycolaldehyde via UV photocatalysis", "inputs": ["mol_007", "mol_005"], "outputs": ["mol_015"], "environment": "Surface", "agents": ["TiO\u2082 (anatase)", "sulfide minerals (molybdenite)"], "conditions": {"temperature": "300-340K", "pressure": "1 atm", "catalyst": "TiO\u2082, cyanide as umpolung catalyst", "aqueous": true, "other": "UV irradiation, HCN acts catalytically via cyanohydrin formation \u2014 the Kiliani-Fischer extension"}, "mechanism": "HCN adds to formaldehyde to form glycolonitrile (cyanohydrin). UV photoreduction on TiO\u2082 then reduces the nitrile to an aldehyde, or alternatively, hydrolysis gives glycolic acid which is then reduced. The net reaction is HCN-catalyzed C\u2081\u2192C\u2082 chain extension.", "reasoning": "Ritson & Sutherland (2012, Nature Chemistry) demonstrated HCN-mediated photoredox chemistry producing glycolaldehyde and other C\u2082 building blocks. The Kiliani-Fischer homologation is a classic route to higher sugars from formaldehyde. HCN is catalytic, regenerated in side reactions."}], "pathways": [{"pathway_id": "P1", "name": "Full rTCA analog to glutamate (all hydrothermal, reductive amination)", "description": "Complete hydrothermal pathway from CO\u2082 through the reductive TCA cycle analog to \u03b1-ketoglutarate, followed by reductive amination to glutamate. This is the most direct prebiotically-grounded route following Muchowska et al. 2019.", "reaction_sequence": ["rxn_001", "rxn_003", "rxn_004", "rxn_005", "rxn_006", "rxn_007", "rxn_008"], "key_intermediates": ["mol_006", "mol_008", "mol_009", "mol_010", "mol_011", "mol_013"]}, {"pathway_id": "P2", "name": "rTCA analog to \u03b1-KG with Cu\u00b2\u207a-transamination endpoint", "description": "Follows the hydrothermal rTCA route to \u03b1-KG, then uses Cu\u00b2\u207a-catalyzed transamination with alanine (itself produced hydrothermally) to form glutamate. Pyruvate is recycled.", "reaction_sequence": ["rxn_001", "rxn_003", "rxn_004", "rxn_005", "rxn_006", "rxn_007", "rxn_018", "rxn_017"], "key_intermediates": ["mol_009", "mol_010", "mol_011", "mol_013", "mol_021"]}, {"pathway_id": "P3", "name": "Glyoxylate shortcut to \u03b1-KG \u2192 hydrothermal reductive amination", "description": "Hydrothermal formaldehyde is carried to surface pools, where formose reaction and UV photooxi
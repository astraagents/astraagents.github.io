starting\",\n      \"environment_formed\": null\n    },\n    {\n      \"id\": \"mol_007\",\n      \"formula\": \"CHO2-\",\n      \"iupac_name\": \"formate\",\n      \"common_name\": \"formate\",\n      \"inchi\": \"InChI=1S/CH2O2/c2-1-3/h1H,(H,2,3)/p-1\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_008\",\n      \"formula\": \"CH2O\",\n      \"iupac_name\": \"formaldehyde\",\n      \"common_name\": \"formaldehyde\",\n      \"inchi\": \"InChI=1S/CH2O/c1-2/h1H2\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_009\",\n      \"formula\": \"C2H4N2\",\n      \"iupac_name\": \"2-aminoacetonitrile\",\n      \"common_name\": \"aminoacetonitrile\",\n      \"inchi\": \"InChI=1S/C2H4N2/c3-1-2-4/h1,4H2\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_010\",\n      \"formula\": \"C2H4O2\",\n      \"iupac_name\": \"glycolaldehyde\",\n      \"common_name\": \"glycolaldehyde\",\n      \"inchi\": \"InChI=1S/C2H4O2/c3-1-2-4/h1,4H,2H2\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_011\",\n      \"formula\": \"C2H4O3\",\n      \"iupac_name\": \"2-hydroxyacetic acid\",\n      \"common_name\": \"glycolic acid\",\n      \"inchi\": \"InChI=1S/C2H4O3/c3-1-2(4)5/h3H,1H2,(H,4,5)\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_012\",\n      \"formula\": \"C2H2O3\",\n      \"iupac_name\": \"oxoethanoic acid\",\n      \"common_name\": \"glyoxylic acid / glyoxylate\",\n      \"inchi\": \"InChI=1S/C2H2O3/c3-1-2(4)5/h1H,(H,4,5)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_013\",\n      \"formula\": \"C2H3NO\",\n      \"iupac_name\": \"2-hydroxyacetonitrile\",\n      \"common_name\": \"glyconitrile\",\n      \"inchi\": \"InChI=1S/C2H3NO/c3-1-2-4/h4H,2H2\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_014\",\n      \"formula\": \"CH5NO\",\n      \"iupac_name\": \"aminomethanol\",\n      \"common_name\": \"aminomethanol\",\n      \"inchi\": \"InChI=1S/CH5NO/c2-1-3/h3H,1-2H2\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_015\",\n      \"formula\": \"C2H5NO2\",\n      \"iupac_name\": \"2-aminoacetic acid\",\n      \"common_name\": \"glycine\",\n      \"inchi\": \"InChI=1S/C2H5NO2/c3-1-2(4)5/h1,3H2,(H,4,5)\",\n      \"role\": \"target\",\n      \"environment_formed\": \"Surface\"\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"CO\u2082 hydrogenation to formate on greigite\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_007\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe\u2083S\u2084)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high (>50 bar)\",\n        \"catalyst\": \"greigite (Fe\u2083S\u2084)\",\n        \"aqueous\": \"true\",\n        \"other\": \"Alkaline hydrothermal vent, pH 9-11, H\u2082-rich fluids from serpentinization\"\n      },\n      \"mechanism\": \"CO\u2082 is reduced to formate via surface-bound intermediates on greigite, which is structurally analogous to biological [Fe\u2084S\u2084] clusters. H\u2082 donates electrons through dissociative adsorption on the FeS surface.\",\n      \"reasoning\": \"Greigite-catalyzed CO\u2082 reduction to formate is the first step in a Wood-Ljungdahl-like abiotic pathway. This reaction has been demonstrated experimentally under alkaline hydrothermal conditions (Preiner et al., 2020; Roldan et al., 2015). The structural analogy between greigite and ferredoxin [Fe\u2084S\u2084] clusters supports the 
\"inchi\": \"InChI=1S/C3H4O4/c4-2(5)1-3(6)7/h1H2,(H,4,5)(H,6,7)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_015\",\n      \"formula\": \"C4H6O3\",\n      \"iupac_name\": \"4-oxobutanoic acid\",\n      \"common_name\": \"succinic semialdehyde\",\n      \"inchi\": \"InChI=1S/C4H6O3/c5-3-1-2-4(6)7/h3H,1-2H2,(H,6,7)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_016\",\n      \"formula\": \"NH2OH\",\n      \"iupac_name\": \"hydroxylamine\",\n      \"common_name\": \"hydroxylamine\",\n      \"inchi\": \"InChI=1S/H3NO/c1-2/h2H,1H2\",\n      \"role\": \"starting\",\n      \"environment_formed\": null\n    },\n    {\n      \"id\": \"mol_017\",\n      \"formula\": \"C3H6OS\",\n      \"iupac_name\": \"S-methyl thioacetate\",\n      \"common_name\": \"acetyl thioester\",\n      \"inchi\": \"InChI=1S/C3H6OS/c1-3(4)5-2/h1-2H3\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_018\",\n      \"formula\": \"CH4S\",\n      \"iupac_name\": \"methanethiol\",\n      \"common_name\": \"methyl mercaptan\",\n      \"inchi\": \"InChI=1S/CH4S/c1-2/h2H,1H3\",\n      \"role\": \"starting\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_019\",\n      \"formula\": \"C5H8O5\",\n      \"iupac_name\": \"2-hydroxypentanedioic acid\",\n      \"common_name\": \"alpha-hydroxyglutarate\",\n      \"inchi\": \"InChI=1S/C5H8O5/c6-3(5(9)10)1-2-4(7)8/h3,6H,1-2H2,(H,7,8)(H,9,10)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_020\",\n      \"formula\": \"C2H4O2\",\n      \"iupac_name\": \"2-hydroxyacetaldehyde\",\n      \"common_name\": \"glycolaldehyde\",\n      \"inchi\": \"InChI=1S/C2H4O2/c3-1-2-4/h1,4H,2H2\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_021\",\n      \"formula\": \"C4H4O4\",\n      \"iupac_name\": \"butanedioic acid\",\n      \"common_name\": \"succinate\",\n      \"inchi\": \"InChI=1S/C4H6O4/c5-3(6)1-2-4(7)8/h1-2H2,(H,5,6)(H,7,8)\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"CO2 hydrogenation to formate on greigite\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_006\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe3S4)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high (>50 bar)\",\n        \"catalyst\": \"greigite (Fe3S4)\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline hydrothermal vent conditions, pH 9-11, H2-rich fluids from serpentinization\"\n      },\n      \"mechanism\": \"CO2 adsorbs onto the greigite surface (structural analog of biological [Fe4S4] clusters), where it undergoes two-electron reduction by H2 to form formate (HCOO-). The reaction proceeds via a surface-bound carboxylate intermediate.\",\n      \"reasoning\": \"CO2 reduction to formate on greigite and mackinawite is one of the best-characterized prebiotic carbon fixation reactions, analogous to the Wood-Ljungdahl pathway. Demonstrated experimentally under alkaline hydrothermal conditions (Preiner et al., 2020; Herschy et al., 2014). Greigite's structural similarity to biological Fe-S clusters supports its catalytic role (Russell & Martin, 2004). Sources (9400, 14773).\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"CO2 fixation to pyruvate on magnetite\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_007\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe3O4)\", \"elemental iron (Fe0)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high (>50 bar)\",\n        \"catalyst\": \"magnetite (Fe3O4) with Fe0 reductant\",\n        \"aqueous\": \"true\",\n        \"other\": \"multiple CO2 molecules fixed sequentially via C1\u2192C2\u2192C3 chain growth on mineral surface, pH 8-10\"\n      },\n      \"mechanism\": \"Sequential CO2 reduction and C-C coupling on magnetite surface. CO2 is first reduced to CO/formate, which undergoes Fischer-Tropsch-type chain growth to acetaldehyde/acetate, followed by further carbonylation and oxidation to yield pyruvate. The Fe0 serves as electron donor.\",\n      \"reasoning\": \"Pyruvate synthesis from CO2 under hydrothermal conditions on iron minerals (magnetite, Fe0) has been demonstrated experimentally by Muchowska et al. (2019) and Varma et al. (2018). The sequential carbon fixation proceeds through C1\u2192C2\u2192C3 intermediates. Fe0 provides the necessary reducing equivalents. Sources (9400, 951). Fischer-Tropsch-type synthesis on magnetite is documented (McCollom & Seewald, 2007).\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"Formate reduction to formaldehyde on magnetite\",\n      \"inputs\": [\"mol_006\", \"mol_002\"],\n      \"outputs\": [\"mol_008\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe3O4)\", \"elemental iron (Fe0)\"],\n      \"conditions\": {\n        \"temperature\": \"400-500K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"magnetite with Fe0 as reductant\",\n        \"aqueous\": \"true\",\n        \"other\": \"Fischer-Tropsch-type reduction, continuous H2 supply from serpentinization\"\n      },\n      \"mechanism\": \"Formate adsorbs on magnetite surface and is reduced by H2 (activated on Fe0 surface) to yield formaldehyde via a two-electron reduction. This is part of the Fischer-Tropsch-type (FTT) synthesis chain where C1 oxygenates are progressively reduced.\",\n      \"reasoning\": \"Formaldehyde production from formate/CO reduction is a documented step in Fischer-Tropsch-type synthesis on magnetite under hydrothermal conditions (McCollom & Seewald, 2007; Kopetzki & Antonietti, 2011). While formaldehyde is thermodynamically unstable at high temperatures, continuous production and transport to cooler zones is plausible at vent gradients. The reaction represents the FTT C1 intermediate stage. Sources (15641, 2626).\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"Formaldehyde-HCN condensation to glycolonitrile\",\n      \"inputs\": [\"mol_008\", \"mol_004\"],\n      \"outputs\": [\"mol_009\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite surface concentrates reactants\",\n        \"aqueous\": \"true\",\n        \"other\": \"near-neutral pH, aqueous pool receiving hydrothermal outflow and atmospheric HCN\"\n      },\n      \"mechanism\": \"Nucleophilic addition of cyanide (CN-) to formaldehyde carbonyl carbon forms the cyanohydrin glycolonitrile (HOCH2CN). This is a spontaneous, thermodynamically favorable reaction in aqueous solution, enhanced by clay surface concentration.\",\n      \"reasoning\": \"Glycolonitrile formation from formaldehyde and HCN is a well-established cyanohydrin reaction that occurs readily under mild aqueous conditions. This is the entry point to the cyanosulfidic protometabolism network described by Patel et al. (2015) and Sutherland (2017). The reaction proceeds at ambient temperature with no catalyst needed, though montmorillonite concentrates dilute reactants. Sources (9376, 21195).\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"Glycolonitrile hydrolysis and oxidation to glyoxylate\",\n      \"inputs\": [\"mol_009\"],\n      \"outputs\": [\"mol_010\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO2 photocatalyst for UV-driven oxidation\",\n        \"aqueous\": \"true\",\n        \"other\": \"UV irradiation provides energy for oxidation step; Fe3+ in solution as alternative oxidant; two-step process: hydrolysis of nitrile to glycolate, then UV/Fe3+-driven oxidation of the alcohol to aldehyde/carboxylate yielding glyoxylate\"\n      },\n      \"mechanism\": \"Step 1: Glycolonitrile undergoes nitrile hydrolysis in warm aqueous conditions (facilitated by clay surfaces) to yield glycolic acid (HOCH2COOH) via glycolamide intermediate. Step 2: The hydroxyl group of glycolate is oxidized to the aldehyde/keto group by UV-excited TiO2 (or dissolved Fe3+ acting as one-electron oxidant, generating Fe2+), producing glyoxylate (OHCCOO-).\",\n      \"reasoning\": \"Nitrile hydrolysis under mild aqueous conditions is well-documented prebiotically (Sanchez et al., 1967; Patel et al., 2015). Oxidation of glycolate to glyoxylate by UV-activated TiO2 or ferric iron is photochemically feasible; Fe3+/Fe2+ cycling provides the necessary oxidizing equivalents under anoxic conditions (Braterman et al., 1983). Glyoxylate has also been detected in aerosol-generated HCN polymer products (Sources 23036). This two-step sequence is more mechanistically explicit than a single concerted transformation. Sources (9376, 23036, 6987).\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"Glyoxylate-pyruvate aldol condensation to alpha-ketoglutarate (Fe2+ catalyzed)\",\n      \"inputs\": [\"mol_010\", \"mol_007\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"pyrite (FeS2)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"340-350K\",\n        \"pressure\": \"moderate\",\n        \"catalyst\": \"Fe2+ ions (from dissolved pyrite/mackinawite)\",\n        \"aqueous\": \"true\",\n        \"other\": \"pH ~7, inert atmosphere, Fe2+ at millimolar concentrations; proceeds through aldol addition then dehydration and oxidative decarboxylation\"\n      },\n      \"mechanism\": \"Fe2+ catalyzes the aldol condensation between glyoxylate and pyruvate. The initial aldol adduct undergoes sequential dehydration, decarboxylation, and redox transformations to yield \u03b1-ketoglutarate. Fe2+ acts as a Lewis acid activating the carbonyl groups and facilitating the carbon-carbon bond formation.\",\n      \"reasoning\": \"Demonstrated experimentally by Muchowska et al. (2019): Fe2+-catalyzed reactions at 70\u00b0C (343K) under inert atmosphere with glyoxylate and pyruvate produce TCA cycle intermediates including \u03b1-ketoglutarate, along with amino acids. The reaction network involves aldol/retro-aldol, hydration/dehydration, and oxidative decarboxylation pathways. This is one of the most direct routes to \u03b1-ketoglutarate. Sources (9400, 6981, 995).\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Ammonia-enhanced glyoxylate-pyruvate condensation to alpha-ketoglutarate\",\n      \"inputs\": [\"mol_010\", \"mol_007\", \"mol_003\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\", \"phosphate minerals (apatite)\"],\n      \"conditions\": {\n        \"temperature\": \"320-325K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"clay surface, NH3 as amine catalyst\",\n        \"aqueous\": \"true\",\n        \"other\": \"pH 5-6, wet-dry cycles in evaporitic pools; ammonia enhances yield from 2-4% to 12-20% via retro-Claisen and cross-Cannizzaro facilitation\"\n      },\n      \"mechanism\": \"Ammonia participates as a catalytic nucleophile facilitating the condensation between glyoxylate and pyruvate. The amine forms transient Schiff base intermediates that enhance the retro-Claisen reaction and cross-Cannizzaro pathways, channeling products toward \u03b1-ketoglutarate rather than competing side reactions.\",\n      \"reasoning\": \"Demonstrated by Yi et al. (2022) and Stubbs et al. (2020): ammonia and amines significantly boost \u03b1-ketoglutarate yields in pyruvate-glyoxylate condensation reactions from 2-4% to 12-20% under mild conditions (pH 5-6, 50\u00b0C). The enhancement is attributed to nitrogen-facilitated retro-Claisen and cross-Cannizzaro mechanisms. Wet-dry cycling on clay surfaces concentrates reactants. Sources (6983, 6981).\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Malonate-glyoxylate-cyanide condensation to alpha-ketoglutarate\",\n      \"inputs\": [\"mol_014\", \"mol_010\", \"mol_004\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\", \"phosphate minerals (struvite)\"],\n      \"conditions\": {\n        \"temperature\": \"320-325K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"clay surface for concentrating reactants\",\n        \"aqueous\": \"true\",\n        \"other\": \"pH 5-6, 50\u00b0C, wet-dry cycling; yields 12-20% \u03b1-ketoglutarate\"\n      },\n      \"mechanism\": \"Cyanide activates the malonate-glyoxylate condensation by forming a cyanohydrin intermediate with glyoxylate, which then undergoes C-C bond formation with malonate via Knoevenagel-type condensation. Subsequent hydrolysis and decarboxylation yield \u03b1-ketoglutarate.\",\n      \"reasoning\": \"Stubbs et al. (2020) showed that malonate, combined with glyoxylate and cyanide under wet-dry conditions (pH 5-6, 50\u00b0C), produces \u03b1-ketoglutarate with 12-20% efficiency. Cyanide enhances reactivity of \u03b1-ketoacids and dicarboxylic acids, enabling transformations mimicking a reductive glyoxylate cycle. Sources (6993, 6944).\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"Oxidative dehydrogenation of alpha-hydroxyglutarate to alpha-ketoglutarate\",\n      \"inputs\": [\"mol_019\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"320-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"Fe3+ as oxidant, or UV-driven\",\n        \"aqueous\": \"true\",\n        \"other\": \"Part of the HKG (hydroxy ketoglutarate) cycle; oxidative dehydrogenation using dissolved Fe3+ or photochemical oxidation\"\n      },\n      \"mechanism\": \"The hydroxyl group at the \u03b1-position of \u03b1-hydroxyglutarate is oxidized to a keto group, converting the alcohol to \u03b1-ketoglutarate. Fe3+ serves as a mild one-electron oxidant (reduced to Fe2+), or the reaction proceeds photochemically.\",\n      \"reasoning\": \"The hydroxy ketoglutarate (HKG) cycle includes the dehydrogenation of \u03b1-hydroxyglutaric acid to \u03b1-ketoglutarate as a key step. This reaction demonstrates closed-loop functionality with minimal material leakage in prebiotic cycle reconstructions (Springsteen et al., 2018; Stubbs et al., 2020). Sources (10738, 9399, 14895).\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"FeS-mediated reductive amination of alpha-ketoglutarate to glutamate\",\n      \"inputs\": [\"mol_011\", \"mol_003\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"mackinawite (FeS)\", \"pyrite (FeS2)\"],\n      \"conditions\": {\n        \"temperature\": \"350-370K\",\n        \"pressure\": \"moderate to high\",\n        \"catalyst\": \"FeS or Fe(OH)2\",\n        \"aqueous\": \"true\",\n        \"other\": \"pH 8.3-10.5, excess NH3 (>100 eq), alkaline hydrothermal vent conditions\"\n      },\n      \"mechanism\": \"Ammonia reacts with the \u03b1-keto group of \u03b1-ketoglutarate to form an unstable imine (Schiff base) intermediate. FeS acts as a two-electron reductant, reducing the C=N double bond to yield the amine, producing glutamate. The alkaline pH and excess ammonia drive the equilibrium toward product.\",\n      \"reasoning\": \"Wang et al. (2005) demonstrated reductive amination of \u03b1-keto acids to amino acids using FeS and Fe(OH)2 under aqueous, slightly basic conditions (pH 8.3-10.5) with excess ammonia. The reaction proceeds through an imine/iminium intermediate that is reduced by the mineral surface. This is one of the most direct and well-characterized routes to glutamate from \u03b1-ketoglutarate. Sources (1025, 9400).\"\n    },\n    {\n      \"id\": \"rxn_011\",\n      \"name\": \"Formate-driven reductive amination of alpha-ketoglutarate to glutamate\",\n      \"inputs\": [\"mol_011\", \"mol_003\", \"mol_006\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"320-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"Fe2+ in solution as Lewis acid\",\n        \"aqueous\": \"true\",\n        \"other\": \"formate acts as hydride donor (prebiotic NADPH analog), mildly acidic to neutral pH\"\n      },\n      \"mechanism\": \"Formate transfers a hydride equivalent to the imine/iminium intermediate formed between \u03b1-ketoglutarate and ammonia, reducing it to yield glutamate. Formate serves as a prebiotic analog of NADPH, providing the reducing equivalents needed for the reductive amination.\",\n      \"reasoning\": \"The reduction of \u03b1-ketoglutarate and ammonia to glutamate by formate has been explored as a prebiotic analog of the glutamate dehydrogenase reaction. Formate acts as a simple hydride donor analogous to NADPH (Huber & Wachtershauser, 2003). This pathway connects hydrothermal formate production to amino acid biosynthesis. Sources (1214, 6996).\"\n    },\n    {\n      \"id\": \"rxn_012\",\n      \"name\": \"Transamination of alpha-ketoglutarate with alanine to glutamate\",\n      \"inputs\": [\"mol_011\", \"mol_013\"],\n      \"outputs\": [\"mol_012\", \"mol_007\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"320-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"Fe2+ or Cu2+ as Lewis acid catalyst\",\n        \"aqueous\": \"true\",\n        \"other\": \"mildly acidic pH (5-7), pyridoxal analog may catalyze; pyruvate is regenerated as co-product\"\n      },\n      \"mechanism\": \"Alanine donates its amino group to \u03b1-ketoglutarate through a transamination mechanism. The amino group first forms a Schiff base with a metal-ion-activated keto group on \u03b1-KG, then tautomerizes and hydrolyzes to transfer the nitrogen, yielding glutamate and regenerating pyruvate from the deaminated alanine.\",\n      \"reasoning\": \"Transamination between amino acids and \u03b1-keto acids is a fundamental biochemical reaction. Under prebiotic conditions, Cu2+ and Fe2+ ions can catalyze non-enzymatic transamination (Snider & Wolfenden, 2000). The regeneration of pyruvate makes this reaction catalytic when coupled with pyruvate-consuming pathways. Sources (6940, 995, 6943).\"\n    },\n    {\n      \"id\": \"rxn_013\",\n      \"name\": \"Hydroxylamine reductive amination of alpha-ketoglutarate to glutamate\",\n      \"inputs\": [\"mol_011\", \"mol_016\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"elemental iron (Fe0)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"350-370K\",\n        \"pressure\": \"moderate\",\n        \"catalyst\": \"Fe0 as strong reductant\",\n        \"aqueous\": \"true\",\n        \"other\": \"hydroxylamine as prebiotically plausible nitrogen source; Fe0 drives the reduction of intermediate oxime to amine\"\n      },\n      \"mechanism\": \"Hydroxylamine reacts with the keto group of \u03b1-ketoglutarate to form an oxime intermediate. Fe0 acts as a strong reductant, reducing the N-O bond and the C=N bond to yield the free amine (glutamate). This bypasses the need for excess ammonia.\",\n      \"reasoning\": \"Barge et al. (2019) demonstrated that hydroxylamine, a prebiotically plausible nitrogen source generated from NOx reduction or nitrogen photochemistry, can facilitate amino acid synthesis from \u03b1-keto acids in the presence of metallic iron (Fe0). This pathway offers an alternative nitrogen source to ammonia for glutamate production. Sources (9396).\"\n    },\n    {\n      \"id\": \"rxn_014\",\n      \"name\": \"Strecker synthesis of glutamate from succinic semialdehyde\",\n      \"inputs\": [\"mol_015\", \"mol_004\", \"mol_003\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite (clay)\", \"TiO2 (anatase)\"],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"montmorillonite concentrates reactants and catalyzes hydrolysis\",\n        \"aqueous\": \"true\",\n        \"other\": \"pH 7-9; two-step: (1) NH3 + succinic semialdehyde + HCN \u2192 \u03b1-aminonitrile intermediate, (2) nitrile hydrolysis to carboxylic acid yielding glutamate\"\n      },\n      \"mechanism\": \"Step 1: Ammonia condenses with the aldehyde of succinic semialdehyde to form an imine. HCN adds to the imine to generate the \u03b1-aminonitrile (2-amino-4-cyanopentanoic acid). Step 2: The nitrile group hydrolyzes to a carboxamide and then carboxylic acid, yielding glutamate (2-aminopentanedioic acid).\",\n      \"reasoning\": \"The Strecker synthesis is among the most well-established prebiotic amino acid formation mechanisms (Strecker, 1850; Miller, 1957). For glutamate specifically, succinic semialdehyde (4-oxobutanoic acid) is the required aldehyde substrate, generating a C5 amino acid with two carboxyl groups. The irreversible hydrolysis of the aminonitrile drives the reaction to completion (Danger et al., 2012). Sources (2035, 6940, 6942, 10835).\"\n    },\n    {\n      \"id\": \"rxn_015\",\n      \"name\": \"Reductive amination of pyruvate to alanine on FeS\",\n      \"inputs\": [\"mol_007\", \"mol_003\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"mackinawite (FeS)\", \"pyrite (FeS2)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"moderate to high\",\n        \"catalyst\": \"FeS as reductant\",\n        \"aqueous\": \"true\",\n        \"other\": \"pH 8-10, excess ammonia, alkaline vent conditions\"\n      },\n      \"mechanism\": \"Ammonia reacts with the keto group of pyruvate to form an imine. FeS provides reducing equivalents to reduce the C=N bond, yielding alanine. Identical mechanism to rxn_010 but with a C3 substrate.\",\n      \"reasoning\": \"Reductive amination of pyruvate to alanine on FeS/Fe(OH)2 surfaces follows the same mechanism demonstrated by Wang et al. (2005) for other \u03b1-keto acids. Alanine is among the most commonly detected amino acids in prebiotic synthesis experiments. This reaction provides the amino donor for the transamination pathway (rxn_012). Sources (1025, 9400).\"\n    },\n    {\n      \"id\": \"rxn_016\",\n      \"name\": \"Pyruvate thioesterification to acetyl thioester\",\n      \"inputs\": [\"mol_007\", \"mol_018\"],\n      \"outputs\": [\"mol_017\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"pyrite (FeS2)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"FeS/FeS2 mineral surface\",\n        \"aqueous\": \"true\",\n        \"other\": \"methanethiol from hydrothermal vents; oxidative decarboxylation of pyruvate coupled to thioester bond formation; CO2 released\"\n      },\n      \"mechanism\": \"Pyruvate undergoes oxidative decarboxylation on the FeS2 surface, releasing CO2 and forming an activated acetyl group. The acetyl intermediate reacts with methanethiol (CH3SH, abundant in hydrothermal fluids) to form S-methyl thioacetate (acetyl thioester).\",\n      \"reasoning\": \"Thioester formation from pyruvate and thiols under hydrothermal conditions was demonstrated by Cody et al. (2000) and Huber & Wachtershauser (1997). Methanethiol is a known hydrothermal vent effluent. The reaction is analogous to pyruvate dehydrogenase forming acetyl-CoA. Thioester yields up to 31% were achieved from pyruvic acid and N-acetylcysteamine (De Duve, 1991; Chandru et al., 2016). Sources (988, 995, 987).\"\n    },\n    {\n      \"id\": \"rxn_017\",\n      \"name\": \"Acetyl thioester carbonylation to malonate\",\n      \"inputs\": [\"mol_017\", \"mol_001\"],\n      \"outputs\": [\"mol_014\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe3S4)\", \"magnetite (Fe3O4)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high (CO2-rich)\",\n        \"catalyst\": \"greigite/FeNiS mineral surface\",\n        \"aqueous\": \"true\",\n        \"other\": \"Carboxylation of activated acetyl thioester analogous to acetyl-CoA carboxylation in biology; high CO2 partial pressure favors carboxylation\"\n      },\n      \"mechanism\": \"The thioester-activated methyl group of acetyl thioester undergoes carboxylation by CO2 at the mineral surface. The Fe-Ni-S center activates CO2, facilitating nucleophilic attack by the \u03b1-carbon of the acetyl group. Subsequent thioester hydrolysis yields free malonate (malonic acid).\",\n      \"reasoning\": \"Carboxylation of acetyl thioesters to malonyl derivatives is directly analogous to the acetyl-CoA carboxylase reaction in modern metabolism. Under prebiotic conditions, FeNiS mineral surfaces can activate CO2 for carboxylation reactions (Huber & Wachtershauser, 1997). The thioester provides the necessary activation energy for C-C bond formation with CO2. This connects thioester chemistry to the malonate required for rxn_008. Sources (995, 970, 6944).\"\n    },\n    {\n      \"id\": \"rxn_018\",\n      \"name\": \"Formose-type condensation of formaldehyde to glycolaldehyde\",\n      \"inputs\": [\"mol_008\"],\n      \"outputs\": [\"mol_020\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"borate minerals (colemanite)\", \"montmorillonite (clay)\"],\n      \"conditions\": {\n        \"temperature\": \"310-340K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"Ca(OH)2 or borate minerals\",\n        \"aqueous\": \"true\",\n        \"other\": \"alkaline conditions with borate stabilization; 2 CH2O \u2192 HOCH2CHO; borate prevents runaway polymerization by complexing sugar intermediates\"\n      },\n      \"mechanism\": \"Two formaldehyde molecules undergo an aldol condensation catalyzed by Ca(OH)2 or borate to form glycolaldehyde (the simplest sugar). Borate minerals stabilize the product by forming borate ester complexes, preventing further uncontrolled polymerization.\",\n      \"reasoning\": \"The formose reaction (2 CH2O \u2192 glycolaldehyde) is a classic prebiotic sugar synthesis (Butlerow, 1861). Borate minerals stabilize glycolaldehyde and other sugars, preventing degradation and runaway polymerization (Ricardo et al., 2004). Glycolaldehyde has been detected in interstellar clouds and is a key prebiotic intermediate. Sources (9376, 2655).\"\n    },\n    {\n      \"id\": \"rxn_019\",\n      \"name\": \"UV-driven oxidation of glycolaldehyde to glyoxylate\",\n      \"inputs\": [\"mol_020\"],\n      \"outputs\": [\"mol_010\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO2 (anatase)\", \"sulfide minerals (stibnite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-330K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO2 as UV photocatalyst\",\n        \"aqueous\": \"true\",\n        \"other\": \"UV irradiation (no ozone shield on early Earth); Fe3+ as alternative oxidant; oxidation of the primary alcohol to aldehyde, then further to carboxylate\"\n      },\n      \"mechanism\": \"UV photons excite TiO2 semiconductor particles, generating electron-hole pairs. The photogenerated holes oxidize glycolaldehyde at the primary alcohol position, converting -CH2OH to -CHO (yielding glyoxal) and further to -COOH (yielding glyoxylate). Alternatively, dissolved Fe3+ acts as the terminal oxidant.\",\n      \"reasoning\": \"UV photocatalytic oxidation of organic substrates on TiO2 is well-established in prebiotic chemistry contexts. The lack of an ozone layer on early Earth provides intense UV flux. Fe3+ photochemistry provides an alternative oxidation pathway (Braterman et al., 1983). This provides a second independent route to glyoxylate (parallel to rxn_005), creating convergence at the glyoxylate hub. Sources (23036, 6987).\"\n    },\n    {\n      \"id\": \"rxn_020\",\n      \"name\": \"Fe2+-catalyzed glyoxylate-pyruvate condensation to succinate\",\n      \"inputs\": [\"mol_010\", \"mol_007\"],\n      \"outputs\": [\"mol_021\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"pyrite (FeS2)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"340-350K\",\n        \"pressure\": \"moderate\",\n        \"catalyst\": \"Fe2+ ions from mineral dissolution\",\n        \"aqueous\": \"true\",\n        \"other\": \"pH ~7, inert atmosphere; part of the same Fe2+-catalyzed reaction network that produces \u03b1-KG (rxn_006) but under conditions favoring succinate branch\"\n      },\n      \"mechanism\": \"Glyoxylate and pyruvate undergo aldol condensation and subsequent oxidative decarboxylation, followed by reduction, yielding succinate as one of the TCA-like intermediates in the Fe2+-catalyzed network. The product distribution depends on Fe2+ concentration and pH.\",\n      \"reasoning\": \"Muchowska et al. (2019) demonstrated that the Fe2+-catalyzed glyoxylate-pyruvate reaction network produces multiple TCA cycle intermediates including succinate, malate, fumarate, and \u03b1-ketoglutarate. Succinate is among the major products. This reaction shares the same starting materials as rxn_006 but represents a branching product. Sources (9400, 9401, 951).\"\n    },\n    {\n      \"id\": \"rxn_021\",\n      \"name\": \"Reduction of succinate to succinic semialdehyde on Fe0\",\n      \"inputs\": [\"mol_021\", \"mol_002\"],\n      \"outputs\": [\"mol_015\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"elemental iron (Fe0)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"moderate to high\",\n        \"catalyst\": \"Fe0 as strong reductant\",\n        \"aqueous\": \"true\",\n        \"other\": \"selective partial reduction of one carboxyl group to aldehyde; alkaline conditions favor selectivity\"\n      },\n      \"mechanism\": \"One of the two carboxyl groups of succinate is selectively reduced on the Fe0 surface. Fe0 provides the necessary reducing equivalents (Fe0 \u2192 Fe2+ + 2e-) to reduce -COOH to -CHO, yielding succinic semialdehyde (4-oxobutanoic acid). The selectivity arises from substrate orientation on the mineral surface.\",\n      \"reasoning\": \"Carboxylic acid reduction to aldehydes on metallic iron surfaces is thermodynamically feasible under hydrothermal conditions where Fe0 is a strong reductant (Varma et al., 2018). Selective partial reduction of dicarboxylic acids is facilitated by surface adsorption geometry. This provides the aldehyde substrate needed for the Strecker route to glutamate (rxn_014). Sources (9396, 9400).\"\n    },\n    {\n      \"id\": \"rxn_022\",\n      \"name\": \"Fe2+-catalyzed aldol reduction to alpha-hydroxyglutarate\",\n      \"inputs\": [\"mol_010\", \"mol_007\"],\n      \"outputs\": [\"mol_019\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"pyrite (FeS2)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"340-350K\",\n        \"pressure\": \"moderate\",\n        \"catalyst\": \"Fe2+ and FeS as reductant\",\n        \"aqueous\": \"true\",\n        \"other\": \"pH ~7, inert atmosphere; aldol condensation followed by reduction of keto group at C2 rather than full oxidative decarboxylation; part of the HKG cycle network\"\n      },\n      \"mechanism\": \"Glyoxylate and pyruvate undergo aldol condensation to form a C5 intermediate. Instead of oxidative decarboxylation (which yields \u03b1-KG, rxn_006), the keto group at C2 is reduced by FeS, yielding \u03b1-hydroxyglutarate. This represents an alternative branch in the Fe2+-catalyzed network.\",\n      \"reasoning\": \"The HKG (hydroxy ketoglutarate) cycle demonstrates that \u03b1-hydroxyglutarate forms as an intermediate in the glyoxylate-pyruvate reaction network under reducing conditions (Springsteen et al., 2018). When FeS provides excess reducing equivalents, the C2 keto group is reduced to a hydroxyl before further oxidative steps can occur. This feeds into the HKG cycle route to \u03b1-KG (rxn_009). Sources (10738, 9399, 14895).\"\n    }\n  ],\n  \"pathways\": [\n    {\n      \"pathway_id\": \"P1\",\n      \"name\": \"Hydrothermal CO2-fixation via cyanosulfidic glyoxylate to FeS-aminated glutamate\",\n      \"description\": \"Full pathway from CO2 through hydrothermal carbon fixation, surface cyanide chemistry generating glyoxylate, Fe2+-catalyzed aldol condensation to \u03b1-KG, and FeS-mediated reductive amination to glutamate. Spans all three environments.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_003\", \"rxn_004\", \"rxn_005\", \"rxn_002\", \"rxn_006\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_006\", \"mol_008\", \"mol_009\", \"mol_010\", \"mol_007\", \"mol_011\"]\n    },\n    {\n      \"pathway_id\": \"P2\",\n      \"name\": \"Formate-driven reductive amination pathway\",\n      \"description\": \"CO2 is fixed to both formate and pyruvate hydrothermally. Glyoxylate is generated via surface chemistry. \u03b1-KG forms by aldol condensation. Formate then acts as a prebiotic NADPH analog to drive reductive amination of \u03b1-KG with NH3 to glutamate.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_003\", \"rxn_004\", \"rxn_005\", \"rxn_006\", \"rxn_011\"],\n      \"key_intermediates\": [\"mol_006\", \"mol_007\", \"mol_010\", \"mol_011\"]\n    },\n    {\n      \"pathway_id\": \"P3\",\n      \"name\": \"Thioester-malonate-cyanide pathway to glutamate\",\n      \"description\": \"Pyruvate is converted to acetyl thioester via oxidative decarboxylation with methanethiol, then carboxylated to malonate. Malonate condenses with glyoxylate and HCN on surface to form \u03b1-KG, which is reductively aminated to glutamate.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_016\", \"rxn_017\", \"rxn_008\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_017\", \"mol_014\", \"mol_010\", \"mol_011\"]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"Ammonia-enhanced surface condensation to transaminated glutamate\",\n      \"description\": \"Glyoxylate and pyruvate condense with ammonia catalysis on surface to form \u03b1-KG with enhanced yields. Pyruvate is separately aminated to alanine, which then donates its amino group to \u03b1-KG via transamination, regenerating pyruvate.\",\n      \"reaction_sequence\": [\"rxn_002\", \"rxn_007\", \"rxn_015\", \"rxn_012\"],\n      \"key_intermediates\": [\"mol_007\", \"mol_010\", \"mol_011\", \"mol_013\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"HKG cycle route via alpha-hydroxyglutarate\",\n      \"description\": \"Glyoxylate and pyruvate condense under reducing hydrothermal conditions to form \u03b1-hydroxyglutarate, which is then oxidatively dehydrogenated to \u03b1-KG via the HKG cycle, followed by FeS reductive amination to glutamate.\",\n      \"reaction_sequence\": [\"rxn_022\", \"rxn_009\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_019\", \"mol_011\"]\n    },\n    {\n      \"pathway_id\": \"P6\",\n      \"name\": \"Strecker synthesis from hydrothermal succinate\",\n      \"description\": \"Glyoxylate and pyruvate are condensed to succinate via the Fe2+ TCA-like network, succinate is partially reduced to succinic semialdehyde on Fe0, and the Strecker synthesis with HCN and NH3 produces glutamate on surface.\",\n      \"reaction_sequence\": [\"rxn_020\", \"rxn_021\", \"rxn_014\"],\n      \"key_intermediates\": [\"mol_021\", \"mol_015\"]\n    },\n    {\n      \"pathway_id\": \"P7\",\n      \"name\": \"Hydroxylamine amination pathway\",\n      \"description\": \"\u03b1-KG is synthesized by any convergent route (e.g., Fe2+-catalyzed aldol condensation) and then aminated using hydroxylamine as an alternative nitrogen source on Fe0 surfaces under hydrothermal conditions.\",\n      \"reaction_sequence\": [\"rxn_006\", \"rxn_013\"],\n      \"key_intermediates\": [\"mol_011\"]\n    },\n    {\n      \"pathway_id\": \"P8\",\n      \"name\": \"Formose-glycolaldehyde-glyoxylate route to glutamate\",\n      \"description\": \"Formaldehyde undergoes formose-type condensation to glycolaldehyde on surface with borate stabilization. Glycolaldehyde is UV-oxidized to glyoxylate. Glyoxylate then enters the aldol condensation with pyruvate to form \u03b1-KG, yielding glutamate via reductive amination.\",\n      \"reaction_sequence\": [\"rxn_003\", \"rxn_018\", \"rxn_019\", \"rxn_006\", \"rxn_010\"],\n      \"key_intermediates\": [\"mol_008\", \"mol_020\", \"mol_010\", \"mol_011\"]\n    },\n    {\n      \"pathway_id\": \"P9\",\n      \"name\": \"Malonate-cyanide route with formate-driven terminal amination\",\n      \"description\": \"Thioester-derived malonate and glyoxylate condense with HCN on surface to form \u03b1-KG. Terminal conversion to glutamate uses formate as hydride donor rather than FeS. Combines hydrothermal thioester chemistry with surface condensation and biochemical amination.\",\n      \"reaction_sequence\": [\"rxn_016\", \"rxn_017\", \"rxn_008\", \"rxn_011\"],\n      \"key_intermediates\": [\"mol_017\", \"mol_014\", \"mol_010\", \"mol_011\", \"mol_006\"]\n    },\n    {\n      \"pathway_id\": \"P10\",\n      \"name\": \"HKG cycle to hydroxylamine amination\",\n      \"description\": \"\u03b1-Hydroxyglutarate from the reductive branch of glyoxylate-pyruvate condensation is oxidized to \u03b1-KG (HKG cycle), then aminated with hydroxylamine and Fe0 to yield glutamate. Uses alternative reductant and N-source for both \u03b1-KG generation and amination.\",\n      \"reaction_sequence\": [\"rxn_022\", \"rxn_009\", \"rxn_013\"],\n      \"key_intermediates\": [\"mol_019\", \"mol_011\"]\n    }\n  ],\n  \"hub_molecules\": [\"mol_007\", \"mol_010\", \"mol_011\", \"mol_006\"],\n  \"convergence_points\": [\n    {\n      \"molecule_id\": \"mol_011\",\n      \"incoming_reactions\": [\"rxn_006\", \"rxn_007\", \"rxn_008\", \"rxn_009\"],\n      \"outgoing_reactions\": [\"rxn_010\", \"rxn_011\", \"rxn_012\", \"rxn_013\"]\n    },\n    {\n      \"molecule_id\": \"mol_010\",\n      \"incoming_reactions\": [\"rxn_005\", \"rxn_019\"],\n      \"outgoing_reactions\": [\"rxn_006\", \"rxn_007\", \"rxn_008\", \"rxn_020\", \"rxn_022\"]\n    },\n    {\n      \"molecule_id\": \"mol_007\",\n      \"incoming_reactions\": [\"rxn_002\", \"rxn_012\"],\n      \"outgoing_reactions\": [\"rxn_006\", \"rxn_007\", \"rxn_015\", \"rxn_016\", \"rxn_020\", \"rxn_022\"]\n    },\n    {\n      \"molecule_id\": \"mol_006\",\n      \"incoming_reactions\": [\"rxn_001\"],\n      \"outgoing_reactions\": [\"rxn_003\", \"rxn_011\"]\n    }\n  ]\n}", "parsed_response": {"target_molecule": "Glutamate", "overall_strategy": "Glutamate (2-aminopentanedioic acid, C5H9NO4) is synthesized through a convergent prebiotic network centered on \u03b1-ketoglutarate as the principal hub. The network begins with hydrothermal CO2 fixation on iron-sulfur minerals producing formate, pyruvate, and formaldehyde. Surface cyanide chemistry and UV-driven oxidation generate glyoxylate through two independent routes (glycolonitrile hydrolysis and glycolaldehyde oxidation). The glyoxylate and pyruvate hubs converge via four distinct routes to \u03b1-ketoglutarate: Fe2+-catalyzed aldol condensation, ammonia-enhanced condensation, malonate-cyanide chemistry (with malonate sourced via thioester carboxylation), and the HKG cycle. Terminal conversion to glutamate proceeds through five mechanisms: FeS-mediated reductive amination, formate-driven amination, transamination with alanine, hydroxylamine amination on Fe0, and Strecker synthesis from succinic semialdehyde. Thioester intermediates bridge hydrothermal pyruvate to surface malonate chemistry, and all intermediates have complete upstream synthesis routes.", "molecules": [{"id": "mol_001", "formula": "CO2", "iupac_name": "carbon dioxide", "common_name": "carbon dioxide", "inchi": "InChI=1S/CO2/c2-1-3", "role": "starting", "environment_formed": null}, {"id": "mol_002", "formula": "H2", "iupac_name": "molecular hydrogen", "common_name": "hydrogen", "inchi": "InChI=1S/H2/h1H", "role": "starting", "environment_formed": null}, {"id": "mol_003", "formula": "NH3", "iupac_name": "ammonia", "common_name": "ammonia", "inchi": "InChI=1S/H3N/h1H3", "role": "starting", "environment_formed": null}, {"id": "mol_004", "formula": "HCN", "iupac_name": "hydrogen cyanide", "common_name": "hydrogen cyanide", "inchi": "InChI=1S/CHN/c1-2/h1H", "role": "starting", "environment_formed": null}, {"id": "mol_005", "formula": "H2S", "iupac_name": "hydrogen sulfide", "common_name": "hydrogen sulfide", "inchi": "InChI=1S/H2S/h1H2", "role": "starting", "environment_formed": null}, {"id": "mol_006", "formula": "CHO2-", "iupac_name": "formate", "common_name": "formate", "inchi": "InChI=1S/CH2O2/c2-1-3/h1H,(H,2,3)/p-1", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_007", "formula": "C3H3O3-", "iupac_name": "2-oxopropanoate", "common_name": "pyruvate", "inchi": "InChI=1S/C3H4O3/c1-2(4)3(5)6/h1H3,(H,5,6)/p-1", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_008", "formula": "CH2O", "iupac_name": "formaldehyde", "common_name": "formaldehyde", "inchi": "InChI=1S/CH2O/c1-2/h1H2", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_009", "formula": "C2H3NO", "iupac_name": "2-hydroxyacetonitrile", "common_name": "glycolonitrile", "inchi": "InChI=1S/C2H3NO/c3-1-2-4/h4H,2H2", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_010", "formula": "C2HO3-", "iupac_name": "oxoacetate", "common_name": "glyoxylate", "inchi": "InChI=1S/C2H2O3/c3-1-2(4)5/h1H,(H,4,5)/p-1", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_011", "formula": "C5H4O5", "iupac_name": "2-oxopentanedioic acid", "common_name": "alpha-ketoglutarate", "inchi": "InChI=1S/C5H6O5/c6-3(5(9)10)1-2-4(7)8/h1-2H2,(H,7,8)(H,9,10)", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_012", "formula": "C5H9NO4", "iupac_name": "2-aminopentanedioic acid", "common_name": "glutamate", "inchi": "InChI=1S/C5H9NO4/c6-3(5(9)10)1-2-4(7)8/h3H,1-2,6H2,(H,7,8)(H,9,10)", "role": "target", "environment_formed": "Biochemical"}, {"id": "mol_013", "formula": "C3H7NO2", "iupac_name": "2-aminopropanoic acid", "common_name": "alanine", "inchi": "InChI=1S/C3H7NO2/c1-2(4)3(5)6/h2H,4H2,1H3,(H,5,6)", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_014", "formula": "C3H2O4", "iupac_name": "propanedioic acid", "common_name": "malonate", "inchi": "InChI=1S/C3H4O4/c4-2(5)1-3(6)7/h1H2,(H,4,5)(H,6,7)", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_015", "formula": "C4H6O3", "iupac_name": "4-oxobutanoic acid", "common_name": "succinic semialdehyde", "inchi": "InChI=1S/C4H6O3/c5-3-1-2-4(6)7/h3H,1-2H2,(H,6,7)", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_016", "formula": "NH2OH", "iupac_name": "hydroxylamine", "common_name": "hydroxylamine", "inchi": "InChI=1S/H3NO/c1-2/h2H,1H2", "role": "starting", "environment_formed": null}, {"id": "mol_017", "formula": "C3H6OS", "iupac_name": "S-methyl thioacetate", "common_name": "acetyl thioester", "inchi": "InChI=1S/C3H6OS/c1-3(4)5-2/h1-2H3", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_018", "formula": "CH4S", "iupac_name": "methanethiol", "common_name": "methyl mercaptan", "inchi": "InChI=1S/CH4S/c1-2/h2H,1H3", "role": "starting", "environment_formed": "Hydrothermal"}, {"id": "mol_019", "formula": "C5H8O5", "iupac_name": "2-hydroxypentanedioic acid", "common_name": "alpha-hydroxyglutarate", "inchi": "InChI=1S/C5H8O5/c6-3(5(9)10)1-2-4(7)8/h3,6H,1-2H2,(H,7,8)(H,9,10)", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_020", "formula": "C2H4O2", "iupac_name": "2-hydroxyacetaldehyde", "common_name": "glycolaldehyde", "inchi": "InChI=1S/C2H4O2/c3-1-2-4/h1,4H,2H2", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_021", "formula": "C4H4O4", "iupac_name": "butanedioic acid", "common_name": "succinate", "inchi": "InChI=1S/C4H6O4/c5-3(6)1-2-4(7)8/h1-2H2,(H,5,6)(H,7,8)", "role": "intermediate", "environment_formed": "Hydrothermal"}], "reactions": [{"id": "rxn_001", "name": "CO2 hydrogenation to formate on greigite", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_006"], "environment": "Hydrothermal", "agents": ["greigite (Fe3S4)", "mackinawite (FeS)"], "conditions": {"temperature": "350-400K", "pressure": "high (>50 bar)", "catalyst": "greigite (Fe3S4)", "aqueous": "true", "other": "alkaline hydrothermal vent conditions, pH 9-11, H2-rich fluids from serpentinization"}, "mechanism": "CO2 adsorbs onto the greigite surface (structural analog of biological [Fe4S4] clusters), where it undergoes two-electron reduction by H2 to form formate (HCOO-). The reaction proceeds via a surface-bound carboxylate intermediate.", "reasoning": "CO2 reduction to formate on greigite and mackinawite is one of the best-characterized prebiotic carbon fixation reactions, analogous to the Wood-Ljungdahl pathway. Demonstrated experimentally under alkaline hydrothermal conditions (Preiner et al., 2020; Herschy et al., 2014). Greigite's structural similarity to biological Fe-S clusters supports its catalytic role (Russell & Martin, 2004). Sources (9400, 14773)."}, {"id": "rxn_002", "name": "CO2 fixation to pyruvate on magnetite", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_007"], "environment": "Hydrothermal", "agents": ["magnetite (Fe3O4)", "elemental iron (Fe0)"], "conditions": {"temperature": "350-400K", "pressure": "high (>50 bar)", "catalyst": "magnetite (Fe3O4) with Fe0 reductant", "aqueous": "true", "other": "multiple CO2 molecules fixed sequentially via C1\u2192C2\u2192C3 chain growth on mineral surface, pH 8-10"}, "mechanism": "Sequential CO2 reduction and C-C coupling on magnetite surface. CO2 is first reduced to CO/formate, which undergoes Fischer-Tropsch-type chain growth to acetaldehyde/acetate, followed by further carbonylation and oxidation to yield pyruvate. The Fe0 serves as electron donor.", "reasoning": "Pyruvate synthesis from CO2 under hydrothermal conditions on iron minerals (magnetite, Fe0) has been demonstrated experimentally by Muchowska et al. (2019) and Varma et al. (2018). The sequential carbon fixation proceeds through C1\u2192C2\u2192C3 intermediates. Fe0 provides the necessary reducing equivalents. Sources (9400, 951). Fischer-Tropsch-type synthesis on magnetite is documented (McCollom & Seewald, 2007)."}, {"id": "rxn_003", "name": "Formate reduction to formaldehyde on magnetite", "inputs": ["mol_006", "mol_002"], "outputs": ["mol_008"], "environment": "Hydrothermal", "agents": ["magnetite (Fe3O4)", "elemental iron (Fe0)"], "conditions": {"temperature": "400-500K", "pressure": "high", "catalyst": "magnetite with Fe0 as reductant", "aqueous": "true", "other": "Fischer-Tropsch-type reduction, continuous H2 supply from serpentinization"}, "mechanism": "Formate adsorbs on magnetite surface and is reduced by H2 (activated on Fe0 surface) to yield formaldehyde via a two-electron reduction. This is part of the Fischer-Tropsch-type (FTT) synthesis chain where C1 oxygenates are progressively reduced.", "reasoning": "Formaldehyde production from formate/CO reduction is a documented step in Fischer-Tropsch-type synthesis on magnetite under hydrothermal conditions (McCollom & Seewald, 2007; Kopetzki & Antonietti, 2011). While formaldehyde is thermodynamically unstable at high temperatures, continuous production and transport to cooler zones is plausible at vent gradients. The reaction represents the FTT C1 intermediate stage. Sources (15641, 2626)."}, {"id": "rxn_004", "name": "Formaldehyde-HCN condensation to glycolonitrile", "inputs": ["mol_008", "mol_004"], "outputs": ["mol_009"], "environment": "Surface", "agents": ["montmorillonite (clay)"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "montmorillonite surface concentrates reactants", "aqueous": "true", "other": "near-neutral pH, aqueous pool receiving hydrothermal outflow and atmospheric HCN"}, "mechanism": "Nucleophilic addition of cyanide (CN-) to formaldehyde carbonyl carbon forms the cyanohydrin glycolonitrile (HOCH2CN). This is a spontaneous, thermodynamically favorable reaction in aqueous solution, enhanced by clay surface concentration.", "reasoning": "Glycolonitrile formation from formaldehyde and HCN is a well-established cyanohydrin reaction that occurs readily under mild aqueous conditions. This is the entry point to the cyanosulfidic protometabolism network described by Patel et al. (2015) and Sutherland (2017). The reaction proceeds at ambient temperature with no catalyst needed, though montmorillonite concentrates dilute reactants. Sources (9376, 21195)."}, {"id": "rxn_005", "name": "Glycolonitrile hydrolysis and oxidation to glyoxylate", "inputs": ["mol_009"], "outputs": ["mol_010"], "environment": "Surface", "agents": ["TiO2 (anatase)", "montmorillonite (clay)"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "TiO2 photocatalyst for UV-driven oxidation", "aqueous": "true", "other": "UV irradiation provides energy for oxidation step; Fe3+ in solution as alternative oxidant; two-step process: hydrolysis of nitrile to glycolate, then UV/Fe3+-driven oxidation of the alcohol to aldehyde/carboxylate yielding glyoxylate"}, "mechanism": "Step 1: Glycolonitrile undergoes nitrile hydrolysis in warm aqueous conditions (facilitated by clay surfaces) to yield glycolic acid (HOCH2COOH) via glycolamide intermediate. Step 2: The hydroxyl group of glycolate is oxidized to the aldehyde/keto group by UV-excited TiO2 (or dissolved Fe3+ acting as one-electron oxidant, generating Fe2+), producing glyoxylate (OHCCOO-).", "reasoning": "Nitrile hydrolysis under mild aqueous conditions is well-documented prebiotically (Sanchez et al., 1967; Patel et al., 2015). Oxidation of glycolate to glyoxylate by UV-activated TiO2 or ferric iron is photochemically feasible; Fe3+/Fe2+ cycling provides the necessary oxidizing equivalents under anoxic conditions (Braterman et al., 1983). Glyoxylate has also been detected in aerosol-generated HCN polymer products (Sources 23036). This two-step sequence is more mechanistically explicit than a single concerted transformation. Sources (9376, 23036, 6987)."}, {"id": "rxn_006", "name": "Glyoxylate-pyruvate aldol condensation to alpha-ketoglutarate (Fe2+ catalyzed)", "inputs": ["mol_010", "mol_007"], "outputs": ["mol_011"], "environment": "Hydrothermal", "agents": ["pyrite (FeS2)", "mackinawite (FeS)"], "conditions": {"temperature": "340-350K", "pressure": "moderate", "catalyst": "Fe2+ ions (from dissolved pyrite/mackinawite)", "aqueous": "true", "other": "pH ~7, inert atmosphere, Fe2+ at millimolar concentrations; proceeds through aldol addition then dehydration and oxidative decarboxylation"}, "mechanism": "Fe2+ catalyzes the aldol condensation between glyoxylate and pyruvate. The initial aldol adduct undergoes sequential dehydration, decarboxylation, and redox transformations to yield \u03b1-ketoglutarate. Fe2+ acts as a Lewis acid activating the carbonyl groups and facilitating the carbon-carbon bond formation.", "reasoning": "Demonstrated experimentally by Muchowska et al. (2019): Fe2+-catalyzed reactions at 70\u00b0C (343K) under inert atmosphere with glyoxylate and pyruvate produce TCA cycle intermediates including \u03b1-ketoglutarate, along with amino acids. The reaction network involves aldol/retro-aldol, hydration/dehydration, and oxidative decarboxylation pathways. This is one of the most direct routes to \u03b1-ketoglutarate. Sources (9400, 6981, 995)."}, {"id": "rxn_007", "name": "Ammonia-enhanced glyoxylate-pyruvate condensation to alpha-ketoglutarate", "inputs": ["mol_010", "mol_007", "mol_003"], "outputs": ["mol_011"], "environment": "Surface", "agents": ["montmorillonite (clay)", "phosphate minerals (apatite)"], "conditions": {"temperature": "320-325K", "pressure": "1 atm", "catalyst": "clay surface, NH3 as amine catalyst", "aqueous": "true", "other": "pH 5-6, wet-dry cycles in evaporitic pools; ammonia enhances yield from 2-4% to 12-20% via retro-Claisen and cross-Cannizzaro facilitation"}, "mechanism": "Ammonia participates as a catalytic nucleophile facilitating the condensation between glyoxylate and pyruvate. The amine forms transient Schiff base intermediates that enhance the retro-Claisen reaction and cross-Cannizzaro pathways, channeling products toward \u03b1-ketoglutarate rather than competing side reactions.", "reasoning": "Demonstrated by Yi et al. (2022) and Stubbs et al. (2020): ammonia and amines significantly boost \u03b1-ketoglutarate yields in pyruvate-glyoxylate condensation reactions from 2-4% to 12-20% under mild conditions (pH 5-6, 50\u00b0C). The enhancement is attributed to nitrogen-facilitated retro-Claisen and cross-Cannizzaro mechanisms. Wet-dry cycling on clay surfaces concentrates reactants. Sources (6983, 6981)."}, {"id": "rxn_008", "name": "Malonate-glyoxylate-cyanide condensation to alpha-ketoglutarate", "inputs": ["mol_014", "mol_010", "mol_004"], "outputs": ["mol_011"], "environment": "Surface", "agents": ["montmorillonite (clay)", "phosphate minerals (struvite)"], "conditions": {"temperature": "320-325K", "pressure": "1 atm", "catalyst": "clay surface for concentrating reactants", "aqueous": "true", "other": "pH 5-6, 50\u00b0C, wet-dry cycling; yields 12-20% \u03b1-ketoglutarate"}, "mechanism": "Cyanide activates the malonate-glyoxylate condensation by forming a cyanohydrin intermediate with glyoxylate, which then undergoes C-C bond formation with malonate via Knoevenagel-type condensation. Subsequent hydrolysis and decarboxylation yield \u03b1-ketoglutarate.", "reasoning": "Stubbs et al. (2020) showed that malonate, combined with glyoxylate and cyanide under wet-dry conditions (pH 5-6, 50\u00b0C), produces \u03b1-ketoglutarate with 12-20% efficiency. Cyanide enhances reactivity of \u03b1-ketoacids and dicarboxylic acids, enabling transformations mimicking a reductive glyoxylate cycle. Sources (6993, 6944)."}, {"id": "rxn_009", "name": "Oxidative dehydrogenation of alpha-hydroxyglutarate to alpha-ketoglutarate", "inputs": ["mol_019"], "outputs": ["mol_011"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "320-350K", "pressure": "1 atm", "catalyst": "Fe3+ as oxidant, or UV-driven", "aqueous": "true", "other": "Part of the HKG (hydroxy ketoglutarate) cycle; oxidative dehydrogenation using dissolved Fe3+ or photochemical oxidation"}, "mechanism": "The hydroxyl group at the \u03b1-position of \u03b1-hydroxyglutarate is oxidized to a keto group, converting the alcohol to \u03b1-ketoglutarate. Fe3+ serves as a mild one-electron oxidant (reduced to Fe2+), or the reaction proceeds photochemically.", "reasoning": "The hydroxy ketoglutarate (HKG) cycle includes the dehydrogenation of \u03b1-hydroxyglutaric acid to \u03b1-ketoglutarate as a key step. This reaction demonstrates closed-loop functionality with minimal material leakage in prebiotic cycle reconstructions (Springsteen et al., 2018; Stubbs et al., 2020). Sources (10738, 9399, 14895)."}, {"id": "rxn_010", "name": "FeS-mediated reductive amination of alpha-ketoglutarate to glutamate", "inputs": ["mol_011", "mol_003"], "outputs": ["mol_012"], "environment": "Hydrothermal", "agents": ["mackinawite (FeS)", "pyrite (FeS2)"], "conditions": {"temperature": "350-370K", "pressure": "moderate to high", "catalyst": "FeS or Fe(OH)2", "aqueous": "true", "other": "pH 8.3-10.5, excess NH3 (>100 eq), alkaline hydrothermal vent conditions"}, "mechanism": "Ammonia reacts with the \u03b1-keto group of \u03b1-ketoglutarate to form an unstable imine (Schiff base) intermediate. FeS acts as a two-electron reductant, reducing the C=N double bond to yield the amine, producing glutamate. The alkaline pH and excess ammonia drive the equilibrium toward product.", "reasoning": "Wang et al. (2005) demonstrated reductive amination of \u03b1-keto acids to amino acids using FeS and Fe(OH)2 under aqueous, slightly basic conditions (pH 8.3-10.5) with excess ammonia. The reaction proceeds through an imine/iminium intermediate that is reduced by the mineral surface. This is one of the most direct and well-characterized routes to glutamate from \u03b1-ketoglutarate. Sources (1025, 9400)."}, {"id": "rxn_011", "name": "Formate-driven reductive amination of alpha-ketoglutarate to glutamate", "inputs": ["mol_011", "mol_003", "mol_006"], "outputs": ["mol_012"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "320-370K", "pressure": "1 atm", "catalyst": "Fe2+ in solution as Lewis acid", "aqueous": "true", "other": "formate acts as hydride donor (prebiotic NADPH analog), mildly acidic to neutral pH"}, "mechanism": "Formate transfers a hydride equivalent to the imine/iminium intermediate formed between \u03b1-ketoglutarate and ammonia, reducing it to yield glutamate. Formate serves as a prebiotic analog of NADPH, providing the reducing equivalents needed for the reductive amination.", "reasoning": "The reduction of \u03b1-ketoglutarate and ammonia to glutamate by formate has been explored as a prebiotic analog of the glutamate dehydrogenase reaction. Formate acts as a simple hydride donor analogous to NADPH (Huber & Wachtershauser, 2003). This pathway connects hydrothermal formate production to amino acid biosynthesis. Sources (1214, 6996)."}, {"id": "rxn_012", "name": "Transamination of alpha-ketoglutarate with alanine to glutamate", "inputs": ["mol_011", "mol_013"], "outputs": ["mol_012", "mol_007"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "320-370K", "pressure": "1 atm", "catalyst": "Fe2+ or Cu2+ as Lewis acid catalyst", "aqueous": "true", "other": "mildly acidic pH (5-7), pyridoxal analog may catalyze; pyruvate is regenerated as co-product"}, "mechanism": "Alanine donates its amino group to \u03b1-ketoglutarate through a transamination mechanism. The amino group first forms a Schiff base with a metal-ion-activated keto group on \u03b1-KG, then tautomerizes and hydrolyzes to transfer the nitrogen, yielding glutamate and regenerating pyruvate from the deaminated alanine.", "reasoning": "Transamination between amino acids and \u03b1-keto acids is a fundamental biochemical reaction. Under prebiotic conditions, Cu2+ and Fe2+ ions can catalyze non-enzymatic transamination (Snider & Wolfenden, 2000). The regeneration of pyruvate makes this reaction catalytic when coupled with pyruvate-consuming pathways. Sources (6940, 995, 6943)."}, {"id": "rxn_013", "name": "Hydroxylamine reductive amination of alpha-ketoglutarate to glutamate", "inputs": ["mol_011", "mol_016"], "outputs": ["mol_012"], "environment": "Hydrothermal", "agents": ["elemental iron (Fe0)", "mackinawite (FeS)"], "conditions": {"temperature": "350-370K", "pressure": "moderate", "catalyst": "Fe0 as strong reductant", "aqueous": "true", "other": "hydroxylamine as prebiotically plausible nitrogen source; Fe0 drives the reduction of intermediate oxime to amine"}, "mechanism": "Hydroxylamine reacts with the keto group of \u03b1-ketoglutarate to form an oxime intermediate. Fe0 acts as a strong reductant, reducing the N-O bond and the C=N bond to yield the free amine (glutamate). This bypasses the need for excess ammonia.", "reasoning": "Barge et al. (2019) demonstrated that hydroxylamine, a prebiotically plausible nitrogen source generated from NOx reduction or nitrogen photochemistry, can facilitate amino acid synthesis from \u03b1-keto acids in the presence of metallic iron (Fe0). This pathway offers an alternative nitrogen source to ammonia for glutamate production. Sources (9396)."}, {"id": "rxn_014", "name": "Strecker synthesis of glutamate from succinic semialdehyde", "inputs": ["mol_015", "mol_004", "mol_003"], "outputs": ["mol_012"], "environment": "Surface", "agents": ["montmorillonite (clay)", "TiO2 (anatase)"], "conditions": {"temperature": "300-340K", "pressure": "1 atm", "catalyst": "montmorillonite concentrates reactants and catalyzes hydrolysis", "aqueous": "true", "other": "pH 7-9; two-step: (1) NH3 + succinic semialdehyde + HCN \u2192 \u03b1-aminonitrile intermediate, (2) nitrile hydrolysis to carboxylic acid yielding glutamate"}, "mechanism": "Step 1: Ammonia condenses with the aldehyde of succinic semialdehyde to form an imine. HCN adds to the imine to generate the \u03b1-aminonitrile (2-amino-4-cyanopentanoic acid). Step 2: The nitrile group hydrolyzes to a carboxamide and then carboxylic acid, yielding glutamate (2-aminopentanedioic acid).", "reasoning": "The Strecker synthesis is among the most well-established prebiotic amino acid formation mechanisms (Strecker, 1850; Miller, 1957). For glutamate specifically, succinic semialdehyde (4-oxobutanoic acid) is the required aldehyde substrate, generating a C5 amino acid with two carboxyl groups. The irreversible hydrolysis of the aminonitrile drives the reaction to completion (Danger et al., 2012). Sources (2035, 6940, 6942, 10835)."}, {"id": "rxn_015", "name": "Reductive amination of pyruvate to alanine on FeS", "inputs": ["mol_007", "mol_003"], "outputs": ["mol_013"], "environment": "Hydrothermal", "agents": ["mackinawite (FeS)", "pyrite (FeS2)"], "conditions": {"temperature": "350-400K", "pressure": "moderate to high", "catalyst": "FeS as reductant", "aqueous": "true", "other": "pH 8-10, excess ammonia, alkaline vent conditions"}, "mechanism": "Ammonia reacts with the keto group of pyruvate to form an imine. FeS provides reducing equivalents to reduce the C=N bond, yielding alanine. Identical mechanism to rxn_010 but with a C3 substrate.", "reasoning": "Reductive amination of pyruvate to alanine on FeS/Fe(OH)2 surfaces follows the same mechanism demonstrated by Wang et al. (2005) for other \u03b1-keto acids. Alanine is among the most commonly detected amino acids in prebiotic synthesis experiments. This reaction provides the amino donor for the transamination pathway (rxn_012). Sources (1025, 9400)."}, {"id": "rxn_016", "name": "Pyruvate thioesterification to acetyl thioester", "inputs": ["mol_007", "mol_018"], "outputs": ["mol_017"], "environment": "Hydrothermal", "agents": ["pyrite (FeS2)", "mackinawite (FeS)"], "conditions": {"temperature": "350-400K", "pressure": "high", "catalyst": "FeS/FeS2 mineral surface", "aqueous": "true", "other": "methanethiol from hydrothermal vents; oxidative decarboxylation of pyruvate coupled to thioester bond formation; CO2 released"}, "mechanism": "Pyruvate undergoes oxidative decarboxylation on the FeS2 surface, releasing CO2 and forming an activated acetyl group. The acetyl intermediate reacts with methanethiol (CH3SH, abundant in hydrothermal fluids) to form S-methyl thioacetate (acetyl thioester).", "reasoning": "Thioester formation from pyruvate and thiols under hydrothermal conditions was demonstrated by Cody et al. (2000) and Huber & Wachtershauser (1997). Methanethiol is a known hydrothermal vent effluent. The reaction is analogous to pyruvate dehydrogenase forming acetyl-CoA. Thioester yields up to 31% were achieved from pyruvic acid and N-acetylcysteamine (De Duve, 1991; Chandru et al., 2016). Sources (988, 995, 987)."}, {"id": "rxn_017", "name": "Acetyl thioester carbonylation to malonate", "inputs": ["mol_017", "mol_001"], "outputs": ["mol_014"], "environment": "Hydrothermal", "agents": ["greigite (Fe3S4)", "magnetite (Fe3O4)"], "conditions": {"temperature": "350-400K", "pressure": "high (CO2-rich)", "catalyst": "greigite/FeNiS mineral surface", "aqueous": "true", "other": "Carboxylation of activated acetyl thioester analogous to acetyl-CoA carboxylation in biology; high CO2 partial pressure favors carboxylation"}, "mechanism": "The thioester-activated methyl group of acetyl thioester undergoes carboxylation by CO2 at the mineral surface. The Fe-Ni-S center activates CO2, facilitating nucleophilic attack by the \u03b1-carbon of the acetyl group. Subsequent thioester hydrolysis yields free malonate (malonic acid).", "reasoning": "Carboxylation of acetyl thioesters to malonyl derivatives is directly analogous to the acetyl-CoA carboxylase reaction in modern metabolism. Under prebiotic conditions, FeNiS mineral surfaces can activate CO2 for carboxylation reactions (Huber & Wachtershauser, 1997). The thioester provides the necessary activation energy for C-C bond formation with CO2. This connects thioester chemistry to the malonate required for rxn_008. Sources (995, 970, 6944)."}, {"id": "rxn_018", "name": "Formose-type condensation of formaldehyde to glycolaldehyde", "inputs": ["mol_008"], "outputs": ["mol_020"], "environment": "Surface", "agents": ["borate minerals (colemanite)", "montmorillonite (clay)"], "conditions": {"temperature": "310-340K", "pressure": "1 atm", "catalyst": "Ca(OH)2 or borate minerals", "aqueous": "true", "other": "alkaline conditions with borate stabilization; 2 CH2O \u2192 HOCH2CHO; borate prevents runaway polymerization by complexing sugar intermediates"}, "mechanism": "Two formaldehyde molecules undergo an aldol condensation catalyzed by Ca(OH)2 or borate to form glycolaldehyde (the simplest sugar). Borate minerals stabilize the product by forming borate ester complexes, preventing further uncontrolled polymerization.", "reasoning": "The formose reaction (2 CH2O \u2192 glycolaldehyde) is a classic prebiotic sugar synthesis (Butlerow, 1861). Borate minerals stabilize glycolaldehyde and other sugars, preventing degradation and runaway polymerization (Ricardo et al., 2004). Glycolaldehyde has been detected in interstellar clouds and is a key prebiotic intermediate. Sources (9376, 2655)."}, {"id": "rxn_019", "name": "UV-driven oxidation of glycolaldehyde to glyoxylate", "inputs": ["mol_020"], "outputs": ["mol_010"], "environment": "Surface", "agents": ["TiO2 (anatase)", "sulfide minerals (stibnite)"], "conditions": {"temperature": "300-330K", "pressure": "1 atm", "catalyst": "TiO2 as UV photocatalyst", "aqueous": "true", "other": "UV irradiation (no ozone shield on early Earth); Fe3+ as alternative oxidant; oxidation of the primary alcohol to aldehyde, then further to carboxylate"}, "mechanism": "UV photons excite TiO2 semiconductor particles, generating electron-hole pairs. The photogenerated holes oxidize glycolaldehyde at the primary alcohol position, converting -CH2OH to -CHO (yielding glyoxal) and further to -COOH (yielding glyoxylate). Alternatively, dissolved Fe3+ acts as the terminal oxidant.", "reasoning": "UV photocatalytic oxidation of organic substrates on TiO2 is well-established in prebiotic chemistry contexts. The lack of an ozone layer on early Earth provides intense UV flux. Fe3+ photochemistry provides an alternative oxidation pathway (Braterman et al., 1983). This provides a second independent route to glyoxylate (parallel to rxn_005), creating convergence at the glyoxylate hub. Sources (23036, 6987)."}, {"id": "rxn_020", "name": "Fe2+-catalyzed glyoxylate-pyruvate condensation to succinate", "inputs": ["mol_010", "mol_007"], "outputs": ["mol_021"], "environment": "Hydrothermal", "agents": ["pyrite (FeS2)", "mackinawite (FeS)"], "conditions": {"temperature": "340-350K", "pressure": "moderate", "catalyst": "Fe2+ ions from mineral dissolution", "aqueous": "true", "other": "pH ~7, inert atmosphere; part of the same Fe2+-catalyzed reaction network that produces \u03b1-KG (rxn_006) but under conditions favoring succinate branch"}, "mechanism": "Glyoxylate and pyruvate undergo aldol condensation and subsequent oxidative decarboxylation, followed by reduction, yielding succinate as one of the TCA-like intermediates in the Fe2+-catalyzed network. The product distribution depends on Fe2+ concentration and pH.", "reasoning": "Muchowska et al. (2019) demonstrated that the Fe2+-catalyzed glyoxylate-pyruvate reaction network produces multiple TCA cycle intermediates including succinate, malate, fumarate, and \u03b1-ketoglutarate. Succinate is among the major products. This reaction shares the same starting materials as rxn_006 but represents a branching product. Sources (9400, 9401, 951)."}, {"id": "rxn_021", "name": "Reduction of succinate to succinic semialdehyde on Fe0", "inputs": ["mol_021", "mol_002"], "outputs": ["mol_015"], "environment": "Hydrothermal", "agents": ["elemental iron (Fe0)", "mackinawite (FeS)"], "conditions": {"temperature": "350-400K", "pressure": "moderate to high", "catalyst": "Fe0 as strong reductant", "aqueous": "true", "other": "selective partial reduction of one carboxyl group to aldehyde; alkaline conditions favor selectivity"}, "mechanism": "One of the two carboxyl groups of succinate is selectively reduced on the Fe0 surface. Fe0 provides the necessary reducing equivalents (Fe0 \u2192 Fe2+ + 2e-) to reduce -COOH to -CHO, yielding succinic semialdehyde (4-oxobutanoic acid). The selectivity arises from substrate orientation on the mineral surface.", "reasoning": "Carboxylic acid reduction to aldehydes on metallic iron surfaces is thermodynamically feasible under hydrothermal conditions where Fe0 is a strong reductant (Varma et al., 2018). Selective partial reduction of dicarboxylic acids is facilitated by surface adsorption geometry. This provides the aldehyde substrate needed for the Strecker route to glutamate (rxn_014). Sources (9396, 9400)."}, {"id": "rxn_022", "name": "Fe2+-catalyzed aldol reduction to alpha-hydroxyglutarate", "inputs": ["mol_010", "mol_007"], "outputs": ["mol_019"], "environment": "Hydrothermal", "agents": ["pyrite (FeS2)", "mackinawite (FeS)"], "conditions": {"temperature": "340-350K", "pressure": "moderate", "catalyst": "Fe2+ and FeS as reductant", "aqueous": "true", "other": "pH ~7, inert atmosphere; aldol condensation followed by reduction of keto group at C2 rather than full oxidative decarboxylation; part of the HKG cycle network"}, "mechanism": "Glyoxylate and pyruvate undergo aldol condensation to form a C5 intermediate. Instead of oxidative decarboxylation (which yields \u03b1-KG, rxn_006), the keto group at C2 is reduced by FeS, yielding \u03b1-hydroxyglutarate. This represents an alternative branch in the Fe2+-catalyzed network.", "reasoning": "The HKG (hydroxy ketoglutarate) cycle demonstrates that \u03b1-hydroxyglutarate forms as an intermediate in the glyoxylate-pyruvate reaction network under reducing conditions (Springsteen et al., 2018). When FeS provides excess reducing equivalents, the C2 keto group is reduced to a hydroxyl before further oxidative steps can occur. This feeds into the HKG cycle route to \u03b1-KG (rxn_009). Sources (10738, 9399, 14895)."}], "pathways": [{"pathway_id": "P1", "name": "Hydrothermal CO2-fixation via cyanosulfidic glyoxylate to FeS-aminated glutamate", "description": "Full pathway from CO2 through hydrothermal carbon fixation, surface cyanide chemistry generating glyoxylate, Fe2+-catalyzed aldol condensation to \u03b1-KG, and FeS-mediated reductive amination to glutamate. Spans all three environments.", "reaction_sequence": ["rxn_001", "rxn_003", "rxn_004", "rxn_005", "rxn_002", "rxn_006", "rxn_010"], "key_intermediates": ["mol_006", "mol_008", "mol_009", "mol_010", "mol_007", "mol_011"]}, {"pathway_id": "P2", "name": "Formate-driven reductive amination pathway", "description": "CO2 is fixed to both formate and pyruvate hydrothermally. Glyoxylate is generated via surface chemistry. \u03b1-KG forms by aldol condensation. Formate then acts as a prebiotic NADPH analog to drive reductive amination of \u03b1-KG with NH3 to glutamate.", "reaction_sequence": ["rxn_001", "rxn_002", "rxn_003", "rxn_004", "rxn_005", "rxn_006", "rxn_011"], "key_intermediates": ["mol_006", "mol_007", "mol_010", "mol_011"]}, {"pathway_id": "P3", "name": "Thioester-malonate-cyanide pathway to glutamate", "description": "Pyruvate is converted to acetyl thioester via oxidative decarboxylation with methanethiol, then carboxylated to malonate. Malonate condenses with glyoxylate and HCN on surface to form \u03b1-KG, which is reductively aminated to glutamate.", "reaction_sequence": ["rxn_002", "rxn_016", "rxn_017", "rxn_008", "rxn_010"], "key_intermediates": ["mol_007", "mol_017", "mol_014", "mol_010", "mol_011"]}, {"pathway_id": "P4", "name": "Ammonia-enhanced surface condensation to transaminated glutamate", "description": "Glyoxylate and pyruvate condense with ammonia catalysis on surface to form \u03b1-KG with enhanced yields. Pyruvate is separately aminated to alanine, which then donates its amino group to \u03b1-KG via transamination, regenerating pyruvate.", "reaction_sequence": ["rxn_002", "rxn_007", "rxn_015", "rxn_012"], "key_intermediates": ["mol_007", "mol_010", "mol_011", "mol_013"]}, {"pathway_id": "P5", "name": "HKG cycle route via alpha-hydroxyglutarate", "description": "Glyoxylate and pyruvate condense under reducing hydrothermal conditions to form \u03b1-hydroxyglutarate, which is then oxidatively dehydrogenated to \u03b1-KG via the HKG cycle, followed by FeS reductive amination to glutamate.", "reaction_sequence": ["rxn_022", "rxn_009",
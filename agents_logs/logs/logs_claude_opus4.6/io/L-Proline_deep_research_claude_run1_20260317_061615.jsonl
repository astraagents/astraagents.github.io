  },\n    {\n      \"id\": \"mol_010\",\n      \"formula\": \"C2HO3-\",\n      \"iupac_name\": \"oxoacetate\",\n      \"common_name\": \"glyoxylate\",\n      \"inchi\": \"InChI=1S/C2H2O3/c3-1-2(4)5/h1H,(H,4,5)/p-1\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_011\",\n      \"formula\": \"C5H4O5\",\n      \"iupac_name\": \"2-oxopentanedioic acid\",\n      \"common_name\": \"alpha-ketoglutarate\",\n      \"inchi\": \"InChI=1S/C5H6O5/c6-3(5-9)1-2-4(7)8/h1-2H2,(H,7,8)(H,9,10)\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_012\",\n      \"formula\": \"C5H9NO4\",\n      \"iupac_name\": \"(2S)-2-aminopentanedioic acid\",\n      \"common_name\": \"L-glutamate\",\n      \"inchi\": \"InChI=1S/C5H9NO4/c6-3(5(9)10)1-2-4(7)8/h3H,1-2,6H2,(H,7,8)(H,9,10)/t3-/m0/s1\",\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_013\",\n      \"formula\": \"C5H9NO3\",\n      \"iupac_name\": \"(2S)-2-amino-5-oxopentanoic acid\",\n      \"common_name\": \"glutamic-gamma-semialdehyde\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Hydrothermal\"\n    },\n    {\n      \"id\": \"mol_014\",\n      \"formula\": \"C5H7NO2\",\n      \"iupac_name\": \"3,4-dihydro-2H-pyrrole-2-carboxylic acid\",\n      \"common_name\": \"delta-1-pyrroline-5-carboxylic acid (P5C)\",\n      \"inchi\": null,\n      \"role\": \"hub_intermediate\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_015\",\n      \"formula\": \"C5H9NO2\",\n      \"iupac_name\": \"(2S)-pyrrolidine-2-carboxylic acid\",\n      \"common_name\": \"L-proline\",\n      \"inchi\": \"InChI=1S/C5H9NO2/c7-4-2-1-3-5(4)8/h4H,1-3,7H2,(H,8,9)/t4-/m0/s1\",\n      \"role\": \"target\",\n      \"environment_formed\": \"Biochemical\"\n    },\n    {\n      \"id\": \"mol_016\",\n      \"formula\": \"C4H5NOS\",\n      \"iupac_name\": \"pyrrolidin-2-thione\",\n      \"common_name\": \"gamma-butyrothiolactam\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_017\",\n      \"formula\": \"C5H8N2O\",\n      \"iupac_name\": \"2-amino-1-pyrroline-5-carbonitrile\",\n      \"common_name\": \"proline alpha-aminonitrile\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_018\",\n      \"formula\": \"C4H4N4\",\n      \"iupac_name\": \"2,3-diaminomaleonitrile\",\n      \"common_name\": \"DAMN\",\n      \"inchi\": \"InChI=1S/C4H4N4/c5-1-3(7)4(8)2-6/h7-8H2\",\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    },\n    {\n      \"id\": \"mol_019\",\n      \"formula\": \"C4H5NO2S\",\n      \"iupac_name\": \"4-hydroxy-4-(sulfanyl)butanenitrile\",\n      \"common_name\": \"4-carbon cyanohydrin-thiol\",\n      \"inchi\": null,\n      \"role\": \"intermediate\",\n      \"environment_formed\": \"Surface\"\n    }\n  ],\n  \"reactions\": [\n    {\n      \"id\": \"rxn_001\",\n      \"name\": \"CO\u2082 hydrogenation to formate on greigite\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_007\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe\u2083S\u2084)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high (>50 bar)\",\n        \"catalyst\": \"greigite (Fe\u2083S\u2084)\",\n        \"aqueous\": true,\n        \"other\": \"alkaline vent conditions, pH 9-11, H\u2082-rich serpentinization fluid\"\n      },\n      \"mechanism\": \"CO\u2082 is adsorbed on the Fe\u2083S\u2084 surface, which is structurally analogous to biological [4Fe-4S] clusters. H\u2082 dissociatively adsorbs and reduces CO\u2082 through a formate intermediate via surface hydride transfer.\",\n      \"reasoning\": \"Greigite (Fe\u2083S\u2084) is structurally analogous to [4Fe-4S] clusters in acetyl-CoA synthase and catalyzes CO\u2082 reduction to formate under hydrothermal conditions (Li et al. 2018, Life 8:46; Russell and Hall 1997, 2006). This represents the first step of carbon fixation in alkaline hydrothermal vent models.\"\n    },\n    {\n      \"id\": \"rxn_002\",\n      \"name\": \"Formate to pyruvate via CO\u2082 fixation on magnetite\",\n      \"inputs\": [\"mol_007\", \"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_009\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe\u2083O\u2084)\", \"greigite (Fe\u2083S\u2084)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"high (>50 bar)\",\n        \"catalyst\": \"magnetite (Fe\u2083O\u2084)\",\n        \"aqueous\": true,\n        \"other\": \"Fischer-Tropsch-type synthesis conditions, alkaline vent mineral surfaces\"\n      },\n      \"mechanism\": \"Sequential C1 additions via Fischer-Tropsch-type chemistry on magnetite surfaces: formate undergoes further reduction and carbonylation to produce acetaldehyde, then reacts with CO\u2082 to yield pyruvate through a reductive carboxylation mechanism.\",\n      \"reasoning\": \"Magnetite catalyzes Fischer-Tropsch-type synthesis of multi-carbon organics from C1 units under hydrothermal conditions. Pyruvate is a key product of hydrothermal CO\u2082 fixation pathways (Cody et al. 2000; reviewed in Martin and Russell 2007). Pyruvate occupies a central position in proto-metabolism.\"\n    },\n    {\n      \"id\": \"rxn_003\",\n      \"name\": \"CO\u2082 reduction to glyoxylate on pyrite\",\n      \"inputs\": [\"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_010\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"pyrite (FeS\u2082)\", \"elemental iron (Fe\u2070)\"],\n      \"conditions\": {\n        \"temperature\": \"370-420K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"pyrite (FeS\u2082)\",\n        \"aqueous\": true,\n        \"other\": \"pyrite-pulled reductive synthesis, FeS + H\u2082S \u2192 FeS\u2082 provides driving force\"\n      },\n      \"mechanism\": \"CO\u2082 is reduced on the FeS\u2082 surface with electrons provided by the thermodynamically favorable pyrite formation reaction (FeS + H\u2082S \u2192 FeS\u2082 + 2H\u207a + 2e\u207b). Sequential reduction yields glyoxylate as a C2 keto-acid.\",\n      \"reasoning\": \"W\u00e4chtersh\u00e4user's pyrite-pulled mechanism provides reducing equivalents for CO\u2082 fixation. Glyoxylate is a central intermediate in protometabolic cycles (Springsteen et al. 2018, Nature Communications 9:91). Muchowska et al. (2017, Nature Ecology & Evolution 1:1716-1721) demonstrated that pyrite drives production of TCA cycle intermediates including glyoxylate.\"\n    },\n    {\n      \"id\": \"rxn_004\",\n      \"name\": \"Pyruvate-glyoxylate condensation to \u03b1-ketoglutarate\",\n      \"inputs\": [\"mol_009\", \"mol_010\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite clay\", \"copper minerals (Cu\u00b2\u207a)\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"Cu\u00b2\u207a ions\",\n        \"aqueous\": true,\n        \"other\": \"evaporitic pool conditions, Cu\u00b2\u207a catalysis at neutral to mildly alkaline pH\"\n      },\n      \"mechanism\": \"Aldol-type condensation of pyruvate and glyoxylate followed by oxidative decarboxylation steps produces \u03b1-ketoglutarate. Cu\u00b2\u207a facilitates oxidative transformations. This recapitulates key steps of the non-enzymatic TCA cycle.\",\n      \"reasoning\": \"Stubbs, Yadav, Krishnamurthy, and Springsteen (2020, Nature Chemistry 12:1016-1022) demonstrated that \u03b1-keto acid chemistry can reproduce key features of the TCA cycle without enzymes. Springsteen et al. (2018, Nature Communications 9:91) showed linked cycles of oxidative decarboxylation of glyoxylate as protometabolic analogs. Krishnamurthy's group (2025) demonstrated \u03b1-ketoglutarate formation via pyruvate and glyoxylate intermediates with Cu\u00b2\u207a catalysis.\"\n    },\n    {\n      \"id\": \"rxn_005\",\n      \"name\": \"Reductive amination of \u03b1-ketoglutarate to glutamate on NiFeS\",\n      \"inputs\": [\"mol_011\", \"mol_003\", \"mol_002\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"greigite (Fe\u2083S\u2084)\", \"Ni-bearing iron sulfides (NiFeS)\"],\n      \"conditions\": {\n        \"temperature\": \"295-373K\",\n        \"pressure\": \"1-10 bar H\u2082\",\n        \"catalyst\": \"Ni/FeS or Ni/SiO\u2082-Al\u2082O\u2083\",\n        \"aqueous\": true,\n        \"other\": \"pH 8, mild reducing conditions with H\u2082, also achievable with ground meteorite material\"\n      },\n      \"mechanism\": \"\u03b1-Ketoglutarate undergoes nucleophilic addition of NH\u2083 at the keto group to form an imine intermediate, which is then reduced by H\u2082 on the nickel surface to form L-glutamate. The NiFeS surface activates both H\u2082 and the substrate.\",\n      \"reasoning\": \"Huber and W\u00e4chtersh\u00e4user (1998, Science 281:670-672) demonstrated reductive amination of \u03b1-keto acids to amino acids on (Ni,Fe)S surfaces. Most recently, Kaur, Moran, and colleagues (2024, Chem 10:1528-1540) demonstrated a prebiotic Krebs cycle analog generating amino acids including glutamate with H\u2082 and NH\u2083 over nickel catalysts at 22\u00b0C, pH 8, 1-10 bar H\u2082, using Ni/SiO\u2082-Al\u2082O\u2083 or ground meteorites as catalysts.\"\n    },\n    {\n      \"id\": \"rxn_006\",\n      \"name\": \"Bucherer-Bergs synthesis of glutamate from \u03b1-ketoglutarate\",\n      \"inputs\": [\"mol_011\", \"mol_006\", \"mol_003\"],\n      \"outputs\": [\"mol_012\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite clay\", \"phosphate minerals (apatite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"none required, mineral surfaces concentrate reactants\",\n        \"aqueous\": true,\n        \"other\": \"evaporitic pool, mildly alkaline pH, HCN and NH\u2083 in millimolar concentrations\"\n      },\n      \"mechanism\": \"\u03b1-Ketoglutarate reacts with HCN and NH\u2083 via the Bucherer-Bergs pathway: HCN adds to the keto group forming a cyanohydrin, which reacts with NH\u2083 to form a hydantoin intermediate that hydrolyzes to glutamate. This is a variant of the Strecker synthesis proceeding through a hydantoin.\",\n      \"reasoning\": \"Pulletikurti, Yadav, Springsteen, and Krishnamurthy (2022, Nature Chemistry) demonstrated that \u03b1-ketoacids react with cyanide and ammonia via the Bucherer-Bergs pathway to form amino acids, including glutamate from \u03b1-ketoglutarate. This provides an alternative surface-environment route to glutamate that does not require H\u2082 or metal sulfide catalysis.\"\n    },\n    {\n      \"id\": \"rxn_007\",\n      \"name\": \"Reduction of glutamate \u03b3-carboxyl to glutamic-\u03b3-semialdehyde\",\n      \"inputs\": [\"mol_012\", \"mol_004\"],\n      \"outputs\": [\"mol_013\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"pyrite (FeS\u2082)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"350-400K\",\n        \"pressure\": \"moderate to high\",\n        \"catalyst\": \"FeS/H\u2082S system\",\n        \"aqueous\": true,\n        \"other\": \"reducing conditions, FeS + H\u2082S \u2192 FeS\u2082 provides electrons for selective carboxyl reduction\"\n      },\n      \"mechanism\": \"The \u03b3-carboxyl group of glutamate is selectively reduced to an aldehyde by the FeS/H\u2082S system. The pyrite-pulled reaction provides the thermodynamic driving force: FeS + H\u2082S \u2192 FeS\u2082 + 2[H]. The selective reduction of the \u03b3-carboxyl over the \u03b1-carboxyl is favored by the geometry of surface adsorption.\",\n      \"reasoning\": \"In biology, glutamate \u03b3-semialdehyde is produced by NADPH-dependent reduction; prebiotically, FeS/H\u2082S or Fe\u00b2\u207a could serve as reductants (as discussed in Vogel and Davis 1952 and subsequent prebiotic literature). Huber and W\u00e4chtersh\u00e4user (2003) established that freshly precipitated FeS drives amino acid transformations at 100\u00b0C. This is identified in the literature as the chemically most demanding step\u2014selective reduction of \u03b3-carboxyl without \u03b1-carboxyl reduction.\"\n    },\n    {\n      \"id\": \"rxn_008\",\n      \"name\": \"Spontaneous intramolecular cyclization of GSA to P5C\",\n      \"inputs\": [\"mol_013\"],\n      \"outputs\": [\"mol_014\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"280-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"none required\",\n        \"aqueous\": true,\n        \"other\": \"spontaneous, non-enzymatic cyclization in aqueous solution at physiological to mildly elevated temperature\"\n      },\n      \"mechanism\": \"The free amino group of GSA undergoes intramolecular nucleophilic attack on the \u03b3-aldehyde carbon, forming a cyclic Schiff base (imine) with loss of water. This creates the five-membered dihydropyrrole ring of \u0394\u00b9-pyrroline-5-carboxylic acid (P5C). The reaction is thermodynamically favorable and requires no catalyst.\",\n      \"reasoning\": \"Vogel and Davis (1952, Journal of the American Chemical Society 74:109-112) first characterized this spontaneous, non-enzymatic intramolecular cyclization. As noted in the literature review, this cyclization requires no catalyst and proceeds readily in aqueous solution, making it one of the most prebiotically plausible steps in the entire pathway. This is the crucial ring-closing step that creates proline's pyrrolidine skeleton.\"\n    },\n    {\n      \"id\": \"rxn_009\",\n      \"name\": \"Reduction of P5C to L-proline\",\n      \"inputs\": [\"mol_014\", \"mol_002\"],\n      \"outputs\": [\"mol_015\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"280-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"Fe\u00b2\u207a ions as electron donor\",\n        \"aqueous\": true,\n        \"other\": \"reducing conditions, Fe\u00b2\u207a-rich anoxic water, or H\u2082 from serpentinization\"\n      },\n      \"mechanism\": \"The C=N imine bond of P5C is reduced by Fe\u00b2\u207a (donating one electron per ion) or dissolved H\u2082 to yield the saturated pyrrolidine ring of proline. In the anoxic early Earth, abundant Fe\u00b2\u207a in solution serves as a mild, ubiquitous reductant.\",\n      \"reasoning\": \"Final reduction of P5C to proline could be driven by Fe\u00b2\u207a, FeS/H\u2082S systems, or molecular hydrogen from serpentinization, as discussed in the literature review. The biological pathway uses NADPH-dependent reductase (Strecker 1957, Journal of Biological Chemistry 225:825-834); prebiotically, reduced iron species and H\u2082 are plausible substitutes. This step completes the glutamate-family pathway to proline.\"\n    },\n    {\n      \"id\": \"rxn_010\",\n      \"name\": \"Cyanosulfidic synthesis of 4-carbon cyanohydrin-thiol\",\n      \"inputs\": [\"mol_006\", \"mol_004\"],\n      \"outputs\": [\"mol_019\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"sulfide minerals (stibnite)\", \"copper minerals (Cu(I)/Cu(II))\"],\n      \"conditions\": {\n        \"temperature\": \"308K (35\u00b0C)\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"Cu(I)/Cu(II) photoredox cycling\",\n        \"aqueous\": true,\n        \"other\": \"anoxic atmosphere, neutral pH, UV irradiation, phosphate buffer\"\n      },\n      \"mechanism\": \"HCN undergoes sequential additions and reductions to form a 4-carbon aldehyde cyanohydrin. H\u2082S adds to this cyanohydrin via nucleophilic thiolation, generating a cyanohydrin-thiol species (\u03b1-hydroxythioamide precursor). Cu(I)/Cu(II) cycling drives the necessary redox steps under UV irradiation.\",\n      \"reasoning\": \"Patel, Percivalle, Ritson, Duffy, and Sutherland (2015, Nature Chemistry 7:301-307) described the cyanosulfidic pathway starting from HCN and H\u2082S with Cu(I)/Cu(II) photoredox cycling at 35\u00b0C. In 'movement c' of their network, a 4-carbon cyanohydrin reacts with H\u2082S to produce both an open-chain and a cyclic \u03b1-hydroxythioamide, the precursor to \u03b3-butyrothiolactam.\"\n    },\n    {\n      \"id\": \"rxn_011\",\n      \"name\": \"UV-driven cyclization to \u03b3-butyrothiolactam\",\n      \"inputs\": [\"mol_019\"],\n      \"outputs\": [\"mol_016\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO\u2082 (anatase/rutile)\", \"copper minerals (Cu(I)/Cu(II))\"],\n      \"conditions\": {\n        \"temperature\": \"308K (35\u00b0C)\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"UV light + Cu(I)/Cu(II)\",\n        \"aqueous\": true,\n        \"other\": \"anoxic, neutral pH, UV irradiation drives cyclization and deoxygenation\"\n      },\n      \"mechanism\": \"UV irradiation drives intramolecular cyclization of the 4-carbon cyanohydrin-thiol. The thioamide nitrogen attacks the terminal carbon, closing the five-membered ring. Concurrent UV-mediated deoxygenation removes the hydroxyl group, yielding \u03b3-butyrothiolactam. The pyrrolidine ring forms spontaneously from the geometric constraints of the 4-carbon chain.\",\n      \"reasoning\": \"Patel et al. (2015, Nature Chemistry 7:301-307) demonstrated that UV irradiation drives cyclization and deoxygenation to yield \u03b3-butyrothiolactam. The elegance of this pathway lies in its inevitability\u2014the pyrrolidine ring forms spontaneously from the geometric constraints of the 4-carbon chain at the thioamide stage, requiring no enzymatic guidance.\"\n    },\n    {\n      \"id\": \"rxn_012\",\n      \"name\": \"Photoreduction and HCN addition to form proline aminonitrile\",\n      \"inputs\": [\"mol_016\", \"mol_006\"],\n      \"outputs\": [\"mol_017\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"copper minerals (Cu(I)/Cu(II))\", \"sulfide minerals (stibnite)\"],\n      \"conditions\": {\n        \"temperature\": \"308K (35\u00b0C)\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"UV light + Cu(I)/Cu(II) photoredox\",\n        \"aqueous\": true,\n        \"other\": \"anoxic atmosphere, neutral pH, UV irradiation, HCN in solution\"\n      },\n      \"mechanism\": \"\u03b3-Butyrothiolactam undergoes UV-driven photoreduction of the C=S bond followed by nucleophilic addition of HCN to the resulting imine carbon, generating the \u03b1-aminonitrile precursor of proline (compound 47 in Patel et al. 2015). The cyclic structure is preserved throughout, maintaining the pyrrolidine ring.\",\n      \"reasoning\": \"Patel et al. (2015, Nature Chemistry 7:301-307) showed that \u03b3-butyrothiolactam undergoes photoreduction and HCN addition to generate the \u03b1-aminonitrile precursor of proline (compound 47). This step is part of the broader cyanosulfidic network that simultaneously generates nucleotide and lipid precursors.\"\n    },\n    {\n      \"id\": \"rxn_013\",\n      \"name\": \"Hydrolysis of proline aminonitrile to L-proline\",\n      \"inputs\": [\"mol_017\", \"mol_005\"],\n      \"outputs\": [\"mol_015\"],\n      \"environment\": \"Biochemical\",\n      \"agents\": [],\n      \"conditions\": {\n        \"temperature\": \"300-370K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"none required; mildly acidic or basic aqueous conditions\",\n        \"aqueous\": true,\n        \"other\": \"aminonitrile hydrolysis proceeds through amide intermediate to carboxylic acid\"\n      },\n      \"mechanism\": \"The nitrile group (-C\u2261N) of the proline aminonitrile is hydrolyzed in two steps: first to an amide (-CONH\u2082) by nucleophilic addition of water, then to a carboxylic acid (-COOH) by further hydrolysis, yielding proline. This is the terminal step of the Strecker/cyanosulfidic pathway.\",\n      \"reasoning\": \"Hydrolysis of aminonitriles to amino acids is the final step of both Strecker synthesis and the cyanosulfidic pathway (Patel et al. 2015, Nature Chemistry 7:301-307). Aminonitrile hydrolysis proceeds readily under mildly acidic or basic aqueous conditions and is one of the most well-established reactions in prebiotic amino acid chemistry. Lerner and Cooper (2005, Geochimica et Cosmochimica Acta 69:2901-2906) detected iminodicarboxylic acids in Murchison meteorite providing evidence for Strecker-type hydrolysis on parent bodies.\"\n    },\n    {\n      \"id\": \"rxn_014\",\n      \"name\": \"HCN oligomerization to DAMN\",\n      \"inputs\": [\"mol_006\"],\n      \"outputs\": [\"mol_018\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite clay\"],\n      \"conditions\": {\n        \"temperature\": \"300-350K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"mineral surfaces concentrate HCN; base catalysis (NH\u2083)\",\n        \"aqueous\": true,\n        \"other\": \"requires HCN concentration \u22650.01 M; evaporitic concentration or mineral adsorption helps\"\n      },\n      \"mechanism\": \"Four molecules of HCN undergo stepwise oligomerization: HCN dimerizes to iminoacetonitrile, which adds a third HCN to form aminomalononitrile, followed by a fourth addition to yield diaminomaleonitrile (DAMN). Base catalysis by NH\u2083 facilitates the initial dimerization.\",\n      \"reasoning\": \"Or\u00f3 (1961) first demonstrated HCN oligomerization to amino acid precursors. DAMN (the HCN tetramer) is the key intermediate in HCN polymerization pathways. Ruiz-Bermejo, Zorzano, and Osuna-Esteban (2013, Life 3:421-448) reviewed 23 experimental conditions and found proline among the amino acids detected in HCN polymer hydrolysis experiments.\"\n    },\n    {\n      \"id\": \"rxn_015\",\n      \"name\": \"DAMN polymer hydrolysis to proline and other amino acids\",\n      \"inputs\": [\"mol_018\", \"mol_005\"],\n      \"outputs\": [\"mol_015\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"montmorillonite clay\", \"TiO\u2082 (anatase/rutile)\"],\n      \"conditions\": {\n        \"temperature\": \"320-400K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"thermal and UV-assisted hydrolysis on mineral surfaces\",\n        \"aqueous\": true,\n        \"other\": \"higher temperatures favor more complete hydrolysis; some experiments at >100\u00b0C; wet-dry cycling aids\"\n      },\n      \"mechanism\": \"DAMN undergoes further oligomerization/polymerization to form HCN polymers, which upon thermal and/or UV-assisted hydrolysis in water release a mixture of amino acids. Cyclic amino acids including proline arise from intramolecular cyclization of appropriately substituted hydantoin or aminonitrile intermediates within the polymer structure during hydrolysis.\",\n      \"reasoning\": \"Ruiz-Bermejo, Zorzano, and Osuna-Esteban (2013, Life 3:421-448) found proline among amino acids detected in HCN polymer hydrolysis experiments, particularly those conducted at higher temperatures. The mechanism proceeds through hydantoin intermediates. This pathway connects HCN chemistry directly to proline without requiring the glutamate intermediate.\"\n    },\n    {\n      \"id\": \"rxn_016\",\n      \"name\": \"Formamide synthesis from CO\u2082 and NH\u2083\",\n      \"inputs\": [\"mol_001\", \"mol_003\", \"mol_002\"],\n      \"outputs\": [\"mol_008\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"magnetite (Fe\u2083O\u2084)\", \"mackinawite (FeS)\"],\n      \"conditions\": {\n        \"temperature\": \"370-470K\",\n        \"pressure\": \"high\",\n        \"catalyst\": \"magnetite\",\n        \"aqueous\": true,\n        \"other\": \"subseafloor hydrothermal, rock-water interactions during serpentinization\"\n      },\n      \"mechanism\": \"CO\u2082 is reduced to formate on magnetite, then formate undergoes condensation with NH\u2083 to form formamide with loss of water. Alternatively, CO is hydrogenated to formaldehyde which reacts with NH\u2083. The high temperature and pressure favor dehydration to formamide.\",\n      \"reasoning\": \"Formamide is a key prebiotic intermediate formed from simple C, N, O, H feedstocks under hydrothermal conditions. It serves as a precursor to both HCN (by dehydration) and nucleobases (by various condensation pathways). Saladino et al. (2017) used formamide as a starting material for amino acid synthesis on mineral surfaces.\"\n    },\n    {\n      \"id\": \"rxn_017\",\n      \"name\": \"Formamide photolysis on TiO\u2082 to HCN and amino acid precursors\",\n      \"inputs\": [\"mol_008\"],\n      \"outputs\": [\"mol_006\"],\n      \"environment\": \"Surface\",\n      \"agents\": [\"TiO\u2082 (anatase/rutile)\", \"phosphate minerals (apatite)\"],\n      \"conditions\": {\n        \"temperature\": \"300-340K\",\n        \"pressure\": \"1 atm\",\n        \"catalyst\": \"TiO\u2082 (rutile) under UV irradiation\",\n        \"aqueous\": true,\n        \"other\": \"shallow UV-exposed pools, no ozone layer, strong UV flux on early Earth\"\n      },\n      \"mechanism\": \"UV photons absorbed by TiO\u2082 generate electron-hole pairs that drive radical decomposition and rearrangement of formamide. Dehydration yields HCN as the primary volatile product. Radical recombination on the TiO\u2082 surface also generates more complex C-N intermediates that can serve as amino acid precursors.\",\n      \"reasoning\": \"Saladino et al. (2017) demonstrated prebiotic synthesis of amino acids from formamide under UV irradiation on TiO\u2082 surfaces. Rutile, a common early Earth mineral, could have driven amino acid formation in UV-exposed shallow water environments. This provides a surface-environment route from formamide to HCN and directly to amino acid precursors.\"\n    },\n    {\n      \"id\": \"rxn_018\",\n      \"name\": \"Proto-TCA cycle generation of \u03b1-ketoglutarate on pyrite/Ni surfaces\",\n      \"inputs\": [\"mol_009\", \"mol_001\", \"mol_002\"],\n      \"outputs\": [\"mol_011\"],\n      \"environment\": \"Hydrothermal\",\n      \"agents\": [\"pyrite (FeS\u2082)\", \"Ni-bearing iron sulfides (NiFeS)\"],\n      \"conditions\": {\n        \"temperature\": \"295-373K\",\n        \"pressure\": \"1-10 bar H\u2082\",\n        \"catalyst\": \"FeS\u2082 and Ni surfaces\",\n        \"aqueous\": true,\n        \"other\": \"pH 7-8, mild hydrothermal or ambient vent-proximal conditions\"\n      },\n      \"mechanism\": \"Pyruvate undergoes carboxylation to oxaloacetate, which is then transformed through citrate/aconitate/isocitrate-like intermediates by mineral-catalyzed oxidative and reductive steps to yield \u03b1-ketoglutarate. This recapitulates the oxidative branch of the TCA cycle on mineral surfaces without enzymes.\",\n      \"reasoning\": \"Muchowska et al. (2017, Nature Ecology & Evolution 1:1716-1721) showed pyrite drives production of most TCA cycle intermediates including the proline precursor \u03b1-ketoglutarate. Kaur, Moran, and colleagues (2024, Chem 10:1528-1540) demonstrated a prebiotic Krebs cycle analog using Ni catalysts at 22\u00b0C, generating \u03b1-ketoglutarate among other TCA intermediates. This provides a purely hydrothermal route to the central hub molecule.\"\n    }\n  ],\n  \"pathways\": [\n    {\n      \"pathway_id\": \"P1\",\n      \"name\": \"Full hydrothermal carbon fixation to proline via glutamate reductive amination\",\n      \"description\": \"CO\u2082 is fixed to formate on greigite, then to pyruvate on magnetite. Glyoxylate is produced from CO\u2082 on pyrite. Pyruvate and glyoxylate condense to \u03b1-ketoglutarate, which is reductively aminated to glutamate on NiFeS. Glutamate is reduced to GSA, which spontaneously cyclizes to P5C, then reduced to proline.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_003\", \"rxn_004\", \"rxn_005\", \"rxn_007\", \"rxn_008\", \"rxn_009\"],\n      \"key_intermediates\": [\"mol_009\", \"mol_010\", \"mol_011\", \"mol_012\", \"mol_014\"]\n    },\n    {\n      \"pathway_id\": \"P2\",\n      \"name\": \"Hydrothermal-to-Surface via Bucherer-Bergs glutamate synthesis\",\n      \"description\": \"CO\u2082 fixation produces pyruvate and glyoxylate hydrothermally. These condense to \u03b1-ketoglutarate on the surface. HCN and NH\u2083 convert \u03b1-ketoglutarate to glutamate via the Bucherer-Bergs pathway. Glutamate then follows the GSA \u2192 P5C \u2192 proline cascade.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_003\", \"rxn_004\", \"rxn_006\", \"rxn_007\", \"rxn_008\", \"rxn_009\"],\n      \"key_intermediates\": [\"mol_009\", \"mol_011\", \"mol_006\", \"mol_012\", \"mol_014\"]\n    },\n    {\n      \"pathway_id\": \"P3\",\n      \"name\": \"Cyanosulfidic photochemistry pathway (Patel-Sutherland)\",\n      \"description\": \"HCN and H\u2082S react under UV with Cu(I)/Cu(II) catalysis to form a 4-carbon cyanohydrin-thiol, which UV-cyclizes to \u03b3-butyrothiolactam. Photoreduction and HCN addition yield proline aminonitrile, which hydrolyzes to proline. This bypasses the glutamate intermediate entirely.\",\n      \"reaction_sequence\": [\"rxn_010\", \"rxn_011\", \"rxn_012\", \"rxn_013\"],\n      \"key_intermediates\": [\"mol_019\", \"mol_016\", \"mol_017\"]\n    },\n    {\n      \"pathway_id\": \"P4\",\n      \"name\": \"HCN oligomerization and polymer hydrolysis\",\n      \"description\": \"HCN oligomerizes to DAMN on mineral surfaces. Further polymerization and thermal/UV-assisted hydrolysis releases proline among other amino acids through hydantoin intermediates. This is the simplest route requiring only HCN and water.\",\n      \"reaction_sequence\": [\"rxn_014\", \"rxn_015\"],\n      \"key_intermediates\": [\"mol_018\"]\n    },\n    {\n      \"pathway_id\": \"P5\",\n      \"name\": \"Formamide-to-HCN-to-cyanosulfidic proline\",\n      \"description\": \"CO\u2082 and NH\u2083 are hydrothermally converted to formamide. Formamide is photolyzed to HCN on TiO\u2082 surfaces. HCN then enters the cyanosulfidic pathway to produce proline via \u03b3-butyrothiolactam.\",\n      \"reaction_sequence\": [\"rxn_016\", \"rxn_017\", \"rxn_010\", \"rxn_011\", \"rxn_012\", \"rxn_013\"],\n      \"key_intermediates\": [\"mol_008\", \"mol_006\", \"mol_016\", \"mol_017\"]\n    },\n    {\n      \"pathway_id\": \"P6\",\n      \"name\": \"Formamide-to-HCN-to-DAMN polymer hydrolysis\",\n      \"description\": \"Formamide is produced hydrothermally and photolyzed to HCN on the surface. HCN oligomerizes to DAMN, whose polymers hydrolyze to yield proline directly.\",\n      \"reaction_sequence\": [\"rxn_016\", \"rxn_017\", \"rxn_014\", \"rxn_015\"],\n      \"key_intermediates\": [\"mol_008\", \"mol_006\", \"mol_018\"]\n    },\n    {\n      \"pathway_id\": \"P7\",\n      \"name\": \"Proto-TCA cycle on Ni/FeS to \u03b1-ketoglutarate to proline\",\n      \"description\": \"Pyruvate produced hydrothermally is converted to \u03b1-ketoglutarate via a non-enzymatic proto-TCA cycle on pyrite and nickel surfaces. Reductive amination yields glutamate, which undergoes the GSA \u2192 P5C \u2192 proline cascade.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_018\", \"rxn_005\", \"rxn_007\", \"rxn_008\", \"rxn_009\"],\n      \"key_intermediates\": [\"mol_009\", \"mol_011\", \"mol_012\", \"mol_014\"]\n    },\n    {\n      \"pathway_id\": \"P8\",\n      \"name\": \"HCN-Bucherer-Bergs convergence on glutamate via proto-TCA \u03b1-ketoglutarate\",\n      \"description\": \"Pyruvate from hydrothermal CO\u2082 fixation feeds the proto-TCA cycle to produce \u03b1-ketoglutarate. Meanwhile, HCN derived from formamide photolysis provides the cyanide for Bucherer-Bergs conversion of \u03b1-ketoglutarate to glutamate, completing the route to proline via P5C.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_018\", \"rxn_016\", \"rxn_017\", \"rxn_006\", \"rxn_007\", \"rxn_008\", \"rxn_009\"],\n      \"key_intermediates\": [\"mol_009\", \"mol_011\", \"mol_006\", \"mol_012\", \"mol_014\"]\n    },\n    {\n      \"pathway_id\": \"P9\",\n      \"name\": \"Surface glyoxylate condensation with proto-TCA divergence\",\n      \"description\": \"Glyoxylate from hydrothermal pyrite chemistry and pyruvate condense on the surface to form \u03b1-ketoglutarate. Bucherer-Bergs with HCN from DAMN decomposition produces glutamate, which follows the standard GSA \u2192 P5C \u2192 proline pathway.\",\n      \"reaction_sequence\": [\"rxn_001\", \"rxn_002\", \"rxn_003\", \"rxn_004\", \"rxn_006\", \"rxn_007\", \"rxn_008\", \"rxn_009\"],\n      \"key_intermediates\": [\"mol_010\", \"mol_011\", \"mol_006\", \"mol_012\", \"mol_014\"]\n    },\n    {\n      \"pathway_id\": \"P10\",\n      \"name\": \"Formamide-HCN-Bucherer-Bergs via surface \u03b1-ketoglutarate\",\n      \"description\": \"Formamide from hydrothermal synthesis provides HCN after surface TiO\u2082 photolysis. Simultaneously, pyruvate and glyoxylate from hydrothermal vents condense to \u03b1-ketoglutarate on the surface. HCN and NH\u2083 convert \u03b1-ketoglutarate to glutamate (Bucherer-Bergs). GSA \u2192 P5C \u2192 proline completes the network.\",\n      \"reaction_sequence\": [\"rxn_016\", \"rxn_017\", \"rxn_001\", \"rxn_002\", \"rxn_003\", \"rxn_004\", \"rxn_006\", \"rxn_007\", \"rxn_008\", \"rxn_009\"],\n      \"key_intermediates\": [\"mol_008\", \"mol_006\", \"mol_011\", \"mol_012\", \"mol_014\"]\n    }\n  ],\n  \"hub_molecules\": [\"mol_006\", \"mol_009\", \"mol_011\", \"mol_012\", \"mol_014\"],\n  \"convergence_points\": [\n    {\n      \"molecule_id\": \"mol_006\",\n      \"description\": \"HCN is the central C1-N building block feeding cyanosulfidic, Bucherer-Bergs, and HCN oligomerization pathways\",\n      \"incoming_reactions\": [\"rxn_017\"],\n      \"outgoing_reactions\": [\"rxn_010\", \"rxn_012\", \"rxn_006\", \"rxn_014\"]\n    },\n    {\n      \"molecule_id\": \"mol_009\",\n      \"description\": \"Pyruvate is the central C3 keto-acid hub linking CO\u2082 fixation to proto-TCA and \u03b1-ketoglutarate synthesis\",\n      \"incoming_reactions\": [\"rxn_002\"],\n      \"outgoing_reactions\": [\"rxn_004\", \"rxn_018\"]\n    },\n    {\n      \"molecule_id\": \"mol_011\",\n      \"description\": \"\u03b1-Ketoglutarate is the central branch-point intermediate at the intersection of carbon metabolism and amino acid synthesis\",\n      \"incoming_reactions\": [\"rxn_004\", \"rxn_018\"],\n      \"outgoing_reactions\": [\"rxn_005\", \"rxn_006\"]\n    },\n    {\n      \"molecule_id\": \"mol_012\",\n      \"description\": \"Glutamate is the direct precursor to proline via the GSA \u2192 P5C cyclization cascade, produced by two independent routes\",\n      \"incoming_reactions\": [\"rxn_005\", \"rxn_006\"],\n      \"outgoing_reactions\": [\"rxn_007\"]\n    },\n    {\n      \"molecule_id\": \"mol_014\",\n      \"description\": \"P5C (\u0394\u00b9-pyrroline-5-carboxylic acid) is the penultimate intermediate bearing the completed pyrrolidine ring skeleton\",\n      \"incoming_reactions\": [\"rxn_008\"],\n      \"outgoing_reactions\": [\"rxn_009\"]\n    }\n  ]\n}", "parsed_response": {"target_molecule": "L-Proline", "overall_strategy": "L-Proline synthesis proceeds through four major literature-established routes: (1) hydrothermal CO\u2082 fixation to pyruvate and glyoxylate, which combine to form \u03b1-ketoglutarate\u2014the central metabolic hub\u2014followed by reductive amination to glutamate and the spontaneous GSA\u2192P5C cyclization cascade; (2) cyanosulfidic photochemistry (Patel et al. 2015) converting HCN and H\u2082S through \u03b3-butyrothiolactam to a proline aminonitrile; (3) HCN oligomerization via DAMN and hydantoin intermediates; and (4) formamide photolysis on TiO\u2082. The network is organized around five hub molecules (HCN, pyruvate, \u03b1-ketoglutarate, glutamate, P5C) that interconnect hydrothermal, surface, and biochemical environments, creating 10 distinct pathways with multiple convergence points.", "molecules": [{"id": "mol_001", "formula": "CO2", "iupac_name": "carbon dioxide", "common_name": "carbon dioxide", "inchi": "InChI=1S/CO2/c2-1-3", "role": "starting", "environment_formed": null}, {"id": "mol_002", "formula": "H2", "iupac_name": "molecular hydrogen", "common_name": "hydrogen gas", "inchi": "InChI=1S/H2/h1H", "role": "starting", "environment_formed": null}, {"id": "mol_003", "formula": "NH3", "iupac_name": "ammonia", "common_name": "ammonia", "inchi": "InChI=1S/H3N/h1H3", "role": "starting", "environment_formed": null}, {"id": "mol_004", "formula": "H2S", "iupac_name": "hydrogen sulfide", "common_name": "hydrogen sulfide", "inchi": "InChI=1S/H2S/h1H2", "role": "starting", "environment_formed": null}, {"id": "mol_005", "formula": "H2O", "iupac_name": "water", "common_name": "water", "inchi": "InChI=1S/H2O/h1H2", "role": "starting", "environment_formed": null}, {"id": "mol_006", "formula": "HCN", "iupac_name": "hydrogen cyanide", "common_name": "hydrogen cyanide", "inchi": "InChI=1S/CHN/c1-2/h1H", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_007", "formula": "HCOO-", "iupac_name": "formate", "common_name": "formate", "inchi": "InChI=1S/CH2O2/c2-1-3/h1H,(H,2,3)/p-1", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_008", "formula": "CH3NHCHO", "iupac_name": "formamide", "common_name": "formamide", "inchi": "InChI=1S/CH3NO/c2-1-3/h1H,(H2,2,3)", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_009", "formula": "C3H3O3-", "iupac_name": "2-oxopropanoate", "common_name": "pyruvate", "inchi": "InChI=1S/C3H4O3/c1-2(4)3(5)6/h1H3,(H,5,6)/p-1", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_010", "formula": "C2HO3-", "iupac_name": "oxoacetate", "common_name": "glyoxylate", "inchi": "InChI=1S/C2H2O3/c3-1-2(4)5/h1H,(H,4,5)/p-1", "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_011", "formula": "C5H4O5", "iupac_name": "2-oxopentanedioic acid", "common_name": "alpha-ketoglutarate", "inchi": "InChI=1S/C5H6O5/c6-3(5-9)1-2-4(7)8/h1-2H2,(H,7,8)(H,9,10)", "role": "hub_intermediate", "environment_formed": "Surface"}, {"id": "mol_012", "formula": "C5H9NO4", "iupac_name": "(2S)-2-aminopentanedioic acid", "common_name": "L-glutamate", "inchi": "InChI=1S/C5H9NO4/c6-3(5(9)10)1-2-4(7)8/h3H,1-2,6H2,(H,7,8)(H,9,10)/t3-/m0/s1", "role": "hub_intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_013", "formula": "C5H9NO3", "iupac_name": "(2S)-2-amino-5-oxopentanoic acid", "common_name": "glutamic-gamma-semialdehyde", "inchi": null, "role": "intermediate", "environment_formed": "Hydrothermal"}, {"id": "mol_014", "formula": "C5H7NO2", "iupac_name": "3,4-dihydro-2H-pyrrole-2-carboxylic acid", "common_name": "delta-1-pyrroline-5-carboxylic acid (P5C)", "inchi": null, "role": "hub_intermediate", "environment_formed": "Biochemical"}, {"id": "mol_015", "formula": "C5H9NO2", "iupac_name": "(2S)-pyrrolidine-2-carboxylic acid", "common_name": "L-proline", "inchi": "InChI=1S/C5H9NO2/c7-4-2-1-3-5(4)8/h4H,1-3,7H2,(H,8,9)/t4-/m0/s1", "role": "target", "environment_formed": "Biochemical"}, {"id": "mol_016", "formula": "C4H5NOS", "iupac_name": "pyrrolidin-2-thione", "common_name": "gamma-butyrothiolactam", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_017", "formula": "C5H8N2O", "iupac_name": "2-amino-1-pyrroline-5-carbonitrile", "common_name": "proline alpha-aminonitrile", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_018", "formula": "C4H4N4", "iupac_name": "2,3-diaminomaleonitrile", "common_name": "DAMN", "inchi": "InChI=1S/C4H4N4/c5-1-3(7)4(8)2-6/h7-8H2", "role": "intermediate", "environment_formed": "Surface"}, {"id": "mol_019", "formula": "C4H5NO2S", "iupac_name": "4-hydroxy-4-(sulfanyl)butanenitrile", "common_name": "4-carbon cyanohydrin-thiol", "inchi": null, "role": "intermediate", "environment_formed": "Surface"}], "reactions": [{"id": "rxn_001", "name": "CO\u2082 hydrogenation to formate on greigite", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_007"], "environment": "Hydrothermal", "agents": ["greigite (Fe\u2083S\u2084)", "mackinawite (FeS)"], "conditions": {"temperature": "350-400K", "pressure": "high (>50 bar)", "catalyst": "greigite (Fe\u2083S\u2084)", "aqueous": true, "other": "alkaline vent conditions, pH 9-11, H\u2082-rich serpentinization fluid"}, "mechanism": "CO\u2082 is adsorbed on the Fe\u2083S\u2084 surface, which is structurally analogous to biological [4Fe-4S] clusters. H\u2082 dissociatively adsorbs and reduces CO\u2082 through a formate intermediate via surface hydride transfer.", "reasoning": "Greigite (Fe\u2083S\u2084) is structurally analogous to [4Fe-4S] clusters in acetyl-CoA synthase and catalyzes CO\u2082 reduction to formate under hydrothermal conditions (Li et al. 2018, Life 8:46; Russell and Hall 1997, 2006). This represents the first step of carbon fixation in alkaline hydrothermal vent models."}, {"id": "rxn_002", "name": "Formate to pyruvate via CO\u2082 fixation on magnetite", "inputs": ["mol_007", "mol_001", "mol_002"], "outputs": ["mol_009"], "environment": "Hydrothermal", "agents": ["magnetite (Fe\u2083O\u2084)", "greigite (Fe\u2083S\u2084)"], "conditions": {"temperature": "350-400K", "pressure": "high (>50 bar)", "catalyst": "magnetite (Fe\u2083O\u2084)", "aqueous": true, "other": "Fischer-Tropsch-type synthesis conditions, alkaline vent mineral surfaces"}, "mechanism": "Sequential C1 additions via Fischer-Tropsch-type chemistry on magnetite surfaces: formate undergoes further reduction and carbonylation to produce acetaldehyde, then reacts with CO\u2082 to yield pyruvate through a reductive carboxylation mechanism.", "reasoning": "Magnetite catalyzes Fischer-Tropsch-type synthesis of multi-carbon organics from C1 units under hydrothermal conditions. Pyruvate is a key product of hydrothermal CO\u2082 fixation pathways (Cody et al. 2000; reviewed in Martin and Russell 2007). Pyruvate occupies a central position in proto-metabolism."}, {"id": "rxn_003", "name": "CO\u2082 reduction to glyoxylate on pyrite", "inputs": ["mol_001", "mol_002"], "outputs": ["mol_010"], "environment": "Hydrothermal", "agents": ["pyrite (FeS\u2082)", "elemental iron (Fe\u2070)"], "conditions": {"temperature": "370-420K", "pressure": "high", "catalyst": "pyrite (FeS\u2082)", "aqueous": true, "other": "pyrite-pulled reductive synthesis, FeS + H\u2082S \u2192 FeS\u2082 provides driving force"}, "mechanism": "CO\u2082 is reduced on the FeS\u2082 surface with electrons provided by the thermodynamically favorable pyrite formation reaction (FeS + H\u2082S \u2192 FeS\u2082 + 2H\u207a + 2e\u207b). Sequential reduction yields glyoxylate as a C2 keto-acid.", "reasoning": "W\u00e4chtersh\u00e4user's pyrite-pulled mechanism provides reducing equivalents for CO\u2082 fixation. Glyoxylate is a central intermediate in protometabolic cycles (Springsteen et al. 2018, Nature Communications 9:91). Muchowska et al. (2017, Nature Ecology & Evolution 1:1716-1721) demonstrated that pyrite drives production of TCA cycle intermediates including glyoxylate."}, {"id": "rxn_004", "name": "Pyruvate-glyoxylate condensation to \u03b1-ketoglutarate", "inputs": ["mol_009", "mol_010"], "outputs": ["mol_011"], "environment": "Surface", "agents": ["montmorillonite clay", "copper minerals (Cu\u00b2\u207a)"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "Cu\u00b2\u207a ions", "aqueous": true, "other": "evaporitic pool conditions, Cu\u00b2\u207a catalysis at neutral to mildly alkaline pH"}, "mechanism": "Aldol-type condensation of pyruvate and glyoxylate followed by oxidative decarboxylation steps produces \u03b1-ketoglutarate. Cu\u00b2\u207a facilitates oxidative transformations. This recapitulates key steps of the non-enzymatic TCA cycle.", "reasoning": "Stubbs, Yadav, Krishnamurthy, and Springsteen (2020, Nature Chemistry 12:1016-1022) demonstrated that \u03b1-keto acid chemistry can reproduce key features of the TCA cycle without enzymes. Springsteen et al. (2018, Nature Communications 9:91) showed linked cycles of oxidative decarboxylation of glyoxylate as protometabolic analogs. Krishnamurthy's group (2025) demonstrated \u03b1-ketoglutarate formation via pyruvate and glyoxylate intermediates with Cu\u00b2\u207a catalysis."}, {"id": "rxn_005", "name": "Reductive amination of \u03b1-ketoglutarate to glutamate on NiFeS", "inputs": ["mol_011", "mol_003", "mol_002"], "outputs": ["mol_012"], "environment": "Hydrothermal", "agents": ["greigite (Fe\u2083S\u2084)", "Ni-bearing iron sulfides (NiFeS)"], "conditions": {"temperature": "295-373K", "pressure": "1-10 bar H\u2082", "catalyst": "Ni/FeS or Ni/SiO\u2082-Al\u2082O\u2083", "aqueous": true, "other": "pH 8, mild reducing conditions with H\u2082, also achievable with ground meteorite material"}, "mechanism": "\u03b1-Ketoglutarate undergoes nucleophilic addition of NH\u2083 at the keto group to form an imine intermediate, which is then reduced by H\u2082 on the nickel surface to form L-glutamate. The NiFeS surface activates both H\u2082 and the substrate.", "reasoning": "Huber and W\u00e4chtersh\u00e4user (1998, Science 281:670-672) demonstrated reductive amination of \u03b1-keto acids to amino acids on (Ni,Fe)S surfaces. Most recently, Kaur, Moran, and colleagues (2024, Chem 10:1528-1540) demonstrated a prebiotic Krebs cycle analog generating amino acids including glutamate with H\u2082 and NH\u2083 over nickel catalysts at 22\u00b0C, pH 8, 1-10 bar H\u2082, using Ni/SiO\u2082-Al\u2082O\u2083 or ground meteorites as catalysts."}, {"id": "rxn_006", "name": "Bucherer-Bergs synthesis of glutamate from \u03b1-ketoglutarate", "inputs": ["mol_011", "mol_006", "mol_003"], "outputs": ["mol_012"], "environment": "Surface", "agents": ["montmorillonite clay", "phosphate minerals (apatite)"], "conditions": {"temperature": "300-340K", "pressure": "1 atm", "catalyst": "none required, mineral surfaces concentrate reactants", "aqueous": true, "other": "evaporitic pool, mildly alkaline pH, HCN and NH\u2083 in millimolar concentrations"}, "mechanism": "\u03b1-Ketoglutarate reacts with HCN and NH\u2083 via the Bucherer-Bergs pathway: HCN adds to the keto group forming a cyanohydrin, which reacts with NH\u2083 to form a hydantoin intermediate that hydrolyzes to glutamate. This is a variant of the Strecker synthesis proceeding through a hydantoin.", "reasoning": "Pulletikurti, Yadav, Springsteen, and Krishnamurthy (2022, Nature Chemistry) demonstrated that \u03b1-ketoacids react with cyanide and ammonia via the Bucherer-Bergs pathway to form amino acids, including glutamate from \u03b1-ketoglutarate. This provides an alternative surface-environment route to glutamate that does not require H\u2082 or metal sulfide catalysis."}, {"id": "rxn_007", "name": "Reduction of glutamate \u03b3-carboxyl to glutamic-\u03b3-semialdehyde", "inputs": ["mol_012", "mol_004"], "outputs": ["mol_013"], "environment": "Hydrothermal", "agents": ["pyrite (FeS\u2082)", "mackinawite (FeS)"], "conditions": {"temperature": "350-400K", "pressure": "moderate to high", "catalyst": "FeS/H\u2082S system", "aqueous": true, "other": "reducing conditions, FeS + H\u2082S \u2192 FeS\u2082 provides electrons for selective carboxyl reduction"}, "mechanism": "The \u03b3-carboxyl group of glutamate is selectively reduced to an aldehyde by the FeS/H\u2082S system. The pyrite-pulled reaction provides the thermodynamic driving force: FeS + H\u2082S \u2192 FeS\u2082 + 2[H]. The selective reduction of the \u03b3-carboxyl over the \u03b1-carboxyl is favored by the geometry of surface adsorption.", "reasoning": "In biology, glutamate \u03b3-semialdehyde is produced by NADPH-dependent reduction; prebiotically, FeS/H\u2082S or Fe\u00b2\u207a could serve as reductants (as discussed in Vogel and Davis 1952 and subsequent prebiotic literature). Huber and W\u00e4chtersh\u00e4user (2003) established that freshly precipitated FeS drives amino acid transformations at 100\u00b0C. This is identified in the literature as the chemically most demanding step\u2014selective reduction of \u03b3-carboxyl without \u03b1-carboxyl reduction."}, {"id": "rxn_008", "name": "Spontaneous intramolecular cyclization of GSA to P5C", "inputs": ["mol_013"], "outputs": ["mol_014"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "280-370K", "pressure": "1 atm", "catalyst": "none required", "aqueous": true, "other": "spontaneous, non-enzymatic cyclization in aqueous solution at physiological to mildly elevated temperature"}, "mechanism": "The free amino group of GSA undergoes intramolecular nucleophilic attack on the \u03b3-aldehyde carbon, forming a cyclic Schiff base (imine) with loss of water. This creates the five-membered dihydropyrrole ring of \u0394\u00b9-pyrroline-5-carboxylic acid (P5C). The reaction is thermodynamically favorable and requires no catalyst.", "reasoning": "Vogel and Davis (1952, Journal of the American Chemical Society 74:109-112) first characterized this spontaneous, non-enzymatic intramolecular cyclization. As noted in the literature review, this cyclization requires no catalyst and proceeds readily in aqueous solution, making it one of the most prebiotically plausible steps in the entire pathway. This is the crucial ring-closing step that creates proline's pyrrolidine skeleton."}, {"id": "rxn_009", "name": "Reduction of P5C to L-proline", "inputs": ["mol_014", "mol_002"], "outputs": ["mol_015"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "280-370K", "pressure": "1 atm", "catalyst": "Fe\u00b2\u207a ions as electron donor", "aqueous": true, "other": "reducing conditions, Fe\u00b2\u207a-rich anoxic water, or H\u2082 from serpentinization"}, "mechanism": "The C=N imine bond of P5C is reduced by Fe\u00b2\u207a (donating one electron per ion) or dissolved H\u2082 to yield the saturated pyrrolidine ring of proline. In the anoxic early Earth, abundant Fe\u00b2\u207a in solution serves as a mild, ubiquitous reductant.", "reasoning": "Final reduction of P5C to proline could be driven by Fe\u00b2\u207a, FeS/H\u2082S systems, or molecular hydrogen from serpentinization, as discussed in the literature review. The biological pathway uses NADPH-dependent reductase (Strecker 1957, Journal of Biological Chemistry 225:825-834); prebiotically, reduced iron species and H\u2082 are plausible substitutes. This step completes the glutamate-family pathway to proline."}, {"id": "rxn_010", "name": "Cyanosulfidic synthesis of 4-carbon cyanohydrin-thiol", "inputs": ["mol_006", "mol_004"], "outputs": ["mol_019"], "environment": "Surface", "agents": ["sulfide minerals (stibnite)", "copper minerals (Cu(I)/Cu(II))"], "conditions": {"temperature": "308K (35\u00b0C)", "pressure": "1 atm", "catalyst": "Cu(I)/Cu(II) photoredox cycling", "aqueous": true, "other": "anoxic atmosphere, neutral pH, UV irradiation, phosphate buffer"}, "mechanism": "HCN undergoes sequential additions and reductions to form a 4-carbon aldehyde cyanohydrin. H\u2082S adds to this cyanohydrin via nucleophilic thiolation, generating a cyanohydrin-thiol species (\u03b1-hydroxythioamide precursor). Cu(I)/Cu(II) cycling drives the necessary redox steps under UV irradiation.", "reasoning": "Patel, Percivalle, Ritson, Duffy, and Sutherland (2015, Nature Chemistry 7:301-307) described the cyanosulfidic pathway starting from HCN and H\u2082S with Cu(I)/Cu(II) photoredox cycling at 35\u00b0C. In 'movement c' of their network, a 4-carbon cyanohydrin reacts with H\u2082S to produce both an open-chain and a cyclic \u03b1-hydroxythioamide, the precursor to \u03b3-butyrothiolactam."}, {"id": "rxn_011", "name": "UV-driven cyclization to \u03b3-butyrothiolactam", "inputs": ["mol_019"], "outputs": ["mol_016"], "environment": "Surface", "agents": ["TiO\u2082 (anatase/rutile)", "copper minerals (Cu(I)/Cu(II))"], "conditions": {"temperature": "308K (35\u00b0C)", "pressure": "1 atm", "catalyst": "UV light + Cu(I)/Cu(II)", "aqueous": true, "other": "anoxic, neutral pH, UV irradiation drives cyclization and deoxygenation"}, "mechanism": "UV irradiation drives intramolecular cyclization of the 4-carbon cyanohydrin-thiol. The thioamide nitrogen attacks the terminal carbon, closing the five-membered ring. Concurrent UV-mediated deoxygenation removes the hydroxyl group, yielding \u03b3-butyrothiolactam. The pyrrolidine ring forms spontaneously from the geometric constraints of the 4-carbon chain.", "reasoning": "Patel et al. (2015, Nature Chemistry 7:301-307) demonstrated that UV irradiation drives cyclization and deoxygenation to yield \u03b3-butyrothiolactam. The elegance of this pathway lies in its inevitability\u2014the pyrrolidine ring forms spontaneously from the geometric constraints of the 4-carbon chain at the thioamide stage, requiring no enzymatic guidance."}, {"id": "rxn_012", "name": "Photoreduction and HCN addition to form proline aminonitrile", "inputs": ["mol_016", "mol_006"], "outputs": ["mol_017"], "environment": "Surface", "agents": ["copper minerals (Cu(I)/Cu(II))", "sulfide minerals (stibnite)"], "conditions": {"temperature": "308K (35\u00b0C)", "pressure": "1 atm", "catalyst": "UV light + Cu(I)/Cu(II) photoredox", "aqueous": true, "other": "anoxic atmosphere, neutral pH, UV irradiation, HCN in solution"}, "mechanism": "\u03b3-Butyrothiolactam undergoes UV-driven photoreduction of the C=S bond followed by nucleophilic addition of HCN to the resulting imine carbon, generating the \u03b1-aminonitrile precursor of proline (compound 47 in Patel et al. 2015). The cyclic structure is preserved throughout, maintaining the pyrrolidine ring.", "reasoning": "Patel et al. (2015, Nature Chemistry 7:301-307) showed that \u03b3-butyrothiolactam undergoes photoreduction and HCN addition to generate the \u03b1-aminonitrile precursor of proline (compound 47). This step is part of the broader cyanosulfidic network that simultaneously generates nucleotide and lipid precursors."}, {"id": "rxn_013", "name": "Hydrolysis of proline aminonitrile to L-proline", "inputs": ["mol_017", "mol_005"], "outputs": ["mol_015"], "environment": "Biochemical", "agents": [], "conditions": {"temperature": "300-370K", "pressure": "1 atm", "catalyst": "none required; mildly acidic or basic aqueous conditions", "aqueous": true, "other": "aminonitrile hydrolysis proceeds through amide intermediate to carboxylic acid"}, "mechanism": "The nitrile group (-C\u2261N) of the proline aminonitrile is hydrolyzed in two steps: first to an amide (-CONH\u2082) by nucleophilic addition of water, then to a carboxylic acid (-COOH) by further hydrolysis, yielding proline. This is the terminal step of the Strecker/cyanosulfidic pathway.", "reasoning": "Hydrolysis of aminonitriles to amino acids is the final step of both Strecker synthesis and the cyanosulfidic pathway (Patel et al. 2015, Nature Chemistry 7:301-307). Aminonitrile hydrolysis proceeds readily under mildly acidic or basic aqueous conditions and is one of the most well-established reactions in prebiotic amino acid chemistry. Lerner and Cooper (2005, Geochimica et Cosmochimica Acta 69:2901-2906) detected iminodicarboxylic acids in Murchison meteorite providing evidence for Strecker-type hydrolysis on parent bodies."}, {"id": "rxn_014", "name": "HCN oligomerization to DAMN", "inputs": ["mol_006"], "outputs": ["mol_018"], "environment": "Surface", "agents": ["montmorillonite clay"], "conditions": {"temperature": "300-350K", "pressure": "1 atm", "catalyst": "mineral surfaces concentrate HCN; base catalysis (NH\u2083)", "aqueous": true, "other": "requires HCN concentration \u22650.01 M; evaporitic concentration or mineral adsorption helps"}, "mechanism": "Four molecules of HCN undergo stepwise oligomerization: HCN dimerizes to iminoacetonitrile, which adds a third HCN to form aminomalononitrile, followed by a fourth addition to yield diaminomaleonitrile (DAMN). Base catalysis by NH\u2083 facilitates the initial dimerization.", "reasoning": "Or\u00f3 (1961) first demonstrated HCN oligomerization to amino acid precursors. DAMN (the HCN tetramer) is the key intermediate in HCN polymerization pathways. Ruiz-Bermejo, Zorzano, and Osuna-Esteban (2013, Life 3:421-448) reviewed 23 experimental conditions and found proline among the amino acids detected in HCN polymer hydrolysis experiments."}, {"id": "rxn_015", "name": "DAMN polymer hydrolysis to proline and other amino acids", "inputs": ["mol_018", "mol_005"], "outputs": ["mol_015"], "environment": "Surface", "agents": ["montmorillonite clay", "TiO\u2082 (anatase/rutile)"], "conditions": {"temperature": "320-400K", "pressure": "1 atm", "catalyst": "thermal and UV-assisted hydrolysis on mineral surfaces", "aqueous": true, "other": "higher temperatures favor more complete hydrolysis; some experiments at >100\u00b0C; wet-dry cycling aids"}, "mechanism": "DAMN undergoes further oligomerization/polymerization to form HCN polymers, which upon thermal and/or UV-assisted hydrolysis in water release a mixture of amino acids. Cyclic amino acids including proline arise from intramolecular cyclization of appropriately substituted hydantoin or aminonitrile intermediates within the polymer structure during hydrolysis.", "reasoning": "Ruiz-Bermejo, Zorzano, and Osuna-Esteban (2013, Life 3:421-448) found proline among amino acids detected in HCN polymer hydrolysis experiments, particularly those conducted at higher temperatures. The mechanism proceeds through hydantoin intermediates. This pathway connects HCN chemistry directly to proline without requiring the glutamate intermediate."}, {"id": "rxn_016", "name": "Formamide synthesis from CO\u2082 and NH\u2083", "inputs": ["mol_001", "mol_003", "mol_002"], "outputs": ["mol_008"], "environment": "Hydrothermal", "agents": ["magnetite (Fe\u2083O\u2084)", "mackinawite (FeS)"], "conditions": {"temperature": "370-470K", "pressure": "high", "catalyst": "magnetite", "aqueous": true, "other": "subseafloor hydrothermal, rock-water interactions during serpentinization"}, "mechanism": "CO\u2082 is reduced to formate on magnetite, then formate undergoes condensation with NH\u2083 to form formamide with loss of water. Alternatively, CO is hydrogenated to formaldehyde which reacts with NH\u2083. The high temperature and pressure favor dehydration to formamide.", "reasoning": "Formamide is a key prebiotic intermediate formed from simple C, N, O, H feedstocks under hydrothermal conditions. It serves as a precursor to both HCN (by dehydration) and nucleobases (by various condensation pathways). Saladino et al. (2017) used formamide as a starting material for amino acid synthesis on mineral surfaces."}, {"id": "rxn_017", "name": "Formamide photolysis on TiO\u2082 to HCN and amino acid precursors", "inputs": ["mol_008"], "outputs": ["mol_006"], "environment": "Surface", "agents": ["TiO\u2082 (anatase/rutile)", "phosphate minerals (apatite)"], "conditions": {"temperature": "300-340K", "pressure": "1 atm", "catalyst": "TiO\u2082 (rutile) under UV irradiation", "aqueous": true, "other": "shallow UV-exposed pools, no ozone layer, strong UV flux on early Earth"}, "mechanism": "UV photons absorbed by TiO\u2082 generate electron-hole pairs that drive radical decomposition and rearrangement of formamide. Dehydration yields HCN as the primary volatile product. Radical recombination on the TiO\u2082 surface also generates more complex C-N intermediates that can serve as amino acid precursors.", "reasoning": "Saladino et al. (2017) demonstrated prebiotic synthesis of amino acids from formamide under UV irradiation on TiO\u2082 surfaces. Rutile, a common early Earth mineral, could have driven amino acid formation in UV-exposed shallow water environments. This provides a surface-environment route from formamide to HCN and directly to amino acid precursors."}, {"id": "rxn_018", "name": "Proto-TCA cycle generation of \u03b1-ketoglutarate on pyrite/Ni surfaces", "inputs": ["mol_009", "mol_001", "mol_002"], "outputs": ["mol_011"], "environment": "Hydrothermal", "agents": ["pyrite (FeS\u2082)", "Ni-bearing iron sulfides (NiFeS)"], "conditions": {"temperature": "295-373K", "pressure": "1-10 bar H\u2082", "catalyst": "FeS\u2082 and Ni surfaces", "aqueous": true, "other": "pH 7-8, mild hydrothermal or ambient vent-proximal conditions"}, "mechanism": "Pyruvate undergoes carboxylation to oxaloacetate, which is then transformed through citrate/aconitate/isocitrate-like intermediates by mineral-catalyzed oxidative and reductive steps to yield \u03b1-ketoglutarate. This recapitulates the oxidative branch of the TCA cycle on mineral surfaces without enzymes.", "reasoning": "Muchowska et al. (2017, Nature Ecology & Evolution 1:1716-1721) showed pyrite drives production of most TCA cycle intermediates including the proline precursor \u03b1-ketoglutarate. Kaur, Moran, and colleagues (2024, Chem 10:1528-1540) demonstrated a prebiotic Krebs cycle analog using Ni catalysts at 22\u00b0C, generating \u03b1-ketoglutarate among other TCA intermediates. This provides a purely hydrothermal route to the central hub molecule."}], "pathways": [{"pathway_id": "P1", "name": "Full hydrothermal carbon fixation to proline via glutamate reductive amination", "description": "CO\u2082 is fixed to formate on greigite, then to pyruvate on magnetite. Glyoxylate is produced from CO\u2082 on pyrite. Pyruvate and glyoxylate condense to \u03b1-ketoglutarate, which is reductively aminated to glutamate on NiFeS. Glutamate is reduced to GSA, which spontaneously cyclizes to P5C, then reduced to proline.", "reaction_sequence": ["rxn_001", "rxn_002", "rxn_003", "rxn_004", "rxn_005", "rxn_007", "rxn_008", "rxn_009"], "key_intermediates": ["mol_009", "mol_010", "mol_011", "mol_012", "mol_014"]}, {"pathway_id": "P2", "name": "Hydrothermal-to-Surface via Bucherer-Bergs glutamate synthesis", "description": "CO\u2082 fixation produces pyruvate and glyoxylate hydrothermally. These condense to \u03b1-ketoglutarate on the surface. HCN and NH\u2083 convert \u03b1-ketoglutarate to glutamate via the Bucherer-Bergs pathway. Glutamate then follows the GSA \u2192 P5C \u2192 proline cascade.", "reaction_sequence": ["rxn_001", "rxn_002", "rxn_003", "rxn_004", "rxn_006", "rxn_007", "rxn_008", "rxn_009"], "key_intermediates": ["mol_009", "mol_011", "mol_006", "mol_012", "mol_014"]}, {"pathway_id": "P3", "name": "Cyanosulfidic photochemistry pathway (Patel-Sutherland)", "description": "HCN and H\u2082S react under UV with Cu(I)/Cu(II) catalysis to form a 4-carbon cyanohydrin-thiol, which UV-cyclizes to \u03b3-butyrothiolactam. Photoreduction and HCN addition yield proline aminonitrile, which hydrolyzes to proline. This bypasses the glutamate intermediate entirely.", "reaction_sequence": ["rxn_010", "rxn_011", "rxn_012", "rxn_013"], "key_intermediates": ["mol_019", "mol_016", "mol_017"]}, {"pathway_id": "P4", "name": "HCN oligomerization and polymer hydrolysis", "description": "HCN oligomerizes to DAMN on mineral surfaces. Further polymerization and thermal/UV-assisted hydrolysis releases proline among other amino acids through hydantoin intermediates. This is the simplest route requiring only HCN and water.", "reaction_sequence": ["rxn_014", "rxn_015"], "key_intermediates": ["mol_018"]}, {"pathway_id": "P5", "name": "Formamide-to-HCN-to-cyanosulfidic proline", "description": "CO\u2082 and NH\u2083 are hydrothermally converted to formamide. Formamide is photolyzed to HCN on TiO\u2082 surfaces. HCN then enters the cyanosulfidic pathway to produce proline via \u03b3-butyrothiolactam.", "reaction_sequence": ["rxn_016", "rxn_017", "rxn_010", "rxn_011", "rxn_012", "rxn_013"], "key_intermediates": ["mol_008", "mol_006", "mol_016", "mol_017"]}, {"pathway_id": "P6", "name": "Formamide-to-HCN-to-DAMN polymer hydrolysis", "description": "Formamide is produced hydrothermally and photolyzed to HCN on the surface. HCN oligomerizes to DAMN, whose polymers hydrolyze to yield proline directly.", "reaction_sequence": ["rxn_016", "rxn_017", "rxn_014", "rxn_015"], "key_intermediates": ["mol_008", "mol_006", "mol_018"]}, {"pathway_id": "P7", "name": "Proto-TCA cycle on Ni/FeS to \u03b1-ketoglutarate to proline", "description": "Pyruvate produced hydrothermally is converted to \u03b1-ketoglutarate via a non-enzymatic proto-TCA cycle on pyrite and nickel surfaces. Reductive amination yields glutamate, which undergoes the GSA \u2192 P5C \u2192 proline cascade.", "reaction_sequence": ["rxn_001", "rxn_002", "rxn_018", "rxn_005", "rxn_007", "rxn_008", "rxn_009"], "key_intermediates": ["mol_009", "mol_011", "mol_012", "mol_014"]}, {"pathway_id": "P8", "name": "HCN-Bucherer-Bergs convergence on glutamate via proto-TCA \u03b1-ketoglutarate", "description": "Pyruvate from hydrothermal CO\u2082 fixation feeds the proto-TCA cycle to produce \u03b1-ketoglutarate. Meanwhile, HCN derived from formamide photolysis provides the cyanide for Bucherer-Bergs conversion of \u03b1-ketoglutarate to glutamate, completing the route to proline via P5C.", "reaction_sequence": ["rxn_001", "rxn_002", "rxn_018", "rxn_016", "rxn_017", "rxn_006", "rxn_007", "rxn_008", "rxn_009"], "key_intermediates": ["mol_009", "mol_011", "mol_006", "mol_012", "mol_014"]}, {"pathway_id": "P9", "name": "Surface glyoxylate condensation with proto-TCA divergence", "description": "Glyoxylate from hydrothermal pyrite chemistry and pyruvate condense on the surface to form \u03b1-ketoglutarate. Bucherer-Bergs with HCN from DAMN decomposition produces glutamate, which follows the standard GSA \u2192 P5C \u2192 proline pathway.", "reaction_sequence": ["rxn_001", "rxn_002", "rxn_003", "rxn_004", "rxn_006", "rxn_007", "rxn_008", "rxn_009"], "key_intermediates": ["mol_010", "mol_011", "mol_006", "mol_012", "mol_014"]}, {"pathway_id": "P10", "name": "Formamide-HCN-Bucherer-Bergs via surface \u03b1-ketoglutarate", "description": "Formamide from hydrothermal synthesis provides HCN after surface TiO\u2082 photolysis. Simultaneously, pyruvate and glyoxylate from hydrothermal vents condense to \u03b1-ketoglutarate on the surface. HCN and NH\u2083 convert \u03b1-ketoglutarate to glutamate (Bucherer-Bergs). GSA \u2192 P5C \u2192 proline completes the network.", "reaction_sequence": ["rxn_016", "rxn_017", "rxn_001", "rxn_002", "rxn_003", "rxn_004", "rxn_006", "rxn_007", "rxn_008", "rxn_009"], "key_intermediates": ["mol_008", "mol_006", "mol_011", "mol_012", "mol_014"]}], "hub_molecules": ["mol_006", "mol_009", "mol_011", "mol_012", "mol_014"], "convergence_points": [{"molecule_id": "mol_006", "description": "HCN is the central C1-N building block feeding cyanosulfidic, Bucherer-Bergs, and HCN oligomerization pathways", "incoming_reactions": ["rxn_017"], "outgoing_reactions": ["rxn_010", "rxn_012", "rxn_006", "rxn_014"]}, {"molecule_id": "mol_009", "description": "Pyruvate is the central C3 keto-acid hub linking CO\u2082 fixation to proto-TCA and \u03b1-ketoglutarate synthesis", "incoming_reactions": ["rxn_002"], "outgoing_reactions": ["rxn_004", "rxn_018"]}, {"molecule_id": "mol_011", "description": "\u03b1-Ketoglutarate is the central branch-point intermediate at the intersection of carbon metabolism and amino acid synthesis", "incoming_reactions": ["rxn_004", "rxn_018"], "outgoing_reactions": ["rxn_005", "rxn_006"]}, {"molecule_id": "mol_012", "description": "Glutamate is the direct precursor to proline via the GSA \u2192 P5C cyclization cascade, produced by two independent routes", "incoming_reactions"